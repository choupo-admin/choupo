# =============================================================================
#  residualPlot  --  pop up a live convergence-residual window (foamMonitor-style)
#
#  Reads a case's `residuals.dat` (written by the solution-directory writer when
#  controlDict has `solutionControl { write true; }`) and opens a gnuplot window
#  plotting the GLOBAL, feed-normalised MASS and ENERGY residuals against the
#  recycle outer iteration, on a log-y axis, with the convergence-tolerance line.
#  Two labelled curves: Mass and Energy.  `-persist` keeps the window open after
#  the run finishes --- the user closes it themselves.
#
#  Glass-box, honest, never fatal to a run:
#    * gnuplot missing  -> a one-line install hint + an ASCII fallback table.
#    * no $DISPLAY       -> no window; with --png it still renders a PNG file.
#    * residuals.dat absent / single row -> a clear note, exit 0 (nothing to plot).
#
#  Usage:
#      residualPlot <case>          # open an interactive window (x11/qt), persist
#      residualPlot .               # the current directory is the case
#      residualPlot <case> --png    # ALSO write residuals.png (pngcairo), no window
#      residualPlot <case> --ascii  # force the dumb-terminal ASCII plot to stdout
#
#  Wired into bin/runCase: after an interactive solve of a case whose controlDict
#  enables solutionControl, runCase launches this in the BACKGROUND (gated on a
#  real $DISPLAY + gnuplot), so the window pops up at the end of the run.  The
#  test harness (bin/runTests) NEVER calls it.
# =============================================================================

set -euo pipefail

CASE="."
WANT_PNG=
FORCE_ASCII=
while [ "$#" -gt 0 ]; do
    case "$1" in
        --png)   WANT_PNG=1;     shift ;;
        --ascii) FORCE_ASCII=1;  shift ;;
        -h|--help) sed -n '30,53p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
        -*) echo "residualPlot: unknown option '$1'" >&2; exit 1 ;;
        *)  CASE="$1"; shift ;;
    esac
done

CASE_ABS=$(cd "$CASE" 2>/dev/null && pwd) || {
    echo "residualPlot: '$CASE' is not a directory" >&2; exit 1; }

DAT="$CASE_ABS/residuals.dat"
CASE_NAME=$(basename "$CASE_ABS")

# ---- Nothing to plot is NOT an error (a tear-free or non-solutionControl run) -
if [ ! -f "$DAT" ]; then
    echo "residualPlot: no residuals.dat in '$CASE_ABS'."
    echo "             (enable it with  solutionControl { write true; }  in system/controlDict)"
    exit 0
fi
# Count data rows (skip '#'-comment lines).  One row (seed only) => no march yet.
NROWS=$(grep -cvE '^[[:space:]]*#' "$DAT" || true)
if [ "${NROWS:-0}" -lt 2 ]; then
    echo "residualPlot: residuals.dat in '$CASE_NAME' has <2 data rows -- nothing to plot yet."
    exit 0
fi

# The convergence-tolerance line: read it from the last data row's 5th column
# (every row carries the same recycle tolerance); default 1e-5 if unreadable.
TOL=$(grep -vE '^[[:space:]]*#' "$DAT" | awk 'NF>=5{v=$5} END{print (v==""?"1e-5":v)}')

# ---- ASCII fallback (no gnuplot, or --ascii) ---------------------------------
ascii_table()
{
    echo
    echo "Convergence residuals -- $CASE_NAME   (feed-normalised; tol = $TOL)"
    echo "  iter        mass         energy        tear"
    echo "  ----  ------------  ------------  ------------"
    grep -vE '^[[:space:]]*#' "$DAT" | awk '{
        printf "  %4s  %12.4e  %12.4e  %12.4e\n", $1, $2, $3, $4 }'
    echo
}

if [ -n "$FORCE_ASCII" ] || ! command -v gnuplot >/dev/null 2>&1; then
    if ! command -v gnuplot >/dev/null 2>&1; then
        echo "residualPlot: gnuplot not found -- showing an ASCII table instead."
        echo "             install it for the live window, e.g.:  sudo apt-get install gnuplot"
    fi
    # If gnuplot IS present (only --ascii forced it off), draw the dumb-terminal
    # plot; otherwise the numeric table above is the honest fallback.
    if [ -n "$FORCE_ASCII" ] && command -v gnuplot >/dev/null 2>&1; then
        gnuplot <<GP
set terminal dumb size 100,30
set title "Convergence residuals -- $CASE_NAME"
set xlabel "recycle iteration"
set ylabel "residual"
set logscale y
set grid
set key left bottom
plot "$DAT" using 1:(\$2>0?\$2:1/0) with linespoints title "Mass", \
     "$DAT" using 1:(\$3>0?\$3:1/0) with linespoints title "Energy", \
     $TOL with lines title "tol"
GP
    else
        ascii_table
    fi
    exit 0
fi

# ---- The gnuplot script (shared by the window + the PNG) ----------------------
#  log-y, two labelled curves (Mass, Energy), a dashed tolerance line, titled by
#  the case.  A residual of exactly 0 (the seed row, or an isothermal energy
#  residual) is mapped to 1/0 => undefined => skipped, so the log axis is clean.
gp_body()
{
    cat <<GP
set title "Convergence residuals -- $CASE_NAME" font ",13"
set xlabel "recycle outer iteration"
set ylabel "global residual (feed-normalised)"
set logscale y
set format y "10^{%L}"
set grid ytics mytics
set key right top box
set style line 1 lc rgb "#1f77b4" lw 2 pt 7 ps 1.2
set style line 2 lc rgb "#d62728" lw 2 pt 5 ps 1.2
set style line 3 lc rgb "#555555" lw 1 dt 2
plot \\
    "$DAT" using 1:(\$2>0?\$2:1/0) with linespoints ls 1 title "Mass", \\
    "$DAT" using 1:(\$3>0?\$3:1/0) with linespoints ls 2 title "Energy", \\
    $TOL with lines ls 3 title "tolerance"
GP
}

# ---- PNG (proof / headless) ---------------------------------------------------
if [ -n "$WANT_PNG" ]; then
    PNG="$CASE_ABS/residuals.png"
    { echo 'set terminal pngcairo size 900,560 enhanced font "Sans,11"';
      echo "set output '$PNG'";
      gp_body; } | gnuplot
    echo "residualPlot: wrote $PNG"
    exit 0
fi

# ---- The interactive window ---------------------------------------------------
#  No window without a display server: report and (best-effort) drop a PNG so a
#  headless invocation still leaves something to look at, then exit 0.
if [ -z "${DISPLAY:-}" ] && [ -z "${WAYLAND_DISPLAY:-}" ]; then
    echo "residualPlot: no \$DISPLAY -- cannot open a window (headless session)."
    echo "             rendering residuals.png instead; re-run with --ascii for a table."
    exec "$0" "$CASE_ABS" --png
fi

# Prefer x11 (foamMonitor's choice); fall back to qt, then wxt.  `-persist`
# keeps the window alive after gnuplot exits, so it stays open until the user
# closes it.  We exec into gnuplot so this script's PID becomes the window owner.
TERM_KIND=x11
if ! gnuplot -e "set terminal $TERM_KIND" </dev/null >/dev/null 2>&1; then
    if   gnuplot -e "set terminal qt"  </dev/null >/dev/null 2>&1; then TERM_KIND=qt
    elif gnuplot -e "set terminal wxt" </dev/null >/dev/null 2>&1; then TERM_KIND=wxt
    fi
fi

exec gnuplot -persist -e "set terminal $TERM_KIND size 900,560 title 'Choupo residuals -- $CASE_NAME'" \
             <(gp_body)
