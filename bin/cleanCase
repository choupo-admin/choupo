# =============================================================================
#  cleanCase  --  remove generated output from a case directory
#
#  Removes:
#      log.*            (output of runCase / runApplication)
#      *.log            (legacy)
#      processor*       (placeholder for future parallel runs)
#      reports/         (the reports{} output tree: CSV, .ods, sub-folders)
#      trajectory.csv   (choupoBatch / choupoCtrl time series)
#      code/.build/     (per-case compiled binary from buildCode)
#
#  Source files (controlDict, flowsheetDict, thermoPackage, code/*.cpp, ...)
#  are NEVER touched.
# =============================================================================

set -euo pipefail

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    sed -n '3,12p' "$0" | sed 's/^# \{0,1\}//'
    exit 0
fi

TARGET="${1:-.}"
if [ ! -d "$TARGET" ]; then
    echo "cleanCase: '$TARGET' is not a directory" >&2
    exit 1
fi

count=0

# Top-level generated artifacts (logs, reports/ tree, trajectory.csv, ...).
for pat in 'log.*' '*.log' 'processor[0-9]*' 'reports' 'trajectory.csv'; do
    while IFS= read -r -d '' f; do
        rm -rf "$f"
        count=$((count + 1))
    done < <(find "$TARGET" -maxdepth 1 -name "$pat" -print0 2>/dev/null)
done

# Per-case compiled binary (buildCode), but NEVER the source under code/.
if [ -d "$TARGET/code/.build" ]; then
    rm -rf "$TARGET/code/.build"
    count=$((count + 1))
fi

# Transient time-snapshot directories (choupoBatch / choupoCtrl `solutionControl
# { write true; }` fills the case root with OpenFOAM-style `50/ 100/ ... 1000/`
# or `1/ 2/ 3/ ...`).  These are RUN OUTPUTS -- remove them all EXCEPT the
# authored initial state `0/`.  A dir counts as a time only if its whole name is
# numeric (integer or decimal); `system/ constant/ code/ sectors/ ...` are kept.
while IFS= read -r -d '' d; do
    base=$(basename "$d")
    case "$base" in
        0) ;;                          # the authored initial state -- keep
        *[!0-9.]*) ;;                  # has a non-numeric char -- not a time dir
        '') ;;
        *)  rm -rf "$d"; count=$((count + 1)) ;;
    esac
done < <(find "$TARGET" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)

echo "cleanCase: $count item(s) removed from $TARGET"
