#!/usr/bin/env python3
# choupo-import -- SEAL a case: materialise its property-data dependency
# closure INTO the case's own constant/ tree, which MIRRORS data/standards/
# (the OpenFOAM form, ratified 2026-07-17: ONE home, ONE grammar -- a record
# the catalogue stores at data/standards/<sub> lives case-locally at
# constant/<sub>; there is no parallel machine-owned directory).
#
#   choupo-import <caseDir> [--adopt-local <rel>]... [--overwrite <rel>]...
#
# Ownership, provenance and integrity live in `constant/propertyManifest`
# (one per fractal context -- plant root + each sector that declares its own
# property system; each manifest claims ONLY files inside its own constant/).
# Per claimed file the manifest records: relative path, installed sha256,
# origin path, origin sha256, catalogue release, importer version, and the
# claim type (`imported` | `adopted`).  `sealed true;` forbids the runtime
# every catalogue fallback for the closure (see src/thermo/RecordResolver.H).
#
# FAIL-CLOSED TRANSACTION (the Codex rules a.1-a.6, 2026-07-17):
#   1. A destination file that exists but is NOT in the manifest is a FATAL
#      conflict -- the importer never overwrites an authored file.  The ONLY
#      escape is the explicit `--adopt-local <rel>` decision: the authored
#      file becomes the case's record (claim type `adopted`, never installed,
#      never hash-enforced, never removed by the importer).
#   2. A claimed file whose current hash equals the installed hash is the
#      importer's to update or remove.
#   3. A claimed file whose hash DIVERGED was edited locally: refuse before
#      writing anything, presenting the two explicit choices --
#      `--adopt-local <rel>` (withdraw it from importer ownership) or
#      `--overwrite <rel>` (destructive, confirmed re-install).  No automatic
#      merge of .dat files, ever.
#   4. A claimed file whose record left the closure is removed ONLY if its
#      hash is intact; otherwise it is a conflict, never silent cleanup.
#   5. The whole operation is transactional: closure + hashes are computed
#      first, all conflicts checked, the ENTIRE new case is staged in a temp
#      area and VALIDATED (the staged case must run with the standards
#      catalogue hidden) BEFORE anything is installed; the manifest is
#      replaced LAST.
#   6. Absolute paths, `..`, symlink escapes and duplicate claims are
#      rejected.  In fractal plants each constant/ owns its own manifest and
#      claims only within its own context.
#
# Curation-time tool (like bin/curate/*.py); the engine never estimates or
# imports at runtime.

import re
import shutil
import subprocess
import sys
import tempfile
from hashlib import sha256 as _sha256
from datetime import date
from pathlib import Path

IMPORTER_VERSION = "2"

# A sealed record must never point the builder back at the installation
# catalogue.  Method records ship active `path "data/standards/...";` search
# declarations; the builder resolves pairs/salts by logical ID, NOT by these
# paths, so each such active declaration is dropped on copy.  Comments and
# `origin "data/standards/..."` provenance strings are left untouched.
_ACTIVE_STD_PATH = re.compile(r'^\s*path\s+"data/standards/[^"]*"\s*;\s*$')


def strip_install_paths(body):
    return "".join(
        line for line in body.splitlines(keepends=True)
        if not _ACTIVE_STD_PATH.match(line)
    )


def sha(text):
    return _sha256(text.encode() if isinstance(text, str) else text).hexdigest()


def sha_file(p):
    return _sha256(Path(p).read_bytes()).hexdigest()


def die(msg):
    sys.stderr.write("choupo-import: " + msg + "\n")
    sys.exit(1)


def read(p):
    pp = Path(p)
    return pp.read_text() if (str(p) and pp.is_file()) else None


def words(block):
    return re.findall(r'[A-Za-z0-9_+\-]+', block)


def find_root():
    here = Path(__file__).resolve()
    for p in [here] + list(here.parents):
        if (p / "data" / "standards" / "components").is_dir():
            return p
    die("cannot locate the Choupo data/standards catalogue")


def read_release(root):
    f = root / "data" / "standards" / "CATALOGUE.dat"
    if f.is_file():
        txt = "\n".join(l for l in f.read_text().splitlines()
                        if not l.lstrip().startswith("//"))
        m = re.search(r'\brelease\s+([A-Za-z][A-Za-z0-9_.-]*)\s*;', txt)
        if m:
            return m.group(1)
    return "Choupo-unknown"


def block(text, key):
    # extract the {...} or (...) body following `key`
    m = re.search(key + r'\s*([\{\(])', text)
    if not m:
        return None
    op = m.group(1)
    cl = '}' if op == '{' else ')'
    i = m.end() - 1
    depth = 0
    for j in range(i, len(text)):
        if text[j] == op:
            depth += 1
        elif text[j] == cl:
            depth -= 1
            if depth == 0:
                return text[i + 1:j]
    return None


# ---------------------------------------------------------------------------
# The aqueous model-species catalogue: ONE file (standards grammar), sealed
# as ONE file -- constant/species/aqueous.dat, FILTERED to the case's
# transitive closure (the Codex c) decision: never a per-file forest, never a
# second grammar).  Records are copied VERBATIM (their citations ride along).
# ---------------------------------------------------------------------------
def parse_species_files(std):
    """-> {name: (charge,)} from the flat species/<name>.dat home (the
    2026-07-18 dismantling -- one typed file per model species)."""
    out = {}
    d = std / "species"
    if not d.is_dir():
        return out
    for f in sorted(d.glob("*.dat")):
        if f.name == "aqueous.dat":
            continue
        txt = re.sub(r'/\*.*?\*/', '', f.read_text(), flags=re.S)
        txt = re.sub(r'(^|\s)//.*$', '', txt, flags=re.M)
        nm = re.search(r'\bname\s+([A-Za-z0-9_+\-]+)\s*;', txt)
        zm = re.search(r'\bcharge\s+([+\-]?\d+)\s*;', txt)
        if nm:
            out[nm.group(1)] = (int(zm.group(1)) if zm else 0,)
    return out


SPECIATION_KINDS = ("aqueousSpeciation", "gasLiquidEquilibrium",
                    "ionExchangeEquilibrium")

# propsDict op types that drive the multi-ion aqueous speciation engine (the
# SpeciationSolver): they scan the whole chemistry/ network, the whole aqueous
# species catalogue and every mineral-bearing component -- so the seal pulls the
# whole electrolyte databank (species + chemistry + minerals + Pitzer pairs +
# mixing), existence-guarded.  The single-salt activity ops (pitzerActivity /
# electrolyteActivity / enrtlMultiSalt / enrtlMixedSolvent) are NOT here -- they
# name their ions explicitly and pull only those ions' pairs.
SPECIATION_OP_TYPES = {"speciate", "scalingScan", "exchange"}


# ---------------------------------------------------------------------------
# Partial-overlay MERGE (the sealed form of a non-overlayOf `.dat` overlay).
#
# A case-local constant/components/<name>.dat that is a PARTIAL by-name overlay
# (a delta: e.g. `name` + `role solute;` -- the ammonia loop's role switch --,
# or a lone sorption{} block) relies at RUNTIME on Database::loadComponent
# merging it top-level field-by-field OVER the standards base.  A SEALED case
# reads exactly ONE constant/components/<name>.dat with the catalogue hidden, so
# the seal must carry that merge PRE-MATERIALISED: the standards base with the
# overlay's top-level entries applied.  This mirrors the engine's own overlay
# semantic (top-level replacement -- NOT the `overlayOf` deep-merge, whose demo
# cases stay live against the base by design).  The overlay's own header comment
# ("o sumo" -- WHY the delta) is preserved atop the merged record.
# ---------------------------------------------------------------------------
def _strip_dat_comments(s):
    s = re.sub(r'/\*.*?\*/', '', s, flags=re.S)
    s = re.sub(r'//[^\n]*', '', s)
    return s

def _toplevel_entries(text):
    """[(key, entryText)] at brace-depth 0: `key ... ;` or `key { ... }`."""
    t = _strip_dat_comments(text)
    entries, i, n = [], 0, len(t)
    while i < n:
        while i < n and t[i].isspace():
            i += 1
        if i >= n:
            break
        j = i
        while j < n and (not t[j].isspace()) and t[j] not in '{;':
            j += 1
        key = t[i:j]
        k = j
        while k < n and t[k].isspace():
            k += 1
        if k < n and t[k] == '{':
            depth, m = 0, k
            while m < n:
                if t[m] == '{':
                    depth += 1
                elif t[m] == '}':
                    depth -= 1
                    if depth == 0:
                        m += 1
                        break
                m += 1
            entries.append((key, t[i:m].strip()))
            i = m
        else:
            depth, m = 0, k
            while m < n:
                c = t[m]
                if c in '([':
                    depth += 1
                elif c in ')]':
                    depth -= 1
                elif c == ';' and depth == 0:
                    m += 1
                    break
                m += 1
            entries.append((key, t[i:m].strip()))
            i = m
    return [(k, e) for (k, e) in entries if k]

def _leading_comment(text):
    m = re.match(r'\s*(/\*.*?\*/)', text, flags=re.S)
    return m.group(1) if m else ""

def merge_overlay_text(base_text, overlay_text, rel, release):
    """Standards base with the overlay's top-level entries applied; the
    overlay's header comment kept.  Raises if the overlay declares overlayOf
    (a deep-merge demo, not a flat delta -- never pre-materialise those)."""
    if re.search(r'\boverlayOf\b', overlay_text):
        die("[--merge-overlay %s] declares `overlayOf` -- that is a deep-merge"
            " demo meant to stay live against the standards base; do NOT seal it"
            " by pre-merging." % rel)
    base_entries = _toplevel_entries(base_text)
    over_entries = _toplevel_entries(overlay_text)
    over_map = dict(over_entries)
    base_keys = {k for k, _ in base_entries}
    used = set()
    body = []
    for k, entry in base_entries:
        if k in over_map:
            body.append(over_map[k])
            used.add(k)
        else:
            body.append(entry)
    for k, entry in over_entries:            # overlay-only additions, in order
        if k not in base_keys and k not in used:
            body.append(entry)
            used.add(k)
    hdr = [
        "/*----------------------------------------------------------*\\",
        "  constant/%s -- MERGED sealed record: the standards base with" % rel,
        "  this case's partial overlay applied top-level (%s release)." % release,
        "  Materialised by bin/choupo-import so the sealed case reads ONE",
        "  complete record with the catalogue hidden; provenance (base +",
        "  overlay hashes) is recorded in constant/propertyManifest.",
        "\\*----------------------------------------------------------*/",
    ]
    lead = _leading_comment(overlay_text)
    parts = ["\n".join(hdr)]
    if lead:
        parts.append(lead)
    parts.append("\n\n".join(body))
    return "\n\n".join(parts) + "\n"


# ---------------------------------------------------------------------------
# Closure of ONE property system (a package dict) -- mirrors what the RUNTIME
# resolves (ThermoPackageBuilder::translateV2 + the branch builders + the
# SpeciationSolver scans).  Returns ({rel: standardsPath}, ionNames:set,
# wantAllSpecies:bool).
# ---------------------------------------------------------------------------
def closure_of(pp_path, caseDir, std, AQ):
    recs = {}
    ions = set()
    wantAllSpecies = False
    solute_comps = set()
    nonlocal_flags = {"speciates": False}
    ion_candidates = set()          # flowsheet components whose NAME is a species

    def want(rel):
        src = std / rel
        if src.exists():
            # Seal the STANDARD record even when the case also carries a
            # hand-authored file of the same name -- that collision is the
            # conflict machinery's job (rule 1), never a silent skip.
            recs[rel] = src

    def reachable_speciation_closure(seed_ions, has_exchange):
        # (Codex seal-audit 2026-07-18) the closure is the REACHABLE physical
        # subgraph, never the whole databank: fixed-point over the chemistry
        # network -- a reaction activates when every master it needs is
        # already reachable, and its species then extends the frontier.  The
        # runtime scans DIRECTORIES, so a sealed case whose chemistry/ carries
        # exactly the reachable records resolves the identical network (the
        # solver's own masters-present filter would have skipped the rest
        # after opening them).  Returns the reachable name set.
        chem = std / "chemistry"
        entries = []                  # (fname, kind, product, masters, sites)
        if chem.is_dir():
            for f in sorted(chem.glob("*.dat")):
                txt = f.read_text()
                m = re.search(r'\brecordType\s+([A-Za-z]+)\s*;', txt)
                if not m or m.group(1) not in SPECIATION_KINDS:
                    continue
                kind = m.group(1)
                if kind == "gasLiquidEquilibrium":
                    g = re.search(r'\bgas\s+([A-Za-z0-9_]+)\s*;', txt)
                    d = re.search(r'\bdissolved\s+"?([A-Za-z0-9_]+)"?\s*;', txt)
                    entries.append((f.name, kind,
                                    d.group(1) if d else None,
                                    {g.group(1)} if g else set(), set()))
                    continue
                sp = re.search(r'\bspecies\s+([A-Za-z0-9_]+)\s*;', txt)
                masters = set(re.findall(r'\{\s*ion\s+([A-Za-z0-9_]+)\s*;', txt))
                sites = set(re.findall(r'\{\s*site\s+([A-Za-z0-9_]+)\s*;', txt))
                entries.append((f.name, kind, sp.group(1) if sp else None,
                                masters, sites))
        reach = set(seed_ions) | {"H", "OH"}   # the solver always carries both
        activated = {}                          # fname -> kind
        changed = True
        while changed:
            changed = False
            for fname, kind, product, masters, sites in entries:
                if fname in activated:
                    continue
                if kind == "gasLiquidEquilibrium":
                    ok = bool(masters & reach)          # the GAS name seeded
                elif kind == "ionExchangeEquilibrium":
                    ok = has_exchange and masters <= reach
                else:
                    ok = masters <= reach and (not sites or has_exchange)
                if ok:
                    activated[fname] = kind
                    if product:
                        if product not in reach:
                            reach.add(product); changed = True
        for fname in sorted(activated):
            want("chemistry/" + fname)
        return reach

    def want_reachable_minerals(reach):
        # SI sweep: only the minerals whose DISSOLUTION masters are all
        # reachable can ever report -- the rest self-filtered to nothing
        # after being opened; now they are simply not sealed.
        comps = std / "components"
        if not comps.is_dir():
            return
        for f in sorted(comps.glob("*.dat")):
            txt = f.read_text()
            if "solidPhases" not in txt:
                continue
            need = set(re.findall(r'\{\s*ion\s+([A-Za-z0-9_]+)\s*;', txt))
            if need and need <= reach:
                want("components/" + f.name)

    def harvest_v2(text):
        # (1) every declared parameter record: `source "data/standards/<rel>";`
        for m in re.finditer(r'source\s+"[^"]*?data/standards/([^"]+)"', text):
            want(m.group(1))
        eq = block(text, "equilibrium") or ""
        fm = re.search(r'\bformulation\s+([A-Za-z]+)\s*;', eq)
        form = fm.group(1) if fm else ""
        # (2) the methods/<model>.dat ceremony record was retired 2026-07-18
        #     (Codex "não inventar gramática"): the selection is the propDict
        #     formulation, the equations are C++, the parameters are the pair
        #     .dat -- there is no separate method file to seal.
        # (3) chemistry.salts rides inline on v2 (transitional block):
        #     anchor / solid records, absence-tolerant (the UNIFIED component
        #     solidPhases{} carries them since Migration 5)
        ch = block(text, "chemistry")
        if ch:
            sb = block(ch, "salts")
            for salt in (words(sb) if sb else []):
                want("chemistry/salts/" + salt + ".dat")
                want("phases/solid/" + salt + ".dat")
        # (4) T8: the aqueous-speciation surface -- mark it; the REACHABLE
        #     closure is computed once, with the propsDict seeds (below).
        if block(text, "aqueousProperties") is not None:
            nonlocal_flags["speciates"] = True

    def harvest_v1(text):
        # Method / chemistry / parameter records declared by a v1 block --
        # shared by a propertyPackage AND a per-unit thermo{} override.
        # (methods/<model>.dat retired 2026-07-18 -- no method record to seal)
        ch = block(text, "chemistry")
        if ch:
            sb = block(ch, "salts")
            for salt in (words(sb) if sb else []):
                want("chemistry/salts/" + salt + ".dat")
                want("phases/solid/" + salt + ".dat")
        par = block(text, "parameters")
        if par:
            for m in re.finditer(r'"([^"]*data/standards/([^"]+))"', par):
                want(m.group(2))
            pp_blk = block(par, "pitzerPairs")
            for pair in (words(pp_blk) if pp_blk else []):
                want("parameters/Pitzer/pairs/" + pair + ".dat")

    def walk_up_local(rel):
        p = Path(caseDir).resolve()
        for _ in range(8):
            if (p / "constant" / rel).exists():
                return p / "constant" / rel
            if p.parent == p:
                break
            p = p.parent
        return None

    def mixture_members(token):
        # A predefined mixture (data/standards/mixtures/<token>.dat) is an
        # EXPANSION TABLE, not a component: the loader splices `air` into
        # N2/O2/Ar at assembly (ThermoPackage::expandMixtures).  A sealed case
        # reads the mixture through its MIRRORED constant/mixtures/<token>.dat,
        # so the seal must carry the mixture file AND each member component.
        mf = std / "mixtures" / (token + ".dat")
        if not mf.is_file():
            return None
        mtxt = mf.read_text()
        return re.findall(r'\bcomponent\s+([A-Za-z0-9_+\-]+)\s*;',
                          block(mtxt, "members") or "")

    t = read(pp_path) or ""
    comp_blk = block(t, "components")
    comps = words(comp_blk) if comp_blk else []
    for c in comps:
        members = mixture_members(c)
        if members is not None:
            want("mixtures/" + c + ".dat")
            for mc in members:
                want("components/" + mc + ".dat")
            continue
        want("components/" + c + ".dat")
        csrc = std / "components" / (c + ".dat")
        loc = walk_up_local("components/" + c + ".dat")
        # component-basis ion map: UNIFIED component.speciesMap or the legacy
        # top-level dissociatesTo (speciesMapOf, builder-identical).  Read it
        # from BOTH the standards record AND the case-local overlay and UNION
        # the ions -- a case may ADD the decomposition its standards base lacks
        # (the DSPM-DE salts carry dissociatesTo the standards MgSO4 omits), and
        # the runtime sees the merged record, so the closure must too.
        for ctext in (read(csrc) or "", (read(loc) or "") if loc else ""):
            d2t = block(ctext, "speciesMap") or block(ctext, "dissociatesTo")
            if d2t:
                # P0 (Codex audit): a salt's ion map only mobilises species
                # records when the case runs aqueous/ionic physics -- a lumped
                # NaCl evaporator never opens species/Na.dat.  Candidates,
                # decided with the context below.
                ion_candidates.update(w for w in words(d2t)
                                      if not w.isdigit())
            # a `role solute;` component dissolves by Henry's law -- its
            # (solute, solvent) pair record must ride the closure (below).
            if re.search(r'\brole\s+solute\s*;', ctext):
                solute_comps.add(c)
        # flowsheet-ION basis CANDIDATE (P0 fix, Codex audit 2026-07-18):
        # a name being in the species home does NOT make a component an ion --
        # N2/O2/CH4/H2 and the Cl radical prove a name is not a type.  The
        # decision is made AFTER the aqueous-context scan below: the candidate
        # promotes only when the case actually runs aqueous chemistry, or when
        # the name does not resolve as a process component at all.
        if c in AQ:
            ion_candidates.add(c)
    # ---- Henry's-law dilute-solution pairs -----------------------------------
    # parameters/Henry/<solute>-<solvent>.dat: the HenrysLawRegistry scans the
    # Henry home (case-local constant/parameters/Henry/ first).  A package that
    # declares `solvent <name>;` dissolves each `role solute;` component (and any
    # assembly-level `solutes ( ... );`) into it by Henry's law -- so the sealed
    # case must carry each such (solute, solvent) pair record (existence-guarded,
    # so only real pairs seal).  Mirrors the Pitzer/eNRTL pair tracing below.
    t_nc = re.sub(r'/\*.*?\*/', '', t, flags=re.S)
    t_nc = re.sub(r'(^|\s)//.*$', '', t_nc, flags=re.M)
    ms = re.search(r'\bsolvent\s+([A-Za-z0-9_+\-]+)\s*;', t_nc)
    if ms:
        solvent = ms.group(1)
        henry_solutes = set(solute_comps)
        sblk = block(t_nc, "solutes")
        if sblk:
            henry_solutes.update(words(sblk))
        for sol in sorted(henry_solutes):
            want("parameters/Henry/" + sol + "-" + solvent + ".dat")

    # ---- molecular NRTL pairs under an ELECTROLYTE world ---------------------
    # The eNRTL mixed-solvent (and any electrolyte world with 2+ molecular
    # solvents) resolves the molecular solvent-solvent NRTL pair IMPLICITLY
    # from the catalogue (no declared path -- Crystallizer09's water-ethanol
    # drowning-out).  Sealed, an absent pair silently defaults to IDEAL and the
    # physics moves -- so trace parameters/NRTL/<a>-<b>.dat for every component
    # pair, existence-guarded (only real catalogue pairs ride the closure).
    if re.search(r'\belectrolyte\.[A-Za-z]+\s*;', t_nc) \
       or re.search(r'\bformulation\s+electrolyteGammaPhi\s*;', t_nc):
        for i in range(len(comps)):
            for j in range(i + 1, len(comps)):
                a, b = sorted((comps[i], comps[j]))
                want("parameters/NRTL/" + a + "-" + b + ".dat")

    # ---- UNIFAC group-contribution tables ------------------------------------
    # UNIFAC's R_k/Q_k (groups.dat) + a_mn (interactions.dat) are SINGLETON
    # tables, not per-pair records: the model reads them through the case-local
    # resolver (UNIFAC.cpp), so any package selecting UNIFAC -- v2 `activityModel
    # { model UNIFAC; }` or v1 `activity.UNIFAC` -- must carry BOTH in its closure.
    unifac_texts = [t_nc]
    # per-op thermo{} overrides in the propsDict select models the PACKAGE
    # never names (compare_vle's txy_unifac) -- their closure needs rides too.
    props_dict = Path(caseDir) / "system" / "propsDict"
    if props_dict.exists():
        pt = props_dict.read_text()
        pt = re.sub(r'/\*.*?\*/', '', pt, flags=re.S)
        pt = re.sub(r'(^|\s)//.*$', '', pt, flags=re.M)
        unifac_texts.append(pt)
    if any(re.search(r'\bmodel\s+UNIFAC\s*;', x)
           or re.search(r'\bactivity\.UNIFAC\b', x) for x in unifac_texts):
        want("parameters/UNIFAC/groups.dat")
        want("parameters/UNIFAC/interactions.dat")

    if re.search(r'\brecordType\s+thermophysicalPropertySystem\s*;', t):
        harvest_v2(t_nc)      # comment-stripped: a header PROSE mentioning
                              # "equilibrium" must never satisfy block()
    else:
        harvest_v1(t_nc)      # same comment-stripping guard as harvest_v2

    # ---- operations in the case's system/propsDict --------------------------
    # The property PACKAGE (pp_path) lists the flowsheet components; the propsDict
    # OPERATIONS may name ions / salts / minerals it does not: the single-salt
    # activity ops (pitzerActivity / electrolyteActivity + the eNRTL multi-salt
    # ops) name their ions via `cation`/`anion`; the multi-ion speciation ops
    # (speciate / scalingScan / exchange) reason over the WHOLE aqueous network
    # + minerals.  The runtime resolves all of these, so the seal must carry them.
    props = read(Path(caseDir) / "system" / "propsDict") or ""
    props = re.sub(r'/\*.*?\*/', '', props, flags=re.S)
    props = re.sub(r'(^|\s)//.*$', '', props, flags=re.M)
    props_ops = block(props, "operations") or props
    for m in re.finditer(r'\b(?:cation|anion)\s+([A-Za-z0-9_+\-]+)\s*;', props_ops):
        ions.add(m.group(1))
    op_types = set(re.findall(r'\btype\s+([A-Za-z]+)\s*;', props_ops))
    speciates = bool(op_types & SPECIATION_OP_TYPES)

    # A flowsheet unit may speciate INTERNALLY: the membrane / electrodialysis
    # scaling audit (`scaling {}` block) runs the SpeciationSolver on the module
    # bulk to record calcite / gypsum saturation indices.  Detect it so the seal
    # carries the same aqueous network + minerals the unit resolves at runtime.
    for fsd in Path(caseDir).rglob("system/flowsheetDict"):
        ft = read(fsd) or ""
        ft = re.sub(r'/\*.*?\*/', '', ft, flags=re.S)
        ft = re.sub(r'(^|\s)//.*$', '', ft, flags=re.M)
        if re.search(r'\bscaling\s*\{', ft):
            speciates = True
        # an ionExchanger unit runs the exchange network on the module bulk
        if re.search(r'\bionExchanger\b|\bresin\s+[A-Za-z0-9_]+\s*;', ft):
            speciates = True
            nonlocal_flags["exchange"] = True
        # an electrodialysis stack / ion-selective membrane runs on the
        # flowsheet-ION basis -- its component names ARE solver species
        if re.search(r'\belectrodialysisStack\b|\bdonnan\b', ft):
            nonlocal_flags["ionBasis"] = True
        # a DSPM-DE / charged-pore membrane resolves ion radius+charge from
        # the species records -- ionic context even without scaling{}
        if re.search(r'dspmde|DSPM', ft):
            nonlocal_flags["ionBasis"] = True

    # ---- promote the flowsheet-ION candidates (P0, fail-closed) ------------
    uses_electrolyte_world_early = bool(
        re.search(r'\belectrolyte\.[A-Za-z]+', t_nc)
        or re.search(r'\bformulation\s+electrolyteGammaPhi\s*;', t_nc)
        or re.search(r'\b(?:pitzerActivity|electrolyteActivity|enrtlMultiSalt|'
                     r'enrtlMixedSolvent)\b', props_ops))
    aqueous_context = (speciates or nonlocal_flags["speciates"]
                       or nonlocal_flags.get("exchange", False)
                       or nonlocal_flags.get("ionBasis", False)
                       or uses_electrolyte_world_early)
    for c in sorted(ion_candidates):
        if aqueous_context:
            ions.add(c)
        # else: a gas-side process component that merely SHARES a species
        # name (N2 in a Brayton) -- no aqueous chemistry, no species seal.

    if speciates or nonlocal_flags["speciates"]:
        # ---- SEEDS (Codex seal-audit): what the case actually introduces ----
        seeds = set(ions)                          # flowsheet/single-salt ions
        has_exchange = "exchange" in op_types \
                       or nonlocal_flags.get("exchange", False)
        # composition { NaCl 2.0 mol/kg; } -> the component's ion map
        for bname in ("composition", "totals", "analyticalTotals"):
            for bm in re.finditer(r'\b%s\s*\{' % bname, props_ops):
                body = block(props_ops[bm.start():], bname) or ""
                # every `<name> <number>` entry -- multi-entry lines included
                for key in re.findall(r'\b([A-Za-z][A-Za-z0-9_+\-]*)\s+'
                                      r'[-+]?[0-9.]', body):
                    if key in AQ:
                        seeds.add(key)
                    else:
                        csrc = std / "components" / (key + ".dat")
                        loc = walk_up_local("components/" + key + ".dat")
                        for ct in (read(csrc) or "",
                                   (read(loc) or "") if loc else ""):
                            d2 = block(ct, "speciesMap") \
                                 or block(ct, "dissociatesTo")
                            if d2:
                                seeds.update(w for w in words(d2)
                                             if not w.isdigit())
        # atmosphere { pCO2 ...; O2 ...; } -> gas names (pX -> X)
        for am in re.finditer(r'\batmosphere\s*\{', props_ops):
            body = block(props_ops[am.start():], "atmosphere") or ""
            for key in re.findall(r'\bp?([A-Za-z][A-Za-z0-9_]*)\s+'
                                  r'[-+]?[0-9.]', body):
                seeds.add(key)
        # diagSpecies ( ... ) may name computed species directly
        for dm in re.finditer(r'\bdiagSpecies\s*\(', props_ops):
            body = block(props_ops[dm.start():], "diagSpecies") or ""
            seeds.update(words(body))
        # exchange resin: the site + the resin's form ion enter the network
        for xm in re.finditer(r'\bresin\s+([A-Za-z0-9_]+)\s*;', props_ops):
            has_exchange = True
        if has_exchange:
            seeds.add("X")                       # the exchange site
        # a flowsheet scaling{} audit runs on the module bulk: the package's
        # ion basis is the seed set (already in `ions` via speciesMap union)
        reach = reachable_speciation_closure(seeds, has_exchange)
        ions |= {r for r in reach if r in AQ}   # species catalogue = reachable
        want_reachable_minerals(reach)
        nonlocal_flags["reach"] = reach

    # cation-anion pair records by CHARGE, ONLY for the model that CONSUMES
    # them (Codex invariant 3: no spectator record).  A Davies case pulls NO
    # interaction pairs (Davies is parameter-free: charge + ionic strength);
    # a single-salt/flowsheet electrolyte world pulls its own family only.
    uses_pitzer = bool(re.search(r'\belectrolyte\.pitzer\b', t_nc)
                       or re.search(r'\bmodel\s+Pitzer\s*;', t_nc)
                       or re.search(r'\bpitzerActivity\b', props_ops))
    uses_enrtl  = bool(re.search(r'\belectrolyte\.eNRTL\b', t_nc)
                       or re.search(r'\bmodel\s+eNRTL\s*;', t_nc)
                       or re.search(r'\b(?:enrtlMultiSalt|enrtlMixedSolvent)\b',
                                    props_ops))
    if uses_pitzer or uses_enrtl:
        cats = sorted({i for i in ions if AQ.get(i, (0,))[0] > 0})
        ans = sorted({i for i in ions if AQ.get(i, (0,))[0] < 0})
        for ca in cats:
            for an in ans:
                if uses_pitzer:
                    want("parameters/Pitzer/pairs/" + ca + "-" + an + ".dat")
                if uses_enrtl:
                    want("parameters/eNRTL/" + ca + "-" + an + ".dat")

    # A full-speciation closure (speciate / scalingScan / exchange) reasons over
    # the WHOLE aqueous catalogue -- any ion the network derives (OH, CO3, the
    # CaSO4aq / CO2aq neutral pairs) may enter the multi-ion Pitzer-HMW sums.
    # Pull the COMPLETE Pitzer + eNRTL databank -- the WHOLE mixing home, exactly
    # like want_speciation_closure pulls the whole chemistry/ home and all
    # species.  Globbing the dirs (not enumerating over the ion set) is robust:
    # the neutrals in the mixing files (CO2aq, CaSO4aq) are NOT in the
    # aqueousSpecies list -- they are chemistry-network species -- so an ion-set
    # enumeration would silently drop their lambda / zeta terms.  The runtime
    # resolves each term through the sealed tier; an unused term self-filters.
    # Pitzer interaction records: ONLY the selected model's family and ONLY
    # records whose EVERY participant is reachable (theta/psi/lambda/zeta by
    # filename tokens -- the neutral participants CO2aq/CaSO4aq are network
    # species, present in `reach` when their reactions activated).  Davies
    # seals NO interaction family at all (Codex seal-audit).
    reach = nonlocal_flags.get("reach", set())
    models_txt = props_ops + " " + t_nc
    uses_hmw = bool(re.search(r'\bpitzerHMW\b', models_txt)) \
               or bool(re.search(r'\bPitzerHMW\b', models_txt))
    # verifyGlobal (the DEDICATED validation case): its declared job is the
    # FULL-catalogue single-salt sweep, so its seal deliberately carries the
    # whole Pitzer family -- the one case where "all pairs" is the physics.
    verify_global = bool(re.search(r'\bverifyGlobal\s+true\s*;', props_ops))
    if reach and uses_hmw:
        for sub in ("pairs", "theta", "psi", "lambda", "zeta"):
            dpath = std / "parameters" / "Pitzer" / sub
            if not dpath.is_dir():
                continue
            for f in sorted(dpath.glob("*.dat")):
                toks = set(re.findall(r'[A-Za-z0-9]+', f.stem))
                if verify_global or toks <= reach:
                    want("parameters/Pitzer/" + sub + "/" + f.name)
        if verify_global:
            # the sweep resolves every pair's ion charges from the species
            # catalogue -- the dedicated case seals it whole
            ions.update(AQ.keys())

    # the ion Cp(T) tier (Criss-Cobble nodes): consumed by the ENTHALPY route
    # of an electrolyte WORLD (buildElectrolyte ion Cp), never by the
    # speciation ops -- seal it only when a flowsheet/single-salt electrolyte
    # world named its ions (Codex seal-audit: no consumer, no record).
    # (Criss-Cobble migration 2026-07-18, Vitor's arity-1 call) the CC nodes
    # live in EACH ion's own aqueous-species record now -- the filtered
    # species catalogue carries them; there is no separate record to seal.
    return recs, ions, wantAllSpecies


def parse_packages(caseDir):
    pkgs = []
    for name in ("thermoPhysPropDict", "propertyDict", "propertyPackage"):
        for pp in Path(caseDir).rglob("constant/" + name):
            pkgs.append(pp)
    return pkgs


# ---------------------------------------------------------------------------
# Manifest read / write
# ---------------------------------------------------------------------------
def read_manifest(constant):
    """-> {rel: {'type':..., 'sha256':..., ...}} from constant/propertyManifest
    (empty when the case has none)."""
    f = Path(constant) / "propertyManifest"
    out = {}
    if not f.is_file():
        return out
    txt = re.sub(r'/\*.*?\*/', '', f.read_text(), flags=re.S)
    txt = re.sub(r'^\s*//.*$', '', txt, flags=re.M)
    recs = block(txt, r'\brecords\b')
    if not recs:
        return out
    for m in re.finditer(r'"([^"]+)"\s*\{([^}]*)\}', recs):
        rel, body = m.group(1), m.group(2)
        entry = {}
        for km in re.finditer(r'\b(\w+)\s+("([^"]*)"|[^;\s]+)\s*;', body):
            entry[km.group(1)] = km.group(3) if km.group(3) is not None \
                else km.group(2)
        out[rel] = entry
    return out


def manifest_text(entries, release, ctx_label):
    """entries: {rel: entry-dict} -> the constant/propertyManifest text."""
    L = []
    L.append("/*----------------------------------------------------------*\\")
    L.append("  constant/propertyManifest -- property-record OWNERSHIP registry")
    L.append("  (%s).  Written by bin/choupo-import from the %s catalogue"
             % (ctx_label, release))
    L.append("  release; the manifest is the authority on which files under")
    L.append("  constant/ the importer owns.  A file it does NOT claim is")
    L.append("  authored and untouchable; a claimed file it verifies by sha256.")
    L.append("  `sealed true;` FORBIDS the runtime every catalogue fallback --")
    L.append("  the case runs exclusively from its own constant/ records.")
    L.append("  claim types:  imported = installed + hash-verified copy;")
    L.append("                adopted  = authored record explicitly adopted at")
    L.append("                           import time (never installed, never")
    L.append("                           hash-enforced, never removed);")
    L.append("                merged   = standards base with a partial by-name")
    L.append("                           overlay applied top-level, materialised")
    L.append("                           at import time (base + overlay hashes")
    L.append("                           both recorded; durable like adopted).")
    L.append("\\*----------------------------------------------------------*/")
    L.append("")
    L.append("propertyManifest")
    L.append("{")
    L.append("    sealed             true;")
    L.append("    catalogueRelease   %s;" % release)
    L.append('    importedAt         "%s";' % date.today().isoformat())
    L.append('    importerVersion    "%s";' % IMPORTER_VERSION)
    L.append("    records")
    L.append("    {")
    for rel in sorted(entries):
        e = entries[rel]
        if e.get("type") == "adopted":
            L.append('        "%s"' % rel)
            L.append("        {")
            L.append("            type          adopted;")
            if "adoptedAt" in e:
                L.append('            adoptedAt     "%s";' % e["adoptedAt"])
            L.append("        }")
        elif e.get("type") == "merged":
            L.append('        "%s"' % rel)
            L.append("        {")
            L.append("            type          merged;")
            L.append('            sha256        "%s";' % e["sha256"])
            L.append('            origin        "%s";' % e["origin"])
            L.append('            originSha256  "%s";' % e["originSha256"])
            L.append('            overlaySha256 "%s";' % e["overlaySha256"])
            L.append("            release       %s;" % e.get("release", release))
            L.append("        }")
        else:
            L.append('        "%s"' % rel)
            L.append("        {")
            L.append("            type          imported;")
            L.append('            sha256        "%s";' % e["sha256"])
            L.append('            origin        "%s";' % e["origin"])
            L.append('            originSha256  "%s";' % e["originSha256"])
            L.append("            release       %s;" % e.get("release", release))
            L.append("        }")
    L.append("    }")
    L.append("}")
    return "\n".join(L) + "\n"


# ---------------------------------------------------------------------------
# Path safety (rule 6)
# ---------------------------------------------------------------------------
def check_rel_safe(rel):
    p = Path(rel)
    if p.is_absolute():
        die("unsafe claim (absolute path): " + rel)
    if any(part in ("..", "") for part in p.parts):
        die("unsafe claim (parent traversal): " + rel)


def check_no_symlink_escape(constant, rel):
    # No component of the destination path may traverse a symlink that leaves
    # the context's constant/ tree.
    base = Path(constant).resolve()
    cur = Path(constant)
    for part in Path(rel).parts:
        cur = cur / part
        if cur.is_symlink():
            if not str(cur.resolve()).startswith(str(base) + "/"):
                die("unsafe claim (symlink escapes constant/): " + rel)


# ---------------------------------------------------------------------------
# Validation (rule 5): the staged case must RUN with the catalogue hidden.
# ---------------------------------------------------------------------------
def app_binary(root, caseDir):
    ctl = read(Path(caseDir) / "system" / "controlDict") or ""
    ctl = re.sub(r'/\*.*?\*/', '', ctl, flags=re.S)
    ctl = re.sub(r'^\s*//.*$', '', ctl, flags=re.M)
    m = re.search(r'\bapplication\s+(\w+)\s*;', ctl)
    app = m.group(1) if m else "choupoSolve"
    for build in sorted((root / "build").glob("*")):
        cand = build / app
        if cand.is_file() and not build.name.endswith("Debug"):
            return cand
    for build in sorted((root / "build").glob("*")):
        cand = build / app
        if cand.is_file():
            return cand
    die("cannot find the %s binary under %s/build -- run `make` first"
        % (app, root))


def validate_staged(root, staged):
    """Run the staged case with the standards catalogue HIDDEN (no
    CHOUPO_HOME, cwd outside the repo) -- the sealed contract's own test."""
    binary = app_binary(root, staged)
    env = {k: v for k, v in __import__("os").environ.items()
           if k != "CHOUPO_HOME"}
    try:
        # The engine resolves case-local records by walking UP from the CWD
        # (RecordResolver::localScanDir uses fs::current_path()), so the
        # validation must run FROM INSIDE the staged case -- exactly as
        # runCase/runTests do -- or the sealed closure is invisible to itself.
        r = subprocess.run([str(binary), "."],
                           cwd=str(staged),
                           env=env, capture_output=True, text=True,
                           timeout=300)
    except subprocess.TimeoutExpired:
        die("validation TIMED OUT (300 s) -- nothing was installed")
    if r.returncode != 0:
        tail = "\n".join((r.stdout + "\n" + r.stderr).splitlines()[-25:])
        die("validation FAILED: the staged sealed case does not run with the"
            " catalogue hidden (exit %d) -- nothing was installed.\n"
            "--- last lines ---\n%s" % (r.returncode, tail))


# ---------------------------------------------------------------------------
def main():
    args = sys.argv[1:]
    adopt, overwrite, merge_overlay = set(), set(), set()
    pos = []
    i = 0
    while i < len(args):
        a = args[i]
        if a == "--adopt-local":
            i += 1
            adopt.add(args[i])
        elif a == "--overwrite":
            i += 1
            overwrite.add(args[i])
        elif a == "--merge-overlay":
            i += 1
            merge_overlay.add(args[i])
        elif a.startswith("--"):
            die("unknown option " + a)
        else:
            pos.append(a)
        i += 1
    if len(pos) != 1:
        die("usage: choupo-import <caseDir> [--adopt-local <rel>]..."
            " [--overwrite <rel>]... [--merge-overlay <rel>]...")
    caseDir = Path(pos[0]).resolve()
    if not caseDir.is_dir():
        die("not a directory: " + str(caseDir))
    root = find_root()
    std = root / "data" / "standards"
    release = read_release(root)
    AQ = parse_species_files(std)

    # The retired v1 snapshot home may not coexist with the mirrored form:
    # migrate (delete constant/propertyData/ after checking nothing hand-tuned
    # lives there) before sealing.  Fail-closed, never a silent mix.
    legacy = [p for p in caseDir.rglob("constant/propertyData")]
    if legacy:
        die("this case still carries the retired constant/propertyData/ "
            "snapshot form:\n  "
            + "\n  ".join(str(p) for p in legacy)
            + "\nmigrate first (delete the snapshot tree; hand-tuned records "
              "move to their mirrored constant/ homes), then re-run.")

    # ---- closures per fractal context -------------------------------------
    plant_pp = None
    for name in ("thermoPhysPropDict", "propertyDict", "propertyPackage"):
        cand = caseDir / "constant" / name
        if cand.exists():
            plant_pp = cand
            break
    plant_recs, plant_ions, plant_all = ({}, set(), False)
    if plant_pp:
        plant_recs, plant_ions, plant_all = closure_of(plant_pp, caseDir, std, AQ)
    sector = {}          # sectorDir -> (recs, ions, wantAll)
    for pp in parse_packages(caseDir):
        if plant_pp and pp.resolve() == plant_pp.resolve():
            continue
        sd = pp.parent.parent            # SECTOR/constant/<dict> -> SECTOR
        recs, ions, wantAll = closure_of(pp, sd, std, AQ)
        # A sector keeps ONLY the records the engine resolves PER-NODE (the
        # binary-pair ladders carry a nodeBase: parameters/NRTL|UNIQUAC|Wilson).
        # Everything else (methods/, chemistry/, species, Pitzer pairs, ...) is
        # resolved by the cwd walk-up, which starts at the PLANT ROOT when the
        # whole plant runs -- so those records must live at the root (the
        # drill-in run still finds them: the sector's walk-up climbs to the
        # root).  The retired propertyData snapshots duplicated them into both;
        # the mirrored form promotes instead.
        per_node = ("parameters/NRTL/", "parameters/UNIQUAC/", "parameters/Wilson/")
        extra = {}
        for rel, src in recs.items():
            if rel in plant_recs:
                continue
            if rel.startswith(per_node):
                extra[rel] = src
            else:
                plant_recs[rel] = src
        # ion species resolve through the same cwd walk-up (the filtered
        # constant/species/aqueous.dat) -- promote them to the root catalogue.
        plant_ions.update(ions)
        plant_all = plant_all or wantAll
        sector[sd] = (extra, set(), False)

    # A per-unit thermo{} override in a sector flowsheet is resolved by the
    # FLATTENED plant against the plant ROOT -- fold its records into the
    # plant closure AFTER the sector subtraction (sectors unaffected).
    def want_plant(rel):
        src = std / rel
        if src.exists():
            plant_recs[rel] = src
    for fs_dict in Path(caseDir).rglob("system/flowsheetDict"):
        ftext = read(fs_dict) or ""
        for m in re.finditer(r'\bthermo\b', ftext):
            blk = block(ftext[m.start():], "thermo")
            if blk:
                pm = block(blk, "propertyMethods")
                # (methods/<model>.dat retired 2026-07-18 -- nothing to seal)
                ch = block(blk, "chemistry")
                if ch:
                    sb = block(ch, "salts")
                    for salt in (words(sb) if sb else []):
                        want_plant("chemistry/salts/" + salt + ".dat")
                        want_plant("phases/solid/" + salt + ".dat")
                par = block(blk, "parameters")
                if par:
                    for mm in re.finditer(r'"([^"]*data/standards/([^"]+))"', par):
                        want_plant(mm.group(2))
                    ppb = block(par, "pitzerPairs")
                    for pair in (words(ppb) if ppb else []):
                        want_plant("parameters/Pitzer/pairs/" + pair + ".dat")

    # ---- physical assets referenced by the unit operations / props ops ------
    # Membranes / adsorbents / construction materials / ion-exchange resins are
    # named in the flowsheetDict units (`membrane SW30HR;`), the propsDict ops
    # (`resin SAC_Na;`, isothermEval `adsorbent ...`) and the post/controlDict
    # (`material SS304;` for sizing).  The MembraneRegistry / AdsorbentRegistry /
    # MaterialRegistry / electrodialysisStack / exchange readers resolve them
    # from data/standards/assets/ at runtime, so the seal must mirror each
    # referenced asset (existence-guarded, so an authored case-local overlay --
    # a membrane / adsorbent the case ships in constant/membranes|adsorbents/ --
    # is left untouched).  Adsorbents also pull their per-species equilibria dir.
    asset_names = set()
    for sd_dict in Path(caseDir).rglob("system/*Dict"):
        dtext = read(sd_dict) or ""
        dtext = re.sub(r'/\*.*?\*/', '', dtext, flags=re.S)
        dtext = re.sub(r'(^|\s)//.*$', '', dtext, flags=re.M)
        for m in re.finditer(
                r'\b(?:membrane|adsorbent|material|wallMaterial|wall|resin)'
                r'\s+([A-Za-z0-9_]+)\s*;', dtext):
            asset_names.add(m.group(1))
    for name in sorted(asset_names):
        want_plant("assets/" + name + ".dat")
        eq = std / "parameters" / "adsorption" / "equilibria" / name
        if eq.is_dir():
            for f in sorted(eq.glob("*.dat")):
                want_plant("parameters/adsorption/equilibria/"
                           + name + "/" + f.name)

    # ---- per-context install content --------------------------------------

    def install_map(recs, ions, wantAll):
        """-> {rel: (content, origin, originSha)}"""
        out = {}
        for rel, src in sorted(recs.items()):
            body = strip_install_paths(src.read_text())
            stamp = ('// [imported] origin "data/standards/%s" (%s release) --'
                     ' owned + sha256-verified by constant/propertyManifest\n'
                     % (rel, release))
            out[rel] = (stamp + body, "data/standards/" + rel, sha_file(src))
        # ONE typed file per reached species (2026-07-18: the filtered
        # aqueous catalogue is gone -- the student sees exactly the species
        # files the case consumes).
        names = set(AQ) if wantAll else set(ions)
        names = {n for n in names if n in AQ}
        for nm in sorted(names):
            src = std / "species" / (nm + ".dat")
            if src.is_file():
                rel = "species/" + nm + ".dat"
                out[rel] = (strip_install_paths(src.read_text()),
                            "data/standards/" + rel, sha_file(src))
        return out

    contexts = [(caseDir, install_map(plant_recs, plant_ions, plant_all))]
    for sd, (recs, ions, wantAll) in sector.items():
        contexts.append((sd, install_map(recs, ions, wantAll)))

    # ---- conflict analysis (rules 1-4, 6) -- BEFORE any write -------------
    plans = []       # (ctxDir, installs {rel:(content,origin,osha)},
    #                   removals [rel], entries {rel:entry})
    conflicts = []
    for ctxDir, inst in contexts:
        constant = ctxDir / "constant"
        old = read_manifest(constant)
        entries = {}
        installs = {}
        claimed = set()
        for rel in inst:
            check_rel_safe(rel)
            check_no_symlink_escape(constant, rel)
            if rel in claimed:
                die("duplicate claim: " + rel)
            claimed.add(rel)
        for rel, (content, origin, osha) in inst.items():
            dst = constant / rel
            oldE = old.get(rel)
            if dst.exists() and oldE is None:
                if rel in adopt:
                    entries[rel] = {"type": "adopted",
                                    "adoptedAt": date.today().isoformat()}
                    continue
                if rel in merge_overlay:
                    # partial by-name overlay -> pre-materialise the top-level
                    # merge (standards base `content` + authored delta at dst).
                    overlay_text = dst.read_text()
                    merged = merge_overlay_text(content, overlay_text, rel, release)
                    installs[rel] = (merged, origin, osha)
                    entries[rel] = {"type": "merged",
                                    "sha256": sha(merged),
                                    "origin": origin,
                                    "originSha256": osha,
                                    "overlaySha256": sha(overlay_text),
                                    "release": release}
                    continue
                conflicts.append(
                    "FATAL [rule 1] %s: destination constant/%s exists but is"
                    " NOT in the manifest -- an authored file the importer"
                    " never overwrites.  Either remove/relocate it yourself"
                    " (a curation act), adopt it as the case's record"
                    " (--adopt-local %s), or -- for a PARTIAL by-name overlay --"
                    " seal the base+delta merge (--merge-overlay %s)."
                    % (ctxDir.name, rel, rel, rel))
                continue
            if dst.exists() and oldE is not None:
                if oldE.get("type") in ("adopted", "merged"):
                    # durable: the author's adopted record, or the pre-
                    # materialised base+overlay merge (the partial overlay it
                    # was built from no longer exists on disk -- never re-
                    # install the bare base over it).
                    entries[rel] = oldE
                    continue
                cur = sha_file(dst)
                if cur != oldE.get("sha256"):
                    if rel in adopt:
                        entries[rel] = {"type": "adopted",
                                        "adoptedAt": date.today().isoformat()}
                        continue
                    if rel in overwrite:
                        installs[rel] = (content, origin, osha)
                        entries[rel] = {"type": "imported",
                                        "sha256": sha(content),
                                        "origin": origin,
                                        "originSha256": osha,
                                        "release": release}
                        continue
                    conflicts.append(
                        "REFUSED [rule 3] %s: constant/%s was edited locally"
                        " (hash diverged from the installed record).  Choose"
                        " explicitly:\n"
                        "    --adopt-local %s   (keep your edit; withdraw the"
                        " file from importer ownership)\n"
                        "    --overwrite %s     (DESTRUCTIVE: discard your"
                        " edit, re-install the catalogue record)"
                        % (ctxDir.name, rel, rel, rel))
                    continue
                # hash intact -> rule 2: the importer's to update
            installs[rel] = (content, origin, osha)
            entries[rel] = {"type": "imported", "sha256": sha(content),
                            "origin": origin, "originSha256": osha,
                            "release": release}
        # rule 4: claimed records whose dependency vanished from the closure
        removals = []
        for rel, oldE in old.items():
            if rel in inst:
                continue
            if oldE.get("type") in ("adopted", "merged"):
                entries[rel] = oldE              # adoption / merge is durable
                continue
            dst = constant / rel
            if not dst.exists():
                continue                          # already gone; drop claim
            if sha_file(dst) == oldE.get("sha256"):
                removals.append(rel)
            else:
                conflicts.append(
                    "REFUSED [rule 4] %s: constant/%s left the closure but was"
                    " edited locally -- resolve by hand (keep it as an"
                    " authored file after removing the manifest claim, or"
                    " delete it), then re-run." % (ctxDir.name, rel))
        plans.append((ctxDir, installs, removals, entries))

    if conflicts:
        sys.stderr.write("choupo-import: %d conflict(s); NOTHING was"
                         " written.\n\n" % len(conflicts))
        for c in conflicts:
            sys.stderr.write(c + "\n\n")
        sys.exit(1)

    # ---- stage the ENTIRE new case + validate (rule 5) --------------------
    with tempfile.TemporaryDirectory(prefix="choupo-import-") as tmp:
        staged = Path(tmp) / caseDir.name
        shutil.copytree(caseDir, staged, symlinks=True)
        for ctxDir, installs, removals, entries in plans:
            sconst = staged / ctxDir.relative_to(caseDir) / "constant"
            for rel in removals:
                (sconst / rel).unlink()
            for rel, (content, _o, _s) in installs.items():
                dst = sconst / rel
                dst.parent.mkdir(parents=True, exist_ok=True)
                dst.write_text(content)
            (sconst / "propertyManifest").write_text(
                manifest_text(entries, release,
                              "context: " + (ctxDir.name if ctxDir != caseDir
                                             else "case root")))
        validate_staged(root, staged)

    # ---- install (validated): files first, each manifest LAST -------------
    n_inst = n_adopt = n_rm = 0
    def prune_empty(d, stop):
        # Remove d and any now-empty parent up to (not including) `stop`.
        while d != stop and d.is_dir() and not any(d.iterdir()):
            d.rmdir()
            d = d.parent

    for ctxDir, installs, removals, entries in plans:
        constant = ctxDir / "constant"
        for rel in removals:
            f = constant / rel
            f.unlink()
            prune_empty(f.parent, constant)     # no empty dir left behind
            n_rm += 1
        for rel, (content, _o, _s) in installs.items():
            dst = constant / rel
            dst.parent.mkdir(parents=True, exist_ok=True)
            dst.write_text(content)
            n_inst += 1
        (constant / "propertyManifest").write_text(
            manifest_text(entries, release,
                          "context: " + (ctxDir.name if ctxDir != caseDir
                                         else "case root")))
        n_adopt += sum(1 for e in entries.values()
                       if e.get("type") == "adopted")

    print("choupo-import: sealed %s (%s)" % (caseDir.name, release))
    print("  %d record(s) installed, %d adopted (authored), %d removed,"
          " %d context manifest(s)"
          % (n_inst, n_adopt, n_rm, len(plans)))
    print("  validation: staged case RAN with the standards catalogue hidden"
          " before install")


if __name__ == "__main__":
    main()
