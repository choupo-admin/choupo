#---------------------------------------------------------------------------#
#  agentBridge -- start the LOCAL web-terminal bridge that lets the Choupo
#  GUI's Assistant console run a real `claude -c` session in the project.
#
#  Usage:
#      bin/agentBridge          # start (foreground)
#      bin/agentBridge --kill   # stop a running bridge
#
#  Binds 127.0.0.1:7682 (override with CHOUPO_AGENT_PORT).  LOCAL ONLY.
#  Needs `claude` on PATH and the GUI deps installed (ws + node-pty).
#---------------------------------------------------------------------------#
set -e
script_dir=$(dirname "$(readlink -f "$0")")
root=$(dirname "$script_dir")
bridge="$root/gui/bridge/claudeBridge.mjs"

if [ "${1:-}" = "--kill" ] || [ "${1:-}" = "--stop" ]; then
    pkill -f 'claudeBridge.mjs' 2>/dev/null && echo "[agentBridge] stopped" || echo "[agentBridge] nothing running"
    exit 0
fi

if ! command -v claude > /dev/null; then
    echo "[agentBridge] ERROR: 'claude' not on PATH -- install Claude Code first" >&2
    exit 1
fi
export CHOUPO_HOME="$root"
echo "[agentBridge] starting -> ws://127.0.0.1:${CHOUPO_AGENT_PORT:-7682} (claude -c in $root)"
exec node "$bridge"
