# =============================================================================
#  runApplication  --  application runner
#
#  Runs the given application and writes its stdout/stderr to log.<appName>
#  in the current working directory.  Refuses to overwrite an existing log
#  unless -a (append) is used or the log is removed.
#
#  Usage:
#      runApplication choupoSolve .
#      runApplication -a choupoSolve tutorials/flash01_benzene_toluene
# =============================================================================

set -euo pipefail

APPEND=
case "${1:-}" in
    -a|-append) APPEND="-a"; shift ;;
    -h|--help|"")
        sed -n '3,11p' "$0" | sed 's/^# \{0,1\}//'
        exit 0
        ;;
esac

APP_FULL=$1; shift || true
APP_NAME=$(basename "$APP_FULL")
LOG="log.$APP_NAME"

if [ -f "$LOG" ] && [ -z "$APPEND" ]; then
    cat >&2 <<EOF
runApplication: '$LOG' already exists in $(pwd)
                Remove it (rm $LOG) or pass -a to append.
EOF
    exit 1
fi

echo "Running $APP_NAME on $(pwd)"
[ "$#" -gt 0 ] && echo "  args: $*"
echo "  log:  $LOG"

if [ -n "$APPEND" ]; then
    "$APP_FULL" "$@" >> "$LOG" 2>&1
else
    "$APP_FULL" "$@" > "$LOG" 2>&1
fi
rc=$?

if [ $rc -eq 0 ]; then
    echo "  done."
else
    echo "  FAILED (exit $rc) -- see $LOG" >&2
fi
exit $rc
