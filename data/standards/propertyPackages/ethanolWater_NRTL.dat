/*---------------------------------------------------------------------------*\
  propertyPackage ethanolWater_NRTL -- the declarative thermo MANIFEST a case selects
  (`package ethanolWater_NRTL;` in its constant/propertyPackage, or copy this record
  inline into the case for the self-contained form).
  Components: ethanol water.  Liquid method: activity.NRTL (the world);
  the ThermoPackageBuilder loads + verifies every declared parameter file and
  announces the assembly in the run log.  Grammar: the 2026-07-04 forum
  (models per PHASE, conventions per GROUP, parameters per PAIR, all cited).
\*---------------------------------------------------------------------------*/
recordType propertyPackage;
schemaVersion 1;

name ethanolWater_NRTL;

components ( ethanol water );

propertyMethods
{
    liquid activity.NRTL;
    vapour builtin.idealGas;
}

parameters
{
    binaryPairs
    {
        ethanol-water "data/standards/parameters/binary/NRTL/ethanol-water.dat";
    }
}


notes
{
    purpose "Molecular (degenerate) property package: no dissociation, no chemistry, NRTL. The same ThermoPackageBuilder serves molecular and electrolyte alike.";
}
