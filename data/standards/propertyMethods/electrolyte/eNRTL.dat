/*---------------------------------------------------------------------------*\
  propertyMethod electrolyte.eNRTL -- the electrolyte-NRTL model (local
  composition at segment scale + Pitzer-Debye-Huckel at component scale) for
  aqueous electrolytes; the mixed-solvent extension is served by the separate
  enrtlMixedSolvent op (validated vs Esteso 1989 to 70 wt%; 80/90 wt% carries
  the declared ion-pairing caveat) -- this METHOD record covers the aqueous
  binary/multi-salt engine only.  Per-group rungs as pitzer (A1);
  tau(T) is the anchored, calorimetrically-UNCALIBRATED form -- never carries
  the calorimetricFit flag.  Source: Chen & Evans (1986), AIChE J. 32:444;
  multi-salt per Song & Chen (2009).
\*---------------------------------------------------------------------------*/
recordType propertyMethod;
schemaVersion 1;

name eNRTL;
family electrolyte;

description "Electrolyte-NRTL (single-salt) activity model -- the molality-scale salt adapter; tau(T) is the anchored, calorimetrically UNCALIBRATED form (no heat-of-dilution L_phi).";

componentApproach apparentOrTrue;

// The reference basis lives INSIDE the propertyMethod, per phase (U2,
// final-property-architecture.md).  Same rungs as pitzer: aqueous ion infinite
// dilution + the ion-derived solid datum.
referenceBasis
{
    aqueous
    {
        // A1 (grammar forum 2026-07-04): per-GROUP rungs made explicit --
        // ONE aqueous Gibbs surface, two conventions on it (Gibbs-Duhem).
        water { rung pureLiquidRaoult;          convention "a_w from the osmotic coefficient"; }
        ions  { rung ionAqueousInfiniteDilution; convention "H+(aq)=0"; }
    }

    solid
    {
        rung solidFromIonFormation;
        relation "Hf_solid = sum(nu_i*hfAq_i) - dH_solution";
    }

    vapour
    {
        rung idealGasReference;
    }
}

requires
{
    ionSpecies true;

    ionCharges true;

    pairParameters
    {
        type electrolyteNRTLParameters;
        path "data/standards/parameters/electrolyte/eNRTL/";
    }

    optionalSaltEquilibria
    {
        path "data/standards/chemistry/salts/";
    }
}

provides ( meanActivityCoefficient osmoticCoefficient waterActivity ionicStrength osmoticPressure saturationIndex );

notes
{
    purpose "Defines the eNRTL method contract. Numerical tau parameters live in parameters/electrolyte/eNRTL/.";
    caveat  "calorimetricFit is per-kernel and FALSE for eNRTL: the tau(T) is uncalibrated, so the L_phi heat-of-dilution stays off the energy balance (the builder forces it).";
}
