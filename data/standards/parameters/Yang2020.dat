    // SI row 57 -- "-(CH2)n- (oxide)" : the per-CH2 PER-UNIT contribution
    // (FW = n*14, Yg = n*3.412).  Stored as the n=1 unit; use `count` = n.
    { name CH2oxide;           MW 14;    Yg 3.412;
      structure "-(CH2)- in a poly(oxide) backbone  (per CH2, FW=n*14, Yg=n*3.412)";
      provenance { origin "Yang et al., ACS Omega 5 (2020) 19655, Table S3 (CC-BY)"; note "row 57 -- per-CH2 unit of a -(CH2)n-O- oxide backbone; multiply by count=n"; } }

    // SI row 58 -- "backbone in the side chain" : THE Ngb/Ygb term.  FW "depend
    // on atoms" -> carried as 0 here (its mass is already counted by the side-
    // chain groups); only its Yg = 2.771 enters the Tg bracket, once per Nb.
    { name backboneSideChain;  MW 0;     Yg 2.771;
      structure "backbone atom located in a side chain (the Nb/Ygb term)";
      provenance { origin "Yang et al., ACS Omega 5 (2020) 19655, Table S3 (CC-BY)"; method "Nb*Ygb backbone-in-side-chain term of eq 5"; note "row 58 -- FW 'depend on atoms' (mass counted by the side-chain groups, so MW=0 here); add with count=Nb (0 for common vinyl polymers)"; } }
);
