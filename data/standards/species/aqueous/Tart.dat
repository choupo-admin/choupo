recordType modelSpecies;   // model species — summoned by a property method; never placed in a flowsheet
schemaVersion 1;

name    Tart;
ion     "C4H4O6-2";
charge  -2;

MW { value 148.07; unit g/mol;}

aqueousThermo
{
    hfAq { value -1291000; unit J/mol;}
}

source "tartrate; hfAq Kochergina et al. Russ.J.Phys.Chem. 80 (2006) 899, Tab.5 (mean of 2 methods)";
