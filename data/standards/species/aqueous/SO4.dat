recordType modelSpecies;   // model species — summoned by a property method; never placed in a flowsheet
schemaVersion 1;

name    SO4;
ion     "SO4-2";
charge  -2;

MW { value 96.06; unit g/mol;}

aqueousThermo
{
    hfAq { value -909270; unit J/mol;}
    sAq  { value 20.1;  unit J/mol/K;}
}

transport
{
    radius { value 3.79e-10; unit m;}
    D0     { value 1.06e-09;     unit m2/s;}
}

source "hfAq+sAq Wagman 1982;  radius+D0 Nightingale 1959 (lambda0 160.0 molar)";
