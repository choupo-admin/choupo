recordType modelSpecies;   // model species — summoned by a property method; never placed in a flowsheet
schemaVersion 1;

name    HTart;
ion     "HC4H4O6-";
charge  -1;

MW { value 149.08; unit g/mol;}

aqueousThermo
{
    hfAq { value -1292100; unit J/mol;}
}

source "bitartrate; hfAq Kochergina et al. 2006 Tab.5";
