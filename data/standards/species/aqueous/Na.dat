recordType modelSpecies;   // model species — summoned by a property method; never placed in a flowsheet
schemaVersion 1;

name    Na;
ion     "Na+";
charge  +1;

MW { value 22.99; unit g/mol;}

aqueousThermo
{
    hfAq { value -240120; unit J/mol;}
    sAq  { value 59.0;  unit J/mol/K;}
    cpAq { value 46.4; unit J/mol/K;}
}

transport
{
    radius { value 3.58e-10; unit m;}
    D0     { value 1.33e-09;     unit m2/s;}
}

source "Wagman 1982; radius+D0 Nightingale 1959 (lambda0 50.1)";
