/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): eicosanoic acid, compd. with morpholine (1:1)  (C24H49NO3, CAS 69847-51-4)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component gibbsFormation block.
\*---------------------------------------------------------------------------*/

name           eicosanoicAcidCompdWithMorpholine11;
formula        C24H49NO3;
CAS            69847-51-4;
InChIKey       GZNMENHFXPXDBK-UHFFFAOYSA-N;
MW             399.66;          // g/mol [origin=calculated method=formula-sum]
nonvolatile    true;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { eicosanoic acid 1; morpholine 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
