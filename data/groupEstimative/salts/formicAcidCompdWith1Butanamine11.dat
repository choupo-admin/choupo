/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): formic acid, compd. with 1-butanamine (1:1)  (C5H13NO2, CAS 18721-03-4)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component standardThermochemistry block.
\*---------------------------------------------------------------------------*/

name           formicAcidCompdWith1Butanamine11;
formula        C5H13NO2;
CAS            18721-03-4;
InChIKey       ZQAVAOYDHNUKHF-UHFFFAOYSA-N;
MW             119.164;          // g/mol [origin=calculated method=formula-sum]
role        nonvolatile;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { formic acid 1; 1-butanamine 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
