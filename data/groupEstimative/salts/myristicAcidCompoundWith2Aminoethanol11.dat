/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): myristic acid, compound with 2-aminoethanol (1:1)  (C16H35NO3, CAS 31756-97-5)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component standardThermochemistry block.
\*---------------------------------------------------------------------------*/

name           myristicAcidCompoundWith2Aminoethanol11;
formula        C16H35NO3;
CAS            31756-97-5;
InChIKey       KPYDHOVAALYKRO-UHFFFAOYSA-N;
MW             289.46;          // g/mol [origin=calculated method=formula-sum]
role        nonvolatile;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { myristic acid 1; 2-aminoethanol 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
