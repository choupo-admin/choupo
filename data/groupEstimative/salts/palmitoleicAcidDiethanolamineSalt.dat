/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): palmitoleic acid, diethanolamine salt  (C20H41NO4, CAS 68171-51-7)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component standardThermochemistry block.
\*---------------------------------------------------------------------------*/

name           palmitoleicAcidDiethanolamineSalt;
formula        C20H41NO4;
CAS            68171-51-7;
InChIKey       WMTVNSRGDKFVBA-CFYXSCKTSA-N;
MW             359.551;          // g/mol [origin=calculated method=formula-sum]
nonvolatile    true;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { palmitoleic acid 1; diethanolamine 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
