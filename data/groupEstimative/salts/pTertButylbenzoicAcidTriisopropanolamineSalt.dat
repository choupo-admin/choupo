/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): p-tert-butylbenzoic acid, triisopropanolamine salt  (C20H35NO5, CAS 68258-65-1)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component gibbsFormation block.
\*---------------------------------------------------------------------------*/

name           pTertButylbenzoicAcidTriisopropanolamineSalt;
formula        C20H35NO5;
CAS            68258-65-1;
InChIKey       RLZNLRYGISZOQM-UHFFFAOYSA-N;
MW             369.502;          // g/mol [origin=calculated method=formula-sum]
nonvolatile    true;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { p-tert-butylbenzoic acid 1; triisopropanolamine 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
