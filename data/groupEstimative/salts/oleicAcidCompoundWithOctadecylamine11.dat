/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): oleic acid, compound with octadecylamine (1:1)  (C36H73NO2, CAS 94042-67-8)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component standardThermochemistry block.
\*---------------------------------------------------------------------------*/

name           oleicAcidCompoundWithOctadecylamine11;
formula        C36H73NO2;
CAS            94042-67-8;
InChIKey       SNYNFOXIGQIWMC-UHFFFAOYSA-N;
MW             551.985;          // g/mol [origin=calculated method=formula-sum]
role        nonvolatile;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { oleic acid 1; octadecylamine 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
