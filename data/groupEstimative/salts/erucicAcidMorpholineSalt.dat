/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): erucic acid, morpholine salt  (C26H51NO3, CAS 68015-99-6)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component gibbsFormation block.
\*---------------------------------------------------------------------------*/

name           erucicAcidMorpholineSalt;
formula        C26H51NO3;
CAS            68015-99-6;
InChIKey       YFLWNDYFXXOSBP-KVVVOXFISA-N;
MW             425.698;          // g/mol [origin=calculated method=formula-sum]
nonvolatile    true;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { erucic acid 1; morpholine 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
