/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): n-(3-dimethylaminopropyl)oleamide, lactic acid salt  (C26H52N2O4, CAS 69898-44-8)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component gibbsFormation block.
\*---------------------------------------------------------------------------*/

name           n3DimethylaminopropylOleamideLacticAcidSalt;
formula        C26H52N2O4;
CAS            69898-44-8;
InChIKey       VRTUIPADMRQBPL-AFEZEDKISA-N;
MW             456.712;          // g/mol [origin=calculated method=formula-sum]
nonvolatile    true;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { n-(3-dimethylaminopropyl)oleamide 1; lactic acid 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
