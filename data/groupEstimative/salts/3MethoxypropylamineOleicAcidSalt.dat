/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): 3-methoxypropylamine, oleic acid salt  (C22H45NO3, CAS 68214-77-7)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component standardThermochemistry block.
\*---------------------------------------------------------------------------*/

name           3MethoxypropylamineOleicAcidSalt;
formula        C22H45NO3;
CAS            68214-77-7;
InChIKey       AQTCOVFJPUEXIG-KVVVOXFISA-N;
MW             371.606;          // g/mol [origin=calculated method=formula-sum]
nonvolatile    true;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { 3-methoxypropylamine 1; oleic acid 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
