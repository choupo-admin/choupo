/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): capric acid, isopropanolamine salt  (C13H29NO3, CAS 64012-04-0)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component gibbsFormation block.
\*---------------------------------------------------------------------------*/

name           capricAcidIsopropanolamineSalt;
formula        C13H29NO3;
CAS            64012-04-0;
InChIKey       XXOPKUIPDUCOSI-UHFFFAOYSA-N;
MW             247.379;          // g/mol [origin=calculated method=formula-sum]
nonvolatile    true;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { capric acid 1; isopropanolamine 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
