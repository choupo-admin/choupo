/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): p-tert-butylbenzoic acid, diisopropanolamine salt  (C17H29NO4, CAS 68213-81-0)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component gibbsFormation block.
\*---------------------------------------------------------------------------*/

name           pTertButylbenzoicAcidDiisopropanolamineSalt;
formula        C17H29NO4;
CAS            68213-81-0;
InChIKey       XHEJMLGUSKEJHC-UHFFFAOYSA-N;
MW             311.422;          // g/mol [origin=calculated method=formula-sum]
nonvolatile    true;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { p-tert-butylbenzoic acid 1; diisopropanolamine 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
