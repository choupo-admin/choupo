/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): acetic acid, di(2-ethylhexyl)amine salt  (C16H35N, CAS 50616-05-2)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component standardThermochemistry block.
\*---------------------------------------------------------------------------*/

name           aceticAcidDi2EthylhexylAmineSalt;
formula        C16H35N;
CAS            50616-05-2;
InChIKey       SAIKULLUBZKPDA-IYBDPMFKSA-N;
MW             241.463;          // g/mol [origin=calculated method=formula-sum]
nonvolatile    true;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { acetic acid 1; di(2-ethylhexyl)amine 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
