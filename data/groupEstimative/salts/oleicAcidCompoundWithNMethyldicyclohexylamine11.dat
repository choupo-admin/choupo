/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): oleic acid, compound with n-methyldicyclohexylamine (1:1)  (C31H59NO2, CAS 67633-84-5)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component gibbsFormation block.
\*---------------------------------------------------------------------------*/

name           oleicAcidCompoundWithNMethyldicyclohexylamine11;
formula        C31H59NO2;
CAS            67633-84-5;
InChIKey       KXCCOLSKJMTKGD-KVVVOXFISA-N;
MW             477.818;          // g/mol [origin=calculated method=formula-sum]
nonvolatile    true;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { oleic acid 1; n-methyldicyclohexylamine 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
