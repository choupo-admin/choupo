/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): nonanoic acid, compound with morpholine (1:1)  (C13H27NO3, CAS 67952-98-1)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component standardThermochemistry block.
\*---------------------------------------------------------------------------*/

name           nonanoicAcidCompoundWithMorpholine11;
formula        C13H27NO3;
CAS            67952-98-1;
InChIKey       NKJHSNBLMRLJOE-UHFFFAOYSA-N;
MW             245.363;          // g/mol [origin=calculated method=formula-sum]
role        nonvolatile;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { nonanoic acid 1; morpholine 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
