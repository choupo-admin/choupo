/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): octadecafluoro-9-(trifluoromethyl)decanoic acid, compound with ethylamine (1:1)  (C13H8F21NO2, CAS 68015-85-0)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component standardThermochemistry block.
\*---------------------------------------------------------------------------*/

name           octadecafluoro9TrifluoromethylDecanoicAcidCompoundWithEthyla;
formula        C13H8F21NO2;
CAS            68015-85-0;
InChIKey       JKTIKJAUCOVFKU-UHFFFAOYSA-N;
MW             609.17;          // g/mol [origin=calculated method=formula-sum]
nonvolatile    true;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { octadecafluoro-9-(trifluoromethyl)decanoic acid 1; ethylamine 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
