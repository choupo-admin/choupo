/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): linoleic acid dimer, mono(dimethyloctadecylamine) salt  (C56H107NO4, CAS 71394-30-4)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component gibbsFormation block.
\*---------------------------------------------------------------------------*/

name           linoleicAcidDimerMonoDimethyloctadecylamineSalt;
formula        C56H107NO4;
CAS            71394-30-4;
InChIKey       DLJWDNNNSMJVKO-BNIFLCCKSA-N;
MW             858.475;          // g/mol [origin=calculated method=formula-sum]
nonvolatile    true;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { linoleic acid dimer 1; mono(dimethyloctadecylamine) 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
