/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): octadecanoic acid, compd. with 1-amino-2-propanol (1:1)  (C21H45NO3, CAS 10042-65-6)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component standardThermochemistry block.
\*---------------------------------------------------------------------------*/

name           octadecanoicAcidCompdWith1Amino2Propanol11;
formula        C21H45NO3;
CAS            10042-65-6;
InChIKey       TUSQGJPKLFNBCZ-UHFFFAOYSA-N;
MW             359.595;          // g/mol [origin=calculated method=formula-sum]
nonvolatile    true;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { octadecanoic acid 1; 1-amino-2-propanol 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
