/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): octadecadienoic acid, triethanolamine salt  (C24H47NO5, CAS 68938-98-7)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component standardThermochemistry block.
\*---------------------------------------------------------------------------*/

name           octadecadienoicAcidTriethanolamineSalt;
formula        C24H47NO5;
CAS            68938-98-7;
InChIKey       FWQVMDXVPYRCCJ-OHAASFOQSA-N;
MW             429.642;          // g/mol [origin=calculated method=formula-sum]
role        nonvolatile;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { octadecadienoic acid 1; triethanolamine 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
