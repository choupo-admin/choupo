/*--------------------------------*- Choupo -*-----------------------*\
  Component (SALT): omega-phenylstearic acid, triethanolamine salt  (C30H55NO5, CAS 68797-42-2)
  ELECTROLYTE FORM -- NOT a Joback estimate (a salt has no single molecular
  Tc/Pc/Cp).  Like data/standards/components/NaCl.dat: nonvolatile, with a
  van't Hoff dissociation and a dissociatesTo map.  Formation lives PER
  constituent/ion, never as a component standardThermochemistry block.
\*---------------------------------------------------------------------------*/

name           omegaPhenylstearicAcidTriethanolamineSalt;
formula        C30H55NO5;
CAS            68797-42-2;
InChIKey       WMOUOYWNLXOIOS-UHFFFAOYSA-N;
MW             509.772;          // g/mol [origin=calculated method=formula-sum]
nonvolatile    true;
dissociation   2;              // van't Hoff factor for pi = nu R T c
dissociatesTo  { omega-phenylstearic acid 1; triethanolamine 1; }   // DRAFT constituents from the name -- verify & map to real components/ions
