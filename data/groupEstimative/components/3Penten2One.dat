/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-penten-2-one  (C5H8O, CAS 625-33-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Penten2One;
formula     C5H8O;
CAS         625-33-2;
InChIKey    LABTWGUMFABVFG-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          560.02;      // K   [origin=predictive method=joback]
Pc          39.906;      // bar [origin=predictive method=joback]
omega       0.3428;      // -   [origin=predictive method=lee-kesler]
Tb          372.03;      // K   [origin=predictive method=joback]
HvapTb      33428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.48 0.47084 -0.0003133 8.666e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-3-en-2-one" "(3e)-3-penten-2-one" "3-penten-2-one, (z)-" "3-penten-2-one, (3e)-" "agn-pc-0cqxpz" "3-penten-2-one,(e)- (8ci); 3-penten-2-one, trans- (6ci); (3e)-pent-3-en-2-one;(e)-3-penten-2-one; trans-3-penten-2-one" );
standardThermochemistry
{
    dHf_298   -141890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     370.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57480.0
}
