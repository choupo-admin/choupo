/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenedioic acid (2e)-, 1-hexyl ester, diester with butanediol  (C24H38O8, CAS 63450-29-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenedioicAcid2e1HexylEsterDiesterWithButanediol;
formula     C24H38O8;
CAS         63450-29-3;
InChIKey    RZGVXOAFMQQLRO-UHFFFAOYSA-N;
MW          454.56;      // g/mol [origin=calculated method=formula-sum]
Tc          1216.33;      // K   [origin=predictive method=joback]
Pc          8.661;      // bar [origin=predictive method=joback]
omega       0.7989;      // -   [origin=predictive method=lee-kesler]
Tb          989.92;      // K   [origin=predictive method=joback]
HvapTb      98562.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.344 2.10464 -0.001071 1.408e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group CH=CH; count 2; } { group COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group dCH; count 4; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o4-[4-(4-hexoxy-4-oxidanylidene-but-2-enoyl)oxybutyl] o1-hexyl but-2-enedioate" "2-butenedioic acid (2e)-, monohexyl ester, diester with butanediol" );
gibbsFormation
{
    dHf_298   -1573370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1282.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-929840.0
    phase     gas;
}
