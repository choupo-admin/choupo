/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2(3h)-furanone, dihydro-3-(3-methylbutyl)-  (C9H16O2, CAS 40541-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23hFuranoneDihydro33Methylbutyl;
formula     C9H16O2;
CAS         40541-41-1;
InChIKey    SGQTUZRWTKNTGV-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          657.83;      // K   [origin=predictive method=joback]
Pc          26.598;      // bar [origin=predictive method=joback]
omega       0.5283;      // -   [origin=predictive method=lee-kesler]
Tb          470.04;      // K   [origin=predictive method=joback]
HvapTb      42560.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.808 0.96084 -0.0005946 1.376e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3-methylbutyl)oxolan-2-one" "3-(3-methylbutyl)dihydrofuran-2(3h)-one" ".alpha.-isoamyl-.gamma.-butyrolactone" "a-iso-amyl-gamma-butyrolactone" "alpha-isoamyl-gamma-butyrolactone" "dihydro-3-(3-methylbutyl)furan-2(3h)-one" );
standardThermochemistry
{
    dHf_298   -478850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-227160.0
}
