/*--------------------------------*- Choupo -*-----------------------*\
  Component: cetyl palmitate  (C32H64O2, CAS 540-10-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cetylPalmitate;
formula     C32H64O2;
CAS         540-10-3;
InChIKey    PXDJXZJSCPSGGI-UHFFFAOYSA-N;
MW          480.862;      // g/mol [origin=calculated method=formula-sum]
Tc          1242.65;      // K   [origin=predictive method=joback]
Pc          5.446;      // bar [origin=predictive method=joback]
omega       0.2312;      // -   [origin=predictive method=lee-kesler]
Tb          989.98;      // K   [origin=predictive method=joback]
HvapTb      94233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.791 2.98904 -0.0016224 3.125e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 28; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 29; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecyl hexadecanoate" "palmityl palmitate" "hexadecyl palmitate" "hexadecanoic acid, hexadecyl ester" "cetin" "n-hexadecyl hexadecanoate" "palmitic acid palmityl ester" "hexadecanyl hexadecanoate" "palmitic acid, hexadecyl ester" "we(16:0/16:0)" "n-hexadecanyl palmitate" "cetyl palmitate (nf)" );
standardThermochemistry
{
    dHf_298   -1021090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1453.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-91810.0
}
