/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis-(dimethylaminopropyl)amine  (C10H25N3, CAS 6711-48-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisDimethylaminopropylAmine;
formula     C10H25N3;
CAS         6711-48-4;
InChIKey    BXYVQNNEFZOBOZ-UHFFFAOYSA-N;
MW          187.331;      // g/mol [origin=calculated method=formula-sum]
Tc          667.17;      // K   [origin=predictive method=joback]
Pc          21.256;      // bar [origin=predictive method=joback]
omega       0.7729;      // -   [origin=predictive method=lee-kesler]
Tb          503.45;      // K   [origin=predictive method=joback]
HvapTb      48376.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.794 1.27788 -0.000794 1.931e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH2NH; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group NH; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[3-(dimethylamino)propyl]-n',n'-dimethyl-propane-1,3-diamine" "bis(3-dimethylamino-1-propyl)amine" "tetramethyldipropylenetriamine" "bis[3-(dimethylamino)propyl]amine" "bis(3-dimethylaminopropyl)amine" "3,3'-iminobis(n,n-dimethylpropylamine)" "n,n,n',n'-tetramethyldipropylenetriamine" "2,6,10-triazaundecane, 2,10-dimethyl-" "1,3-propanediamine, n'-[3-(dimethylamino)propyl]-n,n-dimethyl-" "dipropylenetriamine, n,n,n',n'-tetramethyl-" "1,3-propanediamine, n'-(3-(dimethylamino)propyl)-n,n-dimethyl-" "n'-(3-(dimethylamino)propyl)-n,n-dimethyl-1,3-propanediamine" );
gibbsFormation
{
    dHf_298   -61200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     618.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=344270.0
    phase     gas;
}
