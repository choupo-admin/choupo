/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-hexanetriol  (C6H14O3, CAS 90325-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Hexanetriol;
formula     C6H14O3;
CAS         90325-47-6;
InChIKey    XYXCXCJKZRDVPU-UHFFFAOYSA-N;
MW          134.175;      // g/mol [origin=calculated method=formula-sum]
Tc          773.13;      // K   [origin=predictive method=joback]
Pc          44.326;      // bar [origin=predictive method=joback]
omega       1.8042;      // -   [origin=predictive method=lee-kesler]
Tb          612.54;      // K   [origin=predictive method=joback]
HvapTb      78211.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.943 0.68762 -0.0004002 8.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 2; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 2; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexane-1,2,3-triol" "1,2,3-hexanetriol solution" "1,2,3-hexanetriol 1 m solution" );
standardThermochemistry
{
    dHf_298   -634420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-415700.0
}
