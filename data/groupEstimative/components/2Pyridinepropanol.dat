/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pyridinepropanol  (C8H11NO, CAS 2859-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Pyridinepropanol;
formula     C8H11NO;
CAS         2859-68-9;
InChIKey    FVZXYJDGVYLMDB-UHFFFAOYSA-N;
MW          137.182;      // g/mol [origin=calculated method=formula-sum]
Tc          761.45;      // K   [origin=predictive method=joback]
Pc          40.986;      // bar [origin=predictive method=joback]
omega       0.8745;      // -   [origin=predictive method=lee-kesler]
Tb          555.20;      // K   [origin=predictive method=joback]
HvapTb      58567.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.937 0.75266 -0.00048226 1.211e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group OH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-pyridin-2-ylpropan-1-ol" "3-(2-pyridyl)-1-propanol" "3-(2-pyridyl)propanol" "3-(pyridin-2-yl)propan-1-ol" "2-pyridylpropanol" "2-(3-hydroxypropyl)pyridine" "2-propanol pyridine" "pgr-1" "3-(2-pyridyl)propan-1-ol" "3-(2-pyridinyl)-1-propanol" "1-(alpha-pyridine)-2-propanol" "2-pyridineethanol, alpha-methyl-" );
standardThermochemistry
{
    dHf_298   -91360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69120.0
}
