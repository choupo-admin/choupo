/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dichloroacrylic acid  (C3H2Cl2O2, CAS 1561-20-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33DichloroacrylicAcid;
formula     C3H2Cl2O2;
CAS         1561-20-2;
InChIKey    HYODZVPUCNBWNY-UHFFFAOYSA-N;
MW          140.947;      // g/mol [origin=calculated method=formula-sum]
Tc          715.24;      // K   [origin=predictive method=joback]
Pc          48.630;      // bar [origin=predictive method=joback]
omega       0.5890;      // -   [origin=predictive method=lee-kesler]
Tb          492.65;      // K   [origin=predictive method=joback]
HvapTb      48244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.67 0.3731 -0.0003389 1.197e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group COOH; count 1; } { group Cl_C=C_; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group dC; count 1; } { group Cl; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(chloranyl)prop-2-enoic acid" "3,3-dichloropropenoic acid" "3,3-dichloro-2-propenoic acid" "3,3-dichloroprop-2-enoic acid" "2-propenoic acid,2,3-dichloro-" "2-propenoic acid, 3,3-dichloro-" );
standardThermochemistry
{
    dHf_298   -379570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-321720.0
}
