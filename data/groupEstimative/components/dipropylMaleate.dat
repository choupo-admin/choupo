/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipropyl maleate  (C10H16O4, CAS 2432-63-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipropylMaleate;
formula     C10H16O4;
CAS         2432-63-5;
InChIKey    DSTWFRCNXMNXTR-UHFFFAOYSA-N;
MW          200.234;      // g/mol [origin=calculated method=formula-sum]
Tc          731.11;      // K   [origin=predictive method=joback]
Pc          22.334;      // bar [origin=predictive method=joback]
omega       0.7643;      // -   [origin=predictive method=lee-kesler]
Tb          549.00;      // K   [origin=predictive method=joback]
HvapTb      52626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.434 0.86424 -0.0004148 4.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipropyl but-2-enedioate" "2-butenedioic acid (2e)-, dipropyl ester" "2-butenedioic acid (2z)-, dipropyl ester" "2-butenedioic acid (2e)-, 1,4-dipropyl ester" "2-butenedioic acid (2z)-, 1,4-dipropyl ester" );
standardThermochemistry
{
    dHf_298   -767070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-507200.0
}
