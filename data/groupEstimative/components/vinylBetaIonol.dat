/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl-beta-ionol  (C15H24O, CAS 5208-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylBetaIonol;
formula     C15H24O;
CAS         5208-93-5;
InChIKey    PZGYHDPZANRCSM-PKNBQFBNSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          867.26;      // K   [origin=predictive method=joback]
Pc          20.718;      // bar [origin=predictive method=joback]
omega       0.8442;      // -   [origin=predictive method=lee-kesler]
Tb          661.50;      // K   [origin=predictive method=joback]
HvapTb      64549.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.32 1.82768 -0.0015679 5.758e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 2; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 3; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1e)-3-methyl-1-(2,6,6-trimethylcyclohexen-1-yl)penta-1,4-dien-3-ol" "3-methyl-1-(2,6,6-trimethylcyclohex-1-en-1-yl)penta-1,4-dien-3-ol" "ethylene-" "a-ionol" "1,4-pentadien-3-ol, 3-methyl-1-(2,6,6-trimethyl-1-cyclohexen-1-yl)-" "(1e)-3-methyl-1-(2,6,6-trimethyl-1-cyclohexen-1-yl)-1,4-pentadien-3-ol" "(1e)-3-methyl-1-(2,6,6-trimethyl-1-cyclohexenyl)-3-penta-1,4-dienol" "(e)-(1)-3-methyl-1-(2,6,6-trimethylcyclohex-1-en-1-yl)penta-1,4-dien-3-ol" );
standardThermochemistry
{
    dHf_298   -166860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     730.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=139160.0
}
