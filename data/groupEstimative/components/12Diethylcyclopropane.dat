/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-diethylcyclopropane  (C7H14, CAS 71032-67-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Diethylcyclopropane;
formula     C7H14;
CAS         71032-67-2;
InChIKey    AKOVCHSGJHQHEH-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          539.40;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.2920;      // -   [origin=predictive method=lee-kesler]
Tb          361.83;      // K   [origin=predictive method=joback]
HvapTb      30780.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.778 0.79324 -0.0005218 1.432e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -135350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     296.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61100.0
    phase     gas;
}
