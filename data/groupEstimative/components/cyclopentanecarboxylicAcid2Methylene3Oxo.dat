/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentanecarboxylic acid, 2-methylene-3-oxo-  (C7H8O3, CAS 874-21-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentanecarboxylicAcid2Methylene3Oxo;
formula     C7H8O3;
CAS         874-21-5;
InChIKey    ILFPCMXTASDZKM-UHFFFAOYSA-N;
MW          140.138;      // g/mol [origin=calculated method=formula-sum]
Tc          820.35;      // K   [origin=predictive method=joback]
Pc          40.725;      // bar [origin=predictive method=joback]
omega       0.7448;      // -   [origin=predictive method=lee-kesler]
Tb          587.53;      // K   [origin=predictive method=joback]
HvapTb      53003.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.64 0.5655 -0.0002206 -2.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH2=C; count 1; } { group CH2CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylidene-3-oxidanylidene-cyclopentane-1-carboxylic acid" "sarkomycin" "2-methylidene-3-oxocyclopentane-1-carboxylic acid" "2-methylene-3-oxocyclopentane-1-carboxylic acid" "(1r)-2-methylidene-3-oxocyclopentanecarboxylic acid" );
standardThermochemistry
{
    dHf_298   -531060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     326.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-368810.0
}
