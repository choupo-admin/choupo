/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenedioic acid (2e)-, bis(2,4,6-tribromophenyl) ester  (C16H6Br6O4, CAS 24138-34-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenedioicAcid2eBis246TribromophenylEster;
formula     C16H6Br6O4;
CAS         24138-34-9;
InChIKey    YLJNTEPTKSJUFE-UHFFFAOYSA-N;
MW          741.644;      // g/mol [origin=calculated method=formula-sum]
Tc          1459.95;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       1.7288;      // -   [origin=predictive method=lee-kesler]
Tb          1166.48;      // K   [origin=predictive method=joback]
HvapTb      113116.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (92.11 1.1486 -0.00082976 2.186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 8; } { group Br; count 6; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group Br; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[2,4,6-tris(bromanyl)phenyl] but-2-enedioate" "2-butenedioic acid (2z)-, bis(2,4,6-tribromophenyl) ester" "2-butenedioic acid (2e)-, 1,4-bis(2,4,6-tribromophenyl) ester" "2-butenedioic acid (2z)-, 1,4-bis(2,4,6-tribromophenyl) ester" "bis(2,4,6-tribromophenyl) (z)-but-2-enedioate" );
gibbsFormation
{
    dHf_298   -328690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     931.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203720.0
    phase     gas;
}
