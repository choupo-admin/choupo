/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1984971  (C17H12O2, CAS 83053-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1984971;
formula     C17H12O2;
CAS         83053-63-8;
InChIKey    JCENDEWOZZOHKV-UHFFFAOYSA-N;
MW          248.281;      // g/mol [origin=calculated method=formula-sum]
Tc          1099.59;      // K   [origin=predictive method=joback]
Pc          33.529;      // bar [origin=predictive method=joback]
omega       1.0276;      // -   [origin=predictive method=lee-kesler]
Tb          827.99;      // K   [origin=predictive method=joback]
HvapTb      78461.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.13 1.5177 -0.00129248 4.517e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 5; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 7; } { group OH_phenol; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-oxidanyl-15,16-dihydrocyclopenta[a]phenanthren-17-one" "17h-cyclopenta(a)phenanthren-17-one, 15,16-dihydro-11-hydroxy-" "11-hydroxy-15,16-dihydrocyclopenta[a]phenanthren-17-one" );
gibbsFormation
{
    dHf_298   -31820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=180330.0
    phase     gas;
}
