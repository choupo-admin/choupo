/*--------------------------------*- Choupo -*-----------------------*\
  Component: dmapn  (C5H10N2, CAS 1738-25-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dmapn;
formula     C5H10N2;
CAS         1738-25-6;
InChIKey    MTPJEFOSTIKRSS-UHFFFAOYSA-N;
MW          98.149;      // g/mol [origin=calculated method=formula-sum]
Tc          617.19;      // K   [origin=predictive method=joback]
Pc          33.606;      // bar [origin=predictive method=joback]
omega       0.4780;      // -   [origin=predictive method=lee-kesler]
Tb          428.52;      // K   [origin=predictive method=joback]
HvapTb      39245.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.652 0.53754 -0.0003298 7.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH3N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(dimethylamino)propanenitrile" "3-(dimethylamino)propionitrile" "3-dimethylaminopropionitrile" "dimethylaminopropionitrile" "beta-dimethylaminopropionitrile" "propanenitrile, 3-(dimethylamino)-" "propionitrile, 3-(dimethylamino)-" "3-(n,n-dimethylamino)propionitrile" "n,n-(dimethylamino)-3-propionitrile" "3-dimethylaminopropiononitrile" "beta-(n-dimethylamino)propionitrile" "3-(dimethylamino)-propanenitrile" );
standardThermochemistry
{
    dHf_298   85880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=235180.0
}
