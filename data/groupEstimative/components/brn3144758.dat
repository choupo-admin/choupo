name        brn3144758;
formula     C19H26OS;
CAS         108619-67-6;
InChIKey    HKULWYSNQPZVSM-NNGLDNROSA-N;
MW          302.476;      // g/mol [origin=calculated method=formula-sum]
Tc          1098.43;      // K   [origin=predictive method=joback]
Pc          21.816;      // bar [origin=predictive method=joback]
omega       0.8486;      // -   [origin=predictive method=lee-kesler]
Tb          835.04;      // K   [origin=predictive method=joback]
HvapTb      78971.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-222.39 2.49183 -0.00217972 8.007e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(17s)-13-methyl-17-methylsulfanyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-3-ol" "estra-1,3,5(10)-trien-3-ol, 17-beta-(methylthio)-" );
gibbsFormation
{
    dHf_298   -165230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=227520.0
    phase     gas;
}
