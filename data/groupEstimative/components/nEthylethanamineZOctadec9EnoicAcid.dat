/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-ethylethanamine;(z)-octadec-9-enoic acid  (C22H45NO2, CAS 17200-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nEthylethanamineZOctadec9EnoicAcid;
formula     C22H45NO2;
CAS         17200-00-9;
InChIKey    HOKMYEORIPLLGI-KVVVOXFISA-N;
MW          355.607;      // g/mol [origin=calculated method=formula-sum]
Tc          1107.01;      // K   [origin=predictive method=joback]
Pc          9.386;      // bar [origin=predictive method=joback]
omega       0.9106;      // -   [origin=predictive method=lee-kesler]
Tb          904.20;      // K   [origin=predictive method=joback]
HvapTb      88418.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.916 2.03466 -0.0009632 1.193e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 15; } { group CH=CH; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 16; } { group dCH; count 2; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-octadecenoic acid (9z)-, compd. with n-ethylethanamine (1:1)" "n-ethylethanamine; (z)-octadec-9-enoic acid" "oleic acid, compound with diethylamine (1:1)" );
gibbsFormation
{
    dHf_298   -788610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1207.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144700.0
    phase     gas;
}
