/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2,2,3,3-tetrachloropropanoate  (C4H4Cl4O2, CAS 20618-05-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2233Tetrachloropropanoate;
formula     C4H4Cl4O2;
CAS         20618-05-7;
InChIKey    UQYYMXYJSOOLLA-UHFFFAOYSA-N;
MW          225.874;      // g/mol [origin=calculated method=formula-sum]
Tc          717.29;      // K   [origin=predictive method=joback]
Pc          33.881;      // bar [origin=predictive method=joback]
omega       0.4549;      // -   [origin=predictive method=lee-kesler]
Tb          495.39;      // K   [origin=predictive method=joback]
HvapTb      47761.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.07 0.48792 -0.0003558 8.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CHCl2; count 1; } { group CCl2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group C; count 1; } { group Cl; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,2,3,3-tetrakis(chloranyl)propanoate" "propanoic acid, 2,2,3,3-tetrachloro-, methyl ester" );
gibbsFormation
{
    dHf_298   -520160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-374890.0
    phase     gas;
}
