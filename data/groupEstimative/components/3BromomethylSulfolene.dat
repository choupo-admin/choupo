/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(bromomethyl)sulfolene  (C5H7BrO2S, CAS 31554-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H7BrO2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3BromomethylSulfolene;
formula     C5H7BrO2S;
CAS         31554-48-0;
InChIKey    OQRRQSOMYYJAFE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          211.073;      // g/mol [origin=calculated method=formula-sum]
Tc          563.11;      // K   [origin=predictive method=joback]
Pc          57.917;      // bar [origin=predictive method=joback]
omega       0.5371;      // -   [origin=predictive method=lee-kesler]
Tb          378.98;      // K   [origin=predictive method=joback]
HvapTb      46325.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.049 0.6085 -0.00044364 1.237e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=C; count 1; } { group Br; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group Br; count 1; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(bromomethyl)-2,5-dihydrothiophene 1,1-dioxide" "thiophene, 3-(bromomethyl)-2,5-dihydro-, 1,1-dioxide" "3-(bromomethyl)-2,5-dihydrothiophene-1,1-dione" "3-(bromomethyl)-2,5-dihydro-1h-1-lambda'6'-thiophene-1,1-dione" );
standardThermochemistry
{
    dHf_298   -482130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     589.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-419430.0
}
