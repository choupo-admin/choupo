/*--------------------------------*- Choupo -*-----------------------*\
  Component: propiolic acid  (C3H2O2, CAS 471-25-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propiolicAcid;
formula     C3H2O2;
CAS         471-25-0;
InChIKey    UORVCLMRJXCDCP-UHFFFAOYSA-N;
MW          70.047;      // g/mol [origin=calculated method=formula-sum]
Tc          613.93;      // K   [origin=predictive method=joback]
Pc          62.098;      // bar [origin=predictive method=joback]
omega       0.4554;      // -   [origin=predictive method=lee-kesler]
Tb          403.87;      // K   [origin=predictive method=joback]
HvapTb      39294.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.54 0.2457 -0.00020793 7.089e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-ynoic acid" "2-propynoic acid" "propargylic acid" "propynoic acid" "acetylenecarboxylic acid" "carboxyacetylene" "propiolic acidd" "propiolicacid" "propynoate" "acetylenemonocarboxylate" "ynoate" "ynoates" );
gibbsFormation
{
    dHf_298   -163620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     295.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-146460.0
    phase     gas;
}
