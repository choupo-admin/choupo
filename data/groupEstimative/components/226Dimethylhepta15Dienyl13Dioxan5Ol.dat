/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2,6-dimethylhepta-1,5-dienyl)-1,3-dioxan-5-ol  (C13H22O3, CAS 4740-81-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        226Dimethylhepta15Dienyl13Dioxan5Ol;
formula     C13H22O3;
CAS         4740-81-2;
InChIKey    NUQAIRUKFLHEIK-UHFFFAOYSA-N;
MW          226.316;      // g/mol [origin=calculated method=formula-sum]
Tc          864.43;      // K   [origin=predictive method=joback]
Pc          22.547;      // bar [origin=predictive method=joback]
omega       0.9897;      // -   [origin=predictive method=lee-kesler]
Tb          666.08;      // K   [origin=predictive method=joback]
HvapTb      70427.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.408 1.40226 -0.0008838 2.157e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group CH=C; count 2; } { group OH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH; count 2; } { group dC; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxan-5-ol, 2-(2,6-dimethyl-1,5-heptadienyl)-" "1,3-dioxan-5-ol, 2-(2,6-dimethyl-1,5-heptadien-1-yl)-" );
gibbsFormation
{
    dHf_298   -479040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90400.0
    phase     gas;
}
