/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyhexadecanoic acid  (C16H32O3, CAS 764-67-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyhexadecanoicAcid;
formula     C16H32O3;
CAS         764-67-0;
InChIKey    JGHSBPIZNUXPLA-UHFFFAOYSA-N;
MW          272.429;      // g/mol [origin=calculated method=formula-sum]
Tc          986.42;      // K   [origin=predictive method=joback]
Pc          15.199;      // bar [origin=predictive method=joback]
omega       1.3023;      // -   [origin=predictive method=lee-kesler]
Tb          802.93;      // K   [origin=predictive method=joback]
HvapTb      84665.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.447 1.61452 -0.0009528 2.165e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylhexadecanoic acid" "2-hydroxypalmitic acid" "2-hydroxy palmitic acid" "2-hydroxy-hexadecanoic acid" "hexadecanoic acid, hydroxy-" "dl-alpha-hydroxypalmitic acid" "ambap10067-06-8" );
gibbsFormation
{
    dHf_298   -881350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     873.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-399330.0
    phase     gas;
}
