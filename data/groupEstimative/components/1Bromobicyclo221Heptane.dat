/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromobicyclo(2.2.1)heptane  (C7H11Br, CAS 13474-70-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromobicyclo221Heptane;
formula     C7H11Br;
CAS         13474-70-9;
InChIKey    IBGQMFDJANKDLZ-UHFFFAOYSA-N;
MW          175.069;      // g/mol [origin=calculated method=formula-sum]
Tc          678.18;      // K   [origin=predictive method=joback]
Pc          44.983;      // bar [origin=predictive method=joback]
omega       0.3251;      // -   [origin=predictive method=lee-kesler]
Tb          443.91;      // K   [origin=predictive method=joback]
HvapTb      36458.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-150.88 1.2911 -0.001355 5.729e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanylbicyclo[2.2.1]heptane" "1-bromobicyclo[2.2.1]heptane" "4-bromobicyclo[2.2.1]heptane" "bicyclo[2.2.1]heptane,1-bromo-" "bicyclo(2.2.1)heptane, 1-bromo-" );
gibbsFormation
{
    dHf_298   -6800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=126290.0
    phase     gas;
}
