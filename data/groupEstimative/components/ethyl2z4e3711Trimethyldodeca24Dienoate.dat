/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl (2z,4e)-3,7,11-trimethyldodeca-2,4-dienoate  (C17H30O2, CAS 41096-47-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2z4e3711Trimethyldodeca24Dienoate;
formula     C17H30O2;
CAS         41096-47-3;
InChIKey    FYQGBXGJFWXIPP-UHFFFAOYSA-N;
MW          266.425;      // g/mol [origin=calculated method=formula-sum]
Tc          836.30;      // K   [origin=predictive method=joback]
Pc          13.516;      // bar [origin=predictive method=joback]
omega       0.7731;      // -   [origin=predictive method=lee-kesler]
Tb          654.10;      // K   [origin=predictive method=joback]
HvapTb      60063.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.575 1.6158 -0.0009827 2.296e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 2; } { group dCH; count 3; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3,7,11-trimethyldodeca-2,4-dienoate" "2,4-dodecadienoic acid, 3,7,11-trimethyl-, ethyl ester, (z,z)-" "2,4-dodecadienoic acid, 3,7,11-trimethyl-, ethyl ester, (2e,4e)-" "2,4-dodecadienoic acid, 3,7,11-trimethyl-, ethyl ester, (2e,4e,7s)-" );
standardThermochemistry
{
    dHf_298   -497400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     833.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-71100.0
}
