/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-1,1,1,2,2-pentafluoropropane  (C3H2BrF5, CAS 422-01-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo11122Pentafluoropropane;
formula     C3H2BrF5;
CAS         422-01-5;
InChIKey    HKAWJXVJGNTQMW-UHFFFAOYSA-N;
MW          212.943;      // g/mol [origin=calculated method=formula-sum]
Tc          483.05;      // K   [origin=predictive method=joback]
Pc          37.916;      // bar [origin=predictive method=joback]
omega       0.3684;      // -   [origin=predictive method=lee-kesler]
Tb          324.29;      // K   [origin=predictive method=joback]
HvapTb      22030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.139 0.6376 -0.0006364 2.304e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group Br; count 1; } { group CF3; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 2; } { group F; count 5; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-1,1,1,2,2-pentakis(fluoranyl)propane" "2,2,3,3,3-pentafluoropropyl bromide" "propane, 3-bromo-1,1,1,2,2-pentafluoro-" );
gibbsFormation
{
    dHf_298   -1076970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-979670.0
    phase     gas;
}
