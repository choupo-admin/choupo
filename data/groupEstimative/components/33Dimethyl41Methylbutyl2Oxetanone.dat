/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyl-4-(1-methylbutyl)-2-oxetanone  (C10H18O2, CAS 18523-60-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyl41Methylbutyl2Oxetanone;
formula     C10H18O2;
CAS         18523-60-9;
InChIKey    YQQGTMIMGKGIMY-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          670.38;      // K   [origin=predictive method=joback]
Pc          23.842;      // bar [origin=predictive method=joback]
omega       0.5382;      // -   [origin=predictive method=lee-kesler]
Tb          484.22;      // K   [origin=predictive method=joback]
HvapTb      43154.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.648 1.33088 -0.0011726 4.492e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethyl-4-pentan-2-yl-oxetan-2-one" "3,3-dimethyl-4-pentan-2-yloxetan-2-one" "2-oxetanone, 3,3-dimethyl-4-(1-methylbutyl)-" "heptanoic acid, 2,2,4-trimethyl-3-hydroxy-, beta-lactone" );
gibbsFormation
{
    dHf_298   -498430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-219840.0
    phase     gas;
}
