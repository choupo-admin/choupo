/*--------------------------------*- Choupo -*-----------------------*\
  Component: decyl benzoate  (C17H26O2, CAS 36685-97-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decylBenzoate;
formula     C17H26O2;
CAS         36685-97-9;
InChIKey    CUSUFTNOPPMGBK-UHFFFAOYSA-N;
MW          262.393;      // g/mol [origin=calculated method=formula-sum]
Tc          864.72;      // K   [origin=predictive method=joback]
Pc          15.822;      // bar [origin=predictive method=joback]
omega       0.8468;      // -   [origin=predictive method=lee-kesler]
Tb          673.46;      // K   [origin=predictive method=joback]
HvapTb      63119.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.061 1.48512 -0.0008376 1.595e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, decyl ester" "benzoic acid, decylester" );
standardThermochemistry
{
    dHf_298   -474960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     763.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105700.0
}
