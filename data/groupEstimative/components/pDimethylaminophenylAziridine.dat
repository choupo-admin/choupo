/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-dimethylaminophenyl aziridine  (C10H14N2, CAS 82027-08-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pDimethylaminophenylAziridine;
formula     C10H14N2;
CAS         82027-08-5;
InChIKey    FSTZGHIBMJDRNA-UHFFFAOYSA-N;
MW          162.236;      // g/mol [origin=calculated method=formula-sum]
Tc          701.15;      // K   [origin=predictive method=joback]
Pc          33.490;      // bar [origin=predictive method=joback]
omega       0.5332;      // -   [origin=predictive method=lee-kesler]
Tb          492.08;      // K   [origin=predictive method=joback]
HvapTb      44928.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.25 1.25024 -0.00103156 3.406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(aziridin-1-yl)-n,n-dimethyl-aniline" "4-(aziridin-1-yl)-n,n-dimethylaniline" );
gibbsFormation
{
    dHf_298   209690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=438220.0
    phase     gas;
}
