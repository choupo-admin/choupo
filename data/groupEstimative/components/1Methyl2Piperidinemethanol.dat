/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-2-piperidinemethanol  (C7H15NO, CAS 20845-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl2Piperidinemethanol;
formula     C7H15NO;
CAS         20845-34-5;
InChIKey    HXXJMMLIEYAFOZ-UHFFFAOYSA-N;
MW          129.203;      // g/mol [origin=calculated method=formula-sum]
Tc          663.44;      // K   [origin=predictive method=joback]
Pc          38.104;      // bar [origin=predictive method=joback]
omega       0.7765;      // -   [origin=predictive method=lee-kesler]
Tb          479.66;      // K   [origin=predictive method=joback]
HvapTb      50155.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.359 0.95842 -0.0006274 1.588e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-methylpiperidin-2-yl)methanol" "1-methyl-2-hydroxymethylpiperidine" "(1-methyl-2-piperidyl)methan-1-ol" "1-methylpiperidine-2-methanol" "hxxjmmlieyafoz-uhfffaoysa-" "2-hydroxymethyl-1-methylpiperidine" "s950" );
gibbsFormation
{
    dHf_298   -212030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18570.0
    phase     gas;
}
