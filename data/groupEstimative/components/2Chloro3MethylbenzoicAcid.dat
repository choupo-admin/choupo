/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-3-methylbenzoic acid  (C8H7ClO2, CAS 15068-35-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro3MethylbenzoicAcid;
formula     C8H7ClO2;
CAS         15068-35-6;
InChIKey    LWOKLXMNGXXORN-UHFFFAOYSA-N;
MW          170.592;      // g/mol [origin=calculated method=formula-sum]
Tc          836.53;      // K   [origin=predictive method=joback]
Pc          37.500;      // bar [origin=predictive method=joback]
omega       0.7395;      // -   [origin=predictive method=lee-kesler]
Tb          602.22;      // K   [origin=predictive method=joback]
HvapTb      58551.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.8 0.62352 -0.00040152 9.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-3-methyl-benzoic acid" "2-chloro-m-toluic acid" "2-chloro-3-methyl-benzoic acid" "2-chloro-3-methylbenzoicacid" "2-chloro-3-methyl benzoic acid" "lwoklxmngxxorn-uhfffaoysa-" "m-toluicacid, 2-chloro- (6ci,7ci,8ci);" );
standardThermochemistry
{
    dHf_298   -360870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246210.0
}
