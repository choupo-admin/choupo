/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,9-dimethyl-4,8-decadien-3-ol  (C12H22O, CAS 67845-54-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        59Dimethyl48Decadien3Ol;
formula     C12H22O;
CAS         67845-54-9;
InChIKey    PQUSMVMWVMGVGN-UHFFFAOYSA-N;
MW          182.307;      // g/mol [origin=calculated method=formula-sum]
Tc          751.24;      // K   [origin=predictive method=joback]
Pc          21.513;      // bar [origin=predictive method=joback]
omega       0.8826;      // -   [origin=predictive method=lee-kesler]
Tb          573.98;      // K   [origin=predictive method=joback]
HvapTb      58673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.157 1.22358 -0.0008348 2.393e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group CH=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group dCH; count 2; } { group dC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,9-dimethyldeca-4,8-dien-3-ol" );
standardThermochemistry
{
    dHf_298   -233660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     643.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54240.0
}
