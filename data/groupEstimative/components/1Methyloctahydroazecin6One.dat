/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyloctahydroazecin-6-one  (C10H19NO, CAS 19641-26-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyloctahydroazecin6One;
formula     C10H19NO;
CAS         19641-26-0;
InChIKey    OIJNRMULDOGMMI-UHFFFAOYSA-N;
MW          169.268;      // g/mol [origin=calculated method=formula-sum]
Tc          780.57;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       0.4618;      // -   [origin=predictive method=lee-kesler]
Tb          545.69;      // K   [origin=predictive method=joback]
HvapTb      45398.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.37 1.02922 -0.000386 -1.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH2CO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 8; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylazecan-6-one" );
gibbsFormation
{
    dHf_298   -263720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17370.0
    phase     gas;
}
