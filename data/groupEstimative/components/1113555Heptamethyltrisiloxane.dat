name        1113555Heptamethyltrisiloxane;
formula     C7H21O2Si3;
CAS         1873-88-7;
InChIKey    SWGZAKPJNWCPRY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          221.498;      // g/mol [origin=calculated method=formula-sum]
Tc          587.90;      // K   [origin=predictive method=joback]
Pc          19.930;      // bar [origin=predictive method=joback]
omega       0.2575;      // -   [origin=predictive method=lee-kesler]
Tb          408.10;      // K   [origin=predictive method=joback]
HvapTb      36731.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (149.57 0.02704 0.000902 -5.805e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 7; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl-bis(trimethylsilyloxy)silicon" "bis(trimethylsiloxy)methylsilane" "trisiloxane, 1,1,1,3,5,5,5-heptamethyl-" "methylpolysilicone" "di(trimethylsiloxy)methylsilane" "methylbis(trimethylsilyloxy)silane" "1,1,1,3,5,5,5,-heptamethyltrisiloxane" "1,1,1,3,5,5,5-heptamethyltrisiloxane 1873-88-7" "dow corning 1107 water repellent and powder treatment" "2,2,4,6,6-pentamethyl-3,5-dioxa-2,4,6-trisilaheptane" );
gibbsFormation
{
