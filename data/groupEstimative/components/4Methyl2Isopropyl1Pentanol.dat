/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-2-isopropyl-1-pentanol  (C9H20O, CAS 55505-24-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl2Isopropyl1Pentanol;
formula     C9H20O;
CAS         55505-24-3;
InChIKey    CBHPZSADBWMIGE-UHFFFAOYSA-N;
MW          144.258;      // g/mol [origin=calculated method=formula-sum]
Tc          664.87;      // K   [origin=predictive method=joback]
Pc          25.872;      // bar [origin=predictive method=joback]
omega       0.8051;      // -   [origin=predictive method=lee-kesler]
Tb          496.38;      // K   [origin=predictive method=joback]
HvapTb      51143.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.048 0.91058 -0.0005058 1.042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-propan-2-yl-pentan-1-ol" "1-pentanol, 4-methyl-2-(1-methylethyl)-" );
standardThermochemistry
{
    dHf_298   -397160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-119240.0
}
