/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-diphenylhydroquinone  (C18H14O2, CAS 5422-91-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Diphenylhydroquinone;
formula     C18H14O2;
CAS         5422-91-3;
InChIKey    BVVCBZSERKSMIE-UHFFFAOYSA-N;
MW          262.308;      // g/mol [origin=calculated method=formula-sum]
Tc          1137.30;      // K   [origin=predictive method=joback]
Pc          35.856;      // bar [origin=predictive method=joback]
omega       1.0817;      // -   [origin=predictive method=lee-kesler]
Tb          857.70;      // K   [origin=predictive method=joback]
HvapTb      89180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-118.73 1.7268 -0.00149468 5.208e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 4; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 12; } { group dC_ring; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-diphenylbenzene-1,4-diol" "p-terphenyl-2',5'-diol" "[1,1':4',1''-terphenyl]-2',5'-diol" "(1,1':4',1''-terphenyl)-2',5'-diol" "hydroquinone,5-diphenyl-" "hydroquinone, 2,5-diphenyl-" "[1,1''-terphenyl]-2',5'-diol" );
gibbsFormation
{
    dHf_298   -71350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=119040.0
    phase     gas;
}
