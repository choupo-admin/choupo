/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydrofurfuryl acetate  (C7H12O3, CAS 637-64-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydrofurfurylAcetate;
formula     C7H12O3;
CAS         637-64-9;
InChIKey    AAQDYYFAFXGBFZ-UHFFFAOYSA-N;
MW          144.17;      // g/mol [origin=calculated method=formula-sum]
Tc          662.43;      // K   [origin=predictive method=joback]
Pc          34.039;      // bar [origin=predictive method=joback]
omega       0.4865;      // -   [origin=predictive method=lee-kesler]
Tb          460.21;      // K   [origin=predictive method=joback]
HvapTb      43350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.229 0.74272 -0.0003759 4.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH3COO; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxolan-2-ylmethyl ethanoate" "2-acetoxymethyloxolane" "oxolan-2-ylmethyl acetate" "2-furanmethanol, tetrahydro-, acetate" "furfuryl alcohol, tetrahydro-, acetate" "2-(acetoxymethyl)tetrahydrofuran" "tetrahydro-2-furanmethyl acetate" "tetrahydro-2-furylmethyl acetate" "tetrahydro-2-furanmethanol acetate" "(tetrahydrofuran-2-yl)methyl acetate" "2-furanmethanol, tetrahydro-, 2-acetate" "aaqdyyfafxgbfz-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -576610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-351880.0
}
