/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-himachalene  (C15H24, CAS 1461-03-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaHimachalene;
formula     C15H24;
CAS         1461-03-6;
InChIKey    LCOSCMLXPAQCLQ-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          819.22;      // K   [origin=predictive method=joback]
Pc          20.642;      // bar [origin=predictive method=joback]
omega       0.4612;      // -   [origin=predictive method=lee-kesler]
Tb          591.13;      // K   [origin=predictive method=joback]
HvapTb      51089.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.37 1.68408 -0.00130664 4.481e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5,5,9-tetramethyl-1,2,4a,6,7,8-hexahydrobenzo[7]annulene" "himachalene" "3,5,5,9-tetramethyl-2,4a,5,6,7,8-hexahydro-1h-benzo[7]annulene" "1h-benzocycloheptene, 2,4a,5,6,7,8-hexahydro-3,5,5,9-tetramethyl-, (r)-" "1h-benzocycloheptene, 2,4a.beta.,5,6,7,8-hexahydro-3,5,5,9-tetramethyl-, (+)-" "agn-pc-00c4r6" "(6xi)-himachal-1(11),4-diene" "1h-benzocycloheptene, 2,4a,5,6,7,8-hexahydro-3,5,5,9-tetramethyl-" "1h-benzocycloheptene, 2,4abeta,5,6,7,8-hexahydro-3,5,5,9-tetramethyl-, (+)-" "(6xi)-himachal-1(11),4-diene 3,5,5,9-tetramethyl-2,4a,5,6,7,8-hexahydro-1h-benzo[7]annulene" );
gibbsFormation
{
    dHf_298   -141740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161960.0
    phase     gas;
}
