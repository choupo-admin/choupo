/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-butyloctahydro-5h-inden-5-one  (C13H22O, CAS 72152-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Butyloctahydro5hInden5One;
formula     C13H22O;
CAS         72152-83-1;
InChIKey    NMJPUKVHEHWPMV-UHFFFAOYSA-N;
MW          194.318;      // g/mol [origin=calculated method=formula-sum]
Tc          804.75;      // K   [origin=predictive method=joback]
Pc          22.062;      // bar [origin=predictive method=joback]
omega       0.5526;      // -   [origin=predictive method=lee-kesler]
Tb          586.48;      // K   [origin=predictive method=joback]
HvapTb      48812.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.407 1.31702 -0.0006852 1.112e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 3; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-butyl-1,2,3,3a,4,6,7,7a-octahydroinden-5-one" "5h-inden-5-one, 7-butyloctahydro-" );
gibbsFormation
{
    dHf_298   -342570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13480.0
    phase     gas;
}
