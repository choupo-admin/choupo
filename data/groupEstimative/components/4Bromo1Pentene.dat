/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-1-pentene  (C5H9Br, CAS 31950-56-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo1Pentene;
formula     C5H9Br;
CAS         31950-56-8;
InChIKey    PDBJRGFNXXAAMO-UHFFFAOYSA-N;
MW          149.031;      // g/mol [origin=calculated method=formula-sum]
Tc          570.04;      // K   [origin=predictive method=joback]
Pc          40.108;      // bar [origin=predictive method=joback]
omega       0.3202;      // -   [origin=predictive method=lee-kesler]
Tb          376.40;      // K   [origin=predictive method=joback]
HvapTb      32101.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.861 0.50292 -0.0003457 9.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanylpent-1-ene" "4-bromopent-1-ene" "1-pentene, 4-bromo-" );
gibbsFormation
{
    dHf_298   -50.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90940.0
    phase     gas;
}
