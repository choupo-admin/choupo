/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentyl 4-aminobenzoate  (C12H17NO2, CAS 13110-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentyl4Aminobenzoate;
formula     C12H17NO2;
CAS         13110-37-7;
InChIKey    VKYWCHMXHQTCJQ-UHFFFAOYSA-N;
MW          207.273;      // g/mol [origin=calculated method=formula-sum]
Tc          849.07;      // K   [origin=predictive method=joback]
Pc          25.201;      // bar [origin=predictive method=joback]
omega       0.8227;      // -   [origin=predictive method=lee-kesler]
Tb          636.57;      // K   [origin=predictive method=joback]
HvapTb      63292.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.274 1.01252 -0.00054196 8.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentyl 4-azanylbenzoate" "n-pentyl 4-aminobenzoate" "n-amyl 4-aminobenzoate" "4-aminobenzoic acid n-pentyl ester" "benzoic acid, 4-amino-, pentyl ester" );
standardThermochemistry
{
    dHf_298   -349440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90980.0
}
