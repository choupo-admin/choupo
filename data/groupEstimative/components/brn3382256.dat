/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3382256  (C22H20O, CAS 63020-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3382256;
formula     C22H20O;
CAS         63020-27-9;
InChIKey    BWJLESRWSCBOIL-UHFFFAOYSA-N;
MW          300.401;      // g/mol [origin=calculated method=formula-sum]
Tc          1068.92;      // K   [origin=predictive method=joback]
Pc          18.247;      // bar [origin=predictive method=joback]
omega       0.9064;      // -   [origin=predictive method=lee-kesler]
Tb          828.92;      // K   [origin=predictive method=joback]
HvapTb      76820.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.648 1.70264 -0.0012352 3.65e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 10; } { group AC; count 6; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(ethoxymethyl)-12-methyl-benzo[a]anthracene" "9-methyl-10-ethoxymethyl-1,2-benzanthracene" "benz(a)anthracene, 7-ethoxymethyl-12-methyl-" "7-(ethoxymethyl)-12-methylbenzo[a]anthracene" );
gibbsFormation
{
    dHf_298   134230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=423200.0
    phase     gas;
}
