/*--------------------------------*- Choupo -*-----------------------*\
  Component: methoxyacetaldehyde  (C3H6O2, CAS 10312-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methoxyacetaldehyde;
formula     C3H6O2;
CAS         10312-83-1;
InChIKey    YSEFYOVWKJXNCH-UHFFFAOYSA-N;
MW          74.079;      // g/mol [origin=calculated method=formula-sum]
Tc          513.39;      // K   [origin=predictive method=joback]
Pc          47.628;      // bar [origin=predictive method=joback]
omega       0.3839;      // -   [origin=predictive method=lee-kesler]
Tb          339.32;      // K   [origin=predictive method=joback]
HvapTb      31402.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.061 0.20012 -2.14e-05 -3.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CHO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group O; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxyethanal" "2-methoxyacetaldehyde" "methoxyethanal" "acetaldehyde, methoxy-" "acetaldehyde, 2-methoxy-" "acetaldehyde, methoxy- (8ci,9ci)" "acetaldehyde, methoxy-(6ci,7ci,8ci,9ci)" "2-methoxyacetaldehyde;2-methoxyethanal; methoxyacetaldehyde; o-methylglycolaldehyde; a-methoxyacetaldehyde" );
standardThermochemistry
{
    dHf_298   -323050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     302.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230140.0
}
