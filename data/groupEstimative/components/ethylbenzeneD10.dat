/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylbenzene-d10  (C8D10, CAS 25837-05-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8D10 (delta D+10H-10; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethylbenzeneD10;
formula     C8D10;
CAS         25837-05-2;
InChIKey    YNQLUTRBYVCPMQ-CFTAVCBPSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          116.228;      // g/mol [origin=calculated method=formula-sum]
Tc          618.86;      // K   [origin=predictive method=joback]
Pc          36.509;      // bar [origin=predictive method=joback]
omega       0.2940;      // -   [origin=predictive method=lee-kesler]
Tb          409.32;      // K   [origin=predictive method=joback]
HvapTb      35678.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.289 0.68492 -0.0004426 1.095e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentadeuterio-6-(1,1,2,2,2-pentadeuterioethyl)benzene" "decadeuteroethylbenzene" "benzene-d5, ethyl-d5-" "benzene-1,2,3,4,5-d5, 6-(ethyl-1,1,2,2,2-d5)-" "(2h10)ethylbenzene" "de475" "ethylbenzene-d10 >99.5 atom % d" "benzene-d5,ethyl-d5- (8ci,9ci);(ethyl-d5)benzene-d5;ethylbenzene-d10;perdeuteroethylbenzene;" );
gibbsFormation
{
    dHf_298   28080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     361.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128890.0
    phase     gas;
}
