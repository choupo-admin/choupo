/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromocyclohexanol  (C6H11BrO, CAS 2425-33-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromocyclohexanol;
formula     C6H11BrO;
CAS         2425-33-4;
InChIKey    AAMCLCZHZXKWRV-UHFFFAOYSA-N;
MW          179.057;      // g/mol [origin=calculated method=formula-sum]
Tc          721.05;      // K   [origin=predictive method=joback]
Pc          46.849;      // bar [origin=predictive method=joback]
omega       0.7301;      // -   [origin=predictive method=lee-kesler]
Tb          510.10;      // K   [origin=predictive method=joback]
HvapTb      52184.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.75 0.7416 -0.00043 8.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylcyclohexan-1-ol" "2-bromocyclohexan-1-ol" "cyclohexanol, 2-bromo-" "trans-2-bromocyclohexanol" "(1s,2r)-2-bromo-cyclohexanol" "agn-pc-00eosm" "cyclohexanol, 2-bromo-, trans-" );
gibbsFormation
{
    dHf_298   -259090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-106120.0
    phase     gas;
}
