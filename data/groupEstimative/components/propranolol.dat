/*--------------------------------*- Choupo -*-----------------------*\
  Component: propranolol  (C16H21NO2, CAS 525-66-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propranolol;
formula     C16H21NO2;
CAS         525-66-6;
InChIKey    AQHHHDLHHXJYJD-UHFFFAOYSA-N;
MW          259.349;      // g/mol [origin=calculated method=formula-sum]
Tc          987.31;      // K   [origin=predictive method=joback]
Pc          22.915;      // bar [origin=predictive method=joback]
omega       1.2674;      // -   [origin=predictive method=lee-kesler]
Tb          780.21;      // K   [origin=predictive method=joback]
HvapTb      80537.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.488 1.44054 -0.00092188 2.254e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 7; } { group AC; count 3; } { group CH2NH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-naphthalen-1-yloxy-3-(propan-2-ylamino)propan-2-ol" "propanolol" "beta-propranolol" "propanalol" "dociton" "inderal" "euprovasin" "propanix" "sumial" "propranololo" "avlocardyl" "betalong" );
standardThermochemistry
{
    dHf_298   -198980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135960.0
}
