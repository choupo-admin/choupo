/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane, 1,1'-[(1e)-1,2-ethenediylbis(thio)]bis-  (C8H16S2, CAS 1120-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propane111e12EthenediylbisThioBis;
formula     C8H16S2;
CAS         1120-17-8;
InChIKey    WERZWRCQQURDDW-UHFFFAOYSA-N;
MW          176.336;      // g/mol [origin=calculated method=formula-sum]
Tc          740.10;      // K   [origin=predictive method=joback]
Pc          27.701;      // bar [origin=predictive method=joback]
omega       0.5000;      // -   [origin=predictive method=lee-kesler]
Tb          524.36;      // K   [origin=predictive method=joback]
HvapTb      46994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.634 0.77262 -0.0004148 7.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=CH; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-propylsulfanylethenylsulfanyl)propane" "propane, 1,1'-[(1z)-1,2-ethenediylbis(thio)]bis-" );
gibbsFormation
{
    dHf_298   -7490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162940.0
    phase     gas;
}
