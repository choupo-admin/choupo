/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetra acid  (C14H8O8, CAS 128-97-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraAcid;
formula     C14H8O8;
CAS         128-97-2;
InChIKey    OLAPPGSPBNVTRF-UHFFFAOYSA-N;
MW          304.21;      // g/mol [origin=calculated method=formula-sum]
Tc          1433.36;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       2.0589;      // -   [origin=predictive method=lee-kesler]
Tb          1167.54;      // K   [origin=predictive method=joback]
HvapTb      121978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.41 1.2164 -0.00092796 2.744e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 6; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 6; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene-1,4,5,8-tetracarboxylic acid" "1,4,5,8-naphthalenetetracarboxylic acid" "1,4,5,8-tetracarboxynaphthalene" "1,5,8-tetracarboxynaphthalene" "1,5,8-naphthalenetetracarboxylic acid" );
standardThermochemistry
{
    dHf_298   -1351650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     673.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1128100.0
}
