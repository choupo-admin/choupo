/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-naphthalenecarboxaldehyde, 5,6,7,8-tetrahydro-5,5,7,8,8-pentamethyl-  (C16H22O, CAS 113221-73-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H22O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Naphthalenecarboxaldehyde5678Tetrahydro55788Pentamethyl;
formula     C16H22O;
CAS         113221-73-1;
InChIKey    IQAZVEUAPIOTDC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          230.351;      // g/mol [origin=calculated method=formula-sum]
Tc          808.73;      // K   [origin=predictive method=joback]
Pc          20.109;      // bar [origin=predictive method=joback]
omega       0.4235;      // -   [origin=predictive method=lee-kesler]
Tb          580.89;      // K   [origin=predictive method=joback]
HvapTb      49602.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-179.93 2.0062 -0.00202492 8.606e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group C; count 2; } { group ACH; count 3; } { group AC; count 3; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5,7,8,8-pentamethyl-6,7-dihydronaphthalene-2-carbaldehyde" );
gibbsFormation
{
    dHf_298   -27090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     725.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243200.0
    phase     gas;
}
