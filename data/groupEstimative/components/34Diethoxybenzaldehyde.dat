/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-diethoxybenzaldehyde  (C11H14O3, CAS 2029-94-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H14O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        34Diethoxybenzaldehyde;
formula     C11H14O3;
CAS         2029-94-9;
InChIKey    SSTRYEXQYQGGAS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          194.23;      // g/mol [origin=calculated method=formula-sum]
Tc          709.83;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       0.5390;      // -   [origin=predictive method=lee-kesler]
Tb          509.18;      // K   [origin=predictive method=joback]
HvapTb      46127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.082 0.73264 -0.00040272 8.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 3; } { group CHO; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzaldehyde, 3,4-diethoxy-" "benzaldehyde,4-diethoxy-" "3,4-diethoxy benzaldehyde" "3,4-diethoxy-benzaldehyde" "benzaldehyde,3,4-diethoxy-" "sstryexqyqggas-uhfffaoysa-" "t383" );
gibbsFormation
{
    dHf_298   -244770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31150.0
    phase     gas;
}
