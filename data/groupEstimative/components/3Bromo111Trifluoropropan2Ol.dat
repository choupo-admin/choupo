/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-1,1,1-trifluoropropan-2-ol  (C3H4BrF3O, CAS 431-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo111Trifluoropropan2Ol;
formula     C3H4BrF3O;
CAS         431-34-5;
InChIKey    VBHIIZIQRDVGDH-UHFFFAOYSA-N;
MW          192.962;      // g/mol [origin=calculated method=formula-sum]
Tc          588.80;      // K   [origin=predictive method=joback]
Pc          47.366;      // bar [origin=predictive method=joback]
omega       0.8010;      // -   [origin=predictive method=lee-kesler]
Tb          420.72;      // K   [origin=predictive method=joback]
HvapTb      41251.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.761 0.5281 -0.0004654 1.566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group Br; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group F; count 3; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-1,1,1-tris(fluoranyl)propan-2-ol" "3-bromo-1,1,1-trifluoro-2-propanol" "2-propanol,3-bromo-1,1,1-trifluoro-" "3-bromo-1,1,1-trifluoro-propan-2-ol" "3-bromo-1,1,1-trifluoropropan-2-ol 431-34-5" );
gibbsFormation
{
    dHf_298   -833510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-732150.0
    phase     gas;
}
