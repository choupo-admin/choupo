/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylisopseudoionone  (C14H22O, CAS 1117-41-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylisopseudoionone;
formula     C14H22O;
CAS         1117-41-5;
InChIKey    PRMAVUPVLGOONQ-JOWSBRCASA-N;
MW          206.329;      // g/mol [origin=calculated method=formula-sum]
Tc          783.35;      // K   [origin=predictive method=joback]
Pc          18.452;      // bar [origin=predictive method=joback]
omega       0.6243;      // -   [origin=predictive method=lee-kesler]
Tb          585.91;      // K   [origin=predictive method=joback]
HvapTb      53618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.098 1.3656 -0.0009774 2.9396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH=C; count 3; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group dCH; count 3; } { group dC; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e,5e)-3,6,10-trimethylundeca-3,5,9-trien-2-one" "iso-methylpseudoionone" "pseudo-isomethyl ionone" "3,5,9-undecatrien-2-one, 3,6,10-trimethyl-" "2,6,9-trimethylundeca-2,6,8-trien-10-one" "3,6,10-trimethylundeca-3,5,9-trien-2-one" );
standardThermochemistry
{
    dHf_298   -122580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     695.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=153090.0
}
