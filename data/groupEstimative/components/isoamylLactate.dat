/*--------------------------------*- Choupo -*-----------------------*\
  Component: isoamyl lactate  (C8H16O3, CAS 19329-89-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isoamylLactate;
formula     C8H16O3;
CAS         19329-89-6;
InChIKey    CRORGGSWAKIXSA-UHFFFAOYSA-N;
MW          160.213;      // g/mol [origin=calculated method=formula-sum]
Tc          704.29;      // K   [origin=predictive method=joback]
Pc          28.505;      // bar [origin=predictive method=joback]
omega       0.9607;      // -   [origin=predictive method=lee-kesler]
Tb          532.16;      // K   [origin=predictive method=joback]
HvapTb      56712.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.952 0.75486 -0.0003536 3.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutyl 2-oxidanylpropanoate" "isopentyl lactate" "lactic acid isoamyl ester" "propanoic acid, 2-hydroxy-, 3-methylbutyl ester" "3-methylbutyl 2-hydroxypropanoate" "crorggswakixsa-uhfffaoysa-" "propanoic acid,2-hydroxy-, 3-methylbutyl ester" "2-hydroxy-propanoic acid 3-methylbutyl ester" "lacticacid, isopentyl ester (6ci,7ci,8ci);isopentyl alcohol, lactate (8ci);3-methylbutyl lactate;isoamyl lactate;isopentyl 2-hydroxypropanoate;isopentyl lactate;" );
gibbsFormation
{
    dHf_298   -688520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-435590.0
    phase     gas;
}
