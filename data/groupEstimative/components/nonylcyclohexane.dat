/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonylcyclohexane  (C15H30, CAS 2883-02-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonylcyclohexane;
formula     C15H30;
CAS         2883-02-5;
InChIKey    CLMFECCMAVQYQA-UHFFFAOYSA-N;
MW          210.405;      // g/mol [origin=calculated method=formula-sum]
Tc          748.02;      // K   [origin=predictive method=joback]
Pc          16.619;      // bar [origin=predictive method=joback]
omega       0.5986;      // -   [origin=predictive method=lee-kesler]
Tb          562.35;      // K   [origin=predictive method=joback]
HvapTb      49413.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.352 1.55092 -0.0008732 1.769e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-nonylcyclohexane" "1-cyclohexylnonane" "cyclohexane, nonyl-" "clmfeccmavqyqa-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -298610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     709.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99870.0
}
