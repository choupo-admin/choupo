/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(p-chlorophenylthio)butanol  (C10H13ClOS, CAS 15446-08-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4PChlorophenylthioButanol;
formula     C10H13ClOS;
CAS         15446-08-9;
InChIKey    QCOAGIKQNXMJSJ-UHFFFAOYSA-N;
MW          216.723;      // g/mol [origin=calculated method=formula-sum]
Tc          872.34;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       1.0061;      // -   [origin=predictive method=lee-kesler]
Tb          658.45;      // K   [origin=predictive method=joback]
HvapTb      68673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.974 0.85059 -0.00049496 9.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 1; } { group ACCl; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-chlorophenyl)sulfanylbutan-1-ol" "4-(p-chlorophenyl)thio-1-butanol" "4-((4-chlorophenyl)thio)-1-butanol" "4-(p-chlorphenylthio)-butanol [german]" "1-butanol, 4-(p-chlorophenyl)thio-" "4-(p-chlorphenylthio)-butanol" "1-butanol, 4-((4-chlorophenyl)thio)-" "1-butanol, 4-((4-chlorophenyl)thio)- (9ci)" );
gibbsFormation
{
    dHf_298   -150770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20470.0
    phase     gas;
}
