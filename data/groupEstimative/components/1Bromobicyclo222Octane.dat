/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromobicyclo[2.2.2]octane  (C8H13Br, CAS 7697-09-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromobicyclo222Octane;
formula     C8H13Br;
CAS         7697-09-8;
InChIKey    GKIJLFQCRFWQCZ-UHFFFAOYSA-N;
MW          189.096;      // g/mol [origin=calculated method=formula-sum]
Tc          711.02;      // K   [origin=predictive method=joback]
Pc          40.986;      // bar [origin=predictive method=joback]
omega       0.3412;      // -   [origin=predictive method=lee-kesler]
Tb          471.06;      // K   [origin=predictive method=joback]
HvapTb      38856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-156.91 1.3765 -0.001363 5.549e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanylbicyclo[2.2.2]octane" "bicyclo[2.2.2]octane, 1-bromo-" "bicyclo(2.2.2)octane, 1-bromo-" "4-bromobicyclo[2.2.2]octane" );
standardThermochemistry
{
    dHf_298   -33600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122610.0
}
