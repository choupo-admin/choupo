/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylpyrrolidine-2-carboxylic acid  (C11H13NO2, CAS 3005-68-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenylpyrrolidine2CarboxylicAcid;
formula     C11H13NO2;
CAS         3005-68-3;
InChIKey    VDEMEKSASUGYHM-UHFFFAOYSA-N;
MW          191.23;      // g/mol [origin=calculated method=formula-sum]
Tc          932.17;      // K   [origin=predictive method=joback]
Pc          35.347;      // bar [origin=predictive method=joback]
omega       0.8299;      // -   [origin=predictive method=lee-kesler]
Tb          682.63;      // K   [origin=predictive method=joback]
HvapTb      66226.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.04 1.1125 -0.0006898 1.516e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "l-proline, 3-phenyl-,(3r)-" "(2r,3r)-3-phenylpyrrolidine-2-carboxylic acid" );
gibbsFormation
{
    dHf_298   -306160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-73210.0
    phase     gas;
}
