/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-octanoylbromobenzene  (C14H19BrO, CAS 7295-48-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pOctanoylbromobenzene;
formula     C14H19BrO;
CAS         7295-48-9;
InChIKey    QMCHXDWPJPADAK-UHFFFAOYSA-N;
MW          283.209;      // g/mol [origin=calculated method=formula-sum]
Tc          885.92;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.8412;      // -   [origin=predictive method=lee-kesler]
Tb          671.61;      // K   [origin=predictive method=joback]
HvapTb      62877.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.894 1.20562 -0.00075466 1.8106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 4; } { group AC; count 2; } { group CH2CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-bromophenyl)octan-1-one" "p-bromophenyl heptyl ketone" "1-(4-bromophenyl)-octan-1-one" );
gibbsFormation
{
    dHf_298   -193480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     666.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55180.0
    phase     gas;
}
