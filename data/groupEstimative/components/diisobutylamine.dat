/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisobutylamine  (C8H19N, CAS 110-96-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisobutylamine;
formula     C8H19N;
CAS         110-96-3;
InChIKey    NJBCRXCAPCODGX-UHFFFAOYSA-N;
MW          129.247;      // g/mol [origin=calculated method=formula-sum]
Tc          607.90;      // K   [origin=predictive method=joback]
Pc          26.111;      // bar [origin=predictive method=joback]
omega       0.4884;      // -   [origin=predictive method=lee-kesler]
Tb          431.93;      // K   [origin=predictive method=joback]
HvapTb      39062.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.958 0.85188 -0.0004664 9.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-n-(2-methylpropyl)propan-1-amine" "1-propanamine, 2-methyl-n-(2-methylpropyl)-" "amine, diisobutyl-" "bis(beta-methylpropyl)amine" "n-isobutyl-2-methylpropan-1-amine" "n,n-bis(2-methylpropyl)amine" "bis(2-methylpropyl)amine" "2-methyl-n-(2-methylpropyl)-1-propanamine" "di-iso-butylamine" "diisobutylamine(6ci,8ci);di-iso-butylamine;n,n-bis(2-methylpropyl)amine;" );
standardThermochemistry
{
    dHf_298   -165540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100990.0
}
