/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-di(4-pyridyl)propane  (C13H14N2, CAS 17252-51-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Di4PyridylPropane;
formula     C13H14N2;
CAS         17252-51-6;
InChIKey    OGNCVVRIKNGJHQ-UHFFFAOYSA-N;
MW          198.269;      // g/mol [origin=calculated method=formula-sum]
Tc          916.37;      // K   [origin=predictive method=joback]
Pc          30.796;      // bar [origin=predictive method=joback]
omega       0.6256;      // -   [origin=predictive method=lee-kesler]
Tb          657.80;      // K   [origin=predictive method=joback]
HvapTb      61504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.617 1.14852 -0.00076432 1.981e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C5H4N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 2; } { group Nd_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3-pyridin-4-ylpropyl)pyridine" "4,4'-trimethylenedipyridine" "pyridine, 4,4'-(1,3-propanediyl)bis-" "4-(3-(4-pyridyl)propyl)pyridine" "pyridine,4'-trimethylenedi-" "1,3-bis(4-pyridyl)propane" "1,3-di(pyridin-4-yl)propane" "ogncvvrikngjhq-uhfffaoysa-" "pyridine, 4,4'-trimethylenedi-" "4,4'-propane-1,3-diyldipyridine" "pyridine,4'-(1,3-propanediyl)bis-" "4,4'-(propane-1,3-diyl)dipyridine" );
gibbsFormation
{
    dHf_298   226990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=437500.0
    phase     gas;
}
