/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexynoic acid  (C6H8O2, CAS 764-33-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HexynoicAcid;
formula     C6H8O2;
CAS         764-33-0;
InChIKey    AKYAUBWOTZJUBI-UHFFFAOYSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          705.97;      // K   [origin=predictive method=joback]
Pc          41.893;      // bar [origin=predictive method=joback]
omega       0.5845;      // -   [origin=predictive method=lee-kesler]
Tb          491.39;      // K   [origin=predictive method=joback]
HvapTb      48266.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.592 0.47482 -0.00028306 6.718e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group COOH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group tC; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-2-ynoic acid" "akyaubwotzjubi-uhfffaoysa-" "2-hexynoic acid, 96%" );
standardThermochemistry
{
    dHf_298   -245140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-141470.0
}
