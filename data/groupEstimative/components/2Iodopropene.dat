/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-iodopropene  (C3H5I, CAS 4375-96-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Iodopropene;
formula     C3H5I;
CAS         4375-96-6;
InChIKey    KWAHADSKPFGJQF-UHFFFAOYSA-N;
MW          167.973;      // g/mol [origin=calculated method=formula-sum]
Tc          573.22;      // K   [origin=predictive method=joback]
Pc          45.592;      // bar [origin=predictive method=joback]
omega       0.1678;      // -   [origin=predictive method=lee-kesler]
Tb          357.94;      // K   [origin=predictive method=joback]
HvapTb      31055.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.17 0.30772 -0.000246 8.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-iodanylprop-1-ene" "propene, 2-iodo-" "2-iodoprop-1-ene" "2-iodo-prop-1-ene" "1-propene, 2-iodo-" "1-propene, 2-iodo-(9ci)" "propene,2-iodo- (7ci,8ci); 2-iodo-1-propene; 2-iodopropene" );
standardThermochemistry
{
    dHf_298   87260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     319.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=111790.0
}
