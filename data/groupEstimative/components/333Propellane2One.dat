/*--------------------------------*- Choupo -*-----------------------*\
  Component: [3.3.3]propellane-2-one  (C11H16O, CAS 88288-20-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333Propellane2One;
formula     C11H16O;
CAS         88288-20-4;
InChIKey    REDJCHITNLSFNY-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          809.60;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.4219;      // -   [origin=predictive method=lee-kesler]
Tb          553.01;      // K   [origin=predictive method=joback]
HvapTb      42417.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-237.57 1.9243 -0.002019 8.69e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group C_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3.3.3)-propellane-2-one" "tetrahydro-1h,4h-3a,6a-propanopentalen-1-one" );
gibbsFormation
{
    dHf_298   -151170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=73930.0
    phase     gas;
}
