/*--------------------------------*- Choupo -*-----------------------*\
  Component: dl-c-allylglycine  (C5H9NO2, CAS 7685-44-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dlCAllylglycine;
formula     C5H9NO2;
CAS         7685-44-1;
InChIKey    WNNNWFKQCKFSDK-UHFFFAOYSA-N;
MW          115.132;      // g/mol [origin=calculated method=formula-sum]
Tc          739.20;      // K   [origin=predictive method=joback]
Pc          44.326;      // bar [origin=predictive method=joback]
omega       0.7708;      // -   [origin=predictive method=lee-kesler]
Tb          528.28;      // K   [origin=predictive method=joback]
HvapTb      53471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.761 0.5774 -0.0003903 1.042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanylpent-4-enoic acid" "allylglycine" "2-aminopent-4-enoic acid" "dl-2-allylglycine" "4-pentenoic acid, 2-amino-" "dl-2-amino-4-pentenoic acid" "dl-2-amino-1-pentenoic acid" "d-allylglycine" "2-allyl-l-glycine" "2-amino-4-pentenoic acid" "(s)-(-)-2-amino-4-pentenoic acid" "dl-2-aminopent-4-enoic acid" );
gibbsFormation
{
    dHf_298   -342860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200840.0
    phase     gas;
}
