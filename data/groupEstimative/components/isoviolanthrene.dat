/*--------------------------------*- Choupo -*-----------------------*\
  Component: isoviolanthrene  (C34H20, CAS 4430-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isoviolanthrene;
formula     C34H20;
CAS         4430-29-9;
InChIKey    HKSRHNHDUAHAAT-UHFFFAOYSA-N;
MW          428.534;      // g/mol [origin=calculated method=formula-sum]
Tc          1458.94;      // K   [origin=predictive method=joback]
Pc          15.949;      // bar [origin=predictive method=joback]
omega       1.2214;      // -   [origin=predictive method=lee-kesler]
Tb          1176.34;      // K   [origin=predictive method=joback]
HvapTb      109744.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-216.23 2.9152 -0.00270524 1.0004e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 16; } { group AC; count 14; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 16; } { group dC_ring; count 16; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dinaphtho[1,3-cd:1',2',3'-lm]perylene, 9,18-dihydro-" "benzo[rst]phenanthro[10,1,2-cde]pentaphene,9,18-dihydro- (9ci)" );
gibbsFormation
{
    dHf_298   791010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1092120.0
    phase     gas;
}
