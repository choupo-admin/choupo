/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-5-fluorobenzyl bromide  (C7H5Br2F, CAS 112399-50-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo5FluorobenzylBromide;
formula     C7H5Br2F;
CAS         112399-50-5;
InChIKey    CZLWYKAZAVYQIK-UHFFFAOYSA-N;
MW          267.923;      // g/mol [origin=calculated method=formula-sum]
Tc          767.03;      // K   [origin=predictive method=joback]
Pc          44.682;      // bar [origin=predictive method=joback]
omega       0.5512;      // -   [origin=predictive method=lee-kesler]
Tb          527.99;      // K   [origin=predictive method=joback]
HvapTb      46829.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.691 0.5591 -0.00041332 1.216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group Br; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-(bromomethyl)-4-fluoranyl-benzene" "1-bromo-2-(bromomethyl)-4-fluorobenzene" "5-fluoro-2-bromobenzyl bromide" "2-bromo-5-fluorobenzylbromide" "alpha,2-dibromo-5-fluorotoluene" "benzene, 1-bromo-2-(bromomethyl)-4-fluoro-" "3-methyl-4-fluorobenzaldehyde;4-fluoro-3-methylbenzaldehyde;" );
standardThermochemistry
{
    dHf_298   -117670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64960.0
}
