/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-(+)-2,2-dimethyl-1,3-dioxolane-4-methanol  (C6H12O3, CAS 22323-82-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s22Dimethyl13Dioxolane4Methanol;
formula     C6H12O3;
CAS         22323-82-6;
InChIKey    RNVYQYLELCKWAN-YFKPBYRVSA-N;
MW          132.159;      // g/mol [origin=calculated method=formula-sum]
Tc          688.34;      // K   [origin=predictive method=joback]
Pc          42.831;      // bar [origin=predictive method=joback]
omega       0.7802;      // -   [origin=predictive method=lee-kesler]
Tb          493.81;      // K   [origin=predictive method=joback]
HvapTb      53446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.169 0.99894 -0.0009098 3.619e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(4s)-2,2-dimethyl-1,3-dioxolan-4-yl]methanol" "s-glycerol acetonide" "(s)-(+)-1,2-isopropylideneglycerol" "1,2-isopropylidene-sn-glycerol" "1,3-dioxolane-4-methanol, 2,2-dimethyl-,(s)-" "d-(+)-solketal" "(s)-2,2-dimethyl-1,3-dioxolane-4-methanol" "glycerol acetonide" "d-alpha,beta-isopropylideneglycerol" "1,2-o-isopropylidene-d-glycerol" "(s)-solketal" "1,2-o-isopropylidene-sn-glycerine" );
standardThermochemistry
{
    dHf_298   -528020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     314.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-286070.0
}
