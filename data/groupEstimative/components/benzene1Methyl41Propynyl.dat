/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-methyl-4-(1-propynyl)-  (C10H10, CAS 2749-93-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1Methyl41Propynyl;
formula     C10H10;
CAS         2749-93-1;
InChIKey    NAYOGGQFBZAZIV-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          704.76;      // K   [origin=predictive method=joback]
Pc          34.521;      // bar [origin=predictive method=joback]
omega       0.2987;      // -   [origin=predictive method=lee-kesler]
Tb          469.06;      // K   [origin=predictive method=joback]
HvapTb      42944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.25 0.66564 -0.00039222 8.738e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group tC; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-prop-1-ynyl-benzene" "1-methyl-4-(1-propynyl)benzene" "1-methyl-4-(1-propyn-1-yl)-benzene" "ghl.pd_mitscher_leg0.392" "1-methyl-4-prop-1-ynylbenzene" "1-methyl-4-(prop-1-ynyl)benzene" "benzene,1-methyl-4-(1-propyn-1-yl)-" "benzene,1-methyl-4-(1-propynyl)- (9ci); propyne, 1-p-tolyl- (7ci); toluene,p-(1-propynyl)- (8ci); 1-(4-methylphenyl)-1-propyne; 1-(4-methylphenyl)propyne;1-(4-tolyl)-1-propyne; 1-(p-methylphenyl)propyne; 1-p-tolylpropyne; methylp-tolyl acetylene" );
gibbsFormation
{
    dHf_298   247630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=338900.0
    phase     gas;
}
