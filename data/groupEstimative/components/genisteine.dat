/*--------------------------------*- Choupo -*-----------------------*\
  Component: genisteine  (C15H26N2, CAS 90-39-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        genisteine;
formula     C15H26N2;
CAS         90-39-1;
InChIKey    SLRCCWJSBJZJBV-UHFFFAOYSA-N;
MW          234.387;      // g/mol [origin=calculated method=formula-sum]
Tc          828.98;      // K   [origin=predictive method=joback]
Pc          23.406;      // bar [origin=predictive method=joback]
omega       0.6177;      // -   [origin=predictive method=lee-kesler]
Tb          607.45;      // K   [origin=predictive method=joback]
HvapTb      53238.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-248.46 2.2514 -0.001759 5.496e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH; count 4; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 11; } { group CH_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "sparteine" ".beta.-isosparteine" "lupinidine" "7,14-methano-2h,6h-dipyrido[1,2-a:1',2'-e][1,5]diazocine, dodecahydro-, [7s-(7.alpha.,7a.alpha.,14.alpha.,14a.alpha.)]-" "7,14-methano-2h,6h-dipyrido[1,2-a:1',2'-e][1,5]diazocine, dodecahydro-, [7s-(7.alpha.,7a.alpha.,14.alpha.,14a.beta.)]-" "7,14-methano-2h,6h-dipyrido[1,2-a:1',2'-e][1,5]diazocine, dodecahydro-, [7s-(7.alpha.,7a.beta.,14.alpha.,14a.beta.)]-" "7,14-methano-2h,6h-dipyrido[1,2-a:1',2'-e][1,5]diazocine, dodecahydro-" "(7alpha)-sparteine" ".gamma.-isosparteine" "agn-pc-00q4ao" "dodecahydro-7,14-methano-dipyrido[1,2-a;1',2'-e][1,5]diazocine" "(6alpha,7alpha,9alpha)-sparteine" );
standardThermochemistry
{
    dHf_298   54850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=503680.0
}
