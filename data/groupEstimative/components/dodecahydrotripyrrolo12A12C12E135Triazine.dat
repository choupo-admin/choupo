/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecahydrotripyrrolo[1,2-a:1',2'-c:1'',2''-e][1,3,5]triazine  (C12H21N3, CAS 5981-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecahydrotripyrrolo12A12C12E135Triazine;
formula     C12H21N3;
CAS         5981-17-9;
InChIKey    POPXVWAQMYBXLI-UHFFFAOYSA-N;
MW          207.321;      // g/mol [origin=calculated method=formula-sum]
Tc          750.51;      // K   [origin=predictive method=joback]
Pc          30.090;      // bar [origin=predictive method=joback]
omega       0.6653;      // -   [origin=predictive method=lee-kesler]
Tb          543.11;      // K   [origin=predictive method=joback]
HvapTb      48396.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-247.0 2.1456 -0.001903 6.692e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 3; } { group CH2N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group CH_ring; count 3; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecahydro-tripyrrolo[1,2-a:1',2'-c:1'',2''-e][1,3,5]triazine" ""dodecahydrotripyrrolo(1,2-a:1',2'-c:1"""",2""""-e)(1,3,5)triazine"" ""dodecahydrotripyrrolo[1,2-a:1',2'-c:1"",2""-e][1,3,5]triazine"" );
gibbsFormation
{
    dHf_298   223120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=633210.0
    phase     gas;
}
