/*--------------------------------*- Choupo -*-----------------------*\
  Component: menthyl anthranilate  (C17H25NO2, CAS 134-09-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        menthylAnthranilate;
formula     C17H25NO2;
CAS         134-09-8;
InChIKey    SOXAGEOHPCXXIO-UHFFFAOYSA-N;
MW          275.392;      // g/mol [origin=calculated method=formula-sum]
Tc          991.97;      // K   [origin=predictive method=joback]
Pc          18.499;      // bar [origin=predictive method=joback]
omega       0.8174;      // -   [origin=predictive method=lee-kesler]
Tb          760.74;      // K   [origin=predictive method=joback]
HvapTb      73845.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.68 1.56256 -0.00078736 9.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 4; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5-methyl-2-propan-2-yl-cyclohexyl) 2-azanylbenzoate" "meradimate" "meradimate [inn]" "menthyl o-aminobenzoate" "menthyl-o-aminobenzoate" "anthranilic acid, p-menth-3-yl ester" "cyclohexanol, 5-methyl-2-(1-methylethyl)-, 2-aminobenzoate" "2-isopropyl-5-methylcyclohexyl 2-aminobenzoate" "5-methyl-2-(propan-2-yl)cyclohexyl 2-aminobenzoate" "5-methyl-2-(1-methylethyl)cyclohexanol-2-aminobenzoate" "cyclohexanol, 5-methyl-2-(1-methylethyl)-, 1-(2-aminobenzoate)" "meradimate (usan/inn)" );
standardThermochemistry
{
    dHf_298   -444280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     683.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42290.0
}
