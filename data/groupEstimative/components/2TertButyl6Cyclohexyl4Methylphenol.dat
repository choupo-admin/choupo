/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tert-butyl-6-cyclohexyl-4-methylphenol  (C17H26O, CAS 51806-69-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TertButyl6Cyclohexyl4Methylphenol;
formula     C17H26O;
CAS         51806-69-0;
InChIKey    JXGACSBVPLKCJV-UHFFFAOYSA-N;
MW          246.394;      // g/mol [origin=calculated method=formula-sum]
Tc          963.61;      // K   [origin=predictive method=joback]
Pc          21.119;      // bar [origin=predictive method=joback]
omega       0.7165;      // -   [origin=predictive method=lee-kesler]
Tb          722.14;      // K   [origin=predictive method=joback]
HvapTb      69183.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.87 1.82348 -0.00130728 3.814e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group C; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tert-butyl-6-cyclohexyl-4-methyl-phenol" "phenol, 2-cyclohexyl-6-(1,1-dimethylethyl)-4-methyl-" "2-cyclohexyl-6-(1,1-dimethylethyl)-4-methylphenol" );
standardThermochemistry
{
    dHf_298   -312360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     656.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58080.0
}
