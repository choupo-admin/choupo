/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4-methoxyphenyl)propan-1-ol  (C10H14O2, CAS 5406-18-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34MethoxyphenylPropan1Ol;
formula     C10H14O2;
CAS         5406-18-8;
InChIKey    NIIDHUCLROLCBU-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          766.71;      // K   [origin=predictive method=joback]
Pc          31.315;      // bar [origin=predictive method=joback]
omega       0.9470;      // -   [origin=predictive method=lee-kesler]
Tb          574.66;      // K   [origin=predictive method=joback]
HvapTb      59881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.983 0.78622 -0.00040376 6.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-methoxyphenyl)-1-propanol" "4-methoxybenzenepropanol" "benzenepropanol, 4-methoxy-" "benzenepropanol,4-methoxy-" "3-(p-methoxyphenyl)-1-propanol" "3-(p-methoxyphenyl)propanol" );
gibbsFormation
{
    dHf_298   -309120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105720.0
    phase     gas;
}
