name        1TertButyl2EthenylBenzene224466Hexamethyl135246Trioxatrisili;
formula     C27H44O3Si3;
CAS         66836-92-8;
InChIKey    KUJJLDGYGZPTAV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          500.901;      // g/mol [origin=calculated method=formula-sum]
Tc          1211.08;      // K   [origin=predictive method=joback]
Pc          8.377;      // bar [origin=predictive method=joback]
omega       0.5726;      // -   [origin=predictive method=lee-kesler]
Tb          964.97;      // K   [origin=predictive method=joback]
HvapTb      93576.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (94.56 1.5748 0.00017984 -5.399e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group C; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group ACH; count 9; } { group AC; count 3; } { group SiO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclotrisiloxane, 2,2,4,4,6,6-hexamethyl-, polymer with (1,1-dimethylethyl)ethenylbenzene and (1-methylethenyl)benzene" "cyclotrisiloxane, hexamethyl-, polymer with (1,1-dimethylethyl)ethenylbenzene and (1-methylethenyl)benzene" "1-ethenyl-2-tert-butyl-benzene; 2,2,4,4,6,6-hexamethyl-1,3,5,2,4,6-trioxatrisilinane; prop-1-en-2-ylbenzene" "1-tert-butyl-2-ethenylbenzene; 2,2,4,4,6,6-hexamethyl-1,3,5,2,4,6-trioxatrisilinane; prop-1-en-2-ylbenzene" );
gibbsFormation
{
    dHf_298   -767660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1329.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-152080.0
    phase     gas;
}
