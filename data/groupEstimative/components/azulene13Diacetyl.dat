/*--------------------------------*- Choupo -*-----------------------*\
  Component: azulene,1,3-diacetyl-  (C14H12O2, CAS 10487-55-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        azulene13Diacetyl;
formula     C14H12O2;
CAS         10487-55-5;
InChIKey    OOMBQAKQCAZTQJ-UHFFFAOYSA-N;
MW          212.248;      // g/mol [origin=calculated method=formula-sum]
Tc          919.78;      // K   [origin=predictive method=joback]
Pc          27.995;      // bar [origin=predictive method=joback]
omega       0.8115;      // -   [origin=predictive method=lee-kesler]
Tb          683.28;      // K   [origin=predictive method=joback]
HvapTb      65490.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.87 1.07624 -0.00073424 1.9412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-ethanoylazulen-1-yl)ethanone" "azulene, 1,3-diacetyl-" "1-(3-acetylazulen-1-yl)ethanone" "1,1'-azulene-1,3-diyldiethanone" );
standardThermochemistry
{
    dHf_298   -152790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8960.0
}
