/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl glycolate  (C9H10O3, CAS 30379-58-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylGlycolate;
formula     C9H10O3;
CAS         30379-58-9;
InChIKey    VPYJBEIOKFRWQZ-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          781.58;      // K   [origin=predictive method=joback]
Pc          36.553;      // bar [origin=predictive method=joback]
omega       0.9893;      // -   [origin=predictive method=lee-kesler]
Tb          582.60;      // K   [origin=predictive method=joback]
HvapTb      61990.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.498 0.7591 -0.0004328 7.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl) 2-oxidanylethanoate" "benzyl 2-hydroxyacetate" "acetic acid, hydroxy-, phenylmethyl ester" "benzyl-glycolate" "benzyl hydroxyacetate" "benzyl (1)-glycolate" );
standardThermochemistry
{
    dHf_298   -462070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-309880.0
}
