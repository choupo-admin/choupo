/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentanedioic acid, didecyl ester  (C25H48O4, CAS 3634-94-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentanedioicAcidDidecylEster;
formula     C25H48O4;
CAS         3634-94-4;
InChIKey    FFPZYKQFAKXVSW-UHFFFAOYSA-N;
MW          412.655;      // g/mol [origin=calculated method=formula-sum]
Tc          1089.22;      // K   [origin=predictive method=joback]
Pc          7.682;      // bar [origin=predictive method=joback]
omega       0.7096;      // -   [origin=predictive method=lee-kesler]
Tb          888.04;      // K   [origin=predictive method=joback]
HvapTb      86058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.981 2.26924 -0.001147 1.721e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 19; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 21; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "didecyl pentanedioate" "didecyl glutarate" "glutaric acid, didecyl ester" "pentanedioic acid, 1,5-didecyl ester" "pentanedioic acid,1,5-didecyl ester" "pentanedioic acid, bis-(isodecyl) ester" "glutaricacid, didecyl ester (7ci,8ci);pentanedioic acid, didecyl ester (9ci);didecylglutarate;didecyl pentanedioate;glutaric acid, didecyl ester;" );
gibbsFormation
{
    dHf_298   -1193890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1232.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-461120.0
    phase     gas;
}
