/*--------------------------------*- Choupo -*-----------------------*\
  Component: di-n-nonyl sulfide  (C18H38S, CAS 929-98-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diNNonylSulfide;
formula     C18H38S;
CAS         929-98-6;
InChIKey    KMKSVAGOBVUFRO-UHFFFAOYSA-N;
MW          286.562;      // g/mol [origin=calculated method=formula-sum]
Tc          853.25;      // K   [origin=predictive method=joback]
Pc          11.656;      // bar [origin=predictive method=joback]
omega       0.8390;      // -   [origin=predictive method=lee-kesler]
Tb          680.22;      // K   [origin=predictive method=joback]
HvapTb      62479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.126 1.70823 -0.0009152 1.754e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-nonylsulfanylnonane" "1-(nonylsulfanyl)nonane" "dinonyl sulfide" "nonyl sulfide" "nonylthiononane" "nonane, 1-(nonylthio)-" );
standardThermochemistry
{
    dHf_298   -372980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     918.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133800.0
}
