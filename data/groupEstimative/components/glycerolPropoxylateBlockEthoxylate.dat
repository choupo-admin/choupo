/*--------------------------------*- Choupo -*-----------------------*\
  Component: glycerol propoxylate-block-ethoxylate  (C8H22O7, CAS 9082-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glycerolPropoxylateBlockEthoxylate;
formula     C8H22O7;
CAS         9082-00-2;
InChIKey    VKVYTKULMKDWLP-UHFFFAOYSA-N;
MW          230.257;      // g/mol [origin=calculated method=formula-sum]
Tc          1311.43;      // K   [origin=predictive method=joback]
Pc          44.326;      // bar [origin=predictive method=joback]
omega       1.6779;      // -   [origin=predictive method=lee-kesler]
Tb          1029.82;      // K   [origin=predictive method=joback]
HvapTb      149967.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (110.925 0.60122 0.000199 -2.828e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 2; } { group OH; count 5; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 2; } { group OH; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-diol;propane-1,2-diol;propane-1,2,3-triol" );
gibbsFormation
{
    dHf_298   -1507860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1020.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1155660.0
    phase     gas;
}
