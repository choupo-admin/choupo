/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethynylnaphthalene  (C12H8, CAS 2949-26-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethynylnaphthalene;
formula     C12H8;
CAS         2949-26-0;
InChIKey    IZXPFTLEVNQLGD-UHFFFAOYSA-N;
MW          152.196;      // g/mol [origin=calculated method=formula-sum]
Tc          763.64;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.3706;      // -   [origin=predictive method=lee-kesler]
Tb          514.92;      // K   [origin=predictive method=joback]
HvapTb      46742.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.29 0.9078 -0.00072581 2.3169e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethynyl-naphthalene" "naphthalene, 2-ethynyl-" "naphthylene-2-acetylene" "2-ethynyl naphtalene" "2-ethynylnaphthalene;2-naphthylethyne;b-ethynylnaphthalene;b-naphthylacetylene;(naphthalen-2-yl)ethyne;(2-naphthyl)acetylene;" );
standardThermochemistry
{
    dHf_298   417020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     371.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=482660.0
}
