/*--------------------------------*- Choupo -*-----------------------*\
  Component: pipobroman  (C10H16Br2N2O2, CAS 54-91-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pipobroman;
formula     C10H16Br2N2O2;
CAS         54-91-1;
InChIKey    NJBFOOCLYDNZJN-UHFFFAOYSA-N;
MW          356.058;      // g/mol [origin=calculated method=formula-sum]
Tc          928.43;      // K   [origin=predictive method=joback]
Pc          33.412;      // bar [origin=predictive method=joback]
omega       1.1586;      // -   [origin=predictive method=lee-kesler]
Tb          709.02;      // K   [origin=predictive method=joback]
HvapTb      68696.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.786 1.3898 -0.00108 3.3032e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group Br; count 2; } { group CON_CH2_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 4; } { group Br; count 2; } { group CdO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-1-[4-(3-bromanylpropanoyl)piperazin-1-yl]propan-1-one" "vercyte" "amedel" "pipobromanum" "pipobromanum [inn-latin]" "piperazine, 1,4-bis(3-bromo-1-oxopropyl)-" "1,4-bis(3-bromopropionyl)piperazine" "vercyte (tn)" "pipobroman [usan:inn]" "1,4-bis(3-bromopropanoyl)piperazine" "n,n-bis-(3-bromopropionyl)-piperazine" "piperazine, 1,4-bis(3-bromopropionyl)-" );
standardThermochemistry
{
    dHf_298   -200190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     705.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82040.0
}
