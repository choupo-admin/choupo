/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenylhexanoic acid  (C12H16O2, CAS 24716-09-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PhenylhexanoicAcid;
formula     C12H16O2;
CAS         24716-09-4;
InChIKey    PGIOANNVJQQCDT-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          862.67;      // K   [origin=predictive method=joback]
Pc          26.516;      // bar [origin=predictive method=joback]
omega       0.8418;      // -   [origin=predictive method=lee-kesler]
Tb          645.91;      // K   [origin=predictive method=joback]
HvapTb      61358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.007 1.12162 -0.000736 1.846e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 5; } { group ACCH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "alpha-butylphenylacetic acid" "alpha-butylbenzeneacetic acid" "(+-)-2-phenylhexanoic acid" "hexanoic acid, 2-phenyl-" "alpha-phenylcaproic acid" "benzeneacetic acid, alpha-butyl-" "benzeneacetic acid, alpha-butyl- (9ci)" );
standardThermochemistry
{
    dHf_298   -410030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183780.0
}
