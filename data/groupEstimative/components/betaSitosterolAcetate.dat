/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-sitosterol acetate  (C31H52O2, CAS 915-05-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaSitosterolAcetate;
formula     C31H52O2;
CAS         915-05-9;
InChIKey    PBWOIPCULUXTNY-UHFFFAOYSA-N;
MW          456.755;      // g/mol [origin=calculated method=formula-sum]
Tc          1235.10;      // K   [origin=predictive method=joback]
Pc          8.126;      // bar [origin=predictive method=joback]
omega       0.7371;      // -   [origin=predictive method=lee-kesler]
Tb          1004.70;      // K   [origin=predictive method=joback]
HvapTb      89080.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-291.587 3.85624 -0.00304564 1.0375e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 11; } { group CH; count 8; } { group C; count 2; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 3; } { group CH; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[17-(5-ethyl-6-methyl-heptan-2-yl)-10,13-dimethyl-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] ethanoate" ".beta.-sitosterol acetate" "clionasterol acetate" "stigmast-5-en-3-yl acetate" "stigmast-5-en-3-ol, acetate, (3.beta.)-" "24beta-ethylcholesteryl acetate" "[(3s,8s,9s,10r,13r,14s,17r)-17-[(2r)-5-ethyl-6-methylheptan-2-yl]-10,13-dimethyl-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] acetate" "[17-(5-ethyl-6-methylheptan-2-yl)-10,13-dimethyl-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] acetate" "14-(5-ethyl-6-methylheptan-2-yl)-2,15-dimethyltetracyclo[8.7.0.0^{2,7}.0^{11,15}]heptadec-7-en-5-yl acetate" );
gibbsFormation
{
    dHf_298   -740120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1093.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61170.0
    phase     gas;
}
