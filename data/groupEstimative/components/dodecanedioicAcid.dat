/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecanedioic acid  (C12H22O4, CAS 693-23-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecanedioicAcid;
formula     C12H22O4;
CAS         693-23-2;
InChIKey    TVIDDXQYHWJXFK-UHFFFAOYSA-N;
MW          230.304;      // g/mol [origin=calculated method=formula-sum]
Tc          958.27;      // K   [origin=predictive method=joback]
Pc          20.812;      // bar [origin=predictive method=joback]
omega       1.3188;      // -   [origin=predictive method=lee-kesler]
Tb          765.18;      // K   [origin=predictive method=joback]
HvapTb      76634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.18 1.2454 -0.0007742 1.876e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,12-dodecanedioic acid" "1,10-decanedicarboxylic acid" "decamethylenedicarboxylic acid" "1,10-dicarboxydecane" "decane-1,10-dicarboxylic acid" "n-dodecanedioate" "corfree m 2" "n-dodecanedioic acid" "1,12-dodecanedioate" "n-dodecane-a,w-dioate" "sl-ah" "decamethylenedicarboxylate" );
gibbsFormation
{
    dHf_298   -991550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     729.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-637660.0
    phase     gas;
}
