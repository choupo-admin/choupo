/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bis(2-chloroethyl)aminobenzaldehyde  (C11H13Cl2NO, CAS 1208-03-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H13Cl2NO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Bis2ChloroethylAminobenzaldehyde;
formula     C11H13Cl2NO;
CAS         1208-03-3;
InChIKey    PXUFHXLGUJLBMI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          246.131;      // g/mol [origin=calculated method=formula-sum]
Tc          756.95;      // K   [origin=predictive method=joback]
Pc          25.252;      // bar [origin=predictive method=joback]
omega       0.5656;      // -   [origin=predictive method=lee-kesler]
Tb          546.66;      // K   [origin=predictive method=joback]
HvapTb      51458.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.126 1.056 -0.00084516 2.724e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2N; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[bis(2-chloroethyl)amino]benzaldehyde" "4-(n,n-bis(2-chloroethyl)amino)benzaldehyde" "4-[bis-(2-chloroethyl)amino]benzaldehyde" "p-bis(beta-chloroethyl)aminobenzaldehyde" "4-(bis(2-chloroethyl)amino)benzaldehyde" "benzaldehyde, p-(bis(2-chloroethyl)amino)-" "benzaldehyde, 4-(bis(2-chloroethyl)amino)-" "benzaldehyde, 4-[bis(2-chloroethyl)amino]-" "benzaldehyde, p-[bis(2-chloroethyl)amino]-" "4-[n,n-bis(2-chloroethyl)amino]benzaldehyde" "vhr dn2g2g" "p-bis(2-chloroethyl)aminobenzaldehyde" );
gibbsFormation
{
    dHf_298   67190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=275400.0
    phase     gas;
}
