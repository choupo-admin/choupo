/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylumbelliferyl palmitate  (C26H38O4, CAS 17695-48-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethylumbelliferylPalmitate;
formula     C26H38O4;
CAS         17695-48-6;
InChIKey    QKQVFFACWLFRRX-UHFFFAOYSA-N;
MW          414.586;      // g/mol [origin=calculated method=formula-sum]
Tc          1173.91;      // K   [origin=predictive method=joback]
Pc          9.503;      // bar [origin=predictive method=joback]
omega       0.9217;      // -   [origin=predictive method=lee-kesler]
Tb          958.84;      // K   [origin=predictive method=joback]
HvapTb      92888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.216 2.23784 -0.00134076 2.964e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methyl-2-oxidanylidene-chromen-7-yl) hexadecanoate" "4-methyl-2-oxo-2h-chromen-7-yl palmitate" "palmitic acid 4-methylumbelliferyl ester" "4-methylumbelliferone palmitate" "palmitoyl 4-methylumbelliferone" "7-hydroxy-4-methylcoumarin palmitate" "(4-methyl-2-oxochromen-7-yl) hexadecanoate" "4-methyl-2-oxo-2h-1-benzopyran-7-yl palmitate" "hexadecanoic acid 4-methyl-2-oxo-2h-1-benzopyran-7-yl ester" "palmitic acid,ester with 7-hydroxy-4-methylcoumarin (8ci); coumarin, 7-hydroxy-4-methyl-,palmitate (8ci); 4-methylumbelliferone palmitate; 4-methylumbelliferylpalmitate; palmitoyl 4-methylumbelliferone" );
standardThermochemistry
{
    dHf_298   -855330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1041.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-258660.0
}
