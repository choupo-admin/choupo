/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7-methano-1h-indene, 3a,4,7,7a-tetrahydro-, polymer with rel-(1r,3r)-1,3-dimethylcyclohexane  (C18H28, CAS 70729-74-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        47Methano1hIndene3a477aTetrahydroPolymerWithRel1r3r13Dimethy;
formula     C18H28;
CAS         70729-74-7;
InChIKey    FYZNHDPHKLVZHI-OBQMRBKOSA-N;
MW          244.422;      // g/mol [origin=calculated method=formula-sum]
Tc          880.29;      // K   [origin=predictive method=joback]
Pc          17.246;      // bar [origin=predictive method=joback]
omega       0.4644;      // -   [origin=predictive method=lee-kesler]
Tb          645.86;      // K   [origin=predictive method=joback]
HvapTb      56262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-166.67 1.90784 -0.00109956 2.154e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 6; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 6; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dicyclopentadiene, polymer with trans-1,3-dimethylcyclohexane" );
gibbsFormation
{
    dHf_298   -185030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=235020.0
    phase     gas;
}
