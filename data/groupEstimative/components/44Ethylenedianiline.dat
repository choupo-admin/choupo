/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-ethylenedianiline  (C14H16N2, CAS 621-95-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Ethylenedianiline;
formula     C14H16N2;
CAS         621-95-4;
InChIKey    UHNUHZHQLCGZDA-UHFFFAOYSA-N;
MW          212.296;      // g/mol [origin=calculated method=formula-sum]
Tc          981.39;      // K   [origin=predictive method=joback]
Pc          30.323;      // bar [origin=predictive method=joback]
omega       0.8481;      // -   [origin=predictive method=lee-kesler]
Tb          728.30;      // K   [origin=predictive method=joback]
HvapTb      73916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.068 1.1808 -0.00075292 1.786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group ACCH2; count 2; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(4-aminophenyl)ethyl]aniline" "4,4'-diaminobibenzyl" "benzenamine, 4,4'-(1,2-ethanediyl)bis-" "alpha,alpha'-bi-p-toluidine" "1,2-bis(p-aminophenyl)ethane" "4,4'-diaminodibenzyl" ".alpha.,.alpha.'-bi-p-toluidine" "4,4'-ethylenebis(aniline)" "4-[2-(4-aminophenyl)ethyl]phenylamine" "aniline, 4,4'-ethylenedi-" "aniline, p,p'-ethylenedi-" "aniline,4'-ethylenedi-" );
standardThermochemistry
{
    dHf_298   185410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=405460.0
}
