/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorocyclopentane  (C5H9Cl, CAS 930-28-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorocyclopentane;
formula     C5H9Cl;
CAS         930-28-9;
InChIKey    NDTCXABJQNJPCF-UHFFFAOYSA-N;
MW          104.577;      // g/mol [origin=calculated method=formula-sum]
Tc          572.47;      // K   [origin=predictive method=joback]
Pc          41.356;      // bar [origin=predictive method=joback]
omega       0.2197;      // -   [origin=predictive method=lee-kesler]
Tb          366.71;      // K   [origin=predictive method=joback]
HvapTb      31366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.25 0.6173 -0.000396 9.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranylcyclopentane" "cyclopentyl chloride" "cyclopentane, chloro-" "chloroclopentane" "chlorocyclopentante" "chloro-cyclopentane" "sfphadilimup@" "h294" );
gibbsFormation
{
    dHf_298   -101790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     333.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15840.0
    phase     gas;
}
