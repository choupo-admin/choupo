/*--------------------------------*- Choupo -*-----------------------*\
  Component: dienochlor  (C10Cl10, CAS 2227-17-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dienochlor;
formula     C10Cl10;
CAS         2227-17-0;
InChIKey    LWLJUMBEZJHXHV-UHFFFAOYSA-N;
MW          474.61;      // g/mol [origin=calculated method=formula-sum]
Tc          1157.31;      // K   [origin=predictive method=joback]
Pc          23.248;      // bar [origin=predictive method=joback]
omega       0.7985;      // -   [origin=predictive method=lee-kesler]
Tb          870.22;      // K   [origin=predictive method=joback]
HvapTb      86380.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.27 1.169 -0.001457 6.904e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Cl_C=C_; count 8; } { group C=C; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group C_ring; count 2; } { group dC_ring; count 8; } { group Cl; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(chloranyl)-5-[1,2,3,4,5-pentakis(chloranyl)cyclopenta-2,4-dien-1-yl]cyclopenta-1,3-diene" "decachlor" "pentac" "pentac sp" "pentac wp" "hooker hrs-16" "dienochlore" "decachlorobi-2,4-cyclopentadien-1-yl" "hrs 16a" "bis(pentachlorocyclopentadienyl)" "pentac (50wp)" "dienochlor [bsi:iso]" );
standardThermochemistry
{
    dHf_298   -116330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     719.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18940.0
}
