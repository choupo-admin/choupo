/*--------------------------------*- Choupo -*-----------------------*\
  Component: valeric acid, trimethylsilyl ester  (C8H18O2Si, CAS 26429-16-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H18O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        valericAcidTrimethylsilylEster;
formula     C8H18O2Si;
CAS         26429-16-3;
InChIKey    KBBNGLHDTQGESG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          174.315;      // g/mol [origin=calculated method=formula-sum]
Tc          619.78;      // K   [origin=predictive method=joback]
Pc          22.654;      // bar [origin=predictive method=joback]
omega       0.4453;      // -   [origin=predictive method=lee-kesler]
Tb          442.26;      // K   [origin=predictive method=joback]
HvapTb      41103.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.843 0.50288 9.8e-05 -1.903e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH2COO; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethylsilyl pentanoate" "pentanoic acid, trimethylsilyl ester" "valeric acid trimethylsilyl ester" );
standardThermochemistry
{
    dHf_298   -637350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     645.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-398650.0
}
