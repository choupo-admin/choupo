/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1':2'-dihydro-4'-methyl-3:4-benzpyrene  (C21H16, CAS 7499-32-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dihydro4Methyl34Benzpyrene;
formula     C21H16;
CAS         7499-32-3;
InChIKey    YIXWJCYFBRJSQB-UHFFFAOYSA-N;
MW          268.359;      // g/mol [origin=calculated method=formula-sum]
Tc          1052.09;      // K   [origin=predictive method=joback]
Pc          22.568;      // bar [origin=predictive method=joback]
omega       0.8274;      // -   [origin=predictive method=lee-kesler]
Tb          795.74;      // K   [origin=predictive method=joback]
HvapTb      72896.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-124.0 1.79832 -0.00154676 5.404e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 7; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methyl-9,10-dihydrobenzo[a]pyrene" "9,10-dihydro-7-methylbenzo(a)pyrene" "benzo(a)pyrene, 9,10-dihydro-7-methyl-" "9,10-dihydro-7-methylbenzo[a]pyrene" "benzo[a]pyrene,10-dihydro-7-methyl-" "7-methyl-9,10-dihydrobenzo[pqr]tetraphene" );
gibbsFormation
{
    dHf_298   374920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=590710.0
    phase     gas;
}
