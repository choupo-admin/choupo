/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha.,.beta.-dibromostyrene  (C8H6Br2, CAS 6607-46-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaBetaDibromostyrene;
formula     C8H6Br2;
CAS         6607-46-1;
InChIKey    PBTWQCPURDEMRQ-UHFFFAOYSA-N;
MW          261.944;      // g/mol [origin=calculated method=formula-sum]
Tc          807.90;      // K   [origin=predictive method=joback]
Pc          46.913;      // bar [origin=predictive method=joback]
omega       0.4754;      // -   [origin=predictive method=lee-kesler]
Tb          545.68;      // K   [origin=predictive method=joback]
HvapTb      48586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.78 0.7812 -0.0006715 2.269e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)ethenylbenzene" "((e)-1,2-dibromo-vinyl)-benzene" "benzene, (1,2-dibromoethenyl)-" "benzene,(1,2-dibromoethenyl)-" "styrene, a,b-dibromo- (6ci,7ci,8ci); 1,2-dibromo-2-phenylethylene;1,2-dibromostyrene; a,b-dibromostyrene" );
gibbsFormation
{
    dHf_298   188170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=229200.0
    phase     gas;
}
