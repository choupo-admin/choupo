/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-tert-butyl-2-methyl-1,4-dioxaspiro[4.5]decane  (C13H24O2, CAS 62406-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8TertButyl2Methyl14Dioxaspiro45Decane;
formula     C13H24O2;
CAS         62406-83-1;
InChIKey    HFFWINBWALELJR-UHFFFAOYSA-N;
MW          212.333;      // g/mol [origin=calculated method=formula-sum]
Tc          804.11;      // K   [origin=predictive method=joback]
Pc          22.828;      // bar [origin=predictive method=joback]
omega       0.4494;      // -   [origin=predictive method=lee-kesler]
Tb          573.84;      // K   [origin=predictive method=joback]
HvapTb      51310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-163.78 1.88748 -0.0015594 5.468e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group C; count 2; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-tert-butyl-3-methyl-1,4-dioxaspiro[4.5]decane" "1,4-dioxaspiro(4.5)decane, 8-(1,1-dimethylethyl)-2-methyl-" "1,4-dioxaspiro[4.5]decane, 8-(1,1-dimethylethyl)-2-methyl-" "p-tert-butylcyclohexanone propylene glycol ketal" "8-(1,1-dimethylethyl)-2-methyl-1,4-dioxaspiro(4.5)decane" );
standardThermochemistry
{
    dHf_298   -468540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-50920.0
}
