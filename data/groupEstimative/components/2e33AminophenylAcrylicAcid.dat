/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2e)-3-(3-aminophenyl)acrylic acid  (C9H9NO2, CAS 127791-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2e33AminophenylAcrylicAcid;
formula     C9H9NO2;
CAS         127791-53-1;
InChIKey    JNXMJSYJCFTLJB-UHFFFAOYSA-N;
MW          163.176;      // g/mol [origin=calculated method=formula-sum]
Tc          901.28;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       0.8962;      // -   [origin=predictive method=lee-kesler]
Tb          659.38;      // K   [origin=predictive method=joback]
HvapTb      66329.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.99 0.8531 -0.00062976 1.829e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3-aminophenyl)prop-2-enoic acid" "3-aminocinnamic acid" "2-propenoic acid,3-(3-aminophenyl)-" );
standardThermochemistry
{
    dHf_298   -203290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-69560.0
}
