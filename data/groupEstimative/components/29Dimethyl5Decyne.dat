/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,9-dimethyl-5-decyne  (C12H22, CAS 19550-56-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        29Dimethyl5Decyne;
formula     C12H22;
CAS         19550-56-2;
InChIKey    RCFYJIGZQAOTFV-UHFFFAOYSA-N;
MW          166.308;      // g/mol [origin=calculated method=formula-sum]
Tc          671.33;      // K   [origin=predictive method=joback]
Pc          20.774;      // bar [origin=predictive method=joback]
omega       0.4402;      // -   [origin=predictive method=lee-kesler]
Tb          482.28;      // K   [origin=predictive method=joback]
HvapTb      43682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.174 1.00588 -0.00054326 1.0958e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,9-dimethyldec-5-yne" "5-decyne, 2,9-dimethyl-" "rcfyjigzqaotfv-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -29270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=248080.0
}
