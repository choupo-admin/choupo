/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dipropylbenzamide  (C13H19NO, CAS 14657-86-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDipropylbenzamide;
formula     C13H19NO;
CAS         14657-86-4;
InChIKey    XDIWDRFZCSZPTO-UHFFFAOYSA-N;
MW          205.301;      // g/mol [origin=calculated method=formula-sum]
Tc          792.29;      // K   [origin=predictive method=joback]
Pc          23.248;      // bar [origin=predictive method=joback]
omega       0.7254;      // -   [origin=predictive method=lee-kesler]
Tb          590.03;      // K   [origin=predictive method=joback]
HvapTb      55597.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.166 1.25584 -0.0008085 1.9736e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipropylbenzamide" "benzamide, n,n-dipropyl-" "phenyl-n,n-dipropylcarboxamide" "bim-0007606.p001" );
standardThermochemistry
{
    dHf_298   -120170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     598.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=152850.0
}
