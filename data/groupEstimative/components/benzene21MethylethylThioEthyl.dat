/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, [2-[(1-methylethyl)thio]ethyl]-  (C11H16S, CAS 54576-42-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene21MethylethylThioEthyl;
formula     C11H16S;
CAS         54576-42-0;
InChIKey    MJLYFFRRKQGUDV-UHFFFAOYSA-N;
MW          180.309;      // g/mol [origin=calculated method=formula-sum]
Tc          773.81;      // K   [origin=predictive method=joback]
Pc          27.183;      // bar [origin=predictive method=joback]
omega       0.4724;      // -   [origin=predictive method=lee-kesler]
Tb          546.30;      // K   [origin=predictive method=joback]
HvapTb      48785.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.098 0.97023 -0.0005688 1.171e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-ylsulfanylethylbenzene" "2-(1-methylethylthio)ethylbenzene" "benzene, (2-((1-methylethyl)thio)ethyl)-" "[2-(propan-2-ylsulfanyl)ethyl]benzene" );
gibbsFormation
{
    dHf_298   2750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184830.0
    phase     gas;
}
