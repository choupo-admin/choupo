/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-chlorobutoxy)-2-methylbenzene  (C11H15ClO, CAS 83732-48-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Chlorobutoxy2Methylbenzene;
formula     C11H15ClO;
CAS         83732-48-3;
InChIKey    GADHSOUSWKQCEU-UHFFFAOYSA-N;
MW          198.69;      // g/mol [origin=calculated method=formula-sum]
Tc          749.37;      // K   [origin=predictive method=joback]
Pc          24.703;      // bar [origin=predictive method=joback]
omega       0.5726;      // -   [origin=predictive method=lee-kesler]
Tb          542.79;      // K   [origin=predictive method=joback]
HvapTb      49813.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.674 0.85402 -0.00044816 7.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-chloranylbutoxy)-2-methyl-benzene" "ether, 4-chlorobutyl o-tolyl" "ether, 4-chlorobutyl o-tolyl," "4-(2-methylphenoxy)butyl chloride" "benzene,1-(4-chlorobutoxy)-2-methyl-" );
standardThermochemistry
{
    dHf_298   -193270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=27590.0
}
