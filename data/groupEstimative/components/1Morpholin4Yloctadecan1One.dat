/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-morpholin-4-yloctadecan-1-one  (C22H43NO2, CAS 5299-54-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Morpholin4Yloctadecan1One;
formula     C22H43NO2;
CAS         5299-54-7;
InChIKey    FNRZFGPYQDAGEX-UHFFFAOYSA-N;
MW          353.591;      // g/mol [origin=calculated method=formula-sum]
Tc          1003.84;      // K   [origin=predictive method=joback]
Pc          10.645;      // bar [origin=predictive method=joback]
omega       0.9713;      // -   [origin=predictive method=lee-kesler]
Tb          816.17;      // K   [origin=predictive method=joback]
HvapTb      78431.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.544 2.34492 -0.0014358 3.3796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group FCH2O; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -593640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     996.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74360.0
    phase     gas;
}
