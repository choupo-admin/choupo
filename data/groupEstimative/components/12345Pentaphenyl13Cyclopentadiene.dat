/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4,5-pentaphenyl-1,3-cyclopentadiene  (C35H26, CAS 2519-10-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12345Pentaphenyl13Cyclopentadiene;
formula     C35H26;
CAS         2519-10-0;
InChIKey    YGLVWOUNCXBPJF-UHFFFAOYSA-N;
MW          446.593;      // g/mol [origin=calculated method=formula-sum]
Tc          1462.54;      // K   [origin=predictive method=joback]
Pc          13.408;      // bar [origin=predictive method=joback]
omega       0.9624;      // -   [origin=predictive method=lee-kesler]
Tb          1167.32;      // K   [origin=predictive method=joback]
HvapTb      108373.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-186.18 2.716 -0.00187 4.811e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 25; } { group AC; count 4; } { group ACCH; count 1; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group dCH_ring; count 25; } { group dC_ring; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,3,4,5-tetraphenylcyclopenta-1,4-dien-1-yl)benzene" "(2,3,4,5-tetraphenyl-1-cyclopenta-1,4-dienyl)benzene" "(2,3,4,5-tetraphenyl-2,4-cyclopentadien-1-yl)benzene" "(2,3,4,5-tetraphenylcyclopenta-2,4-dienyl)benzene" "cyclopenta-1,3-diene-1,2,3,4,5-pentaylpentabenzene" "benzene, 1,1',1'',1''',1''''-(1,3-cyclopentadiene-1,2,3,4,5-pentayl)pentakis-" "benzene,1,1',1'',1''',1''''-(1,3-cyclopentadiene-1,2,3,4,5-pentayl)pentakis-" );
gibbsFormation
{
    dHf_298   547080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     837.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=863820.0
    phase     gas;
}
