/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethoxy-3-methylbutane  (C7H16O2, CAS 59554-08-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethoxy3Methylbutane;
formula     C7H16O2;
CAS         59554-08-4;
InChIKey    JEPJBZHWRGLINP-UHFFFAOYSA-N;
MW          132.203;      // g/mol [origin=calculated method=formula-sum]
Tc          580.58;      // K   [origin=predictive method=joback]
Pc          27.789;      // bar [origin=predictive method=joback]
omega       0.3728;      // -   [origin=predictive method=lee-kesler]
Tb          400.93;      // K   [origin=predictive method=joback]
HvapTb      34312.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.37 0.6742 -0.00031 3.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group C; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethoxy-3-methyl-butane" );
standardThermochemistry
{
    dHf_298   -466280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-201540.0
}
