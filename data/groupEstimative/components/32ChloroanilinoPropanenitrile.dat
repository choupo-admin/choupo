/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-chloroanilino)propanenitrile  (C9H9ClN2, CAS 94-89-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32ChloroanilinoPropanenitrile;
formula     C9H9ClN2;
CAS         94-89-3;
InChIKey    WZAUNZSICROOPY-UHFFFAOYSA-N;
MW          180.635;      // g/mol [origin=calculated method=formula-sum]
Tc          858.07;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.7333;      // -   [origin=predictive method=lee-kesler]
Tb          626.86;      // K   [origin=predictive method=joback]
HvapTb      59865.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.782 0.7382 -0.00046796 1.097e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH2NH; count 1; } { group CH2CN; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(2-chlorophenyl)amino]propanenitrile" "propanenitrile, 3-((2-chlorophenyl)amino)-" "propanenitrile, 3-[(2-chlorophenyl)amino]-" "3-((2-chlorophenyl)amino)propanenitrile" "3-(o-chloroanilino)propiononitrile" "3-[(2-chlorophenyl)amino]-propionitrile" "2-(methylamino)-n'-(p-tolylsulfonyl)benzohydrazide" );
standardThermochemistry
{
    dHf_298   198580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=338320.0
}
