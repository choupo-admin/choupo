/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methyloctadecane  (C19H40, CAS 10544-96-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methyloctadecane;
formula     C19H40;
CAS         10544-96-4;
InChIKey    MMQAZWNADBJFCD-UHFFFAOYSA-N;
MW          268.529;      // g/mol [origin=calculated method=formula-sum]
Tc          795.21;      // K   [origin=predictive method=joback]
Pc          10.863;      // bar [origin=predictive method=joback]
omega       0.7821;      // -   [origin=predictive method=lee-kesler]
Tb          633.88;      // K   [origin=predictive method=joback]
HvapTb      57500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.065 1.81476 -0.001013 2.144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 15; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 15; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecane, 6-methyl-" );
standardThermochemistry
{
    dHf_298   -440770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     886.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=106660.0
}
