/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2-chloroethyl)morpholine  (C6H12ClNO, CAS 3240-94-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        42ChloroethylMorpholine;
formula     C6H12ClNO;
CAS         3240-94-6;
InChIKey    ZAPMTSHEXFEPSD-UHFFFAOYSA-N;
MW          149.618;      // g/mol [origin=calculated method=formula-sum]
Tc          636.08;      // K   [origin=predictive method=joback]
Pc          37.684;      // bar [origin=predictive method=joback]
omega       0.4352;      // -   [origin=predictive method=lee-kesler]
Tb          433.65;      // K   [origin=predictive method=joback]
HvapTb      40454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.468 0.8597 -0.0006045 1.656e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group FCH2O; count 1; } { group CH2N; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group Cl; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "morpholine, 4-(2-chloroethyl)-" "morpholinoethyl chloride" "beta-chloroethylmorpholine" "n-(chloroethyl)morpholine" "2-morpholinoethyl chloride" "n-(2-chloroethyl)morpholine" "4-(2-chloro-ethyl)-morpholine" "2-(4-morpholinyl)ethyl chloride" "4-(2-chloroethyl)morpholine, hydrochloride" "1-chloro-2-morpholinoethane;1-morpholino-2-chloroethane;2-(4-morpholinyl)ethyl chloride;2-morpholino-1-chloroethane;2-morpholinoethyl chloride;4-(2-chloroethyl)morpholine;morpholinoethyl chloride;n-(2-chloroethyl)morpholine;n-(chloroethyl)morpholine;b-chloroethylmorpholine;b-morpholinoethyl chloride;" );
gibbsFormation
{
    dHf_298   -166560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56630.0
    phase     gas;
}
