/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecanamide, 12-hydroxy-n-octadecyl-  (C36H73NO2, CAS 68155-52-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecanamide12HydroxyNOctadecyl;
formula     C36H73NO2;
CAS         68155-52-2;
InChIKey    XJOOKFNMTRPLEG-UHFFFAOYSA-N;
MW          551.985;      // g/mol [origin=calculated method=formula-sum]
Tc          1689.31;      // K   [origin=predictive method=joback]
Pc          4.943;      // bar [origin=predictive method=joback]
omega       -0.2423;      // -   [origin=predictive method=lee-kesler]
Tb          1219.06;      // K   [origin=predictive method=joback]
HvapTb      125203.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.078 3.51194 -0.0019981 4.2796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 31; } { group CH; count 1; } { group OH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 32; } { group CH; count 1; } { group OH; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-octadecyl-12-oxidanyl-octadecanamide" "12-hydroxy-n-octadecyloctadecan-1-amide" "n-stearyl-12-hydroxystearamide" "12-hydroxy-n-octadecyloctadecanamide" );
gibbsFormation
{
    dHf_298   -1002990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1667.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=73450.0
    phase     gas;
}
