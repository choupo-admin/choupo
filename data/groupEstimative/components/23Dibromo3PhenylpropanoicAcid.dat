/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dibromo-3-phenylpropanoic acid  (C9H8Br2O2, CAS 6286-30-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dibromo3PhenylpropanoicAcid;
formula     C9H8Br2O2;
CAS         6286-30-2;
InChIKey    FXJWTHBNVZNQQP-UHFFFAOYSA-N;
MW          307.969;      // g/mol [origin=calculated method=formula-sum]
Tc          966.86;      // K   [origin=predictive method=joback]
Pc          43.974;      // bar [origin=predictive method=joback]
omega       0.9571;      // -   [origin=predictive method=lee-kesler]
Tb          709.15;      // K   [origin=predictive method=joback]
HvapTb      67162.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.58 0.9189 -0.0007188 2.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group COOH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(bromanyl)-3-phenyl-propanoic acid" "2,3-dibromo-3-phenylpropionic acid" "alpha,beta-dibromohydrocinnamic acid" ".alpha.,.beta.-dibromohydrocinnamic acid" "2,3-dibromohydrocinnamic acid" "alpha,beta-dibromobenzenepropanoic acid" "propionic acid, 2,3-dibromo-3-phenyl-" "hydrocinnamic acid, alpha,beta-dibromo-" "a b-dibromohydrocinnamic acid" "a,b-dibromohydrocinnamic acid" "a,a-dibromohydrocinnamic acid" "hydrocinnamic acid,.beta.-dibromo-" );
standardThermochemistry
{
    dHf_298   -300730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-182840.0
}
