/*--------------------------------*- Choupo -*-----------------------*\
  Component: antioxidant 40  (C54H78O3, CAS 1709-70-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        antioxidant40;
formula     C54H78O3;
CAS         1709-70-2;
InChIKey    VSAWBBYYMBQKIK-UHFFFAOYSA-N;
MW          775.215;      // g/mol [origin=calculated method=formula-sum]
Tc          2480.95;      // K   [origin=predictive method=joback]
Pc          4.562;      // bar [origin=predictive method=joback]
omega       -0.2410;      // -   [origin=predictive method=lee-kesler]
Tb          1819.10;      // K   [origin=predictive method=joback]
HvapTb      183450.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-198.127 5.38272 -0.00410104 1.2902e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 18; } { group C; count 6; } { group ACH; count 6; } { group AC; count 9; } { group ACCH3; count 3; } { group ACCH2; count 3; } { group ACOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 21; } { group CH2; count 3; } { group C; count 6; } { group dCH_ring; count 6; } { group dC_ring; count 18; } { group OH_phenol; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[3,5-bis[(3,5-ditert-butyl-4-oxidanyl-phenyl)methyl]-2,4,6-trimethyl-phenyl]methyl]-2,6-ditert-butyl-phenol" "agidol 40" "1,3,5-trimethyl-2,4,6-tris(3,5-di-tert-butyl-4-hydroxybenzyl)benzene" "ao-40" "santoquin emulsion" "ahydol [russian]" "santoquin mixture 6" "methylene bis ethyl butyl phenol" "ao 40" "1,3,5-trimethyl-2,4,6-tris(3,5-di-tert-butyl-4-hydroxybenzyl)-benzene" "2,4,6-tris(3',5'-di-tert-butyl-4'-hydroxybenzyl)mesitylene" "phenol, 4,4',4''-[(2,4,6-trimethyl-1,3,5-benzenetriyl)tris(methylene)]tris[2,6-bis(1,1-dimethylethyl)-" );
standardThermochemistry
{
    dHf_298   -922370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1612.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=300690.0
}
