/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2-trichloro-1-fluoroethane  (C2H2Cl3F, CAS 811-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112Trichloro1Fluoroethane;
formula     C2H2Cl3F;
CAS         811-95-0;
InChIKey    ZKVMMSGRDBQIOQ-UHFFFAOYSA-N;
MW          151.386;      // g/mol [origin=calculated method=formula-sum]
Tc          548.22;      // K   [origin=predictive method=joback]
Pc          41.785;      // bar [origin=predictive method=joback]
omega       0.2474;      // -   [origin=predictive method=lee-kesler]
Tb          353.69;      // K   [origin=predictive method=joback]
HvapTb      31088.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.361 0.3518 -0.0003344 1.171e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2Cl; count 1; } { group CCl2F; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group F; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2-tris(chloranyl)-1-fluoranyl-ethane" "ethane, 1,1,2-trichloro-1-fluoro-" "sgpbadjhtaxchicup@" "zkvmmsgrdbqioq-uhfffaoysa-" "ethane,1,1,2-trichloro-1-fluoro-" "1-fluoro-1,1,2-trichloroethane" "1,1,2-trichloro-1-fluoroethane;1-fluoro-1,1,2-trichloroethane; f 131a; hcfc 131a; r 131a" );
standardThermochemistry
{
    dHf_298   -336690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     327.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-261800.0
}
