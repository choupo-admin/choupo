/*--------------------------------*- Choupo -*-----------------------*\
  Component: disiloxane, 1,1,3-trimethyl-1,3,3-triphenyl-  (C21H24OSi2, CAS 14920-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C21H24OSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        disiloxane113Trimethyl133Triphenyl;
formula     C21H24OSi2;
CAS         14920-93-5;
InChIKey    NTRDKVXVLNOVCS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          348.592;      // g/mol [origin=calculated method=formula-sum]
Tc          1046.42;      // K   [origin=predictive method=joback]
Pc          16.026;      // bar [origin=predictive method=joback]
omega       0.5656;      // -   [origin=predictive method=lee-kesler]
Tb          785.34;      // K   [origin=predictive method=joback]
HvapTb      72166.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.78 1.28656 -0.0002716 -1.74e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 15; } { group AC; count 3; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl-[methyl(diphenyl)silyl]oxy-phenyl-silane" "dimethyl-[methyl(diphenyl)silyl]oxy-phenylsilane" );
gibbsFormation
{
    dHf_298   -122640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     918.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=148650.0
    phase     gas;
}
