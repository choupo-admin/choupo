/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanol, 2-methylene-  (C7H12O, CAS 4065-80-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanol2Methylene;
formula     C7H12O;
CAS         4065-80-9;
InChIKey    GTAPKXQXCYRLRG-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          665.22;      // K   [origin=predictive method=joback]
Pc          40.364;      // bar [origin=predictive method=joback]
omega       0.6631;      // -   [origin=predictive method=lee-kesler]
Tb          470.65;      // K   [origin=predictive method=joback]
HvapTb      48443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.5 0.7074 -0.000376 6.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylidenecyclohexan-1-ol" "2-methylenecyclohexanol" "cyclohexanol,2-methylene-" "agn-pc-00kgd5" "2-methylene-cyclohexan-1-ol" );
gibbsFormation
{
    dHf_298   -201480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51230.0
    phase     gas;
}
