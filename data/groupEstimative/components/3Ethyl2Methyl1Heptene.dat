/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethyl-2-methyl-1-heptene  (C10H20, CAS 19780-60-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethyl2Methyl1Heptene;
formula     C10H20;
CAS         19780-60-0;
InChIKey    ZNQRZLWSGCOUEI-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          597.03;      // K   [origin=predictive method=joback]
Pc          22.187;      // bar [origin=predictive method=joback]
omega       0.4171;      // -   [origin=predictive method=lee-kesler]
Tb          424.52;      // K   [origin=predictive method=joback]
HvapTb      36876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.566 0.93966 -0.0005486 1.265e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-2-methyl-hept-1-ene" "3-ethyl-2-methylhept-1-ene" "1-heptene,3-ethyl-2-methyl-" );
gibbsFormation
{
    dHf_298   -139370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110170.0
    phase     gas;
}
