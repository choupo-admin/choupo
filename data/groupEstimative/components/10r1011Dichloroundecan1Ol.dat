/*--------------------------------*- Choupo -*-----------------------*\
  Component: (10r)-10,11-dichloroundecan-1-ol  (C11H22Cl2O, CAS 71566-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10r1011Dichloroundecan1Ol;
formula     C11H22Cl2O;
CAS         71566-71-7;
InChIKey    DTBDNKSFDNCDLG-LLVKDONJSA-N;
MW          241.196;      // g/mol [origin=calculated method=formula-sum]
Tc          788.43;      // K   [origin=predictive method=joback]
Pc          19.788;      // bar [origin=predictive method=joback]
omega       1.0666;      // -   [origin=predictive method=lee-kesler]
Tb          617.88;      // K   [origin=predictive method=joback]
HvapTb      65141.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.28 1.1023 -0.000649 1.47e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group OH; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group CH; count 1; } { group Cl; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(10r)-10,11-bis(chloranyl)undecan-1-ol" );
standardThermochemistry
{
    dHf_298   -459360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     692.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-121380.0
}
