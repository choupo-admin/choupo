/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxolane-4-acetamide,2,2-dimethyl-, (4s)-  (C7H13NO3, CAS 185996-33-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxolane4Acetamide22Dimethyl4s;
formula     C7H13NO3;
CAS         185996-33-2;
InChIKey    PDKGYPMMTGPUCJ-YFKPBYRVSA-N;
MW          159.185;      // g/mol [origin=calculated method=formula-sum]
Tc          776.14;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.6704;      // -   [origin=predictive method=lee-kesler]
Tb          550.91;      // K   [origin=predictive method=joback]
HvapTb      56380.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.519 1.09384 -0.0009585 3.6596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(4s)-2,2-dimethyl-1,3-dioxolan-4-yl]ethanamide" "1,3-dioxolane-4-acetamide, 2,2-dimethyl-, (4s)-" "2-((4s)-2,2-dimethyl-1,3-dioxolan-4-yl)acetamide" "2-[(4s)-2,2-dimethyl-1,3-dioxolan-4-yl]acetamide" "1,3-dioxolane-4-acetamide,2,2-dimethyl-, (s)-;" );
standardThermochemistry
{
    dHf_298   -475220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203300.0
}
