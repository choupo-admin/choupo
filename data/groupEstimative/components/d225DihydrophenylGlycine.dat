/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-(-)-2-(2,5-dihydrophenyl)glycine  (C8H11NO2, CAS 26774-88-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        d225DihydrophenylGlycine;
formula     C8H11NO2;
CAS         26774-88-9;
InChIKey    JBJJTCGQCRGNOL-SSDOTTSWSA-N;
MW          153.181;      // g/mol [origin=calculated method=formula-sum]
Tc          866.46;      // K   [origin=predictive method=joback]
Pc          42.330;      // bar [origin=predictive method=joback]
omega       0.8439;      // -   [origin=predictive method=lee-kesler]
Tb          627.76;      // K   [origin=predictive method=joback]
HvapTb      62803.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.66 0.8595 -0.00057452 1.438e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-azanyl-2-cyclohexa-1,4-dien-1-yl-ethanoic acid" "(r)-(-)-2-amino-2-(cyclohexa-1,4-dienyl)acetic acid" "(r)-2-amino-2-(cyclohexa-1,4-dien-1-yl)acetic acid" "(r)-(-)-2-(2,5-dihydrophenyl)glycine" "(r)-alpha-amino-1,4-cyclohexadiene-1-acetic acid" "(2r)-2-amino-2-cyclohexa-1,4-dienylacetic acid" "(r)-" "a-amino-1,4-cyclohexadiene-1-acetic acid" "(2r)-2-amino-2-cyclohexa-1,4-dien-1-ylacetic acid" );
gibbsFormation
{
    dHf_298   -351460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180970.0
    phase     gas;
}
