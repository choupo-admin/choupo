/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyldecahydroazecine  (C10H21N, CAS 6480-47-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyldecahydroazecine;
formula     C10H21N;
CAS         6480-47-3;
InChIKey    CFDHKUGPXKCLHZ-UHFFFAOYSA-N;
MW          155.285;      // g/mol [origin=calculated method=formula-sum]
Tc          696.48;      // K   [origin=predictive method=joback]
Pc          28.689;      // bar [origin=predictive method=joback]
omega       0.3564;      // -   [origin=predictive method=lee-kesler]
Tb          477.87;      // K   [origin=predictive method=joback]
HvapTb      41151.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.8 1.19752 -0.00063 9.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 9; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylazecane" );
gibbsFormation
{
    dHf_298   -126020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=139960.0
    phase     gas;
}
