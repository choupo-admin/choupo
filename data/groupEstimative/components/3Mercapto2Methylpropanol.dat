/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-mercapto-2-methylpropanol  (C4H10OS, CAS 56160-79-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Mercapto2Methylpropanol;
formula     C4H10OS;
CAS         56160-79-3;
InChIKey    FCIVYWQHILCTLI-UHFFFAOYSA-N;
MW          106.183;      // g/mol [origin=calculated method=formula-sum]
Tc          633.81;      // K   [origin=predictive method=joback]
Pc          48.360;      // bar [origin=predictive method=joback]
omega       0.7069;      // -   [origin=predictive method=lee-kesler]
Tb          445.72;      // K   [origin=predictive method=joback]
HvapTb      47526.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.752 0.45102 -0.0002498 5.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-3-sulfanyl-propan-1-ol" "2-methyl-3-sulfanylpropan-1-ol" "2-methyl-3-sulfanyl-1-propanol" "1-propanol, 3-mercapto-2-methyl-" "agn-pc-0crmh8" );
gibbsFormation
{
    dHf_298   -244920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-127070.0
    phase     gas;
}
