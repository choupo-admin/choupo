/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-2-butanol  (C5H12O, CAS 598-75-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl2Butanol;
formula     C5H12O;
CAS         598-75-4;
InChIKey    MXLMTQWGSQIYOW-UHFFFAOYSA-N;
MW          88.15;      // g/mol [origin=calculated method=formula-sum]
Tc          574.31;      // K   [origin=predictive method=joback]
Pc          39.555;      // bar [origin=predictive method=joback]
omega       0.6387;      // -   [origin=predictive method=lee-kesler]
Tb          405.30;      // K   [origin=predictive method=joback]
HvapTb      42627.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.27 0.52466 -0.000285 5.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutan-2-ol" "2-butanol, 3-methyl-" "sec-isoamyl alcohol" "2-methyl-3-butanol" "isopropylmethylcarbinol" "methylisopropylcarbinol" "(s)-(+)-3-methyl-2-butanol" "2-butanol, 3-methyl-, (s)-" "isopropyl methyl carbinol" "(r)-(-)-3-methyl-2-butanol" "1,2-dimethylpropanol" "dl-3-methyl-2-butanol" );
standardThermochemistry
{
    dHf_298   -309320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-150480.0
}
