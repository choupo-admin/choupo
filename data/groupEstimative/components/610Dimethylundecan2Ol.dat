/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,10-dimethylundecan-2-ol  (C13H28O, CAS 38713-13-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        610Dimethylundecan2Ol;
formula     C13H28O;
CAS         38713-13-2;
InChIKey    GNJORAZPXCKMSY-UHFFFAOYSA-N;
MW          200.366;      // g/mol [origin=calculated method=formula-sum]
Tc          752.82;      // K   [origin=predictive method=joback]
Pc          18.108;      // bar [origin=predictive method=joback]
omega       0.9676;      // -   [origin=predictive method=lee-kesler]
Tb          587.90;      // K   [origin=predictive method=joback]
HvapTb      60047.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.684 1.29058 -0.0007234 1.518e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,10-dimethyl-2-undecanol" "2-undecanol,6,10-dimethyl-" "2-undecanol, 6,10-dimethyl-" );
standardThermochemistry
{
    dHf_298   -479720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     684.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85560.0
}
