/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexaethylcyclotrisiloxane  (C12H30O3Si3, CAS 2031-79-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H30O3Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        hexaethylcyclotrisiloxane;
formula     C12H30O3Si3;
CAS         2031-79-0;
InChIKey    KMPBCFZCRNKXSA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          306.624;      // g/mol [origin=calculated method=formula-sum]
Tc          759.08;      // K   [origin=predictive method=joback]
Pc          14.861;      // bar [origin=predictive method=joback]
omega       0.5321;      // -   [origin=predictive method=lee-kesler]
Tb          570.62;      // K   [origin=predictive method=joback]
HvapTb      56940.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (110.216 0.69372 0.0003815 -4.186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 6; } { group SiO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group O_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4,6,6-hexaethyl-1,3,5,2,4,6-trioxatrisilinane" "cyclotrisiloxane, hexaethyl-" "cyclotrisiloxane, 2,2,4,4,6,6-hexaethyl-" "o672" );
gibbsFormation
{
    dHf_298   -928730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-454020.0
    phase     gas;
}
