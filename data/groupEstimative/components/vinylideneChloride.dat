/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinylidene chloride  (C2H2Cl2, CAS 75-35-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylideneChloride;
formula     C2H2Cl2;
CAS         75-35-4;
InChIKey    LGXVIGDEPROXKC-UHFFFAOYSA-N;
MW          96.938;      // g/mol [origin=calculated method=formula-sum]
Tc          507.23;      // K   [origin=predictive method=joback]
Pc          48.427;      // bar [origin=predictive method=joback]
omega       0.1854;      // -   [origin=predictive method=lee-kesler]
Tb          316.78;      // K   [origin=predictive method=joback]
HvapTb      28226.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.17 0.1873 -0.000151 4.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group Cl_C=C_; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)ethene" "1,1-dichloroethene" "1,1-dichloroethylene" "ethene, 1,1-dichloro-" "1,1-dce" "vinylidene dichloride" "vinylidine chloride" "ethylene, 1,1-dichloro-" "as-dichloroethylene" "asym-dichloroethylene" "vinylidene chloride (ii)" "vinylidene chloride, monomer" );
gibbsFormation
{
    dHf_298   -450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     291.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21390.0
    phase     gas;
}
