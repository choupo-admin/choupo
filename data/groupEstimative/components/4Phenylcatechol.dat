/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenylcatechol  (C12H10O2, CAS 92-05-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenylcatechol;
formula     C12H10O2;
CAS         92-05-7;
InChIKey    QDNPCYCBQFHNJC-UHFFFAOYSA-N;
MW          186.21;      // g/mol [origin=calculated method=formula-sum]
Tc          957.08;      // K   [origin=predictive method=joback]
Pc          50.299;      // bar [origin=predictive method=joback]
omega       0.8801;      // -   [origin=predictive method=lee-kesler]
Tb          688.76;      // K   [origin=predictive method=joback]
HvapTb      72886.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.67 1.2952 -0.00120412 4.488e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenylbenzene-1,2-diol" "4-phenylpyrocatechol" "[1,1'-biphenyl]-3,4-diol" "3,4-biphenyldiol" "3,4-dihydroxybiphenyl" "4-phenyl-1,2-benzenediol" "1,1'-biphenyl-3,4-diol" "(1,1'-biphenyl)-3,4-diol" "bp7" "biphenyl-3,4-diol" "[1,4-diol" "1,2-benzenediol, 4-phenyl-" );
standardThermochemistry
{
    dHf_298   -172570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34260.0
}
