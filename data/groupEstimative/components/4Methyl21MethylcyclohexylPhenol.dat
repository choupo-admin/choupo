/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-2-(1-methylcyclohexyl)phenol  (C14H20O, CAS 16152-65-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl21MethylcyclohexylPhenol;
formula     C14H20O;
CAS         16152-65-1;
InChIKey    MQVDCVRWVSDQNN-UHFFFAOYSA-N;
MW          204.313;      // g/mol [origin=calculated method=formula-sum]
Tc          903.57;      // K   [origin=predictive method=joback]
Pc          29.313;      // bar [origin=predictive method=joback]
omega       0.6339;      // -   [origin=predictive method=lee-kesler]
Tb          651.99;      // K   [origin=predictive method=joback]
HvapTb      61988.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-153.96 1.76404 -0.00157192 5.967e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 4-methyl-2-(1-methylcyclohexyl)-" "2-(1-methylcyclohexyl)-p-cresol" );
gibbsFormation
{
    dHf_298   -214980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     654.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=34120.0
    phase     gas;
}
