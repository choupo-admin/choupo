/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-cyclohexyl-1-methylpropyl)cyclohexane  (C16H30, CAS 54890-02-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexyl1MethylpropylCyclohexane;
formula     C16H30;
CAS         54890-02-7;
InChIKey    AXABZNLJYTXFRF-UHFFFAOYSA-N;
MW          222.416;      // g/mol [origin=calculated method=formula-sum]
Tc          830.63;      // K   [origin=predictive method=joback]
Pc          18.499;      // bar [origin=predictive method=joback]
omega       0.4269;      // -   [origin=predictive method=lee-kesler]
Tb          601.55;      // K   [origin=predictive method=joback]
HvapTb      50772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-167.339 1.89384 -0.0011804 2.703e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 2; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyclohexylbutan-2-ylcyclohexane" "cyclohexane, 1,1'-(1-methylpropylidene)bis-" "2,2-dicyclohexylbutane" "1,1'-butane-2,2-diyldicyclohexane" );
standardThermochemistry
{
    dHf_298   -273680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     679.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135580.0
}
