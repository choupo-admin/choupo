/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl propiolate  (C4H4O2, CAS 922-67-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylPropiolate;
formula     C4H4O2;
CAS         922-67-8;
InChIKey    IMAKHNTVDGLIRY-UHFFFAOYSA-N;
MW          84.074;      // g/mol [origin=calculated method=formula-sum]
Tc          527.04;      // K   [origin=predictive method=joback]
Pc          47.628;      // bar [origin=predictive method=joback]
omega       0.2832;      // -   [origin=predictive method=lee-kesler]
Tb          339.46;      // K   [origin=predictive method=joback]
HvapTb      31763.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.44 0.23512 -9.513e-05 -2.31e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH_C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 1; } { group tC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl prop-2-ynoate" "methyl acetylenecarboxylate" "2-propynoic acid, methyl ester" "propiolic acid, methyl ester" "methyl propynoate" "methyl ethynecarboxylate" "propynoic acid methyl ester" "propynoic acid, methyl ester" "propargylic acid methyl ester" "acetylenecarboxylic acid methyl ester" "methyl propiolate," "propiolic acid methyl ester" );
gibbsFormation
{
    dHf_298   -151270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     332.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-104500.0
    phase     gas;
}
