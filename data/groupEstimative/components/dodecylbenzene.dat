/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecylbenzene  (C18H30, CAS 123-01-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecylbenzene;
formula     C18H30;
CAS         123-01-3;
InChIKey    KWKXNDCHNDYVRT-UHFFFAOYSA-N;
MW          246.438;      // g/mol [origin=calculated method=formula-sum]
Tc          823.70;      // K   [origin=predictive method=joback]
Pc          14.624;      // bar [origin=predictive method=joback]
omega       0.7461;      // -   [origin=predictive method=lee-kesler]
Tb          638.12;      // K   [origin=predictive method=joback]
HvapTb      57938.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.379 1.63492 -0.0009866 2.285e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyldodecane" "benzene, dodecyl-" "laurylbenzene" "n-dodecylbenzene" "dodecane, 1-phenyl-" "marlican" "alkane" "detergent alkylate" "alkylate p 1" "dodecylbenzene, crude" "phenyldodecan" "phenyldodecane" );
standardThermochemistry
{
    dHf_298   -178320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     750.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213090.0
}
