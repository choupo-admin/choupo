/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[2-(2-chloroethoxy)ethoxy]-2,4-bis(2-methylpropyl)benzene  (C18H29ClO2, CAS 66028-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        122ChloroethoxyEthoxy24Bis2MethylpropylBenzene;
formula     C18H29ClO2;
CAS         66028-00-0;
InChIKey    GGRIASCZKHAHMZ-UHFFFAOYSA-N;
MW          312.878;      // g/mol [origin=calculated method=formula-sum]
Tc          925.16;      // K   [origin=predictive method=joback]
Pc          13.717;      // bar [origin=predictive method=joback]
omega       0.8579;      // -   [origin=predictive method=lee-kesler]
Tb          729.47;      // K   [origin=predictive method=joback]
HvapTb      67691.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.746 1.40818 -0.00065732 7.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group CH2O; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-(2-chloroethyloxy)ethoxy]-2,4-bis(2-methylpropyl)benzene" "(2-(2-chloroethoxy)ethoxy)bis(2-methylpropyl)benzene" "[2-(2-chloroethoxy)ethoxy]bis(2-methylpropyl)benzene" "benzene, (2-(2-chloroethoxy)ethoxy)bis(2-methylpropyl)-" "benzene, [2-(2-chloroethoxy)ethoxy]bis(2-methylpropyl)-" "diisobutylphenoxyethoxyethylchloride" );
standardThermochemistry
{
    dHf_298   -492000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     775.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32980.0
}
