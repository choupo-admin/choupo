/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,3,5-trichlorophenyl)methanol  (C7H5Cl3O, CAS 4681-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        235TrichlorophenylMethanol;
formula     C7H5Cl3O;
CAS         4681-17-8;
InChIKey    MKERQGLKSFEKAE-UHFFFAOYSA-N;
MW          211.466;      // g/mol [origin=calculated method=formula-sum]
Tc          823.25;      // K   [origin=predictive method=joback]
Pc          37.963;      // bar [origin=predictive method=joback]
omega       0.9055;      // -   [origin=predictive method=lee-kesler]
Tb          605.85;      // K   [origin=predictive method=joback]
HvapTb      65272.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.481 0.4658 -0.00027868 5.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,3,5-tris(chloranyl)phenyl]methanol" "ambap4681-17-8" "benzenemethanol, 2,3,5-trichloro-" );
standardThermochemistry
{
    dHf_298   -185140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-81030.0
}
