/*--------------------------------*- Choupo -*-----------------------*\
  Component: decimemide  (C19H31NO4, CAS 14817-09-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decimemide;
formula     C19H31NO4;
CAS         14817-09-5;
InChIKey    REYUZOLYIOQRIG-UHFFFAOYSA-N;
MW          337.46;      // g/mol [origin=calculated method=formula-sum]
Tc          1073.87;      // K   [origin=predictive method=joback]
Pc          13.850;      // bar [origin=predictive method=joback]
omega       1.1541;      // -   [origin=predictive method=lee-kesler]
Tb          869.60;      // K   [origin=predictive method=joback]
HvapTb      86767.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (84.959 1.39576 -0.00053158 3.26e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 2; } { group CH2O; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-decoxy-3,5-dimethoxy-benzamide" "denegyt" "decimemidum [inn-latin]" "4-(decyloxy)-3,5-dimethoxybenzamide" "benzamide, 4-(decyloxy)-3,5-dimethoxy-" "4-n-decyloxy-3,5-dimethoxybenzoic acid amide" "decimemida" "decimemidum" "decimemide [inn]" "4-decoxy-3,5-dimethoxybenzamide" "c18h29no4.c2h6" );
gibbsFormation
{
    dHf_298   -708820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     883.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-184850.0
    phase     gas;
}
