/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-pyran, 2-((3,13-tetradecadiynyl)oxy)tetrahydro-  (C19H30O2, CAS 71393-94-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hPyran2313TetradecadiynylOxyTetrahydro;
formula     C19H30O2;
CAS         71393-94-7;
InChIKey    BDNJRDAELLGHDH-UHFFFAOYSA-N;
MW          290.447;      // g/mol [origin=calculated method=formula-sum]
Tc          907.01;      // K   [origin=predictive method=joback]
Pc          15.319;      // bar [origin=predictive method=joback]
omega       0.7741;      // -   [origin=predictive method=lee-kesler]
Tb          702.36;      // K   [origin=predictive method=joback]
HvapTb      67247.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.83 1.621 -0.00086969 1.5837e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group CH_C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group tCH; count 1; } { group tC; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tetradeca-3,13-diynoxyoxane" "2h-pyran, tetrahydro-2-(3,13-tetradecadiyn-1-yloxy)-" "2h-pyran, tetrahydro-2-((3,13-tetradecadiynyl)oxy)-" "2h-pyran, tetrahydro-2-[(3,13-tetradecadiynyl)oxy]-" );
standardThermochemistry
{
    dHf_298   -81190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     766.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=368300.0
}
