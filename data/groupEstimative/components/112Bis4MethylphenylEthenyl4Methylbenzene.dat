/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[1,2-bis(4-methylphenyl)ethenyl]-4-methylbenzene  (C23H22, CAS 6629-83-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112Bis4MethylphenylEthenyl4Methylbenzene;
formula     C23H22;
CAS         6629-83-0;
InChIKey    DFDOYRNMBGBYGX-UHFFFAOYSA-N;
MW          298.429;      // g/mol [origin=calculated method=formula-sum]
Tc          1080.71;      // K   [origin=predictive method=joback]
Pc          17.061;      // bar [origin=predictive method=joback]
omega       0.7266;      // -   [origin=predictive method=lee-kesler]
Tb          824.86;      // K   [origin=predictive method=joback]
HvapTb      75644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.71 1.79356 -0.00120598 3.135e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 12; } { group AC; count 3; } { group ACCH3; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[1,2-bis(4-methylphenyl)ethenyl]-4-methyl-benzene" "benzene, 1,1',1''-(1-ethenyl-2-ylidene)tris(4-methyl-" "benzene,1',1''-(1-ethenyl-2-ylidene)tris[4-methyl-" );
standardThermochemistry
{
    dHf_298   264560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     703.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=522790.0
}
