/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,3-trimethyl-1-pentene  (C8H16, CAS 560-23-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        233Trimethyl1Pentene;
formula     C8H16;
CAS         560-23-6;
InChIKey    TUSBCMPNIOJUBX-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          557.57;      // K   [origin=predictive method=joback]
Pc          27.127;      // bar [origin=predictive method=joback]
omega       0.2617;      // -   [origin=predictive method=lee-kesler]
Tb          375.97;      // K   [origin=predictive method=joback]
HvapTb      31516.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.539 0.86958 -0.0006084 1.751e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,3-trimethylpent-1-ene" "1-pentene, 2,3,3-trimethyl-" );
gibbsFormation
{
    dHf_298   -101560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98610.0
    phase     gas;
}
