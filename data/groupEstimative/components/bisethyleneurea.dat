/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisethyleneurea  (C5H8N2O, CAS 1192-75-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisethyleneurea;
formula     C5H8N2O;
CAS         1192-75-2;
InChIKey    XTSFUENKKGFYNX-UHFFFAOYSA-N;
MW          112.132;      // g/mol [origin=calculated method=formula-sum]
Tc          599.11;      // K   [origin=predictive method=joback]
Pc          53.828;      // bar [origin=predictive method=joback]
omega       0.5568;      // -   [origin=predictive method=lee-kesler]
Tb          407.03;      // K   [origin=predictive method=joback]
HvapTb      37656.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.8 1.0726 -0.0010987 4.2886e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(aziridin-1-yl)methanone" "n,n'-diethyleneurea" "carbonylbis(aziridine)" "diethyleneurea" "carbonylbis(1-aziridine)" "bis(1-aziridinyl) ketone" "bis(1-aziridinyl)ketone" "aziridine, 1,1'-carbonylbis-" "aziridine,1'-carbonylbis-" "aziridine, 1,1'-carbonylbis-, homopolymer" );
gibbsFormation
{
    dHf_298   74550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     273.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=244980.0
    phase     gas;
}
