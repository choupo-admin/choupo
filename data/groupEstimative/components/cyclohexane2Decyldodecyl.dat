/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane, (2-decyldodecyl)-  (C28H56, CAS 6704-00-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexane2Decyldodecyl;
formula     C28H56;
CAS         6704-00-3;
InChIKey    JLRNDLKAVDEGBL-UHFFFAOYSA-N;
MW          392.756;      // g/mol [origin=calculated method=formula-sum]
Tc          1052.44;      // K   [origin=predictive method=joback]
Pc          7.332;      // bar [origin=predictive method=joback]
omega       0.6826;      // -   [origin=predictive method=lee-kesler]
Tb          859.35;      // K   [origin=predictive method=joback]
HvapTb      77963.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.851 2.79184 -0.0015836 3.311e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 24; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 19; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-decyldodecylcyclohexane" "heneicosane, 11-(cyclohexylmethyl)-" "1-cyclohexyl-2-n-decyldodecane" );
gibbsFormation
{
    dHf_298   -572210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1206.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=206890.0
    phase     gas;
}
