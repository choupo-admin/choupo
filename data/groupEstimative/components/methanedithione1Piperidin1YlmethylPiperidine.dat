/*--------------------------------*- Choupo -*-----------------------*\
  Component: methanedithione;1-(piperidin-1-ylmethyl)piperidine  (C12H22N2S2, CAS 68133-93-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H22N2S2 (delta S+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methanedithione1Piperidin1YlmethylPiperidine;
formula     C12H22N2S2;
CAS         68133-93-7;
InChIKey    DURYNXRIGZVXBX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          258.442;      // g/mol [origin=calculated method=formula-sum]
Tc          763.95;      // K   [origin=predictive method=joback]
Pc          27.127;      // bar [origin=predictive method=joback]
omega       0.5000;      // -   [origin=predictive method=lee-kesler]
Tb          542.21;      // K   [origin=predictive method=joback]
HvapTb      47959.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.939 1.5573 -0.0010644 2.797e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH2N; count 2; } { group CS2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCd; count 1; } { group CH2_ring; count 10; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperidine, 1,1'-methylenebis-, polymer with carbon disulfide" "methanedithione; 1-(piperidin-1-ylmethyl)piperidine" );
standardThermochemistry
{
    dHf_298   168470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     688.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=488520.0
}
