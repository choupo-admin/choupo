/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[2-[2-(octadec-9-enoylamino)ethoxy]ethoxy]-4-oxidanylidene-but-2-enoic acid  (C26H45NO6, CAS 56381-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        422Octadec9EnoylaminoEthoxyEthoxy4OxidanylideneBut2EnoicAcid;
formula     C26H45NO6;
CAS         56381-65-8;
InChIKey    KFEBJZRLAXVSGZ-UHFFFAOYSA-N;
MW          467.647;      // g/mol [origin=calculated method=formula-sum]
Tc          1418.71;      // K   [origin=predictive method=joback]
Pc          8.368;      // bar [origin=predictive method=joback]
omega       0.5910;      // -   [origin=predictive method=lee-kesler]
Tb          1132.99;      // K   [origin=predictive method=joback]
HvapTb      113549.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.548 2.49482 -0.0014551 3.1056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH=CH; count 2; } { group CH2O; count 1; } { group COOH; count 1; } { group COO; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group dCH; count 4; } { group O; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butenedioic acid (2z)-, 1-[2-[2-[[9z)-(1-oxo-9-octadecenyl]amino]ethoxy]ethyl] ester, stereoisomer" );
standardThermochemistry
{
    dHf_298   -1204410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1338.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-470330.0
}
