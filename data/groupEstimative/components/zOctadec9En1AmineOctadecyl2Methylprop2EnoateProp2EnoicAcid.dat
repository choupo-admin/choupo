/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-octadec-9-en-1-amine;octadecyl 2-methylprop-2-enoate;prop-2-enoic acid  (C43H83NO4, CAS 167078-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        zOctadec9En1AmineOctadecyl2Methylprop2EnoateProp2EnoicAcid;
formula     C43H83NO4;
CAS         167078-20-8;
InChIKey    WMZRSTFCRPCCQD-MEILSSRFSA-N;
MW          678.14;      // g/mol [origin=calculated method=formula-sum]
Tc          2193.99;      // K   [origin=predictive method=joback]
Pc          3.656;      // bar [origin=predictive method=joback]
omega       -0.5046;      // -   [origin=predictive method=lee-kesler]
Tb          1459.90;      // K   [origin=predictive method=joback]
HvapTb      145810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.082 3.71426 -0.0016391 1.32e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 31; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 32; } { group dCH2; count 2; } { group dCH; count 3; } { group dC; count 1; } { group COOH; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, octadecyl ester, polymer with 2-propenoic acid, compd. with (9z)-9-octadecen-1-amine" );
standardThermochemistry
{
    dHf_298   -1429560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     2182.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-238820.0
}
