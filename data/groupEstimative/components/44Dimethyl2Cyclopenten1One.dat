/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-dimethyl-2-cyclopenten-1-one  (C7H10O, CAS 22748-16-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dimethyl2Cyclopenten1One;
formula     C7H10O;
CAS         22748-16-9;
InChIKey    YVFVCSCZJJGBAK-UHFFFAOYSA-N;
MW          110.156;      // g/mol [origin=calculated method=formula-sum]
Tc          669.54;      // K   [origin=predictive method=joback]
Pc          39.357;      // bar [origin=predictive method=joback]
omega       0.3150;      // -   [origin=predictive method=lee-kesler]
Tb          442.26;      // K   [origin=predictive method=joback]
HvapTb      34821.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.74 0.86814 -0.00076028 3.008e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4-dimethylcyclopent-2-en-1-one" "4,4-dimethylcyclopent-2-enone" "4,4-dimethyl-cyclopent-2-en-1-one" "2-cyclopenten-1-one,4,4-dimethyl-" );
gibbsFormation
{
    dHf_298   -192010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     331.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-53510.0
    phase     gas;
}
