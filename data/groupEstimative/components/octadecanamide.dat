/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecanamide  (C18H37NO, CAS 124-26-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecanamide;
formula     C18H37NO;
CAS         124-26-5;
InChIKey    LYRFLYHAGKPMFH-UHFFFAOYSA-N;
MW          283.5;      // g/mol [origin=calculated method=formula-sum]
Tc          915.37;      // K   [origin=predictive method=joback]
Pc          12.521;      // bar [origin=predictive method=joback]
omega       1.0136;      // -   [origin=predictive method=lee-kesler]
Tb          737.84;      // K   [origin=predictive method=joback]
HvapTb      73049.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.376 1.74772 -0.0009801 2.0496e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "stearamide" "stearic acid amide" "octadecamide" "octadecylamide" "stearoylamide" "stearoylamine" "stearylamide" "stearic amide" "kemamide s" "adogen 42" "amide c18" "octadecanoic acid amide" );
standardThermochemistry
{
    dHf_298   -493640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     935.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38210.0
}
