/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexamethylcyclohexane  (C12H24, CAS 51345-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexamethylcyclohexane;
formula     C12H24;
CAS         51345-51-8;
InChIKey    OKDCYQXBGGJTCU-UHFFFAOYSA-N;
MW          168.324;      // g/mol [origin=calculated method=formula-sum]
Tc          702.45;      // K   [origin=predictive method=joback]
Pc          22.762;      // bar [origin=predictive method=joback]
omega       0.2907;      // -   [origin=predictive method=lee-kesler]
Tb          485.09;      // K   [origin=predictive method=joback]
HvapTb      38664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-211.72 2.08872 -0.002197 9.788e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 3; } { group C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2_ring; count 3; } { group C_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2,3,3-hexamethylcyclohexane" "agn-pc-00n656" "cyclohexane, 1,1,2,2,3,3-hexamethyl-" );
standardThermochemistry
{
    dHf_298   -231650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     716.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42720.0
}
