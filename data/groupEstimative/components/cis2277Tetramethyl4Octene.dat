/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-2,2,7,7-tetramethyl-4-octene  (C12H24, CAS 5223-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis2277Tetramethyl4Octene;
formula     C12H24;
CAS         5223-57-4;
InChIKey    VUVGYCAGSXOGCC-FPLPWBNLSA-N;
MW          168.324;      // g/mol [origin=calculated method=formula-sum]
Tc          661.03;      // K   [origin=predictive method=joback]
Pc          19.237;      // bar [origin=predictive method=joback]
omega       0.3703;      // -   [origin=predictive method=lee-kesler]
Tb          471.86;      // K   [origin=predictive method=joback]
HvapTb      39672.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.148 1.41552 -0.0010564 3.228e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-2,2,7,7-tetramethyloct-4-ene" );
standardThermochemistry
{
    dHf_298   -191290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136060.0
}
