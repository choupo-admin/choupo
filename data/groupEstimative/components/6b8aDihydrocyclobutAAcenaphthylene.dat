/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6b,8a-dihydrocyclobut[a]acenaphthylene  (C14H10, CAS 30736-79-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6b8aDihydrocyclobutAAcenaphthylene;
formula     C14H10;
CAS         30736-79-9;
InChIKey    MKRSLSRLZZVPKE-UHFFFAOYSA-N;
MW          178.234;      // g/mol [origin=calculated method=formula-sum]
Tc          822.91;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       0.5320;      // -   [origin=predictive method=lee-kesler]
Tb          579.64;      // K   [origin=predictive method=joback]
HvapTb      51772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-129.05 1.3972 -0.00129212 4.748e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 6; } { group AC; count 2; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6b,8a-dihydrocyclobuta[a]acenaphthylene" "6b,8a-dihydrocyclobut(a)acenaphthylene" );
standardThermochemistry
{
    dHf_298   288070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     215.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=442460.0
}
