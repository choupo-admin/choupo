/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(cyclopropylamino)propionitrile  (C6H10N2, CAS 58196-47-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3CyclopropylaminoPropionitrile;
formula     C6H10N2;
CAS         58196-47-7;
InChIKey    OZHWHTICSNFGBZ-UHFFFAOYSA-N;
MW          110.16;      // g/mol [origin=calculated method=formula-sum]
Tc          702.71;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.5909;      // -   [origin=predictive method=lee-kesler]
Tb          495.87;      // K   [origin=predictive method=joback]
HvapTb      45777.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.018 0.7357 -0.0005404 1.637e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2NH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(cyclopropylamino)propanenitrile" "3-(3-cyclopropylamino)propionitrile" "propanenitrile,3-(cyclopropylamino)-" "3-(cyclopropylamino)propanenitrile;3-(cyclopropylamino)propionitrile;n-(2-cyanoethyl)-n-(cyclopropyl)amine;" );
standardThermochemistry
{
    dHf_298   123980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=282960.0
}
