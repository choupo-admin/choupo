/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-(aziridin-1-yl)butanoate  (C7H13NO2, CAS 68083-50-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Aziridin1YlButanoate;
formula     C7H13NO2;
CAS         68083-50-1;
InChIKey    SBVKABQEJSQEOZ-UHFFFAOYSA-N;
MW          143.186;      // g/mol [origin=calculated method=formula-sum]
Tc          619.81;      // K   [origin=predictive method=joback]
Pc          32.992;      // bar [origin=predictive method=joback]
omega       0.5536;      // -   [origin=predictive method=lee-kesler]
Tb          437.12;      // K   [origin=predictive method=joback]
HvapTb      40288.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.499 0.93084 -0.0007002 2.093e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-aziridineacetic acid, " "a-ethyl-, methyl ester" "methyl 2-(1'-aziridinyl)butyrate" "methyl alpha-ethylaziridine-1-acetate" "1-aziridineacetic acid, alpha-ethyl-, methyl ester" "1-aziridineacetic acid, .alpha.-ethyl-, methyl ester" );
standardThermochemistry
{
    dHf_298   -343540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113410.0
}
