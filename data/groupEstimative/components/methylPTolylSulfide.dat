/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl p-tolyl sulfide  (C8H10S, CAS 623-13-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylPTolylSulfide;
formula     C8H10S;
CAS         623-13-2;
InChIKey    VHILIAIEEYLJNA-UHFFFAOYSA-N;
MW          138.228;      // g/mol [origin=calculated method=formula-sum]
Tc          719.25;      // K   [origin=predictive method=joback]
Pc          36.598;      // bar [origin=predictive method=joback]
omega       0.3572;      // -   [origin=predictive method=lee-kesler]
Tb          483.08;      // K   [origin=predictive method=joback]
HvapTb      43157.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.39 0.61983 -0.00033536 5.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-methylsulfanyl-benzene" "4-methylthioanisole" "4-(methylthio)toluene" "p-(methylthio)toluene" "benzene, 1-methyl-4-(methylthio)-" "1-methyl-4-(methylthio)benzene" "sulfide, methyl p-tolyl" "p-tolyl methyl sulfide" "methyl p-cresyl sulfide" "p-cresyl methyl sulfide" "p-methylphenyl methyl sulfide" "4-methyl-(1-thiaethyl)benzene" );
standardThermochemistry
{
    dHf_298   58480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=152380.0
}
