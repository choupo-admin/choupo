/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-hydroxyethyl)lactamide  (C5H11NO3, CAS 5422-34-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2HydroxyethylLactamide;
formula     C5H11NO3;
CAS         5422-34-4;
InChIKey    RZCHTMXTKQHYDT-UHFFFAOYSA-N;
MW          133.147;      // g/mol [origin=calculated method=formula-sum]
Tc          774.32;      // K   [origin=predictive method=joback]
Pc          48.902;      // bar [origin=predictive method=joback]
omega       1.6145;      // -   [origin=predictive method=lee-kesler]
Tb          601.96;      // K   [origin=predictive method=joback]
HvapTb      72876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.392 0.60092 -0.0003421 6.886e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 2; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-hydroxyethyl)-2-oxidanyl-propanamide" "lactamide mea" "propanamide, 2-hydroxy-n-(2-hydroxyethyl)-" "2-hydroxy-n-(2-hydroxyethyl)propanamide" "2-lactamidoethanol" "lactamide, n-(2-hydroxyethyl)-" "n-2-hydroxyethyllactamide" "lactic acid monoethanolamide" "n-beta-hydroxyethyllactamide" "n-(beta-hydroxyethyl)lactamide" "n-hydroxyaethyllactamid [german]" "monoethanolamine lactic acid amide" );
standardThermochemistry
{
    dHf_298   -515380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-324390.0
}
