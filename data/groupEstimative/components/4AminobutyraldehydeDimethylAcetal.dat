/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-aminobutyraldehyde dimethyl acetal  (C6H15NO2, CAS 19060-15-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4AminobutyraldehydeDimethylAcetal;
formula     C6H15NO2;
CAS         19060-15-2;
InChIKey    TYVAXMOICMBSMT-UHFFFAOYSA-N;
MW          133.191;      // g/mol [origin=calculated method=formula-sum]
Tc          637.12;      // K   [origin=predictive method=joback]
Pc          32.173;      // bar [origin=predictive method=joback]
omega       0.5993;      // -   [origin=predictive method=lee-kesler]
Tb          453.81;      // K   [origin=predictive method=joback]
HvapTb      44023.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.243 0.51524 -0.0001272 -3.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH3O; count 2; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group O; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4-dimethoxybutan-1-amine" "4,4-dimethoxybutylamine" "1-amino-4,4-dimethoxybutane" "tyvaxmoicmbsmt-uhfffaoysa-" "4-aminobutyraldehyde dimethylacetal" "butyraldehyde,4-amino-, dimethyl acetal (6ci,7ci,8ci); butylamine, 4,4-dimethoxy- (8ci);4,4-bis(methyloxy)butylamine; 4,4-dimethoxy-1-butanamine;4,4-dimethoxybutylamine; 4-aminobutanal dimethyl acetal; 4-aminobutyraldehydedimethyl acetal; g-aminobutyraldehydedimethyl acetal" );
standardThermochemistry
{
    dHf_298   -403100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-146350.0
}
