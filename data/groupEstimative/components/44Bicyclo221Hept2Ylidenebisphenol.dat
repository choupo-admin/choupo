/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-bicyclo(2.2.1)hept-2-ylidenebisphenol  (C19H20O2, CAS 1943-96-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Bicyclo221Hept2Ylidenebisphenol;
formula     C19H20O2;
CAS         1943-96-0;
InChIKey    RBWZNZOIVJUVRB-UHFFFAOYSA-N;
MW          280.367;      // g/mol [origin=calculated method=formula-sum]
Tc          1137.96;      // K   [origin=predictive method=joback]
Pc          31.385;      // bar [origin=predictive method=joback]
omega       1.0443;      // -   [origin=predictive method=lee-kesler]
Tb          862.24;      // K   [origin=predictive method=joback]
HvapTb      87006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-249.69 2.5178 -0.00245612 9.706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[3-(4-hydroxyphenyl)-3-bicyclo[2.2.1]heptanyl]phenol" "phenol, 4,4'-bicyclo[2.2.1]hept-2-ylidenebis-" "phenol, 4,4'-bicyclo(2.2.1)hept-2-ylidenebis-" "agn-pc-00i9ei" "4,4'-bicyclo[2.2.1]heptane-2,2-diyldiphenol" );
standardThermochemistry
{
    dHf_298   -182710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120880.0
}
