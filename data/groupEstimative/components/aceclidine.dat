/*--------------------------------*- Choupo -*-----------------------*\
  Component: aceclidine  (C9H15NO2, CAS 827-61-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aceclidine;
formula     C9H15NO2;
CAS         827-61-2;
InChIKey    WRJPSSPFHGNBMG-UHFFFAOYSA-N;
MW          169.224;      // g/mol [origin=calculated method=formula-sum]
Tc          697.08;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.5529;      // -   [origin=predictive method=lee-kesler]
Tb          493.93;      // K   [origin=predictive method=joback]
HvapTb      45076.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.18 1.22012 -0.0008778 2.449e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH3COO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azabicyclo[2.2.2]octan-3-yl ethanoate" "3-acetoxyquinuclidine" "glaucostat" "3-quinuclidinol acetate (ester)" "3-quinuclidinol acetate" "aceclidine [usan:inn]" "quinuclidin-3-yl acetate" "aceclidinum [inn-latin]" "3-quinuclidinol, acetate (ester)" "1-azabicyclo(2.2.2)octan-3-ol, acetate (ester)" "1-azabicyclo(2.2.2)octan-3-ol, acetate" "aceclidin" );
gibbsFormation
{
    dHf_298   -339400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-65290.0
    phase     gas;
}
