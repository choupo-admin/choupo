/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3,4-tetramethylcyclopentane  (C9H18, CAS 20309-77-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1134Tetramethylcyclopentane;
formula     C9H18;
CAS         20309-77-7;
InChIKey    OWHFMVURUNNXMJ-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          610.56;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       0.2606;      // -   [origin=predictive method=lee-kesler]
Tb          411.70;      // K   [origin=predictive method=joback]
HvapTb      34116.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.89 1.22948 -0.001015 3.77e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cis-1,1,3,4-tetramethylcyclopentane" "trans-1,1,3,4-tetramethylcyclopentane" "cyclopentane, 1,1,3,4-tetramethyl-, cis-" "cyclopentane, 1,1,3,4-tetramethyl-, trans-" "1,1,3,4-tetramethyl cyclopentane" );
gibbsFormation
{
    dHf_298   -194050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40540.0
    phase     gas;
}
