/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolethane octanoate decanoate laurate  (C32H60O6, CAS 68411-73-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolethaneOctanoateDecanoateLaurate;
formula     C32H60O6;
CAS         68411-73-4;
InChIKey    BKPIDSZKWXYETM-UHFFFAOYSA-N;
MW          540.826;      // g/mol [origin=calculated method=formula-sum]
Tc          1418.73;      // K   [origin=predictive method=joback]
Pc          5.492;      // bar [origin=predictive method=joback]
omega       0.1098;      // -   [origin=predictive method=lee-kesler]
Tb          1105.98;      // K   [origin=predictive method=joback]
HvapTb      108659.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.345 2.88536 -0.0014364 1.978e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 22; } { group CH; count 1; } { group CH2COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 25; } { group CH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-decanoyloxy-2-octanoyloxy-ethyl) dodecanoate" "dodecanoic acid, mixed esters with decanoic acid, octanoic acid and trimethylolethane" "trimethylolethane caprylate, caprate, laurate" "(1-decanoyloxy-2-octanoyloxyethyl) dodecanoate" );
gibbsFormation
{
    dHf_298   -1660930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1546.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-714990.0
    phase     gas;
}
