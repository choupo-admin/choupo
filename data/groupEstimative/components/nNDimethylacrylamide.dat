/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylacrylamide  (C5H9NO, CAS 2680-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylacrylamide;
formula     C5H9NO;
CAS         2680-03-7;
InChIKey    YLGYACDQVQQZSW-UHFFFAOYSA-N;
MW          99.133;      // g/mol [origin=calculated method=formula-sum]
Tc          557.65;      // K   [origin=predictive method=joback]
Pc          39.308;      // bar [origin=predictive method=joback]
omega       0.4125;      // -   [origin=predictive method=lee-kesler]
Tb          376.99;      // K   [origin=predictive method=joback]
HvapTb      34843.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.98 0.55474 -0.000365 9.406e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylprop-2-enamide" "2-propenamide, n,n-dimethyl-" "acylamide, n,n-dimethyl" "n,n-dimethyl-2-propenamide" "acylamide,n-dimethyl" "acrylamide,n-dimethyl-" "2-propenamide,n-dimethyl-" "nn-dimethylacrylamide" "n,n-dimethyl-acrylamide" "dimethylamid kyseliny akrylove" "ylgyacdqvqqzsw-uhfffaoysa-" "r449" );
standardThermochemistry
{
    dHf_298   -66150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60920.0
}
