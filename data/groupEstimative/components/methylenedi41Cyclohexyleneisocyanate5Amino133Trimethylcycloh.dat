\*---------------------------------------------------------------------------*/

name        methylenedi41Cyclohexyleneisocyanate5Amino133Trimethylcycloh;
formula     C31H54N4O4;
CAS         67599-31-9;
InChIKey    JXOUEHYHBZRCQK-UHFFFAOYSA-N;
MW          546.797;      // g/mol [origin=calculated method=formula-sum]
Tc          1602.36;      // K   [origin=predictive method=joback]
Pc          9.089;      // bar [origin=predictive method=joback]
omega       0.8804;      // -   [origin=predictive method=lee-kesler]
Tb          1308.70;      // K   [origin=predictive method=joback]
HvapTb      131256.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 16; } { group CH; count 4; } { group C; count 2; } { group CH2COO; count 1; } { group CH2NH2; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCd; count 2; } { group CH2_ring; count 16; } { group CH_ring; count 5; } { group C_ring; count 2; } { group COO; count 1; } { group dO_oth; count 2; } { group NH2; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(aminomethyl)-3,5,5-trimethyl-cyclohexan-1-amine;1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane;oxepan-2-one" "2-oxepanone, polymer with 5-amino-1,3,3-trimethylcyclohexanemethanamine and 1,1'-methylenebis(4-isocyanatocyclohexane)" "3-(aminomethyl)-3,5,5-trimethylcyclohexan-1-amine; 1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane; oxepan-2-one" );
