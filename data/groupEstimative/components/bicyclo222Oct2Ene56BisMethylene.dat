/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo(2.2.2)oct-2-ene, 5,6-bis(methylene)-  (C10H12, CAS 36528-62-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo222Oct2Ene56BisMethylene;
formula     C10H12;
CAS         36528-62-8;
InChIKey    FGUYOMZFYKDVOZ-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          659.13;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.3454;      // -   [origin=predictive method=lee-kesler]
Tb          447.90;      // K   [origin=predictive method=joback]
HvapTb      38634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.57 0.9454 -0.00067028 1.926e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethylidenebicyclo[2.2.2]oct-5-ene" "bicyclo[2.2.2]oct-2-ene,5,6-bis(methylene)-" );
gibbsFormation
{
    dHf_298   109810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     315.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=266740.0
    phase     gas;
}
