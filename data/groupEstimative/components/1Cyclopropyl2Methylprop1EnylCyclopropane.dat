/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-cyclopropyl-2-methylprop-1-enyl)cyclopropane  (C10H16, CAS 27720-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclopropyl2Methylprop1EnylCyclopropane;
formula     C10H16;
CAS         27720-84-9;
InChIKey    XLIRFUSHTRXZKU-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          653.20;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       0.3377;      // -   [origin=predictive method=lee-kesler]
Tb          445.80;      // K   [origin=predictive method=joback]
HvapTb      37798.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.25 1.27544 -0.001049 3.574e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-cyclopropyl-2-methyl-prop-1-enyl)cyclopropane" "cyclopropane, 1,1'-(2-methyl-1-propenylidene)bis-" );
standardThermochemistry
{
    dHf_298   -6490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=217940.0
}
