/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dichlorobutane  (C4H8Cl2, CAS 4279-22-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dichlorobutane;
formula     C4H8Cl2;
CAS         4279-22-5;
InChIKey    BSRTYNDWQXVCKR-UHFFFAOYSA-N;
MW          127.008;      // g/mol [origin=calculated method=formula-sum]
Tc          557.57;      // K   [origin=predictive method=joback]
Pc          36.421;      // bar [origin=predictive method=joback]
omega       0.2322;      // -   [origin=predictive method=lee-kesler]
Tb          362.75;      // K   [origin=predictive method=joback]
HvapTb      31972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.561 0.52324 -0.0004064 1.263e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)butane" "butane, 2,2-dichloro-" );
standardThermochemistry
{
    dHf_298   -166120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     339.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-38220.0
}
