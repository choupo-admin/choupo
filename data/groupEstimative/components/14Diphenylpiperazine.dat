/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-diphenylpiperazine  (C16H18N2, CAS 613-39-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Diphenylpiperazine;
formula     C16H18N2;
CAS         613-39-8;
InChIKey    LLZRSOPHIGKISM-UHFFFAOYSA-N;
MW          238.334;      // g/mol [origin=calculated method=formula-sum]
Tc          906.12;      // K   [origin=predictive method=joback]
Pc          27.469;      // bar [origin=predictive method=joback]
omega       0.6577;      // -   [origin=predictive method=lee-kesler]
Tb          659.60;      // K   [origin=predictive method=joback]
HvapTb      60242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-162.15 1.7816 -0.0013634 4.026e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 10; } { group AC; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperazine,4-diphenyl-" "n,n'-diphenylpiperazine" "1,4-diphenyl-piperazine" "piperazine, 1,4-diphenyl-" "piperazine, n,n'-diphenyl-" "n,n'-diphenyldiethylenediamine" );
gibbsFormation
{
    dHf_298   321530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=586580.0
    phase     gas;
}
