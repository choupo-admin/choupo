/*--------------------------------*- Choupo -*-----------------------*\
  Component: moperone  (C22H26FNO2, CAS 1050-79-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        moperone;
formula     C22H26FNO2;
CAS         1050-79-9;
InChIKey    AGAHNABIDCTLHW-UHFFFAOYSA-N;
MW          355.453;      // g/mol [origin=calculated method=formula-sum]
Tc          1165.90;      // K   [origin=predictive method=joback]
Pc          17.879;      // bar [origin=predictive method=joback]
omega       1.3109;      // -   [origin=predictive method=lee-kesler]
Tb          939.56;      // K   [origin=predictive method=joback]
HvapTb      94199.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-158.747 2.38232 -0.00190202 6.3306e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 1; } { group OH; count 1; } { group CH2CO; count 1; } { group CH2N; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 1; } { group OH; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-fluorophenyl)-4-[4-(4-methylphenyl)-4-oxidanyl-piperidin-1-yl]butan-1-one" "methylperidol" "meperon" "luvatren" "moperone (inn)" "moperone [inn]" "luvatrena" "moperone hcl" "1-(4-fluorophenyl)-4-[4-hydroxy-4-(4-methylphenyl)piperidin-1-yl]butan-1-one" "1-butanone, 1-(4-fluorophenyl)-4-[4-hydroxy-4-(4-methylphenyl)-1-piperidinyl]-" "mopiperone" "moperona" );
gibbsFormation
{
    dHf_298   -364960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     932.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21210.0
    phase     gas;
}
