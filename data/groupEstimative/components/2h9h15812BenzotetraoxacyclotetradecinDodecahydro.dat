/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h,9h-1,5,8,12-benzotetraoxacyclotetradecin, dodecahydro-  (C14H26O4, CAS 88718-31-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2h9h15812BenzotetraoxacyclotetradecinDodecahydro;
formula     C14H26O4;
CAS         88718-31-4;
InChIKey    FZPNKCKRUARCII-UHFFFAOYSA-N;
MW          258.358;      // g/mol [origin=calculated method=formula-sum]
Tc          951.85;      // K   [origin=predictive method=joback]
Pc          24.076;      // bar [origin=predictive method=joback]
omega       0.5862;      // -   [origin=predictive method=lee-kesler]
Tb          692.44;      // K   [origin=predictive method=joback]
HvapTb      66688.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.49 1.5084 -0.0005658 -3.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 2; } { group FCH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 12; } { group CH_ring; count 2; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6,9,13-tetraoxabicyclo[12.4.0]octadecane" "cyclohexyl-14-crown-4" "dodecahydro-2h,9h-1,5,8,12-benzotetraoxacyclotetradecine" );
standardThermochemistry
{
    dHf_298   -788610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-301180.0
}
