/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methoxyindan  (C10H12O, CAS 5111-69-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methoxyindan;
formula     C10H12O;
CAS         5111-69-3;
InChIKey    WPPWEFVZGFJESZ-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          721.52;      // K   [origin=predictive method=joback]
Pc          33.374;      // bar [origin=predictive method=joback]
omega       0.4543;      // -   [origin=predictive method=lee-kesler]
Tb          498.87;      // K   [origin=predictive method=joback]
HvapTb      44086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.19 0.87012 -0.00058192 1.562e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methoxy-2,3-dihydro-1h-indene" "5-methoxyindane" "indane, 5-methoxy" "1h-indene,2,3-dihydro-5-methoxy-" );
gibbsFormation
{
    dHf_298   -75220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89930.0
    phase     gas;
}
