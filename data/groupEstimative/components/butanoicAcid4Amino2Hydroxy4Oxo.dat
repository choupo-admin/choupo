/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanoic acid, 4-amino-2-hydroxy-4-oxo-  (C4H7NO4, CAS 66398-52-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanoicAcid4Amino2Hydroxy4Oxo;
formula     C4H7NO4;
CAS         66398-52-5;
InChIKey    RTTYFXMXRFYCHM-UHFFFAOYSA-N;
MW          133.103;      // g/mol [origin=calculated method=formula-sum]
Tc          858.02;      // K   [origin=predictive method=joback]
Pc          59.814;      // bar [origin=predictive method=joback]
omega       1.5206;      // -   [origin=predictive method=lee-kesler]
Tb          654.77;      // K   [origin=predictive method=joback]
HvapTb      75340.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.311 0.5084 -0.0003247 7.566e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanyl-2-oxidanyl-4-oxidanylidene-butanoic acid" "4-amino-2-hydroxy-4-oxobutanoic acid" "agn-pc-00krec" );
gibbsFormation
{
    dHf_298   -712460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-562840.0
    phase     gas;
}
