/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloro(difluoro)methane; 1-chloro-1,1,2,2,2-pentafluoroethane  (C3HCl2F7, CAS 39432-81-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloroDifluoroMethane1Chloro11222Pentafluoroethane;
formula     C3HCl2F7;
CAS         39432-81-0;
InChIKey    SGVQWMHGPNLWSW-UHFFFAOYSA-N;
MW          240.927;      // g/mol [origin=calculated method=formula-sum]
Tc          480.83;      // K   [origin=predictive method=joback]
Pc          26.653;      // bar [origin=predictive method=joback]
omega       0.3617;      // -   [origin=predictive method=lee-kesler]
Tb          332.49;      // K   [origin=predictive method=joback]
HvapTb      22637.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.77 0.4363 -0.000227 7.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CF3; count 1; } { group CClF2; count 1; } { group HCClF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 2; } { group F; count 7; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranyl-bis(fluoranyl)methane;1-chloranyl-1,1,2,2,2-pentakis(fluoranyl)ethane" "1-chloro-1,1,2,2,2-pentafluoroethane - chloro(difluoro)methane (1:1)" "chloro-difluoro-methane; 1-chloro-1,1,2,2,2-pentafluoro-ethane" "chlorodifluoromethane and chloropentafluoroethane mixture of refrigerant gas r 502 with fixed boiling point, with approximately 49% chlorodifluoromethane" );
gibbsFormation
{
    dHf_298   -1643900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1514670.0
    phase     gas;
}
