/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-nonen-1-ol  (C9H18O, CAS 13038-21-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Nonen1Ol;
formula     C9H18O;
CAS         13038-21-6;
InChIKey    FKGFCVJJLGSFSB-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          656.24;      // K   [origin=predictive method=joback]
Pc          26.353;      // bar [origin=predictive method=joback]
omega       0.8881;      // -   [origin=predictive method=lee-kesler]
Tb          494.38;      // K   [origin=predictive method=joback]
HvapTb      51637.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.993 0.8728 -0.0005191 1.231e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "non-8-en-1-ol" "8-nonene-1-ol;8-nonen-1-ol97+%;" );
gibbsFormation
{
    dHf_298   -255890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     552.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-24080.0
    phase     gas;
}
