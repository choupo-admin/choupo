/*--------------------------------*- Choupo -*-----------------------*\
  Component: triallyl aconitate  (C15H18O6, CAS 13675-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triallylAconitate;
formula     C15H18O6;
CAS         13675-27-9;
InChIKey    NZHHDFRSEQSGLN-BENRWUELSA-N;
MW          294.303;      // g/mol [origin=calculated method=formula-sum]
Tc          901.31;      // K   [origin=predictive method=joback]
Pc          16.525;      // bar [origin=predictive method=joback]
omega       1.0097;      // -   [origin=predictive method=lee-kesler]
Tb          711.54;      // K   [origin=predictive method=joback]
HvapTb      69233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.634 1.2243 -0.0006632 9.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 3; } { group CH=C; count 1; } { group CH2COO; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 3; } { group dCH; count 4; } { group dC; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(prop-2-enyl) (z)-prop-1-ene-1,2,3-tricarboxylate" "triprop-2-en-1-yl prop-1-ene-1,2,3-tricarboxylate" "1-propene-1,3-tricarboxylic acid, triallyl ester" "1-propene-1,2,3-tricarboxylic acid, triallyl ester" "1-propene-1,2,3-tricarboxylic acid, triallyl ester (8ci)" );
gibbsFormation
{
    dHf_298   -821050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     869.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-520500.0
    phase     gas;
}
