/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxy-n,n-bis(2-hydroxyethyl)-2-naphthamide  (C15H17NO4, CAS 10089-93-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3HydroxyNNBis2Hydroxyethyl2Naphthamide;
formula     C15H17NO4;
CAS         10089-93-7;
InChIKey    AWOGQGYSUKXISO-UHFFFAOYSA-N;
MW          275.304;      // g/mol [origin=calculated method=formula-sum]
Tc          1139.65;      // K   [origin=predictive method=joback]
Pc          34.480;      // bar [origin=predictive method=joback]
omega       1.9778;      // -   [origin=predictive method=lee-kesler]
Tb          924.73;      // K   [origin=predictive method=joback]
HvapTb      108723.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.466 1.6052 -0.00130414 4.3006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 6; } { group AC; count 3; } { group OH; count 2; } { group ACOH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH; count 2; } { group OH_phenol; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(2-hydroxyethyl)-3-oxidanyl-naphthalene-2-carboxamide" "3-hydroxy-n,n-bis(2-hydroxyethyl)naphthalene-2-carboxamide" "2-naphthalenecarboxamide, 3-hydroxy-n,n-bis(2-hydroxyethyl)-" "2-hydroxynaphthalene-3-carbonyldiethanolamide" "2-hydroxy-3-naphthoic acid diethanolamide" );
gibbsFormation
{
    dHf_298   -463620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-161550.0
    phase     gas;
}
