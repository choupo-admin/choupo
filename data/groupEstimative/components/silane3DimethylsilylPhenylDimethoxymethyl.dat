/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, (3-(dimethylsilyl)phenyl)dimethoxymethyl-  (C11H19O2Si2, CAS 33546-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H19O2Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silane3DimethylsilylPhenylDimethoxymethyl;
formula     C11H19O2Si2;
CAS         33546-27-9;
InChIKey    GWWPSGQTHGHONX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          239.441;      // g/mol [origin=calculated method=formula-sum]
Tc          739.73;      // K   [origin=predictive method=joback]
Pc          20.888;      // bar [origin=predictive method=joback]
omega       0.4273;      // -   [origin=predictive method=lee-kesler]
Tb          529.88;      // K   [origin=predictive method=joback]
HvapTb      48279.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (85.51 0.4748 0.00030544 -3.151e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-[dimethoxy(methyl)silyl]phenyl]-dimethyl-silicon" "[3-[dimethoxy(methyl)silyl]phenyl]-dimethylsilicon" );
gibbsFormation
{
    dHf_298   -477180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     693.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-222620.0
    phase     gas;
}
