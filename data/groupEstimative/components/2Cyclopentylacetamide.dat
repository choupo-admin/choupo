/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclopentylacetamide  (C7H13NO, CAS 933-04-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclopentylacetamide;
formula     C7H13NO;
CAS         933-04-0;
InChIKey    OXRCIXHTUHZNRY-UHFFFAOYSA-N;
MW          127.187;      // g/mol [origin=calculated method=formula-sum]
Tc          721.56;      // K   [origin=predictive method=joback]
Pc          39.555;      // bar [origin=predictive method=joback]
omega       0.5514;      // -   [origin=predictive method=lee-kesler]
Tb          501.44;      // K   [origin=predictive method=joback]
HvapTb      48820.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.109 0.8344 -0.0005091 1.1356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyclopentylethanamide" "cyclopentaneacetamide" "agn-pc-01vucf" );
standardThermochemistry
{
    dHf_298   -206120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17860.0
}
