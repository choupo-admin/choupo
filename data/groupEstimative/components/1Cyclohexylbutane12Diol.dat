/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexylbutane-1,2-diol  (C10H20O2, CAS 70289-26-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexylbutane12Diol;
formula     C10H20O2;
CAS         70289-26-8;
InChIKey    DOEPVCQGRSSMBZ-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          815.54;      // K   [origin=predictive method=joback]
Pc          31.811;      // bar [origin=predictive method=joback]
omega       1.2703;      // -   [origin=predictive method=lee-kesler]
Tb          631.43;      // K   [origin=predictive method=joback]
HvapTb      70865.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.589 1.15572 -0.0006684 1.36e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 3; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexaneethanol, alpha-ethyl-2-hydroxy-" "cyclohexaneethanol, a-ethyl-2-hydroxy-" );
gibbsFormation
{
    dHf_298   -510430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-220750.0
    phase     gas;
}
