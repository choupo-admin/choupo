/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-oxo-1,3-dihydroisobenzofuran-1-yliden)acetic acid  (C10H6O4, CAS 4743-57-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Oxo13Dihydroisobenzofuran1YlidenAceticAcid;
formula     C10H6O4;
CAS         4743-57-1;
InChIKey    XKMGDVJBAWUUDZ-UHFFFAOYSA-N;
MW          190.154;      // g/mol [origin=calculated method=formula-sum]
Tc          902.94;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       1.0118;      // -   [origin=predictive method=lee-kesler]
Tb          673.30;      // K   [origin=predictive method=joback]
HvapTb      66028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.64 0.9305 -0.00079926 2.675e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 3; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-oxidanylidene-2-benzofuran-1-ylidene)ethanoic acid" "2-(3-oxo-2-benzofuran-1-ylidene)acetic acid" );
standardThermochemistry
{
    dHf_298   -510730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-380060.0
}
