/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dihexylaniline  (C18H31N, CAS 4430-09-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDihexylaniline;
formula     C18H31N;
CAS         4430-09-5;
InChIKey    DGYRVXQIGUEFFK-UHFFFAOYSA-N;
MW          261.453;      // g/mol [origin=calculated method=formula-sum]
Tc          834.57;      // K   [origin=predictive method=joback]
Pc          14.601;      // bar [origin=predictive method=joback]
omega       0.7984;      // -   [origin=predictive method=lee-kesler]
Tb          650.56;      // K   [origin=predictive method=joback]
HvapTb      59981.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.07 1.75884 -0.0010992 2.659e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-di-n-hexylaniline" "benzenamine,n,n-dihexyl-" "dihexylamine,n-phenyl- (6ci,8ci);dihexylphenylamine;n,n-dihexylaniline;n-phenyldihexylamine;" );
gibbsFormation
{
    dHf_298   -110790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     766.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=323870.0
    phase     gas;
}
