/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(5-bromo-2-hydroxy-3-methylphenyl)propan-1-one  (C10H11BrO2, CAS 2887-56-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Bromo2Hydroxy3MethylphenylPropan1One;
formula     C10H11BrO2;
CAS         2887-56-1;
InChIKey    SKZDSFWVNVYIIY-UHFFFAOYSA-N;
MW          243.1;      // g/mol [origin=calculated method=formula-sum]
Tc          906.04;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.9106;      // -   [origin=predictive method=lee-kesler]
Tb          665.69;      // K   [origin=predictive method=joback]
HvapTb      67649.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.879 0.92074 -0.00072638 2.4166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group OH_phenol; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(5-bromanyl-3-methyl-2-oxidanyl-phenyl)propan-1-one" "propiophenone, 5-bromo-2-hydroxy-3-methyl-" "propiophenone, 5-bromo-2-hydroxy-3-methyl-," "propiophenone, 5'-bromo-2'-hydroxy-3'-methyl-" );
standardThermochemistry
{
    dHf_298   -299700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-142750.0
}
