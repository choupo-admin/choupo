/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisobutyl phthalate  (C16H22O4, CAS 84-69-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisobutylPhthalate;
formula     C16H22O4;
CAS         84-69-5;
InChIKey    MGWAVDBGNNKXQV-UHFFFAOYSA-N;
MW          278.348;      // g/mol [origin=calculated method=formula-sum]
Tc          916.75;      // K   [origin=predictive method=joback]
Pc          17.189;      // bar [origin=predictive method=joback]
omega       0.8908;      // -   [origin=predictive method=lee-kesler]
Tb          712.90;      // K   [origin=predictive method=joback]
HvapTb      68186.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.192 1.28768 -0.00062796 6.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-methylpropyl) benzene-1,2-dicarboxylate" "palatinol ic" "isobutyl phthalate" "phthalic acid, diisobutyl ester" "hexaplas m/1b" "dibp" "di-iso-butyl phthalate" "diisobutylphthalat" "kodaflex dibp" "hatcol dibp" "1,2-benzenedicarboxylic acid, bis(2-methylpropyl) ester" "di(i-butyl)phthalate" );
standardThermochemistry
{
    dHf_298   -793630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     750.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-439000.0
}
