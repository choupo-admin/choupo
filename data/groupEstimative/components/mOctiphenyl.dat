/*--------------------------------*- Choupo -*-----------------------*\
  Component: m-octiphenyl  (C48H34, CAS 16716-11-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mOctiphenyl;
formula     C48H34;
CAS         16716-11-3;
InChIKey    QJOBYJDULSYRSC-UHFFFAOYSA-N;
MW          610.8;      // g/mol [origin=calculated method=formula-sum]
Tc          1886.84;      // K   [origin=predictive method=joback]
Pc          9.363;      // bar [origin=predictive method=joback]
omega       0.9083;      // -   [origin=predictive method=lee-kesler]
Tb          1541.16;      // K   [origin=predictive method=joback]
HvapTb      144622.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-226.19 3.5756 -0.00243476 6.146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 34; } { group AC; count 14; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 34; } { group dC_ring; count 14; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl-3-[3-[3-[3-[3-(3-phenylphenyl)phenyl]phenyl]phenyl]phenyl]benzene" "1,1':3',1'':3'',1''':3''',1'''':3'''',1''''':3''''',1'''''':3'''''',1'''''''-octiphenyl" "m-octaphenyl" );
standardThermochemistry
{
    dHf_298   789370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1137.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1194780.0
}
