/*--------------------------------*- Choupo -*-----------------------*\
  Component: acropor  (C5H6ClN, CAS 9003-00-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acropor;
formula     C5H6ClN;
CAS         9003-00-3;
InChIKey    GRFFKYTUNTWAGG-UHFFFAOYSA-N;
MW          115.56;      // g/mol [origin=calculated method=formula-sum]
Tc          662.21;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       0.3418;      // -   [origin=predictive method=lee-kesler]
Tb          448.27;      // K   [origin=predictive method=joback]
HvapTb      40541.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.07 0.1742 0.0001314 -1.314e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACRY; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH; count 2; } { group Cl; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranylethene;prop-2-enenitrile" "acropore" "kanekalon" "modacryle" "dynel" "acropor an" "vinyon n" "dynel nygl" "skhn6" "2-propenenitrile, polymer with chloroethene" "acrylonitrile, polymer with chloroethylene" "chloroethene; prop-2-enenitrile" );
gibbsFormation
{
    dHf_298   141850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=183390.0
    phase     gas;
}
