/*--------------------------------*- Choupo -*-----------------------*\
  Component: didemethyldoxepin  (C17H17NO, CAS 5626-16-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        didemethyldoxepin;
formula     C17H17NO;
CAS         5626-16-4;
InChIKey    HLUSHBJOSPBFOC-DHDCSXOGSA-N;
MW          251.329;      // g/mol [origin=calculated method=formula-sum]
Tc          1020.43;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       0.8771;      // -   [origin=predictive method=lee-kesler]
Tb          769.41;      // K   [origin=predictive method=joback]
HvapTb      75472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.048 1.5008 -0.00110292 3.23e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group FCH2O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 5; } { group O_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3z)-3-(6h-benzo[c][1]benzoxepin-11-ylidene)propan-1-amine" "dibenz(b,e)oxepin-delta(sup 11(6h)), gamma-propylamine" "1-propanamine, 3-dibenz(b,e)oxepin-11(6h)-ylidene-" "1-propanamine, 3-dibenz(b,e)oxepin-11(6h)-ylidene- (9ci)" );
standardThermochemistry
{
    dHf_298   126870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=392070.0
}
