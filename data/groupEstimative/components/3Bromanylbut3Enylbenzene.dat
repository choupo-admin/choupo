/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromanylbut-3-enylbenzene  (C10H11Br, CAS 62692-40-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromanylbut3Enylbenzene;
formula     C10H11Br;
CAS         62692-40-4;
InChIKey    FXQTUECZVAFUFD-UHFFFAOYSA-N;
MW          211.102;      // g/mol [origin=calculated method=formula-sum]
Tc          748.13;      // K   [origin=predictive method=joback]
Pc          33.374;      // bar [origin=predictive method=joback]
omega       0.4593;      // -   [origin=predictive method=lee-kesler]
Tb          517.80;      // K   [origin=predictive method=joback]
HvapTb      45975.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.598 0.893 -0.000648 1.866e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   128770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=239340.0
}
