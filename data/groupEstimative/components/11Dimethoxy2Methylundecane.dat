/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethoxy-2-methylundecane  (C14H30O2, CAS 68141-17-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dimethoxy2Methylundecane;
formula     C14H30O2;
CAS         68141-17-3;
InChIKey    NJXYRZMLVYMJHM-UHFFFAOYSA-N;
MW          230.392;      // g/mol [origin=calculated method=formula-sum]
Tc          729.15;      // K   [origin=predictive method=joback]
Pc          15.023;      // bar [origin=predictive method=joback]
omega       0.7496;      // -   [origin=predictive method=lee-kesler]
Tb          563.88;      // K   [origin=predictive method=joback]
HvapTb      50802.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.798 1.21928 -0.0005222 4.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethoxy-2-methyl-undecane" "mna dimethyl acetal" "aldehyde c-12 mna dimethyl acetal" "undecane, 1,1-dimethoxy-2-methyl-" "methyl nonyl acetaldehyde dimethyl acetal" "2-methylundecanal dimethyl acetal" "methylnonylacetaldehyde dimethacetal" "alpha-methyl-alpha-nonylacetaldehyde, dimethyl acetal" );
standardThermochemistry
{
    dHf_298   -607290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147880.0
}
