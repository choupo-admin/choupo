/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-methylphenyl)cyclohexanol  (C13H18O, CAS 6957-09-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12MethylphenylCyclohexanol;
formula     C13H18O;
CAS         6957-09-1;
InChIKey    MCZGYWBDNZZZTJ-UHFFFAOYSA-N;
MW          190.286;      // g/mol [origin=calculated method=formula-sum]
Tc          866.79;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.8221;      // -   [origin=predictive method=lee-kesler]
Tb          640.67;      // K   [origin=predictive method=joback]
HvapTb      63427.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.84 1.54842 -0.00129156 4.615e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methylphenyl)cyclohexan-1-ol" "1-(o-tolyl)cyclohexan-1-ol" "cyclohexanol, 1-(2-methylphenyl)-" );
standardThermochemistry
{
    dHf_298   -169260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=43500.0
}
