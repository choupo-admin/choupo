/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-methanoanthracene,1,4-dihydro-9,10-dimethoxy-  (C17H16O2, CAS 52457-25-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Methanoanthracene14Dihydro910Dimethoxy;
formula     C17H16O2;
CAS         52457-25-7;
InChIKey    MVNKVWQSNVLBIV-UHFFFAOYSA-N;
MW          252.313;      // g/mol [origin=calculated method=formula-sum]
Tc          938.56;      // K   [origin=predictive method=joback]
Pc          22.741;      // bar [origin=predictive method=joback]
omega       0.8034;      // -   [origin=predictive method=lee-kesler]
Tb          707.35;      // K   [origin=predictive method=joback]
HvapTb      64766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.3 1.42724 -0.00105284 3.212e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 4; } { group ACCH; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "antrhracene, 1,4-dihydro-1,4-methano-9,10-dimethoxy-" "9,10-dimethoxy-1,4-dihydro-1,4-methanoanthracene" "1,4-methanoanthracene, 1,4-dihydro-9,10-dimethoxy-" );
gibbsFormation
{
    dHf_298   -67390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=226360.0
    phase     gas;
}
