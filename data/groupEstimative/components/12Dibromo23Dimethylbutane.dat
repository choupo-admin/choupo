/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromo-2,3-dimethylbutane  (C6H12Br2, CAS 29916-45-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromo23Dimethylbutane;
formula     C6H12Br2;
CAS         29916-45-8;
InChIKey    ZUUWMYZAMGXEKF-UHFFFAOYSA-N;
MW          243.97;      // g/mol [origin=calculated method=formula-sum]
Tc          685.89;      // K   [origin=predictive method=joback]
Pc          37.684;      // bar [origin=predictive method=joback]
omega       0.4145;      // -   [origin=predictive method=lee-kesler]
Tb          465.53;      // K   [origin=predictive method=joback]
HvapTb      40136.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.339 0.78196 -0.0006204 1.998e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)-2,3-dimethyl-butane" );
gibbsFormation
{
    dHf_298   -128540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28680.0
    phase     gas;
}
