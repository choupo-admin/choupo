/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butanamine, 2-(3-pentadecylphenoxy)-  (C25H45NO, CAS 62609-90-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butanamine23Pentadecylphenoxy;
formula     C25H45NO;
CAS         62609-90-9;
InChIKey    PFPQBPMLYGILQK-UHFFFAOYSA-N;
MW          375.641;      // g/mol [origin=calculated method=formula-sum]
Tc          1100.59;      // K   [origin=predictive method=joback]
Pc          9.444;      // bar [origin=predictive method=joback]
omega       0.9013;      // -   [origin=predictive method=lee-kesler]
Tb          897.77;      // K   [origin=predictive method=joback]
HvapTb      86845.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.134 2.24504 -0.00123596 2.426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH-O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-pentadecylphenoxy)butan-1-amine" );
gibbsFormation
{
    dHf_298   -437980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1070.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=221410.0
    phase     gas;
}
