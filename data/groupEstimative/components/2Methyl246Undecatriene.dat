/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-2,4,6-undecatriene  (C12H20, CAS 73398-99-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl246Undecatriene;
formula     C12H20;
CAS         73398-99-9;
InChIKey    UIIGNQXUZIMYKD-UHFFFAOYSA-N;
MW          164.292;      // g/mol [origin=calculated method=formula-sum]
Tc          673.50;      // K   [origin=predictive method=joback]
Pc          20.493;      // bar [origin=predictive method=joback]
omega       0.4638;      // -   [origin=predictive method=lee-kesler]
Tb          486.52;      // K   [origin=predictive method=joback]
HvapTb      42260.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.257 1.20376 -0.0008827 2.756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH=CH; count 2; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH; count 5; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylundeca-2,4,6-triene" "2,4,6-undecatriene, 2-methyl-" );
standardThermochemistry
{
    dHf_298   50860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=282270.0
}
