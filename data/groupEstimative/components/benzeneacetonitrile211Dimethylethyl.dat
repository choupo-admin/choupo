/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzeneacetonitrile, 2-(1,1-dimethylethyl)-  (C12H15N, CAS 72269-54-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneacetonitrile211Dimethylethyl;
formula     C12H15N;
CAS         72269-54-6;
InChIKey    QCOBYVFHJPONNS-UHFFFAOYSA-N;
MW          173.259;      // g/mol [origin=calculated method=formula-sum]
Tc          834.45;      // K   [origin=predictive method=joback]
Pc          23.565;      // bar [origin=predictive method=joback]
omega       0.5515;      // -   [origin=predictive method=lee-kesler]
Tb          604.67;      // K   [origin=predictive method=joback]
HvapTb      54426.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.099 1.06606 -0.00073396 1.978e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-tert-butylphenyl)ethanenitrile" "o-tert-butylbenzyl cyanide" "2-(2-tert-butylphenyl)acetonitrile" );
standardThermochemistry
{
    dHf_298   90180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=288960.0
}
