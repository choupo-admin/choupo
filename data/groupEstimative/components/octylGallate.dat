/*--------------------------------*- Choupo -*-----------------------*\
  Component: octyl gallate  (C15H22O5, CAS 1034-01-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octylGallate;
formula     C15H22O5;
CAS         1034-01-1;
InChIKey    NRPKURNSADTHLJ-UHFFFAOYSA-N;
MW          282.336;      // g/mol [origin=calculated method=formula-sum]
Tc          1091.69;      // K   [origin=predictive method=joback]
Pc          28.444;      // bar [origin=predictive method=joback]
omega       1.5348;      // -   [origin=predictive method=lee-kesler]
Tb          869.56;      // K   [origin=predictive method=joback]
HvapTb      97709.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.003 1.75892 -0.00149788 5.35e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octyl 3,4,5-tris(oxidanyl)benzoate" "n-octyl gallate" "octyl 3,4,5-trihydroxybenzoate" "progallin o" "stabilizer ga 8" "gallic acid, octyl ester" "gallic acid n-octyl ester" "benzoic acid, 3,4,5-trihydroxy-, octyl ester" "ga 8 (van)" "e311" "n-octyl ester of 3,4,5-trihydroxybenzoic acid" "n-octylgallate" );
standardThermochemistry
{
    dHf_298   -965610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     764.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-586400.0
}
