/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropylphenyl isocyanate  (C10H11NO, CAS 56309-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2IsopropylphenylIsocyanate;
formula     C10H11NO;
CAS         56309-56-9;
InChIKey    MWBSQVPLYJZPTG-UHFFFAOYSA-N;
MW          161.204;      // g/mol [origin=calculated method=formula-sum]
Tc          746.32;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.5332;      // -   [origin=predictive method=lee-kesler]
Tb          526.29;      // K   [origin=predictive method=joback]
HvapTb      49936.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-2-propan-2-yl-benzene" "1-isocyanato-2-isopropylbenzene" "2-isopropylphenylisocyanate" "1-isocyanato-2-propan-2-ylbenzene" "2-(methylethyl)benzenisocyanate" "o-isopropylphenyl isocyanate" "1-isocyanato-2-isopropyl-benzene" "1-isocyanato-2-(propan-2-yl)benzene" "benzene,1-isocyanato-2-(1-methylethyl)-" "1-isocyanato-2-isopropylbenzene;2-isopropylphenyl isocyanate;o-cumenyl isocyanate;" );
