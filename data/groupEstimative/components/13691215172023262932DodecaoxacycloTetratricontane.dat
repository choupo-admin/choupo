/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,6,9,12,15,17,20,23,26,29,32-dodecaoxacyclo-tetratricontane  (C22H44O12, CAS 74485-52-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13691215172023262932DodecaoxacycloTetratricontane;
formula     C22H44O12;
CAS         74485-52-2;
InChIKey    WYXQDRKSZZXFCT-UHFFFAOYSA-N;
MW          500.582;      // g/mol [origin=calculated method=formula-sum]
Tc          1470.38;      // K   [origin=predictive method=joback]
Pc          16.000;      // bar [origin=predictive method=joback]
omega       1.0707;      // -   [origin=predictive method=lee-kesler]
Tb          1170.14;      // K   [origin=predictive method=joback]
HvapTb      124240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.19 1.9376 0.0001566 -6.532e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group FCH2O; count 12; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 22; } { group O_ring; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,6,9,12,15,17,20,23,26,29,32-dodecaoxacyclotetratriacontane" );
gibbsFormation
{
    dHf_298   -2179230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     966.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1205720.0
    phase     gas;
}
