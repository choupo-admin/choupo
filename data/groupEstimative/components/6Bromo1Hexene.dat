/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-bromo-1-hexene  (C6H11Br, CAS 2695-47-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Bromo1Hexene;
formula     C6H11Br;
CAS         2695-47-8;
InChIKey    RIMXEJYJXDBLIE-UHFFFAOYSA-N;
MW          163.058;      // g/mol [origin=calculated method=formula-sum]
Tc          587.52;      // K   [origin=predictive method=joback]
Pc          35.305;      // bar [origin=predictive method=joback]
omega       0.4002;      // -   [origin=predictive method=lee-kesler]
Tb          399.72;      // K   [origin=predictive method=joback]
HvapTb      34715.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.634 0.592 -0.0003969 1.117e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-bromanylhex-1-ene" "6-bromohex-1-ene" "1-bromo-5-hexene" "1-hexene, 6-bromo-" "5-hexenyl bromide" "6-bromo-hexene" "6-bromo-hex-1-ene" "bromo(6-)-1-hexene" "hex-5-en-1-yl bromide" "rimxejyjxdblie-uhfffaoysa-" "1-bromo-5-hexene;5-hexen-1-yl bromide;5-hexenyl bromide;6-bromohexene;" "1-bromo-5-hexene; 5-hexen-1-yl bromide; 5-hexenyl bromide; 6-bromo-1-hexene; 6-bromohexene" );
gibbsFormation
{
    dHf_298   -15410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=101800.0
    phase     gas;
}
