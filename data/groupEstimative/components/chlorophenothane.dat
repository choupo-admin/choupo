/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorophenothane  (C14H9Cl5, CAS 50-29-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorophenothane;
formula     C14H9Cl5;
CAS         50-29-3;
InChIKey    YVGGHNCTFXOJCH-UHFFFAOYSA-N;
MW          354.476;      // g/mol [origin=calculated method=formula-sum]
Tc          1041.61;      // K   [origin=predictive method=joback]
Pc          22.937;      // bar [origin=predictive method=joback]
omega       0.6368;      // -   [origin=predictive method=lee-kesler]
Tb          766.72;      // K   [origin=predictive method=joback]
HvapTb      72875.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.75 1.2227 -0.00094312 2.73e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 1; } { group CCl3; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-[2,2,2-tris(chloranyl)-1-(4-chlorophenyl)ethyl]benzene" "clofenotane" "p,p'-ddt" "dichlorodiphenyltrichloroethane" "chlorphenothan" "chlorphenotoxum" "parachlorocidum" "pentachlorin" "dicophane" "4,4'-ddt" "benzochloryl" "arkotine" );
standardThermochemistry
{
    dHf_298   25100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213310.0
}
