/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-octadecenoic acid (9z)-, 1-[(acetyloxy)methyl]-1,2-ethanediyl ester  (C41H74O6, CAS 67873-96-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9OctadecenoicAcid9z1AcetyloxyMethyl12EthanediylEster;
formula     C41H74O6;
CAS         67873-96-5;
InChIKey    UPZFMXRNWVDKHF-UHFFFAOYSA-N;
MW          663.037;      // g/mol [origin=calculated method=formula-sum]
Tc          1881.14;      // K   [origin=predictive method=joback]
Pc          3.957;      // bar [origin=predictive method=joback]
omega       -0.4041;      // -   [origin=predictive method=lee-kesler]
Tb          1320.22;      // K   [origin=predictive method=joback]
HvapTb      128609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.8 3.78036 -0.0020936 3.997e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 28; } { group CH; count 1; } { group CH=CH; count 2; } { group CH3COO; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 30; } { group CH; count 1; } { group dCH; count 4; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-acetyloxy-2-octadec-9-enoyloxy-propyl) octadec-9-enoate" "9-octadecenoic acid (9z)-, 1,1'-[1-[(acetyloxy)methyl]-1,2-ethanediyl] ester" );
standardThermochemistry
{
    dHf_298   -1612250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1884.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-478770.0
}
