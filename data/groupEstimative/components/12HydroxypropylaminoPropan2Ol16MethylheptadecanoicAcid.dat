/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-hydroxypropylamino)propan-2-ol; 16-methylheptadecanoic acid  (C24H51NO4, CAS 93920-27-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12HydroxypropylaminoPropan2Ol16MethylheptadecanoicAcid;
formula     C24H51NO4;
CAS         93920-27-5;
InChIKey    JCYUOONTSJDBNQ-UHFFFAOYSA-N;
MW          417.675;      // g/mol [origin=calculated method=formula-sum]
Tc          1440.63;      // K   [origin=predictive method=joback]
Pc          9.183;      // bar [origin=predictive method=joback]
omega       0.5097;      // -   [origin=predictive method=lee-kesler]
Tb          1128.84;      // K   [origin=predictive method=joback]
HvapTb      125106.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.816 2.29038 -0.0010586 1.138e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 15; } { group CH; count 3; } { group OH; count 2; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 16; } { group CH; count 3; } { group OH; count 2; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "16-methylheptadecanoic acid;1-(2-oxidanylpropylamino)propan-2-ol" "isooctadecanoic acid compd. with 1,1'-iminobis[2-propanol] (1:1)" "isooctadecanoic acid, compound with 1,1'-iminodi(propan-2-ol) (1:1)" );
gibbsFormation
{
    dHf_298   -1267410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1365.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-489040.0
    phase     gas;
}
