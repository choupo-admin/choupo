/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(dioctadecylcarbamoyl)benzoic acid  (C44H79NO3, CAS 127733-92-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DioctadecylcarbamoylBenzoicAcid;
formula     C44H79NO3;
CAS         127733-92-0;
InChIKey    QWZDGDRJLIDZKT-UHFFFAOYSA-N;
MW          670.12;      // g/mol [origin=calculated method=formula-sum]
Tc          2165.24;      // K   [origin=predictive method=joback]
Pc          4.039;      // bar [origin=predictive method=joback]
omega       -0.4619;      // -   [origin=predictive method=lee-kesler]
Tb          1449.80;      // K   [origin=predictive method=joback]
HvapTb      142429.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.446 4.19214 -0.00250046 5.6936e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 32; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 34; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, 2-[(dioctadecylamino)carbonyl]-" "benzoic acid, 2-((dioctadecylamino)carbonyl)-" "distearyl phthalamic acid" "agn-pc-00jp9d" "dihydrogenated tallow phthalic acid amide" "2-[(dioctadecylamino)carbonyl]benzoic acid" );
gibbsFormation
{
    dHf_298   -1121750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1853.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60330.0
    phase     gas;
}
