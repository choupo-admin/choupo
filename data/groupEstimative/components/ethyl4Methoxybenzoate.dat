/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 4-methoxybenzoate  (C10H12O3, CAS 94-30-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl4Methoxybenzoate;
formula     C10H12O3;
CAS         94-30-4;
InChIKey    FHUODBDRWMIBQP-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          749.66;      // K   [origin=predictive method=joback]
Pc          28.475;      // bar [origin=predictive method=joback]
omega       0.6169;      // -   [origin=predictive method=lee-kesler]
Tb          540.70;      // K   [origin=predictive method=joback]
HvapTb      50609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.101 0.69744 -0.00027876 -3.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl p-anisate" "ethyl anisate" "p-anisic acid, ethyl ester" "ethyl p-methoxybenzoate" "4-methoxybenzoic acid ethyl ester" "benzoic acid, 4-methoxy-, ethyl ester" "p-anisic acid ethyl ester" "ethyl p-methoxylbenzoate" "benzoic acid, p-methoxy-, ethyl ester" "ethyl-4-anisate" "ethyl-p-methoxy benzoate" "4-methoxy-benzoic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -474170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-279270.0
    phase     gas;
}
