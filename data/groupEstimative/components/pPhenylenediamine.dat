/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-phenylenediamine  (C6H8N2, CAS 106-50-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pPhenylenediamine;
formula     C6H8N2;
CAS         106-50-3;
InChIKey    CBCKQZAAMUWICA-UHFFFAOYSA-N;
MW          108.144;      // g/mol [origin=calculated method=formula-sum]
Tc          757.47;      // K   [origin=predictive method=joback]
Pc          53.749;      // bar [origin=predictive method=joback]
omega       0.5462;      // -   [origin=predictive method=lee-kesler]
Tb          513.60;      // K   [origin=predictive method=joback]
HvapTb      53170.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.19 0.5592 -0.00035356 8.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,4-diamine" "1,4-benzenediamine" "1,4-diaminobenzene" "4-aminoaniline" "1,4-phenylenediamine" "p-aminoaniline" "orsin" "para-phenylenediamine" "p-diaminobenzene" "4-phenylenediamine" "paraphenylenediamine" "p-phenyldiamine" );
standardThermochemistry
{
    dHf_298   125470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=235320.0
}
