/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclododecane, methoxy-  (C13H26O, CAS 2986-54-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclododecaneMethoxy;
formula     C13H26O;
CAS         2986-54-1;
InChIKey    WDSOYUINLRIGNV-UHFFFAOYSA-N;
MW          198.35;      // g/mol [origin=calculated method=formula-sum]
Tc          797.16;      // K   [origin=predictive method=joback]
Pc          22.083;      // bar [origin=predictive method=joback]
omega       0.3952;      // -   [origin=predictive method=lee-kesler]
Tb          564.63;      // K   [origin=predictive method=joback]
HvapTb      48403.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.76 1.24012 -0.000375 -8.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 11; } { group CH_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methoxycyclododecane" "cyclododecyl methyl ether" "methyl cyclododecyl ether" "cyclododecanolmethylether" "ether,cyclododecyl methyl (7ci,8ci); cyclododecyl methyl ether; methoxycyclododecane" );
gibbsFormation
{
    dHf_298   -426510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     762.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94570.0
    phase     gas;
}
