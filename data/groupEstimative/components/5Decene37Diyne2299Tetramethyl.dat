/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-decene-3,7-diyne, 2,2,9,9-tetramethyl-  (C14H20, CAS 102745-35-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Decene37Diyne2299Tetramethyl;
formula     C14H20;
CAS         102745-35-7;
InChIKey    UUSGALMHPVDLPR-UHFFFAOYSA-N;
MW          188.314;      // g/mol [origin=calculated method=formula-sum]
Tc          771.99;      // K   [origin=predictive method=joback]
Pc          21.593;      // bar [origin=predictive method=joback]
omega       0.2890;      // -   [origin=predictive method=lee-kesler]
Tb          535.62;      // K   [origin=predictive method=joback]
HvapTb      48428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.85 1.30592 -0.00098092 3.0456e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group CH=CH; count 1; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group dCH; count 2; } { group tC; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,9,9-tetramethyldec-5-en-3,7-diyne" );
gibbsFormation
{
    dHf_298   312030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=558500.0
    phase     gas;
}
