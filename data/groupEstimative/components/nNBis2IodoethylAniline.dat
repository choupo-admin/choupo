/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(2-iodoethyl)aniline  (C10H13I2N, CAS 1669-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis2IodoethylAniline;
formula     C10H13I2N;
CAS         1669-84-7;
InChIKey    JQLBXLQMDUHDGG-UHFFFAOYSA-N;
MW          401.021;      // g/mol [origin=calculated method=formula-sum]
Tc          916.07;      // K   [origin=predictive method=joback]
Pc          27.906;      // bar [origin=predictive method=joback]
omega       0.5443;      // -   [origin=predictive method=lee-kesler]
Tb          653.80;      // K   [origin=predictive method=joback]
HvapTb      60919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.416 1.0768 -0.0008268 2.505e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group I; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(2-iodanylethyl)aniline" "aniline, n,n-bis(2-iodoethyl)-" "aniline,n,n-bis(2-iodoethyl)-, hydrochloride (7ci,8ci)" "benzenamine,n,n-bis(2-iodoethyl)-, hydrochloride (1:1)" );
gibbsFormation
{
    dHf_298   208070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=372750.0
    phase     gas;
}
