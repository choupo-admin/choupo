/*--------------------------------*- Choupo -*-----------------------*\
  Component: poly(5-methyl-1,9-nonaneterephthalamide)  (C18H30N2O4, CAS 50507-31-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        poly5Methyl19Nonaneterephthalamide;
formula     C18H30N2O4;
CAS         50507-31-8;
InChIKey    UZYXKHDZSWRYKO-UHFFFAOYSA-N;
MW          338.448;      // g/mol [origin=calculated method=formula-sum]
Tc          1324.12;      // K   [origin=predictive method=joback]
Pc          17.104;      // bar [origin=predictive method=joback]
omega       1.4381;      // -   [origin=predictive method=lee-kesler]
Tb          1080.14;      // K   [origin=predictive method=joback]
HvapTb      114116.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.238 1.60052 -0.00073996 6.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2NH2; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylnonane-1,9-diamine;terephthalic acid" "1,4-benzenedicarboxylic acid, polymer with 5-methyl-1,9-nonanediamine" "5-methylnonane-1,9-diamine; terephthalic acid" "benzene-1,4-dicarboxylic acid; 5-methylnonane-1,9-diamine" );
standardThermochemistry
{
    dHf_298   -939650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1052.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-458660.0
}
