/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropyl-2,5,5-trimethyl-1,3-dioxane  (C10H20O2, CAS 32362-64-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropyl255Trimethyl13Dioxane;
formula     C10H20O2;
CAS         32362-64-4;
InChIKey    IXOFPNRLOQANTH-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          714.42;      // K   [origin=predictive method=joback]
Pc          26.958;      // bar [origin=predictive method=joback]
omega       0.3968;      // -   [origin=predictive method=lee-kesler]
Tb          497.22;      // K   [origin=predictive method=joback]
HvapTb      44304.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.89 1.6332 -0.0015864 6.673e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH; count 1; } { group C; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5,5-trimethyl-2-propan-2-yl-1,3-dioxane" "1,3-dioxane, 2,5,5-trimethyl-2-(1-methylethyl)-" "m-dioxane, 2-isopropyl-2,5,5-trimethyl-" "2,5,5-trimethyl-2-(propan-2-yl)-1,3-dioxane" "methyl isopropyl ketone, 2,2-dimethyl-1,3-propanediol ketal" );
gibbsFormation
{
    dHf_298   -454550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-135600.0
    phase     gas;
}
