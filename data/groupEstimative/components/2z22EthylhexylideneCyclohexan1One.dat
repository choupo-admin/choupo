/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2z)-2-(2-ethylhexylidene)cyclohexan-1-one  (C14H24O, CAS 6628-38-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2z22EthylhexylideneCyclohexan1One;
formula     C14H24O;
CAS         6628-38-2;
InChIKey    KBSFOAUXMZPTDU-UHFFFAOYSA-N;
MW          208.345;      // g/mol [origin=calculated method=formula-sum]
Tc          828.99;      // K   [origin=predictive method=joback]
Pc          19.718;      // bar [origin=predictive method=joback]
omega       0.6412;      // -   [origin=predictive method=lee-kesler]
Tb          618.16;      // K   [origin=predictive method=joback]
HvapTb      52142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.536 1.24254 -0.0006019 8.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group dCH; count 1; } { group CH2_ring; count 4; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-ethylhexylidene)cyclohexan-1-one" "2-(beta-ethylhexylidene)-1-cyclohexanone" "2-(2-ethylhexylidene)cyclohexanone" "(2e)-2-[(2r)-2-ethylhexylidene]cyclohexanone" );
gibbsFormation
{
    dHf_298   -324580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=19590.0
    phase     gas;
}
