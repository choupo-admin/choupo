/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butylcyclopentanone  (C9H16O, CAS 934-42-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butylcyclopentanone;
formula     C9H16O;
CAS         934-42-9;
InChIKey    ZAQYRXDJFINJJE-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          697.57;      // K   [origin=predictive method=joback]
Pc          28.689;      // bar [origin=predictive method=joback]
omega       0.4553;      // -   [origin=predictive method=lee-kesler]
Tb          488.62;      // K   [origin=predictive method=joback]
HvapTb      40132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.347 0.82222 -0.0003492 2.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butylcyclopentan-1-one" "cyclopentanone, 2-butyl-" "2-butyl cyclopentanone" );
gibbsFormation
{
    dHf_298   -306310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-61140.0
    phase     gas;
}
