/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-tert-butylphenoxy)acetic acid  (C12H16O3, CAS 1798-04-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylphenoxyAceticAcid;
formula     C12H16O3;
CAS         1798-04-5;
InChIKey    FBIGAJNVRFKBJL-UHFFFAOYSA-N;
MW          208.257;      // g/mol [origin=calculated method=formula-sum]
Tc          893.31;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       0.8492;      // -   [origin=predictive method=lee-kesler]
Tb          670.52;      // K   [origin=predictive method=joback]
HvapTb      63522.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.999 1.11886 -0.00072656 1.773e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-tert-butylphenoxy)ethanoic acid" "4-tert-butylphenoxyacetic acid" "(4-tert-butyl-phenoxy)-acetic acid" "(p-tert-butylphenoxy)acetic acid" "2-[4-(tert-butyl)phenoxy]acetic acid" "p-tert-butylphenoxyacetic acid" "2-(4-tert-butylphenoxy)acetic acid" "acetic acid,1-dimethylethyl)phenoxy]-" "4-(1,1-dimethylethyl)phenoxyacetic acid" "acetic acid,2-[4-(1,1-dimethylethyl)phenoxy]-" );
gibbsFormation
{
    dHf_298   -557190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-293130.0
    phase     gas;
}
