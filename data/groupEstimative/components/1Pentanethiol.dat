/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentanethiol  (C5H12S, CAS 110-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pentanethiol;
formula     C5H12S;
CAS         110-66-7;
InChIKey    ZRKMQKLGEQPLNS-UHFFFAOYSA-N;
MW          104.211;      // g/mol [origin=calculated method=formula-sum]
Tc          566.76;      // K   [origin=predictive method=joback]
Pc          37.454;      // bar [origin=predictive method=joback]
omega       0.3240;      // -   [origin=predictive method=lee-kesler]
Tb          376.86;      // K   [origin=predictive method=joback]
HvapTb      33461.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.234 0.50612 -0.0002706 5.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentane-1-thiol" "n-amyl mercaptan" "amyl mercaptan" "pentyl mercaptan" "pentanethiol" "pentylmercaptan" "pentalarm" "amyl mercaptans" "amyl sulfhydrate" "amyl thioalcohol" "thioamyl alcohol" "amyl hydrosulfide" );
standardThermochemistry
{
    dHf_298   -108050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20610.0
}
