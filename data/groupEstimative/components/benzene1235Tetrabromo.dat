/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,2,3,5-tetrabromo-  (C6H2Br4, CAS 634-89-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1235Tetrabromo;
formula     C6H2Br4;
CAS         634-89-9;
InChIKey    YPFCYPZKFQPCOC-UHFFFAOYSA-N;
MW          393.698;      // g/mol [origin=calculated method=formula-sum]
Tc          931.70;      // K   [origin=predictive method=joback]
Pc          65.884;      // bar [origin=predictive method=joback]
omega       0.7256;      // -   [origin=predictive method=lee-kesler]
Tb          643.14;      // K   [origin=predictive method=joback]
HvapTb      58952.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.19 0.4692 -0.00041828 1.474e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group Br; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,5-tetrakis(bromanyl)benzene" "1,2,3,5-tetrabromobenzene" "1,2,3,5-tetrabromo-benzene" );
standardThermochemistry
{
    dHf_298   140270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140440.0
}
