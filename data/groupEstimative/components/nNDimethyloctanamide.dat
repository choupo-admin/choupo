/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyloctanamide  (C10H21NO, CAS 1118-92-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyloctanamide;
formula     C10H21NO;
CAS         1118-92-9;
InChIKey    VHRUBWHAOUIMDW-UHFFFAOYSA-N;
MW          171.284;      // g/mol [origin=calculated method=formula-sum]
Tc          665.94;      // K   [origin=predictive method=joback]
Pc          22.313;      // bar [origin=predictive method=joback]
omega       0.6846;      // -   [origin=predictive method=lee-kesler]
Tb          494.71;      // K   [origin=predictive method=joback]
HvapTb      46643.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.534 1.04976 -0.0006141 1.3616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octanamide, n,n-dimethyl-" "n,n-dimethylcaprylamide" "nn-dimethyloctanamide" "n,n-dimethyl octanamide" "caprylamide,n,n-dimethyl- (4ci);n,n-dimethylcaprylamide;" );
standardThermochemistry
{
    dHf_298   -294780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15180.0
}
