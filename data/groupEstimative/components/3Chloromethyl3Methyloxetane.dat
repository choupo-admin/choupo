/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(chloromethyl)-3-methyloxetane  (C5H9ClO, CAS 822-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloromethyl3Methyloxetane;
formula     C5H9ClO;
CAS         822-48-0;
InChIKey    MCZYEFODKAZWIH-UHFFFAOYSA-N;
MW          120.576;      // g/mol [origin=calculated method=formula-sum]
Tc          596.88;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       0.2913;      // -   [origin=predictive method=lee-kesler]
Tb          389.63;      // K   [origin=predictive method=joback]
HvapTb      34553.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.799 0.91582 -0.0009611 4.16e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group FCH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group Cl; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(chloromethyl)-3-methyl-oxetane" "2-(chloromethyl)-2-methyl-1,3-epoxypropane" "oxetane, 3-(chloromethyl)-3-methyl-" "3-chloromethyl-3-methyloxetane" "2-(chloromethyl)-1,3-epoxy-2-methylpropane" "ht698" "3-methyl-3-chloromethyloxetane" "3-methyloxetane, 3-(chloromethyl)-" "822-48-0 3-(chloromethyl)-3-methyloxetane" );
standardThermochemistry
{
    dHf_298   -212390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     332.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-63670.0
}
