/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethyloct-6-enyl but-2-enoate  (C14H24O2, CAS 68039-38-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethyloct6EnylBut2Enoate;
formula     C14H24O2;
CAS         68039-38-3;
InChIKey    MYGZJMACIRJNPL-UHFFFAOYSA-N;
MW          224.344;      // g/mol [origin=calculated method=formula-sum]
Tc          769.61;      // K   [origin=predictive method=joback]
Pc          16.797;      // bar [origin=predictive method=joback]
omega       0.6968;      // -   [origin=predictive method=lee-kesler]
Tb          585.90;      // K   [origin=predictive method=joback]
HvapTb      53773.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.166 1.32488 -0.0008163 1.944e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group dCH; count 3; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butenoic acid 3,7-dimethyl-6-octenyl ester" "2-butenoic acid, 3,7-dimethyl-6-octen-1-yl ester" );
gibbsFormation
{
    dHf_298   -430200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     725.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-93920.0
    phase     gas;
}
