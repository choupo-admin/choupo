/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(acetoxy)-3-methylnonan-1-oic acid  (C12H22O4, CAS 68922-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Acetoxy3Methylnonan1OicAcid;
formula     C12H22O4;
CAS         68922-16-7;
InChIKey    VIBLYVCTGOEYFA-UHFFFAOYSA-N;
MW          230.304;      // g/mol [origin=calculated method=formula-sum]
Tc          865.39;      // K   [origin=predictive method=joback]
Pc          19.579;      // bar [origin=predictive method=joback]
omega       1.0411;      // -   [origin=predictive method=lee-kesler]
Tb          677.01;      // K   [origin=predictive method=joback]
HvapTb      66101.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.625 1.15166 -0.0006134 1.015e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 2; } { group CH3COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-acetyloxy-3-methyl-nonanoic acid" "3-methyl-4-acetoxynonanoic acid" "nonanoic acid, 4-(acetyloxy)-3-methyl-" "4-acetyloxy-3-methylnonanoic acid" "nonanoic acid,4-(acetyloxy)-3-methyl-" );
gibbsFormation
{
    dHf_298   -969120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     708.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-609000.0
    phase     gas;
}
