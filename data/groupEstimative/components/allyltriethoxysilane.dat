/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyltriethoxysilane  (C9H20O3Si, CAS 2550-04-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H20O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        allyltriethoxysilane;
formula     C9H20O3Si;
CAS         2550-04-1;
InChIKey    UMFJXASDGBJDEB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          204.341;      // g/mol [origin=calculated method=formula-sum]
Tc          642.63;      // K   [origin=predictive method=joback]
Pc          20.456;      // bar [origin=predictive method=joback]
omega       0.5464;      // -   [origin=predictive method=lee-kesler]
Tb          470.86;      // K   [origin=predictive method=joback]
HvapTb      42482.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (109.034 0.44306 0.0002591 -2.683e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CH2O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethoxy(prop-2-enyl)silane" "triethoxyallylsilane" "silane, triethoxy-2-propenyl-" "allytriethoxysilane" "silane, allyltriethoxy-" "silane, triethoxy-2-propen-1-yl-" "3-(triethoxysilyl)prop-1-ene" "triethoxy(prop-2-en-1-yl)silane" );
gibbsFormation
{
    dHf_298   -611940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     662.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-307020.0
    phase     gas;
}
