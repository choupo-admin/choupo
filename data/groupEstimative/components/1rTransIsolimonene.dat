/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r)-(+)-trans-isolimonene  (C10H16, CAS 5113-87-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1rTransIsolimonene;
formula     C10H16;
CAS         5113-87-1;
InChIKey    TWCNAXRPQBLSNO-UWVGGRQHSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          646.03;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       0.2917;      // -   [origin=predictive method=lee-kesler]
Tb          439.00;      // K   [origin=predictive method=joback]
HvapTb      37676.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.77 0.97334 -0.00055828 1.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,6r)-3-methyl-6-prop-1-en-2-yl-cyclohexene" "(+)-p-mentha-2,8-diene" "p-mentha-2,8-diene,(1r,4r)-(+)-" "(3r,6r)-3-isopropenyl-6-methylcyclohexene" "p-mentha-2,8-diene, (1r,4r)-(+)-" "(1r)-trans-isolimonene" "()-p-mentha-2,8-diene" "cyclohexene, 3-methyl-6-(1-methylethenyl)-, (3r-trans)-" "(1r)-()-trans-isolimonene" "(3r,6r)-3-methyl-6-prop-1-en-2-ylcyclohexene" "(3r-trans)-3-methyl-6-(1-methylvinyl)cyclohexene" "cyclohexene,3-methyl-6-(1-methylethenyl)-, (3r-trans)-; p-mentha-2,8-diene, (1r,4r)-(+)-(8ci); (+)-(1r,4r)-isolimonene; (+)-(1r,4r)-trans-isolimonene;(+)-trans-1-methyl-4-isopropenyl-2-cyclohexene; (+)-trans-isolimonene;(1r)-(+)-trans-isolimonene; (1r,4r)-isolimonene; isolimonene; isolimonene,trans-(+)-; trans-(+)-isolimonene" );
gibbsFormation
{
    dHf_298   -42330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=159310.0
    phase     gas;
}
