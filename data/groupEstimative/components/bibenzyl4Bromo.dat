/*--------------------------------*- Choupo -*-----------------------*\
  Component: bibenzyl, 4-bromo-  (C14H13Br, CAS 14310-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bibenzyl4Bromo;
formula     C14H13Br;
CAS         14310-24-8;
InChIKey    FTRWFZZSIXRXFI-UHFFFAOYSA-N;
MW          261.162;      // g/mol [origin=calculated method=formula-sum]
Tc          897.81;      // K   [origin=predictive method=joback]
Pc          29.345;      // bar [origin=predictive method=joback]
omega       0.6018;      // -   [origin=predictive method=lee-kesler]
Tb          644.42;      // K   [origin=predictive method=joback]
HvapTb      58407.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.158 1.1547 -0.00080456 2.156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-(2-phenylethyl)benzene" "benzene, 1-bromo-4-(2-phenylethyl)-" "1-bromo-4-phenethylbenzene" "1-(4-bromophenyl)-2-phenylethane" "1-bromo-4-(2-phenylethyl)benzene" );
gibbsFormation
{
    dHf_298   155630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=296510.0
    phase     gas;
}
