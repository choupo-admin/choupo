/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenyl-4-propan-2-yloxybutanenitrile  (C13H17NO, CAS 70289-00-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenyl4Propan2Yloxybutanenitrile;
formula     C13H17NO;
CAS         70289-00-8;
InChIKey    KBAUUAZQHABMLG-UHFFFAOYSA-N;
MW          203.285;      // g/mol [origin=calculated method=formula-sum]
Tc          865.24;      // K   [origin=predictive method=joback]
Pc          21.414;      // bar [origin=predictive method=joback]
omega       0.7123;      // -   [origin=predictive method=lee-kesler]
Tb          647.34;      // K   [origin=predictive method=joback]
HvapTb      58920.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.698 1.04334 -0.000579 1.069e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CH-O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenyl-4-propan-2-yloxy-butanenitrile" "4-phenyl-4-(propan-2-yloxy)butanenitrile" "gamma-(1-methylethoxy)benzenebutyronitrile" "benzenebutanenitrile, " "a-(1-methylethoxy)-" "benzenebutanenitrile, g-(1-methylethoxy)-" "benzenebutanenitrile, .gamma.-(1-methylethoxy)-" );
standardThermochemistry
{
    dHf_298   -53020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=194290.0
}
