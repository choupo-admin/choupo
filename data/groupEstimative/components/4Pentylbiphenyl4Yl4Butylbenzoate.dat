/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-pentylbiphenyl-4-yl 4-butylbenzoate  (C28H32O2, CAS 59748-34-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pentylbiphenyl4Yl4Butylbenzoate;
formula     C28H32O2;
CAS         59748-34-4;
InChIKey    MYVSMQJGGRPENO-UHFFFAOYSA-N;
MW          400.562;      // g/mol [origin=calculated method=formula-sum]
Tc          1228.35;      // K   [origin=predictive method=joback]
Pc          11.468;      // bar [origin=predictive method=joback]
omega       0.9765;      // -   [origin=predictive method=lee-kesler]
Tb          993.44;      // K   [origin=predictive method=joback]
HvapTb      94143.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.973 2.19384 -0.00129728 2.667e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group ACH; count 12; } { group AC; count 4; } { group ACCH2; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(4-pentylphenyl)phenyl] 4-butylbenzoate" "benzoic acid, 4-butyl-, 4'-pentyl(1,1'-biphenyl)-4-yl ester" "benzoic acid, 4-butyl-, 4'-pentyl[1,1'-biphenyl]-4-yl ester" "4'-pentyl(1,1'-biphenyl)-4-yl 4-butylbenzoate" "4-(4-n-butylbenzoyloxy)-4'-n-pentylbiphenyl" "4-n-pentyl-4'-(4-n-butylbenzoyloxy)biphenyl" );
gibbsFormation
{
    dHf_298   -263350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     960.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=182850.0
    phase     gas;
}
