/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethyl-2-phenoxyacetamide  (C12H17NO2, CAS 3613-97-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethyl2Phenoxyacetamide;
formula     C12H17NO2;
CAS         3613-97-6;
InChIKey    CAKRCYBQYAFXDI-UHFFFAOYSA-N;
MW          207.273;      // g/mol [origin=calculated method=formula-sum]
Tc          792.88;      // K   [origin=predictive method=joback]
Pc          25.125;      // bar [origin=predictive method=joback]
omega       0.7580;      // -   [origin=predictive method=lee-kesler]
Tb          589.57;      // K   [origin=predictive method=joback]
HvapTb      55781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.757 1.09764 -0.0006431 1.3066e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-2-phenoxy-ethanamide" "beta-repellin" "phenoxyacetic n,n-diethylamide" "phenoxyacetic acid diethylamide" "n,n-diethylamide of phenoxyacetic acid" "acetamide,n,n-diethyl-2-phenoxy-" "n,n-diethyl-2-phenoxyacetamide;n,n-diethylphenoxyacetamide; phenoxyacetic acid diethylamide; r 203; r 203(insect repellent); b-repellin" );
standardThermochemistry
{
    dHf_298   -231750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39430.0
}
