/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-triacetylbenzene  (C12H12O3, CAS 779-90-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Triacetylbenzene;
formula     C12H12O3;
CAS         779-90-8;
InChIKey    HSOAIPRTHLEQFI-UHFFFAOYSA-N;
MW          204.225;      // g/mol [origin=calculated method=formula-sum]
Tc          896.69;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       0.8919;      // -   [origin=predictive method=lee-kesler]
Tb          672.41;      // K   [origin=predictive method=joback]
HvapTb      66144.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.75 0.86196 -0.00047002 8.018e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CH3CO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group CdO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3,5-diethanoylphenyl)ethanone" "benzene, 1,3,5-triacetyl-" "1-(3,5-diacetylphenyl)ethanone" "1,5-triacetylbenzene" "1,3,5,triacetylbenzene" "benzene,3,5-triacetyl-" "1-(3,5-diacetylphenyl)ethanon" "1,1',1''-benzene-1,3,5-triyltriethanone" "1,1',1''-(benzene-1,3,5-triyl)triethanone" "ethanone,1',1''-(1,3,5-benzenetriyl)tris-" "ethanone, 1,1',1''-(1,3,5-benzenetriyl)tris-" "1-(3,5-diacetylphenyl)ethanone;1,1',1''-(1,3,5-benzenetriyl)triethanone;1,1',1''-(benzene-1,3,5-triyl)trisethanone;1,3,5-triacetylbenzene,98%;" );
gibbsFormation
{
    dHf_298   -415160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-243450.0
    phase     gas;
}
