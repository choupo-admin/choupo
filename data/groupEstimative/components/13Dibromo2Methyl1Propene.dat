/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dibromo-2-methyl-1-propene  (C4H6Br2, CAS 35911-17-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dibromo2Methyl1Propene;
formula     C4H6Br2;
CAS         35911-17-2;
InChIKey    ZGUSGHWDLWVHBI-UHFFFAOYSA-N;
MW          213.9;      // g/mol [origin=calculated method=formula-sum]
Tc          649.50;      // K   [origin=predictive method=joback]
Pc          50.514;      // bar [origin=predictive method=joback]
omega       0.3866;      // -   [origin=predictive method=lee-kesler]
Tb          427.48;      // K   [origin=predictive method=joback]
HvapTb      37406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.761 0.48012 -0.0004227 1.538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(bromanyl)-2-methyl-prop-1-ene" "1-propene,1,3-dibromo-2-methyl-" "1,3-dibromo-2-methylpropene(e/z mixture)" "1-propene, 1,3-dibromo-2-methyl-, (z)-" );
standardThermochemistry
{
    dHf_298   34200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83110.0
}
