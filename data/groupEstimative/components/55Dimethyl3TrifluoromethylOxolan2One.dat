/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-3-(trifluoromethyl)oxolan-2-one  (C7H9F3O2, CAS 164929-15-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl3TrifluoromethylOxolan2One;
formula     C7H9F3O2;
CAS         164929-15-1;
InChIKey    NSQKIHBAKTVICL-UHFFFAOYSA-N;
MW          182.141;      // g/mol [origin=calculated method=formula-sum]
Tc          591.54;      // K   [origin=predictive method=joback]
Pc          28.936;      // bar [origin=predictive method=joback]
omega       0.4656;      // -   [origin=predictive method=lee-kesler]
Tb          414.87;      // K   [origin=predictive method=joback]
HvapTb      33289.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.56 1.19154 -0.0011808 4.728e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group F; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "a-methyl-" "a-(trifluoromethyl)-" "a-valerolactone" "gamma-methyl-a-(trifluoromethyl)-gamma-valerolactone" "5,5-dimethyl-3-(trifluoromethyl)dihydrofuran-2(3h)-one" "dihydro-5,5-dimethyl-3-(trifluoromethyl)-2(3h)-furanone" "gamma -methyl-alpha-(trifluoromethyl)- gamma-valerolactone" "5,5-dimethyl-3-(trifluoromethyl)-3,4,5-trihydrofuran-2-one" );
standardThermochemistry
{
    dHf_298   -1034470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-836350.0
}
