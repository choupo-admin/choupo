/*--------------------------------*- Choupo -*-----------------------*\
  Component: inverts of 2,4-d and 2,4-dp  (C34H26Cl10O12, CAS 8053-21-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        invertsOf24DAnd24Dp;
formula     C34H26Cl10O12;
CAS         8053-21-2;
InChIKey    VNJMGALGBJNMRK-UHFFFAOYSA-N;
MW          981.07;      // g/mol [origin=calculated method=formula-sum]
Tc          3273.63;      // K   [origin=predictive method=joback]
Pc          7.556;      // bar [origin=predictive method=joback]
omega       -0.2406;      // -   [origin=predictive method=lee-kesler]
Tb          2183.38;      // K   [origin=predictive method=joback]
HvapTb      229254.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (347.752 1.73484 -9.26e-05 -4.234e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 10; } { group AC; count 4; } { group CH2O; count 2; } { group CH-O; count 2; } { group COOH; count 4; } { group ACCl; count 10; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 14; } { group Cl; count 10; } { group O; count 4; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4-bis(chloranyl)phenoxy]ethanoic acid;2-[2,4-bis(chloranyl)phenoxy]propanoic acid;2-[2,4,5-tris(chloranyl)phenoxy]ethanoic acid;2-[2,4,5-tris(chloranyl)phenoxy]propanoic acid" "2-(2,4-dichlorophenoxy)acetic acid; 2-(2,4-dichlorophenoxy)propanoic acid; 2-(2,4,5-trichlorophenoxy)acetic acid; 2-(2,4,5-trichlorophenoxy)propanoic acid" "propanoic acid, 2-(2,4-dichlorophenoxy)-, mixt. with (2,4-dichlorophenoxy)acetic acid, (2,4,5-trichlorophenoxy)acetic acid and 2-(2,4,5-trichlorophenoxy)propanoic acid" );
standardThermochemistry
{
    dHf_298   -2346450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1888.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1645360.0
}
