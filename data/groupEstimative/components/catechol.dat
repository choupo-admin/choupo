/*--------------------------------*- Choupo -*-----------------------*\
  Component: catechol  (C6H6O2, CAS 120-80-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        catechol;
formula     C6H6O2;
CAS         120-80-9;
InChIKey    YCIMNLLNPGFGHC-UHFFFAOYSA-N;
MW          110.112;      // g/mol [origin=calculated method=formula-sum]
Tc          767.15;      // K   [origin=predictive method=joback]
Pc          75.614;      // bar [origin=predictive method=joback]
omega       0.6734;      // -   [origin=predictive method=lee-kesler]
Tb          519.82;      // K   [origin=predictive method=joback]
HvapTb      56592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.61 0.8636 -0.00091356 3.768e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,2-diol" "pyrocatechol" "1,2-benzenediol" "1,2-dihydroxybenzene" "pyrocatechin" "2-hydroxyphenol" "o-benzenediol" "o-dihydroxybenzene" "pyrocatechine" "o-dioxybenzene" "o-hydroquinone" "o-hydroxyphenol" );
gibbsFormation
{
    dHf_298   -273790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-187560.0
    phase     gas;
}
