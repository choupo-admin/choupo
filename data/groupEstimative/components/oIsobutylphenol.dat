/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-isobutylphenol  (C10H14O, CAS 4167-75-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oIsobutylphenol;
formula     C10H14O;
CAS         4167-75-3;
InChIKey    NFIDBGJMFKNGGQ-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          758.68;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       0.5823;      // -   [origin=predictive method=lee-kesler]
Tb          535.26;      // K   [origin=predictive method=joback]
HvapTb      52756.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.709 1.03544 -0.00081096 2.659e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methylpropyl)phenol" "2-isobutylphenol" "phenol, 2-(2-methylpropyl)-" "phenol, o-isobutyl-" "phenol, (2-methylpropyl)-" "isobutylphenol" "2-isobutyl-phenol" "phenol,(2-methylpropyl)-" "phenol,isobutyl- (7ci); isobutylphenol" );
standardThermochemistry
{
    dHf_298   -195790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11330.0
}
