/*--------------------------------*- Choupo -*-----------------------*\
  Component: diallyldiphenylsilane  (C18H20Si, CAS 10519-88-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C18H20Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diallyldiphenylsilane;
formula     C18H20Si;
CAS         10519-88-7;
InChIKey    ZODWTWYKYYGSFS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          264.443;      // g/mol [origin=calculated method=formula-sum]
Tc          897.14;      // K   [origin=predictive method=joback]
Pc          18.579;      // bar [origin=predictive method=joback]
omega       0.5161;      // -   [origin=predictive method=lee-kesler]
Tb          659.56;      // K   [origin=predictive method=joback]
HvapTb      59168.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.448 1.3098 -0.0006488 7.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 2; } { group ACH; count 10; } { group AC; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diphenyl-bis(prop-2-enyl)silane" "diphenyldiallylsilane" "silane, diphenyldi-2-propenyl-" "silane, diallyldiphenyl-" "benzene, 1,1'-(di-2-propen-1-ylsilylene)bis-" "benzene,1,1'-(di-2-propen-1-ylsilylene)bis-" );
standardThermochemistry
{
    dHf_298   197450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     761.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=396420.0
}
