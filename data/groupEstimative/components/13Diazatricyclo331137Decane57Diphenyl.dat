/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diazatricyclo(3.3.1.13,7)decane, 5,7-diphenyl-  (C20H22N2, CAS 38705-08-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diazatricyclo331137Decane57Diphenyl;
formula     C20H22N2;
CAS         38705-08-7;
InChIKey    LPJAFIHSDNKPEA-UHFFFAOYSA-N;
MW          290.41;      // g/mol [origin=calculated method=formula-sum]
Tc          1016.76;      // K   [origin=predictive method=joback]
Pc          25.201;      // bar [origin=predictive method=joback]
omega       0.7646;      // -   [origin=predictive method=lee-kesler]
Tb          756.54;      // K   [origin=predictive method=joback]
HvapTb      66326.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-356.01 3.0664 -0.0031794 1.3046e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 2; } { group ACH; count 10; } { group AC; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group C_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diazatricyclo[3.3.1.13,7]decane,5,7-diphenyl-" );
gibbsFormation
{
    dHf_298   427370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     645.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=754980.0
    phase     gas;
}
