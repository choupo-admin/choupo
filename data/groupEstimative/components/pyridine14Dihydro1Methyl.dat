/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyridine, 1,4-dihydro-1-methyl-  (C6H9N, CAS 33666-44-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyridine14Dihydro1Methyl;
formula     C6H9N;
CAS         33666-44-3;
InChIKey    ZKIJTTNWOULCBY-UHFFFAOYSA-N;
MW          95.145;      // g/mol [origin=calculated method=formula-sum]
Tc          565.72;      // K   [origin=predictive method=joback]
Pc          43.800;      // bar [origin=predictive method=joback]
omega       0.2883;      // -   [origin=predictive method=lee-kesler]
Tb          367.59;      // K   [origin=predictive method=joback]
HvapTb      32143.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.12 0.74392 -0.00057256 1.737e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4h-pyridine" "pyridine,1,4-dihydro-1-methyl-" );
standardThermochemistry
{
    dHf_298   96740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=214600.0
}
