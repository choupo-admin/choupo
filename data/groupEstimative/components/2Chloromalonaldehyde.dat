/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloromalonaldehyde  (C3H3ClO2, CAS 36437-19-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloromalonaldehyde;
formula     C3H3ClO2;
CAS         36437-19-1;
InChIKey    KTRZQCIGJUWSGE-UHFFFAOYSA-N;
MW          106.505;      // g/mol [origin=calculated method=formula-sum]
Tc          598.54;      // K   [origin=predictive method=joback]
Pc          51.981;      // bar [origin=predictive method=joback]
omega       0.4935;      // -   [origin=predictive method=lee-kesler]
Tb          402.55;      // K   [origin=predictive method=joback]
HvapTb      39709.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.17 0.2505 -0.000149 2.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHO; count 2; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group Cl; count 1; } { group OdCH_al; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylpropanedial" "chloromalonaldehyde" "2-chloropropanedial" "propanedial, chloro-" "propanedial, 2-chloro-" "chloromalonaldehyde; chloromalondialdehyde; chloromalonic dialdehyde;2-chloromalonaldehyde" "malonaldehyde,chloro- (6ci);propanedial, chloro- (9ci);2-chloro-1,3-propanedial;chloromalonaldehyde;chloromalonic dialdehyde;" );
standardThermochemistry
{
    dHf_298   -297430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-239030.0
}
