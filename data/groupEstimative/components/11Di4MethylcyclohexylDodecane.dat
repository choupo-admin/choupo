/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-di(4-methylcyclohexyl)dodecane  (C26H50, CAS 55334-09-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Di4MethylcyclohexylDodecane;
formula     C26H50;
CAS         55334-09-3;
InChIKey    ARDIJKGJYOGVEO-UHFFFAOYSA-N;
MW          362.686;      // g/mol [origin=calculated method=formula-sum]
Tc          1022.63;      // K   [origin=predictive method=joback]
Pc          8.847;      // bar [origin=predictive method=joback]
omega       0.7151;      // -   [origin=predictive method=lee-kesler]
Tb          823.80;      // K   [origin=predictive method=joback]
HvapTb      73322.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.76 2.67096 -0.001445 2.605e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 18; } { group CH; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-[1-(4-methylcyclohexyl)dodecyl]cyclohexane" "cyclohexane, 1,1'-dodecylidenebis[4-methyl-" "cyclohexane,1'-dodecylidenebis[4-methyl-" );
gibbsFormation
{
    dHf_298   -517290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1013.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=199080.0
    phase     gas;
}
