/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tert-butyl-1-cyclohexene  (C10H18, CAS 3419-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButyl1Cyclohexene;
formula     C10H18;
CAS         3419-66-7;
InChIKey    GQBKAYONUCKYKT-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          667.78;      // K   [origin=predictive method=joback]
Pc          27.701;      // bar [origin=predictive method=joback]
omega       0.2988;      // -   [origin=predictive method=lee-kesler]
Tb          453.53;      // K   [origin=predictive method=joback]
HvapTb      38250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.14 1.11276 -0.00074864 1.968e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butylcyclohexene" "cyclohexene, 1-(1,1-dimethylethyl)-" "1-tert-butyl-cyclohexene" "cyclohexene, (1,1-dimethylethyl)-" );
standardThermochemistry
{
    dHf_298   -137510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=88650.0
}
