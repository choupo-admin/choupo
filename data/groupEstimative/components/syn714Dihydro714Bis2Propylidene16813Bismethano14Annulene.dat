/*--------------------------------*- Choupo -*-----------------------*\
  Component: syn-7,14-dihydro-7,14-bis(2-propylidene)-1,6:8,13-bismethano(14)annulene  (C22H24, CAS 109216-47-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        syn714Dihydro714Bis2Propylidene16813Bismethano14Annulene;
formula     C22H24;
CAS         109216-47-9;
InChIKey    SDQUZEYARJZOCM-UHFFFAOYSA-N;
MW          288.434;      // g/mol [origin=calculated method=formula-sum]
Tc          1041.52;      // K   [origin=predictive method=joback]
Pc          16.769;      // bar [origin=predictive method=joback]
omega       0.7161;      // -   [origin=predictive method=lee-kesler]
Tb          795.00;      // K   [origin=predictive method=joback]
HvapTb      72570.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.81 1.82968 -0.00127212 3.548e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH=CH; count 2; } { group CH=C; count 4; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "anti-7,14-dihydro-7,14-bis(2-propylidene)-1,6:8,13-bismethano(14)annulene" "anti-7,14-dihydro-7,14-bis(2-propylidene)-1,6:8,13-bismethano[14]annulene" "syn-7,14-dihydro-7,14-bis(2-propylidene)-1,6:8,13-bismethano[14]annulene" );
gibbsFormation
{
    dHf_298   172170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     695.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=470100.0
    phase     gas;
}
