/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-norbornanol, 3-(benzylmethylaminomethyl)-  (C16H23NO, CAS 74111-27-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Norbornanol3Benzylmethylaminomethyl;
formula     C16H23NO;
CAS         74111-27-6;
InChIKey    PHMYEAYOKNYDGR-UHFFFAOYSA-N;
MW          245.366;      // g/mol [origin=calculated method=formula-sum]
Tc          910.68;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       1.0349;      // -   [origin=predictive method=lee-kesler]
Tb          705.39;      // K   [origin=predictive method=joback]
HvapTb      71588.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.688 1.84202 -0.001304 3.642e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 4; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[methyl-(phenylmethyl)amino]methyl]bicyclo[2.2.1]heptan-3-ol" "2-norbornanol, 3-[(benzylmethylamino)methyl]-" "3-(n-benzyl-n-methylaminomethyl)-2-norbornanol" "bicyclo(2.2.1)heptan-2-ol, 3-((methyl(phenylmethyl)amino)methyl)-" "bicyclo[2.2.1]heptan-2-ol, 3-[[methyl(phenylmethyl)amino]methyl]-" "2-[[benzyl(methyl)amino]methyl]bicyclo[2.2.1]heptan-3-ol" "3-{[benzyl(methyl)amino]methyl}bicyclo[2.2.1]heptan-2-ol" "bicyclo(2.2.1)heptan-2-ol, 3-((methyl(phenylmethyl)amino)methyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   -122980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=264190.0
}
