/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1784443  (C7H10Cl2O4, CAS 10140-75-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1784443;
formula     C7H10Cl2O4;
CAS         10140-75-7;
InChIKey    MYDZFJITMAYGKQ-UHFFFAOYSA-N;
MW          229.053;      // g/mol [origin=calculated method=formula-sum]
Tc          748.18;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.7098;      // -   [origin=predictive method=lee-kesler]
Tb          550.18;      // K   [origin=predictive method=joback]
HvapTb      53984.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.761 0.58464 -0.000215 -2.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH3COO; count 2; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group Cl; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[1-acetyloxy-2,3-bis(chloranyl)propyl] ethanoate" "1,1-propanediol, 2,3-dichloro-, diacetate" "(1-acetyloxy-2,3-dichloropropyl) acetate" );
standardThermochemistry
{
    dHf_298   -864410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-641420.0
}
