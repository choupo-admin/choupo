/*--------------------------------*- Choupo -*-----------------------*\
  Component: neopentylidenecyclohexane  (C11H20, CAS 39546-80-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        neopentylidenecyclohexane;
formula     C11H20;
CAS         39546-80-0;
InChIKey    MHNGPSUOLFWERG-UHFFFAOYSA-N;
MW          152.281;      // g/mol [origin=calculated method=formula-sum]
Tc          694.22;      // K   [origin=predictive method=joback]
Pc          25.303;      // bar [origin=predictive method=joback]
omega       0.3297;      // -   [origin=predictive method=lee-kesler]
Tb          478.91;      // K   [origin=predictive method=joback]
HvapTb      40309.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.03 1.24576 -0.0008513 2.303e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpropylidenecyclohexane" "(2,2-dimethylpropylidene)cyclohexane" "cyclohexane,(2,2-dimethylpropylidene)-" "(2,2-dimethylpropylidene)cyclohexane;neo-pentylidenecyclopentane" );
standardThermochemistry
{
    dHf_298   -128430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122200.0
}
