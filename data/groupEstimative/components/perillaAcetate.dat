/*--------------------------------*- Choupo -*-----------------------*\
  Component: perilla acetate  (C12H18O2, CAS 15111-96-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        perillaAcetate;
formula     C12H18O2;
CAS         15111-96-3;
InChIKey    WTXBCFKGCNWPLS-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          760.10;      // K   [origin=predictive method=joback]
Pc          22.849;      // bar [origin=predictive method=joback]
omega       0.5560;      // -   [origin=predictive method=lee-kesler]
Tb          552.63;      // K   [origin=predictive method=joback]
HvapTb      50506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.819 1.07554 -0.00056084 8.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-prop-1-en-2-ylcyclohexen-1-yl)methyl ethanoate" "perillyl acetate" "1-cyclohexene-1-methanol, 4-(1-methylethenyl)-, acetate" "dihydrocuminyl acetate" "menthadien-7-carbinyl acetate" "1,8-p-menthadien-7-yl acetate" "p-mentha-1,8-dien-7-yl acetate" "p-mentha-1,8-dien-7-ol, acetate" "4-isopropenyl-1-cyclohexene carbinyl acetate" "(4-isopropenyl-1-cyclohexen-1-yl)methyl acetate" "4-(1-methylvinyl)cyclohex-1-ene-1-methyl acetate" "4-(1-methylethenyl)-1-cyclohexene-1-methyl acetate" );
standardThermochemistry
{
    dHf_298   -392020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-136140.0
}
