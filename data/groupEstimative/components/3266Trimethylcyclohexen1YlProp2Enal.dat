/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2,6,6-trimethylcyclohexen-1-yl)prop-2-enal  (C12H18O, CAS 4951-40-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3266Trimethylcyclohexen1YlProp2Enal;
formula     C12H18O;
CAS         4951-40-0;
InChIKey    FLOPAOUVAMIAJN-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          773.79;      // K   [origin=predictive method=joback]
Pc          25.303;      // bar [origin=predictive method=joback]
omega       0.5355;      // -   [origin=predictive method=lee-kesler]
Tb          555.89;      // K   [origin=predictive method=joback]
HvapTb      49878.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.02 1.37736 -0.0011726 4.389e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group CHO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2,6,6-trimethyl-1-cyclohexen-1-yl)acrylaldehyde" "2-propenal,3-(2,6,6-trimethyl-1-cyclohexen-1-yl)-" "2-propenal, 3-(2,6,6-trimethyl-1-cyclohexen-1-yl)-, (e)-" "1-cyclohexene-1-acrolein,2,6,6-trimethyl- (7ci,8ci); 3-(2,6,6-trimethyl-1-cyclohexen-1-yl)propenal" );
gibbsFormation
{
    dHf_298   -154970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60520.0
    phase     gas;
}
