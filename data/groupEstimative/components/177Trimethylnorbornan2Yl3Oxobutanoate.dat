/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,7,7-trimethylnorbornan-2-yl) 3-oxobutanoate  (C14H22O3, CAS 54717-80-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        177Trimethylnorbornan2Yl3Oxobutanoate;
formula     C14H22O3;
CAS         54717-80-5;
InChIKey    RGHAHCRVPZUAPH-UHFFFAOYSA-N;
MW          238.327;      // g/mol [origin=calculated method=formula-sum]
Tc          854.43;      // K   [origin=predictive method=joback]
Pc          20.946;      // bar [origin=predictive method=joback]
omega       0.7184;      // -   [origin=predictive method=lee-kesler]
Tb          640.90;      // K   [origin=predictive method=joback]
HvapTb      57989.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-170.779 2.07408 -0.0019729 7.9756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 2; } { group CH3CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 2; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4,7,7-trimethyl-3-bicyclo[2.2.1]heptanyl) 3-oxidanylidenebutanoate" "butanoic acid, 3-oxo-, (1r,2r,4r)-1,7,7-trimethylbicyclo(2.2.1)hept-2-yl ester, rel-" "butanoic acid, 3-oxo-, (1r,2r,4r)-1,7,7-trimethylbicyclo[2.2.1]hept-2-yl ester, rel-" "agn-pc-00n8n5" "1,7,7-trimethylbicyclo[2.2.1]hept-2-yl 3-oxobutanoate" "(4,7,7-trimethyl-3-bicyclo[2.2.1]heptanyl) 3-oxobutanoate" "[(1s,3r,4s)-4,7,7-trimethyl-3-bicyclo[2.2.1]heptanyl] 3-oxobutanoate" );
gibbsFormation
{
    dHf_298   -632910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     673.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-289290.0
    phase     gas;
}
