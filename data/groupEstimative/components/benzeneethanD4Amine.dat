/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzeneethan-d4-amine  (C8H7D4N, CAS 876-20-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H7D4N (delta D+4H-4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzeneethanD4Amine;
formula     C8H7D4N;
CAS         876-20-0;
InChIKey    BHHGXPLMPWCGHP-KXGHAPEVSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          125.207;      // g/mol [origin=calculated method=formula-sum]
Tc          704.97;      // K   [origin=predictive method=joback]
Pc          39.160;      // bar [origin=predictive method=joback]
omega       0.4626;      // -   [origin=predictive method=lee-kesler]
Tb          481.85;      // K   [origin=predictive method=joback]
HvapTb      46319.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.798 0.7468 -0.000486 1.205e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetradeuterio-2-phenyl-ethanamine" "2-phenyl(2h4)ethanamine" "phenethyl-1,1,2,2-d4-amine" "1,1,2,2-tetradeuterio-2-phenylethanamine" );
gibbsFormation
{
    dHf_298   61870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195340.0
    phase     gas;
}
