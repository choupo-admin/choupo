/*--------------------------------*- Choupo -*-----------------------*\
  Component: mirex  (C10Cl12, CAS 2385-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mirex;
formula     C10Cl12;
CAS         2385-85-5;
InChIKey    GVYLCNUFSHDAAW-UHFFFAOYSA-N;
MW          545.51;      // g/mol [origin=calculated method=formula-sum]
Tc          1210.43;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.6208;      // -   [origin=predictive method=lee-kesler]
Tb          868.96;      // K   [origin=predictive method=joback]
HvapTb      76124.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-547.33 4.6244 -0.007147 3.7008e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:8
    joback ( { group C_ring; count 10; } { group Cl; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dechlorane" "perchloropentacyclodecane" "paramex" "perchlorodihomocubane" "bichlorendo" "dodecaclor" "ferriamicide" "perchlordecone" "mirex solution" "dodecachloropentacyclodecane" "fire ant bait" "hrs l276" );
gibbsFormation
{
    dHf_298   6890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     879.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160960.0
    phase     gas;
}
