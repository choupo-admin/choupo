/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane, 1,4-dimethylene-  (C8H12, CAS 4982-20-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexane14Dimethylene;
formula     C8H12;
CAS         4982-20-1;
InChIKey    JPBHXVRMWGWSMX-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          610.50;      // K   [origin=predictive method=joback]
Pc          34.199;      // bar [origin=predictive method=joback]
omega       0.2843;      // -   [origin=predictive method=lee-kesler]
Tb          405.18;      // K   [origin=predictive method=joback]
HvapTb      34458.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.35 0.6774 -0.000363 6.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group CH2_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethylidenecyclohexane" "cyclohexane, 1,4-bis(methylene)-" "1,4-dimethylene cyclohexane" "1,4-dimethyl ene cyclohexane" );
gibbsFormation
{
    dHf_298   34690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=154800.0
    phase     gas;
}
