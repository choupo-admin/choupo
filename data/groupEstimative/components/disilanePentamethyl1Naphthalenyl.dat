/*--------------------------------*- Choupo -*-----------------------*\
  Component: disilane, pentamethyl-1-naphthalenyl-  (C15H22Si2, CAS 38446-40-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H22Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        disilanePentamethyl1Naphthalenyl;
formula     C15H22Si2;
CAS         38446-40-1;
InChIKey    HOCAJYZQOFSYAZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          258.511;      // g/mol [origin=calculated method=formula-sum]
Tc          828.51;      // K   [origin=predictive method=joback]
Pc          18.310;      // bar [origin=predictive method=joback]
omega       0.3882;      // -   [origin=predictive method=lee-kesler]
Tb          596.24;      // K   [origin=predictive method=joback]
HvapTb      54150.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.84 0.8744 -6.348e-05 -1.854e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group ACH; count 7; } { group AC; count 3; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl-naphthalen-1-yl-trimethylsilyl-silane" "disilane,pentamethyl-1-naphthalenyl-" "dimethyl-naphthalen-1-yl-trimethylsilylsilane" );
gibbsFormation
{
    dHf_298   -160040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     771.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75330.0
    phase     gas;
}
