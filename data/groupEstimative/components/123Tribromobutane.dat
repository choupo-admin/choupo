/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-tribromobutane  (C4H7Br3, CAS 632-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Tribromobutane;
formula     C4H7Br3;
CAS         632-05-3;
InChIKey    HKTNRDJXZCCMGH-UHFFFAOYSA-N;
MW          294.812;      // g/mol [origin=calculated method=formula-sum]
Tc          724.21;      // K   [origin=predictive method=joback]
Pc          52.586;      // bar [origin=predictive method=joback]
omega       0.5141;      // -   [origin=predictive method=lee-kesler]
Tb          488.72;      // K   [origin=predictive method=joback]
HvapTb      43027.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.461 0.51022 -0.0004144 1.377e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-tris(bromanyl)butane" "butane, 1,2,3-tribromo-" "1,2,3-tribromobutane;1,2,3-tribromo-butan;butane,1,2,3-tribromo-" );
gibbsFormation
{
    dHf_298   -57460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20880.0
    phase     gas;
}
