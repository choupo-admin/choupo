/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid;n1,n1,n4,n4-tetramethylbenzene-1,4-diamine;(2,2,4-trimethyl-3-oxidanyl-pentyl) 2-methylpropanoate  (C28H50N2O7, CAS 68922-29-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcidN1N1N4N4Tetramethylbenzene14Diamine224Trimeth;
formula     C28H50N2O7;
CAS         68922-29-2;
InChIKey    NLDSGUWLBQVPHQ-UHFFFAOYSA-N;
MW          526.715;      // g/mol [origin=calculated method=formula-sum]
Tc          1707.34;      // K   [origin=predictive method=joback]
Pc          8.392;      // bar [origin=predictive method=joback]
omega       0.4372;      // -   [origin=predictive method=lee-kesler]
Tb          1336.45;      // K   [origin=predictive method=joback]
HvapTb      141488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.465 2.5853 -0.00112156 4.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 1; } { group CH3N; count 2; } { group COOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group COOH; count 2; } { group COO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanedioic acid, polymer with n,n,n',n'-tetramethyl-1,4-benzenediamine and 2,2,4-trimethyl-1,3-pentanediol mono(2-methylpropanoate)" "hexanedioic acid, polymer with n1,n1,n4,n4-tetramethyl-1,4-benzenediamine and 2,2,4-trimethyl-1,3-pentanediol mono(2-methylpropanoate)" "2-methylpropanoic acid, 2,2,4-trimethyl-1,3-pentanediol monoester, 1,4-bis(dimethylamino)benzene, adipic acid polymer" );
gibbsFormation
{
    dHf_298   -1679010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1522.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-839790.0
    phase     gas;
}
