/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dimorpholinoethane  (C10H20N2O2, CAS 1723-94-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dimorpholinoethane;
formula     C10H20N2O2;
CAS         1723-94-0;
InChIKey    QRQKCMFVJWNKQI-UHFFFAOYSA-N;
MW          200.282;      // g/mol [origin=calculated method=formula-sum]
Tc          759.94;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.6587;      // -   [origin=predictive method=lee-kesler]
Tb          547.08;      // K   [origin=predictive method=joback]
HvapTb      52092.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-125.788 1.512 -0.0010832 3.006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group FCH2O; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 8; } { group O_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-morpholin-4-ylethyl)morpholine" "4,4'-ethylenedimorpholine" "1,2-di-n-morpholinylethane" "4-[2-(4-morpholinyl)ethyl]morpholine" "morpholine, 4,4'-(1,2-ethanediyl)bis-" "morpholine,4'-ethylenedi-" "morpholine, 4,4'-ethylenedi-" "morpholine,4'-(1,2-ethanediyl)bis-" "4,4'-(ethane-1,2-diyl)bismorpholine" "4-[2-(morpholin-4-yl)ethyl]morpholine" "morpholine,4,4'-(1,2-ethanediyl)bis-" "4,4'-(1,2-ethanediyl)bis-morpholine" );
gibbsFormation
{
    dHf_298   -217030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=171160.0
    phase     gas;
}
