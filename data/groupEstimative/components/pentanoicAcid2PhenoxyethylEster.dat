/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentanoic acid, 2-phenoxyethyl ester  (C13H18O3, CAS 23495-13-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentanoicAcid2PhenoxyethylEster;
formula     C13H18O3;
CAS         23495-13-8;
InChIKey    VTDVFBXXQCGSIB-UHFFFAOYSA-N;
MW          222.284;      // g/mol [origin=calculated method=formula-sum]
Tc          803.20;      // K   [origin=predictive method=joback]
Pc          21.694;      // bar [origin=predictive method=joback]
omega       0.7628;      // -   [origin=predictive method=lee-kesler]
Tb          604.36;      // K   [origin=predictive method=joback]
HvapTb      56625.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.075 1.04192 -0.000509 5.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenoxyethyl pentanoate" "2-phenoxyethyl valerate" "pentanoic acid,2-phenoxyethyl ester" "pentanoic acid 2-phenoxyethyl ester" );
standardThermochemistry
{
    dHf_298   -524620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     618.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-244380.0
}
