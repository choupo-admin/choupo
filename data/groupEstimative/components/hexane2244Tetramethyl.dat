/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexane, 2,2,4,4-tetramethyl-  (C10H22, CAS 51750-65-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexane2244Tetramethyl;
formula     C10H22;
CAS         51750-65-3;
InChIKey    PXHNHTBJHHSVPT-UHFFFAOYSA-N;
MW          142.286;      // g/mol [origin=calculated method=formula-sum]
Tc          605.71;      // K   [origin=predictive method=joback]
Pc          21.836;      // bar [origin=predictive method=joback]
omega       0.3114;      // -   [origin=predictive method=lee-kesler]
Tb          421.94;      // K   [origin=predictive method=joback]
HvapTb      35262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.148 1.20552 -0.0008638 2.516e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4-tetramethylhexane" );
gibbsFormation
{
    dHf_298   -267230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39000.0
    phase     gas;
}
