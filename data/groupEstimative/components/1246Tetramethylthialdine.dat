/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,4,6-tetramethylthialdine  (C7H15NS2, CAS 37434-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1246Tetramethylthialdine;
formula     C7H15NS2;
CAS         37434-57-4;
InChIKey    AZHPCHPZVNDJKI-WDSKDSINSA-N;
MW          177.324;      // g/mol [origin=calculated method=formula-sum]
Tc          695.95;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.3552;      // -   [origin=predictive method=lee-kesler]
Tb          473.80;      // K   [origin=predictive method=joback]
HvapTb      44482.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.13 0.9003 -0.0005236 1.102e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH3N; count 1; } { group CHS; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH_ring; count 3; } { group N; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4s,6s)-2,4,5,6-tetramethyl-1,3,5-dithiazinane" );
gibbsFormation
{
    dHf_298   -9960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=219690.0
    phase     gas;
}
