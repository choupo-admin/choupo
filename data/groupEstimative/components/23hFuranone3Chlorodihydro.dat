/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2(3h)-furanone, 3-chlorodihydro-  (C4H5ClO2, CAS 31167-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23hFuranone3Chlorodihydro;
formula     C4H5ClO2;
CAS         31167-90-5;
InChIKey    OARNHESMASZJCO-UHFFFAOYSA-N;
MW          120.532;      // g/mol [origin=calculated method=formula-sum]
Tc          593.19;      // K   [origin=predictive method=joback]
Pc          44.208;      // bar [origin=predictive method=joback]
omega       0.3732;      // -   [origin=predictive method=lee-kesler]
Tb          393.51;      // K   [origin=predictive method=joback]
HvapTb      36203.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.69 0.4867 -0.0003398 8.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CHCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyloxolan-2-one" "3-chlorodihydrofuran-2(3h)-one" "3-chlorooxolan-2-one" "alpha-chloro-gamma-butyrolactone" "2(3h)-furanone,3-chlorodihydro-" ".alpha.-chloro-.gamma.-butyrolactone" );
standardThermochemistry
{
    dHf_298   -386110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     306.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-278750.0
}
