name        secrovin;
formula     C43H56O4;
CAS         8015-19-8;
InChIKey    KKVNENSFUWDQCF-BWHNGHDOSA-N;
MW          636.917;      // g/mol [origin=calculated method=formula-sum]
Tc          2005.58;      // K   [origin=predictive method=joback]
Pc          9.318;      // bar [origin=predictive method=joback]
omega       0.7103;      // -   [origin=predictive method=lee-kesler]
Tb          1607.48;      // K   [origin=predictive method=joback]
HvapTb      161422.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
