/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-butylphenol  (C10H14O, CAS 1638-22-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Butylphenol;
formula     C10H14O;
CAS         1638-22-8;
InChIKey    CYYZDBDROVLTJU-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          754.15;      // K   [origin=predictive method=joback]
Pc          34.684;      // bar [origin=predictive method=joback]
omega       0.6178;      // -   [origin=predictive method=lee-kesler]
Tb          535.70;      // K   [origin=predictive method=joback]
HvapTb      53144.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.027 1.02952 -0.00080776 2.664e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-n-butylphenol" "phenol, 4-butyl-" "p-butylphenol" "p-hydroxybutylbenzene" "phenol, p-butyl-" "phenol, p-butyl" "1-hydroxy-4-n-butylbenzene" "4-butyl-phenol" "4-n-ethylphenol" "4-butylcyclohexanol;" "1-(4-hydroxyphenyl)butane" );
standardThermochemistry
{
    dHf_298   -190510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-8890.0
}
