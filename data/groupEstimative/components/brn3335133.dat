/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3335133  (C20H16O, CAS 63020-45-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3335133;
formula     C20H16O;
CAS         63020-45-1;
InChIKey    NKALMYNXJQQHFR-UHFFFAOYSA-N;
MW          272.347;      // g/mol [origin=calculated method=formula-sum]
Tc          1081.14;      // K   [origin=predictive method=joback]
Pc          24.387;      // bar [origin=predictive method=joback]
omega       1.2267;      // -   [origin=predictive method=lee-kesler]
Tb          847.94;      // K   [origin=predictive method=joback]
HvapTb      85975.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.338 1.6693 -0.00133484 4.307e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 11; } { group AC; count 6; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-benzo[a]anthracen-7-ylethanol" "10-beta-hydroxyethyl-1:2-benzanthracene" );
standardThermochemistry
{
    dHf_298   166970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=384170.0
}
