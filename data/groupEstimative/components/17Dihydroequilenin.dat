/*--------------------------------*- Choupo -*-----------------------*\
  Component: 17-dihydroequilenin  (C18H20O2, CAS 1423-97-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17Dihydroequilenin;
formula     C18H20O2;
CAS         1423-97-8;
InChIKey    RYWZPRVUQHMJFF-BZSNNMDCSA-N;
MW          268.356;      // g/mol [origin=calculated method=formula-sum]
Tc          1092.41;      // K   [origin=predictive method=joback]
Pc          28.843;      // bar [origin=predictive method=joback]
omega       1.2997;      // -   [origin=predictive method=lee-kesler]
Tb          853.18;      // K   [origin=predictive method=joback]
HvapTb      89133.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-203.51 2.25842 -0.0021472 8.412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(13s,14s,17s)-13-methyl-11,12,14,15,16,17-hexahydrocyclopenta[a]phenanthrene-3,17-diol" "beta-dihydroequilenin" "estra-1,3,5,7,9-pentaene-3,17beta-diol" "beta-estra-1,3,5,7,9-pentaen-3,17-diol" "a-dihydroequilenin" "17" "a-dihydro equilenin" "17" "a-equilenol" "beta-dihydroequilenina" "estra-1,3,5,7,9-pentaene-3,17" "a-diol" "(17" "a)-estra-1,3,5,7,9-pentaene-3,17-diol" );
gibbsFormation
{
    dHf_298   -205390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105240.0
    phase     gas;
}
