/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-azabicyclo(2.2.1)hept-5-ene, 2-hydroxy-  (C6H8NO, CAS 81640-22-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        2Azabicyclo221Hept5Ene2Hydroxy;
formula     C6H8NO;
CAS         81640-22-4;
InChIKey    OVVGSNNNCRJRDE-UHFFFAOYSA-N;
role        radical;
MW          110.136;      // g/mol [origin=calculated method=formula-sum]
Tc          528.00;      // K   [origin=predictive method=joback]
Pc          51.981;      // bar [origin=predictive method=joback]
omega       0.4367;      // -   [origin=predictive method=lee-kesler]
Tb          350.76;      // K   [origin=predictive method=joback]
HvapTb      36873.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.55 1.0662 -0.00103758 3.912e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dO_oth; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-$l^{1}-oxidanyl-5-azabicyclo[2.2.1]hept-2-ene" "2-azabicyclo[2.2.1]hept-5-ene, 2-hydroxy-" "azabicyclo[2.2.1]hept-5-ene, 2-hydroxy-" );
standardThermochemistry
{
    dHf_298   -88060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     247.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63430.0
}
