/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-difluorobenzotrifluoride  (C7H3F5, CAS 32137-19-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Difluorobenzotrifluoride;
formula     C7H3F5;
CAS         32137-19-2;
InChIKey    MVCGQTYWLZSKSB-UHFFFAOYSA-N;
MW          182.091;      // g/mol [origin=calculated method=formula-sum]
Tc          562.62;      // K   [origin=predictive method=joback]
Pc          31.036;      // bar [origin=predictive method=joback]
omega       0.4307;      // -   [origin=predictive method=lee-kesler]
Tb          389.52;      // K   [origin=predictive method=joback]
HvapTb      29395.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.8 0.6557 -0.00050792 1.477e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACF; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(fluoranyl)-4-(trifluoromethyl)benzene" "1,2-difluoro-4-(trifluoromethyl)benzene" "alpha,alpha,alpha,3,4-pentafluorotoluene" "benzene, 1,2-difluoro-4-(trifluoromethyl)-" "d165" "o932" );
standardThermochemistry
{
    dHf_298   -963520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-870000.0
}
