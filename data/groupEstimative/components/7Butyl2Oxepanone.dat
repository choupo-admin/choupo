/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-butyl-2-oxepanone  (C10H18O2, CAS 5579-78-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Butyl2Oxepanone;
formula     C10H18O2;
CAS         5579-78-2;
InChIKey    YKVIWISPFDZYOW-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          697.24;      // K   [origin=predictive method=joback]
Pc          25.176;      // bar [origin=predictive method=joback]
omega       0.5447;      // -   [origin=predictive method=lee-kesler]
Tb          501.90;      // K   [origin=predictive method=joback]
HvapTb      45518.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.277 1.03072 -0.000553 9.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-butyloxepan-2-one" "epsilon-decalactone" "6-butylhexanolide" "6-hydroxydecanoic acid epsilon-lactone" "a-decalactone" "decanoicacid, 6-hydroxy-, e-lactone (6ci,7ci);(?a'a a'a currency)-e-decalactone;e-decalactone;" );
gibbsFormation
{
    dHf_298   -506530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-240500.0
    phase     gas;
}
