/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dihydroxypropyl methacrylate  (C7H12O4, CAS 5919-74-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DihydroxypropylMethacrylate;
formula     C7H12O4;
CAS         5919-74-4;
InChIKey    QRIMLDXJAPZHJE-UHFFFAOYSA-N;
MW          160.169;      // g/mol [origin=calculated method=formula-sum]
Tc          768.42;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       1.4409;      // -   [origin=predictive method=lee-kesler]
Tb          598.46;      // K   [origin=predictive method=joback]
HvapTb      70963.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.152 0.66782 -0.0003516 5.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group OH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(oxidanyl)propyl 2-methylprop-2-enoate" "glyceryl methacrylate" "2-propenoic acid, 2-methyl-, 2,3-dihydroxypropyl ester" "polyglycerylmethacrylate" "2,4-dihydroxypropyl methacrylate" "2-propenoic acid, 2-methyl-, 2,3-dihydroxypropyl ester, homopolymer" "2,3-dihydroxypropyl 2-methylprop-2-enoate" "2-methyl-2-propenoic acid, 2,3-dihydroxypropyl ester" );
standardThermochemistry
{
    dHf_298   -699190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-499100.0
}
