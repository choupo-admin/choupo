/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2,5-endomethylenecyclohexylmethyl)amine  (C16H27N, CAS 10171-76-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis25EndomethylenecyclohexylmethylAmine;
formula     C16H27N;
CAS         10171-76-3;
InChIKey    CEKRYRXNZFBGPG-UHFFFAOYSA-N;
MW          233.399;      // g/mol [origin=calculated method=formula-sum]
Tc          858.12;      // K   [origin=predictive method=joback]
Pc          19.983;      // bar [origin=predictive method=joback]
omega       0.6723;      // -   [origin=predictive method=lee-kesler]
Tb          642.01;      // K   [origin=predictive method=joback]
HvapTb      57024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-212.198 2.1314 -0.0015724 4.707e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH; count 6; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 6; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-bicyclo[2.2.1]heptanyl)-n-(3-bicyclo[2.2.1]heptanylmethyl)methanamine" "dimethylamine, 1,1'-di-2-norbornyl-, endo,endo-" );
gibbsFormation
{
    dHf_298   -81900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=376610.0
    phase     gas;
}
