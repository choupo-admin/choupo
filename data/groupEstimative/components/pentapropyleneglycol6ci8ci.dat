/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentapropyleneglycol (6ci,8ci)  (C15H32O6, CAS 21482-12-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentapropyleneglycol6ci8ci;
formula     C15H32O6;
CAS         21482-12-2;
InChIKey    AQRQHYITOOVBTO-UHFFFAOYSA-N;
MW          308.415;      // g/mol [origin=calculated method=formula-sum]
Tc          997.84;      // K   [origin=predictive method=joback]
Pc          15.974;      // bar [origin=predictive method=joback]
omega       1.3878;      // -   [origin=predictive method=lee-kesler]
Tb          814.64;      // K   [origin=predictive method=joback]
HvapTb      90042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (93.425 1.2736 -0.000425 -3.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 3; } { group CH2O; count 2; } { group C2H4O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 5; } { group OH; count 2; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-(2-oxidanylpropoxy)propoxy]propoxy]propoxy]propan-1-ol" "3,6,9,12-tetraoxapentadecane-1,14-diol, 2,5,8,11-tetramethyl-" "3,6,9,12-tetraoxapentadecane-1,14-diol,2,5,8,11-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -1212670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     839.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-630420.0
}
