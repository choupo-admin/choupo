/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-heptadecyne  (C17H32, CAS 26186-00-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Heptadecyne;
formula     C17H32;
CAS         26186-00-5;
InChIKey    DQDNKQWGBZFFRA-UHFFFAOYSA-N;
MW          236.443;      // g/mol [origin=calculated method=formula-sum]
Tc          744.60;      // K   [origin=predictive method=joback]
Pc          13.697;      // bar [origin=predictive method=joback]
omega       0.7277;      // -   [origin=predictive method=lee-kesler]
Tb          578.68;      // K   [origin=predictive method=joback]
HvapTb      53294.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.214 1.52492 -0.00089693 2.0949e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptadec-1-yne" "pentadecylacetylene" );
gibbsFormation
{
    dHf_298   -102310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     787.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=315330.0
    phase     gas;
}
