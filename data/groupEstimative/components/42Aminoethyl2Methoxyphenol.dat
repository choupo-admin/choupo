/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2-aminoethyl)-2-methoxyphenol  (C9H13NO2, CAS 554-52-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        42Aminoethyl2Methoxyphenol;
formula     C9H13NO2;
CAS         554-52-9;
InChIKey    DIVQKHQLANKJQO-UHFFFAOYSA-N;
MW          167.208;      // g/mol [origin=calculated method=formula-sum]
Tc          841.69;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.8531;      // -   [origin=predictive method=lee-kesler]
Tb          612.75;      // K   [origin=predictive method=joback]
HvapTb      64631.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.828 0.87372 -0.00061872 1.858e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-azanylethyl)-2-methoxy-phenol" "4-(2-amino-ethyl)-2-methoxy-phenol" "3-methoxytyramine" "3-o-methyldopamine" "3-methoxy-4-hydroxyphenylethyl amine" "phenol, 4-(2-aminoethyl)-2-methoxy-" "tyramine, 3-methoxy-" "4-(2-aminoethyl)-2-methoxy-phenol" "3-methoxy-4-hydroxyphenethylamine" "agn-pc-04y20c" "4-hydroxy-3-methoxyphenylethylamine" "phenol,5-(2-aminoethyl)-2-methoxy-" );
gibbsFormation
{
    dHf_298   -279770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-65490.0
    phase     gas;
}
