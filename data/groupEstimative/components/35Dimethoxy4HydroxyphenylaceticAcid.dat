/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dimethoxy-4-hydroxyphenylacetic acid  (C10H12O5, CAS 4385-56-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dimethoxy4HydroxyphenylaceticAcid;
formula     C10H12O5;
CAS         4385-56-2;
InChIKey    BQBQKSSTFGCRQL-UHFFFAOYSA-N;
MW          212.201;      // g/mol [origin=calculated method=formula-sum]
Tc          960.68;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       1.2344;      // -   [origin=predictive method=lee-kesler]
Tb          736.01;      // K   [origin=predictive method=joback]
HvapTb      76452.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.171 0.83494 -0.00052428 1.35e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3O; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3,5-dimethoxy-4-oxidanyl-phenyl)ethanoic acid" "homosyringic acid" "(4-hydroxy-3,5-dimethoxyphenyl)acetic acid" "2-(4-hydroxy-3,5-dimethoxyphenyl)acetic acid" "4-hydroxy-3,5-dimethoxyphenylacetic acid" "benzeneacetic acid,4-hydroxy-3,5-dimethoxy-" "3,5-dimethoxy-4-hydroxy-phenylacetic acid" "aceticacid, (4-hydroxy-3,5-dimethoxyphenyl)- (6ci,8ci);3,5-dimethoxy-4-hydroxyphenylacetic acid;4-hydroxy-3,5-dimethoxybenzeneaceticacid;4-hydroxy-3,5-dimethoxyphenylacetic acid;homosyringic acid;" );
gibbsFormation
{
    dHf_298   -828160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-582060.0
    phase     gas;
}
