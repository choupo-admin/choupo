/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-tert-butyl-2',6'-dimethylacetophenone  (C14H20O, CAS 2040-10-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButyl26Dimethylacetophenone;
formula     C14H20O;
CAS         2040-10-0;
InChIKey    JNHLHPMTMTYLCP-UHFFFAOYSA-N;
MW          204.313;      // g/mol [origin=calculated method=formula-sum]
Tc          828.80;      // K   [origin=predictive method=joback]
Pc          20.774;      // bar [origin=predictive method=joback]
omega       0.6060;      // -   [origin=predictive method=lee-kesler]
Tb          612.18;      // K   [origin=predictive method=joback]
HvapTb      56470.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.96 1.17432 -0.00072098 1.6906e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-tert-butyl-2,6-dimethyl-phenyl)ethanone" "acetophenone, 4'-tert-butyl-2',6'-dimethyl-" "1-acetyl-4-(tert-butyl)-2,6-dimethylbenzene" "ethanone, 1-(4-(1,1-dimethylethyl)-2,6-dimethylphenyl)-" "ethanone, 1-[4-(1,1-dimethylethyl)-2,6-dimethylphenyl]-" "acetophenone,6'-dimethyl-" "1-(4-tert-butyl-2,6-dimethylphenyl)ethanone" "ethanone,1-dimethylethyl)-2,6-dimethylphenyl]-" "acetophenone, 4'-tert-butyl-2',6'-dimethyl- (8ci)" "ethanone,1-[4-(1,1-dimethylethyl)-2,6-dimethylphenyl]-" "4 inverted exclamation marka-tert-butyl-2 inverted exclamation marka,6 inverted exclamation marka-dimethylacetophenone" );
gibbsFormation
{
    dHf_298   -251500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24440.0
    phase     gas;
}
