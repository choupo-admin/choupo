/*--------------------------------*- Choupo -*-----------------------*\
  Component: hex-3-enyl formate  (C7H12O2, CAS 33467-73-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H12O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        hex3EnylFormate;
formula     C7H12O2;
CAS         33467-73-1;
InChIKey    XJHQVZQZUGLZLS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          509.58;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       0.2616;      // -   [origin=predictive method=lee-kesler]
Tb          340.34;      // K   [origin=predictive method=joback]
HvapTb      28761.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.157 0.69692 -0.0005938 2.162e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-3-enyl methanoate" "(e)-hex-3-enyl formate" "cis-3-hexenylformate" "3-hexen-1-ol, formate, (3e)-" "3-hexen-1-ol, 1-formate, (3e)-" "3-hexen-1-ol, 1-formate" "3-hexen-1-ol,formate (7ci,8ci,9ci);3-hexen-1-yl formate;3-hexenyl formate;" "3-hexen-1-ol,formate, (3z)- (9ci);3-hexen-1-ol, formate, (z)- (8ci);(z)-3-hexen-1-ylformate;(z)-3-hexenyl formate;" );
standardThermochemistry
{
    dHf_298   5860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132240.0
}
