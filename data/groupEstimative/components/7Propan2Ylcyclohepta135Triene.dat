/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-propan-2-ylcyclohepta-1,3,5-triene  (C10H14, CAS 17678-85-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Propan2Ylcyclohepta135Triene;
formula     C10H14;
CAS         17678-85-2;
InChIKey    VUZPRMDAVNIKAV-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          665.52;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       0.3015;      // -   [origin=predictive method=lee-kesler]
Tb          449.26;      // K   [origin=predictive method=joback]
HvapTb      38943.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.27 0.90424 -0.00051984 9.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group CH=CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-cycloheptatriene, 7-(1-methylethyl)-" );
standardThermochemistry
{
    dHf_298   -33510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133110.0
}
