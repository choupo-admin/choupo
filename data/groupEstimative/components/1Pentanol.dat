/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentanol  (C5H12O, CAS 71-41-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pentanol;
formula     C5H12O;
CAS         71-41-0;
InChIKey    AMQJEAYHLZJPGS-UHFFFAOYSA-N;
MW          88.15;      // g/mol [origin=calculated method=formula-sum]
Tc          567.90;      // K   [origin=predictive method=joback]
Pc          38.771;      // bar [origin=predictive method=joback]
omega       0.7127;      // -   [origin=predictive method=lee-kesler]
Tb          406.18;      // K   [origin=predictive method=joback]
HvapTb      43403.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.634 0.51282 -0.0002786 5.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentan-1-ol" "amyl alcohol" "pentyl alcohol" "n-amyl alcohol" "n-pentanol" "butylcarbinol" "pentanol" "amylol" "n-butylcarbinol" "pentanol-1" "1-pentyl alcohol" "n-pentan-1-ol" );
gibbsFormation
{
    dHf_298   -298760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-145600.0
    phase     gas;
}
