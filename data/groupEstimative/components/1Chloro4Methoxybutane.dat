/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-4-methoxybutane  (C5H11ClO, CAS 17913-18-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro4Methoxybutane;
formula     C5H11ClO;
CAS         17913-18-7;
InChIKey    DFLRARJQZRCCKN-UHFFFAOYSA-N;
MW          122.592;      // g/mol [origin=calculated method=formula-sum]
Tc          547.19;      // K   [origin=predictive method=joback]
Pc          32.579;      // bar [origin=predictive method=joback]
omega       0.3879;      // -   [origin=predictive method=lee-kesler]
Tb          373.85;      // K   [origin=predictive method=joback]
HvapTb      33519.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.734 0.42242 -0.0001576 2.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH3O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-methoxy-butane" "4-chlorobutyl methyl ether" "ether, 4-chlorobutyl methyl" "butane, 1-chloro-4-methoxy-" "1-chlor-4-methoxybutan" "4-methoxybutyl chloride" "4-methoxy-1-chlorobutane" "methyl 4-chlorobutyl ether" "a-chlorobutyl methyl ether" "ether,4-chlorobutyl methyl (6ci,7ci,8ci);1-chloro-4-methoxybutane;4-methoxy-1-chlorobutane;4-methoxybutyl chloride;methyl4-chlorobutyl ether;d-chlorobutyl methyl ether;" );
gibbsFormation
{
    dHf_298   -294490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125710.0
    phase     gas;
}
