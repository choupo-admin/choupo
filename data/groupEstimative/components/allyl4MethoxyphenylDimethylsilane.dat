/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl(4-methoxyphenyl)dimethylsilane  (C12H18OSi, CAS 68469-60-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H18OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        allyl4MethoxyphenylDimethylsilane;
formula     C12H18OSi;
CAS         68469-60-3;
InChIKey    BEKRXBQZYQZFBV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          206.36;      // g/mol [origin=calculated method=formula-sum]
Tc          736.00;      // K   [origin=predictive method=joback]
Pc          21.653;      // bar [origin=predictive method=joback]
omega       0.4354;      // -   [origin=predictive method=lee-kesler]
Tb          526.32;      // K   [origin=predictive method=joback]
HvapTb      47278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.701 0.71606 -9.026e-05 -1.224e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methoxyphenyl)-dimethyl-prop-2-enyl-silane" "allyldimethyl(4-methoxyphenyl)silane" "(4-methoxyphenyl)-dimethyl-prop-2-enylsilane" );
standardThermochemistry
{
    dHf_298   -184360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     643.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31020.0
}
