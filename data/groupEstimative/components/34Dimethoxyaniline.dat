/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethoxyaniline  (C8H11NO2, CAS 6315-89-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dimethoxyaniline;
formula     C8H11NO2;
CAS         6315-89-5;
InChIKey    LGDHZCLREKIGKJ-UHFFFAOYSA-N;
MW          153.181;      // g/mol [origin=calculated method=formula-sum]
Tc          757.31;      // K   [origin=predictive method=joback]
Pc          36.202;      // bar [origin=predictive method=joback]
omega       0.6232;      // -   [origin=predictive method=lee-kesler]
Tb          536.65;      // K   [origin=predictive method=joback]
HvapTb      52463.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.8 0.50144 -0.00012992 -3.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3O; count 2; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-aminoveratrole" "benzenamine, 3,4-dimethoxy-" "4-aminoveratrol" "3,4-dimethoxybenzenamine" "3,4-dimethyloxy aniline" "aniline, 3,4-dimethoxy-" "2-methoxy-4-aminoanisole" "3,4-dimethoxy aniline" "3,4-dimethoxyphenylamine" "ghl.pd_mitscher_leg0.825" "(3,4-dimethoxyphenyl)-amine" "lgdhzclrekigkj-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -225510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-33920.0
    phase     gas;
}
