/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-methoxyphenyl)benzamide  (C14H13NO2, CAS 67856-55-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22MethoxyphenylBenzamide;
formula     C14H13NO2;
CAS         67856-55-7;
InChIKey    FGIMLEOUWYBPNF-UHFFFAOYSA-N;
MW          227.263;      // g/mol [origin=calculated method=formula-sum]
Tc          981.60;      // K   [origin=predictive method=joback]
Pc          29.959;      // bar [origin=predictive method=joback]
omega       0.8803;      // -   [origin=predictive method=lee-kesler]
Tb          732.06;      // K   [origin=predictive method=joback]
HvapTb      72431.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.7 1.02772 -0.00057982 1.0376e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group CH3O; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1,1'-biphenyl)-2-carboxamide, 2'-methoxy-" "[1,1'-biphenyl]-2-carboxamide, 2'-methoxy-" "polyoxyethylene, partially phosphoric acid esterified, triethanolamine salt" "2'-methoxy(1,1'-biphenyl)-2-carboxamide" );
standardThermochemistry
{
    dHf_298   -93180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105090.0
}
