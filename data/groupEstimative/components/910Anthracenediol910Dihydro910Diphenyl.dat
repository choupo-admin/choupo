/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,10-anthracenediol, 9,10-dihydro-9,10-diphenyl-  (C26H20O2, CAS 6318-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        910Anthracenediol910Dihydro910Diphenyl;
formula     C26H20O2;
CAS         6318-17-8;
InChIKey    RYFIDGIWTNANMO-UHFFFAOYSA-N;
MW          364.444;      // g/mol [origin=calculated method=formula-sum]
Tc          1353.29;      // K   [origin=predictive method=joback]
Pc          23.248;      // bar [origin=predictive method=joback]
omega       1.5745;      // -   [origin=predictive method=lee-kesler]
Tb          1093.80;      // K   [origin=predictive method=joback]
HvapTb      114386.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-256.35 2.825 -0.00271852 1.067e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 2; } { group ACH; count 18; } { group AC; count 6; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 2; } { group dCH_ring; count 18; } { group dC_ring; count 6; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10-diphenylanthracene-9,10-diol" "9,10-dihydro-9,10-diphenyl-9,10-anthracenediol" "9,10-diphenyl-9,10-dihydroanthracene-9,10-diol" "9,10-diphenyl-9,10-anthracenediol" "9, 9,10-dihydro-9,10-diphenyl-" "9,10-dihydro-9,10-diphenylanthracene-9,10-diol" );
gibbsFormation
{
    dHf_298   127850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     819.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=378940.0
    phase     gas;
}
