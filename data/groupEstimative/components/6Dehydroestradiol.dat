/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-dehydroestradiol  (C18H22O2, CAS 7291-41-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Dehydroestradiol;
formula     C18H22O2;
CAS         7291-41-0;
InChIKey    VVLCELUSWGWMSW-ZBRFXRBCSA-N;
MW          270.372;      // g/mol [origin=calculated method=formula-sum]
Tc          1070.97;      // K   [origin=predictive method=joback]
Pc          26.735;      // bar [origin=predictive method=joback]
omega       1.2229;      // -   [origin=predictive method=lee-kesler]
Tb          834.72;      // K   [origin=predictive method=joback]
HvapTb      86899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-228.01 2.38042 -0.0021832 8.304e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,13s,14s,17s)-13-methyl-8,9,11,12,14,15,16,17-octahydrocyclopenta[a]phenanthrene-3,17-diol" "6-dehydro-17beta-estradiol" "estra-1,3,5(10),6-tetraen-3,17beta-diol" "oestra-1(10),2,4,6-tetraene-3,17beta-diol" "estra-1,3,5(10),6-tetraene-3,17-diol" "6-dehydro-estradiol" "6,7-dehydro estradiol" " currency6,7-estradiol" "estra-1(10),2,4,6-tetraene-3,17beta-diol" "estra-1,3,5(10),6-tetraen-3,17" "a-diol" "estra-1,3,5(10),6-tetraene-3,17" "a-diol" "estra-1,3,5(10)-6-tetraen-3,17" "a-diol" );
standardThermochemistry
{
    dHf_298   -280910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79120.0
}
