/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-(2-hydroxyethoxy)ethoxy)ethyl acetate  (C8H16O5, CAS 52337-72-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222HydroxyethoxyEthoxyEthylAcetate;
formula     C8H16O5;
CAS         52337-72-1;
InChIKey    HZIJXNRGQFAGJR-UHFFFAOYSA-N;
MW          192.211;      // g/mol [origin=calculated method=formula-sum]
Tc          743.61;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       1.1990;      // -   [origin=predictive method=lee-kesler]
Tb          577.88;      // K   [origin=predictive method=joback]
HvapTb      62308.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (77.316 0.61662 -0.0001252 -7.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH3COO; count 1; } { group CH2O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group OH; count 1; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-hydroxyethyloxy)ethoxy]ethyl ethanoate" "2-[2-(2-hydroxyethoxy)ethoxy]ethyl acetate" "ethanol, 2-(2-(2-(acetyloxy)ethoxy)ethoxy)-" "ethanol, 2-[2-[2-(acetyloxy)ethoxy]ethoxy]-" "ethanol, 2-(2-(2-hydroxyethoxy)ethoxy)-, monoacetate" );
standardThermochemistry
{
    dHf_298   -942400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-640710.0
}
