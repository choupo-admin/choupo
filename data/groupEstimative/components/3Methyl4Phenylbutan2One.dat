/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-4-phenylbutan-2-one  (C11H14O, CAS 2550-27-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl4Phenylbutan2One;
formula     C11H14O;
CAS         2550-27-8;
InChIKey    YEHRTTZJTORGJL-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          747.67;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       0.5310;      // -   [origin=predictive method=lee-kesler]
Tb          531.39;      // K   [origin=predictive method=joback]
HvapTb      48714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.339 0.94784 -0.0005903 1.3566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-4-phenyl-butan-2-one" "2-butanone, 3-methyl-4-phenyl-" "3-methyl-4-phenyl-2-butanone" "2-butanone,3-methyl-4-phenyl-" "3-methyl-4-phenyl-2-butanone;" "yehrttzjtorgjl-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -151700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22790.0
    phase     gas;
}
