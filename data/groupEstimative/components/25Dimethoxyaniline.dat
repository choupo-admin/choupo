/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethoxyaniline  (C8H11NO2, CAS 102-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethoxyaniline;
formula     C8H11NO2;
CAS         102-56-7;
InChIKey    NAZDVUBIEPVUKE-UHFFFAOYSA-N;
MW          153.181;      // g/mol [origin=calculated method=formula-sum]
Tc          757.31;      // K   [origin=predictive method=joback]
Pc          36.202;      // bar [origin=predictive method=joback]
omega       0.6232;      // -   [origin=predictive method=lee-kesler]
Tb          536.65;      // K   [origin=predictive method=joback]
HvapTb      52463.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.8 0.50144 -0.00012992 -3.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3O; count 2; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aminohydroquinone dimethyl ether" "2,5-dimethoxy aniline" "benzenamine, 2,5-dimethoxy-" "aniline, 2,5-dimethoxy-" "1-amino-2,5-dimethoxybenzene" "2,5-dimethoxybenzenamine" "2,5-dimethoxyphenylamine" "2,5 dimethoxy aniline" "dimethoxyaniline(2,5-)" "2-amino-1,4-dimethoxybenzene" "2-aminohydroquinone dimethyl ether" "l096" );
standardThermochemistry
{
    dHf_298   -225510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-33920.0
}
