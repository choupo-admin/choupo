/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenyldecane  (C16H26, CAS 4537-12-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenyldecane;
formula     C16H26;
CAS         4537-12-6;
InChIKey    QTDBKYLPIZUTFN-UHFFFAOYSA-N;
MW          218.384;      // g/mol [origin=calculated method=formula-sum]
Tc          784.88;      // K   [origin=predictive method=joback]
Pc          17.146;      // bar [origin=predictive method=joback]
omega       0.6394;      // -   [origin=predictive method=lee-kesler]
Tb          591.92;      // K   [origin=predictive method=joback]
HvapTb      53098.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.243 1.45084 -0.000881 2.042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decan-4-ylbenzene" "benzene, (1-propylheptyl)-" "decane, 4-phenyl-" );
standardThermochemistry
{
    dHf_298   -142320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     663.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=193810.0
}
