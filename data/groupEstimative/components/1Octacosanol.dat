/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octacosanol  (C28H58O, CAS 557-61-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octacosanol;
formula     C28H58O;
CAS         557-61-9;
InChIKey    CNNRPFQICPFDPO-UHFFFAOYSA-N;
MW          410.771;      // g/mol [origin=calculated method=formula-sum]
Tc          1160.66;      // K   [origin=predictive method=joback]
Pc          6.874;      // bar [origin=predictive method=joback]
omega       0.4804;      // -   [origin=predictive method=lee-kesler]
Tb          932.42;      // K   [origin=predictive method=joback]
HvapTb      94601.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.273 2.69782 -0.0015298 3.318e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 27; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 27; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octacosan-1-ol" "octacosanol" "montanyl alcohol" "octacosyl alcohol" "cluytyl alcohol" "n-octacosanol" "octacosanol-1" "octacosyl" "polycosanol" "octanosol" "67905-27-5 (aluminum[1:3]salt)" "k972" );
gibbsFormation
{
    dHf_298   -773480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1297.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48060.0
    phase     gas;
}
