/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-dodecylbenzyl)benzoic acid  (C26H36O2, CAS 71195-67-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24DodecylbenzylBenzoicAcid;
formula     C26H36O2;
CAS         71195-67-0;
InChIKey    IETZQXITVDPXRF-UHFFFAOYSA-N;
MW          380.572;      // g/mol [origin=calculated method=formula-sum]
Tc          1230.71;      // K   [origin=predictive method=joback]
Pc          11.163;      // bar [origin=predictive method=joback]
omega       1.0451;      // -   [origin=predictive method=lee-kesler]
Tb          1003.31;      // K   [origin=predictive method=joback]
HvapTb      96510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.358 2.24782 -0.00139152 3.274e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(4-dodecylphenyl)methyl]benzoic acid" "benzoic acid, 2-((4-dodecylphenyl)methyl)-" "benzoic acid, 2-[(4-dodecylphenyl)methyl]-" "alpha-(p-dodecylphenyl)-o-touic acid" );
standardThermochemistry
{
    dHf_298   -480120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     996.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29690.0
}
