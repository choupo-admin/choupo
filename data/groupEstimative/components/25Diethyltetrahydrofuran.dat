/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-diethyltetrahydrofuran  (C8H16O, CAS 41239-48-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Diethyltetrahydrofuran;
formula     C8H16O;
CAS         41239-48-9;
InChIKey    YKWLEIXVUHRKEF-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          612.94;      // K   [origin=predictive method=joback]
Pc          29.282;      // bar [origin=predictive method=joback]
omega       0.3609;      // -   [origin=predictive method=lee-kesler]
Tb          420.20;      // K   [origin=predictive method=joback]
HvapTb      37860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.608 0.86604 -0.0004695 8.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-diethyloxolane" "furan, 2,5-diethyltetrahydro-" );
standardThermochemistry
{
    dHf_298   -300310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40800.0
}
