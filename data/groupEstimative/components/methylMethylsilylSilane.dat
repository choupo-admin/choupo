/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl(methylsilyl)silane  (C2H10Si2, CAS 870-26-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C2H10Si2 (delta H+4Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methylMethylsilylSilane;
formula     C2H10Si2;
CAS         870-26-8;
InChIKey    UPARUZSLIVQDTG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          90.272;      // g/mol [origin=calculated method=formula-sum]
Tc          401.95;      // K   [origin=predictive method=joback]
Pc          38.965;      // bar [origin=predictive method=joback]
omega       0.0620;      // -   [origin=predictive method=lee-kesler]
Tb          245.36;      // K   [origin=predictive method=joback]
HvapTb      20046.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.07 0.19384 -8.5e-05 1.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group SiH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "disilane, 1,2-dimethyl-(7ci,8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -84610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34040.0
}
