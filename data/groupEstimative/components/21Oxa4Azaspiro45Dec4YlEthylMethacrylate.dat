/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1-oxa-4-azaspiro(4.5)dec-4-yl)ethyl methacrylate  (C14H23NO3, CAS 4203-89-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        21Oxa4Azaspiro45Dec4YlEthylMethacrylate;
formula     C14H23NO3;
CAS         4203-89-8;
InChIKey    DCEYPVNNJBGUHA-UHFFFAOYSA-N;
MW          253.342;      // g/mol [origin=calculated method=formula-sum]
Tc          860.46;      // K   [origin=predictive method=joback]
Pc          22.504;      // bar [origin=predictive method=joback]
omega       0.7588;      // -   [origin=predictive method=lee-kesler]
Tb          645.29;      // K   [origin=predictive method=joback]
HvapTb      59628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-152.258 1.97122 -0.0016563 5.813e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group C; count 1; } { group CH2=C; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 7; } { group C_ring; count 1; } { group O_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1-oxa-4-azaspiro[4.5]decan-4-yl)ethyl 2-methylprop-2-enoate" "2-(1-oxa-4-azaspiro[4.5]dec-4-yl)ethyl methacrylate" "2-propenoic acid, 2-methyl-, 2-(1-oxa-4-azaspiro(4.5)dec-4-yl)ethyl ester" "2-propenoic acid, 2-methyl-, 2-(1-oxa-4-azaspiro[4.5]dec-4-yl)ethyl ester" "2-(4-oxa-1-azaspiro[4.5]decan-1-yl)ethyl 2-methylprop-2-enoate" "2-(spiro(cyclohexane-1,2'-oxazolidin)-3'-yl)ethyl methacrylate" "2-propenoic acid,2-methyl-, 2-(1-oxa-4-azaspiro[4.5]dec-4-yl)ethyl ester" "methacrylicacid, 2-(1-oxa-4-azaspiro[4.5]dec-4-yl)ethyl ester (7ci,8ci); 1-oxa-4-azaspiro[4.5]decane,2-propenoic acid deriv.; 1-oxa-4-azaspiro[4.5]decane-4-ethanol, methacrylate(ester) (8ci); 3-[2-(methacryloxy)ethyl]-2,2-spirocyclohexyloxazolidine" );
gibbsFormation
{
    dHf_298   -435700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     699.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-52000.0
    phase     gas;
}
