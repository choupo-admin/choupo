/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetamide, n-(1-heptyl-3-piperidyl)-  (C14H28N2O, CAS 24026-79-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetamideN1Heptyl3Piperidyl;
formula     C14H28N2O;
CAS         24026-79-7;
InChIKey    LDQHWEGEIVKUJZ-UHFFFAOYSA-N;
MW          240.391;      // g/mol [origin=calculated method=formula-sum]
Tc          848.39;      // K   [origin=predictive method=joback]
Pc          19.458;      // bar [origin=predictive method=joback]
omega       0.9222;      // -   [origin=predictive method=lee-kesler]
Tb          655.91;      // K   [origin=predictive method=joback]
HvapTb      62161.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.485 1.67004 -0.0010663 2.6146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group CH2N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2_ring; count 5; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(3-piperidin-1-ylheptyl)ethanamide" "n-(3-piperidin-1-ylheptyl)acetamide" );
gibbsFormation
{
    dHf_298   -248330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     767.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=180070.0
    phase     gas;
}
