/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-(p-chlorophenyl)phenethyl 4-(o-methoxyphenyl)piperazinyl ketone  (C26H27ClN2O2, CAS 23902-91-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaPChlorophenylPhenethyl4OMethoxyphenylPiperazinylKetone;
formula     C26H27ClN2O2;
CAS         23902-91-2;
InChIKey    JDTFZNXSBNLHFV-UHFFFAOYSA-N;
MW          434.964;      // g/mol [origin=calculated method=formula-sum]
Tc          1292.45;      // K   [origin=predictive method=joback]
Pc          15.379;      // bar [origin=predictive method=joback]
omega       1.1468;      // -   [origin=predictive method=lee-kesler]
Tb          1038.32;      // K   [origin=predictive method=joback]
HvapTb      99255.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.479 2.45522 -0.00169842 4.4196e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 13; } { group AC; count 3; } { group ACCH; count 1; } { group CH3O; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group Cl; count 1; } { group O; count 1; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-chlorophenyl)-1-[4-(2-methoxyphenyl)piperazin-1-yl]-3-phenyl-propan-1-one" "1-(3-(p-chlorophenyl)-3-phenylpropionyl)-4-(o-methoxyphenyl)piperazine" "ketone, beta-(p-chlorophenyl)phenethyl 4-(o-methoxyphenyl)piperazinyl" "piperazine, 1-(3-(p-chlorophenyl)-3-phenylpropionyl)-4-(o-methoxyphenyl)-" "3-(4-chlorophenyl)-1-[4-(2-methoxyphenyl)piperazin-1-yl]-3-phenylpropan-1-one" );
gibbsFormation
{
    dHf_298   62900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     903.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=515640.0
    phase     gas;
}
