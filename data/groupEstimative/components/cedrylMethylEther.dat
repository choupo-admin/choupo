/*--------------------------------*- Choupo -*-----------------------*\
  Component: cedryl methyl ether  (C16H28O, CAS 67874-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cedrylMethylEther;
formula     C16H28O;
CAS         67874-81-1;
InChIKey    HRGPYCVTDOECMG-FETWPZQLSA-N;
MW          236.399;      // g/mol [origin=calculated method=formula-sum]
Tc          827.73;      // K   [origin=predictive method=joback]
Pc          18.986;      // bar [origin=predictive method=joback]
omega       0.4787;      // -   [origin=predictive method=lee-kesler]
Tb          603.57;      // K   [origin=predictive method=joback]
HvapTb      49323.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-279.28 2.6904 -0.002735 1.1719e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 3; } { group C; count 3; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cedramber" "cedrol methyl ether" "methyl cedryl ether" "1h-3a,7-methanoazulene, octahydro-6-methoxy-3,6,8,8-tetramethyl-, (3r,3as,6r,7r,8as)-" "(3r-(3alpha,3abeta,6alpha,7beta,8aalpha))-octahydro-6-methoxy-3,6,8,8-tetramethyl-1h-3a,7-methanoazulene" );
gibbsFormation
{
    dHf_298   -315010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97290.0
    phase     gas;
}
