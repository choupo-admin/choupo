/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-dodecen-1-ol, (z)-  (C12H24O, CAS 20056-92-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Dodecen1OlZ;
formula     C12H24O;
CAS         20056-92-2;
InChIKey    WWDOVTHLTQFGOZ-WAYWQWQTSA-N;
MW          184.323;      // g/mol [origin=calculated method=formula-sum]
Tc          733.82;      // K   [origin=predictive method=joback]
Pc          20.181;      // bar [origin=predictive method=joback]
omega       1.0000;      // -   [origin=predictive method=lee-kesler]
Tb          570.50;      // K   [origin=predictive method=joback]
HvapTb      58943.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.911 1.19782 -0.0007432 1.888e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-dodec-7-en-1-ol" "cis-7-dodecen-1-ol" "looplure inhibitor" "(z)-dodec-7-enol" "7z-dodecen-1-ol" "z-7-ddol" "(z)-7-ddol" );
gibbsFormation
{
    dHf_298   -326020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     667.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6440.0
    phase     gas;
}
