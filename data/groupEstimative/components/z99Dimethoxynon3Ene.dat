/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-9,9-dimethoxynon-3-ene  (C11H22O2, CAS 68555-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        z99Dimethoxynon3Ene;
formula     C11H22O2;
CAS         68555-53-3;
InChIKey    UVCRVXVBFFMDFR-WAYWQWQTSA-N;
MW          186.295;      // g/mol [origin=calculated method=formula-sum]
Tc          671.86;      // K   [origin=predictive method=joback]
Pc          19.788;      // bar [origin=predictive method=joback]
omega       0.6273;      // -   [origin=predictive method=lee-kesler]
Tb          499.84;      // K   [origin=predictive method=joback]
HvapTb      44470.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.025 0.94836 -0.0004396 5.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH=CH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group dCH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cis-6-nonenal dimethylacetal" "cis-6-nonenal dimethyl acetal" "3-nonene, 9,9-dimethoxy-, (z)-" "3-nonene, 9,9-dimethoxy-, (3z)-" "cis-6-nonen-1-al dimethyl acetal" );
gibbsFormation
{
    dHf_298   -422870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90480.0
    phase     gas;
}
