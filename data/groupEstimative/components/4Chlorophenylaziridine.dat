/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorophenylaziridine  (C8H8ClN, CAS 28192-05-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chlorophenylaziridine;
formula     C8H8ClN;
CAS         28192-05-4;
InChIKey    LDLKZJFSHAEEKE-UHFFFAOYSA-N;
MW          153.609;      // g/mol [origin=calculated method=formula-sum]
Tc          696.02;      // K   [origin=predictive method=joback]
Pc          40.518;      // bar [origin=predictive method=joback]
omega       0.4317;      // -   [origin=predictive method=lee-kesler]
Tb          471.31;      // K   [origin=predictive method=joback]
HvapTb      42818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.85 0.9431 -0.00083056 2.884e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-chlorophenyl)aziridine" );
gibbsFormation
{
    dHf_298   167700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     336.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=298670.0
    phase     gas;
}
