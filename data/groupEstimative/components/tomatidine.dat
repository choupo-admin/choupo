/*--------------------------------*- Choupo -*-----------------------*\
  Component: tomatidine  (C27H45NO2, CAS 77-59-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tomatidine;
formula     C27H45NO2;
CAS         77-59-8;
InChIKey    XYNPYHXGMWJBLV-VXPJTDKGSA-N;
MW          415.662;      // g/mol [origin=calculated method=formula-sum]
Tc          1273.25;      // K   [origin=predictive method=joback]
Pc          12.664;      // bar [origin=predictive method=joback]
omega       1.0428;      // -   [origin=predictive method=lee-kesler]
Tb          1028.07;      // K   [origin=predictive method=joback]
HvapTb      99018.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-433.76 4.14138 -0.0036627 1.3896e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 8; } { group C; count 3; } { group OH; count 1; } { group CH-O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 11; } { group CH_ring; count 9; } { group C_ring; count 3; } { group OH; count 1; } { group O_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tomatidin" "5alpha-tomatidan-3beta-ol" "(3beta,5alpha,22beta,25s)-spirosolan-3-ol" "(3beta,5alpha,25s)-spirosolan-3-ol" "prestwick_473" "ambap77-59-8" "5alpha-tomatidan-3beta-ol (8ci)" "(22s,25s)-5alpha-spirosolan-3beta-ol" "spirosolan-3-ol, (3beta,5alpha,22beta,25s)-" "spirosolan-3-ol, (3beta,5alpha,22beta,25s)- (9ci)" );
standardThermochemistry
{
    dHf_298   -529670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     753.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=258300.0
}
