/*--------------------------------*- Choupo -*-----------------------*\
  Component: butibufen  (C14H20O2, CAS 55837-18-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butibufen;
formula     C14H20O2;
CAS         55837-18-8;
InChIKey    UULSXYSSHHRCQK-UHFFFAOYSA-N;
MW          220.312;      // g/mol [origin=calculated method=formula-sum]
Tc          910.89;      // K   [origin=predictive method=joback]
Pc          21.816;      // bar [origin=predictive method=joback]
omega       0.8947;      // -   [origin=predictive method=lee-kesler]
Tb          696.21;      // K   [origin=predictive method=joback]
HvapTb      66084.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.208 1.25806 -0.00078096 1.83e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(2-methylpropyl)phenyl]butanoic acid" "butilopan" "butibufene [inn-french]" "butibufenum [inn-latin]" "2-(p-isobutylphenyl)butyrate" "2-(4-isobutylphenyl)buttersaeure" "2-(4-isobutylphenyl)butyric acid" "2-(4-isobutylphenyl)butanoic acid" "butyric acid, 2-(4-isobutylphenyl)-" "alpha-ethyl-4-(2-methylpropyl)benzeneacetic acid" "butibufene" "butibufeno" );
standardThermochemistry
{
    dHf_298   -468060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-179010.0
}
