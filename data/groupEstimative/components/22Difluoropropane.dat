/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-difluoropropane  (C3H6F2, CAS 420-45-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Difluoropropane;
formula     C3H6F2;
CAS         420-45-1;
InChIKey    YZXSQDNPKVBDOG-UHFFFAOYSA-N;
MW          80.077;      // g/mol [origin=calculated method=formula-sum]
Tc          414.49;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.1868;      // -   [origin=predictive method=lee-kesler]
Tb          263.55;      // K   [origin=predictive method=joback]
HvapTb      19342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.13 0.43824 -0.000344 1.076e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(fluoranyl)propane" "propane, 2,2-difluoro-" "dimethyldifluoromethane" "2,2-difluoropropane;dimethyldifluoromethane;" );
gibbsFormation
{
    dHf_298   -506220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     297.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-412400.0
    phase     gas;
}
