/*--------------------------------*- Choupo -*-----------------------*\
  Component: voglibose  (C10H21NO7, CAS 83480-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        voglibose;
formula     C10H21NO7;
CAS         83480-29-9;
InChIKey    FZNCGRZWXLXZSZ-UHFFFAOYSA-N;
MW          267.278;      // g/mol [origin=calculated method=formula-sum]
Tc          1448.94;      // K   [origin=predictive method=joback]
Pc          51.387;      // bar [origin=predictive method=joback]
omega       1.6269;      // -   [origin=predictive method=lee-kesler]
Tb          1124.50;      // K   [origin=predictive method=joback]
HvapTb      158697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.897 1.5819 -0.0011768 3.812e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 4; } { group C; count 1; } { group OH; count 7; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group C_ring; count 1; } { group OH; count 7; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-[1,3-bis(oxidanyl)propan-2-ylamino]-1-(hydroxymethyl)cyclohexane-1,2,3,4-tetrol" "2,3-dideoxy-2-((2-hydroxy-1-(hydroxymethyl)ethyl)amino)-4-c-(hydroxymethyl)-epi-inositol" "5-(1,3-dihydroxypropan-2-ylamino)-1-(hydroxymethyl)cyclohexane-1,2,3,4-tetrol" "5-(2-hydroxy-1-(hydroxymethyl)ethyl)amino-1-c-(hydroxymethyl)-1,2,3,4-cyclohexanetetrol" "5-[(1,3-dihydroxypropan-2-yl)amino]-1-(hydroxymethyl)cyclohexane-1,2,3,4-tetrol" "epi-inositol, 2,3-dideoxy-2-((2-hydroxy-1-(hydroxymethyl)ethyl)amino)-4-c-(hydroxymethyl)-" "voglibose [usan:inn]" "voglibosum [inn-latin]" "3,4-dideoxy-4-((2-hydroxy-1-(hydroxymethyl)ethyl)amino)-2-c-(hydroxymethyl)-d-epi-inositol" "(1r,2r,3s,4r,5r)-5-(1,3-dihydroxypropan-2-ylamino)-1-(hydroxymethyl)cyclohexane-1,2,3,4-tetraol" "(1s,2s,3r,4s)-5-(1,3-dihydroxypropan-2-ylamino)-1-(hydroxymethyl)cyclohexane-1,2,3,4-tetrol" );
gibbsFormation
{
    dHf_298   -1278950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     802.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-849350.0
    phase     gas;
}
