/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[bis(benzylsulfanyl)methyl]-4-(trichloromethyl)benzene  (C22H19Cl3S2, CAS 81269-09-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1BisBenzylsulfanylMethyl4TrichloromethylBenzene;
formula     C22H19Cl3S2;
CAS         81269-09-2;
InChIKey    USIDHRSKKDHIBL-UHFFFAOYSA-N;
MW          453.864;      // g/mol [origin=calculated method=formula-sum]
Tc          1327.46;      // K   [origin=predictive method=joback]
Pc          17.332;      // bar [origin=predictive method=joback]
omega       0.9135;      // -   [origin=predictive method=lee-kesler]
Tb          1034.16;      // K   [origin=predictive method=joback]
HvapTb      97161.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.808 1.93848 -0.00135536 3.454e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 3; } { group ACCH; count 1; } { group CCl3; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group Cl; count 3; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[bis(phenylmethylsulfanyl)methyl]-4-(trichloromethyl)benzene" );
standardThermochemistry
{
    dHf_298   223200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     862.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=492810.0
}
