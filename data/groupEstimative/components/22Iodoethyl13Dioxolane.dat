/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-iodoethyl)-1,3-dioxolane  (C5H9IO2, CAS 83665-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Iodoethyl13Dioxolane;
formula     C5H9IO2;
CAS         83665-55-8;
InChIKey    QFGHSJVNOHRSNT-UHFFFAOYSA-N;
MW          228.025;      // g/mol [origin=calculated method=formula-sum]
Tc          713.34;      // K   [origin=predictive method=joback]
Pc          41.197;      // bar [origin=predictive method=joback]
omega       0.3757;      // -   [origin=predictive method=lee-kesler]
Tb          476.32;      // K   [origin=predictive method=joback]
HvapTb      45374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.808 0.6435 -0.0004292 1.103e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group FCH2O; count 2; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group I; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-iodanylethyl)-1,3-dioxolane" "2-(2-iodo-ethyl)-[1,3]dioxolane" );
gibbsFormation
{
    dHf_298   -273180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     253.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-86350.0
    phase     gas;
}
