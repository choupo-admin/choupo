/*--------------------------------*- Choupo -*-----------------------*\
  Component: dichlorobis(trimethylsilyl)methane  (C7H18Cl2Si2, CAS 15951-41-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H18Cl2Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dichlorobisTrimethylsilylMethane;
formula     C7H18Cl2Si2;
CAS         15951-41-4;
InChIKey    WWPQQMDJOWANKG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          229.291;      // g/mol [origin=calculated method=formula-sum]
Tc          638.74;      // K   [origin=predictive method=joback]
Pc          20.946;      // bar [origin=predictive method=joback]
omega       0.1942;      // -   [origin=predictive method=lee-kesler]
Tb          434.19;      // K   [origin=predictive method=joback]
HvapTb      39238.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (79.47 0.39592 0.00026 -2.724e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CCl2; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[bis(chloranyl)-trimethylsilyl-methyl]-trimethyl-silane" "(dichloromethanediyl)bis(trimethylsilane)" "silane, (dichloromethylene)bis*trimethyl-" "silane, (dichloromethylene)bis[trimethyl-" "[dichloro(trimethylsilyl)methyl]-trimethylsilane" "silane,1,1'-(dichloromethylene)bis[1,1,1-trimethyl-" );
gibbsFormation
{
    dHf_298   -451280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     709.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-222480.0
    phase     gas;
}
