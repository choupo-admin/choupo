/*--------------------------------*- Choupo -*-----------------------*\
  Component: glycerin 1-tetradecyl ether  (C17H36O3, CAS 1561-06-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glycerin1TetradecylEther;
formula     C17H36O3;
CAS         1561-06-4;
InChIKey    JSSKAZULTFHXBH-UHFFFAOYSA-N;
MW          288.472;      // g/mol [origin=calculated method=formula-sum]
Tc          973.20;      // K   [origin=predictive method=joback]
Pc          13.975;      // bar [origin=predictive method=joback]
omega       1.2728;      // -   [origin=predictive method=lee-kesler]
Tb          794.90;      // K   [origin=predictive method=joback]
HvapTb      88816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.835 1.62952 -0.000854 1.554e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group OH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 1; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-tetradecoxypropane-1,2-diol" "myristyl glyceryl ether" "1,2-propanediol, 3-(tetradecyloxy)-" "3-tetradecyloxy-1,2-propanediol" "1, 3-(tetradecyloxy)-" "agn-pc-00jzm3" "1,2-propanediol, 3-(tetradecyloxy)- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -836170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     921.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-288820.0
}
