/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pyrrolidino-1-cyclohexene  (C10H17N, CAS 1125-99-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pyrrolidino1Cyclohexene;
formula     C10H17N;
CAS         1125-99-1;
InChIKey    KTZNVZJECQAMBV-UHFFFAOYSA-N;
MW          151.253;      // g/mol [origin=calculated method=formula-sum]
Tc          707.89;      // K   [origin=predictive method=joback]
Pc          33.297;      // bar [origin=predictive method=joback]
omega       0.4083;      // -   [origin=predictive method=lee-kesler]
Tb          484.88;      // K   [origin=predictive method=joback]
HvapTb      41983.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.66 1.2786 -0.00091864 2.599e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH=C; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(cyclohexen-1-yl)pyrrolidine" "1-pyrrolidinocyclohexene" "pyrrolidine, 1-(1-cyclohexen-1-yl)-" "cyclohexanone pyrrolidine enamine" "1-(1-cyclohexen-1-yl)pyrrolidine" "1-cyclohex-1-en-1-ylpyrrolidine" "cyclohex-1-enylpyrrolidine" "1-pyrrolidinyl-1-cyclohexene" "n-(1-cyclohexenyl)pyrrolidine" "1-(1-pyrrolidinyl)cyclohexene" "1-(1-cyclohexenyl)-pyrrolidine" "1-(1-pyrrolidino)-1-cyclohexene" );
gibbsFormation
{
    dHf_298   25750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252950.0
    phase     gas;
}
