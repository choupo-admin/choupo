/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3260555  (C12H15NO2, CAS 63887-52-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3260555;
formula     C12H15NO2;
CAS         63887-52-5;
InChIKey    FIWNTYXJJOOZFV-UHFFFAOYSA-N;
MW          205.257;      // g/mol [origin=calculated method=formula-sum]
Tc          799.54;      // K   [origin=predictive method=joback]
Pc          25.820;      // bar [origin=predictive method=joback]
omega       0.7326;      // -   [origin=predictive method=lee-kesler]
Tb          591.23;      // K   [origin=predictive method=joback]
HvapTb      55773.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.449 1.01814 -0.00059896 1.2316e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-2-prop-2-enoxy-benzamide" "benzamide, o-allyloxy-n,n-dimethyl-" "n,n-dimethyl-2-prop-2-enoxybenzamide" );
standardThermochemistry
{
    dHf_298   -117790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117640.0
}
