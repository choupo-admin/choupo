/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7-cyclodecadien-1-ol, 1,7-dimethyl-4-(1-methylethyl)-  (C15H26O, CAS 72120-50-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        27Cyclodecadien1Ol17Dimethyl41Methylethyl;
formula     C15H26O;
CAS         72120-50-4;
InChIKey    RHCTXHCNRLCYBN-UHFFFAOYSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          882.72;      // K   [origin=predictive method=joback]
Pc          20.965;      // bar [origin=predictive method=joback]
omega       0.8115;      // -   [origin=predictive method=lee-kesler]
Tb          670.04;      // K   [origin=predictive method=joback]
HvapTb      66178.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.42 1.64638 -0.00110592 3.199e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,7-dimethyl-4-propan-2-yl-cyclodeca-2,7-dien-1-ol" "agn-pc-03dqis" );
gibbsFormation
{
    dHf_298   -381770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     777.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-50700.0
    phase     gas;
}
