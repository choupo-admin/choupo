/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl prop-2-enoate;methyl 2-methylprop-2-enoate;prop-1-ene  (C15H26O4, CAS 64652-56-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylProp2EnoateMethyl2Methylprop2EnoateProp1Ene;
formula     C15H26O4;
CAS         64652-56-8;
InChIKey    YXEZNZVACJBAJO-UHFFFAOYSA-N;
MW          270.369;      // g/mol [origin=calculated method=formula-sum]
Tc          840.06;      // K   [origin=predictive method=joback]
Pc          13.789;      // bar [origin=predictive method=joback]
omega       0.7206;      // -   [origin=predictive method=lee-kesler]
Tb          651.96;      // K   [origin=predictive method=joback]
HvapTb      62456.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (113.043 0.84678 0.0001556 -3.273e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate; methyl 2-methylprop-2-enoate; prop-1-ene" );
gibbsFormation
{
    dHf_298   -844230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1040.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-499870.0
    phase     gas;
}
