/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylisoborneol  (C11H20O, CAS 2371-42-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylisoborneol;
formula     C11H20O;
CAS         2371-42-8;
InChIKey    LFYXNXGVLGKVCJ-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          758.55;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.7065;      // -   [origin=predictive method=lee-kesler]
Tb          552.59;      // K   [origin=predictive method=joback]
HvapTb      52686.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-245.52 2.19778 -0.002486 1.1358e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4,7,7-tetramethylbicyclo[2.2.1]heptan-3-ol" "2-bornanol, 2-methyl-" "1,2,7,7-tetramethylbicyclo[2.2.1]heptan-2-ol" "bicyclo(2.2.1)heptan-2-ol, 1,2,7,7-tetramethyl-, exo-" "2-methyl-2-bornanol" "bicyclo[2.2.1]heptan-2-ol, 1,2,7,7-tetramethyl-, (1s,2r,4s)-" "bicyclo[2.2.1]heptan-2-ol, 1,2,7,7-tetramethyl-" );
gibbsFormation
{
    dHf_298   -278120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     598.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17570.0
    phase     gas;
}
