/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 6-hydroxyhexanoate  (C8H16O3, CAS 5299-60-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl6Hydroxyhexanoate;
formula     C8H16O3;
CAS         5299-60-5;
InChIKey    HYXRUZUPCFVWAH-UHFFFAOYSA-N;
MW          160.213;      // g/mol [origin=calculated method=formula-sum]
Tc          698.97;      // K   [origin=predictive method=joback]
Pc          28.024;      // bar [origin=predictive method=joback]
omega       1.0336;      // -   [origin=predictive method=lee-kesler]
Tb          533.04;      // K   [origin=predictive method=joback]
HvapTb      57488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.316 0.74302 -0.0003472 3.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 6-oxidanylhexanoate" "6-hydroxy-hexanoic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -677960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-430710.0
    phase     gas;
}
