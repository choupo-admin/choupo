/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethyl methyl sulfide  (C2H5ClS, CAS 2373-51-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloromethylMethylSulfide;
formula     C2H5ClS;
CAS         2373-51-5;
InChIKey    JWMLCCRPDOIBAV-UHFFFAOYSA-N;
MW          96.572;      // g/mol [origin=calculated method=formula-sum]
Tc          554.18;      // K   [origin=predictive method=joback]
Pc          48.902;      // bar [origin=predictive method=joback]
omega       0.2385;      // -   [origin=predictive method=lee-kesler]
Tb          351.57;      // K   [origin=predictive method=joback]
HvapTb      31248.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.561 0.19501 -6.52e-05 -6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2Cl; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group Cl; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranyl(methylsulfanyl)methane" "chlorodimethyl sulfide" "chloro(methylthio)methane" "chlorodimethyl thioether" "methylthiomethyl chloride" "monochlorodimethyl sulfide" "chloromethyl methyl sulphide" "chloromethyl methyl thioether" "methane, chloro(methylthio)-" "sulfide, chloromethyl methyl" "chloromethylmethyl sulfide" "chloro(methylsulfanyl)methane" );
gibbsFormation
{
    dHf_298   -58480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     328.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12850.0
    phase     gas;
}
