/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl tribromoacetate  (C3H3Br3O2, CAS 3222-05-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylTribromoacetate;
formula     C3H3Br3O2;
CAS         3222-05-7;
InChIKey    QQHSHLKOWBDOFC-UHFFFAOYSA-N;
MW          310.767;      // g/mol [origin=calculated method=formula-sum]
Tc          770.44;      // K   [origin=predictive method=joback]
Pc          61.515;      // bar [origin=predictive method=joback]
omega       0.5910;      // -   [origin=predictive method=lee-kesler]
Tb          521.71;      // K   [origin=predictive method=joback]
HvapTb      47688.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.67 0.47442 -0.0004308 1.416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group Br; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group Br; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,2,2-tris(bromanyl)ethanoate" "tribromoacetic acid, methyl ester" "methyl 2,2,2-tribromoacetate" "acetic acid,2,2,2-tribromo-, methyl ester" "aceticacid, tribromo-, methyl ester (6ci,7ci,8ci,9ci); methyl tribromoacetate" );
gibbsFormation
{
    dHf_298   -352290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-290190.0
    phase     gas;
}
