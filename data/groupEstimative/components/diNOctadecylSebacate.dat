/*--------------------------------*- Choupo -*-----------------------*\
  Component: di-n-octadecyl sebacate  (C46H90O4, CAS 3072-03-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diNOctadecylSebacate;
formula     C46H90O4;
CAS         3072-03-5;
InChIKey    NTUPDNAURMTJID-UHFFFAOYSA-N;
MW          707.222;      // g/mol [origin=calculated method=formula-sum]
Tc          2182.75;      // K   [origin=predictive method=joback]
Pc          3.162;      // bar [origin=predictive method=joback]
omega       -0.5927;      // -   [origin=predictive method=lee-kesler]
Tb          1368.52;      // K   [origin=predictive method=joback]
HvapTb      132804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.892 4.26424 -0.0022894 4.22e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 40; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 42; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dioctadecyl decanedioate" );
standardThermochemistry
{
    dHf_298   -1627330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     2050.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-284300.0
}
