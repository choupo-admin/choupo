/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxycyclohexanecarboxylic acid  (C8H14O3, CAS 99799-10-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethoxycyclohexanecarboxylicAcid;
formula     C8H14O3;
CAS         99799-10-7;
InChIKey    KAWNRNMMEKTYGM-UHFFFAOYSA-N;
MW          158.197;      // g/mol [origin=calculated method=formula-sum]
Tc          783.30;      // K   [origin=predictive method=joback]
Pc          32.954;      // bar [origin=predictive method=joback]
omega       0.6943;      // -   [origin=predictive method=lee-kesler]
Tb          565.45;      // K   [origin=predictive method=joback]
HvapTb      53096.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.95 0.84702 -0.0003986 3.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxycyclohexane-1-carboxylic acid" "cyclohexanecarboxylic acid, 3-methoxy-" "3-methoxycyclohexanecarboxylic acid, mixture of cis and trans" );
standardThermochemistry
{
    dHf_298   -656960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-415690.0
}
