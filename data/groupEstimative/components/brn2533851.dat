/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2533851  (C20H14BrCl, CAS 796-13-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2533851;
formula     C20H14BrCl;
CAS         796-13-4;
InChIKey    LUFBUHNWDHJVBG-UHFFFAOYSA-N;
MW          369.686;      // g/mol [origin=calculated method=formula-sum]
Tc          1136.79;      // K   [origin=predictive method=joback]
Pc          23.428;      // bar [origin=predictive method=joback]
omega       0.7573;      // -   [origin=predictive method=lee-kesler]
Tb          849.73;      // K   [origin=predictive method=joback]
HvapTb      78542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.19 1.6724 -0.00127096 3.725e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 3; } { group ACCl; count 1; } { group Br; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC; count 2; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-bromanyl-2,2-diphenyl-ethenyl)-4-chloranyl-benzene" "1-bromo-1-(p-chlorophenyl)-2,2-diphenylethylene" "ethylene, 1-bromo-1-(p-chlorophenyl)-2,2-diphenyl-" "1-(1-bromo-2,2-diphenyl-vinyl)-4-chlorobenzene" "1-(1-bromo-2,2-diphenylethenyl)-4-chlorobenzene" "1-[1-bromo-2,2-di(phenyl)ethenyl]-4-chlorobenzene" "benzene,1-(1-bromo-2,2-diphenylethenyl)-4-chloro-" "1-(1-bromo-2,2-diphenyl-ethenyl)-4-chloro-benzene" "1-(1-bromo-2,2-diphenyl-vinyl)-4-chloro-benzene" "ethylene,1-bromo-1-(p-chlorophenyl)-2,2-diphenyl- (7ci,8ci);1-bromo-1-(p-chlorophenyl)-2,2-diphenylethylene" );
gibbsFormation
{
    dHf_298   350220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     679.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=510630.0
    phase     gas;
}
