/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-hydroxy-2-naphthoate  (C13H12O3, CAS 7163-25-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Hydroxy2Naphthoate;
formula     C13H12O3;
CAS         7163-25-9;
InChIKey    CVEOWBRXZJEZRQ-UHFFFAOYSA-N;
MW          216.236;      // g/mol [origin=calculated method=formula-sum]
Tc          923.53;      // K   [origin=predictive method=joback]
Pc          32.616;      // bar [origin=predictive method=joback]
omega       0.9022;      // -   [origin=predictive method=lee-kesler]
Tb          686.52;      // K   [origin=predictive method=joback]
HvapTb      69531.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.489 1.19652 -0.00094604 3.012e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 6; } { group AC; count 3; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-oxidanylnaphthalene-2-carboxylate" "ethyl 3-hydroxynaphthalene-2-carboxylate" "2-naphthalenecarboxylic acid, 3-hydroxy-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -390110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-196980.0
}
