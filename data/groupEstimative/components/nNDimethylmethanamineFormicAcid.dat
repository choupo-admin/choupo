/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylmethanamine; formic acid  (C4H11NO2, CAS 58828-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H11NO2 (delta H+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nNDimethylmethanamineFormicAcid;
formula     C4H11NO2;
CAS         58828-90-3;
InChIKey    UPVCRZBVVOXMDA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          105.137;      // g/mol [origin=calculated method=formula-sum]
Tc          644.06;      // K   [origin=predictive method=joback]
Pc          39.506;      // bar [origin=predictive method=joback]
omega       0.5776;      // -   [origin=predictive method=lee-kesler]
Tb          449.77;      // K   [origin=predictive method=joback]
HvapTb      43852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.57 0.45546 -0.0001716 -6.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH3N; count 1; } { group HCOOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylmethanamine;methanoic acid" "formic acid, compd. with n,n-dimethylmethanamine (1:1)" "formic acid- n,n-dimethylmethanamine(1:1)" "trimethylammonium formate solution" "formic acid,n-dimethylmethanamine (1:1)" "formic acid - n,n-dimethylmethanamine (1:1)" "buffer solution 1 m ph 5.0-6.0 (volatile)" );
standardThermochemistry
{
    dHf_298   -464440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-302710.0
}
