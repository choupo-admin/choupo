/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butanamine, n-(2-methylpropyl)-  (C8H19N, CAS 20810-06-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1ButanamineN2Methylpropyl;
formula     C8H19N;
CAS         20810-06-4;
InChIKey    CCRUHKGZAQXBKC-UHFFFAOYSA-N;
MW          129.247;      // g/mol [origin=calculated method=formula-sum]
Tc          604.51;      // K   [origin=predictive method=joback]
Pc          25.899;      // bar [origin=predictive method=joback]
omega       0.5213;      // -   [origin=predictive method=lee-kesler]
Tb          432.37;      // K   [origin=predictive method=joback]
HvapTb      39450.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.276 0.84596 -0.0004632 9.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-methylpropyl)butan-1-amine" "butyl(2-methylpropyl)amine" "butylisobutyl amine" "n-isobutylbutylamine" );
standardThermochemistry
{
    dHf_298   -160260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103430.0
}
