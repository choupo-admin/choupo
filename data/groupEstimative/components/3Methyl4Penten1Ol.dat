/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-4-penten-1-ol  (C6H12O, CAS 51174-44-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl4Penten1Ol;
formula     C6H12O;
CAS         51174-44-8;
InChIKey    VTCQTYOGWYLVES-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          593.15;      // K   [origin=predictive method=joback]
Pc          36.642;      // bar [origin=predictive method=joback]
omega       0.7018;      // -   [origin=predictive method=lee-kesler]
Tb          425.30;      // K   [origin=predictive method=joback]
HvapTb      44571.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.948 0.59372 -0.0003591 8.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylpent-4-en-1-ol" "4-penten-1-ol, 3-methyl-" );
standardThermochemistry
{
    dHf_298   -199250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51780.0
}
