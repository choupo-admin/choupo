/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.2]oct-2-ene,1,4-dimethoxy-  (C10H16O2, CAS 59880-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo222Oct2Ene14Dimethoxy;
formula     C10H16O2;
CAS         59880-82-9;
InChIKey    NJIGIOLXLHRNMW-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          717.10;      // K   [origin=predictive method=joback]
Pc          31.704;      // bar [origin=predictive method=joback]
omega       0.4241;      // -   [origin=predictive method=lee-kesler]
Tb          494.90;      // K   [origin=predictive method=joback]
HvapTb      40834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-158.13 1.63784 -0.00169828 7.372e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 2; } { group CH=CH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethoxybicyclo[2.2.2]oct-2-ene" "bicyclo(2.2.2)oct-2-ene, 1,4-dimethoxy-" );
gibbsFormation
{
    dHf_298   -292630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60400.0
    phase     gas;
}
