/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dihydroxypropyl 3-sulfanylpropanoate  (C6H12O4S, CAS 67874-65-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dihydroxypropyl3Sulfanylpropanoate;
formula     C6H12O4S;
CAS         67874-65-1;
InChIKey    YTARCXSUNGADNU-UHFFFAOYSA-N;
MW          180.218;      // g/mol [origin=calculated method=formula-sum]
Tc          822.62;      // K   [origin=predictive method=joback]
Pc          42.552;      // bar [origin=predictive method=joback]
omega       1.5645;      // -   [origin=predictive method=lee-kesler]
Tb          641.88;      // K   [origin=predictive method=joback]
HvapTb      76064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.634 0.6202 -0.0002944 2.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group CH2COO; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 1; } { group OH; count 2; } { group COO; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(oxidanyl)propyl 3-sulfanylpropanoate" "2,3-dihydroxypropyl 3-mercaptopropionate" "propanoic acid, 3-mercapto-, 2,3-dihydroxypropyl ester" "3-mercaptopropanoic acid, glyceryl monoester" "glyceryl 3-mercaptopropionate" );
standardThermochemistry
{
    dHf_298   -755710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-557420.0
}
