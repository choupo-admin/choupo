/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxyethanol  (C3H8O2, CAS 109-86-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxyethanol;
formula     C3H8O2;
CAS         109-86-4;
InChIKey    XNWFRZJHXBZDAG-UHFFFAOYSA-N;
MW          76.095;      // g/mol [origin=calculated method=formula-sum]
Tc          545.81;      // K   [origin=predictive method=joback]
Pc          48.834;      // bar [origin=predictive method=joback]
omega       0.6952;      // -   [origin=predictive method=lee-kesler]
Tb          382.84;      // K   [origin=predictive method=joback]
HvapTb      41361.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.952 0.25962 -5.88e-05 -2.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl cellosolve" "ethanol, 2-methoxy-" "ethylene glycol monomethyl ether" "methyl oxitol" "2-methoxy-1-ethanol" "monomethyl glycol" "dowanol em" "methoxyhydroxyethane" "poly-solv em" "1-hydroxy-2-methoxyethane" "3-oxa-1-butanol" "egme" );
standardThermochemistry
{
    dHf_298   -389700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     335.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-267440.0
}
