/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethynodiol diacetate  (C24H32O4, CAS 297-76-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethynodiolDiacetate;
formula     C24H32O4;
CAS         297-76-7;
InChIKey    ONKUMRGIYFNPJW-KIEAKMPYSA-N;
MW          384.516;      // g/mol [origin=calculated method=formula-sum]
Tc          1133.64;      // K   [origin=predictive method=joback]
Pc          13.647;      // bar [origin=predictive method=joback]
omega       0.8577;      // -   [origin=predictive method=lee-kesler]
Tb          894.20;      // K   [origin=predictive method=joback]
HvapTb      81927.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-240.99 3.02476 -0.00255657 9.1699e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 5; } { group C; count 2; } { group CH=C; count 1; } { group CH3COO; count 2; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,8r,9s,10r,13s,14s,17r)-17-acetyloxy-17-ethynyl-13-methyl-2,3,6,7,8,9,10,11,12,14,15,16-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] ethanoate" "continuin" "femulen" "metrodiol" "luto-metrodiol" "cervicundin" "ovulen" "metrodiol diacetate" "ethinodiol diacetate" "ovulen 50" "luteonorm" "metrulen" );
standardThermochemistry
{
    dHf_298   -605180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     869.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77750.0
}
