/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-aminoethanol; 2,2-dimethyloctanoic acid  (C12H27NO3, CAS 68298-99-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Aminoethanol22DimethyloctanoicAcid;
formula     C12H27NO3;
CAS         68298-99-7;
InChIKey    DZSYKIJJEKAQER-UHFFFAOYSA-N;
MW          233.352;      // g/mol [origin=calculated method=formula-sum]
Tc          976.35;      // K   [origin=predictive method=joback]
Pc          20.642;      // bar [origin=predictive method=joback]
omega       1.3600;      // -   [origin=predictive method=lee-kesler]
Tb          782.55;      // K   [origin=predictive method=joback]
HvapTb      85788.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.707 1.21016 -0.0005324 3.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group C; count 1; } { group OH; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group C; count 1; } { group OH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanylethanol;2,2-dimethyloctanoic acid" "2,2-dimethyloctanoic acid, compound with 2-aminoethanol (1:1)" "octanoic acid, 2,2-dimethyl-, compd. with 2-aminoethanol (1:1)" "2,2-dimethyloctanoic acid - 2-aminoethanol (1:1)" );
gibbsFormation
{
    dHf_298   -880090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     847.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-466040.0
    phase     gas;
}
