/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dimethylindan  (C11H14, CAS 4175-53-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dimethylindan;
formula     C11H14;
CAS         4175-53-5;
InChIKey    IIJUYSSJMAITHJ-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          704.67;      // K   [origin=predictive method=joback]
Pc          28.874;      // bar [origin=predictive method=joback]
omega       0.3733;      // -   [origin=predictive method=lee-kesler]
Tb          485.01;      // K   [origin=predictive method=joback]
HvapTb      42622.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.02 1.03484 -0.00070356 1.914e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dimethyl-2,3-dihydro-1h-indene" "1h-indene, 2,3-dihydro-1,3-dimethyl-" "indan, 1,3-dimethyl-" "indan,3-dimethyl-" "indan, 1,3-dimethyl- (8ci)" "1,3-dimethyl-(2,3-dihydroindene)" "1h-indene,3-dihydro-1,3-dimethyl-" "(1r,3s)-1,3-dimethyl-2,3-dihydro-1h-indene" "1h-indene, 2,3-dihydro-1,3-dimethyl- (9ci)" );
standardThermochemistry
{
    dHf_298   7150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     339.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197560.0
}
