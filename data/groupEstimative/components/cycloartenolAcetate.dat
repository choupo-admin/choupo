/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloartenol acetate  (C32H52O2, CAS 1259-10-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloartenolAcetate;
formula     C32H52O2;
CAS         1259-10-5;
InChIKey    PQNTWKDHNSWVPU-ZKVYRWFYSA-N;
MW          468.766;      // g/mol [origin=calculated method=formula-sum]
Tc          1262.61;      // K   [origin=predictive method=joback]
Pc          8.640;      // bar [origin=predictive method=joback]
omega       0.7473;      // -   [origin=predictive method=lee-kesler]
Tb          1022.61;      // K   [origin=predictive method=joback]
HvapTb      86973.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-509.118 5.09416 -0.0051149 2.1452e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 11; } { group CH; count 5; } { group C; count 5; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 4; } { group C_ring; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -578580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1220.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=186580.0
    phase     gas;
}
