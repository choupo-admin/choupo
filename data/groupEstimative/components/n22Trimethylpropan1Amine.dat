/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,2,2-trimethylpropan-1-amine  (C6H15N, CAS 26153-91-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n22Trimethylpropan1Amine;
formula     C6H15N;
CAS         26153-91-3;
InChIKey    UQGXHNDRCRTZAC-UHFFFAOYSA-N;
MW          101.193;      // g/mol [origin=calculated method=formula-sum]
Tc          565.13;      // K   [origin=predictive method=joback]
Pc          32.210;      // bar [origin=predictive method=joback]
omega       0.3569;      // -   [origin=predictive method=lee-kesler]
Tb          383.82;      // K   [origin=predictive method=joback]
HvapTb      34090.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.249 0.77588 -0.000523 1.426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propanamine, n,2,2-trimethyl-" "n,2,2-trimethyl-1-propanamine hydrochloride" "agn-pc-00k1lu" "(2,2-dimethylpropyl)(methyl)amine" "methyl-2,2-dimethylpropylamine" );
gibbsFormation
{
    dHf_298   -122450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91870.0
    phase     gas;
}
