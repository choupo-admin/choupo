/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxyphenyl methacrylate  (C10H10O3, CAS 31480-93-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HydroxyphenylMethacrylate;
formula     C10H10O3;
CAS         31480-93-0;
InChIKey    PJMXUSNWBKGQEZ-UHFFFAOYSA-N;
MW          178.187;      // g/mol [origin=calculated method=formula-sum]
Tc          820.65;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.7283;      // -   [origin=predictive method=lee-kesler]
Tb          590.48;      // K   [origin=predictive method=joback]
HvapTb      59961.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.3 0.95462 -0.00073836 2.285e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-hydroxyphenyl) 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 4-hydroxyphenyl ester" "p-hydroxyphenyl methacrylate" "4-hydroxyphenyl 2-methylprop-2-enoate" );
standardThermochemistry
{
    dHf_298   -392150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-239970.0
}
