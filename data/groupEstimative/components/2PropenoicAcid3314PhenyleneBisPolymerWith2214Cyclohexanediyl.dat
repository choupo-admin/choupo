/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 3,3'-(1,4-phenylene)bis-, polymer with 2,2'-(1,4-cyclohexanediylbis(oxy))bis(ethanol)  (C22H30O8, CAS 53710-66-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid3314PhenyleneBisPolymerWith2214Cyclohexanediyl;
formula     C22H30O8;
CAS         53710-66-0;
InChIKey    XDIOGRIJHMREOD-PUFOULASSA-N;
MW          422.474;      // g/mol [origin=calculated method=formula-sum]
Tc          1590.16;      // K   [origin=predictive method=joback]
Pc          16.026;      // bar [origin=predictive method=joback]
omega       1.1994;      // -   [origin=predictive method=lee-kesler]
Tb          1279.44;      // K   [origin=predictive method=joback]
HvapTb      140340.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.146 1.928 -0.00089956 7.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH=CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 2; } { group C2H5O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group O; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(2-hydroxyethyloxy)cyclohexyl]oxyethanol;(e)-3-[4-[(e)-3-oxidanyl-3-oxidanylidene-prop-1-enyl]phenyl]prop-2-enoic acid" "2-[4-(2-hydroxyethoxy)cyclohexyl]oxyethanol; (e)-3-[4-[(e)-3-hydroxy-3-oxoprop-1-enyl]phenyl]prop-2-enoic acid" );
gibbsFormation
{
    dHf_298   -1384990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1152.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-861900.0
    phase     gas;
}
