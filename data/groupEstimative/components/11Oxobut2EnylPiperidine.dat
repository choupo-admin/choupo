/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(1-oxobut-2-enyl)piperidine  (C9H15NO, CAS 3626-69-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Oxobut2EnylPiperidine;
formula     C9H15NO;
CAS         3626-69-5;
InChIKey    DEHSTVNSEJEWPR-UHFFFAOYSA-N;
MW          153.225;      // g/mol [origin=calculated method=formula-sum]
Tc          705.70;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.5264;      // -   [origin=predictive method=lee-kesler]
Tb          495.94;      // K   [origin=predictive method=joback]
HvapTb      44941.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.23 1.13292 -0.0008263 2.3936e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group CH2_ring; count 5; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-piperidin-1-ylbut-2-en-1-one" );
standardThermochemistry
{
    dHf_298   -76100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=131240.0
}
