/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-nonene, 9-chloro-  (C9H17Cl, CAS 872-06-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Nonene9Chloro;
formula     C9H17Cl;
CAS         872-06-0;
InChIKey    AJGQFZNQNJVFQX-UHFFFAOYSA-N;
MW          160.685;      // g/mol [origin=calculated method=formula-sum]
Tc          612.92;      // K   [origin=predictive method=joback]
Pc          23.181;      // bar [origin=predictive method=joback]
omega       0.4843;      // -   [origin=predictive method=lee-kesler]
Tb          439.63;      // K   [origin=predictive method=joback]
HvapTb      39343.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.607 0.8456 -0.0005091 1.223e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2=CH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-chloranylnon-1-ene" "9-chloronon-1-ene" "9-chloro-1-nonene" );
gibbsFormation
{
    dHf_298   -119400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100810.0
    phase     gas;
}
