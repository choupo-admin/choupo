/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-octadecanediol  (C18H38O2, CAS 20294-76-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Octadecanediol;
formula     C18H38O2;
CAS         20294-76-2;
InChIKey    XWAMHGPDZOVVND-UHFFFAOYSA-N;
MW          286.5;      // g/mol [origin=calculated method=formula-sum]
Tc          973.75;      // K   [origin=predictive method=joback]
Pc          13.185;      // bar [origin=predictive method=joback]
omega       1.2200;      // -   [origin=predictive method=lee-kesler]
Tb          795.36;      // K   [origin=predictive method=joback]
HvapTb      88632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.574 1.78772 -0.0010194 2.221e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group CH; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecane-1,2-diol" "1,2-dihydroxyoctadecane" "1,12-dihydroxyoctadecane" "o-hexadecylethanediol" "stearyl glycol" );
standardThermochemistry
{
    dHf_298   -724590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     949.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-175400.0
}
