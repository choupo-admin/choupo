/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethoxy-4-methylpentanal  (C8H16O2, CAS 68084-08-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethoxy4Methylpentanal;
formula     C8H16O2;
CAS         68084-08-2;
InChIKey    BJRVNLMGJUBQLM-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          631.01;      // K   [origin=predictive method=joback]
Pc          27.326;      // bar [origin=predictive method=joback]
omega       0.5664;      // -   [origin=predictive method=lee-kesler]
Tb          452.84;      // K   [origin=predictive method=joback]
HvapTb      41756.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.152 0.68696 -0.0002998 2.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group O; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethoxy-4-methyl-pentanal" "3-ethoxy-4-methylvaleraldehyde" "pentanal, 3-ethoxy-4-methyl-" );
gibbsFormation
{
    dHf_298   -436810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-192920.0
    phase     gas;
}
