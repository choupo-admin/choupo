/*--------------------------------*- Choupo -*-----------------------*\
  Component: citronellyl phenylacetate  (C18H26O2, CAS 139-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        citronellylPhenylacetate;
formula     C18H26O2;
CAS         139-70-8;
InChIKey    CVJBFMVLVJZZMM-UHFFFAOYSA-N;
MW          274.404;      // g/mol [origin=calculated method=formula-sum]
Tc          901.65;      // K   [origin=predictive method=joback]
Pc          15.439;      // bar [origin=predictive method=joback]
omega       0.8008;      // -   [origin=predictive method=lee-kesler]
Tb          699.94;      // K   [origin=predictive method=joback]
HvapTb      64995.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.525 1.60596 -0.0009813 2.201e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyloct-6-enyl 2-phenylethanoate" "citronellyl alpha-toluate" "benzeneacetic acid, 3,7-dimethyl-6-octenyl ester" "3,7-dimethyl-6-octen-1-yl phenylacetate" "3,7-dimethyl-6-octenyl phenylacetate" "3,7-dimethyl-6-octenyl benzeneacetate" "3,7-dimethyloct-6-en-1-yl phenylacetate" "benzeneacetic acid, 3,7-dimethyl-6-octen-1-yl ester" "3,7-dimethyloct-6-enyl 2-phenylacetate" "benzeneacetic acid,3,7-dimethyl-6-octen-1-yl ester" "aceticacid, phenyl-, 3,7-dimethyl-6-octenyl ester (8ci); benzeneacetic acid,3,7-dimethyl-6-octenyl ester (9ci); 6-octen-1-ol, 3,7-dimethyl-, phenylacetate;citronellyl phenylacetate; phenylacetic acid, 3,7-dimethyl-6-octenyl ester" );
standardThermochemistry
{
    dHf_298   -393450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     781.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28050.0
}
