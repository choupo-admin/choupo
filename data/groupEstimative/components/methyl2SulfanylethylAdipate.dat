/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-sulfanylethyl adipate  (C9H16O4S, CAS 70942-33-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2SulfanylethylAdipate;
formula     C9H16O4S;
CAS         70942-33-5;
InChIKey    KPTJEIGJHHBFJH-UHFFFAOYSA-N;
MW          220.283;      // g/mol [origin=calculated method=formula-sum]
Tc          778.28;      // K   [origin=predictive method=joback]
Pc          24.801;      // bar [origin=predictive method=joback]
omega       0.8313;      // -   [origin=predictive method=lee-kesler]
Tb          584.82;      // K   [origin=predictive method=joback]
HvapTb      57179.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.416 0.77652 -0.000299 -1.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2COO; count 2; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group COO; count 2; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-methyl o6-(2-sulfanylethyl) hexanedioate" "hexanedioic acid, 2-mercaptoethyl methyl ester" "hexanedioic acid 2-mercaptoethyl methyl ester" "hexanedioic acid, 1-(2-mercaptoethyl) 6-methyl ester" "methyl 2-sulfanylethyl hexanedioate" "2'-mercaptoethyl 5-carbomethoxypentanoate" "1-o-methyl 6-o-(2-sulfanylethyl) hexanedioate" );
gibbsFormation
{
    dHf_298   -825170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     671.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-566450.0
    phase     gas;
}
