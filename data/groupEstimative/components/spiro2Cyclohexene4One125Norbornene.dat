/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro-2-cyclohexene-4-one-1,2'-(5-norbornene)  (C12H14O, CAS 30834-51-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro2Cyclohexene4One125Norbornene;
formula     C12H14O;
CAS         30834-51-6;
InChIKey    ZANBBQSNIRIMCX-UHFFFAOYSA-N;
MW          174.243;      // g/mol [origin=calculated method=formula-sum]
Tc          828.37;      // K   [origin=predictive method=joback]
Pc          32.541;      // bar [origin=predictive method=joback]
omega       0.4508;      // -   [origin=predictive method=lee-kesler]
Tb          573.57;      // K   [origin=predictive method=joback]
HvapTb      46241.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-172.11 1.5793 -0.00141356 5.332e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro[bicyclo[2.2.1]hept-2-ene-5,4'-cyclohex-2-ene]-1'-one" "spiro[bicyclo[2.2.1]heptane-2,1'-cyclohexane]-2',5-dien-4'-one" );
gibbsFormation
{
    dHf_298   -97990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     328.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127950.0
    phase     gas;
}
