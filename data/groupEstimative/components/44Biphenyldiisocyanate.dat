/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-biphenyldiisocyanate  (C14H8N2O2, CAS 2761-22-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Biphenyldiisocyanate;
formula     C14H8N2O2;
CAS         2761-22-0;
InChIKey    RQBUVIFBALZGPC-UHFFFAOYSA-N;
MW          236.23;      // g/mol [origin=calculated method=formula-sum]
Tc          966.74;      // K   [origin=predictive method=joback]
Pc          31.491;      // bar [origin=predictive method=joback]
omega       0.8599;      // -   [origin=predictive method=lee-kesler]
Tb          716.58;      // K   [origin=predictive method=joback]
HvapTb      71698.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group dCd; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-4-(4-isocyanatophenyl)benzene" );
