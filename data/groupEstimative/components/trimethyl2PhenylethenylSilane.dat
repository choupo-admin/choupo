/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethyl(2-phenylethenyl)silane  (C11H16Si, CAS 19372-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethyl2PhenylethenylSilane;
formula     C11H16Si;
CAS         19372-00-0;
InChIKey    FIONWRDVKJFHRC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          176.334;      // g/mol [origin=calculated method=formula-sum]
Tc          702.94;      // K   [origin=predictive method=joback]
Pc          24.727;      // bar [origin=predictive method=joback]
omega       0.3076;      // -   [origin=predictive method=lee-kesler]
Tb          483.52;      // K   [origin=predictive method=joback]
HvapTb      42608.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.38 0.78376 -0.0002748 -2.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene,[(1e)-2-(trimethylsilyl)ethenyl]-" "silane,trimethyl(2-phenylethenyl)-, (e)-; silane, trimethyl[(1e)-2-phenylethenyl]-(9ci); silane, trimethylstyryl-, (e)- (8ci);(e)-1-phenyl-2-(trimethylsilyl)ethene; (e)-1-phenyl-2-(trimethylsilyl)ethylene;(e)-1-trimethylsilyl-2-phenylethene; (e)-[2-(trimethylsilyl)vinyl]benzene; (e)-b-(trimethylsilyl)styrene; (e)-b-styryltrimethylsilane;trans-1-phenyl-2-(trimethylsilyl)ethylene;trans-trimethyl(2-phenylvinyl)silane; trans-trimethylstyrylsilane; trans-b-(trimethylsilyl)styrene" );
gibbsFormation
{
    dHf_298   -28240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=129610.0
    phase     gas;
}
