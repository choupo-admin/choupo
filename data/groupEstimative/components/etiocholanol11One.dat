/*--------------------------------*- Choupo -*-----------------------*\
  Component: etiocholanol-11-one  (C19H28O3, CAS 739-27-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        etiocholanol11One;
formula     C19H28O3;
CAS         739-27-5;
InChIKey    IUNYGQONJQTULL-UKZLPJRTSA-N;
MW          304.43;      // g/mol [origin=calculated method=formula-sum]
Tc          1140.35;      // K   [origin=predictive method=joback]
Pc          19.859;      // bar [origin=predictive method=joback]
omega       1.1076;      // -   [origin=predictive method=lee-kesler]
Tb          896.92;      // K   [origin=predictive method=joback]
HvapTb      80344.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-244.97 2.56614 -0.0021 7.578e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 5; } { group C; count 2; } { group OH; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group OH; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,5r,8s,9s,10s,13s,14s)-10,13-dimethyl-3-oxidanyl-2,3,4,5,6,7,8,9,12,14,15,16-dodecahydro-1h-cyclopenta[a]phenanthrene-11,17-dione" "11-oxoetiocholanolone" "11-oxoaetiocholanolone" "11-ketoetiocholanolone" "3alpha-hydroxy-5beta-androstane-11,17-dione" "5beta-androstan-3alpha-ol-11,17-dione" "3" "a-hydroxy-11,17-dioxo-5" "a-androstane" "3alpha-hydroxy-11,17-dioxo-5beta-androstane" "5beta-androstane-11,17-dione, 3alpha-hydroxy- (8ci)" "androstane-11,17-dione, 3-hydroxy-, (3alpha,5beta)- (9ci)" "5" "a-androstan-3" "a-ol-11,17-dione" "5" "a-androstane-3" "a-ol-11,17-dione" );
gibbsFormation
{
    dHf_298   -633260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124510.0
    phase     gas;
}
