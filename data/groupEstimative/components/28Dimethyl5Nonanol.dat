/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,8-dimethyl-5-nonanol  (C11H24O, CAS 19780-96-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        28Dimethyl5Nonanol;
formula     C11H24O;
CAS         19780-96-2;
InChIKey    WXCCASRWBAGQGY-UHFFFAOYSA-N;
MW          172.312;      // g/mol [origin=calculated method=formula-sum]
Tc          708.51;      // K   [origin=predictive method=joback]
Pc          21.473;      // bar [origin=predictive method=joback]
omega       0.8944;      // -   [origin=predictive method=lee-kesler]
Tb          542.14;      // K   [origin=predictive method=joback]
HvapTb      55595.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.866 1.10058 -0.0006146 1.28e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,8-dimethylnonan-5-ol" "5-nonanol,2,8-dimethyl-" "5-nonanol, 2,8-dimethyl-" );
gibbsFormation
{
    dHf_298   -438440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     606.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-102400.0
    phase     gas;
}
