/*--------------------------------*- Choupo -*-----------------------*\
  Component: [4-(aminomethyl)-4-ethylcyclohexyl]methanamine; 1,2-dichloroethane  (C12H26Cl2N2, CAS 67924-08-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Aminomethyl4EthylcyclohexylMethanamine12Dichloroethane;
formula     C12H26Cl2N2;
CAS         67924-08-7;
InChIKey    QSVSQADINOTHEQ-UHFFFAOYSA-N;
MW          269.254;      // g/mol [origin=calculated method=formula-sum]
Tc          940.75;      // K   [origin=predictive method=joback]
Pc          20.642;      // bar [origin=predictive method=joback]
omega       0.7629;      // -   [origin=predictive method=lee-kesler]
Tb          710.60;      // K   [origin=predictive method=joback]
HvapTb      71621.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.095 1.46252 -0.0009 2.338e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group CH2NH2; count 2; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group Cl; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(aminomethyl)-4-ethyl-cyclohexyl]methanamine;1,2-bis(chloranyl)ethane" "1,4-cyclohexanebis(methylamine), 1-ethyl-, copolymer with 1,2-dichloroethane" );
standardThermochemistry
{
    dHf_298   -317310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     897.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65690.0
}
