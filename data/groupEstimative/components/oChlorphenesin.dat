/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-chlorphenesin  (C9H11ClO3, CAS 5112-21-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oChlorphenesin;
formula     C9H11ClO3;
CAS         5112-21-0;
InChIKey    UEDJPYLQEIVDLD-UHFFFAOYSA-N;
MW          202.634;      // g/mol [origin=calculated method=formula-sum]
Tc          872.82;      // K   [origin=predictive method=joback]
Pc          37.730;      // bar [origin=predictive method=joback]
omega       1.4775;      // -   [origin=predictive method=lee-kesler]
Tb          680.95;      // K   [origin=predictive method=joback]
HvapTb      78331.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.392 0.7379 -0.00040336 6.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 1; } { group ACCl; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-chloranylphenoxy)propane-1,2-diol" "3-(2-chlorophenoxy)propane-1,2-diol" "3-(o-chlorophenoxy)-1,2-propanediol" "1,2-propanediol, 3-(o-chlorophenoxy)-" "3-(2-chlorophenoxy)-1,2-propanediol" );
standardThermochemistry
{
    dHf_298   -461730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-265330.0
}
