/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholest-5-en-3-ol (3.beta.)-, 2-butenoate  (C31H50O2, CAS 24951-77-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholest5En3Ol3Beta2Butenoate;
formula     C31H50O2;
CAS         24951-77-7;
InChIKey    WAPKZPLWLMQRHV-UHFFFAOYSA-N;
MW          454.739;      // g/mol [origin=calculated method=formula-sum]
Tc          1241.62;      // K   [origin=predictive method=joback]
Pc          8.334;      // bar [origin=predictive method=joback]
omega       0.7525;      // -   [origin=predictive method=lee-kesler]
Tb          1009.30;      // K   [origin=predictive method=joback]
HvapTb      89426.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-304.087 3.87032 -0.00312624 1.0854e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 11; } { group CH; count 7; } { group C; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 2; } { group dCH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] but-2-enoate" "cholest-5-en-3-ol (3.beta.)-, 3-(2-butenoate)" );
gibbsFormation
{
    dHf_298   -617620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1096.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143830.0
    phase     gas;
}
