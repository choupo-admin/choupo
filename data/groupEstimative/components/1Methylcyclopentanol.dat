/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylcyclopentanol  (C6H12O, CAS 1462-03-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylcyclopentanol;
formula     C6H12O;
CAS         1462-03-9;
InChIKey    CAKWRXVKWGUISE-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          640.39;      // K   [origin=predictive method=joback]
Pc          45.839;      // bar [origin=predictive method=joback]
omega       0.6080;      // -   [origin=predictive method=lee-kesler]
Tb          444.58;      // K   [origin=predictive method=joback]
HvapTb      44735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.75 1.03142 -0.000993 4.075e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylcyclopentan-1-ol" "cyclopentanol, 1-methyl-" "1-hydroxy-1-methylcyclopentane" "1-methyl cyclopentanol" "cyclopentanol, methyl-" "1-methyl-cyclopentanol" "1-methyl-1-cyclopentanol" "1-methyl-cyclopentan-1-ol" "ghl.pd_mitscher_leg0.419" );
gibbsFormation
{
    dHf_298   -243680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-106120.0
    phase     gas;
}
