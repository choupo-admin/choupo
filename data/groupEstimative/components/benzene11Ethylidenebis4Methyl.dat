/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,1'-ethylidenebis[4-methyl-  (C16H18, CAS 530-45-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene11Ethylidenebis4Methyl;
formula     C16H18;
CAS         530-45-0;
InChIKey    IDONYCOFOUUWLB-UHFFFAOYSA-N;
MW          210.32;      // g/mol [origin=calculated method=formula-sum]
Tc          865.54;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.5384;      // -   [origin=predictive method=lee-kesler]
Tb          628.56;      // K   [origin=predictive method=joback]
HvapTb      56698.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.55 1.25296 -0.00077812 1.799e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 8; } { group AC; count 1; } { group ACCH3; count 2; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-[1-(4-methylphenyl)ethyl]benzene" "benzene, 1,1'-ethylidenebis(4-methyl-" "1,1-di-p-tolylethane" "benzene,1,1'-ethylidenebis[4-methyl-" "1-methyl-4-[1-(p-tolyl)-ethyl]-benzene" "ethane,1,1-di-p-tolyl- (6ci,7ci,8ci); 1,1-bis(4-methylphenyl)ethane;1,1-bis(p-tolyl)ethane; 1,1-di(4-methylphenyl)ethane; 1,1-di-p-tolylethane;4,4',a-trimethyldiphenylmethane; a,a-di-p-tolylethane" );
gibbsFormation
{
    dHf_298   71270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=286960.0
    phase     gas;
}
