/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-4-isopropylaniline  (C11H17N, CAS 4139-78-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyl4Isopropylaniline;
formula     C11H17N;
CAS         4139-78-0;
InChIKey    MJRUTYCVCLZWSR-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          700.08;      // K   [origin=predictive method=joback]
Pc          26.245;      // bar [origin=predictive method=joback]
omega       0.4640;      // -   [origin=predictive method=lee-kesler]
Tb          494.94;      // K   [origin=predictive method=joback]
HvapTb      44673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.09 1.04028 -0.00065456 1.572e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-4-propan-2-yl-aniline" "4-isopropyl-n,n-dimethylaniline" "n,n-dimethyl-4-propan-2-ylaniline" "benzenamine,n,n-dimethyl-4-(1-methylethyl)-" "cumidine,n,n-dimethyl- (7ci,8ci); 4-isopropyl-n,n-dimethylaniline;p-isopropyl-n,n-dimethylaniline" );
standardThermochemistry
{
    dHf_298   16940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252860.0
}
