/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1496802  (C20H22BrNO2, CAS 143-84-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1496802;
formula     C20H22BrNO2;
CAS         143-84-0;
InChIKey    HIDNFGJRJQKLLL-UHFFFAOYSA-N;
MW          388.305;      // g/mol [origin=calculated method=formula-sum]
Tc          1193.38;      // K   [origin=predictive method=joback]
Pc          23.680;      // bar [origin=predictive method=joback]
omega       1.3463;      // -   [origin=predictive method=lee-kesler]
Tb          947.26;      // K   [origin=predictive method=joback]
HvapTb      95530.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-157.909 2.1716 -0.0016215 4.6146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 1; } { group Br; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group Br; count 1; } { group OH; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-1-[4-[oxidanyl(diphenyl)methyl]piperidin-1-yl]ethanone" "4-piperidinemethanol, 1-bromoacetyl-alpha,alpha-diphenyl-" "ketone, bromomethyl 4-(diphenylhydroxymethyl)piperidino" "2-bromo-1-[4-[hydroxy(diphenyl)methyl]piperidin-1-yl]ethanone" "2-bromo-1-{4-[hydroxy(diphenyl)methyl]piperidin-1-yl}ethanone" );
gibbsFormation
{
    dHf_298   -102290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     777.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=241090.0
    phase     gas;
}
