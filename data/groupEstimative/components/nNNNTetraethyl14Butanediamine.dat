/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,n',n'-tetraethyl-1,4-butanediamine  (C12H28N2, CAS 69704-44-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNNNTetraethyl14Butanediamine;
formula     C12H28N2;
CAS         69704-44-5;
InChIKey    YXVIGUHBJDFXKZ-UHFFFAOYSA-N;
MW          200.37;      // g/mol [origin=calculated method=formula-sum]
Tc          657.78;      // K   [origin=predictive method=joback]
Pc          17.743;      // bar [origin=predictive method=joback]
omega       0.7045;      // -   [origin=predictive method=lee-kesler]
Tb          499.04;      // K   [origin=predictive method=joback]
HvapTb      46392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.402 1.39168 -0.0008542 2.064e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,n',n'-tetraethylbutane-1,4-diamine" "agn-pc-03nger" "1,4-butanediamine, n,n,n',n'-tetraethyl-" "n,n,n`,n`-tetraethyl-1,4-diaminobutane" );
gibbsFormation
{
    dHf_298   -155950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     655.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=271720.0
    phase     gas;
}
