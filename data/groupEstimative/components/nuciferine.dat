/*--------------------------------*- Choupo -*-----------------------*\
  Component: nuciferine  (C19H21NO2, CAS 475-83-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nuciferine;
formula     C19H21NO2;
CAS         475-83-2;
InChIKey    ORJVQPIHKOARKV-OAHLLOKOSA-N;
MW          295.382;      // g/mol [origin=calculated method=formula-sum]
Tc          1006.80;      // K   [origin=predictive method=joback]
Pc          19.788;      // bar [origin=predictive method=joback]
omega       0.9466;      // -   [origin=predictive method=lee-kesler]
Tb          779.47;      // K   [origin=predictive method=joback]
HvapTb      72404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.57 1.69856 -0.0012162 3.558e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 4; } { group ACCH2; count 2; } { group ACCH; count 1; } { group CH3O; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 7; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6ar)-1,2-dimethoxy-6-methyl-5,6,6a,7-tetrahydro-4h-dibenzo[de,g]quinoline" "nuciferin" "l-nuciferine" "sanjoinine e" "l-5,6-dimethoxyaporphine" "(-)-nucipherine" "(r)-1,2-dimethoxyaporphine" "1,2-dimethoxy-6abeta-aporphine" "6a-beta-aporphine, 1,2-dimethoxy-" "4h-dibenzo(de,g)quinoline, 5,6,6a,7-tetrahydro-1,2-dimethoxy-6-methyl-, (r)-" "4h-dibenzo(de,g)quinoline, 5,6,6a,7-tetrahydro-1,2-dimethoxy-6-methyl-, (r)- (9ci)" "4h-dibenzo[de,g]quinoline,5,6,6a,7-tetrahydro-1,2-dimethoxy-6-methyl-, (6ar)-" );
standardThermochemistry
{
    dHf_298   -38430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=339960.0
}
