/*--------------------------------*- Choupo -*-----------------------*\
  Component: lard glyceride  (C21H42O5, CAS 61789-10-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lardGlyceride;
formula     C21H42O5;
CAS         61789-10-4;
InChIKey    VWBHJJNWHBJGKS-UHFFFAOYSA-N;
MW          374.562;      // g/mol [origin=calculated method=formula-sum]
Tc          1279.54;      // K   [origin=predictive method=joback]
Pc          11.593;      // bar [origin=predictive method=joback]
omega       0.7775;      // -   [origin=predictive method=lee-kesler]
Tb          1013.96;      // K   [origin=predictive method=joback]
HvapTb      119008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.717 2.05782 -0.0011216 2.1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH; count 2; } { group OH; count 3; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group CH; count 2; } { group OH; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-tris(oxidanyl)propyl octadecanoate" "monoglycerides, lard" "glycerides, lard mono-" "1,2,3-trihydroxypropyl octadecanoate" );
gibbsFormation
{
    dHf_298   -1261300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1158.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-599770.0
    phase     gas;
}
