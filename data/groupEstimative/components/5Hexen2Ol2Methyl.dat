/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-hexen-2-ol, 2-methyl-  (C7H14O, CAS 16744-89-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Hexen2Ol2Methyl;
formula     C7H14O;
CAS         16744-89-1;
InChIKey    RVHXDRXNRJQLGG-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          618.79;      // K   [origin=predictive method=joback]
Pc          33.144;      // bar [origin=predictive method=joback]
omega       0.6782;      // -   [origin=predictive method=lee-kesler]
Tb          445.39;      // K   [origin=predictive method=joback]
HvapTb      45889.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.648 0.80864 -0.0005821 1.712e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylhex-5-en-2-ol" "2-methyl-5-hexen-2-ol" "2-methyl-5-hexene-2-ol" "1,1-dimethyl-4-penten-1-ol;2-methyl-5-hexen-2-ol; dimethyl(vinylethyl)carbinol" );
gibbsFormation
{
    dHf_298   -223360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-38080.0
    phase     gas;
}
