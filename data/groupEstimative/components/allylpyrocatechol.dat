/*--------------------------------*- Choupo -*-----------------------*\
  Component: allylpyrocatechol  (C9H10O2, CAS 1125-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylpyrocatechol;
formula     C9H10O2;
CAS         1125-74-2;
InChIKey    PARWTEYYJSDGQM-UHFFFAOYSA-N;
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          828.94;      // K   [origin=predictive method=joback]
Pc          50.228;      // bar [origin=predictive method=joback]
omega       0.8033;      // -   [origin=predictive method=lee-kesler]
Tb          590.12;      // K   [origin=predictive method=joback]
HvapTb      63262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.029 1.0691 -0.00103262 4.05e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-prop-2-enylbenzene-1,2-diol" "1,2-benzenediol, (2-propenyl)-" "3-(prop-2-en-1-yl)benzene-1,2-diol" );
gibbsFormation
{
    dHf_298   -221750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-84090.0
    phase     gas;
}
