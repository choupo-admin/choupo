/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-tolyl undec-10-enoate  (C18H26O2, CAS 67874-76-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pTolylUndec10Enoate;
formula     C18H26O2;
CAS         67874-76-4;
InChIKey    JBSXTRRQRUQNQG-UHFFFAOYSA-N;
MW          274.404;      // g/mol [origin=calculated method=formula-sum]
Tc          891.29;      // K   [origin=predictive method=joback]
Pc          14.988;      // bar [origin=predictive method=joback]
omega       0.8590;      // -   [origin=predictive method=lee-kesler]
Tb          698.00;      // K   [origin=predictive method=joback]
HvapTb      65337.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.662 1.50062 -0.00084786 1.639e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methylphenyl) undec-10-enoate" "10-undecenoic acid, 4-methylphenyl ester" "p-cresyl 10-undecylenate" );
standardThermochemistry
{
    dHf_298   -381640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     791.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19070.0
}
