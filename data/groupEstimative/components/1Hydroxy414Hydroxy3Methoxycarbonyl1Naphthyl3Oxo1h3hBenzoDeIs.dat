/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hydroxy-4-{1-[4-hydroxy-3-(methoxycarbonyl)-1-naphthyl]-3-oxo-1h,3h-benzo[de]isochromen-1-yl}-6-(octadecyloxy)-2-naphthoic acid  (C53H58O9, CAS 38122-80-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hydroxy414Hydroxy3Methoxycarbonyl1Naphthyl3Oxo1h3hBenzoDeIs;
formula     C53H58O9;
CAS         38122-80-4;
InChIKey    GQAKXAZXUYZQAI-UHFFFAOYSA-N;
MW          839.038;      // g/mol [origin=calculated method=formula-sum]
Tc          3295.71;      // K   [origin=predictive method=joback]
Pc          5.729;      // bar [origin=predictive method=joback]
omega       -0.4387;      // -   [origin=predictive method=lee-kesler]
Tb          2028.13;      // K   [origin=predictive method=joback]
HvapTb      208788.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-168.153 5.02374 -0.0040246 1.3473e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group C; count 1; } { group ACH; count 15; } { group AC; count 13; } { group ACOH; count 2; } { group CH2O; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group C_ring; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 15; } { group OH_phenol; count 2; } { group O; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-hydroxy-4-(1-(4-hydroxy-3-(methoxycarbonyl)-1-naphthalenyl)-3-oxo-1h,3h-naphtho(1,8-cd)pyran-1-yl)-6-(octadecyloxy)-2-naphthalenecarboxylic acid" "1-hydroxy-4-(1-(4-hydroxy-3-(methoxycarbonyl)-1-naphthyl)-3-oxo-1h,3h-naphtho(1,8-cd)pyran-1-yl)-6-(octadecyloxy)-2-naphthoic acid" "1-hydroxy-4-{1-[4-hydroxy-3-(methoxycarbonyl)naphthalen-1-yl]-3-oxo-1h,3h-benzo[de]isochromen-1-yl}-6-(octadecyloxy)naphthalene-2-carboxylic acid" "2-naphthalenecarboxylic acid, 1-hydroxy-4-(1-(4-hydroxy-3-(methoxycarbonyl)-1-naphthalenyl)-3-oxo-1h,3h-naphtho(1,8-cd)pyran-1-yl)-6-(octadecyloxy)-" );
standardThermochemistry
{
    dHf_298   -1306050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1690.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-314280.0
}
