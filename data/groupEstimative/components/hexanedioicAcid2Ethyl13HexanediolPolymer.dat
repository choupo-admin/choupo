/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid, 2-ethyl-1,3-hexanediol polymer  (C14H28O6, CAS 53351-10-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcid2Ethyl13HexanediolPolymer;
formula     C14H28O6;
CAS         53351-10-3;
InChIKey    WZDSCYYAQLVXCP-UHFFFAOYSA-N;
MW          292.372;      // g/mol [origin=calculated method=formula-sum]
Tc          1221.11;      // K   [origin=predictive method=joback]
Pc          19.372;      // bar [origin=predictive method=joback]
omega       1.5462;      // -   [origin=predictive method=lee-kesler]
Tb          995.82;      // K   [origin=predictive method=joback]
HvapTb      113962.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.398 1.30904 -0.0005354 1.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 2; } { group OH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 2; } { group OH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylhexane-1,3-diol;hexanedioic acid" "hexanedioic acid, polymer with 2-ethyl-1,3-hexanediol" "2-ethylhexane-1,3-diol; hexanedioic acid" );
gibbsFormation
{
    dHf_298   -1459470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     997.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1004100.0
    phase     gas;
}
