/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropylphenol  (C9H12O, CAS 99-89-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Isopropylphenol;
formula     C9H12O;
CAS         99-89-8;
InChIKey    YQUQWHNMBPIWGK-UHFFFAOYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          739.85;      // K   [origin=predictive method=joback]
Pc          39.357;      // bar [origin=predictive method=joback]
omega       0.5310;      // -   [origin=predictive method=lee-kesler]
Tb          512.38;      // K   [origin=predictive method=joback]
HvapTb      50530.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.8 0.94044 -0.00075656 2.54e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-propan-2-ylphenol" "p-cumenol" "p-isopropylphenol" "phenol, 4-(1-methylethyl)-" "phenol, p-isopropyl-" "australol" "1-hydroxy-4-isopropylbenzene" "4-hydroxycumene" "4-(1-methylethyl)phenol" "4-isopropyl phenol" "4-isopropyl-phenol" "para-isopropylphenol" );
gibbsFormation
{
    dHf_298   -175150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19750.0
    phase     gas;
}
