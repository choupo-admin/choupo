/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,10-dimethylenetricyclo(5.3.0.02,8)deca-3,5-diene  (C12H12, CAS 61278-86-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        910Dimethylenetricyclo530028Deca35Diene;
formula     C12H12;
CAS         61278-86-2;
InChIKey    DGOUBEVFJPOVFL-UHFFFAOYSA-N;
MW          156.228;      // g/mol [origin=calculated method=formula-sum]
Tc          706.42;      // K   [origin=predictive method=joback]
Pc          28.354;      // bar [origin=predictive method=joback]
omega       0.4081;      // -   [origin=predictive method=lee-kesler]
Tb          490.62;      // K   [origin=predictive method=joback]
HvapTb      42810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.79 1.2134 -0.00097756 3.216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 4; } { group CH=CH; count 2; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10-dimethylenetricyclo[5.3.0.02,8]deca-3,5-diene" );
standardThermochemistry
{
    dHf_298   184930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     203.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=378680.0
}
