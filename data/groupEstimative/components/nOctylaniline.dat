/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-octylaniline  (C14H23N, CAS 3007-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nOctylaniline;
formula     C14H23N;
CAS         3007-71-4;
InChIKey    GCULWAWIZUGXTO-UHFFFAOYSA-N;
MW          205.345;      // g/mol [origin=calculated method=formula-sum]
Tc          791.83;      // K   [origin=predictive method=joback]
Pc          20.327;      // bar [origin=predictive method=joback]
omega       0.7363;      // -   [origin=predictive method=lee-kesler]
Tb          596.77;      // K   [origin=predictive method=joback]
HvapTb      55470.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.953 1.33112 -0.0008176 1.914e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aniline, n-octyl-" "benzenamine, n-octyl-" "octylphenylamine" "phenyloctylamine" "octylamine, n-phenyl-" "1-octanamine, n-phenyl-" );
standardThermochemistry
{
    dHf_298   -42290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=268800.0
}
