/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo sec-butyl benzene  (C10H13Br, CAS 39220-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BromoSecButylBenzene;
formula     C10H13Br;
CAS         39220-69-4;
InChIKey    DGZQEAKNZXNTNL-UHFFFAOYSA-N;
MW          213.118;      // g/mol [origin=calculated method=formula-sum]
Tc          752.98;      // K   [origin=predictive method=joback]
Pc          31.385;      // bar [origin=predictive method=joback]
omega       0.4781;      // -   [origin=predictive method=lee-kesler]
Tb          525.78;      // K   [origin=predictive method=joback]
HvapTb      46839.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.299 0.85954 -0.00055896 1.42e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-butan-2-yl-benzene" "1-bromo-4-(1-methylpropyl)benzene" "benzene, 1-bromo-4-(1-methylpropyl)-" "agn-pc-00pgyv" "1-bromo-4-butan-2-ylbenzene" "1-bromo-4-(sec-butyl)benzene" "benzene,1-bromo-4-(1-methylpropyl)-" "benzene,1-bromo-4-sec-butyl- (5ci); 2-(4-bromophenyl)butane" );
gibbsFormation
{
    dHf_298   -3620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147980.0
    phase     gas;
}
