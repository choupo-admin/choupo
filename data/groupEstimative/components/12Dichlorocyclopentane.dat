/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dichlorocyclopentane  (C5H8Cl2, CAS 14376-81-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dichlorocyclopentane;
formula     C5H8Cl2;
CAS         14376-81-9;
InChIKey    QPIRTTQWLDPXBN-UHFFFAOYSA-N;
MW          139.019;      // g/mol [origin=calculated method=formula-sum]
Tc          613.55;      // K   [origin=predictive method=joback]
Pc          37.870;      // bar [origin=predictive method=joback]
omega       0.2478;      // -   [origin=predictive method=lee-kesler]
Tb          399.47;      // K   [origin=predictive method=joback]
HvapTb      35442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.42 0.5976 -0.000361 7.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CHCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)cyclopentane" "trans-1,2-dichlorocyclopentane" "cyclopentane, 1,2-dichloro-" "cyclopentane, 1,2-dichloro-, trans-" "1,2-dichloro-cyclopentane" "cyclopentane,2-dichloro-, trans-" "cyclopentane, 1,2-dichloro-, cis-" );
gibbsFormation
{
    dHf_298   -137870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     324.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3800.0
    phase     gas;
}
