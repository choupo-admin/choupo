/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-diaminotoluene  (C7H10N2, CAS 823-40-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Diaminotoluene;
formula     C7H10N2;
CAS         823-40-5;
InChIKey    RLYCRLGLCUXUPO-UHFFFAOYSA-N;
MW          122.171;      // g/mol [origin=calculated method=formula-sum]
Tc          781.68;      // K   [origin=predictive method=joback]
Pc          45.964;      // bar [origin=predictive method=joback]
omega       0.5967;      // -   [origin=predictive method=lee-kesler]
Tb          541.46;      // K   [origin=predictive method=joback]
HvapTb      56058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.2 0.59472 -0.00034092 6.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 1; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbenzene-1,3-diamine" "2,6-toluenediamine" "1,3-benzenediamine, 2-methyl-" "toluene-2,6-diamine" "2,6-tolylenediamine" "2,6-toluylenediamine" "2-methyl-m-phenylenediamine" "o-toluene diamine" "2,6-diamino-1-methylbenzene" "2-methyl-1,3-benzenediamine" "2-methyl-1,3-phenylenediamine" "2,6-diamino toluene" );
gibbsFormation
{
    dHf_298   93360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=234110.0
    phase     gas;
}
