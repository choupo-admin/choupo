/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-threoninol  (C4H11NO2, CAS 44520-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dThreoninol;
formula     C4H11NO2;
CAS         44520-55-0;
InChIKey    MUVQIIBPDFTEKM-IMJSIDKUSA-N;
MW          105.137;      // g/mol [origin=calculated method=formula-sum]
Tc          722.60;      // K   [origin=predictive method=joback]
Pc          55.278;      // bar [origin=predictive method=joback]
omega       1.3835;      // -   [origin=predictive method=lee-kesler]
Tb          547.13;      // K   [origin=predictive method=joback]
HvapTb      67721.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.961 0.52552 -0.0003044 6.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 2; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group OH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,3s)-2-azanylbutane-1,3-diol" "h-d-thr-ol" "d(-)-threoninol" "1,3-butanediol,2-amino-, (2s,3s)-" "1,3-butanediol,2-amino-, [s-(r*,r*)]-;(2s,3s)-2-aminobutane-1,3-diol;1,3-butanediol, 2-amino-, (2s,3s)-;" );
standardThermochemistry
{
    dHf_298   -407120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-229270.0
}
