/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(trimethylsilyl)propyne  (C9H20Si2, CAS 21752-80-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H20Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13BisTrimethylsilylPropyne;
formula     C9H20Si2;
CAS         21752-80-7;
InChIKey    DUPUXONPNLEQPD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          184.429;      // g/mol [origin=calculated method=formula-sum]
Tc          617.17;      // K   [origin=predictive method=joback]
Pc          21.394;      // bar [origin=predictive method=joback]
omega       0.1827;      // -   [origin=predictive method=lee-kesler]
Tb          417.32;      // K   [origin=predictive method=joback]
HvapTb      38368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (93.901 0.29672 0.00045594 -3.5952e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group C_C; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(3-trimethylsilylprop-1-ynyl)silane" "silane, 1-propyne-1,3-diylbis[trimethyl-" "agn-pc-0cxfhv" "prop-1-yne-1,3-diylbis(trimethylsilane)" "trimethyl-(3-trimethylsilylprop-2-ynyl)silane" );
standardThermochemistry
{
    dHf_298   -180030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     731.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18180.0
}
