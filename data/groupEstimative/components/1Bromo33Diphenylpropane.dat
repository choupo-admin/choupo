/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-3,3-diphenylpropane  (C15H15Br, CAS 20017-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo33Diphenylpropane;
formula     C15H15Br;
CAS         20017-68-9;
InChIKey    SLHSRCBFPHCSGL-UHFFFAOYSA-N;
MW          275.189;      // g/mol [origin=calculated method=formula-sum]
Tc          914.01;      // K   [origin=predictive method=joback]
Pc          27.155;      // bar [origin=predictive method=joback]
omega       0.6184;      // -   [origin=predictive method=lee-kesler]
Tb          661.88;      // K   [origin=predictive method=joback]
HvapTb      59583.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.048 1.3151 -0.0009292 2.519e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-bromanyl-1-phenyl-propyl)benzene" "3,3-diphenylpropyl bromide" "3-bromo-1,1-diphenylpropane" "(3-bromo-1-phenylpropyl)benzene" "benzene, 1,1'-(3-bromopropylidene)bis-" "(3-bromopropane-1,1-diyl)dibenzene" "1,1'-(3-bromopropylidene)bisbenzene" "benzene,1,1'-(3-bromopropylidene)bis-" "1,1'-(3-bromopropane-1,1-diyl)dibenzene" );
standardThermochemistry
{
    dHf_298   141180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=312120.0
}
