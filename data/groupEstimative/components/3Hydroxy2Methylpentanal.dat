/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxy-2-methylpentanal  (C6H12O2, CAS 615-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hydroxy2Methylpentanal;
formula     C6H12O2;
CAS         615-30-5;
InChIKey    YWUGUGHGGWKGEG-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          651.10;      // K   [origin=predictive method=joback]
Pc          38.483;      // bar [origin=predictive method=joback]
omega       0.8751;      // -   [origin=predictive method=lee-kesler]
Tb          476.84;      // K   [origin=predictive method=joback]
HvapTb      51573.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.761 0.59414 -0.0003324 6.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group OH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group OH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-3-oxidanyl-pentanal" "pentanal, 3-hydroxy-2-methyl-" "agn-pc-00hm8r" "pentanal,3-hydroxy-2-methyl-" );
standardThermochemistry
{
    dHf_298   -415540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-241580.0
}
