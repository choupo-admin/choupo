/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexyl-2-methyl-2-propanol  (C10H20O, CAS 5531-30-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexyl2Methyl2Propanol;
formula     C10H20O;
CAS         5531-30-6;
InChIKey    XRIXVTPYOOVPIX-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          734.16;      // K   [origin=predictive method=joback]
Pc          28.843;      // bar [origin=predictive method=joback]
omega       0.7139;      // -   [origin=predictive method=lee-kesler]
Tb          536.90;      // K   [origin=predictive method=joback]
HvapTb      53666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.989 1.23574 -0.0008034 1.991e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexyl-2-methyl-propan-2-ol" "1-cyclohexyl-2-methylpropan-2-ol" );
standardThermochemistry
{
    dHf_298   -356390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76210.0
}
