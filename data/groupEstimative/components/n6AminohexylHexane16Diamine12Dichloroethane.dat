/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(6-aminohexyl)hexane-1,6-diamine; 1,2-dichloroethane  (C14H33Cl2N3, CAS 67924-07-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n6AminohexylHexane16Diamine12Dichloroethane;
formula     C14H33Cl2N3;
CAS         67924-07-6;
InChIKey    JSCQUJVRUMNPEQ-UHFFFAOYSA-N;
MW          314.339;      // g/mol [origin=calculated method=formula-sum]
Tc          985.94;      // K   [origin=predictive method=joback]
Pc          14.827;      // bar [origin=predictive method=joback]
omega       1.1067;      // -   [origin=predictive method=lee-kesler]
Tb          791.41;      // K   [origin=predictive method=joback]
HvapTb      83540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.534 1.3412 -0.0004992 -1.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH2NH2; count 2; } { group CH2NH; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 14; } { group Cl; count 2; } { group NH2; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-(6-azanylhexyl)hexane-1,6-diamine;1,2-bis(chloranyl)ethane" "bishexamethylenetriamine, ethylene dichloride copolymer" "1,6-hexanediamine, n-(6-aminohexyl)-, polymer with 1,2-dichloroethane" "1,6-hexanediamine, n1-(6-aminohexyl)-, polymer with 1,2-dichloroethane" "n'-(6-aminohexyl)hexane-1,6-diamine; 1,2-dichloroethane" );
standardThermochemistry
{
    dHf_298   -354340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1019.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160670.0
}
