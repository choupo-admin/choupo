/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid, polymer with 1,3-butanediol, hexadecanoate tetradecanoate  (C40H76O8, CAS 69029-26-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcidPolymerWith13ButanediolHexadecanoateTetradeca;
formula     C40H76O8;
CAS         69029-26-1;
InChIKey    HBJNKAPBIZSBAK-UHFFFAOYSA-N;
MW          685.04;      // g/mol [origin=calculated method=formula-sum]
Tc          2428.48;      // K   [origin=predictive method=joback]
Pc          4.081;      // bar [origin=predictive method=joback]
omega       -0.5185;      // -   [origin=predictive method=lee-kesler]
Tb          1523.22;      // K   [origin=predictive method=joback]
HvapTb      153682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (65.682 3.59556 -0.0016966 1.889e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 30; } { group CH; count 1; } { group CH2COO; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 32; } { group CH; count 1; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanedioic acid;3-tetradecanoyloxybutyl hexadecanoate" );
standardThermochemistry
{
    dHf_298   -2320930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     2021.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1129840.0
}
