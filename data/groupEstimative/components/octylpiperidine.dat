/*--------------------------------*- Choupo -*-----------------------*\
  Component: octylpiperidine  (C13H27N, CAS 7335-02-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octylpiperidine;
formula     C13H27N;
CAS         7335-02-6;
InChIKey    OQJRUUUFRQCENE-UHFFFAOYSA-N;
MW          197.366;      // g/mol [origin=calculated method=formula-sum]
Tc          711.28;      // K   [origin=predictive method=joback]
Pc          19.666;      // bar [origin=predictive method=joback]
omega       0.6273;      // -   [origin=predictive method=lee-kesler]
Tb          529.43;      // K   [origin=predictive method=joback]
HvapTb      47141.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.043 1.52092 -0.0009788 2.486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH2_ring; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-octylpiperidine" "1-octyl-piperidine" "piperidine, 1-octyl-" );
standardThermochemistry
{
    dHf_298   -163300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     670.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213620.0
}
