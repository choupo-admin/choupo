/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclotetrasiloxane, 2,2,4,4,6,6,8,8-octamethyl-, polymer with 1,3-diethenyl-1,1,3,3-tetramethyldisiloxane  (C16H42O5Si6, CAS 60162-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H42O5Si6 (delta Si+6; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        cyclotetrasiloxane22446688OctamethylPolymerWith13Diethenyl11;
formula     C16H42O5Si6;
CAS         60162-06-3;
InChIKey    OMHXNOYYZVLVEU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          483.017;      // g/mol [origin=calculated method=formula-sum]
Tc          924.43;      // K   [origin=predictive method=joback]
Pc          8.948;      // bar [origin=predictive method=joback]
omega       0.3975;      // -   [origin=predictive method=lee-kesler]
Tb          714.74;      // K   [origin=predictive method=joback]
HvapTb      72772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (301.57 0.13324 0.0019486 -1.2984e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group CH2=CH; count 2; } { group Si; count 1; } { group SiO; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group dCH2; count 2; } { group dCH; count 2; } { group O; count 1; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl-[ethenyl(dimethyl)silyl]oxy-dimethyl-silane;2,2,4,4,6,6,8,8-octamethyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" "ethenyl-[ethenyl(dimethyl)silyl]oxy-dimethylsilane; 2,2,4,4,6,6,8,8-octamethyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" );
standardThermochemistry
{
    dHf_298   -1477290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1414.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-866920.0
}
