/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(3-phenoxy-2-hydroxypropyl)aniline  (C24H27NO4, CAS 3088-05-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis3Phenoxy2HydroxypropylAniline;
formula     C24H27NO4;
CAS         3088-05-9;
InChIKey    PGJOBAKEAXXLSG-UHFFFAOYSA-N;
MW          393.483;      // g/mol [origin=calculated method=formula-sum]
Tc          1309.54;      // K   [origin=predictive method=joback]
Pc          17.879;      // bar [origin=predictive method=joback]
omega       1.4956;      // -   [origin=predictive method=lee-kesler]
Tb          1069.52;      // K   [origin=predictive method=joback]
HvapTb      115291.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.116 2.1244 -0.0013332 2.973e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 15; } { group AC; count 3; } { group CH2N; count 1; } { group C2H4O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 2; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group OH; count 2; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(2-oxidanyl-3-phenoxy-propyl)-phenyl-amino]-3-phenoxy-propan-2-ol" "benzenamine, n,n-bis(2-hydroxy-3-phenoxypropyl)-" "1-(n-(2-hydroxy-3-phenoxypropyl)anilino)-3-phenoxypropan-2-ol" "1-[(2-hydroxy-3-phenoxy-propyl)-phenyl-amino]-3-phenoxy-propan-2-ol" );
gibbsFormation
{
    dHf_298   -341030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     892.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110690.0
    phase     gas;
}
