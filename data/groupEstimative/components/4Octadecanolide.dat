/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-octadecanolide  (C18H34O2, CAS 502-26-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Octadecanolide;
formula     C18H34O2;
CAS         502-26-1;
InChIKey    GYDWWIHJZSCRGV-UHFFFAOYSA-N;
MW          282.468;      // g/mol [origin=calculated method=formula-sum]
Tc          849.18;      // K   [origin=predictive method=joback]
Pc          12.655;      // bar [origin=predictive method=joback]
omega       0.8956;      // -   [origin=predictive method=lee-kesler]
Tb          676.40;      // K   [origin=predictive method=joback]
HvapTb      62982.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.307 1.80992 -0.001081 2.452e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-tetradecyloxolan-2-one" ".gamma.-stearolactone" "4-octadecalactone" "gamma-stearolactone" "2(3h)-furanone, dihydro-5-tetradecyl-" "gamma-octadecalactone" "dihydro-5-tetradecyl-2(3h)-furanone" "octadecanoic acid, 4-hydroxy-, gamma-lactone" "octadecanoic acid, .gamma.-lactone" "octadecanoic acid, 4-hydroxy-, gamma-lactone (7ci)" );
gibbsFormation
{
    dHf_298   -659330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     818.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-148940.0
    phase     gas;
}
