/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4,5-trimethoxybenzyl chloride  (C10H13ClO3, CAS 3840-30-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        345TrimethoxybenzylChloride;
formula     C10H13ClO3;
CAS         3840-30-0;
InChIKey    XXRUQNNAKXZSOS-UHFFFAOYSA-N;
MW          216.661;      // g/mol [origin=calculated method=formula-sum]
Tc          782.40;      // K   [origin=predictive method=joback]
Pc          25.508;      // bar [origin=predictive method=joback]
omega       0.6794;      // -   [origin=predictive method=lee-kesler]
Tb          574.71;      // K   [origin=predictive method=joback]
HvapTb      53731.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (92.181 0.51366 -3.768e-05 -9.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 3; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(chloromethyl)-1,2,3-trimethoxy-benzene" "5-(chloromethyl)-1,2,3-trimethoxybenzene" "benzene, 5-(chloromethyl)-1,2,3-trimethoxy-" "5-(chloromethyl)pyrogallol trimethyl ether" "3,4,5-trimethoxybenzylchloride" "1-(chloromethyl)-2,4,5-trimethoxybenzene" "benzene,5-(chloromethyl)-1,2,3-trimethoxy-" );
standardThermochemistry
{
    dHf_298   -460010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-210090.0
}
