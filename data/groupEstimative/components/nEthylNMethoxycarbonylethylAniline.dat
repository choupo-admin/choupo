/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-ethyl-n-methoxycarbonylethyl aniline  (C12H17NO2, CAS 21608-06-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nEthylNMethoxycarbonylethylAniline;
formula     C12H17NO2;
CAS         21608-06-0;
InChIKey    AGKYCLGMYBHGSV-UHFFFAOYSA-N;
MW          207.273;      // g/mol [origin=calculated method=formula-sum]
Tc          772.39;      // K   [origin=predictive method=joback]
Pc          24.124;      // bar [origin=predictive method=joback]
omega       0.6996;      // -   [origin=predictive method=lee-kesler]
Tb          571.50;      // K   [origin=predictive method=joback]
HvapTb      54032.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.207 1.13404 -0.0006782 1.374e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-[ethyl(phenyl)amino]propanoate" "methyl n-ethyl-n-phenyl-beta-alaninate" "beta-alanine, n-ethyl-n-phenyl-, methyl ester" "methyl 3-(n-ethylanilino)propanoate" "n-ethyl-n-methoxy carbonyl ethyl aniline" ".beta.-alanine, n-ethyl-n-phenyl-, methyl ester" );
gibbsFormation
{
    dHf_298   -304230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-37020.0
    phase     gas;
}
