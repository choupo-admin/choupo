/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenylpentanoic acid  (C11H14O2, CAS 16433-43-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4PhenylpentanoicAcid;
formula     C11H14O2;
CAS         16433-43-5;
InChIKey    UIIMQLPOAXFKFW-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          843.62;      // K   [origin=predictive method=joback]
Pc          29.345;      // bar [origin=predictive method=joback]
omega       0.7932;      // -   [origin=predictive method=lee-kesler]
Tb          623.03;      // K   [origin=predictive method=joback]
HvapTb      59132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.098 1.02662 -0.0006816 1.727e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenylvaleric acid" "valeric acid, 4-phenyl-" "pentanoic acid, 4-phenyl-" "gamma-methylbenzenebutanoic acid" "4-phenyl-pentanoic acid" "benzenebutanoic acid, gamma-methyl-" "benzenebutanoic acid, .gamma.-methyl-" "benzenebutanoic acid, gamma-methyl- (9ci)" );
gibbsFormation
{
    dHf_298   -389390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-192200.0
    phase     gas;
}
