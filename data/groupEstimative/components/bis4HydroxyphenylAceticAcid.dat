/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(4-hydroxyphenyl)acetic acid  (C14H12O4, CAS 40232-93-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis4HydroxyphenylAceticAcid;
formula     C14H12O4;
CAS         40232-93-7;
InChIKey    SCBGJZIOPNAEMH-UHFFFAOYSA-N;
MW          244.246;      // g/mol [origin=calculated method=formula-sum]
Tc          1142.23;      // K   [origin=predictive method=joback]
Pc          44.150;      // bar [origin=predictive method=joback]
omega       1.4292;      // -   [origin=predictive method=lee-kesler]
Tb          879.59;      // K   [origin=predictive method=joback]
HvapTb      94114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.57 1.5419 -0.00138872 5.001e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 1; } { group ACOH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(4-hydroxyphenyl)ethanoic acid" "2,2-bis(4-hydroxyphenyl)acetic acid" "benzeneacetic acid,4-hydroxy-a-(4-hydroxyphenyl)-" "benzeneacetic acid, 4-hydroxy-alpha-(4-hydroxyphenyl)-" "benzeneacetic acid, 4-hydroxy-.alpha.-(4-hydroxyphenyl)-" "aceticacid, bis(p-hydroxyphenyl)- (6ci,7ci); 2,2-bis(p-hydroxyphenyl)acetic acid;bis(4-hydroxyphenyl)acetic acid" );
gibbsFormation
{
    dHf_298   -569400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-363770.0
    phase     gas;
}
