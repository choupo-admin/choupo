/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,8-methanocyclobuta(b)naphthalene, 2a,3,8,8a-tetrahydro-,(2aalpha,3alpha,8alpha,8aalpha)-  (C13H12, CAS 54443-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        38MethanocyclobutaBNaphthalene2a388aTetrahydro2aalpha3alpha8;
formula     C13H12;
CAS         54443-68-4;
InChIKey    FLKOIGZBVYAFSE-UHFFFAOYSA-N;
MW          168.239;      // g/mol [origin=calculated method=formula-sum]
Tc          767.21;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.4595;      // -   [origin=predictive method=lee-kesler]
Tb          534.87;      // K   [origin=predictive method=joback]
HvapTb      46848.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-155.3 1.4898 -0.00133284 4.778e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group CH=CH; count 1; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,8-methanocyclobuta[b]naphthalene,2a,3,8,8a-tetrahydro-((2a.alpha.,3.beta.,8.beta.,8a.alpha.)-" "3,8-methanocyclobuta[b]naphthalene,2a,3,8,8a-tetrahydro-(2a.alpha.,3.alpha.,8.alpha.,8a.alpha.)-" );
standardThermochemistry
{
    dHf_298   181570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     159.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=390060.0
}
