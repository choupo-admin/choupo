/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipentene, beta-phellandrene copolymer  (C20H32, CAS 68240-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipenteneBetaPhellandreneCopolymer;
formula     C20H32;
CAS         68240-10-8;
InChIKey    WSABNSICFIWGEB-UHFFFAOYSA-N;
MW          272.476;      // g/mol [origin=calculated method=formula-sum]
Tc          921.74;      // K   [origin=predictive method=joback]
Pc          13.871;      // bar [origin=predictive method=joback]
omega       0.5233;      // -   [origin=predictive method=lee-kesler]
Tb          696.28;      // K   [origin=predictive method=joback]
HvapTb      61693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.9 1.63868 -0.00065492 1.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 3; } { group CH=CH; count 1; } { group CH2=C; count 2; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH2; count 2; } { group dC; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylidene-6-propan-2-yl-cyclohexene;1-methyl-4-prop-1-en-2-yl-cyclohexene" "cyclohexene, 3-methylene-6-(1-methylethyl)-, polymer with 1-methyl-4-(1-methylethenyl)cyclohexene" "3-methylidene-6-propan-2-ylcyclohexene; 1-methyl-4-prop-1-en-2-ylcyclohexene" );
standardThermochemistry
{
    dHf_298   -160420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     856.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=241880.0
}
