/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dichlorotoluene  (C7H6Cl2, CAS 19398-61-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dichlorotoluene;
formula     C7H6Cl2;
CAS         19398-61-9;
InChIKey    KFAKZJUYBOYVKA-UHFFFAOYSA-N;
MW          161.025;      // g/mol [origin=calculated method=formula-sum]
Tc          700.78;      // K   [origin=predictive method=joback]
Pc          36.159;      // bar [origin=predictive method=joback]
omega       0.3580;      // -   [origin=predictive method=lee-kesler]
Tb          471.26;      // K   [origin=predictive method=joback]
HvapTb      43546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.0 0.48452 -0.00029492 6.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(chloranyl)-2-methyl-benzene" "1,4-dichloro-2-methylbenzene" "benzene, 1,4-dichloro-2-methyl-" "toluene, 2,5-dichloro-" "toluene,5-dichloro-" "benzene,4-dichloro-2-methyl-" "kfakzjuyboyvka-uhfffaoysa-" "2,5-dct" "toluene, 2,5-dichloro- (8ci)" "1,4-dichloro-2-methyl-benzene" );
standardThermochemistry
{
    dHf_298   -5700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77350.0
}
