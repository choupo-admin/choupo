/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalene-d8  (C10D8, CAS 1146-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10D8 (delta D+8H-8; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        naphthaleneD8;
formula     C10D8;
CAS         1146-65-2;
InChIKey    UFWIBTONFRDIAS-PGRXLJNUSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          136.222;      // g/mol [origin=calculated method=formula-sum]
Tc          711.77;      // K   [origin=predictive method=joback]
Pc          38.965;      // bar [origin=predictive method=joback]
omega       0.3449;      // -   [origin=predictive method=lee-kesler]
Tb          474.06;      // K   [origin=predictive method=joback]
HvapTb      41770.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.55 0.8712 -0.00068812 2.144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5,6,7,8-octadeuterionaphthalene" "(2h8)naphthalene" "perdeuteronaphthalene" "perdeuterated naphthalene" "de865" "naphthalene-d8 >98.0 atom % d" );
standardThermochemistry
{
    dHf_298   177870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252380.0
}
