/*--------------------------------*- Choupo -*-----------------------*\
  Component: terphenyl, hydrogenated  (C18H22, CAS 61788-32-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        terphenylHydrogenated;
formula     C18H22;
CAS         61788-32-7;
InChIKey    TVBYFUMVFJKKNJ-UHFFFAOYSA-N;
MW          238.374;      // g/mol [origin=calculated method=formula-sum]
Tc          939.36;      // K   [origin=predictive method=joback]
Pc          21.674;      // bar [origin=predictive method=joback]
omega       0.5081;      // -   [origin=predictive method=lee-kesler]
Tb          680.52;      // K   [origin=predictive method=joback]
HvapTb      60042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-148.73 1.7076 -0.00105612 2.312e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH=CH; count 2; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohex-2-en-1-yl-4-cyclohex-3-en-1-yl-benzene" "agn-pc-03vcdy" "1-cyclohex-2-en-1-yl-4-cyclohex-3-en-1-ylbenzene" );
gibbsFormation
{
    dHf_298   34410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=312280.0
    phase     gas;
}
