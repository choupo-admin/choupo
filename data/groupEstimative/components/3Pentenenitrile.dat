/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pentenenitrile  (C5H7N, CAS 4635-87-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Pentenenitrile;
formula     C5H7N;
CAS         4635-87-4;
InChIKey    UVKXJAUUKPDDNW-UHFFFAOYSA-N;
MW          81.118;      // g/mol [origin=calculated method=formula-sum]
Tc          620.87;      // K   [origin=predictive method=joback]
Pc          35.814;      // bar [origin=predictive method=joback]
omega       0.3826;      // -   [origin=predictive method=lee-kesler]
Tb          420.24;      // K   [origin=predictive method=joback]
HvapTb      37160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.161 0.43362 -0.000301 8.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-3-enenitrile" "3-pentenenitrile, (3z)-" "3-pentenenitrile, (3e)-" "1-cyano-2-butene;3-pentenonitrile;crotyl cyanide;" );
gibbsFormation
{
    dHf_298   135570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=204620.0
    phase     gas;
}
