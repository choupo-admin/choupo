/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-butoxyethyl) azelaate  (C21H40O6, CAS 63021-23-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2ButoxyethylAzelaate;
formula     C21H40O6;
CAS         63021-23-8;
InChIKey    LOOYQSKMLPFZQX-UHFFFAOYSA-N;
MW          388.545;      // g/mol [origin=calculated method=formula-sum]
Tc          1030.07;      // K   [origin=predictive method=joback]
Pc          9.421;      // bar [origin=predictive method=joback]
omega       0.9139;      // -   [origin=predictive method=lee-kesler]
Tb          841.36;      // K   [origin=predictive method=joback]
HvapTb      81974.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (85.617 1.76284 -0.0007074 1.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH2COO; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-butoxyethyl) nonanedioate" "nonanedioic acid, bis(2-butoxyethyl) ester" "nonanedioic acid, 1,9-bis(2-butoxyethyl) ester" "di(butoxyethyl) azelate" "bis(2-butoxyethyl) azelate" "nonanedioic acid bis(2-butoxyethyl) ester" );
gibbsFormation
{
    dHf_298   -1375770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1099.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-704800.0
    phase     gas;
}
