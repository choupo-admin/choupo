/*--------------------------------*- Choupo -*-----------------------*\
  Component: biisopropenyl  (C6H10, CAS 513-81-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        biisopropenyl;
formula     C6H10;
CAS         513-81-5;
InChIKey    SDJHPPZKZZWAKF-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          507.62;      // K   [origin=predictive method=joback]
Pc          34.602;      // bar [origin=predictive method=joback]
omega       0.2128;      // -   [origin=predictive method=lee-kesler]
Tb          330.00;      // K   [origin=predictive method=joback]
HvapTb      27770.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.93 0.53364 -0.000353 9.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethylbuta-1,3-diene" "2,3-dimethyl-1,3-butadiene" "1,3-butadiene, 2,3-dimethyl-" "diisopropenyl" "2,3-dimethylbutadiene" "2,3-dimethylenebutane" "2,3-diene" "agn-pc-0cpc2c" "2,3-dimethyl-buta-1,3-diene" );
standardThermochemistry
{
    dHf_298   64110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158220.0
}
