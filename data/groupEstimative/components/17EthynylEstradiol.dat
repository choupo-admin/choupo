/*--------------------------------*- Choupo -*-----------------------*\
  Component: 17-ethynyl estradiol  (C20H24O2, CAS 57-63-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17EthynylEstradiol;
formula     C20H24O2;
CAS         57-63-6;
InChIKey    BFPYWIDHMRZLRN-UHFFFAOYSA-N;
MW          296.41;      // g/mol [origin=calculated method=formula-sum]
Tc          1118.23;      // K   [origin=predictive method=joback]
Pc          25.793;      // bar [origin=predictive method=joback]
omega       1.1993;      // -   [origin=predictive method=lee-kesler]
Tb          871.68;      // K   [origin=predictive method=joback]
HvapTb      89766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-273.82 2.82442 -0.00283325 1.16639e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 2; } { group C; count 2; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "17-ethynyl-13-methyl-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthrene-3,17-diol" "17alpha-ethynyl-1,3,5[10]-estratriene-3,17 beta-diol" "17alpha-ethynylestradiol" "ethylnylestradiol" "agn-pc-00hpqn" "19-nor-1,3,5(10),17alpha-pregnatrien-20-yne-3,17-diol" "19-norpregna-1,3,5(10)-trien-20-yne-3,17-diol, (17.alpha.)-" "brd-a43286952-001-01-7" "17alpha-ethynyl-delta1,3,5(10)-estra-triene-3,17 beta-diol" "17alpha-ethynyl-delta1,3,5(10) -estra- triene-3,17 beta-diol" "(8alpha,9beta,13alpha,14beta,17beta)-17-ethynylestra-1,3,5(10)-triene-3,17-diol" "(8alpha,9beta,14beta,17beta)-17-ethynylestra-1,3,5(10)-triene-3,17-diol" );
standardThermochemistry
{
    dHf_298   -72830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     692.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=283580.0
}
