/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2,4-dimethylbenzoate  (C10H12O2, CAS 23617-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl24Dimethylbenzoate;
formula     C10H12O2;
CAS         23617-71-2;
InChIKey    QQCLNRPRQRDMCK-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          735.49;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       0.5366;      // -   [origin=predictive method=lee-kesler]
Tb          523.26;      // K   [origin=predictive method=joback]
HvapTb      48861.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.9 0.70116 -0.00032272 2.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-dimethylbenzoic acid methyl ester" "benzoic acid, 2,4-dimethyl-, methyl ester" "2,4-dimethyl-benzoic acid methyl ester" "benzoic acid,2,4-dimethyl-, methyl ester" "2,4-dimethylbenzoicacid methyl ester; methyl 2,4-dimethylbenzoate" );
gibbsFormation
{
    dHf_298   -353420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183900.0
    phase     gas;
}
