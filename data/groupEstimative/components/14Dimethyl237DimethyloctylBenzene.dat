/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dimethyl-2-(3,7-dimethyloctyl)benzene  (C18H30, CAS 19550-60-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dimethyl237DimethyloctylBenzene;
formula     C18H30;
CAS         19550-60-8;
InChIKey    GDGPOTBJJLOPRZ-UHFFFAOYSA-N;
MW          246.438;      // g/mol [origin=calculated method=formula-sum]
Tc          840.92;      // K   [origin=predictive method=joback]
Pc          14.468;      // bar [origin=predictive method=joback]
omega       0.6855;      // -   [origin=predictive method=lee-kesler]
Tb          647.20;      // K   [origin=predictive method=joback]
HvapTb      58486.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.145 1.5278 -0.00085892 1.777e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group ACH; count 3; } { group ACCH3; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3,7-dimethyloctyl)-1,4-dimethyl-benzene" "octane, 3,7-dimethyl-1-(2,5-xylyl)-" "1,7-dimethyloctyl)benzene" "octane,7-dimethyl-1-(2,5-xylyl)-" "2-(3,7-dimethyloctyl)-1,4-dimethylbenzene" );
standardThermochemistry
{
    dHf_298   -211820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     719.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=188950.0
}
