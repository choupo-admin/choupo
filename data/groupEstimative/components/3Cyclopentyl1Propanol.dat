/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cyclopentyl-1-propanol  (C8H16O, CAS 767-05-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Cyclopentyl1Propanol;
formula     C8H16O;
CAS         767-05-5;
InChIKey    IBMXMCXCSPGCDQ-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          674.04;      // K   [origin=predictive method=joback]
Pc          34.039;      // bar [origin=predictive method=joback]
omega       0.7593;      // -   [origin=predictive method=lee-kesler]
Tb          490.10;      // K   [origin=predictive method=joback]
HvapTb      50338.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.577 0.9295 -0.0005692 1.333e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cyclopentylpropan-1-ol" "cyclopentanepropanol" "cyclopentanepropanol-" "1-cyclopentyl-3-hydroxypropane" "ibmxmcxcspgcdq-uhfffaoysa-" "(3-hydroxyprop-1-yl)cyclopentane" "c123" );
standardThermochemistry
{
    dHf_298   -300200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83790.0
}
