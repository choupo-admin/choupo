/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-benzenediamine, n4,n4-diethyl-2-methyl-  (C11H18N2, CAS 148-71-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BenzenediamineN4N4Diethyl2Methyl;
formula     C11H18N2;
CAS         148-71-0;
InChIKey    XBTWVJKPQPQTDW-UHFFFAOYSA-N;
MW          178.279;      // g/mol [origin=calculated method=formula-sum]
Tc          784.19;      // K   [origin=predictive method=joback]
Pc          27.183;      // bar [origin=predictive method=joback]
omega       0.6760;      // -   [origin=predictive method=lee-kesler]
Tb          572.89;      // K   [origin=predictive method=joback]
HvapTb      56364.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.618 1.03676 -0.00062772 1.438e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n4,n4-diethyl-2-methyl-benzene-1,4-diamine" "n1,n1-diethyl-3-methyl-para-phenylenediamine" "n-4,n-4-diethyl-2-methyl-1,4-phenylenediamine" "(4-amino-3-methylphenyl)diethylamine" "cd 2 color developer" "4-(n,n-diethyl)-2-methyl-p-phenylenediamine monohydrochloride" "4-diethylamino-o-toluidine" "2051-79-8 (mono-hydrochloride)" "24828-38-4 (unspecified hydrochloride)" "n1,n1-diethyl-3-methylbenzene-1,4-diamine" "n4,n4-diethyl-2-methyl-1,4-benzenediamine" "1-n,1-n-diethyl-3-methylbenzene-1,4-diamine" );
gibbsFormation
{
    dHf_298   44540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=312120.0
    phase     gas;
}
