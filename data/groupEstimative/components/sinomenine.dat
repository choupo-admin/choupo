/*--------------------------------*- Choupo -*-----------------------*\
  Component: sinomenine  (C19H23NO4, CAS 115-53-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sinomenine;
formula     C19H23NO4;
CAS         115-53-7;
InChIKey    INYYVPJSBIVGPH-QHRIQVFBSA-N;
MW          329.396;      // g/mol [origin=calculated method=formula-sum]
Tc          1150.61;      // K   [origin=predictive method=joback]
Pc          22.419;      // bar [origin=predictive method=joback]
omega       1.2040;      // -   [origin=predictive method=lee-kesler]
Tb          905.55;      // K   [origin=predictive method=joback]
HvapTb      85326.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.63 2.21426 -0.00187692 6.838e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } { group CH3O; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group O; count 2; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "coculine" "cucoline" "kukoline" "sabianine a" "sinomenine hcl" "(9alpha,13alpha,14alpha)-7,8-didehydro-4-hydroxy-3,7-dimethoxy-17-methylmorphinan-6-one" "7,8-didehydro-4-hydroxy-3,7-dimethoxy-17-methyl-9-alpha,13-alpha,14-alpha-morphinan-6-one" "9-alpha,13-alpha,14-alpha-morphinan-6-one, 7,8-didehydro-4-hydroxy-3,7-dimethoxy-17-methyl-" "sinomenine, cucoline, kukoline, coculine, sabianine a" "cuculine" "s2359_selleck" "upcmld-dp085" );
standardThermochemistry
{
    dHf_298   -460030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10810.0
}
