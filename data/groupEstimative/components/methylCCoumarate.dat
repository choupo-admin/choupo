/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl-c-coumarate  (C10H10O3, CAS 20883-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylCCoumarate;
formula     C10H10O3;
CAS         20883-98-1;
InChIKey    YMXREWKKROWOSO-UHFFFAOYSA-N;
MW          178.187;      // g/mol [origin=calculated method=formula-sum]
Tc          829.21;      // K   [origin=predictive method=joback]
Pc          37.135;      // bar [origin=predictive method=joback]
omega       0.7474;      // -   [origin=predictive method=lee-kesler]
Tb          598.08;      // K   [origin=predictive method=joback]
HvapTb      60509.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.8 0.99472 -0.00079696 2.567e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-(2-hydroxyphenyl)prop-2-enoate" "3-(2-hydroxyphenyl)-acrylic acid methyl ester" "2-propenoic acid,3-(2-hydroxyphenyl)-, methyl ester" "3-(2-hydroxy-phenyl)-acrylic acid methyl ester" "2-propenoic acid, 3-(2-hydroxyphenyl)-, methyl ester, (2e)-" "cinnamicacid, o-hydroxy-, methyl ester (7ci,8ci); 3-(2-hydroxyphenyl)-2-propenoic acidmethyl ester; methyl 2-hydroxycinnamate; methyl o-coumarate; methylo-hydroxycinnamate" );
standardThermochemistry
{
    dHf_298   -390570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-239040.0
}
