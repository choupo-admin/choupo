/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicyclopentenyl acrylate  (C13H14O2, CAS 50976-02-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicyclopentenylAcrylate;
formula     C13H14O2;
CAS         50976-02-8;
InChIKey    VEVJYJYFAXTUGJ-UHFFFAOYSA-N;
MW          202.253;      // g/mol [origin=calculated method=formula-sum]
Tc          782.11;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.5678;      // -   [origin=predictive method=lee-kesler]
Tb          565.41;      // K   [origin=predictive method=joback]
HvapTb      51146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.92 1.4421 -0.00108966 3.238e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 5; } { group CH2=CH; count 1; } { group CH=CH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 5; } { group dCH_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dicyclopentadienyl acrylate" "acrylic acid, dicyclopentadienyl ester" "2-propenoic acid, 3a,4,7,7a-tetrahydro-4,7-methano-1h-indenyl ester" "3a,4,7,7a-tetrahydro-4,7-methano-1h-indenyl acrylate" "acrylic acid, ((3a,4,7,7a-tetrahydro)4,7-methanoindenyl) ester" );
standardThermochemistry
{
    dHf_298   -216380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     298.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50700.0
}
