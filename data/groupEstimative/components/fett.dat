/*--------------------------------*- Choupo -*-----------------------*\
  Component: fett  (C17H24O, CAS 58243-85-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C17H24O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        fett;
formula     C17H24O;
CAS         58243-85-9;
InChIKey    QCWQUWUCARNNRI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          244.378;      // g/mol [origin=calculated method=formula-sum]
Tc          837.93;      // K   [origin=predictive method=joback]
Pc          18.773;      // bar [origin=predictive method=joback]
omega       0.4960;      // -   [origin=predictive method=lee-kesler]
Tb          613.42;      // K   [origin=predictive method=joback]
HvapTb      52799.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-172.479 2.0682 -0.00206768 8.758e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-5,5,8,8-tetramethyl-6,7-dihydronaphthalene-2-carbaldehyde" "formylethyltetramethyltetralin" "tetramethylethylformyltetralin" "2-naphthalenecarboxaldehyde, 3-ethyl-5,6,7,8-tetrahydro-5,5,8,8-tetramethyl-" "1,1,4,4-tetramethyl-6-ethyl-7-formyltetralin" "6-ethyl-7-formyl-1,1,4,4-tetramethyl-1,2,3,4-tetrahydronaphthalene" "3-ethyl-5,6,7,8-tetrahydro-5,5,8,8-tetramethylnaphthalene-2-carbaldehyde" "5,6,7,8-tetrahydro-3-ethyl-5,5,8,8-tetramethyl-2-naphthalenecarboxaldehyde" "2-naphthalenecarboxaldehyde, 5,6,7,8-tetrahydro-3-ethyl-5,5,8,8-tetramethyl-" );
gibbsFormation
{
    dHf_298   -38860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     800.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=249700.0
    phase     gas;
}
