/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyloctadecanoic acid  (C20H40O2, CAS 14276-80-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthyloctadecanoicAcid;
formula     C20H40O2;
CAS         14276-80-3;
InChIKey    OHIOERKSFVRABL-UHFFFAOYSA-N;
MW          312.538;      // g/mol [origin=calculated method=formula-sum]
Tc          986.04;      // K   [origin=predictive method=joback]
Pc          10.814;      // bar [origin=predictive method=joback]
omega       0.9934;      // -   [origin=predictive method=lee-kesler]
Tb          802.27;      // K   [origin=predictive method=joback]
HvapTb      76890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.374 1.96054 -0.00114 2.543e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group CH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylstearic acid" "octadecanoic acid, 2-ethyl-" "octadecanoic acid, ethyl-" );
gibbsFormation
{
    dHf_298   -811680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     978.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-228830.0
    phase     gas;
}
