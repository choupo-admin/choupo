/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl p-bis(2-hydroxyethyl)aminobenzoate  (C13H19NO4, CAS 15716-30-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylPBis2HydroxyethylAminobenzoate;
formula     C13H19NO4;
CAS         15716-30-0;
InChIKey    XFPHFLGZXKHBMU-UHFFFAOYSA-N;
MW          253.298;      // g/mol [origin=calculated method=formula-sum]
Tc          971.22;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       1.6445;      // -   [origin=predictive method=lee-kesler]
Tb          783.72;      // K   [origin=predictive method=joback]
HvapTb      90278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.235 1.23752 -0.00072636 1.44e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 2; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 4-[bis(2-hydroxyethyl)amino]benzoate" "benzoic acid, p-(bis(2-hydroxyethyl)amino)-, ethyl ester" "benzoic acid, p-[bis(2-hydroxy-ethyl)amino]-, ethyl ester" );
gibbsFormation
{
    dHf_298   -640800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     718.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-311870.0
    phase     gas;
}
