/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-butyltrifluoroacetamide  (C6H10F3NO, CAS 400-59-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nButyltrifluoroacetamide;
formula     C6H10F3NO;
CAS         400-59-9;
InChIKey    BIBAVAVHXLGIBU-UHFFFAOYSA-N;
MW          169.146;      // g/mol [origin=calculated method=formula-sum]
Tc          601.30;      // K   [origin=predictive method=joback]
Pc          29.730;      // bar [origin=predictive method=joback]
omega       0.6647;      // -   [origin=predictive method=lee-kesler]
Tb          435.50;      // K   [origin=predictive method=joback]
HvapTb      38385.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.617 0.78322 -0.0005535 1.5036e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CF3; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group F; count 3; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-butyl-2,2,2-tris(fluoranyl)ethanamide" "n-butyl-2,2,2-trifluoroacetamide" "acetamide, n-butyl-2,2,2-trifluoro-" "n-butyl-2,2,2-trifluoro-acetamide" );
gibbsFormation
{
    dHf_298   -823360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-621480.0
    phase     gas;
}
