/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxy-n,n-dimethylbenzylamine  (C10H15NO, CAS 15184-99-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethoxyNNDimethylbenzylamine;
formula     C10H15NO;
CAS         15184-99-3;
InChIKey    IENUHHADGQLQLU-UHFFFAOYSA-N;
MW          165.236;      // g/mol [origin=calculated method=formula-sum]
Tc          696.68;      // K   [origin=predictive method=joback]
Pc          28.263;      // bar [origin=predictive method=joback]
omega       0.5240;      // -   [origin=predictive method=lee-kesler]
Tb          494.92;      // K   [origin=predictive method=joback]
HvapTb      45245.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.999 0.87616 -0.00048596 9.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-methoxyphenyl)-n,n-dimethyl-methanamine" "[(3-methoxyphenyl)methyl]dimethylamine" "3-methoxy-n,n-dimethyl-benzenemethanamine" "(3-methoxyphenyl)-n,n-dimethylmethanamine" "benzenemethanamine,3-methoxy-n,n-dimethyl-" "1-(3-methoxyphenyl)-n,n-dimethylmethanamine" );
standardThermochemistry
{
    dHf_298   -89360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=141880.0
}
