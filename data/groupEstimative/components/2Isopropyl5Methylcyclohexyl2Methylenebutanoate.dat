/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropyl-5-methylcyclohexyl 2-methylenebutanoate  (C15H26O2, CAS 67801-24-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropyl5Methylcyclohexyl2Methylenebutanoate;
formula     C15H26O2;
CAS         67801-24-5;
InChIKey    JOORVZPXBJMPEI-UHFFFAOYSA-N;
MW          238.371;      // g/mol [origin=calculated method=formula-sum]
Tc          806.85;      // K   [origin=predictive method=joback]
Pc          16.538;      // bar [origin=predictive method=joback]
omega       0.6046;      // -   [origin=predictive method=lee-kesler]
Tb          607.35;      // K   [origin=predictive method=joback]
HvapTb      55224.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.429 1.42898 -0.0006962 8.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 4; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5-methyl-2-propan-2-yl-cyclohexyl) 2-methylidenebutanoate" "butanoic acid, 2-methylene-, 5-methyl-2-(1-methylethyl)cyclohexyl ester" "2-isopropyl-5-methylcyclohexyl 2-ethylacrylate" "(5-methyl-2-propan-2-ylcyclohexyl) 2-methylidenebutanoate" "5-methyl-2-(propan-2-yl)cyclohexyl 2-methylidenebutanoate" );
standardThermochemistry
{
    dHf_298   -546210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     658.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-149070.0
}
