/*--------------------------------*- Choupo -*-----------------------*\
  Component: dmamp  (C6H15NO, CAS 7005-47-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dmamp;
formula     C6H15NO;
CAS         7005-47-2;
InChIKey    XRIBIDPMFSLGFS-UHFFFAOYSA-N;
MW          117.192;      // g/mol [origin=calculated method=formula-sum]
Tc          607.85;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.7192;      // -   [origin=predictive method=lee-kesler]
Tb          438.27;      // K   [origin=predictive method=joback]
HvapTb      46376.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.439 0.85758 -0.0006174 1.793e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)-2-methyl-propan-1-ol" "1-propanol, 2-(dimethylamino)-2-methyl-" "2-dimethylamino-2-methyl-1-propanol" "2-(dimethylamino)-2-methyl-1-propanol" "usaf cs-1" "2-(dimethylamino)-2-methylpropanol" "2-(dimethylamino)-2-methylpropan-1-ol" "2-dimethylamino-2-methylpropan-1-ol" "2-(n,n-dimethylamino)-2-methyl-1-propanol" "2-(dimethylamino)isobutanol" "dmamp-80(tm)" "2-(n,n-dimethylamino)isobutanol" );
gibbsFormation
{
    dHf_298   -260620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23560.0
    phase     gas;
}
