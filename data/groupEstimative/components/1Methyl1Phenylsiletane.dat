/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-1-phenylsiletane  (C10H14Si, CAS 3944-08-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H14Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Methyl1Phenylsiletane;
formula     C10H14Si;
CAS         3944-08-9;
InChIKey    SEWJDYLLWONCRV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          162.307;      // g/mol [origin=calculated method=formula-sum]
Tc          698.30;      // K   [origin=predictive method=joback]
Pc          30.727;      // bar [origin=predictive method=joback]
omega       0.2830;      // -   [origin=predictive method=lee-kesler]
Tb          467.89;      // K   [origin=predictive method=joback]
HvapTb      40646.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.47 0.84612 -0.0004122 4.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-1-phenyl-siletane" "1-methyl-1-phenyl-1-silacyclobutane" "1-phenyl-1-methyl-1-silacyclobutane" );
gibbsFormation
{
    dHf_298   -31680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109430.0
    phase     gas;
}
