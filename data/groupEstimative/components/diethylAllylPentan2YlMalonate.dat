/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl allyl(pentan-2-yl)malonate  (C15H26O4, CAS 22328-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylAllylPentan2YlMalonate;
formula     C15H26O4;
CAS         22328-93-4;
InChIKey    VTRMVPBHEGUYBA-UHFFFAOYSA-N;
MW          270.369;      // g/mol [origin=calculated method=formula-sum]
Tc          834.69;      // K   [origin=predictive method=joback]
Pc          15.035;      // bar [origin=predictive method=joback]
omega       0.8411;      // -   [origin=predictive method=lee-kesler]
Tb          652.25;      // K   [origin=predictive method=joback]
HvapTb      61444.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.925 1.43098 -0.0008009 1.419e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-pentan-2-yl-2-prop-2-enyl-propanedioate" "malonic acid, allyl-1-methylbutyl-, diethyl ester" "agn-pc-03g35d" "diethyl 2-pentan-2-yl-2-prop-2-enylpropanedioate" "diethyl 2-[(2r)-pentan-2-yl]-2-prop-2-enylpropanedioate" );
standardThermochemistry
{
    dHf_298   -876090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     789.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-457080.0
}
