/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-piperidinoethanol  (C7H15NO, CAS 3040-44-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Piperidinoethanol;
formula     C7H15NO;
CAS         3040-44-6;
InChIKey    KZTWONRVIPPDKH-UHFFFAOYSA-N;
MW          129.203;      // g/mol [origin=calculated method=formula-sum]
Tc          668.44;      // K   [origin=predictive method=joback]
Pc          39.705;      // bar [origin=predictive method=joback]
omega       0.8124;      // -   [origin=predictive method=lee-kesler]
Tb          484.33;      // K   [origin=predictive method=joback]
HvapTb      50464.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.298 0.9849 -0.0006828 1.87e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 5; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-piperidin-1-ylethanol" "1-piperidineethanol" "n-(2-hydroxyethyl)piperidine" "1-(2-hydroxyethyl)piperidine" "2-(1-piperidinyl)ethanol" "n-piperidineethanol" "n-(hydroxyethyl)piperidine" "beta-piperidylethanol" "2-(piperidin-1-yl)ethanol" "beta-piperidinoethanol" ".beta.-piperidinoethanol" "2-hydroxyethyl piperidine" );
gibbsFormation
{
    dHf_298   -191690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=26280.0
    phase     gas;
}
