/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-1,2,2,6,6-pentamethylpiperidine  (C10H20BrN, CAS 63867-64-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo12266Pentamethylpiperidine;
formula     C10H20BrN;
CAS         63867-64-1;
InChIKey    ASLNITXQJFGECM-UHFFFAOYSA-N;
MW          234.181;      // g/mol [origin=calculated method=formula-sum]
Tc          733.05;      // K   [origin=predictive method=joback]
Pc          27.498;      // bar [origin=predictive method=joback]
omega       0.4364;      // -   [origin=predictive method=lee-kesler]
Tb          513.42;      // K   [origin=predictive method=joback]
HvapTb      43669.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-157.29 1.7785 -0.001786 7.584e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 2; } { group CH3N; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 2; } { group Br; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-1,2,2,6,6-pentamethyl-piperidine" "piperidine, 4-bromo-1,2,2,6,6-pentamethyl-" );
gibbsFormation
{
    dHf_298   -105590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     616.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=168570.0
    phase     gas;
}
