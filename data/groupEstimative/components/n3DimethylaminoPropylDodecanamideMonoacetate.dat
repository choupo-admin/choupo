/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(3-(dimethylamino)propyl)dodecanamide monoacetate  (C19H40N2O3, CAS 22890-14-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3DimethylaminoPropylDodecanamideMonoacetate;
formula     C19H40N2O3;
CAS         22890-14-8;
InChIKey    ITEOMQZUDMOKMS-UHFFFAOYSA-N;
MW          344.54;      // g/mol [origin=calculated method=formula-sum]
Tc          1099.43;      // K   [origin=predictive method=joback]
Pc          11.360;      // bar [origin=predictive method=joback]
omega       1.0801;      // -   [origin=predictive method=lee-kesler]
Tb          897.71;      // K   [origin=predictive method=joback]
HvapTb      90571.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.493 1.82558 -0.0008101 6.456e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 12; } { group CH3N; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 13; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[3-(dimethylamino)propyl]dodecanamide;ethanoic acid" "n-[3-(dimethylamino)propyl]dodecanamide acetate(1:1)" "n-[3-(dimethylamino)propyl]dodecanamide monoacetate" "dodecanamide, n-(3-(dimethylamino)propyl)-, monoacetate" "dodecanamide, n-(3-(dimethylamino)propyl)-, acetate (1:1)" "acetic acid; n-[3-(dimethylamino)propyl]dodecanamide" );
gibbsFormation
{
    dHf_298   -888960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1140.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-268320.0
    phase     gas;
}
