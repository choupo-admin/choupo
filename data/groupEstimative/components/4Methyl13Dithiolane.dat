/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-1,3-dithiolane  (C4H8S2, CAS 50363-43-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl13Dithiolane;
formula     C4H8S2;
CAS         50363-43-4;
InChIKey    RCAGLIUGQCZIDE-UHFFFAOYSA-N;
MW          120.228;      // g/mol [origin=calculated method=formula-sum]
Tc          638.36;      // K   [origin=predictive method=joback]
Pc          48.630;      // bar [origin=predictive method=joback]
omega       0.2132;      // -   [origin=predictive method=lee-kesler]
Tb          402.06;      // K   [origin=predictive method=joback]
HvapTb      36379.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.59 0.54434 -0.0003586 9.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dithiolane, 4-methyl-" "4-methyl-1,3-dithiacyclopentane" );
standardThermochemistry
{
    dHf_298   25110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     361.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99070.0
}
