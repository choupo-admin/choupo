/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyl-1-naphthylamine  (C11H11N, CAS 2216-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethyl1Naphthylamine;
formula     C11H11N;
CAS         2216-68-4;
InChIKey    AKEYUWUEAXIBTF-UHFFFAOYSA-N;
MW          157.216;      // g/mol [origin=calculated method=formula-sum]
Tc          786.28;      // K   [origin=predictive method=joback]
Pc          34.602;      // bar [origin=predictive method=joback]
omega       0.5502;      // -   [origin=predictive method=lee-kesler]
Tb          552.09;      // K   [origin=predictive method=joback]
HvapTb      51094.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.37 0.98292 -0.00072408 2.119e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methylnaphthalen-1-amine" "1-naphthalenamine, n-methyl-" "1-methylaminonaphthalene" "1-naphthylamine, n-methyl" "methyl(1-naphthyl)amine" "n-methyl-alpha-naphthylamine" "n-methyl-.alpha.-naphthylamine" "methylnaphthylamine" "1-naphthylamine, n-methyl-" "n-methyl-1-naftylamin" "n-methyl-n-1-naphthylamine" );
standardThermochemistry
{
    dHf_298   199230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=340560.0
}
