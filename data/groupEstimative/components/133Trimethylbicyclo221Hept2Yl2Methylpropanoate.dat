/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,3-trimethylbicyclo[2.2.1]hept-2-yl 2-methylpropanoate  (C14H24O2, CAS 67845-32-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        133Trimethylbicyclo221Hept2Yl2Methylpropanoate;
formula     C14H24O2;
CAS         67845-32-3;
InChIKey    GNEDPOFWFUPIPQ-UHFFFAOYSA-N;
MW          224.344;      // g/mol [origin=calculated method=formula-sum]
Tc          797.27;      // K   [origin=predictive method=joback]
Pc          19.930;      // bar [origin=predictive method=joback]
omega       0.5584;      // -   [origin=predictive method=lee-kesler]
Tb          586.59;      // K   [origin=predictive method=joback]
HvapTb      50855.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-179.82 2.108 -0.0019948 8.061e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 3; } { group C; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,2,4-trimethyl-3-bicyclo[2.2.1]heptanyl) 2-methylpropanoate" "1,3,3-trimethylbicyclo(2.2.1)hept-2-yl isobutyrate" "1,3,3-trimethylbicyclo[2.2.1]hept-2-yl isobutyrate" "propanoic acid, 2-methyl-, 1,3,3-trimethylbicyclo(2.2.1)hept-2-yl ester" "propanoic acid, 2-methyl-, 1,3,3-trimethylbicyclo[2.2.1]hept-2-yl ester" "isobutyric acid, 1,3,3-trimethylbicyclo(2.2.1)hept-2-yl ester" );
gibbsFormation
{
    dHf_298   -525610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     636.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-162810.0
    phase     gas;
}
