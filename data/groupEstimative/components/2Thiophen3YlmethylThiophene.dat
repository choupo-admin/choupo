/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(thiophen-3-ylmethyl)thiophene  (C9H8S2, CAS 31270-74-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Thiophen3YlmethylThiophene;
formula     C9H8S2;
CAS         31270-74-3;
InChIKey    IHRIZWIQYHCDDL-UHFFFAOYSA-N;
MW          180.283;      // g/mol [origin=calculated method=formula-sum]
Tc          816.36;      // K   [origin=predictive method=joback]
Pc          41.409;      // bar [origin=predictive method=joback]
omega       0.3979;      // -   [origin=predictive method=lee-kesler]
Tb          547.68;      // K   [origin=predictive method=joback]
HvapTb      50876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.779 0.86102 -0.00068384 2.159e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group C4H3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3'-dithienylmethane" );
standardThermochemistry
{
    dHf_298   231250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=293720.0
}
