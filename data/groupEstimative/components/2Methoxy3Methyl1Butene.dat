/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-3-methyl-1-butene  (C6H12O, CAS 51776-45-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy3Methyl1Butene;
formula     C6H12O;
CAS         51776-45-5;
InChIKey    KDMASJAWKNAFBX-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          530.99;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.2986;      // -   [origin=predictive method=lee-kesler]
Tb          355.42;      // K   [origin=predictive method=joback]
HvapTb      30382.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.57 0.49646 -0.00022 2.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-3-methyl-but-1-ene" "2-methoxy-3-methylbut-1-ene" );
gibbsFormation
{
    dHf_298   -189030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28510.0
    phase     gas;
}
