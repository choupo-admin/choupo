/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-amino-1-naphthol  (C10H9NO, CAS 4384-92-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Amino1Naphthol;
formula     C10H9NO;
CAS         4384-92-3;
InChIKey    ZYSOYLBBCYWEMB-UHFFFAOYSA-N;
MW          159.188;      // g/mol [origin=calculated method=formula-sum]
Tc          891.22;      // K   [origin=predictive method=joback]
Pc          50.228;      // bar [origin=predictive method=joback]
omega       0.7794;      // -   [origin=predictive method=lee-kesler]
Tb          632.19;      // K   [origin=predictive method=joback]
HvapTb      66087.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.68 1.0282 -0.00092084 3.336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACOH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-azanylnaphthalen-1-ol" "2-amino-8-naphthol" "7-aminonaphthalen-1-ol" "1-naphthalenol,7-amino-" "1-naphthalenol, 7-amino-" );
gibbsFormation
{
    dHf_298   22880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=154580.0
    phase     gas;
}
