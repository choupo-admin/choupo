/*--------------------------------*- Choupo -*-----------------------*\
  Component: perfluoro-tert-butanol  (C4HF9O, CAS 2378-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        perfluoroTertButanol;
formula     C4HF9O;
CAS         2378-02-1;
InChIKey    XZNOAVNRSFURIR-UHFFFAOYSA-N;
MW          236.033;      // g/mol [origin=calculated method=formula-sum]
Tc          493.33;      // K   [origin=predictive method=joback]
Pc          29.569;      // bar [origin=predictive method=joback]
omega       0.7866;      // -   [origin=predictive method=lee-kesler]
Tb          363.81;      // K   [origin=predictive method=joback]
HvapTb      28640.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.53 1.0272 -0.001059 3.842e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group OH; count 1; } { group CF3; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 4; } { group F; count 9; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,3,3,3-hexakis(fluoranyl)-2-(trifluoromethyl)propan-2-ol" "nonafluoro-tert-butanol" "perfluoro-tert-butyl alcohol" "nonafluoro-tert-butyl alcohol" "1,1,1,3,3,3-hexafluoro-2-(trifluoromethyl)-2-propanol" "1,1,1,3,3,3-hexafluoro-2-(trifluoromethyl)propan-2-ol" "2-propanol, 1,1,1,3,3,3-hexafluoro-2-(trifluoromethyl)-" "1,1,1,3,3,3-hexafluoro-2-trifluoromethyl-2-propanol" "perfluoro-t-butanol" "nonafluor-terc.butanol" "nonafluoro-t-butyl alcohol" "perfluoro-tert-butanol 99%" );
standardThermochemistry
{
    dHf_298   -2078110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1895950.0
}
