/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-dimethylaminopropyl methacrylamide  (C9H18N2O, CAS 5205-93-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3DimethylaminopropylMethacrylamide;
formula     C9H18N2O;
CAS         5205-93-6;
InChIKey    GDFCSMCGLZFNFY-UHFFFAOYSA-N;
MW          170.256;      // g/mol [origin=calculated method=formula-sum]
Tc          700.21;      // K   [origin=predictive method=joback]
Pc          26.004;      // bar [origin=predictive method=joback]
omega       0.7474;      // -   [origin=predictive method=lee-kesler]
Tb          518.56;      // K   [origin=predictive method=joback]
HvapTb      50263.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.517 1.01086 -0.0006335 1.5396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=C; count 1; } { group CH3N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[3-(dimethylamino)propyl]-2-methyl-prop-2-enamide" "n-(3-(dimethylamino)propyl)methacrylamide" "n-[3-(dimethylamino)propyl]-2-methylprop-2-enamide" "2-propenamide, n-(3-(dimethylamino)propyl)-2-methyl-" "2-propenamide, n-[3-(dimethylamino)propyl]-2-methyl-" "n-((dimethylamino)propyl)methacrylamide" "n-[3-(dimethylamino)propyl]methacrylamide" "n-[3-(dimethylamino)propyl]-2-methylacrylamide" "3-dimethylaminopropyl-methylacrylamide" "dimethyl amino propyl methacrylamide" "n-(3-dimethylaminopropyl)methacrylamide" "u597" );
gibbsFormation
{
    dHf_298   -105030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     581.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175440.0
    phase     gas;
}
