/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,8-dimethyl-1,8-nonadiene  (C11H20, CAS 20054-25-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        28Dimethyl18Nonadiene;
formula     C11H20;
CAS         20054-25-5;
InChIKey    CTURECVBUDVEDW-UHFFFAOYSA-N;
MW          152.281;      // g/mol [origin=calculated method=formula-sum]
Tc          618.65;      // K   [origin=predictive method=joback]
Pc          21.042;      // bar [origin=predictive method=joback]
omega       0.4459;      // -   [origin=predictive method=lee-kesler]
Tb          444.40;      // K   [origin=predictive method=joback]
HvapTb      38900.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.475 1.00864 -0.000625 1.581e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH2; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,8-dimethylnona-1,8-diene" "1,8-nonadiene, 2,8-dimethyl-" );
gibbsFormation
{
    dHf_298   -39090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=200320.0
    phase     gas;
}
