/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclodocosane  (C22H44, CAS 296-86-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclodocosane;
formula     C22H44;
CAS         296-86-6;
InChIKey    COZWXTZNDSMXKZ-UHFFFAOYSA-N;
MW          308.594;      // g/mol [origin=calculated method=formula-sum]
Tc          1063.64;      // K   [origin=predictive method=joback]
Pc          13.799;      // bar [origin=predictive method=joback]
omega       0.4562;      // -   [origin=predictive method=lee-kesler]
Tb          795.50;      // K   [origin=predictive method=joback]
HvapTb      68056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-170.59 2.0888 -0.000567 -1.9e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 22; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 22; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-00ni2n" );
gibbsFormation
{
    dHf_298   -521310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1343.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-27080.0
    phase     gas;
}
