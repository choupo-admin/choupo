/*--------------------------------*- Choupo -*-----------------------*\
  Component: [2-(acetyloxy)-2,5,5,8a-tetramethyldecahydronaphthalen-1-yl]acetic acid  (C18H30O4, CAS 31207-65-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Acetyloxy2558aTetramethyldecahydronaphthalen1YlAceticAcid;
formula     C18H30O4;
CAS         31207-65-5;
InChIKey    XWPRKOUKBYLKPF-UHFFFAOYSA-N;
MW          310.434;      // g/mol [origin=calculated method=formula-sum]
Tc          1060.70;      // K   [origin=predictive method=joback]
Pc          16.578;      // bar [origin=predictive method=joback]
omega       0.9525;      // -   [origin=predictive method=lee-kesler]
Tb          832.44;      // K   [origin=predictive method=joback]
HvapTb      76367.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-236.589 2.7695 -0.0026198 1.0623e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 2; } { group C; count 3; } { group CH3COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group C_ring; count 3; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-acetyloxy-2,5,5,8a-tetramethyl-3,4,4a,6,7,8-hexahydro-1h-naphthalen-1-yl)ethanoic acid" "1-naphthaleneacetic acid, 2-(acetyloxy)decahydro-2,5,5,8a-tetramethyl-, (1r,2r,4as,8as)-" "2-(2-acetyloxy-2,5,5,8a-tetramethyl-3,4,4a,6,7,8-hexahydro-1h-naphthalen-1-yl)acetic acid" "acetic acid, 2-(2-acetoxy-2,5,5,8a-tetramethyldecalin-1-yl)-" "decahydro-2-hydroxy-2,5,5,8a-tetramethyl-1-naphthaleneacetic acid, acetate" );
standardThermochemistry
{
    dHf_298   -976740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     942.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-520100.0
}
