/*--------------------------------*- Choupo -*-----------------------*\
  Component: forfenimex  (C9H11NO4, CAS 71522-58-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        forfenimex;
formula     C9H11NO4;
CAS         71522-58-2;
InChIKey    JRBXPUUAYKCCLQ-QMMMGPOBSA-N;
MW          197.19;      // g/mol [origin=calculated method=formula-sum]
Tc          1054.17;      // K   [origin=predictive method=joback]
Pc          53.202;      // bar [origin=predictive method=joback]
omega       1.8075;      // -   [origin=predictive method=lee-kesler]
Tb          827.58;      // K   [origin=predictive method=joback]
HvapTb      95676.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.119 1.0276 -0.00083592 2.779e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-2-[4-(hydroxymethyl)-3-oxidanyl-phenyl]ethanoic acid" "forphenicinol" "forfenimexum [latin]" "(+)-(s)-2-(a,3-dihydroxy-p-tolyl)glycine" "benzeneacetic acid, alpha-amino-3-hydroxy-4-(hydroxymethyl)-, (s)-" "forfenimexa" "forfenimexum" "forfenimex [inn]" "2-amino-2-[3-hydroxy-4-(hydroxymethyl)phenyl]acetic acid" "(+)-(s)-2-(alpha,3-dihydroxy-p-tolyl)glycine" "alpha-amino-3-hydroxy-4-(hydroxymethyl)benzeneacetic acid" "(2s)-2-amino-2-[3-hydroxy-4-(hydroxymethyl)phenyl]acetic acid" );
gibbsFormation
{
    dHf_298   -655330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-443660.0
    phase     gas;
}
