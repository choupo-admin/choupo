/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dioxane-2,3-diol  (C4H8O4, CAS 4845-50-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dioxane23Diol;
formula     C4H8O4;
CAS         4845-50-5;
InChIKey    YLVACWCCJCZITJ-UHFFFAOYSA-N;
MW          120.104;      // g/mol [origin=calculated method=formula-sum]
Tc          731.78;      // K   [origin=predictive method=joback]
Pc          62.590;      // bar [origin=predictive method=joback]
omega       1.2728;      // -   [origin=predictive method=lee-kesler]
Tb          544.26;      // K   [origin=predictive method=joback]
HvapTb      66996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.19 0.5414 -0.0002524 2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group OH; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group OH; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydroxy-1,4-dioxane" "p-dioxane-2,3-diol" "(2r,3r)-1,4-dioxane-2,3-diol" "(2s,3s)-1,4-dioxane-2,3-diol" "1,3-diol" "glyoxal monoethylene acetal" "trans-1,4-dioxane-2,3-diol" "trans-2,3-dihydroxy-1,4-dioxane" "(2r,3s)-1,4-dioxane-2,3-diol" );
gibbsFormation
{
    dHf_298   -660370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     238.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-446340.0
    phase     gas;
}
