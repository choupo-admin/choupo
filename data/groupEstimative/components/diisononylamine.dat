/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisononylamine  (C18H39N, CAS 28454-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisononylamine;
formula     C18H39N;
CAS         28454-70-8;
InChIKey    KHFRJOPGKUBZLL-UHFFFAOYSA-N;
MW          269.517;      // g/mol [origin=calculated method=formula-sum]
Tc          827.94;      // K   [origin=predictive method=joback]
Pc          11.752;      // bar [origin=predictive method=joback]
omega       0.8558;      // -   [origin=predictive method=lee-kesler]
Tb          660.73;      // K   [origin=predictive method=joback]
HvapTb      61322.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.048 1.80188 -0.0010104 2.125e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 11; } { group CH; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methyl-n-(7-methyloctyl)octan-1-amine" "isononanamine, n-isononyl-" "diisononylamine(8ci)" "isononanamine,n-isononyl-" "1-isononanamine, n-isononyl-" );
standardThermochemistry
{
    dHf_298   -371940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     878.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185190.0
}
