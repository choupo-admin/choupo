/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-bis(chloranyl)-3-(chloromethyl)but-2-enoic acid  (C5H5Cl3O2, CAS 215226-72-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44BisChloranyl3ChloromethylBut2EnoicAcid;
formula     C5H5Cl3O2;
CAS         215226-72-5;
InChIKey    DVENUTRETHQGSX-UHFFFAOYSA-N;
MW          203.443;      // g/mol [origin=calculated method=formula-sum]
Tc          799.76;      // K   [origin=predictive method=joback]
Pc          36.509;      // bar [origin=predictive method=joback]
omega       0.7224;      // -   [origin=predictive method=lee-kesler]
Tb          575.40;      // K   [origin=predictive method=joback]
HvapTb      56693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.061 0.5758 -0.0004713 1.52e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group COOH; count 1; } { group CH2Cl; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -441870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-319250.0
}
