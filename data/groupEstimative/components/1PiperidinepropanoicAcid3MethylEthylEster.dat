/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-piperidinepropanoic acid, 3-methyl-, ethyl ester  (C11H21NO2, CAS 70644-49-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PiperidinepropanoicAcid3MethylEthylEster;
formula     C11H21NO2;
CAS         70644-49-4;
InChIKey    AATMBDYQEPKVEN-UHFFFAOYSA-N;
MW          199.294;      // g/mol [origin=calculated method=formula-sum]
Tc          727.76;      // K   [origin=predictive method=joback]
Pc          22.871;      // bar [origin=predictive method=joback]
omega       0.6543;      // -   [origin=predictive method=lee-kesler]
Tb          537.22;      // K   [origin=predictive method=joback]
HvapTb      49787.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.877 1.24964 -0.00072 1.395e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2COO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-(3-methylpiperidin-1-yl)propanoate" "ethyl 3-methylpiperidine-1-propionate" "1-piperidinepropanoicacid, 3-methyl-, ethyl ester" );
gibbsFormation
{
    dHf_298   -459640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-121300.0
    phase     gas;
}
