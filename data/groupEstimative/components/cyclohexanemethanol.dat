/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanemethanol  (C7H14O, CAS 100-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanemethanol;
formula     C7H14O;
CAS         100-49-2;
InChIKey    VSSAZBXXNIABDN-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          664.37;      // K   [origin=predictive method=joback]
Pc          39.407;      // bar [origin=predictive method=joback]
omega       0.6710;      // -   [origin=predictive method=lee-kesler]
Tb          471.49;      // K   [origin=predictive method=joback]
HvapTb      48284.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.789 0.8249 -0.0004684 9.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexylmethanol" "cyclohexylcarbinol" "hexahydrobenzyl alcohol" "cyclohexanecarbinol" "(hydroxymethyl)cyclohexane" "methanol, cyclohexyl-" "cyclohexylmethyl alcohol" "benzyl alcohol, hexahydro-" "usaf do-49" "cyclohexyl-methanol" "hydroxymethylcyclohexane" "cyclohexyl methanol" );
gibbsFormation
{
    dHf_298   -285720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-104310.0
    phase     gas;
}
