/*--------------------------------*- Choupo -*-----------------------*\
  Component: hex-3-enedioic acid  (C6H8O4, CAS 4436-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hex3EnedioicAcid;
formula     C6H8O4;
CAS         4436-74-2;
InChIKey    YHGNXQAFNHCBTK-UHFFFAOYSA-N;
MW          144.126;      // g/mol [origin=calculated method=formula-sum]
Tc          844.05;      // K   [origin=predictive method=joback]
Pc          40.881;      // bar [origin=predictive method=joback]
omega       1.0941;      // -   [origin=predictive method=lee-kesler]
Tb          632.06;      // K   [origin=predictive method=joback]
HvapTb      63236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.548 0.6954 -0.0005316 1.636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trans-?-hydromuconic acid" "trans-3-dihydromuconic acid" );
gibbsFormation
{
    dHf_298   -750490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-607960.0
    phase     gas;
}
