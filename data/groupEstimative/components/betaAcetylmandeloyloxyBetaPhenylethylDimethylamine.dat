/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-acetylmandeloyloxy-beta-phenylethyl dimethylamine  (C20H23NO4, CAS 73118-22-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaAcetylmandeloyloxyBetaPhenylethylDimethylamine;
formula     C20H23NO4;
CAS         73118-22-6;
InChIKey    NUSNCQAWMMRWPC-UHFFFAOYSA-N;
MW          341.407;      // g/mol [origin=calculated method=formula-sum]
Tc          1147.91;      // K   [origin=predictive method=joback]
Pc          19.052;      // bar [origin=predictive method=joback]
omega       1.3438;      // -   [origin=predictive method=lee-kesler]
Tb          923.60;      // K   [origin=predictive method=joback]
HvapTb      95857.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.889 1.95286 -0.0013313 3.3026e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH3CO; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group CdO; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(dimethylamino)-1-phenyl-ethyl] 2-oxidanyl-3-oxidanylidene-2-phenyl-butanoate" "acetylmandelic acid (2-(dimethylamino)-1-phenyl)ethyl ester" "mandelic acid, alpha-acetyl-, 2-(dimethylamino)-1-phenylethyl ester" "[2-(dimethylamino)-1-phenylethyl] 2-hydroxy-3-oxo-2-phenylbutanoate" "mandelic acid, alpha-acetyl-,  2-(dimethylamino)-1-phenylethyl ester" );
gibbsFormation
{
    dHf_298   -511660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     818.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122590.0
    phase     gas;
}
