/*--------------------------------*- Choupo -*-----------------------*\
  Component: zymosterol  (C27H44O, CAS 128-33-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        zymosterol;
formula     C27H44O;
CAS         128-33-6;
InChIKey    CGSJXLIKVBJVRY-XTGBIJOFSA-N;
MW          384.648;      // g/mol [origin=calculated method=formula-sum]
Tc          1187.49;      // K   [origin=predictive method=joback]
Pc          11.276;      // bar [origin=predictive method=joback]
omega       0.9773;      // -   [origin=predictive method=lee-kesler]
Tb          961.71;      // K   [origin=predictive method=joback]
HvapTb      91233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-310.218 3.5401 -0.0030211 1.1103e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 11; } { group CH; count 5; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,5s,10s,13r,14r,17r)-10,13-dimethyl-17-[(2r)-6-methylhept-5-en-2-yl]-2,3,4,5,6,7,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-ol" "5alpha-cholesta-8,24-dien-3beta-ol" "delta8,24-cholestadien-3beta-ol" "zymostrol" "zymosterol intermediate 2" "cholest-8,24-dien-3b-ol" "cholesta-8,24-dien-3-ol" "5" "a-cholesta-8,24-dien-3" "a-ol" "(3b,5a)- cholesta-8,24-dien-3-ol" "5-alpha-cholesta-8,24-dien-3-beta-ol" );
standardThermochemistry
{
    dHf_298   -365650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     981.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=275670.0
}
