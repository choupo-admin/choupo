/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-{[2-(2-hydroxyethoxy)ethyl](methyl)amino}ethanol  (C7H17NO3, CAS 68213-98-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222HydroxyethoxyEthylMethylAminoEthanol;
formula     C7H17NO3;
CAS         68213-98-9;
InChIKey    DHFGYXVVIQTUSZ-UHFFFAOYSA-N;
MW          163.217;      // g/mol [origin=calculated method=formula-sum]
Tc          735.83;      // K   [origin=predictive method=joback]
Pc          33.606;      // bar [origin=predictive method=joback]
omega       1.5008;      // -   [origin=predictive method=lee-kesler]
Tb          578.98;      // K   [origin=predictive method=joback]
HvapTb      68987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.916 0.79752 -0.0004194 7.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 1; } { group CH3N; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group OH; count 2; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-hydroxyethyloxy)ethyl-methyl-amino]ethanol" "ethanol, 2-((2-(2-hydroxyethoxy)ethyl)methylamino)-" "ethanol, 2-[[2-(2-hydroxyethoxy)ethyl]methylamino]-" "n-methyl-n-hydroxyethyl-n-hydroxyethoxyethylamine" "2-[2-(2-hydroxyethoxy)ethyl-methylamino]ethanol" "2-[[2-(2-hydroxyethoxy)ethyl]methylamino]ethanol" );
standardThermochemistry
{
    dHf_298   -556960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-259800.0
}
