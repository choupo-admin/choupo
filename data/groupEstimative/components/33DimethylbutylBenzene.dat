/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3,3-dimethylbutyl)benzene  (C12H18, CAS 17314-92-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33DimethylbutylBenzene;
formula     C12H18;
CAS         17314-92-0;
InChIKey    NKDJZTYRVIGJCG-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          709.92;      // K   [origin=predictive method=joback]
Pc          24.507;      // bar [origin=predictive method=joback]
omega       0.3901;      // -   [origin=predictive method=lee-kesler]
Tb          497.61;      // K   [origin=predictive method=joback]
HvapTb      43286.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.398 1.19076 -0.000832 2.29e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylbutylbenzene" "benzene, (3,3-dimethylbutyl)-" "1-phenyl-3,3-dimethylbutane" "agn-pc-04y20m" );
gibbsFormation
{
    dHf_298   -63230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=165410.0
    phase     gas;
}
