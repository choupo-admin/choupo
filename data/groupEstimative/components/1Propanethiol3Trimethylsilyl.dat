/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propanethiol, 3-trimethylsilyl-  (C6H16SSi, CAS 13399-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H16SSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Propanethiol3Trimethylsilyl;
formula     C6H16SSi;
CAS         13399-93-4;
InChIKey    HCZBMENVWKFZDJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          148.339;      // g/mol [origin=calculated method=formula-sum]
Tc          596.84;      // K   [origin=predictive method=joback]
Pc          29.218;      // bar [origin=predictive method=joback]
omega       0.2766;      // -   [origin=predictive method=lee-kesler]
Tb          401.14;      // K   [origin=predictive method=joback]
HvapTb      35981.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.143 0.39496 8.98e-05 -1.514e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH2SH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-trimethylsilylpropane-1-thiol" "3-mercaptopropyltrimethylsilane" );
gibbsFormation
{
    dHf_298   -240310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75730.0
    phase     gas;
}
