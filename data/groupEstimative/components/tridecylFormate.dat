/*--------------------------------*- Choupo -*-----------------------*\
  Component: tridecyl formate  (C14H28O2, CAS 42875-41-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H28O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tridecylFormate;
formula     C14H28O2;
CAS         42875-41-2;
InChIKey    WZHQGBLYYBBXAJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          228.376;      // g/mol [origin=calculated method=formula-sum]
Tc          654.43;      // K   [origin=predictive method=joback]
Pc          15.379;      // bar [origin=predictive method=joback]
omega       0.6140;      // -   [origin=predictive method=lee-kesler]
Tb          496.34;      // K   [origin=predictive method=joback]
HvapTb      44385.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.338 1.34192 -0.0008908 2.521e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridecyl methanoate" "agn-pc-00k6ov" );
gibbsFormation
{
    dHf_298   -255840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     884.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110960.0
    phase     gas;
}
