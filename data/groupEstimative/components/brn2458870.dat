/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2458870  (C12H16N2O2, CAS 25439-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2458870;
formula     C12H16N2O2;
CAS         25439-20-7;
InChIKey    OZTTXCISDPJUDI-UHFFFAOYSA-N;
MW          220.272;      // g/mol [origin=calculated method=formula-sum]
Tc          883.40;      // K   [origin=predictive method=joback]
Pc          27.643;      // bar [origin=predictive method=joback]
omega       0.9909;      // -   [origin=predictive method=lee-kesler]
Tb          671.19;      // K   [origin=predictive method=joback]
HvapTb      66553.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.108 1.20904 -0.000784 1.8692e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group CONHCH2; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 2; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[2-(dimethylamino)-2-oxidanylidene-ethyl]-2-phenyl-ethanamide" "benzeneacetamide,n-[2-(dimethylamino)-2-oxoethyl]-" "n-[2-(dimethylamino)-2-oxoethyl]-2-phenylacetamide" "acetamide,n,n-dimethyl-2-(2-phenylacetamido)- (8ci)" "n,n-dimethyl-2-[(2-phenylacetyl)amino]acetamide" );
gibbsFormation
{
    dHf_298   -158640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104900.0
    phase     gas;
}
