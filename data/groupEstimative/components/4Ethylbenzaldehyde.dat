/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethylbenzaldehyde  (C9H10O, CAS 4748-78-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H10O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Ethylbenzaldehyde;
formula     C9H10O;
CAS         4748-78-1;
InChIKey    QNGNSVIICDLXHT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          134.178;      // g/mol [origin=calculated method=formula-sum]
Tc          620.85;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       0.2940;      // -   [origin=predictive method=lee-kesler]
Tb          413.60;      // K   [origin=predictive method=joback]
HvapTb      36193.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.399 0.72852 -0.00058296 1.932e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-ethylbenzaldehyde" "benzaldehyde, 4-ethyl-" "benzaldehyde, ethyl-" "4-ethyl-benzaldehyde" "ethyl benzaldehyde" "ethylbenzaldehyde, p-" "p-ethylbenzaldehyde, d" "benzaldehyde, p-ethyl-" "benzaldehyde,4-ethyl" );
gibbsFormation
{
    dHf_298   72420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=171640.0
    phase     gas;
}
