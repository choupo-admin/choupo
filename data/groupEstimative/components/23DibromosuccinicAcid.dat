/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dibromosuccinic acid  (C4H4Br2O4, CAS 526-78-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DibromosuccinicAcid;
formula     C4H4Br2O4;
CAS         526-78-3;
InChIKey    FJWGRXKOBIVTFA-UHFFFAOYSA-N;
MW          275.88;      // g/mol [origin=calculated method=formula-sum]
Tc          955.73;      // K   [origin=predictive method=joback]
Pc          62.000;      // bar [origin=predictive method=joback]
omega       1.3058;      // -   [origin=predictive method=lee-kesler]
Tb          713.58;      // K   [origin=predictive method=joback]
HvapTb      70920.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.47 0.5736 -0.0004882 1.596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group COOH; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group Br; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(bromanyl)butanedioic acid" "2,3-dibromobutanedioic acid" "butanedioic acid, 2,3-dibromo-" "2,3-dibromosuccinicacid" "sym.-dibromosuccinic acid" "succinic acid,3-dibromo-" "2,3-dibromo succinic acid" "butanedioic acid,3-dibromo-" "2,3-dibromo-butanedioic acid" "alpha,beta-dibromosuccinic acid" "succinic acid, 2,3-dibromo-" "butanedioicacid, 2,3-dibromo-" );
standardThermochemistry
{
    dHf_298   -784330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-681260.0
}
