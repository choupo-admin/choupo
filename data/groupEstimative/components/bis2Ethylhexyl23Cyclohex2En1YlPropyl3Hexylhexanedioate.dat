/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-ethylhexyl) 2-[3-(cyclohex-2-en-1-yl)propyl]-3-hexylhexanedioate  (C37H68O4, CAS 67844-46-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2Ethylhexyl23Cyclohex2En1YlPropyl3Hexylhexanedioate;
formula     C37H68O4;
CAS         67844-46-6;
InChIKey    DVFSRCNTNCWQSO-UHFFFAOYSA-N;
MW          576.947;      // g/mol [origin=calculated method=formula-sum]
Tc          1508.26;      // K   [origin=predictive method=joback]
Pc          4.967;      // bar [origin=predictive method=joback]
omega       0.0551;      // -   [origin=predictive method=lee-kesler]
Tb          1179.55;      // K   [origin=predictive method=joback]
HvapTb      111939.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.48 3.499 -0.00188088 3.267e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 22; } { group CH; count 5; } { group CH=CH; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 20; } { group CH; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-ethylhexyl) 2-(3-cyclohex-2-en-1-ylpropyl)-3-hexyl-hexanedioate" "2-cyclohexene-1-octanoic acid, 5(or 6)-(((2-ethylhexyl)oxy)carbonyl)-4-hexyl-, 2-ethylhexyl ester" "2-ethylhexyl 5(or 6)-(((2-ethylhexyl)oxy)carbonyl)-4-hexyl-2-cyclohexene-1-octanoate" "2-ethylhexyl 5(or 6)-[[(2-ethylhexyl)oxy]carbonyl]-4-hexyl-2-cyclohexene-1-octanoate" "2-cyclohexene-1-octanoic acid, 5(or 6)-[[(2-ethylhexyl)oxy]carbonyl]-4-hexyl-, 2-ethylhexyl ester" "bis(2-ethylhexyl) 2-(3-cyclohex-2-en-1-ylpropyl)-3-hexylhexanedioate" "2-ethylhexyl 5(or 6)-(((2-ethylhexyl)oxy)carbonyl)-4-hexylcyclohex-2-ene-1-octanoate" "5(6)-carboxy-4-hexyl-2-cyclohexene-1-octanoic acid, bis(2-ethylhexyl) ester" );
gibbsFormation
{
    dHf_298   -1350590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1593.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-315430.0
    phase     gas;
}
