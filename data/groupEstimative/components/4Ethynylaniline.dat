/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethynylaniline  (C8H7N, CAS 14235-81-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethynylaniline;
formula     C8H7N;
CAS         14235-81-5;
InChIKey    JXYITCJMBRETQX-UHFFFAOYSA-N;
MW          117.151;      // g/mol [origin=calculated method=formula-sum]
Tc          719.31;      // K   [origin=predictive method=joback]
Pc          46.593;      // bar [origin=predictive method=joback]
omega       0.3898;      // -   [origin=predictive method=lee-kesler]
Tb          476.95;      // K   [origin=predictive method=joback]
HvapTb      46839.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.72 0.5934 -0.00041489 1.1399e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-aminophenylacetylene" "1-amino-4-ethynylbenzene" "p-apac" "benzenamine, 4-ethynyl-" "(4-ethynyl-phenyl)-amine" "4-h2n-c6h4-cch" "e104" "aniline,p-ethynyl- (6ci,7ci,8ci);(4-ethynylphenyl)amine;1-amino-4-ethynylbenzene;4-amino-1-ethynylbenzene;4-aminophenylacetylene;p-ethynylaniline;4-ethynylbenzenamine;p-apac;p-aminophenylacetylene;" );
gibbsFormation
{
    dHf_298   342300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=408780.0
    phase     gas;
}
