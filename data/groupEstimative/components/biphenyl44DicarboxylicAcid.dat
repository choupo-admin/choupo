/*--------------------------------*- Choupo -*-----------------------*\
  Component: biphenyl-4,4'-dicarboxylic acid  (C14H10O4, CAS 787-70-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        biphenyl44DicarboxylicAcid;
formula     C14H10O4;
CAS         787-70-2;
InChIKey    NEQFBGHQPUXOFH-UHFFFAOYSA-N;
MW          242.23;      // g/mol [origin=calculated method=formula-sum]
Tc          1126.33;      // K   [origin=predictive method=joback]
Pc          32.579;      // bar [origin=predictive method=joback]
omega       1.3147;      // -   [origin=predictive method=lee-kesler]
Tb          874.26;      // K   [origin=predictive method=joback]
HvapTb      86962.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.85 1.1586 -0.00081132 2.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-carboxyphenyl)benzoic acid" "4,4'-biphenyldicarboxylic acid" "4,4'-bibenzoic acid" "4,4'-diphenic acid" "p,p'-diphenic acid" "4,4'-dicarboxybiphenyl" "[1,1'-biphenyl]-4,4'-dicarboxylic acid" "usaf do-69" "bibenzoic acid" "4,4'-dibenzoic acid" "4,4'-biphenyl dicarboxylic acid" "(1,1'-biphenyl)-4,4'-dicarboxylic acid" );
gibbsFormation
{
    dHf_298   -582710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-415260.0
    phase     gas;
}
