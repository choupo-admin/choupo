/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,9,12-tripropylheptadecane  (C26H54, CAS 15874-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6912Tripropylheptadecane;
formula     C26H54;
CAS         15874-06-3;
InChIKey    UCZYIEWSWYMYBM-UHFFFAOYSA-N;
MW          366.718;      // g/mol [origin=calculated method=formula-sum]
Tc          971.66;      // K   [origin=predictive method=joback]
Pc          7.344;      // bar [origin=predictive method=joback]
omega       0.6812;      // -   [origin=predictive method=lee-kesler]
Tb          793.16;      // K   [origin=predictive method=joback]
HvapTb      72306.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.792 2.4916 -0.0014002 2.967e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 18; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 18; } { group CH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptadecane, 6,9,12-tripropyl-" "heptadecane, 6,9,12-tripropyl-," );
standardThermochemistry
{
    dHf_298   -595810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1140.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160720.0
}
