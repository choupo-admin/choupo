/*--------------------------------*- Choupo -*-----------------------*\
  Component: octachlorostyrene  (C8Cl8, CAS 29082-74-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octachlorostyrene;
formula     C8Cl8;
CAS         29082-74-4;
InChIKey    RUYUCCQRWINUHE-UHFFFAOYSA-N;
MW          379.688;      // g/mol [origin=calculated method=formula-sum]
Tc          1006.09;      // K   [origin=predictive method=joback]
Pc          25.925;      // bar [origin=predictive method=joback]
omega       0.6747;      // -   [origin=predictive method=lee-kesler]
Tb          737.58;      // K   [origin=predictive method=joback]
HvapTb      74186.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (122.77 0.4616 -0.000359 1.08e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group ACCl; count 5; } { group Cl_C=C_; count 3; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC; count 2; } { group dC_ring; count 6; } { group Cl; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(chloranyl)-6-[1,2,2-tris(chloranyl)ethenyl]benzene" "benzene, pentachloro(trichloroethenyl)-" "styrene, octachloro-" "trichlorovinylpentachlorobenzene" "1,2,3,4,5-pentachloro-6-(trichloroethenyl)benzene" "octachlorostyrene solution" "polychlorinated styrene" "1,2,3,4,5-pentachloro-6-(trichlorovinyl)benzene" "1,2,3,4,5-pentachloro-6-(1,2,2-trichloroethenyl)benzene" "benzene,1,2,3,4,5-pentachloro-6-(1,2,2-trichloroethenyl)-" "benzene,pentachloro(trichloroethenyl)- (9ci); styrene, octachloro- (7ci,8ci); ocs;octachlorostyrene; octachlorostyrol; perchlorostyrene;trichlorovinylpentachlorobenzene" );
standardThermochemistry
{
    dHf_298   -57550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48420.0
}
