/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dimethoxybenzaldehyde  (C9H10O3, CAS 7311-34-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H10O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        35Dimethoxybenzaldehyde;
formula     C9H10O3;
CAS         7311-34-4;
InChIKey    VFZRZRDOXPRTSC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          669.63;      // K   [origin=predictive method=joback]
Pc          31.883;      // bar [origin=predictive method=joback]
omega       0.4399;      // -   [origin=predictive method=lee-kesler]
Tb          463.42;      // K   [origin=predictive method=joback]
HvapTb      41675.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.9 0.54264 -0.00029392 5.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CHO; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzaldehyde, 3,5-dimethoxy-" "3,5-dimethoxybenzaldehyd" "3,5-dimethoxy-benzaldehyde" "ghl.pd_mitscher_leg0.694" "benzaldehyde, 3,5-dimethoxy-;" "benzaldehyde,5-dimiethoxy" );
gibbsFormation
{
    dHf_298   -203490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-47990.0
    phase     gas;
}
