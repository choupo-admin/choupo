/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentanol, 1-phenyl-  (C11H14O, CAS 10487-96-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentanol1Phenyl;
formula     C11H14O;
CAS         10487-96-4;
InChIKey    ITHZGJVAQFFNCZ-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          811.85;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.7576;      // -   [origin=predictive method=lee-kesler]
Tb          585.66;      // K   [origin=predictive method=joback]
HvapTb      58141.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.2 1.4275 -0.0012962 4.925e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylcyclopentan-1-ol" "1-phenylcyclopentanol-1" "1-phenyl-cyclopentanol" "cyclopentanol,1-phenyl-" "benzene, cyclopent-1-yl-1-ol-" "1-phenyl-1-cyclopentanol" );
standardThermochemistry
{
    dHf_298   -110350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48390.0
}
