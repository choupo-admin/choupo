/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dibutylethylenediamine  (C10H24N2, CAS 3529-09-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDibutylethylenediamine;
formula     C10H24N2;
CAS         3529-09-7;
InChIKey    PWNDYKKNXVKQJO-UHFFFAOYSA-N;
MW          172.316;      // g/mol [origin=calculated method=formula-sum]
Tc          686.13;      // K   [origin=predictive method=joback]
Pc          22.187;      // bar [origin=predictive method=joback]
omega       0.7333;      // -   [origin=predictive method=lee-kesler]
Tb          513.37;      // K   [origin=predictive method=joback]
HvapTb      50538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.402 1.13964 -0.0006762 1.562e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH2NH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n',n'-dibutylethane-1,2-diamine" "2-dibutylaminoethylamine" "2-di-n-butylaminoethylamine" "(2-aminoethyl)dibutylamine" "2-aminoethyl-dibutyl-amine" "2-(dibutylamino)ethylamine" "2-amino-ethyl-dibutyl-amine" "pwndykknxvkqjo-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -148410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=210550.0
}
