/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxybis(2,1-ethanediyloxy-2,1-ethanediyl) bis(3-(4-morpholinyl)propanoate  (C22H40N2O9, CAS 71487-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxybis21Ethanediyloxy21EthanediylBis34MorpholinylPropanoate;
formula     C22H40N2O9;
CAS         71487-08-6;
InChIKey    VPUMVHRPBGQYNP-UHFFFAOYSA-N;
MW          476.567;      // g/mol [origin=calculated method=formula-sum]
Tc          1231.71;      // K   [origin=predictive method=joback]
Pc          11.360;      // bar [origin=predictive method=joback]
omega       1.0755;      // -   [origin=predictive method=lee-kesler]
Tb          1005.34;      // K   [origin=predictive method=joback]
HvapTb      100848.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.378 2.3528 -0.0012138 1.648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH2COO; count 2; } { group CH2O; count 3; } { group FCH2O; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group CH2_ring; count 8; } { group O; count 3; } { group O_ring; count 2; } { group COO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-(3-morpholin-4-ylpropanoyloxy)ethoxy]ethoxy]ethoxy]ethyl 3-morpholin-4-ylpropanoate" "oxybis(2,1-ethanediyloxy-2,1-ethanediyl) bis(3-(4-morpholinyl)propionate" "oxybis(2,1-ethanediyloxy-2,1-ethanediyl) bis[3-(4-morpholinyl)propionate" "4-morpholinepropanoic acid, 4,4'-(oxybis(2,1-ethanediyloxy-2,1-ethanediyl)) ester" "4-morpholinepropanoic acid, 4,4'-[oxybis(2,1-ethanediyloxy-2,1-ethanediyl)] ester" "4-morpholinepropanoic acid, oxybis(2,1-ethanediyloxy-2,1-ethanediyl) ester" );
standardThermochemistry
{
    dHf_298   -1495930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1062.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-663540.0
}
