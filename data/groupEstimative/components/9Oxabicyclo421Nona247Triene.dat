/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-oxabicyclo[4.2.1]nona-2,4,7-triene  (C8H8O, CAS 7140-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Oxabicyclo421Nona247Triene;
formula     C8H8O;
CAS         7140-63-8;
InChIKey    QRZHVKCGHWXXRG-UHFFFAOYSA-N;
MW          120.151;      // g/mol [origin=calculated method=formula-sum]
Tc          659.08;      // K   [origin=predictive method=joback]
Pc          41.516;      // bar [origin=predictive method=joback]
omega       0.3155;      // -   [origin=predictive method=lee-kesler]
Tb          433.36;      // K   [origin=predictive method=joback]
HvapTb      39130.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.57 0.8658 -0.00066054 1.968e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 3; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 6; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-oxabicyclo(4.2.1)nona-2,4,7-triene" );
gibbsFormation
{
    dHf_298   -39990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     183.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105440.0
    phase     gas;
}
