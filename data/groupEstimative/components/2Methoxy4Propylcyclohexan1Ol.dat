/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-4-propylcyclohexan-1-ol  (C10H20O2, CAS 23950-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy4Propylcyclohexan1Ol;
formula     C10H20O2;
CAS         23950-98-3;
InChIKey    FLNSLKJOWVMPEE-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          737.88;      // K   [origin=predictive method=joback]
Pc          25.925;      // bar [origin=predictive method=joback]
omega       0.8392;      // -   [origin=predictive method=lee-kesler]
Tb          553.21;      // K   [origin=predictive method=joback]
HvapTb      56754.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.138 0.99374 -0.0004098 1.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 3; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-4-propyl-cyclohexan-1-ol" "cyclohexanol, 2-methoxy-4-propyl-" "cyclohexanol,2-methoxy-4-propyl-" );
gibbsFormation
{
    dHf_298   -520540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199470.0
    phase     gas;
}
