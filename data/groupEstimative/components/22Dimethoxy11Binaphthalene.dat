/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-dimethoxy-1,1'-binaphthalene  (C22H18O2, CAS 2960-93-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethoxy11Binaphthalene;
formula     C22H18O2;
CAS         2960-93-2;
InChIKey    BJAADAKPADTRCH-UHFFFAOYSA-N;
MW          314.384;      // g/mol [origin=calculated method=formula-sum]
Tc          1110.47;      // K   [origin=predictive method=joback]
Pc          19.372;      // bar [origin=predictive method=joback]
omega       0.9247;      // -   [origin=predictive method=lee-kesler]
Tb          859.04;      // K   [origin=predictive method=joback]
HvapTb      79866.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.61 1.56424 -0.00101868 2.546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 8; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 8; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-1-(2-methoxynaphthalen-1-yl)naphthalene" "(s)-(-)-2,2'-dimethoxy-1,1'-binaphthalene" "(r)-(+)-2,2'-dimethoxy-1,1'-binaphthyl" "2,2'-dimethoxy-1,1'-binaphthyl" "(r)-2,2'-dimethoxy-1,1'-binaphthyl" "(s)-2,2'-dimethoxy-1,1'-binaphthyl" "(s)-1,1'-bi-2-naphthyl dimethyl ether" "(r)-2,2'-dimethoxy-1,1'-binaphthalene" "(s)-1,1'-bi-2-naphthol dimethyl ether" "(s)-2,2'-dimethoxy-1,1'-binaphthalene" "2-methoxy-1-(2-methoxynaphthyl)naphthalene" "(+/-)-1,1'-bi-2-naphthol dimethyl ether" );
standardThermochemistry
{
    dHf_298   47470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=323960.0
}
