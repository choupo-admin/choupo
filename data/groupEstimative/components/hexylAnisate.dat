/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexyl anisate  (C14H20O3, CAS 71607-26-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexylAnisate;
formula     C14H20O3;
CAS         71607-26-6;
InChIKey    DUALVGKOWZJXLR-UHFFFAOYSA-N;
MW          236.311;      // g/mol [origin=calculated method=formula-sum]
Tc          829.38;      // K   [origin=predictive method=joback]
Pc          19.613;      // bar [origin=predictive method=joback]
omega       0.8045;      // -   [origin=predictive method=lee-kesler]
Tb          632.22;      // K   [origin=predictive method=joback]
HvapTb      59513.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.465 1.07744 -0.00049636 4.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexyl 4-methoxybenzoate" "p-methoxybenzoic acid, hexyl ester" "benzoic acid, methoxy-,hexyl ester (9ci)" );
gibbsFormation
{
    dHf_298   -556730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     651.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-245590.0
    phase     gas;
}
