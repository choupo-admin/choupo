/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-diacetyldiphenylethane  (C18H18O2, CAS 793-06-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Diacetyldiphenylethane;
formula     C18H18O2;
CAS         793-06-6;
InChIKey    ZSLCVLSXAOHWBQ-UHFFFAOYSA-N;
MW          266.34;      // g/mol [origin=calculated method=formula-sum]
Tc          1017.01;      // K   [origin=predictive method=joback]
Pc          20.888;      // bar [origin=predictive method=joback]
omega       0.9256;      // -   [origin=predictive method=lee-kesler]
Tb          782.50;      // K   [origin=predictive method=joback]
HvapTb      75030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.968 1.38104 -0.00084632 1.8612e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-[2-(4-ethanoylphenyl)ethyl]phenyl]ethanone" "4,4'-diacetylbibenzyl" "1,1'-(1,2-ethanediyldi-4,1-phenylene)bisethanone" "1,1'-(ethane-1,2-diyldibenzene-4,1-diyl)diethanone" "1-[4-[2-(4-acetylphenyl)ethyl]phenyl]ethanone" "1-{4-[2-(4-acetylphenyl)ethyl]phenyl}ethanone" "1-acetyl-4-[2-(4-acetylphenyl)ethyl]benzene" "1-{4-[2-(4-acetylphenyl)ethyl]phenyl}ethan-1-one" "ethanone, 1,1'-(1,2-ethanediyldi-4,1-phenylene)bis-" "ethanone, 1,1'-(1,2-ethanediyldi-4,1-phenylene)bis- (9ci)" "ethanone,1,1'-(1,2-ethanediyldi-4,1-phenylene)bis- (9ci)" );
standardThermochemistry
{
    dHf_298   -189890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     685.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48400.0
}
