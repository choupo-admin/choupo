/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutane,tetrakis(methylene)-  (C8H8, CAS 3227-91-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobutaneTetrakisMethylene;
formula     C8H8;
CAS         3227-91-6;
InChIKey    GSMUOFYVMIBBMK-UHFFFAOYSA-N;
MW          104.152;      // g/mol [origin=calculated method=formula-sum]
Tc          587.45;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       0.3312;      // -   [origin=predictive method=lee-kesler]
Tb          394.96;      // K   [origin=predictive method=joback]
HvapTb      34432.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.47 0.4616 -0.000271 6.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 4; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetramethylidenecyclobutane" "cyclobutane, tetrakis(methylene)-" );
standardThermochemistry
{
    dHf_298   215490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=285160.0
}
