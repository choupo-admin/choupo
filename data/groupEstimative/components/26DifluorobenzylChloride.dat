/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-difluorobenzyl chloride  (C7H5ClF2, CAS 697-73-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DifluorobenzylChloride;
formula     C7H5ClF2;
CAS         697-73-4;
InChIKey    MJXRENZUAQXZGJ-UHFFFAOYSA-N;
MW          162.563;      // g/mol [origin=calculated method=formula-sum]
Tc          631.43;      // K   [origin=predictive method=joback]
Pc          33.960;      // bar [origin=predictive method=joback]
omega       0.4147;      // -   [origin=predictive method=lee-kesler]
Tb          432.37;      // K   [origin=predictive method=joback]
HvapTb      37527.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.291 0.5013 -0.00030732 6.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CH2Cl; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(chloromethyl)-1,3-bis(fluoranyl)benzene" "2-(chloromethyl)-1,3-difluorobenzene" "2,6-difluorobenzylchloride" "alpha-chloro-2,6-difluorotoluene" "2, 6-difluorobenzyl chloride" "2-(chlormethyl)-1,3-difluorbenzol" "benzene, 2-(chloromethyl)-1,3-difluoro-" "697-73-4 2,6-difluorobenzyl chloride" "1-chloromethyl-2,6-difluorobenzene" "2,6-difluoro benzyl chloride" "d194" "p359" );
standardThermochemistry
{
    dHf_298   -382180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-300340.0
}
