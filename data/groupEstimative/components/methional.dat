/*--------------------------------*- Choupo -*-----------------------*\
  Component: methional  (C4H8OS, CAS 3268-49-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methional;
formula     C4H8OS;
CAS         3268-49-3;
InChIKey    CLUWOWRTHNNBBU-UHFFFAOYSA-N;
MW          104.167;      // g/mol [origin=calculated method=formula-sum]
Tc          608.16;      // K   [origin=predictive method=joback]
Pc          43.800;      // bar [origin=predictive method=joback]
omega       0.4247;      // -   [origin=predictive method=lee-kesler]
Tb          408.56;      // K   [origin=predictive method=joback]
HvapTb      38035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.252 0.35271 -0.0001466 6.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CHO; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group OdCH_al; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylsulfanylpropanal" "3-(Methylmercapto)propanal" "3-(Methylmercapto)propionaldehyde" "3-(Methylthio)propanal" "3-(Methylthio)propionaldehyde" "3-methylsulfanylpropionaldehyde" "3-methylthio-1-propanal" "3-methylthiopropan-1-one" "3-methylthiopropanaldehyde" "Propanal, 3-(methylthio)-" "Propionaldehyde, 3-(methylthio)-" "β-(methylmercapto)propionaldehyde" );
gibbsFormation
{
    dHf_298   -169600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83600.0
    phase     gas;
}
