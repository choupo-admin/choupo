/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl isonipecotate  (C7H13NO2, CAS 2971-79-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylIsonipecotate;
formula     C7H13NO2;
CAS         2971-79-1;
InChIKey    RZVWBASHHLFBJF-UHFFFAOYSA-N;
MW          143.186;      // g/mol [origin=calculated method=formula-sum]
Tc          703.74;      // K   [origin=predictive method=joback]
Pc          36.509;      // bar [origin=predictive method=joback]
omega       0.4862;      // -   [origin=predictive method=lee-kesler]
Tb          486.08;      // K   [origin=predictive method=joback]
HvapTb      45770.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.75 0.72272 -0.0002828 -8.3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2NH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group COO; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl piperidine-4-carboxylate" "methyl 4-piperidinecarboxylate" "4-piperidinecarboxylic acid methyl ester" "piperidine-4-carboxylic acid methyl ester" "4-piperidinecarboxylic acid, methyl ester" "isonipecotic acid methyl ester" "methyl 4-piperidinecarboxylate hydrochloride" "methyl piperidin-4-carboxylate" "methylpiperidine-4-carboxylate" "isonipecotic acid, methyl and ethyl esters" "4-piperdinecarboxylic acid, methyl ester" );
standardThermochemistry
{
    dHf_298   -412960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-190150.0
}
