/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3,3-dimethylallyl)cyclazocine  (C19H27NO, CAS 359-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        233DimethylallylCyclazocine;
formula     C19H27NO;
CAS         359-83-1;
InChIKey    VOKSWYLNZZRQPF-NIKGAXFTSA-N;
MW          285.431;      // g/mol [origin=calculated method=formula-sum]
Tc          1002.35;      // K   [origin=predictive method=joback]
Pc          19.753;      // bar [origin=predictive method=joback]
omega       0.8993;      // -   [origin=predictive method=lee-kesler]
Tb          772.13;      // K   [origin=predictive method=joback]
HvapTb      74287.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-212.009 2.53608 -0.00234662 9.036e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "fortalin" "fortral" "sosegon" "sosigon" "talwin" "lexir" "pentazocina [dcit]" "(-)-pentazocine" "pentazocinum [inn-latin]" "ii-c-2" "pentazocine [usan:inn:ban:jan]" "rel-pentazocine" );
standardThermochemistry
{
    dHf_298   -72280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     661.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=348010.0
}
