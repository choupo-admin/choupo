/*--------------------------------*- Choupo -*-----------------------*\
  Component: ether, allyl tert-butyl  (C7H14O, CAS 1471-04-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        etherAllylTertButyl;
formula     C7H14O;
CAS         1471-04-1;
InChIKey    FHVRTMVXBVDWCK-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          554.66;      // K   [origin=predictive method=joback]
Pc          29.345;      // bar [origin=predictive method=joback]
omega       0.3090;      // -   [origin=predictive method=lee-kesler]
Tb          375.63;      // K   [origin=predictive method=joback]
HvapTb      31620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.439 0.71146 -0.0004407 1.066e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-2-prop-2-enoxy-propane" "1-propene, 3-(1,1-dimethylethoxy)-" "2-methyl-2-prop-2-enoxypropane" );
standardThermochemistry
{
    dHf_298   -203350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6260.0
}
