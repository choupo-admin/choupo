/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propylpiperazine  (C7H16N2, CAS 21867-64-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propylpiperazine;
formula     C7H16N2;
CAS         21867-64-1;
InChIKey    QLEIDMAURCRVCX-UHFFFAOYSA-N;
MW          128.219;      // g/mol [origin=calculated method=formula-sum]
Tc          641.76;      // K   [origin=predictive method=joback]
Pc          36.553;      // bar [origin=predictive method=joback]
omega       0.4578;      // -   [origin=predictive method=lee-kesler]
Tb          440.70;      // K   [origin=predictive method=joback]
HvapTb      40543.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.668 0.93752 -0.0005918 1.443e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propylpiperazine" "1-propylpiperazine dihydrochloride" "1-propylpiperazine hcl" "n-propylpiperazine" "n-propylpiperazine;" "1-propyl-piperazine" "1-n-propylpiperazine" "piperazine, 1-propyl-" "qleidmaurcrvcx-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -1650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=250810.0
    phase     gas;
}
