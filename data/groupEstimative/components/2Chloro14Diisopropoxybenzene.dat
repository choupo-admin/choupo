/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-1,4-diisopropoxybenzene  (C12H17ClO2, CAS 61886-39-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro14Diisopropoxybenzene;
formula     C12H17ClO2;
CAS         61886-39-3;
InChIKey    KHJPWDHXQSXQRM-UHFFFAOYSA-N;
MW          228.716;      // g/mol [origin=calculated method=formula-sum]
Tc          803.02;      // K   [origin=predictive method=joback]
Pc          22.166;      // bar [origin=predictive method=joback]
omega       0.6307;      // -   [origin=predictive method=lee-kesler]
Tb          592.19;      // K   [origin=predictive method=joback]
HvapTb      54335.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.2 0.83818 -0.00033092 5.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 3; } { group AC; count 2; } { group CH-O; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-1,4-di(propan-2-yloxy)benzene" "2-chloro-1,4-bis(1-methylethoxy)benzene" "benzene, 2-chloro-1,4-bis(1-methylethoxy)-" "2-chloro-1,4-di(propan-2-yloxy)benzene" "benzene,2-chloro-1,4-bis(1-methylethoxy)-" "2-chloro-1,4-bis(1-methylethoxy)benzene;2-chloro-para-diisopropoxybenzene" );
gibbsFormation
{
    dHf_298   -368160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83500.0
    phase     gas;
}
