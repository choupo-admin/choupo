/*--------------------------------*- Choupo -*-----------------------*\
  Component: viridiflorol  (C15H26O, CAS 552-02-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        viridiflorol;
formula     C15H26O;
CAS         552-02-3;
InChIKey    AYXPYQRXGNDJFU-OMDCQRFSSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          851.69;      // K   [origin=predictive method=joback]
Pc          21.276;      // bar [origin=predictive method=joback]
omega       0.8086;      // -   [origin=predictive method=lee-kesler]
Tb          645.54;      // K   [origin=predictive method=joback]
HvapTb      62208.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-242.65 2.37418 -0.002234 8.984e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 5; } { group C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 5; } { group C_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1ar,4s,4as,7r,7as)-1,1,4,7-tetramethyl-2,3,4a,5,6,7,7a,7b-octahydro-1ah-cyclopropa[e]azulen-4-ol" "d-viridiflorol" "(1ar-(1aalpha,4beta,4abeta,7alpha,7abeta,7balpha))-decahydro-1,1,4,7-tetramethyl-1h-cycloprop(e)azulen-4-ol" "1h-cycloprop(e)azulen-4-ol, decahydro-1,1,4,7-tetramethyl-, (1ar-(1aalpha,4beta,4abeta,7alpha,7abeta,7balpha))-" "1h-cycloprop[e]azulen-4-ol, decahydro-1,1,4,7-tetramethyl-, [1ar-(1a?,4ss,4ass ,7?,7ass,7b?)]-" );
gibbsFormation
{
    dHf_298   -349960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54830.0
    phase     gas;
}
