/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromoacetaldehyde  (C2H3BrO, CAS 17157-48-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromoacetaldehyde;
formula     C2H3BrO;
CAS         17157-48-1;
InChIKey    NMPVEAUIHMEAQP-UHFFFAOYSA-N;
MW          122.949;      // g/mol [origin=calculated method=formula-sum]
Tc          556.92;      // K   [origin=predictive method=joback]
Pc          62.294;      // bar [origin=predictive method=joback]
omega       0.3847;      // -   [origin=predictive method=lee-kesler]
Tb          360.18;      // K   [origin=predictive method=joback]
HvapTb      33201.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.661 0.2065 -0.0001494 4.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CHO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group Br; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylethanal" "2-bromoacetaldehyde" "acetaldehyde, bromo-" "bromo-acetaldehyde" "monobromoacetaldehyde" "2-bromo-acetaldehyde" "acetaldehyde, bromo-(6ci,7ci,8ci,9ci)" "2-bromoacetaldehyde;bromoacetaldehyde; monobromoacetaldehyde; a-bromoacetaldehyde" );
gibbsFormation
{
    dHf_298   -143860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     303.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-119240.0
    phase     gas;
}
