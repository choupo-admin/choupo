/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-hexadecyl-2-hydroxybenzoic acid  (C23H38O3, CAS 28294-58-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Hexadecyl2HydroxybenzoicAcid;
formula     C23H38O3;
CAS         28294-58-8;
InChIKey    VCLDAIPENLEIRV-UHFFFAOYSA-N;
MW          362.554;      // g/mol [origin=calculated method=formula-sum]
Tc          1204.54;      // K   [origin=predictive method=joback]
Pc          12.124;      // bar [origin=predictive method=joback]
omega       1.1405;      // -   [origin=predictive method=lee-kesler]
Tb          983.63;      // K   [origin=predictive method=joback]
HvapTb      99908.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.945 2.25582 -0.00152052 4.242e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-hexadecyl-2-oxidanyl-benzoic acid" "benzoic acid, 5-hexadecyl-2-hydroxy-" "5-hexadecylsalicylic acid" "benzoic acid,5-hexadecyl-2-hydroxy-" "salicylicacid, 5-hexadecyl- (8ci); 5-hexadecylsalicylic acid" );
gibbsFormation
{
    dHf_298   -820570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1018.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-252970.0
    phase     gas;
}
