/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-norbornanediol  (C7H12O2, CAS 21462-09-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Norbornanediol;
formula     C7H12O2;
CAS         21462-09-9;
InChIKey    YHUQPGPXJUVMNN-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          735.21;      // K   [origin=predictive method=joback]
Pc          45.225;      // bar [origin=predictive method=joback]
omega       1.1867;      // -   [origin=predictive method=lee-kesler]
Tb          552.53;      // K   [origin=predictive method=joback]
HvapTb      63914.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.62 0.976 -0.000701 2.04e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 4; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 4; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.1]heptane-2,5-diol" "bicyclo(2.2.1)heptane-2,5-diol" "norbornane-2,5-diol" );
gibbsFormation
{
    dHf_298   -393510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     285.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-171600.0
    phase     gas;
}
