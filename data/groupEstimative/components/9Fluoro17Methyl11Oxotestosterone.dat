/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-fluoro-17-methyl-11-oxotestosterone  (C20H27FO3, CAS 465-69-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Fluoro17Methyl11Oxotestosterone;
formula     C20H27FO3;
CAS         465-69-0;
InChIKey    YUMWOIMGKYOLOA-MWTXUKJESA-N;
MW          334.431;      // g/mol [origin=calculated method=formula-sum]
Tc          1175.52;      // K   [origin=predictive method=joback]
Pc          19.912;      // bar [origin=predictive method=joback]
omega       1.1542;      // -   [origin=predictive method=lee-kesler]
Tb          928.36;      // K   [origin=predictive method=joback]
HvapTb      80714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-323.63 3.16776 -0.00321164 1.3788e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 2; } { group C; count 3; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 2; } { group CF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group C_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group F; count 1; } { group OH; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,9r,10s,13s,14s,17s)-9-fluoranyl-10,13,17-trimethyl-17-oxidanyl-2,6,7,8,12,14,15,16-octahydro-1h-cyclopenta[a]phenanthrene-3,11-dione" "testosterone, 9-fluoro-17-methyl-11-oxo-" "9alpha-fluoro-17alpha-methyl-17-hydroxy-4-androstene-3,11-dione" "androst-4-ene-3,11-dione, 9-fluoro-17" "a-hydroxy-17-methyl-" "androst-4-ene-3,11-dione, 9-fluoro-17beta-hydroxy-17-methyl-" "9-alpha-fluoro-17-alpha-methyl-17-hydroxy-4-androstene-3,11-dione" "androst-4-ene-3,11-dione, 9-fluoro-17-beta-hydroxy-17-methyl-" "9-fluoro-17-methyl-11-oxo-testosterone" "9 alpha-fluoro-11-keto-17 alpha-methyltestosterone" "androst-4-ene-3, 9-fluoro-17.beta.-hydroxy-17-methyl-" "androst-4-ene-3, 9-fluoro-17-hydroxy-17-methyl-, (17.beta.)-" "9alpha-fluoro-17beta-hydroxy-17alpha-methylandrost-4-ene-3,11-dione" );
gibbsFormation
{
    dHf_298   -752880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     748.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-293840.0
    phase     gas;
}
