/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-(4-methoxyphenyl)propanoate  (C11H14O3, CAS 15823-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl34MethoxyphenylPropanoate;
formula     C11H14O3;
CAS         15823-04-8;
InChIKey    AKQLYAFBUYHFCK-UHFFFAOYSA-N;
MW          194.23;      // g/mol [origin=calculated method=formula-sum]
Tc          769.30;      // K   [origin=predictive method=joback]
Pc          25.767;      // bar [origin=predictive method=joback]
omega       0.6667;      // -   [origin=predictive method=lee-kesler]
Tb          563.58;      // K   [origin=predictive method=joback]
HvapTb      52835.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.192 0.79244 -0.00033316 8.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-(4-methoxyphenyl)propionate" "methyl p-methoxyhydrocinnamate" "benzenepropanoic acid, 4-methoxy-, methyl ester" "hydrocinnamic acid, p-methoxy-, methyl ester" "methyl 4-methoxyphenylpropionate" "methyl 3-(p-methoxyphenyl)-propionate" "benzenepropanoic acid,4-methoxy-, methyl ester" );
gibbsFormation
{
    dHf_298   -494810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-270850.0
    phase     gas;
}
