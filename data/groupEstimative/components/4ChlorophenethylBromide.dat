/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorophenethyl bromide  (C8H8BrCl, CAS 6529-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorophenethylBromide;
formula     C8H8BrCl;
CAS         6529-53-9;
InChIKey    YAFMYKFAUNCQPU-UHFFFAOYSA-N;
MW          219.506;      // g/mol [origin=calculated method=formula-sum]
Tc          753.22;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       0.4718;      // -   [origin=predictive method=lee-kesler]
Tb          517.89;      // K   [origin=predictive method=joback]
HvapTb      47160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.908 0.6704 -0.00046736 1.277e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCl; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-bromoethyl)-4-chloranyl-benzene" "1-(2-bromoethyl)-4-chlorobenzene" "2-(4-chlorophenyl)ethylbromide" "p-chloro-.beta.-phenethyl bromide" "1-chloro-4-(2-bromoethyl)benzene" "4-chloro-1-(2-bromoethyl)benzene" "benzene, 1-(2-bromoethyl)-4-chloro-" "1-bromo-2-(4-chlorophenyl)ethane" "4-chlorophenethylbromide" "1-(2-bromo-ethyl)-4-chloro-benzene" "benzene,1-(2-bromoethyl)-4-chloro-" "1-(2-bromoethyl)-4-chlorobenzene;1-bromo-2-(4-chlorophenyl)ethane;1-chloro-4-(2-bromoethyl)benzene;2-(4-chlorophenyl)ethyl bromide;2-(p-chlorophenyl)ethyl bromide;4-chlorophenethyl bromide;p-chloro-b-phenethyl bromide;p-chlorophenethyl bromide;4-chloro-1-(2-bromoethyl)benzene;" );
gibbsFormation
{
    dHf_298   27200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=121650.0
    phase     gas;
}
