/*--------------------------------*- Choupo -*-----------------------*\
  Component: undecanenitrile  (C11H21N, CAS 2244-07-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        undecanenitrile;
formula     C11H21N;
CAS         2244-07-7;
InChIKey    SZKKNEOUHLFYNA-UHFFFAOYSA-N;
MW          167.296;      // g/mol [origin=calculated method=formula-sum]
Tc          732.97;      // K   [origin=predictive method=joback]
Pc          18.920;      // bar [origin=predictive method=joback]
omega       0.7063;      // -   [origin=predictive method=lee-kesler]
Tb          553.36;      // K   [origin=predictive method=joback]
HvapTb      50558.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.889 0.98362 -0.0005436 1.134e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyanodecane" "decyl cyanide" "n-decyl cyanide" );
standardThermochemistry
{
    dHf_298   -105490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=174920.0
}
