/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-tribromophenol  (C6H3Br3O, CAS 118-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Tribromophenol;
formula     C6H3Br3O;
CAS         118-79-6;
InChIKey    BSWWXRFVMJHFBN-UHFFFAOYSA-N;
MW          330.801;      // g/mol [origin=calculated method=formula-sum]
Tc          935.28;      // K   [origin=predictive method=joback]
Pc          77.353;      // bar [origin=predictive method=joback]
omega       0.8614;      // -   [origin=predictive method=lee-kesler]
Tb          652.62;      // K   [origin=predictive method=joback]
HvapTb      64869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.78 0.6451 -0.00067028 2.713e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-tris(bromanyl)phenol" "tribromophenol" "bromkal pur 3" "bromol" "phenol, 2,4,6-tribromo-" "xeroform" "flammex 3bp" "ta 10" "bismuth tribromophenate" "2,4,6-tbp" "2,6-tribromophenol" "phenol,4,6-tribromo-" );
gibbsFormation
{
    dHf_298   -51900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18870.0
    phase     gas;
}
