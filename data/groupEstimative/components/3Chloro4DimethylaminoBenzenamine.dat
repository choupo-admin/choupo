/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-4-(dimethylamino)benzenamine  (C8H11ClN2, CAS 6085-59-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro4DimethylaminoBenzenamine;
formula     C8H11ClN2;
CAS         6085-59-2;
InChIKey    AMQHNJUMJKWREE-UHFFFAOYSA-N;
MW          170.64;      // g/mol [origin=calculated method=formula-sum]
Tc          768.87;      // K   [origin=predictive method=joback]
Pc          35.986;      // bar [origin=predictive method=joback]
omega       0.5865;      // -   [origin=predictive method=lee-kesler]
Tb          541.68;      // K   [origin=predictive method=joback]
HvapTb      54071.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.0 0.75854 -0.00048492 1.171e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CH3N; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n1,n1-dimethyl-benzene-1,4-diamine" "2-chloro-1-n,1-n-dimethylbenzene-1,4-diamine" "3-chloro-4-(dimethylamino)aniline" "1,4-benzenediamine, 2-chloro-n1,n1-dimethyl-" "(4-amino-2-chlorophenyl)dimethylamine" "2-chloro-n1,n1-dimethylbenzene-1,4-diamine" "n-(4-amino-2-chlorophenyl)-n,n-dimethylamine" "2-chloro-n~1~,n~1~-dimethylbenzene-1,4-diamine" "1,4-benzenediamine, 2-chloro-n~1~,n~1~-dimethyl-" "p-phenylenediamine,2-chloro-n1,n1-dimethyl- (6ci,7ci,8ci); 2-chloro-4-amino-n,n-dimethylaniline;3-chloro-4-(dimethylamino)aniline" );
gibbsFormation
{
    dHf_298   90720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=274930.0
    phase     gas;
}
