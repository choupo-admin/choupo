/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, 4-biphenylyltriphenyl-  (C30H24Si, CAS 3172-34-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C30H24Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silane4Biphenylyltriphenyl;
formula     C30H24Si;
CAS         3172-34-7;
InChIKey    KIKBAQXCRQQWGH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          412.607;      // g/mol [origin=calculated method=formula-sum]
Tc          1320.44;      // K   [origin=predictive method=joback]
Pc          15.046;      // bar [origin=predictive method=joback]
omega       0.7893;      // -   [origin=predictive method=lee-kesler]
Tb          1025.78;      // K   [origin=predictive method=joback]
HvapTb      94710.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.79 2.1936 -0.00128236 2.312e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 24; } { group AC; count 6; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 24; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triphenyl-(4-phenylphenyl)silane" "triphenyl(biphenyl)silane" "1,1'-biphenyl, 4-(triphenylsilyl)-" "silane, (1,1'-biphenyl)-4-yltriphenyl-" "silane, [1,1'-biphenyl]-4-yltriphenyl-" "triphenyl-p-biphenyl-silane" "biphenyl-4-yltriphenylsilane" "biphenyl-4-yl(triphenyl)silane" "silane, 4-biphenylyltriphenyl- (8ci)" );
gibbsFormation
{
    dHf_298   397030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     912.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=649380.0
    phase     gas;
}
