/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-butanetetracarboxylic acid  (C8H10O8, CAS 1703-58-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234ButanetetracarboxylicAcid;
formula     C8H10O8;
CAS         1703-58-8;
InChIKey    GGAUUQHSCNMCAU-UHFFFAOYSA-N;
MW          234.16;      // g/mol [origin=calculated method=formula-sum]
Tc          1193.29;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       1.9921;      // -   [origin=predictive method=lee-kesler]
Tb          963.80;      // K   [origin=predictive method=joback]
HvapTb      101282.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.652 0.9788 -0.0007082 1.95e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 2; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,2,3,4-tetracarboxylic acid" "ggauuqhscnmcau-uhfffaoysa-" "1,3,4-butanetetracarboxylic acid" "k844" "meso-1,2,3,4-butanetetracarboxylic acid" "1,2,3,4-butanetetracarboxylicacid (8ci)" "1,2,3,4-butanetetracarboxylic acid (8ci) (9ci)" "1,2,3,4-tetracarboxybutane;butanetetracarboxylic acid;butane-1,2,3,4-tetracarboxylic acid;" );
gibbsFormation
{
    dHf_298   -1620090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     661.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1364040.0
    phase     gas;
}
