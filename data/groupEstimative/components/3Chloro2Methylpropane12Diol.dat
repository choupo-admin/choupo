/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-2-methylpropane-1,2-diol  (C4H9ClO2, CAS 597-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro2Methylpropane12Diol;
formula     C4H9ClO2;
CAS         597-33-1;
InChIKey    AVVXLRRTQZKHSP-UHFFFAOYSA-N;
MW          124.564;      // g/mol [origin=calculated method=formula-sum]
Tc          682.78;      // K   [origin=predictive method=joback]
Pc          48.494;      // bar [origin=predictive method=joback]
omega       1.1632;      // -   [origin=predictive method=lee-kesler]
Tb          509.68;      // K   [origin=predictive method=joback]
HvapTb      60945.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.748 0.58442 -0.0004468 1.369e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group OH; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group Cl; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-2-methyl-propane-1,2-diol" "1,2-propanediol, 3-chloro-2-methyl-" "3-chloro-2-methyl-1,2-propanediol" "1,2-propanediol,3-chloro-2-methyl-" );
gibbsFormation
{
    dHf_298   -454840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-299930.0
    phase     gas;
}
