/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 2-ethenyl-1,3-dimethyl-  (C10H12, CAS 2039-90-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene2Ethenyl13Dimethyl;
formula     C10H12;
CAS         2039-90-9;
InChIKey    OWRKXOZFTROHSH-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          673.72;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.3651;      // -   [origin=predictive method=lee-kesler]
Tb          461.72;      // K   [origin=predictive method=joback]
HvapTb      40784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.5 0.73594 -0.00044022 1.009e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethenyl-1,3-dimethyl-benzene" "styrene, 2,6-dimethyl-" "2,6-dimethylstyrene" "1,3-dimethyl-2-vinylbenzene" "ambap2039-90-9" "2-ethenyl-1,3-dimethylbenzene" );
standardThermochemistry
{
    dHf_298   89290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=214310.0
}
