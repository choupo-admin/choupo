/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-hydroxyethyl)-n-[2-(stearoylamino)ethyl]glycine  (C24H48N2O4, CAS 139-92-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2HydroxyethylN2StearoylaminoEthylGlycine;
formula     C24H48N2O4;
CAS         139-92-4;
InChIKey    LNOVYKOGIVPBAI-UHFFFAOYSA-N;
MW          428.658;      // g/mol [origin=calculated method=formula-sum]
Tc          1397.45;      // K   [origin=predictive method=joback]
Pc          9.369;      // bar [origin=predictive method=joback]
omega       0.5804;      // -   [origin=predictive method=lee-kesler]
Tb          1102.89;      // K   [origin=predictive method=joback]
HvapTb      118086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.579 2.54072 -0.0015273 3.5106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 19; } { group OH; count 1; } { group CH2N; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 21; } { group OH; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-hydroxyethyl-[2-(octadecanoylamino)ethyl]amino]ethanoic acid" "glycine, n-(2-hydroxyethyl)-n-(2-((1-oxooctadecyl)amino)ethyl)-" "glycine, n-(2-hydroxyethyl)-n-[2-[(1-oxooctadecyl)amino]ethyl]-" "n-(2-hydroxyethyl)-n-(2-((1-oxooctadecyl)amino)ethyl)glycine" "2-[2-hydroxyethyl-[2-(octadecanoylamino)ethyl]amino]acetic acid" );
gibbsFormation
{
    dHf_298   -1032770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1278.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-258280.0
    phase     gas;
}
