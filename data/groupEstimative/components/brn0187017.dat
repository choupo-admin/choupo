/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 0187017  (C17H19NO, CAS 66839-97-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn0187017;
formula     C17H19NO;
CAS         66839-97-2;
InChIKey    XQJLHCHLQCZANH-UHFFFAOYSA-N;
MW          253.345;      // g/mol [origin=calculated method=formula-sum]
Tc          1008.52;      // K   [origin=predictive method=joback]
Pc          28.658;      // bar [origin=predictive method=joback]
omega       0.8925;      // -   [origin=predictive method=lee-kesler]
Tb          755.64;      // K   [origin=predictive method=joback]
HvapTb      74101.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.989 1.8478 -0.00149452 4.853e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenyl-2-(pyrrolidin-1-ylmethyl)phenol" "3-(1-pyrrolidinylmethyl)(1,1'-biphenyl)-4-ol" "3-(1-pyrrolidinylmethyl)-4-hydroxybiphenyl" "(1,1'-biphenyl)-4-ol, 3-(1-pyrrolidinylmethyl)-" );
standardThermochemistry
{
    dHf_298   44580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=319970.0
}
