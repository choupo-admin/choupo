/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-menth-8-ene, cis-  (C10H18, CAS 1124-27-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pMenth8EneCis;
formula     C10H18;
CAS         1124-27-2;
InChIKey    WPMKLOWQWIDOJN-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          644.75;      // K   [origin=predictive method=joback]
Pc          26.057;      // bar [origin=predictive method=joback]
omega       0.2934;      // -   [origin=predictive method=lee-kesler]
Tb          439.84;      // K   [origin=predictive method=joback]
HvapTb      37384.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.55 1.02934 -0.000571 1.084e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-prop-1-en-2-yl-cyclohexane" "p-menth-8-ene, trans-" "cyclohexane, 1-methyl-4-(1-methylethenyl)-, cis-" "cyclohexane, 1-methyl-4-(1-methylethenyl)-, trans-" "beta-dihydrolimonene" "1-methyl-4-prop-1-en-2-ylcyclohexane" "cyclohexane, 1-methyl-4-(1-methylethenyl)-" "1-methyl-4-(1-methylethenyl)cyclohexane" );
standardThermochemistry
{
    dHf_298   -100110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=129350.0
}
