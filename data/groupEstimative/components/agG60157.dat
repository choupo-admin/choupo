/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-60157  (C13H20N2O4, CAS 68133-26-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG60157;
formula     C13H20N2O4;
CAS         68133-26-6;
InChIKey    AZQGFJYXVUIQEN-UHFFFAOYSA-N;
MW          268.313;      // g/mol [origin=calculated method=formula-sum]
Tc          966.29;      // K   [origin=predictive method=joback]
Pc          22.166;      // bar [origin=predictive method=joback]
omega       1.1803;      // -   [origin=predictive method=lee-kesler]
Tb          759.44;      // K   [origin=predictive method=joback]
HvapTb      77436.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (67.454 0.99784 -0.00035592 -2.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 3; } { group AC; count 2; } { group CH2COO; count 1; } { group CH3O; count 2; } { group CH2NH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group COO; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxyethyl 3-[(5-azanyl-2-methoxy-phenyl)amino]propanoate" "2-methoxyethyl n-(5-amino-2-methoxyphenyl)-beta-alaninate" "2-methoxyethyl n-(5-amino-2-methoxyphenyl)-" "a-alaninate" "n-(5-amino-2-methoxyphenyl)-beta-alanine, 2-methoxyethyl ester" "2-methoxyethyl 3-(5-amino-2-methoxyanilino)propanoate" ".beta.-alanine, n-(5-amino-2-methoxyphenyl)-, 2-methoxyethyl ester" "beta-alanine, n-(5-amino-2-methoxyphenyl)-, 2-methoxyethyl ester" );
gibbsFormation
{
    dHf_298   -592520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     709.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-212800.0
    phase     gas;
}
