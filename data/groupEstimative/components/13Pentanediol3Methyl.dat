/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-pentanediol, 3-methyl-  (C6H14O2, CAS 33879-72-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Pentanediol3Methyl;
formula     C6H14O2;
CAS         33879-72-0;
InChIKey    HIYKOZFIVZIBFO-UHFFFAOYSA-N;
MW          118.176;      // g/mol [origin=calculated method=formula-sum]
Tc          683.48;      // K   [origin=predictive method=joback]
Pc          39.506;      // bar [origin=predictive method=joback]
omega       1.1879;      // -   [origin=predictive method=lee-kesler]
Tb          518.01;      // K   [origin=predictive method=joback]
HvapTb      61012.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.457 0.76764 -0.0005352 1.517e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylpentane-1,3-diol" "agn-pc-02n6hi" );
standardThermochemistry
{
    dHf_298   -480380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-271160.0
}
