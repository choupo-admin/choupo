/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-(2,5-dimethoxyphenyl)propanoate  (C13H18O4, CAS 72018-06-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl325DimethoxyphenylPropanoate;
formula     C13H18O4;
CAS         72018-06-5;
InChIKey    XBOHFGDUPHTTGX-UHFFFAOYSA-N;
MW          238.283;      // g/mol [origin=calculated method=formula-sum]
Tc          835.72;      // K   [origin=predictive method=joback]
Pc          20.774;      // bar [origin=predictive method=joback]
omega       0.8367;      // -   [origin=predictive method=lee-kesler]
Tb          636.74;      // K   [origin=predictive method=joback]
HvapTb      60359.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.173 0.85976 -0.00026392 -4.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,5-dimethoxyhydrocinnamate" "benzenepropanoic acid, 2,5-dimethoxy-, ethyl ester" "3-(2,5-dimethoxy-phenyl)-propanoic acid ethyl ester" "benzenepropanoic acid,2,5-dimethoxy-, ethyl ester" "3-(2,5-dimethoxy-phenyl)-propionic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -679780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     617.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-368640.0
    phase     gas;
}
