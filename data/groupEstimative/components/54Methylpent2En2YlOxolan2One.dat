/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-(4-methylpent-2-en-2-yl)oxolan-2-one  (C10H16O2, CAS 67800-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        54Methylpent2En2YlOxolan2One;
formula     C10H16O2;
CAS         67800-85-5;
InChIKey    FXCKJKMSFIQXFM-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          694.94;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       0.5141;      // -   [origin=predictive method=lee-kesler]
Tb          496.96;      // K   [origin=predictive method=joback]
HvapTb      44824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.59 1.07576 -0.0007351 1.987e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(1,3-dimethyl-1-butenyl)dihydrofuran-2(3h)-one" "2(3h)-furanone, 5-(1,3-dimethyl-1-butenyl)dihydro-" "2(3h)-furanone, 5-(1,3-dimethyl-1-buten-1-yl)dihydro-" "5-[(e)-4-methylpent-2-en-2-yl]oxolan-2-one" );
gibbsFormation
{
    dHf_298   -392060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147070.0
    phase     gas;
}
