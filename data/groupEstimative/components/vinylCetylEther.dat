/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl cetyl ether  (C18H36O, CAS 822-28-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylCetylEther;
formula     C18H36O;
CAS         822-28-6;
InChIKey    UKDKWYQGLUUPBF-UHFFFAOYSA-N;
MW          268.485;      // g/mol [origin=calculated method=formula-sum]
Tc          792.04;      // K   [origin=predictive method=joback]
Pc          11.720;      // bar [origin=predictive method=joback]
omega       0.8297;      // -   [origin=predictive method=lee-kesler]
Tb          630.54;      // K   [origin=predictive method=joback]
HvapTb      57402.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.035 1.63062 -0.0008673 1.656e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH2=CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenoxyhexadecane" "hexadecane, 1-(ethenyloxy)-" "cetyl vinyl ether" "ether, hexadecyl vinyl" "1-vinyloxyhexadecane" "vinyl hexadecyl ether" "ether, hexadecyl vinyl (8ci)" );
standardThermochemistry
{
    dHf_298   -421640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     863.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83520.0
}
