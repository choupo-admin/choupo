/*--------------------------------*- Choupo -*-----------------------*\
  Component: triiodosilane  (HI3Si, CAS 13465-72-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula HI3Si (delta H+1Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        triiodosilane;
formula     HI3Si;
CAS         13465-72-0;
InChIKey    DNAPJAGHXMPFLD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          409.793;      // g/mol [origin=calculated method=formula-sum]
Tc          795.20;      // K   [origin=predictive method=joback]
Pc          51.609;      // bar [origin=predictive method=joback]
omega       0.1049;      // -   [origin=predictive method=lee-kesler]
Tb          479.72;      // K   [origin=predictive method=joback]
HvapTb      43860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.37 0.0177 -1.3e-05 -1e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group I; count 3; } { group SiH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group I; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(iodanyl)silane" "sihi3" "silane, triiodo-(7ci,8ci,9ci)" );
gibbsFormation
{
    dHf_298   131470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71100.0
    phase     gas;
}
