/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptadecane-1,2-diol  (C17H36O2, CAS 34719-63-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptadecane12Diol;
formula     C17H36O2;
CAS         34719-63-6;
InChIKey    FDEPHESLFILWER-UHFFFAOYSA-N;
MW          272.473;      // g/mol [origin=calculated method=formula-sum]
Tc          946.21;      // K   [origin=predictive method=joback]
Pc          14.154;      // bar [origin=predictive method=joback]
omega       1.2778;      // -   [origin=predictive method=lee-kesler]
Tb          772.48;      // K   [origin=predictive method=joback]
HvapTb      86406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.665 1.69272 -0.000965 2.102e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-heptadecanediol" );
gibbsFormation
{
    dHf_298   -703950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     910.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183820.0
    phase     gas;
}
