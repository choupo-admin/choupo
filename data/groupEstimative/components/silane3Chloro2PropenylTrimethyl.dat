/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, (3-chloro-2-propenyl)trimethyl-  (C6H13ClSi, CAS 18187-39-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H13ClSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silane3Chloro2PropenylTrimethyl;
formula     C6H13ClSi;
CAS         18187-39-8;
InChIKey    PCULCDOARKKVRX-SNAWJCMRSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          148.705;      // g/mol [origin=calculated method=formula-sum]
Tc          568.17;      // K   [origin=predictive method=joback]
Pc          27.730;      // bar [origin=predictive method=joback]
omega       0.2371;      // -   [origin=predictive method=lee-kesler]
Tb          379.87;      // K   [origin=predictive method=joback]
HvapTb      33587.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.961 0.39446 8e-06 -1.006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH=CH; count 1; } { group Cl_C=C_; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-3-chloranylprop-2-enyl]-trimethyl-silane" "1-chloro-3-trimethylsilylpropene" "[(e)-3-chloroprop-2-enyl]-trimethylsilane" "(3-chloroprop-2-en-1-yl)(trimethyl)silane" );
standardThermochemistry
{
    dHf_298   -177310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     543.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-36830.0
}
