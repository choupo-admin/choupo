/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicyclopentadiene  (C10H12, CAS 77-73-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicyclopentadiene;
formula     C10H12;
CAS         77-73-6;
InChIKey    HECLRDQVFMWTQS-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          664.77;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.3266;      // -   [origin=predictive method=lee-kesler]
Tb          446.54;      // K   [origin=predictive method=joback]
HvapTb      38040.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.55 1.2584 -0.00105356 3.56e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 4; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentadiene dimer" "bicyclopentadiene" "biscyclopentadiene" "4,7-methano-1h-indene, 3a,4,7,7a-tetrahydro-" "dicyklopentadien" "dimer cyklopentadienu" "4,7-methanoindene, 3a,4,7,7a-tetrahydro-" "1,3-cyclopentadiene, dimer" "3a,4,7,7a-tetrahydro-4,7-methanoindene" "1,3-cpd" "alpha-dicyclopentadiene (endo form)" "tricyclo(5.2.1.0)-3,8-decadiene" );
standardThermochemistry
{
    dHf_298   57730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     177.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=255680.0
}
