/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzo[c]thiophene  (C8H6S, CAS 270-82-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoCThiophene;
formula     C8H6S;
CAS         270-82-6;
InChIKey    LYTMVABTDYMBQK-UHFFFAOYSA-N;
MW          134.196;      // g/mol [origin=calculated method=formula-sum]
Tc          722.17;      // K   [origin=predictive method=joback]
Pc          45.839;      // bar [origin=predictive method=joback]
omega       0.3314;      // -   [origin=predictive method=lee-kesler]
Tb          472.70;      // K   [origin=predictive method=joback]
HvapTb      42666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.57 0.76121 -0.00065714 2.251e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-benzothiophene" "isobenzothiophene" "benzo(c)thiophene" );
gibbsFormation
{
    dHf_298   212790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     319.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=257540.0
    phase     gas;
}
