/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tridecen-7-yne, 1-(1-ethoxyethoxy)-, (4e)-  (C17H30O2, CAS 61565-23-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Tridecen7Yne11Ethoxyethoxy4e;
formula     C17H30O2;
CAS         61565-23-9;
InChIKey    CJVKIEPXYQXRFT-UHFFFAOYSA-N;
MW          266.425;      // g/mol [origin=calculated method=formula-sum]
Tc          827.73;      // K   [origin=predictive method=joback]
Pc          14.091;      // bar [origin=predictive method=joback]
omega       0.7853;      // -   [origin=predictive method=lee-kesler]
Tb          646.12;      // K   [origin=predictive method=joback]
HvapTb      59978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.129 1.36856 -0.00067386 1.0738e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2O; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 1; } { group dCH; count 2; } { group tC; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-ethoxyethoxy)tridec-4-en-7-yne" );
standardThermochemistry
{
    dHf_298   -274410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     796.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162840.0
}
