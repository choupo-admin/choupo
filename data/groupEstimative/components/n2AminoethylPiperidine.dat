/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-aminoethyl)piperidine  (C7H16N2, CAS 27578-60-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2AminoethylPiperidine;
formula     C7H16N2;
CAS         27578-60-5;
InChIKey    CJNRGSHEMCMUOE-UHFFFAOYSA-N;
MW          128.219;      // g/mol [origin=calculated method=formula-sum]
Tc          671.65;      // K   [origin=predictive method=joback]
Pc          38.010;      // bar [origin=predictive method=joback]
omega       0.5112;      // -   [origin=predictive method=lee-kesler]
Tb          464.68;      // K   [origin=predictive method=joback]
HvapTb      44426.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.098 1.0128 -0.0006958 1.882e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2NH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 5; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-piperidin-1-ylethanamine" "1-(2-aminoethyl)piperidine" "1-piperidineethanamine" "2-(piperidin-1-yl)ethanamine" "n-aminoethylpiperidine" "2-piperidinoethylamine" "2-(1-piperidinyl)ethanamine" "2-piperidylethylamine" "2-(1-piperidino)ethylamine" "2-piperidin-1-yl-ethylamine" "cjnrgshemcmuoe-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -5670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=229550.0
}
