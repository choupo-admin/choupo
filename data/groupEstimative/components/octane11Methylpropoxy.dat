/*--------------------------------*- Choupo -*-----------------------*\
  Component: octane, 1-(1-methylpropoxy)-  (C12H26O, CAS 51182-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octane11Methylpropoxy;
formula     C12H26O;
CAS         51182-83-3;
InChIKey    XBOIOIYBBXTWHB-UHFFFAOYSA-N;
MW          186.339;      // g/mol [origin=calculated method=formula-sum]
Tc          660.31;      // K   [origin=predictive method=joback]
Pc          17.669;      // bar [origin=predictive method=joback]
omega       0.6309;      // -   [origin=predictive method=lee-kesler]
Tb          496.14;      // K   [origin=predictive method=joback]
HvapTb      44328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.798 1.08656 -0.0005212 7.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butan-2-yloxyoctane" );
standardThermochemistry
{
    dHf_298   -428510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57280.0
}
