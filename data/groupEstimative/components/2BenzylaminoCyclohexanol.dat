/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-benzylamino-cyclohexanol  (C13H19NO, CAS 40571-86-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BenzylaminoCyclohexanol;
formula     C13H19NO;
CAS         40571-86-6;
InChIKey    NJNCYFUGUYIMEQ-CHWSQXEVSA-N;
MW          205.301;      // g/mol [origin=calculated method=formula-sum]
Tc          897.09;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       1.0113;      // -   [origin=predictive method=lee-kesler]
Tb          680.95;      // K   [origin=predictive method=joback]
HvapTb      70043.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.419 1.3657 -0.0008192 1.707e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2r)-2-[(phenylmethyl)amino]cyclohexan-1-ol" "(1r,2r)-2-(benzylamino)cyclohexanol" "trans-2-(benzylamino)cyclohexanol" "trans-2-benzylamino-1-cyclohexanol" "trans-2-benzylamino-cyclohexanol" "aa288" "(1r,2r)-2-(benzylamino)cyclohexan-1-ol" "cyclohexanol,2-[(phenylmethyl)amino]-, (1r,2r)-rel-" "cyclohexanol,2-[(phenylmethyl)amino]-, trans-;trans-2-(benzylamino)-1-cyclohexanol;" );
gibbsFormation
{
    dHf_298   -139900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140300.0
    phase     gas;
}
