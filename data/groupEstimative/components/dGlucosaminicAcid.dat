/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-glucosaminic acid  (C6H13NO6, CAS 3646-68-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dGlucosaminicAcid;
formula     C6H13NO6;
CAS         3646-68-2;
InChIKey    UFYKDFXCZBTLOO-TXICZTDVSA-N;
MW          195.171;      // g/mol [origin=calculated method=formula-sum]
Tc          1128.64;      // K   [origin=predictive method=joback]
Pc          64.205;      // bar [origin=predictive method=joback]
omega       2.6609;      // -   [origin=predictive method=lee-kesler]
Tb          921.88;      // K   [origin=predictive method=joback]
HvapTb      121919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.961 0.8461 -0.000553 1.364e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 3; } { group OH; count 4; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 4; } { group OH; count 4; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3r,4s,5r)-2-azanyl-3,4,5,6-tetrakis(oxidanyl)hexanoic acid" "glucosaminate" "2-amino-2-deoxy-d-gluconic acid" "d-glucosamic acid" "d-glucosaminate" "(3r,4s,5r)-3,4,5,6-tetrahydroxy-d-norleucin" "2-amino-2-deoxygluconic acid" "2-amino-2-deoxy-d-gluconate" "glucosaminic acid" "(2r,3r,4s,5r)-2-amino-3,4,5,6-tetrahydroxyhexanoic acid" "gluconic acid, 2-amino-2-deoxy-" "d-gluconic acid, 2-amino-2-deoxy-" );
gibbsFormation
{
    dHf_298   -1113690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     659.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-834860.0
    phase     gas;
}
