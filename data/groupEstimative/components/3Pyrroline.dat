/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pyrroline  (C4H7N, CAS 109-96-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Pyrroline;
formula     C4H7N;
CAS         109-96-6;
InChIKey    JVQIKJMSUIMUDI-UHFFFAOYSA-N;
MW          69.107;      // g/mol [origin=calculated method=formula-sum]
Tc          570.19;      // K   [origin=predictive method=joback]
Pc          56.703;      // bar [origin=predictive method=joback]
omega       0.2552;      // -   [origin=predictive method=lee-kesler]
Tb          358.78;      // K   [origin=predictive method=joback]
HvapTb      32114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.47 0.4726 -0.00030328 7.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dihydro-1h-pyrrole" "2,5-dihydropyrrole" "1h-pyrrole, 2,5-dihydro-" "delta3-pyrroline" "delta(3)-pyrroline" ".delta.3-pyrroline" "1h-pyrrole,5-dihydro-" "109-96-6 3-pyrroline" "jvqikjmsuimudi-uhfffaoysa-" "8223c0dc-29eb-4298-aab6-7fa93c67aa2a" );
standardThermochemistry
{
    dHf_298   50520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     260.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=144730.0
}
