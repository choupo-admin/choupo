/*--------------------------------*- Choupo -*-----------------------*\
  Component: thietane, 2-methyl-  (C4H8S, CAS 17837-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thietane2Methyl;
formula     C4H8S;
CAS         17837-41-1;
InChIKey    DUTRXPYVMIFJQZ-UHFFFAOYSA-N;
MW          88.168;      // g/mol [origin=calculated method=formula-sum]
Tc          557.09;      // K   [origin=predictive method=joback]
Pc          47.366;      // bar [origin=predictive method=joback]
omega       0.1972;      // -   [origin=predictive method=lee-kesler]
Tb          349.96;      // K   [origin=predictive method=joback]
HvapTb      30395.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.29 0.53953 -0.0003863 1.146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylthietane" "butane, 1,3-epithio-" "agn-pc-00k1o6" "butane,1,3-epithio- (8ci); 2-methylthiacyclobutane; 2-methylthietane; a-methylthietane" );
standardThermochemistry
{
    dHf_298   -13990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     291.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71310.0
}
