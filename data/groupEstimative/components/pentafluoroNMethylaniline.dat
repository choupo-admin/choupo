/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentafluoro-n-methylaniline  (C7H4F5N, CAS 1201-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentafluoroNMethylaniline;
formula     C7H4F5N;
CAS         1201-02-1;
InChIKey    ZWWAUEAPYBCUMT-UHFFFAOYSA-N;
MW          197.106;      // g/mol [origin=calculated method=formula-sum]
Tc          628.72;      // K   [origin=predictive method=joback]
Pc          29.345;      // bar [origin=predictive method=joback]
omega       0.6942;      // -   [origin=predictive method=lee-kesler]
Tb          457.86;      // K   [origin=predictive method=joback]
HvapTb      39113.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.36 0.42762 -0.0001836 1.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group CH3NH; count 1; } { group ACF; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dC_ring; count 6; } { group F; count 5; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5,6-pentakis(fluoranyl)-n-methyl-aniline" "benzenamine, 2,3,4,5,6-pentafluoro-n-methyl-" "2,3,4,5,6-pentafluoro-n-methylaniline" );
gibbsFormation
{
    dHf_298   -935710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-812340.0
    phase     gas;
}
