/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-piperidinepropanenitrile  (C8H14N2, CAS 3088-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Piperidinepropanenitrile;
formula     C8H14N2;
CAS         3088-41-3;
InChIKey    YZICFVIUVMCCOC-UHFFFAOYSA-N;
MW          138.214;      // g/mol [origin=calculated method=formula-sum]
Tc          729.26;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.5540;      // -   [origin=predictive method=lee-kesler]
Tb          517.11;      // K   [origin=predictive method=joback]
HvapTb      46489.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.498 0.9807 -0.0006758 1.828e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 5; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-piperidin-1-ylpropanenitrile" "beta-piperidinopropionitrile" "3-piperidinopropionitrile" "1-(2-cyanoethyl)piperidine" "3-(1-piperidine)propionitrile" "3-(piperidin-1-yl)propanenitrile" "3-piperidylpropanenitrile" "piperidinopropionitrile" "3-piperidin-1-yl-propionitrile" "1-piperidinepropionitrile(6ci,7ci,8ci);1-(2-cyanoethyl)piperidine;3-(1-piperidinyl)propionitrile;3-piperidinopropanenitrile;3-piperidinopropionitrile;b-piperidinopropionitrile;" );
standardThermochemistry
{
    dHf_298   104780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=304700.0
}
