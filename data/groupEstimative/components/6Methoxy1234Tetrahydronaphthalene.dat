/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methoxy-1,2,3,4-tetrahydronaphthalene  (C11H14O, CAS 1730-48-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methoxy1234Tetrahydronaphthalene;
formula     C11H14O;
CAS         1730-48-9;
InChIKey    SUFDFKRJYKNTFH-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          753.18;      // K   [origin=predictive method=joback]
Pc          30.796;      // bar [origin=predictive method=joback]
omega       0.4710;      // -   [origin=predictive method=lee-kesler]
Tb          526.02;      // K   [origin=predictive method=joback]
HvapTb      46484.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.22 0.95552 -0.00058992 1.382e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methoxytetralin" "naphthalene, 1,2,3,4-tetrahydro-6-methoxy-" "1,2,3,4-tetrahydro-6-methoxynaphthalene" "agn-pc-03dwy4" "1,3,4-tetrahydro-6-methoxynaphthalene" "6-methoxy-1,3,4-tetrahydronaphthalene" "naphthalene,2,3,4-tetrahydro-6-methoxy-" "6-methoxy-1,2,3,4-tetrahydro-naphthalene" "methyl 1,2,3,4-tetrahydro-6-naphthyl ether" );
gibbsFormation
{
    dHf_298   -102020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86250.0
    phase     gas;
}
