/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-(dodecylimino)dipropan-2-ol  (C18H39NO2, CAS 1541-66-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11DodecyliminoDipropan2Ol;
formula     C18H39NO2;
CAS         1541-66-8;
InChIKey    BZJZJFAPSOEUFE-UHFFFAOYSA-N;
MW          301.515;      // g/mol [origin=calculated method=formula-sum]
Tc          988.45;      // K   [origin=predictive method=joback]
Pc          13.242;      // bar [origin=predictive method=joback]
omega       1.2238;      // -   [origin=predictive method=lee-kesler]
Tb          807.36;      // K   [origin=predictive method=joback]
HvapTb      90287.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.947 1.91756 -0.0011352 2.59e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 2; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 13; } { group CH; count 2; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[dodecyl(2-oxidanylpropyl)amino]propan-2-ol" "2-propanol, 1,1'-(dodecylimino)bis-" "1-[dodecyl(2-hydroxypropyl)amino]propan-2-ol" "dodecylbis(2-hydroxypropyl)amine" );
gibbsFormation
{
    dHf_298   -662340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     955.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-67060.0
    phase     gas;
}
