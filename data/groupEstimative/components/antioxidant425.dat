/*--------------------------------*- Choupo -*-----------------------*\
  Component: antioxidant 425  (C25H36O2, CAS 88-24-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        antioxidant425;
formula     C25H36O2;
CAS         88-24-4;
InChIKey    GPNYZBKIGXGYNU-UHFFFAOYSA-N;
MW          368.561;      // g/mol [origin=calculated method=formula-sum]
Tc          1240.42;      // K   [origin=predictive method=joback]
Pc          13.923;      // bar [origin=predictive method=joback]
omega       1.1010;      // -   [origin=predictive method=lee-kesler]
Tb          999.66;      // K   [origin=predictive method=joback]
HvapTb      101880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.237 2.54396 -0.00198676 6.477e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group C; count 2; } { group ACH; count 4; } { group AC; count 3; } { group ACCH2; count 3; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 3; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tert-butyl-6-[(3-tert-butyl-5-ethyl-2-oxidanyl-phenyl)methyl]-4-ethyl-phenol" "2,2'-methylenebis(6-tert-butyl-4-ethylphenol)" "chemanox 22" "2,2'-methylenebis(4-ethyl-6-tert-butylphenol)" "plastanox 425 antioxidant" "usaf cy-6" "agidol 7" "nocrac ns 5" "2,2'-methylenebis(ethyl-6-tert-butylphenol)" "bis(2-hydroxy-3-tert-butyl-5-ethylphenyl)methane" "bis(3-tert-butyl-5-ethyl-2-hydroxyphenyl)methane" "phenol, 2,2'-methylenebis(6-tert-butyl-4-ethyl-" );
gibbsFormation
{
    dHf_298   -504270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     867.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42360.0
    phase     gas;
}
