/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylanisole  (C8H10O, CAS 100-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylanisole;
formula     C8H10O;
CAS         100-84-5;
InChIKey    OSIGJGFTADMDOB-UHFFFAOYSA-N;
MW          122.167;      // g/mol [origin=calculated method=formula-sum]
Tc          646.65;      // K   [origin=predictive method=joback]
Pc          35.137;      // bar [origin=predictive method=joback]
omega       0.3657;      // -   [origin=predictive method=lee-kesler]
Tb          436.72;      // K   [origin=predictive method=joback]
HvapTb      38750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.51 0.56224 -0.00026456 2.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-3-methyl-benzene" "3-methoxytoluene" "m-methylanisole" "1-methoxy-3-methylbenzene" "benzene, 1-methoxy-3-methyl-" "anisole, m-methyl-" "m-cresol methyl ether" "methyl m-cresyl ether" "m-methoxytoluene" "methyl 3-methylphenyl ether" "methyl m-tolyl ether" "m-cresyl methyl ether" );
gibbsFormation
{
    dHf_298   -115610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     366.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14260.0
    phase     gas;
}
