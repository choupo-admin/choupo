/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pyrrolidinopropylamine  (C7H16N2, CAS 23159-07-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Pyrrolidinopropylamine;
formula     C7H16N2;
CAS         23159-07-1;
InChIKey    VPBWZBGZWHDNKL-UHFFFAOYSA-N;
MW          128.219;      // g/mol [origin=calculated method=formula-sum]
Tc          659.56;      // K   [origin=predictive method=joback]
Pc          36.865;      // bar [origin=predictive method=joback]
omega       0.5457;      // -   [origin=predictive method=lee-kesler]
Tb          460.41;      // K   [origin=predictive method=joback]
HvapTb      44254.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.977 1.0224 -0.0007422 2.181e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2NH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 4; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-pyrrolidin-1-ylpropan-1-amine" "1-(3-aminopropyl)pyrrolidine" "3-(pyrrolidin-1-yl)propan-1-amine" "n-(3-aminopropyl)pyrrolidine" "1-(3-aminopropyl)-pyrrolidine" "3-(1-pyrrolidinyl)propylamine" "pyrrolidine, 1-(3-aminopropyl)-" "3-pyrrolidinylpropylamine" "pyrrolidine-1-propylamine" "3-pyrrolidin-1-yl-propylamine" "3-(pyrrolidin-1-yl)propylamine" );
gibbsFormation
{
    dHf_298   490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=241650.0
    phase     gas;
}
