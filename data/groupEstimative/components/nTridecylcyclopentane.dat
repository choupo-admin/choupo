/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-tridecylcyclopentane  (C18H36, CAS 6006-34-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nTridecylcyclopentane;
formula     C18H36;
CAS         6006-34-4;
InChIKey    NYZHNJGPFXHHNR-UHFFFAOYSA-N;
MW          252.486;      // g/mol [origin=calculated method=formula-sum]
Tc          802.53;      // K   [origin=predictive method=joback]
Pc          13.071;      // bar [origin=predictive method=joback]
omega       0.7358;      // -   [origin=predictive method=lee-kesler]
Tb          626.72;      // K   [origin=predictive method=joback]
HvapTb      55919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.958 1.84552 -0.0010828 2.425e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group CH2_ring; count 4; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridecylcyclopentane" "1-cyclopentyltridecane" "cyclopentane, tridecyl-" );
gibbsFormation
{
    dHf_298   -354370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     806.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=137230.0
    phase     gas;
}
