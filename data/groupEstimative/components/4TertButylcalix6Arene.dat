/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butylcalix[6]arene  (C66H84O6, CAS 78092-53-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylcalix6Arene;
formula     C66H84O6;
CAS         78092-53-2;
InChIKey    UOEYZAXKBKAKRO-UHFFFAOYSA-N;
MW          973.392;      // g/mol [origin=calculated method=formula-sum]
Tc          3977.98;      // K   [origin=predictive method=joback]
Pc          4.934;      // bar [origin=predictive method=joback]
omega       -0.4884;      // -   [origin=predictive method=lee-kesler]
Tb          2418.08;      // K   [origin=predictive method=joback]
HvapTb      255156.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-360.85 6.91776 -0.00565468 1.8962e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 18; } { group C; count 6; } { group ACH; count 12; } { group AC; count 12; } { group ACCH2; count 6; } { group ACOH; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 18; } { group C; count 6; } { group CH2_ring; count 6; } { group dCH_ring; count 12; } { group dC_ring; count 24; } { group OH_phenol; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexa-tert-butyl(hexahydroxy)calix[6]arene" "5,11,17,23,29,35-hexa(tert-butyl)heptacyclo[31.3.1.1~3,7~.1~9,13~.1~15,19~.1~21,25~.1~27,31~]dotetraconta-1(37),3,5,7(42),9(41),10,12,15,17,19(40),21( 3+" "5,11,17,23,29,35-hexa-tert-butylheptacyclo[31.3.1.1(3,7).1(9,13).1(15,19).1(21,25).1(27,31)]dotetraconta-1(37),3(42),4,6,9(41),10,12,15(40),16,18,21(39),22,24,27(38),28,30,33,35-octadecaene-37,38,39,40,41,42-hexol" );
standardThermochemistry
{
    dHf_298   -1165730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1951.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185220.0
}
