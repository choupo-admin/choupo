/*--------------------------------*- Choupo -*-----------------------*\
  Component: desmethylcyproheptadine  (C20H19N, CAS 14051-46-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        desmethylcyproheptadine;
formula     C20H19N;
CAS         14051-46-8;
InChIKey    INPJSDMJYRCDGA-UHFFFAOYSA-N;
MW          273.379;      // g/mol [origin=calculated method=formula-sum]
Tc          1086.41;      // K   [origin=predictive method=joback]
Pc          24.076;      // bar [origin=predictive method=joback]
omega       0.7816;      // -   [origin=predictive method=lee-kesler]
Tb          812.98;      // K   [origin=predictive method=joback]
HvapTb      75616.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.15 1.7086 -0.0011844 3.19e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH2NH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 6; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(dibenzo[1,2-a:1',2'-e][7]annulen-11-ylidene)piperidine" "4-(5h-dibenzo[a,d][7]annulen-5-ylidene)piperidine" "piperidine, 4-(5h-dibenzo(a,d)cyclohepten-5-ylidene)-" "piperidine,4-(5h-dibenzo[a,d]cyclohepten-5-ylidene)-" "4-(5-dibenzo[a,d]cycloheptenylidene)piperidine;4-(5h-dibenzo[a,d]cyclohepten-5-ylidene)piperidine; demethylcyproheptadine;desmethylcyproheptadine; n-desmethylcyproheptadine; norcyproheptadine" );
standardThermochemistry
{
    dHf_298   292220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=552070.0
}
