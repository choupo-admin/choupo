/*--------------------------------*- Choupo -*-----------------------*\
  Component: sulfide, isopropyl 2-propynyl  (C6H10S, CAS 14272-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sulfideIsopropyl2Propynyl;
formula     C6H10S;
CAS         14272-25-4;
InChIKey    LIIXPZMKZWEJRJ-UHFFFAOYSA-N;
MW          114.206;      // g/mol [origin=calculated method=formula-sum]
Tc          603.68;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.2706;      // -   [origin=predictive method=lee-kesler]
Tb          395.34;      // K   [origin=predictive method=joback]
HvapTb      35237.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.131 0.48023 -0.00026153 5.049e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH_C; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group tCH; count 1; } { group tC; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-prop-2-ynylsulfanylpropane" "1-propyne, 3-[(1-methylethyl)thio]-" );
standardThermochemistry
{
    dHf_298   161320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=253390.0
}
