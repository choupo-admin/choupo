/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-methylbicyclo(2.2.1)hept-5-ene-2-carboxylate  (C11H16O2, CAS 67845-29-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Methylbicyclo221Hept5Ene2Carboxylate;
formula     C11H16O2;
CAS         67845-29-8;
InChIKey    CVCQFCVMUMOBBJ-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          718.75;      // K   [origin=predictive method=joback]
Pc          24.654;      // bar [origin=predictive method=joback]
omega       0.5310;      // -   [origin=predictive method=lee-kesler]
Tb          517.07;      // K   [origin=predictive method=joback]
HvapTb      47159.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.649 1.17724 -0.00075048 1.791e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 4; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-methylbicyclo[2.2.1]hept-5-ene-3-carboxylate" "ethyl 3-methylbicyclo[2.2.1]hept-5-ene-2-carboxylate" "bicyclo(2.2.1)hept-5-ene-2-carboxylic acid, 3-methyl-, ethyl ester" "bicyclo[2.2.1]hept-5-ene-2-carboxylic acid, 3-methyl-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -431110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     353.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144690.0
}
