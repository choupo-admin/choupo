/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,10-trioxa-7,13-diazacyclopentadecane  (C10H22N2O3, CAS 31249-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1410Trioxa713Diazacyclopentadecane;
formula     C10H22N2O3;
CAS         31249-95-3;
InChIKey    STHIZMRUXPMSCW-UHFFFAOYSA-N;
MW          218.297;      // g/mol [origin=calculated method=formula-sum]
Tc          942.50;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.6167;      // -   [origin=predictive method=lee-kesler]
Tb          669.00;      // K   [origin=predictive method=joback]
HvapTb      67186.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.03 0.9802 -7.61e-05 -2.154e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group FCH2O; count 3; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group O_ring; count 3; } { group NH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cryptand 21" "1,4,10-trioxa-7,13-diaza-cyclopentadecane" "kryptofix 21" "kryptofix(r) 21" "kryptofix&reg; 21" "4,10-diaza-15-crown 5-ether" "4,7,13-trioxa-1,10-diazacyclopentadecane" "4,7,13-trioxa-1,10-diazacyclopentadecane;" );
standardThermochemistry
{
    dHf_298   -550890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-126360.0
}
