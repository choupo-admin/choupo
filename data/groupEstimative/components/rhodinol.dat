/*--------------------------------*- Choupo -*-----------------------*\
  Component: rhodinol  (C10H20O, CAS 6812-78-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        rhodinol;
formula     C10H20O;
CAS         6812-78-8;
InChIKey    JGQFVRIQXUFPAH-JTQLQIEISA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          683.34;      // K   [origin=predictive method=joback]
Pc          24.243;      // bar [origin=predictive method=joback]
omega       0.8687;      // -   [origin=predictive method=lee-kesler]
Tb          516.70;      // K   [origin=predictive method=joback]
HvapTb      53555.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.275 0.97364 -0.000579 1.363e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s)-3,7-dimethyloct-7-en-1-ol" "1-citronellol" "rhodinol (natural)" "rhodinol, (-)-" "(-)-.alpha.-citronellol" "alpha-citronellol, (-)-" "7-octen-1-ol, 3,7-dimethyl-, (s)-" "(s)-3,7-dimethyl-7-octen-1-ol" "7-octen-1-ol, 3,7-dimethyl-, (3s)-" "(s)-(-)-" "a-citronellol" "7-octen-1-ol,3,7-dimethyl-, (3s)-" "rhodinol (6ci);(-)-rhodinol;(-)-a-citronellol;(s)-a-citronellol;rhodinol, (-)-;a-citronellol, (-)-;" );
standardThermochemistry
{
    dHf_298   -291600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26650.0
}
