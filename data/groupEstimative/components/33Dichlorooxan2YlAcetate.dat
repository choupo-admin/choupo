/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dichlorooxan-2-yl acetate  (C7H10Cl2O3, CAS 141942-54-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dichlorooxan2YlAcetate;
formula     C7H10Cl2O3;
CAS         141942-54-3;
InChIKey    NVEIBZFEVMVCPU-UHFFFAOYSA-N;
MW          213.054;      // g/mol [origin=calculated method=formula-sum]
Tc          765.15;      // K   [origin=predictive method=joback]
Pc          32.616;      // bar [origin=predictive method=joback]
omega       0.5008;      // -   [origin=predictive method=lee-kesler]
Tb          534.91;      // K   [origin=predictive method=joback]
HvapTb      50832.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.62 1.01212 -0.0008475 3.037e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH3COO; count 1; } { group FCH2O; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group Cl; count 2; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3,3-bis(chloranyl)oxan-2-yl] ethanoate" "2h-pyran-2-ol,3,3-dichlorotetrahydro-, 2-acetate" "3,3-dichloro-2h-3,4,5,6-tetrahydropyran-2-yl acetate" "(3,3-dichlorooxan-2-yl) acetate" "2-acetoxy-3,3-dichlorotetrahydropyran" "3,3-dichlorotetrahydro-2h-pyran-2-yl acetate" "2h-pyran-2-ol,3,3-dichlorotetrahydro-, acetate (9ci); 2-acetoxy-3,3-dichlorotetrahydropyran" );
gibbsFormation
{
    dHf_298   -619350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-401040.0
    phase     gas;
}
