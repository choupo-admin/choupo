/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-hydroxyethyl)-n-methyl-4-hydroxybutyramide  (C7H15NO3, CAS 68083-83-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2HydroxyethylNMethyl4Hydroxybutyramide;
formula     C7H15NO3;
CAS         68083-83-0;
InChIKey    DORXJCORWAVZTD-UHFFFAOYSA-N;
MW          161.201;      // g/mol [origin=calculated method=formula-sum]
Tc          775.02;      // K   [origin=predictive method=joback]
Pc          36.955;      // bar [origin=predictive method=joback]
omega       1.5844;      // -   [origin=predictive method=lee-kesler]
Tb          610.43;      // K   [origin=predictive method=joback]
HvapTb      73323.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.775 0.83272 -0.0005117 1.2006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 2; } { group CONCH3CH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group OH; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-hydroxyethyl)-n-methyl-4-oxidanyl-butanamide" "butanamide, 4-hydroxy-n-(2-hydroxyethyl)-n-methyl-" "4-hydroxy-n-(2-hydroxyethyl)-n-methylbutanamide" "4-hydroxy-n-(2-hydroxyethyl)-n-methylbutyramide" );
gibbsFormation
{
    dHf_298   -537320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-283720.0
    phase     gas;
}
