/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-iodobenzyl bromide  (C7H6BrI, CAS 16004-15-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4IodobenzylBromide;
formula     C7H6BrI;
CAS         16004-15-2;
InChIKey    BQTRMYJYYNQQGK-UHFFFAOYSA-N;
MW          296.929;      // g/mol [origin=calculated method=formula-sum]
Tc          820.98;      // K   [origin=predictive method=joback]
Pc          42.887;      // bar [origin=predictive method=joback]
omega       0.4103;      // -   [origin=predictive method=lee-kesler]
Tb          550.72;      // K   [origin=predictive method=joback]
HvapTb      49922.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.199 0.6076 -0.00047396 1.467e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group I; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(bromomethyl)-4-iodanyl-benzene" "1-(bromomethyl)-4-iodobenzene" "4-iodobenzylbromide" "p-iodobenzyl bromide" "1-bromomethyl-4-iodo-benzene" "alpha-bromo-4-iodotoluene" "4-(bromomethyl)-1-iodobenzene" "4-iodo benzyl bromide" "p-odobenzyl bromide;a-bromo-4-iodotoluene" "benzene, 1-(bromomethyl)-4-iodo-" );
gibbsFormation
{
    dHf_298   140450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=183280.0
    phase     gas;
}
