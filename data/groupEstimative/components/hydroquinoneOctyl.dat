/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydroquinone, octyl-  (C14H22O2, CAS 1706-69-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydroquinoneOctyl;
formula     C14H22O2;
CAS         1706-69-0;
InChIKey    ZZXILYOBAFPJNS-UHFFFAOYSA-N;
MW          222.328;      // g/mol [origin=calculated method=formula-sum]
Tc          921.50;      // K   [origin=predictive method=joback]
Pc          26.763;      // bar [origin=predictive method=joback]
omega       1.0729;      // -   [origin=predictive method=lee-kesler]
Tb          707.84;      // K   [origin=predictive method=joback]
HvapTb      75062.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.583 1.56412 -0.00128172 4.471e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-octylbenzene-1,4-diol" "2-octylhydroquinone" "1,4-benzenediol, 2-octyl-" "1, 2-octyl-" "1,4-benzenediol,2-octyl-" );
standardThermochemistry
{
    dHf_298   -450380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-129830.0
}
