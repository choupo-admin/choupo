/*--------------------------------*- Choupo -*-----------------------*\
  Component: fenoprop-3-butoxypropyl  (C16H21Cl3O4, CAS 6047-17-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fenoprop3Butoxypropyl;
formula     C16H21Cl3O4;
CAS         6047-17-2;
InChIKey    UFYGEGSDUCLKNR-UHFFFAOYSA-N;
MW          383.69;      // g/mol [origin=calculated method=formula-sum]
Tc          1028.57;      // K   [origin=predictive method=joback]
Pc          14.702;      // bar [origin=predictive method=joback]
omega       1.0588;      // -   [origin=predictive method=lee-kesler]
Tb          822.65;      // K   [origin=predictive method=joback]
HvapTb      80854.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (112.418 1.10562 -0.00042128 -9.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 2; } { group AC; count 1; } { group CH2COO; count 1; } { group CH2O; count 2; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-butoxypropyl 3-[2,4,5-tris(chloranyl)phenoxy]propanoate" "fenoprop-3-butoxypropyl [iso]" "3-butoxypropyl 3-(2,4,5-trichlorophenoxy)propanoate" "propanoic acid, 3-(2,4,5-trichlorophenoxy)-, 3-butoxypropyl ester" "propionic acid, 3-(2,4,5-trichlorophenoxy)-, 3-butoxypropyl ester" "3-(2,4,5-trichlorophenoxy)propionic acid propylene glycol butyl ether ester" "propanoic acid,3-(2,4,5-trichlorophenoxy)-, 3-butoxypropyl ester" "propionicacid, 3-(2,4,5-trichlorophenoxy)-, 3-butoxypropyl ester (8ci)" );
standardThermochemistry
{
    dHf_298   -800390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     828.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-388800.0
}
