/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyloctyl methacrylate  (C13H24O2, CAS 67905-46-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethyloctylMethacrylate;
formula     C13H24O2;
CAS         67905-46-8;
InChIKey    MBKJMZOZZHUVLO-UHFFFAOYSA-N;
MW          212.333;      // g/mol [origin=calculated method=formula-sum]
Tc          725.94;      // K   [origin=predictive method=joback]
Pc          17.275;      // bar [origin=predictive method=joback]
omega       0.6966;      // -   [origin=predictive method=lee-kesler]
Tb          551.38;      // K   [origin=predictive method=joback]
HvapTb      50961.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.116 1.16986 -0.0006172 1.051e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyloctyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 2-methyloctyl ester" );
gibbsFormation
{
    dHf_298   -518570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     695.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-174940.0
    phase     gas;
}
