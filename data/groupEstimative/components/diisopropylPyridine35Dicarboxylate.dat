/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisopropyl pyridine-3,5-dicarboxylate  (C13H17NO4, CAS 3737-22-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisopropylPyridine35Dicarboxylate;
formula     C13H17NO4;
CAS         3737-22-2;
InChIKey    JHKOMVRNWGLUFA-UHFFFAOYSA-N;
MW          251.282;      // g/mol [origin=calculated method=formula-sum]
Tc          916.69;      // K   [origin=predictive method=joback]
Pc          22.187;      // bar [origin=predictive method=joback]
omega       0.8723;      // -   [origin=predictive method=lee-kesler]
Tb          697.96;      // K   [origin=predictive method=joback]
HvapTb      67718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.98 1.03644 -0.00047402 3.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group C5H3N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group COO; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipropan-2-yl pyridine-3,5-dicarboxylate" "3,5-pyridinedicarboxylic acid, diisopropyl ester" "3,5-pyridinedicarboxylic acid, bis(1-methylethyl) ester" );
gibbsFormation
{
    dHf_298   -698920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-387210.0
    phase     gas;
}
