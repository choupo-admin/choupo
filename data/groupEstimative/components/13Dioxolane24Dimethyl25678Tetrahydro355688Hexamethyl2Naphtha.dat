/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxolane, 2,4-dimethyl-2-(5,6,7,8-tetrahydro-3,5,5,6,8,8-hexamethyl-2-naphthalenyl)-  (C21H32O2, CAS 131812-48-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxolane24Dimethyl25678Tetrahydro355688Hexamethyl2Naphtha;
formula     C21H32O2;
CAS         131812-48-1;
InChIKey    OKMNDOGDSXEHMU-UHFFFAOYSA-N;
MW          316.485;      // g/mol [origin=calculated method=formula-sum]
Tc          1025.99;      // K   [origin=predictive method=joback]
Pc          14.850;      // bar [origin=predictive method=joback]
omega       0.6923;      // -   [origin=predictive method=lee-kesler]
Tb          788.60;      // K   [origin=predictive method=joback]
HvapTb      71584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-220.57 2.80476 -0.00265368 1.0904e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 1; } { group CH; count 1; } { group C; count 3; } { group ACH; count 2; } { group AC; count 3; } { group ACCH3; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3,5,5,6,8,8-hexamethyl-6,7-dihydronaphthalen-2-yl)-2,4-dimethyl-1,3-dioxolane" "agn-pc-02pfel" );
gibbsFormation
{
    dHf_298   -426830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     707.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82820.0
    phase     gas;
}
