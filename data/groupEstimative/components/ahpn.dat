/*--------------------------------*- Choupo -*-----------------------*\
  Component: ahpn  (C27H26O3, CAS 125316-60-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ahpn;
formula     C27H26O3;
CAS         125316-60-1;
InChIKey    LDGIHZJOIQSHPB-UHFFFAOYSA-N;
MW          398.502;      // g/mol [origin=calculated method=formula-sum]
Tc          1428.10;      // K   [origin=predictive method=joback]
Pc          19.186;      // bar [origin=predictive method=joback]
omega       1.3700;      // -   [origin=predictive method=lee-kesler]
Tb          1150.83;      // K   [origin=predictive method=joback]
HvapTb      112503.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-282.23 3.1427 -0.00286336 1.0664e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } { group ACH; count 9; } { group AC; count 6; } { group ACOH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 7; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-[3-(1-adamantyl)-4-oxidanyl-phenyl]naphthalene-2-carboxylic acid" "cd437" "6-[3-(1-adamantyl)-4-hydroxyphenyl]naphthalene-2-carboxylic acid" "6-[3-(1-adamantyl)-4-hydroxyphenyl]-2-naphthalene carboxylic acid" "6-[3-(1-adamantyl)-4-hydroxyphenyl]-2-naphthalenecarboxylic acid" "2-naphthalenecarboxylic acid, 6-(4-hydroxy-3-tricyclo(3.3.1.1(3,7))dec-1-ylphenyl)-" "2-naphthalenecarboxylicacid, 6-(4-hydroxy-3-tricyclo[3.3.1.13,7]dec-1-ylphenyl)-" "6-(4-hydroxy-3-tricyclo(3.3.1.1(3,7))dec-1-ylphenyl)-2-naphthalenecarboxylic acid" "o-desmethyl adapalene" "cd 437/ahpn" "o-demethylated adapalene" "brd-k28907958-001-01-9" );
standardThermochemistry
{
    dHf_298   -291330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     723.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=137460.0
}
