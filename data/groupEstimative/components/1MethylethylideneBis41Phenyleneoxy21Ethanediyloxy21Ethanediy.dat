/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyl) bismethacrylate  (C31H40O8, CAS 56744-60-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1MethylethylideneBis41Phenyleneoxy21Ethanediyloxy21Ethanediy;
formula     C31H40O8;
CAS         56744-60-6;
InChIKey    NREFJJBCYMZUEK-UHFFFAOYSA-N;
MW          540.653;      // g/mol [origin=calculated method=formula-sum]
Tc          1437.42;      // K   [origin=predictive method=joback]
Pc          8.131;      // bar [origin=predictive method=joback]
omega       0.7285;      // -   [origin=predictive method=lee-kesler]
Tb          1168.21;      // K   [origin=predictive method=joback]
HvapTb      112454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.478 2.39528 -0.00117992 1.358e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group CH2=C; count 2; } { group ACH; count 8; } { group AC; count 4; } { group CH2O; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group C; count 1; } { group dCH2; count 2; } { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[4-[2-[4-[2-[2-(2-methylprop-2-enoyloxy)ethoxy]ethoxy]phenyl]propan-2-yl]phenoxy]ethoxy]ethyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, (1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyl) ester" "propane-2,2-diylbis(benzene-4,1-diyloxyethane-2,1-diyloxyethane-2,1-diyl) bis(2-methylprop-2-enoate)" "2-propenoic acid, 2-methyl-, 1,1'-((1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyl)) ester" "2-propenoic acid, 2-methyl-, 1,1'-[(1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyl)] ester" "2-propenoic acid,2-methyl-,1,1'-[(1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyl)]ester" "2-propenoicacid, 2-methyl-, (1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyl)ester (9ci); 2,2-bis[4-(methacryloxydiethoxy)phenyl]propane; bpe 200; bisphenola bis(methacryloyloxyethoxyethyl ether); d 121; diacryl 121; nk ester be 400;nk ester bpe 200; nk ester bpe 4; nk-bpe 200; tedpadma" );
standardThermochemistry
{
    dHf_298   -1173960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1229.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-463620.0
}
