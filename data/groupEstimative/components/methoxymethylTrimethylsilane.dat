/*--------------------------------*- Choupo -*-----------------------*\
  Component: (methoxymethyl)trimethylsilane  (C5H14OSi, CAS 14704-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H14OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methoxymethylTrimethylsilane;
formula     C5H14OSi;
CAS         14704-14-4;
InChIKey    PPNQXAYCPNTVHH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          118.251;      // g/mol [origin=calculated method=formula-sum]
Tc          508.46;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.2383;      // -   [origin=predictive method=lee-kesler]
Tb          337.82;      // K   [origin=predictive method=joback]
HvapTb      29428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.661 0.20948 0.0002776 -2.237e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH3O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methoxymethyl(trimethyl)silane" "methoxymethyltrimethylsilane" "silane, (methoxymethyl)trimethyl-" "(trimethylsilyl)methyl methyl ether" "methoxymethyl-trimethylsilane" "(methoxymethyl)trimethylsilane;" "silane,(methoxymethyl)trimethyl-" "ppnqxaycpntvhh-uhfffaoysa-" "trimethylsilylmethyl methyl ether" );
standardThermochemistry
{
    dHf_298   -390370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-218540.0
}
