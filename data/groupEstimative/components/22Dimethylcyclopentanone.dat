/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethylcyclopentanone  (C7H12O, CAS 4541-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethylcyclopentanone;
formula     C7H12O;
CAS         4541-32-6;
InChIKey    FTGZMZBYOHMEPS-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          667.95;      // K   [origin=predictive method=joback]
Pc          37.638;      // bar [origin=predictive method=joback]
omega       0.3163;      // -   [origin=predictive method=lee-kesler]
Tb          443.10;      // K   [origin=predictive method=joback]
HvapTb      34529.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.52 0.92414 -0.000773 2.966e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylcyclopentan-1-one" "cyclopentanone, 2,2-dimethyl-" "cyclopentanone, dimethyl-" "2,2-dimethyl-cyclopentan-1-one" );
gibbsFormation
{
    dHf_298   -249790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83470.0
    phase     gas;
}
