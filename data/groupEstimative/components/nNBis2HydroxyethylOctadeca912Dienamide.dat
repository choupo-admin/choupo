/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(2-hydroxyethyl)octadeca-9,12-dienamide  (C22H41NO3, CAS 56863-02-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis2HydroxyethylOctadeca912Dienamide;
formula     C22H41NO3;
CAS         56863-02-6;
InChIKey    CKNOIIXFUKKRIC-UHFFFAOYSA-N;
MW          367.574;      // g/mol [origin=calculated method=formula-sum]
Tc          1189.15;      // K   [origin=predictive method=joback]
Pc          11.253;      // bar [origin=predictive method=joback]
omega       0.9627;      // -   [origin=predictive method=lee-kesler]
Tb          961.95;      // K   [origin=predictive method=joback]
HvapTb      106629.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.224 2.29772 -0.0014953 3.9336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH=CH; count 2; } { group OH; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group dCH; count 4; } { group OH; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -612480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1144.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=3020.0
}
