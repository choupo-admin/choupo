/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimipramine maleate  (C24H30N2O4, CAS 521-78-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimipramineMaleate;
formula     C24H30N2O4;
CAS         521-78-8;
InChIKey    YDGHCKHAXOUQOS-BTJKTKAUSA-N;
MW          410.514;      // g/mol [origin=calculated method=formula-sum]
Tc          1397.03;      // K   [origin=predictive method=joback]
Pc          14.725;      // bar [origin=predictive method=joback]
omega       1.3098;      // -   [origin=predictive method=lee-kesler]
Tb          1140.20;      // K   [origin=predictive method=joback]
HvapTb      113222.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.428 2.36316 -0.00157472 3.935e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group CH3N; count 1; } { group CH2N; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COOH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-but-2-enedioic acid;3-(5,6-dihydrobenzo[b][1]benzazepin-11-yl)-n,n,2-trimethyl-propan-1-amine" "trimipramine maleate salt" "surmontil maleate" "trimeprimine maleate" "surmontil" "trimeprimine monomaleate" "trimipramini maleas" "trimipramium maleinicum" "trimipramine acid maleate" "trimipramine hydrogen maleate" "c20h26n2.c4h4o4" "739-71-9 (parent)" );
gibbsFormation
{
    dHf_298   -554430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1027.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55920.0
    phase     gas;
}
