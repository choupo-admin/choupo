/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-(dimethylamino)ethyl)-1-adamantaneacetamide ethyl iodide  (C18H33IN2O, CAS 54099-13-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2DimethylaminoEthyl1AdamantaneacetamideEthylIodide;
formula     C18H33IN2O;
CAS         54099-13-7;
InChIKey    PGOKHCGKMLHFFS-UHFFFAOYSA-N;
MW          420.375;      // g/mol [origin=calculated method=formula-sum]
Tc          1070.53;      // K   [origin=predictive method=joback]
Pc          15.319;      // bar [origin=predictive method=joback]
omega       0.9221;      // -   [origin=predictive method=lee-kesler]
Tb          842.52;      // K   [origin=predictive method=joback]
HvapTb      79005.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-165.406 2.42726 -0.0018559 6.0236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 3; } { group C; count 1; } { group CH3N; count 1; } { group I; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group I; count 1; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1-adamantyl)-n-[2-(dimethylamino)ethyl]ethanamide;iodanylethane" "1-adamantaneacetamide, n-(2-(dimethylamino)ethyl)-, ethyl iodide" "2-(1-adamantyl)-n-(2-dimethylaminoethyl)acetamide; iodoethane" );
gibbsFormation
{
    dHf_298   -234040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     880.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=282240.0
    phase     gas;
}
