/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,2-trifluoroethyl trifluoroacetate  (C4H2F6O2, CAS 407-38-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222TrifluoroethylTrifluoroacetate;
formula     C4H2F6O2;
CAS         407-38-5;
InChIKey    ZKUJOCJJXCPCFS-UHFFFAOYSA-N;
MW          196.046;      // g/mol [origin=calculated method=formula-sum]
Tc          480.66;      // K   [origin=predictive method=joback]
Pc          29.893;      // bar [origin=predictive method=joback]
omega       0.5017;      // -   [origin=predictive method=lee-kesler]
Tb          338.50;      // K   [origin=predictive method=joback]
HvapTb      24411.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.261 0.6514 -0.0005412 1.567e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CF3; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 2; } { group F; count 6; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(fluoranyl)ethyl 2,2,2-tris(fluoranyl)ethanoate" "2,2,2-trifluoroethyl 2,2,2-trifluoroacetate" "trifluoroacetic acid 2,2,2-trifluoroethyl ester" "acetic acid, trifluoro-, 2,2,2-trifluoroethyl ester" "2,2,2-trifluoroethyl 2,2,2-trifluoroethanoate" "aceticacid, trifluoro-, 2,2,2-trifluoroethyl ester (6ci,7ci,8ci,9ci);ethanol,2,2,2-trifluoro-, trifluoroacetate (8ci);2,2,2-trifluoroethyltrifluoroacetate;trifluoroethyl trifluoroacetate;" );
gibbsFormation
{
    dHf_298   -1637330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1490750.0
    phase     gas;
}
