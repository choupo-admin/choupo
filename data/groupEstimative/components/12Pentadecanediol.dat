/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-pentadecanediol  (C15H32O2, CAS 33968-47-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Pentadecanediol;
formula     C15H32O2;
CAS         33968-47-7;
InChIKey    FETBCQJCOOEKPM-UHFFFAOYSA-N;
MW          244.419;      // g/mol [origin=calculated method=formula-sum]
Tc          893.40;      // K   [origin=predictive method=joback]
Pc          16.444;      // bar [origin=predictive method=joback]
omega       1.3631;      // -   [origin=predictive method=lee-kesler]
Tb          726.72;      // K   [origin=predictive method=joback]
HvapTb      81954.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.847 1.50272 -0.0008562 1.864e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadecane-1,2-diol" "(?a'a a'a currency)-1,2-pentadecanediol" );
standardThermochemistry
{
    dHf_298   -662670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     832.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200660.0
}
