/*--------------------------------*- Choupo -*-----------------------*\
  Component: sabinyl acetate  (C12H18O2, CAS 3536-54-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sabinylAcetate;
formula     C12H18O2;
CAS         3536-54-7;
InChIKey    PBWRFXQNNGSAQG-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          744.11;      // K   [origin=predictive method=joback]
Pc          23.428;      // bar [origin=predictive method=joback]
omega       0.5592;      // -   [origin=predictive method=lee-kesler]
Tb          540.15;      // K   [origin=predictive method=joback]
HvapTb      47850.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.54 1.54466 -0.0013628 5.133e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methylidene-1-propan-2-yl-3-bicyclo[3.1.0]hexanyl) ethanoate" "4(10)-thujen-3-ol, acetate" "bicyclo[3.1.0]hexan-3-ol, 4-methylene-1-(1-methylethyl)-, acetate" "bicyclo(3.1.0)hexan-3-ol, 4-methylene-1-(1-methylethyl)-, acetate" "(2-methylidene-5-propan-2-yl-3-bicyclo[3.1.0]hexanyl) acetate" "(1s,3r,5s)-4-methylidene-1-(propan-2-yl)bicyclo[3.1.0]hex-3-yl acetate" );
standardThermochemistry
{
    dHf_298   -388830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-101270.0
}
