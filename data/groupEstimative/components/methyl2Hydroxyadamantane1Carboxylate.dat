/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-hydroxyadamantane-1-carboxylate  (C12H18O3, CAS 41171-74-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Hydroxyadamantane1Carboxylate;
formula     C12H18O3;
CAS         41171-74-8;
InChIKey    SEVMKXVZUKPSMQ-UHFFFAOYSA-N;
MW          210.273;      // g/mol [origin=calculated method=formula-sum]
Tc          844.64;      // K   [origin=predictive method=joback]
Pc          28.323;      // bar [origin=predictive method=joback]
omega       0.9808;      // -   [origin=predictive method=lee-kesler]
Tb          639.95;      // K   [origin=predictive method=joback]
HvapTb      64534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-171.28 1.80502 -0.0016008 5.939e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 4; } { group C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 4; } { group C_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-oxidanyladamantane-1-carboxylate" "methyl 2-hydroxy-1-adamantanecarboxylate" "tricyclo[3.3.1.1(3,7)]decane-2-ol-1-carboxylic acid, methyl ester" "tricyclo(3.3.1.13,7)decane-2-ol-1-carboxylic acid, methyl ester" );
standardThermochemistry
{
    dHf_298   -573720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-247790.0
}
