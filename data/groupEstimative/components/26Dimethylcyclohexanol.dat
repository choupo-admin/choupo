/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethylcyclohexanol  (C8H16O, CAS 5337-72-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethylcyclohexanol;
formula     C8H16O;
CAS         5337-72-4;
InChIKey    MOISVRZIQDQVPF-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          675.10;      // K   [origin=predictive method=joback]
Pc          32.467;      // bar [origin=predictive method=joback]
omega       0.6565;      // -   [origin=predictive method=lee-kesler]
Tb          485.03;      // K   [origin=predictive method=joback]
HvapTb      49892.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.82 0.86694 -0.000412 4.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethylcyclohexan-1-ol" "cyclohexanol, 2,6-dimethyl-" "cyclohexanol,6-dimethyl-" "2,6-dimethyl-cyclohexan-1-ol" "a,a-2,6-dimethylcyclohexanol, (e)" "a,e-2,6-dimethylcyclohexanol, (e)" "e,a-2,6-dimethylcyclohexanol, (a)" "e,e-2,6-dimethylcyclohexanol, (a)" "e,e-2,6-dimethylcyclohexanol, (e)" "4-(1-oxo-1,3-dihydro-2h-isoindol-2-yl)benzamide" "3,3a-diphenyl-4-thioxo-3,3a,4,8b-tetrahydro-2h-indeno[2,1-d][1,3]oxazol-2-one" );
standardThermochemistry
{
    dHf_298   -347040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-111310.0
}
