/*--------------------------------*- Choupo -*-----------------------*\
  Component: oleyl oleamide  (C36H69NO, CAS 72901-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oleylOleamide;
formula     C36H69NO;
CAS         72901-31-6;
InChIKey    GCAONVVVMAVFDE-UHFFFAOYSA-N;
MW          531.954;      // g/mol [origin=calculated method=formula-sum]
Tc          1472.03;      // K   [origin=predictive method=joback]
Pc          4.951;      // bar [origin=predictive method=joback]
omega       -0.0125;      // -   [origin=predictive method=lee-kesler]
Tb          1135.64;      // K   [origin=predictive method=joback]
HvapTb      108828.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.051 3.51204 -0.0021321 5.1346e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 28; } { group CH=CH; count 2; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 29; } { group dCH; count 4; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-octadec-9-enyloctadec-9-enamide" "9-octadecenamide, n-(9z)-9-octadecenyl-, (9z)-" "9-octadecenamide, n-(9z)-9-octadecen-1-yl-, (9z)-" "(e)-n-[(e)-octadec-9-enyl]octadec-9-enamide" );
gibbsFormation
{
    dHf_298   -611040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1612.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=373150.0
    phase     gas;
}
