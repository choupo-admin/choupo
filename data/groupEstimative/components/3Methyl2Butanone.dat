/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-2-butanone  (C5H10O, CAS 563-80-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl2Butanone;
formula     C5H10O;
CAS         563-80-4;
InChIKey    SYBYTAAJFKOIEJ-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          550.07;      // K   [origin=predictive method=joback]
Pc          37.777;      // bar [origin=predictive method=joback]
omega       0.3457;      // -   [origin=predictive method=lee-kesler]
Tb          367.43;      // K   [origin=predictive method=joback]
HvapTb      33082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.02 0.45676 -0.0002327 3.876e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutan-2-one" "isopropyl methyl ketone" "2-butanone, 3-methyl-" "2-acetylpropane" "methyl isopropyl ketone" "methyl butanone-2" "mipk" "ketone, isopropyl methyl" "3-methylbutanone" "2-acetyl propane" "methylbutanone (van)" "2-methyl-3-butanone" );
gibbsFormation
{
    dHf_298   -264390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     367.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-140140.0
    phase     gas;
}
