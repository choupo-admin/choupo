/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-(2-hydroxyethoxy)benzoate  (C10H12O4, CAS 3204-73-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl42HydroxyethoxyBenzoate;
formula     C10H12O4;
CAS         3204-73-7;
InChIKey    VFBYWNSASHHPPA-UHFFFAOYSA-N;
MW          196.202;      // g/mol [origin=calculated method=formula-sum]
Tc          828.58;      // K   [origin=predictive method=joback]
Pc          31.491;      // bar [origin=predictive method=joback]
omega       1.1227;      // -   [origin=predictive method=lee-kesler]
Tb          632.88;      // K   [origin=predictive method=joback]
HvapTb      67288.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.392 0.73142 -0.00030916 6.3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-(2-hydroxyethyloxy)benzoate" "4-(2-hydroxyethoxy)benzoic acid methyl ester" "benzoic acid, 4-(2-hydroxyethoxy)-, methyl ester" "methyl p-(2-hydroxyethoxy)benzoate" "benzoic acid,4-(2-hydroxyethoxy)-, methyl ester" "benzoicacid, p-(2-hydroxyethoxy)-, methyl ester (6ci,7ci,8ci);4-(2-hydroxyethoxy)benzoic acid methyl ester; methyl4-(2-hydroxyethoxy)benzoate; methyl 4-(b-hydroxyethoxy)benzoate; methylp-(2-hydroxyethoxy)benzoate; methyl p-(b-hydroxyethoxy)benzoate" );
standardThermochemistry
{
    dHf_298   -626400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-416090.0
}
