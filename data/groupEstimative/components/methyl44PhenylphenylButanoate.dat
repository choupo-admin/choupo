/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-(4-phenylphenyl)butanoate  (C17H18O2, CAS 20637-07-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl44PhenylphenylButanoate;
formula     C17H18O2;
CAS         20637-07-4;
InChIKey    ZKYIDZVHHNPNSZ-UHFFFAOYSA-N;
MW          254.329;      // g/mol [origin=calculated method=formula-sum]
Tc          932.89;      // K   [origin=predictive method=joback]
Pc          20.699;      // bar [origin=predictive method=joback]
omega       0.7697;      // -   [origin=predictive method=lee-kesler]
Tb          705.12;      // K   [origin=predictive method=joback]
HvapTb      66057.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.667 1.34672 -0.00080176 1.601e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-biphenylyl)butanoic acid methyl ester" );
standardThermochemistry
{
    dHf_298   -249900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2920.0
}
