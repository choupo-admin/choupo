/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4-trifluorophenyl isocyanate  (C7H2F3NO, CAS 190774-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        234TrifluorophenylIsocyanate;
formula     C7H2F3NO;
CAS         190774-58-4;
InChIKey    LSKOUPSEWMJCEP-UHFFFAOYSA-N;
MW          173.093;      // g/mol [origin=calculated method=formula-sum]
Tc          660.06;      // K   [origin=predictive method=joback]
Pc          36.072;      // bar [origin=predictive method=joback]
omega       0.5979;      // -   [origin=predictive method=lee-kesler]
Tb          465.86;      // K   [origin=predictive method=joback]
HvapTb      42519.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACF; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group dCd; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 3; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-tris(fluoranyl)-4-isocyanato-benzene" "2,3,4-trifluorobenzenisocyanate" "2,3,4-trifluorophenylisocyanate;" "1,2,3-trifluoro-4-isocyanatobenzene" "benzene,1,2,3-trifluoro-4-isocyanato-" );
