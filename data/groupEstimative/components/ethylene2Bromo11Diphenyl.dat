/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylene, 2-bromo-1,1-diphenyl-  (C14H11Br, CAS 13249-58-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylene2Bromo11Diphenyl;
formula     C14H11Br;
CAS         13249-58-6;
InChIKey    QRDVTIMUEDYLOC-UHFFFAOYSA-N;
MW          259.146;      // g/mol [origin=calculated method=formula-sum]
Tc          912.41;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.5367;      // -   [origin=predictive method=lee-kesler]
Tb          643.48;      // K   [origin=predictive method=joback]
HvapTb      57783.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.33 1.2341 -0.0009577 2.897e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-bromanyl-1-phenyl-ethenyl)benzene" "(2-bromo-1-phenylethenyl)benzene" "(2-bromo-1-phenylvinyl)benzene" );
standardThermochemistry
{
    dHf_298   274530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=377810.0
}
