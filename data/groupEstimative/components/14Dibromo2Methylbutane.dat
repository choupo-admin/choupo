/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dibromo-2-methylbutane  (C5H10Br2, CAS 69498-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dibromo2Methylbutane;
formula     C5H10Br2;
CAS         69498-28-8;
InChIKey    SBCDMKDTWODACO-UHFFFAOYSA-N;
MW          229.943;      // g/mol [origin=calculated method=formula-sum]
Tc          654.87;      // K   [origin=predictive method=joback]
Pc          41.516;      // bar [origin=predictive method=joback]
omega       0.4668;      // -   [origin=predictive method=lee-kesler]
Tb          445.88;      // K   [origin=predictive method=joback]
HvapTb      39206.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.043 0.56112 -0.0003942 1.16e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(bromanyl)-2-methyl-butane" "agn-pc-00gjul" "butane, 1,4-dibromo-2-methyl-" );
standardThermochemistry
{
    dHf_298   -99150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17420.0
}
