/*--------------------------------*- Choupo -*-----------------------*\
  Component: carveol  (C10H16O, CAS 99-48-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carveol;
formula     C10H16O;
CAS         99-48-9;
InChIKey    BAVONGHXFVOKBV-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          731.93;      // K   [origin=predictive method=joback]
Pc          29.345;      // bar [origin=predictive method=joback]
omega       0.7345;      // -   [origin=predictive method=lee-kesler]
Tb          536.16;      // K   [origin=predictive method=joback]
HvapTb      55017.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.18 0.94784 -0.00052164 9.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2=C; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-5-prop-1-en-2-yl-cyclohex-2-en-1-ol" "p-mentha-1,8-dien-6-ol" "p-mentha-6,8-dien-2-ol" "l-carveol" "2-cyclohexen-1-ol, 2-methyl-5-(1-methylethenyl)-" "1-methyl-4-isopropenyl-6-cyclohexen-2-ol" "5-isopropenyl-2-methylcyclohex-2-en-1-ol" "5-isopropenyl-2-methyl-2-cyclohexen-1-ol" "p-mentha-1(6),8-dien-2-ol" "2-methyl-5-(1-methylethenyl)-2-cyclohexen-1-ol" "p-mentha-6,8-dien-2-ol (van)" "2-methyl-5-isopropenyl-2-cyclohexen-1-ol" );
gibbsFormation
{
    dHf_298   -206030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12860.0
    phase     gas;
}
