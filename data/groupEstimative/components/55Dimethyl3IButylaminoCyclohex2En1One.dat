/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-3-i-butylamino-cyclohex-2-en-1-one  (C12H21NO, CAS 82663-49-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl3IButylaminoCyclohex2En1One;
formula     C12H21NO;
CAS         82663-49-8;
InChIKey    TWJANHDHUVWEPJ-UHFFFAOYSA-N;
MW          195.306;      // g/mol [origin=calculated method=formula-sum]
Tc          837.72;      // K   [origin=predictive method=joback]
Pc          23.959;      // bar [origin=predictive method=joback]
omega       0.6492;      // -   [origin=predictive method=lee-kesler]
Tb          615.64;      // K   [origin=predictive method=joback]
HvapTb      52833.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.999 1.35618 -0.00097064 3.155e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethyl-3-(2-methylpropylamino)cyclohex-2-en-1-one" "5,5-dimethyl-3-(isobutylamino)cyclohex-2-enone" );
standardThermochemistry
{
    dHf_298   -264650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53810.0
}
