/*--------------------------------*- Choupo -*-----------------------*\
  Component: 15-tetracosenoic acid, (e)-  (C24H46O2, CAS 506-37-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15TetracosenoicAcidE;
formula     C24H46O2;
CAS         506-37-6;
InChIKey    GWHCXVQVJPWHRF-UHFFFAOYSA-N;
MW          366.63;      // g/mol [origin=calculated method=formula-sum]
Tc          1100.16;      // K   [origin=predictive method=joback]
Pc          8.748;      // bar [origin=predictive method=joback]
omega       0.8438;      // -   [origin=predictive method=lee-kesler]
Tb          898.39;      // K   [origin=predictive method=joback]
HvapTb      86140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.51 2.35462 -0.0014382 3.498e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 20; } { group CH=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 20; } { group dCH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetracos-15-enoic acid" "15-tetracosenoic acid" );
gibbsFormation
{
    dHf_298   -771740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1137.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-112490.0
    phase     gas;
}
