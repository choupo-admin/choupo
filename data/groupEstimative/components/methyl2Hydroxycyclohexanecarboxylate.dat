/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-hydroxycyclohexanecarboxylate  (C8H14O3, CAS 2236-11-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Hydroxycyclohexanecarboxylate;
formula     C8H14O3;
CAS         2236-11-5;
InChIKey    IAJQZEQYGUQTQS-UHFFFAOYSA-N;
MW          158.197;      // g/mol [origin=calculated method=formula-sum]
Tc          743.05;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.8603;      // -   [origin=predictive method=lee-kesler]
Tb          547.92;      // K   [origin=predictive method=joback]
HvapTb      57608.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.35 0.83862 -0.0003728 1.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-oxidanylcyclohexane-1-carboxylate" "methyl 2-hydroxycyclohexane-1-carboxylate" "cyclohexanecarboxylic acid, 2-hydroxy-, methyl ester" "2-carbomethoxycyclohexanol" );
standardThermochemistry
{
    dHf_298   -643980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-413970.0
}
