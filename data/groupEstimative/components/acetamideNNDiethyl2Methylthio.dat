/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetamide, n,n-diethyl-2-methylthio-  (C7H15NOS, CAS 14680-21-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetamideNNDiethyl2Methylthio;
formula     C7H15NOS;
CAS         14680-21-8;
InChIKey    UHOGSWLXHHRSFG-UHFFFAOYSA-N;
MW          161.263;      // g/mol [origin=calculated method=formula-sum]
Tc          690.64;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.6089;      // -   [origin=predictive method=lee-kesler]
Tb          494.85;      // K   [origin=predictive method=joback]
HvapTb      46782.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.793 0.75915 -0.0004107 7.286e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CON_CH2_2; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CdO; count 1; } { group N; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-2-methylsulfanyl-ethanamide" "n,n-diethyl-2-methylsulfanylacetamide" );
gibbsFormation
{
    dHf_298   -190990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23040.0
    phase     gas;
}
