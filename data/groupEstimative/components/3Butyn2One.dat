/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-butyn-2-one  (C4H4O, CAS 1423-60-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Butyn2One;
formula     C4H4O;
CAS         1423-60-5;
InChIKey    XRGPFNGLRSIPSA-UHFFFAOYSA-N;
MW          68.075;      // g/mol [origin=calculated method=formula-sum]
Tc          527.25;      // K   [origin=predictive method=joback]
Pc          51.683;      // bar [origin=predictive method=joback]
omega       0.2617;      // -   [origin=predictive method=lee-kesler]
Tb          335.11;      // K   [origin=predictive method=joback]
HvapTb      31102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.39 0.26192 -0.00017103 4.575e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 1; } { group tC; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-3-yn-2-one" "1-butyn-3-one" "methyl ethynyl ketone" "acetylacetylene" "acetylethyne" "butyn-2-one" "1-butyne-3-one" "3-butyne-2-one" "ethynyl methyl ketone" "3 -butyn-2-one" "ch3coc#ch" "3-butyn-2-one(6ci,7ci,8ci,9ci)" );
gibbsFormation
{
    dHf_298   53430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     308.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76950.0
    phase     gas;
}
