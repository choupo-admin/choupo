/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxybenzoic acid  (C7H6O3, CAS 99-96-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HydroxybenzoicAcid;
formula     C7H6O3;
CAS         99-96-7;
InChIKey    FJKROLUGYXJWQN-UHFFFAOYSA-N;
MW          138.122;      // g/mol [origin=calculated method=formula-sum]
Tc          855.92;      // K   [origin=predictive method=joback]
Pc          57.305;      // bar [origin=predictive method=joback]
omega       0.9026;      // -   [origin=predictive method=lee-kesler]
Tb          612.57;      // K   [origin=predictive method=joback]
HvapTb      63630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.7 0.7953 -0.00071716 2.587e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylbenzoic acid" "p-hydroxybenzoic acid" "4-carboxyphenol" "benzoic acid, 4-hydroxy-" "p-salicylic acid" "benzoic acid, p-hydroxy-" "p-carboxyphenol" "4-hydroxybenzoesaeure" "para-hydroxybenzoic acid" "p-oxybenzoesaure [german]" "p-salicyclic acid" "hydroxybenzoic acid" );
gibbsFormation
{
    dHf_298   -478860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-378060.0
    phase     gas;
}
