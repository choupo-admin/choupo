/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1-tridecene  (C14H28, CAS 18094-01-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Tridecene;
formula     C14H28;
CAS         18094-01-4;
InChIKey    VNBHQOHLCULRDN-UHFFFAOYSA-N;
MW          196.378;      // g/mol [origin=calculated method=formula-sum]
Tc          681.28;      // K   [origin=predictive method=joback]
Pc          15.810;      // bar [origin=predictive method=joback]
omega       0.6277;      // -   [origin=predictive method=lee-kesler]
Tb          516.48;      // K   [origin=predictive method=joback]
HvapTb      46168.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.52 1.31374 -0.000763 1.746e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyltridec-1-ene" "2-methyl-n-1-tridecene" "1-tridecene, 2-methyl-" );
gibbsFormation
{
    dHf_298   -216650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     692.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=146290.0
    phase     gas;
}
