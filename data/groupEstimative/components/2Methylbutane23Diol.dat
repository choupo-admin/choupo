/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylbutane-2,3-diol  (C5H12O2, CAS 5396-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylbutane23Diol;
formula     C5H12O2;
CAS         5396-58-7;
InChIKey    IDEOPBXRUBNYBN-UHFFFAOYSA-N;
MW          104.149;      // g/mol [origin=calculated method=formula-sum]
Tc          664.46;      // K   [origin=predictive method=joback]
Pc          45.225;      // bar [origin=predictive method=joback]
omega       1.0992;      // -   [origin=predictive method=lee-kesler]
Tb          494.69;      // K   [origin=predictive method=joback]
HvapTb      58398.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.23 0.67856 -0.000484 1.393e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-2,3-butanediol" "2,3-dihydroxy-2-methylbutane" "2,3-butanediol, 2-methyl-" "2,3-butanediol,2-methyl-" "2,3-butanediol, 2-methyl- (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   -465020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-282020.0
    phase     gas;
}
