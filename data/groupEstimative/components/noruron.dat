/*--------------------------------*- Choupo -*-----------------------*\
  Component: noruron  (C13H22N2O, CAS 18530-56-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        noruron;
formula     C13H22N2O;
CAS         18530-56-8;
InChIKey    YGLMVCVJLXREAK-UHFFFAOYSA-N;
MW          222.332;      // g/mol [origin=calculated method=formula-sum]
Tc          838.48;      // K   [origin=predictive method=joback]
Pc          23.959;      // bar [origin=predictive method=joback]
omega       0.7937;      // -   [origin=predictive method=lee-kesler]
Tb          628.67;      // K   [origin=predictive method=joback]
HvapTb      59050.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-157.44 1.80104 -0.0013293 3.9396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 4; } { group CHNH; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 5; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "norea" "herban" "narea" "nores" "asepta herban" "noruron [iso]" "norea [ansi]" "3-(hexahydro-4,7-methanoindan-5-yl)-1,1-dimethylurea" "urea, n,n-dimethyl-n'-(octahydro-4,7-methano-1h-inden-5-yl)-" "1,1-dimethyl-3-tetrahydrodicyclopentadienylurea" "n,n-dimethyl-n'-tetrahydrodicyclopentadienylurea" "1-(tetrahydrodicyclopentadienyl)-3,3-dimethylurea" );
gibbsFormation
{
    dHf_298   -131670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=284560.0
    phase     gas;
}
