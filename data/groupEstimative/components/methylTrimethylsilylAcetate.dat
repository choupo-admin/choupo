/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl(trimethylsilyl)acetate  (C6H14O2Si, CAS 2916-76-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H14O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methylTrimethylsilylAcetate;
formula     C6H14O2Si;
CAS         2916-76-9;
InChIKey    JIHUZDFFYVRXKP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          146.261;      // g/mol [origin=calculated method=formula-sum]
Tc          576.43;      // K   [origin=predictive method=joback]
Pc          27.440;      // bar [origin=predictive method=joback]
omega       0.3498;      // -   [origin=predictive method=lee-kesler]
Tb          396.50;      // K   [origin=predictive method=joback]
HvapTb      36651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.661 0.31288 0.0002068 -2.141e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2COO; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-trimethylsilylethanoate" "methyl (trimethylsilyl)acetate" "methyl trimethylsilylacetate" "methyl 2-trimethylsilylacetate" "jihuzdffyvrxkp-uhfffaoysa-" "methyl 2-(trimethylsilyl)acetate" );
gibbsFormation
{
    dHf_298   -596070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-415490.0
    phase     gas;
}
