/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-2,4-hexadiene  (C7H12, CAS 28823-42-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl24Hexadiene;
formula     C7H12;
CAS         28823-42-9;
InChIKey    KOXWOWPVSGRFCZ-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          553.44;      // K   [origin=predictive method=joback]
Pc          31.526;      // bar [origin=predictive method=joback]
omega       0.2622;      // -   [origin=predictive method=lee-kesler]
Tb          367.96;      // K   [origin=predictive method=joback]
HvapTb      31172.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.53 0.70876 -0.0005269 1.687e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 3; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylhexa-2,4-diene" "2,4-hexadiene, 3-methyl-, (z,z)-" );
standardThermochemistry
{
    dHf_298   36840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=159950.0
}
