/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-decyne-4,7-diol  (C10H18O2, CAS 1070-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Decyne47Diol;
formula     C10H18O2;
CAS         1070-40-2;
InChIKey    DPWCXHJKJXRDBZ-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          796.73;      // K   [origin=predictive method=joback]
Pc          30.256;      // bar [origin=predictive method=joback]
omega       1.3083;      // -   [origin=predictive method=lee-kesler]
Tb          620.88;      // K   [origin=predictive method=joback]
HvapTb      72588.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.574 0.88384 -0.00049526 1.0538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group tC; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dec-5-yne-4,7-diol" );
standardThermochemistry
{
    dHf_298   -292450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42400.0
}
