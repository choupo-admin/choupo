/*--------------------------------*- Choupo -*-----------------------*\
  Component: propionic acid, 3-(4-chloro-3,5-xylyloxy)-, ethyl ester  (C13H17ClO3, CAS 53830-54-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propionicAcid34Chloro35XylyloxyEthylEster;
formula     C13H17ClO3;
CAS         53830-54-9;
InChIKey    IZVZOJUBPHYREU-UHFFFAOYSA-N;
MW          256.726;      // g/mol [origin=calculated method=formula-sum]
Tc          862.06;      // K   [origin=predictive method=joback]
Pc          20.127;      // bar [origin=predictive method=joback]
omega       0.8157;      // -   [origin=predictive method=lee-kesler]
Tb          656.73;      // K   [origin=predictive method=joback]
HvapTb      62996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.863 0.87026 -0.00032828 -8.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 2; } { group CH2COO; count 1; } { group CH2O; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-(4-chloranyl-3,5-dimethyl-phenoxy)propanoate" "ethyl 3-(4-chloro-3,5-dimethyl-phenoxy)propanoate" "ethyl 3-(4-chloro-3,5-dimethylphenoxy)propanoate" );
gibbsFormation
{
    dHf_298   -574770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-285200.0
    phase     gas;
}
