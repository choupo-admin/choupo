/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,9-dihydroxybenzanthracene  (C18H12O2, CAS 56614-97-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        39Dihydroxybenzanthracene;
formula     C18H12O2;
CAS         56614-97-2;
InChIKey    CQTBIAMUVNXBKY-UHFFFAOYSA-N;
MW          260.292;      // g/mol [origin=calculated method=formula-sum]
Tc          1139.64;      // K   [origin=predictive method=joback]
Pc          38.483;      // bar [origin=predictive method=joback]
omega       1.2007;      // -   [origin=predictive method=lee-kesler]
Tb          866.26;      // K   [origin=predictive method=joback]
HvapTb      90210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-130.95 1.814 -0.0017754 6.882e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 6; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 10; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzo[a]anthracene-3,9-diol" "3,9-dihydroxybenz(a)anthracene" "benz(a)anthracene-3,9-diol" );
gibbsFormation
{
    dHf_298   17330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=204540.0
    phase     gas;
}
