/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylenebis(4-phenylisocyanate), adipic acid, 1,4-butylene glycol, 4,4'-diaminodiphenylmethane polymer  (C38H44N4O8, CAS 50981-28-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylenebis4PhenylisocyanateAdipicAcid14ButyleneGlycol44Dia;
formula     C38H44N4O8;
CAS         50981-28-7;
InChIKey    JQYGJZUSCJRGHC-UHFFFAOYSA-N;
MW          684.79;      // g/mol [origin=calculated method=formula-sum]
Tc          2945.72;      // K   [origin=predictive method=joback]
Pc          9.514;      // bar [origin=predictive method=joback]
omega       -0.1701;      // -   [origin=predictive method=lee-kesler]
Tb          1953.66;      // K   [origin=predictive method=joback]
HvapTb      220848.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 8; } { group ACH; count 16; } { group AC; count 4; } { group ACCH2; count 2; } { group OH; count 2; } { group ACNH2; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 10; } { group dCd; count 2; } { group dCH_ring; count 16; } { group dC_ring; count 8; } { group OH; count 2; } { group COOH; count 2; } { group dO_oth; count 2; } { group NH2; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(4-aminophenyl)methyl]aniline;butane-1,4-diol;hexanedioic acid;1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene" "4-[(4-aminophenyl)methyl]aniline; butane-1,4-diol; hexanedioic acid; 1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene" "hexanedioic acid, polymer with 1,4-butanediol, 4,4'-methylenebis(benzenamine) and 1,1'-methylenebis(4-isocyanatobenzene)" );
