/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3,5-dibromo-2-pentyloxybenzyloxy)triethylamine  (C18H29Br2NO2, CAS 109593-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        235Dibromo2PentyloxybenzyloxyTriethylamine;
formula     C18H29Br2NO2;
CAS         109593-75-1;
InChIKey    LQXINFJRTAAUGV-UHFFFAOYSA-N;
MW          451.243;      // g/mol [origin=calculated method=formula-sum]
Tc          1049.98;      // K   [origin=predictive method=joback]
Pc          15.283;      // bar [origin=predictive method=joback]
omega       1.1296;      // -   [origin=predictive method=lee-kesler]
Tb          842.66;      // K   [origin=predictive method=joback]
HvapTb      79657.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.209 1.53036 -0.00081888 1.498e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2O; count 2; } { group CH2N; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 2; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[3,5-bis(bromanyl)-2-pentoxy-phenyl]methoxy]-n,n-diethyl-ethanamine" "triethylamine, 2-(3,5-dibromo-2-pentyloxybenzyloxy)-" "2-[(3,5-dibromo-2-pentoxyphenyl)methoxy]-n,n-diethylethanamine" );
gibbsFormation
{
    dHf_298   -356980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     872.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113620.0
    phase     gas;
}
