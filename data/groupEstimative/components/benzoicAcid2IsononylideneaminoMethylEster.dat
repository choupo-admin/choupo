/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 2-(isononylideneamino)-, methyl ester  (C17H25NO2, CAS 67923-84-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid2IsononylideneaminoMethylEster;
formula     C17H25NO2;
CAS         67923-84-6;
InChIKey    LVANARGDNNHGNV-UHFFFAOYSA-N;
MW          275.392;      // g/mol [origin=calculated method=formula-sum]
Tc          963.81;      // K   [origin=predictive method=joback]
Pc          17.189;      // bar [origin=predictive method=joback]
omega       0.9564;      // -   [origin=predictive method=lee-kesler]
Tb          754.69;      // K   [origin=predictive method=joback]
HvapTb      73992.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.135 1.51344 -0.00090096 1.925e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2NH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-(8-azanyl-7-methyl-oct-1-enyl)benzoate" );
standardThermochemistry
{
    dHf_298   -340700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     792.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28900.0
}
