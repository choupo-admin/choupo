/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 4-(tridecyloxy)-  (C20H32O3, CAS 15872-45-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid4Tridecyloxy;
formula     C20H32O3;
CAS         15872-45-4;
InChIKey    QYHMLTVCBNFGAU-UHFFFAOYSA-N;
MW          320.473;      // g/mol [origin=calculated method=formula-sum]
Tc          1058.16;      // K   [origin=predictive method=joback]
Pc          13.223;      // bar [origin=predictive method=joback]
omega       1.1128;      // -   [origin=predictive method=lee-kesler]
Tb          856.79;      // K   [origin=predictive method=joback]
HvapTb      82626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.798 1.75302 -0.00098996 2.006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-tridecoxybenzoic acid" "agn-pc-02ot8z" );
standardThermochemistry
{
    dHf_298   -713560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     886.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-228610.0
}
