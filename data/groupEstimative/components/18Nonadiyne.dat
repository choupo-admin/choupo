/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-nonadiyne  (C9H12, CAS 2396-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Nonadiyne;
formula     C9H12;
CAS         2396-65-8;
InChIKey    DMOVPHYFYSASTC-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          572.80;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.3110;      // -   [origin=predictive method=lee-kesler]
Tb          385.76;      // K   [origin=predictive method=joback]
HvapTb      35344.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.265 0.671 -0.00045766 1.3268e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group tCH; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nona-1,8-diyne" );
standardThermochemistry
{
    dHf_298   354710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=471040.0
}
