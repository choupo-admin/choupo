/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,4,4-tetramethylcyclopentene  (C9H16, CAS 65378-76-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1244Tetramethylcyclopentene;
formula     C9H16;
CAS         65378-76-9;
InChIKey    NOZQIIOHDFVATK-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          634.97;      // K   [origin=predictive method=joback]
Pc          29.187;      // bar [origin=predictive method=joback]
omega       0.3083;      // -   [origin=predictive method=lee-kesler]
Tb          430.16;      // K   [origin=predictive method=joback]
HvapTb      36350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.39 1.10748 -0.000979 3.878e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4,4-tetramethyl-1-cyclopentene" "1,2,4,4-tetramethyl cyclopentene" "cyclopentene,1,2,4,4-tetramethyl-" "1,2,4,4-tetramethyl-1-cyclopentene;1,2,4,4-tetramethylcyclopentene" );
gibbsFormation
{
    dHf_298   -118530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66660.0
    phase     gas;
}
