/*--------------------------------*- Choupo -*-----------------------*\
  Component: tridecanal  (C13H26O, CAS 10486-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tridecanal;
formula     C13H26O;
CAS         10486-19-8;
InChIKey    BGEHHAVMRVXCGR-UHFFFAOYSA-N;
MW          198.35;      // g/mol [origin=calculated method=formula-sum]
Tc          711.24;      // K   [origin=predictive method=joback]
Pc          17.477;      // bar [origin=predictive method=joback]
omega       0.7843;      // -   [origin=predictive method=lee-kesler]
Tb          545.70;      // K   [origin=predictive method=joback]
HvapTb      51252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.471 1.21332 -0.0006764 1.414e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridecyl aldehyde" "n-tridecylaldehyde" "tridecanaldehyde" "n-tridecanal, 90%" "aldehyde13-13;tridecanaldehyde;tridecyl aldehyde;n-tridecanal;n-tridecylaldehyde;" );
gibbsFormation
{
    dHf_298   -397230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     681.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40940.0
    phase     gas;
}
