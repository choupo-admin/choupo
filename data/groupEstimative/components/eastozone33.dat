/*--------------------------------*- Choupo -*-----------------------*\
  Component: eastozone 33  (C20H36N2, CAS 3081-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eastozone33;
formula     C20H36N2;
CAS         3081-14-9;
InChIKey    ZJNLYGOUHDJHMG-UHFFFAOYSA-N;
MW          304.522;      // g/mol [origin=calculated method=formula-sum]
Tc          986.48;      // K   [origin=predictive method=joback]
Pc          13.090;      // bar [origin=predictive method=joback]
omega       0.9443;      // -   [origin=predictive method=lee-kesler]
Tb          787.44;      // K   [origin=predictive method=joback]
HvapTb      74372.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.046 1.94152 -0.00113836 2.464e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CHNH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n4-bis(5-methylhexan-2-yl)benzene-1,4-diamine" "eastozone" "tenamene 4" "elastozone 33" "flexzone 4l" "santoflex 77" "1,4-benzenediamine, n,n'-bis(1,4-dimethylpentyl)-" "n,n'-bis(1,4-dimethylpentyl)-p-phenylenediamine" "p-phenylenediamine, n,n'-bis(1,4-dimethylpentyl)-" "n,n-di(1,4-dimethylpentyl)-p-phenylenediamine" "n,n'-bis-(1,4 dimethylpentyl)-p-phenylenediamine" "1,4-benzenediamine, n1,n4-bis(1,4-dimethylpentyl)-" );
gibbsFormation
{
    dHf_298   -145250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     865.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=389320.0
    phase     gas;
}
