/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentaerythritol tetravalerate  (C25H44O8, CAS 15834-04-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentaerythritolTetravalerate;
formula     C25H44O8;
CAS         15834-04-5;
InChIKey    ZQYCVIGMGPFQQS-UHFFFAOYSA-N;
MW          472.619;      // g/mol [origin=calculated method=formula-sum]
Tc          1234.40;      // K   [origin=predictive method=joback]
Pc          7.807;      // bar [origin=predictive method=joback]
omega       0.6736;      // -   [origin=predictive method=lee-kesler]
Tb          1001.25;      // K   [origin=predictive method=joback]
HvapTb      99576.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.326 2.28548 -0.0011296 1.298e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group C; count 1; } { group CH2COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 16; } { group C; count 1; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-pentanoyloxy-2,2-bis(pentanoyloxymethyl)propyl] pentanoate" "2,2-bis(((1-oxopentyl)oxy)methyl)propane-1,3-diyl divalerate" "2,2-bis[[(1-oxopentyl)oxy]methyl]propane-1,3-diyl divalerate" "pentanoic acid, 1,1'-(2,2-bis(((1-oxopentyl)oxy)methyl)-1,3-propanediyl) ester" "pentanoic acid, 1,1'-[2,2-bis[[(1-oxopentyl)oxy]methyl]-1,3-propanediyl] ester" "2,2-bis(((1-oxopentyl)oxy)methyl)-1,3-propanediyl pentanoate" "pentanoic acid, 2,2-bis(((1-oxopentyl)oxy)methyl)-1,3-propanediyl ester" );
gibbsFormation
{
    dHf_298   -1837200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1296.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1079020.0
    phase     gas;
}
