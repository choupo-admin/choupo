/*--------------------------------*- Choupo -*-----------------------*\
  Component: (-)-menthyl lactate  (C13H24O3, CAS 17162-29-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        menthylLactate;
formula     C13H24O3;
CAS         17162-29-7;
InChIKey    UJNOLBSYLSYIBM-UHFFFAOYSA-N;
MW          228.332;      // g/mol [origin=calculated method=formula-sum]
Tc          847.46;      // K   [origin=predictive method=joback]
Pc          20.401;      // bar [origin=predictive method=joback]
omega       0.9769;      // -   [origin=predictive method=lee-kesler]
Tb          656.77;      // K   [origin=predictive method=joback]
HvapTb      67653.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.32 1.29898 -0.0005958 4.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 5; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5-methyl-2-propan-2-yl-cyclohexyl) 2-oxidanylpropanoate" "propanoic acid, 2-hydroxy-, 5-methyl-2-(1-methylethyl)cyclohexyl ester" "l-menthyl lactate" "5-methyl-2-(propan-2-yl)cyclohexyl 2-hydroxypropanoate" "agn-pc-02lt6u" "(r)-2-hydroxypropionic acid (1r,2s,5r)-2-isopropyl-5-methylcyclohexyl ester" "p972" "5-methyl-2-(1-methylethyl)cyclohexyl lactate" "2-isopropyl-5-methylcyclohexyl 2-hydroxypropanoate" "(5-methyl-2-propan-2-ylcyclohexyl) 2-hydroxypropanoate" "propanoicacid, 2-hydroxy-, 5-methyl-2-(1-methylethyl)cyclohexyl ester, [1r-[1a(r*),2b,5a]]-;l-menthyl d-lactate;propanoic acid,2-hydroxy-, (1r,2s,5r)-5-methyl-2-(1-methylethyl)cyclohexyl ester, (2r)-;" );
standardThermochemistry
{
    dHf_298   -778080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-384460.0
}
