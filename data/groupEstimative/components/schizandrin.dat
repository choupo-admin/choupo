/*--------------------------------*- Choupo -*-----------------------*\
  Component: schizandrin  (C24H32O7, CAS 7432-28-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        schizandrin;
formula     C24H32O7;
CAS         7432-28-2;
InChIKey    YEFOAORQXAOVJQ-UHFFFAOYSA-N;
MW          432.513;      // g/mol [origin=calculated method=formula-sum]
Tc          1316.35;      // K   [origin=predictive method=joback]
Pc          12.548;      // bar [origin=predictive method=joback]
omega       1.1750;      // -   [origin=predictive method=lee-kesler]
Tb          1075.20;      // K   [origin=predictive method=joback]
HvapTb      108630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (86.53 1.71166 -0.00082328 1.464e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group C; count 1; } { group ACH; count 2; } { group AC; count 8; } { group ACCH2; count 2; } { group OH; count 1; } { group CH3O; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 10; } { group OH; count 1; } { group O; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "schizandra" "schisandrol a" "schizandrol a" "wuweizichun a" "wuweizi alcohol a" "schisandrin" "(+)-schizandrin" "dibenzo(a,c)cycloocten-6-ol, 5,6,7,8-tetrahydro-1,2,3,10,11,12-hexamethoxy-6,7-dimethyl-, stereoisomer" "dibenzo(a,c)cycloocten-6-ol, 5,6,7,8-tetrahydro-6,7-dimethyl-1,2 3,10,11,12-hexamethoxy-, stereoisomer" "magnolia vine" "wu-wei-zi" "schisandra chinensis" );
gibbsFormation
{
    dHf_298   -1041400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     904.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-432390.0
    phase     gas;
}
