/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethoxyethane  (C4H10O2, CAS 534-15-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dimethoxyethane;
formula     C4H10O2;
CAS         534-15-6;
InChIKey    SPEUIVXLLWOEMJ-UHFFFAOYSA-N;
MW          90.122;      // g/mol [origin=calculated method=formula-sum]
Tc          504.88;      // K   [origin=predictive method=joback]
Pc          37.730;      // bar [origin=predictive method=joback]
omega       0.3243;      // -   [origin=predictive method=lee-kesler]
Tb          335.52;      // K   [origin=predictive method=joback]
HvapTb      28930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.57 0.26336 2.5e-05 -7.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl acetal" "ethane, 1,1-dimethoxy-" "dimethylacetal" "acetaldehyde dimethyl acetal" "acetaldehyde, dimethyl acetal" "methyl formyl" "ethylidene dimethyl ether" "dimethoxy ethane" "dimethyl aldehyde" "acetaldehyde methyl acetal" "3-methyl-2,4-dioxapentane" "dimethoxyethan" );
gibbsFormation
{
    dHf_298   -395610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     324.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-229640.0
    phase     gas;
}
