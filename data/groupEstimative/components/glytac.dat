/*--------------------------------*- Choupo -*-----------------------*\
  Component: glytac  (C6H4Cl6O4, CAS 2514-53-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glytac;
formula     C6H4Cl6O4;
CAS         2514-53-6;
InChIKey    SSDZRWBPFCFZGB-UHFFFAOYSA-N;
MW          352.794;      // g/mol [origin=calculated method=formula-sum]
Tc          903.97;      // K   [origin=predictive method=joback]
Pc          25.820;      // bar [origin=predictive method=joback]
omega       0.7652;      // -   [origin=predictive method=lee-kesler]
Tb          671.44;      // K   [origin=predictive method=joback]
HvapTb      67482.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (76.652 0.7566 -0.0005794 1.438e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CCl3; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 2; } { group Cl; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,2,2-tris(chloranyl)ethanoyloxy]ethyl 2,2,2-tris(chloranyl)ethanoate" "tca-ethadyl" "ethylene glycol bis(trichloroacetate)" "ethylene trichloroacetate" "glycol bis(trichloroacetate)" "tca-ethadyl [iso]" "ethylene bis(trichloroacetate)" "acetic acid, trichloro-, 1,2-ethanediyl ester" "ethylene glycol, bis(trichloroacetate)" "acetic acid, trichloro-, ethylene ester (2:1)" "egt" "2-(2,2,2-trichloroacetyl)oxyethyl 2,2,2-trichloroacetate" );
gibbsFormation
{
    dHf_298   -913670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     615.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-687000.0
    phase     gas;
}
