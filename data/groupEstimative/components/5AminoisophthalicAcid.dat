/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-aminoisophthalic acid  (C8H7NO4, CAS 99-31-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5AminoisophthalicAcid;
formula     C8H7NO4;
CAS         99-31-0;
InChIKey    KBZFDRWPMZESDI-UHFFFAOYSA-N;
MW          181.147;      // g/mol [origin=calculated method=formula-sum]
Tc          1026.33;      // K   [origin=predictive method=joback]
Pc          47.562;      // bar [origin=predictive method=joback]
omega       1.3699;      // -   [origin=predictive method=lee-kesler]
Tb          782.83;      // K   [origin=predictive method=joback]
HvapTb      81971.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.0 0.7294 -0.00049712 1.267e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACNH2; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COOH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-azanylbenzene-1,3-dicarboxylic acid" "5-aminobenzene-1,3-dicarboxylic acid" "1,3-benzenedicarboxylic acid, 5-amino-" "5-amino-1,3-isophthalic acid" "3,5-dicarboxyaniline" "5-amino isophthalic acid" "isophthalic acid, 5-amino-" "(3,5-dicarboxycyclohexyl)amine" "isophthalic acid, 5-amino- (8ci)" "5-amino-1,3-benzendicarboxylic acid" "k781" "5-amino-1,3-benzenedicarboxylic acid" );
gibbsFormation
{
    dHf_298   -661610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-511740.0
    phase     gas;
}
