/*--------------------------------*- Choupo -*-----------------------*\
  Component: cloperastine  (C20H24ClNO, CAS 3703-76-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cloperastine;
formula     C20H24ClNO;
CAS         3703-76-2;
InChIKey    FLNXBVJLPJNOSI-UHFFFAOYSA-N;
MW          329.868;      // g/mol [origin=calculated method=formula-sum]
Tc          1049.12;      // K   [origin=predictive method=joback]
Pc          18.483;      // bar [origin=predictive method=joback]
omega       0.8463;      // -   [origin=predictive method=lee-kesler]
Tb          807.34;      // K   [origin=predictive method=joback]
HvapTb      74344.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.208 1.9181 -0.00126756 3.117e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 9; } { group AC; count 1; } { group ACCH; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-[(4-chlorophenyl)-phenyl-methoxy]ethyl]piperidine" "cloperastinum [inn-latin]" "cloperastine (inn)" "cloperastine [inn]" "1-(2-((4-chlorophenyl)phenylmethoxy)ethyl)piperidine" "1-(2-((4-chlorophenyl)(phenyl)methoxy)ethyl)piperidine" "1-{2-[(4-chlorophenyl)(phenyl)methoxy]ethyl}piperidine" "piperidine, 1-[2-[(4-chlorophenyl)phenylmethoxy]ethyl]-" "piperidine, 1-(2-((p-chloro-alpha-phenylbenzyl)oxy)ethyl)-" "ht 11" "piperidine, 1-(2-((4-chlorophenyl)phenylmethoxy)ethyl)-" "cloperastina" );
standardThermochemistry
{
    dHf_298   570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     759.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=368380.0
}
