/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-1-(2,6,6-trimethylcyclohex-2-en-1-yl)hex-1-en-3-one  (C16H26O, CAS 70092-23-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl1266Trimethylcyclohex2En1YlHex1En3One;
formula     C16H26O;
CAS         70092-23-8;
InChIKey    QLDFUXZWCMSFEO-UHFFFAOYSA-N;
MW          234.383;      // g/mol [origin=calculated method=formula-sum]
Tc          854.10;      // K   [origin=predictive method=joback]
Pc          17.463;      // bar [origin=predictive method=joback]
omega       0.6326;      // -   [origin=predictive method=lee-kesler]
Tb          642.53;      // K   [origin=predictive method=joback]
HvapTb      57449.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.739 1.7938 -0.00139334 4.7576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-5-methyl-1-(2,6,6-trimethylcyclohex-2-en-1-yl)hex-1-en-3-one" "1-hexen-3-one, 5-methyl-1-(2,6,6-trimethyl-2-cyclohexen-1-yl)-" );
standardThermochemistry
{
    dHf_298   -278680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     742.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64280.0
}
