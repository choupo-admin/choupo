/*--------------------------------*- Choupo -*-----------------------*\
  Component: nitriles, c8-18 and c18-unsatd.  (C19H34N2, CAS 68648-31-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nitrilesC818AndC18Unsatd;
formula     C19H34N2;
CAS         68648-31-7;
InChIKey    SLVZBAVHUAXKMR-MKWAYWHRSA-N;
MW          290.495;      // g/mol [origin=calculated method=formula-sum]
Tc          1042.26;      // K   [origin=predictive method=joback]
Pc          10.220;      // bar [origin=predictive method=joback]
omega       0.8915;      // -   [origin=predictive method=lee-kesler]
Tb          844.04;      // K   [origin=predictive method=joback]
HvapTb      79096.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.253 1.49224 -0.0006168 3.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH=CH; count 1; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group dCH; count 2; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octanenitrile;(z)-undec-7-enenitrile" "(c8-c18 and c18)unsaturated alkyl nitrile" "octanenitrile; (z)-undec-7-enenitrile" "(c8-c18) and c18 unsaturated alkyl nitrile" );
gibbsFormation
{
    dHf_298   -100130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1009.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=350920.0
    phase     gas;
}
