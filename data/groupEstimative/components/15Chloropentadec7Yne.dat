/*--------------------------------*- Choupo -*-----------------------*\
  Component: 15-chloropentadec-7-yne  (C15H27Cl, CAS 71317-70-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Chloropentadec7Yne;
formula     C15H27Cl;
CAS         71317-70-9;
InChIKey    APWWCBNUZFUOSP-UHFFFAOYSA-N;
MW          242.831;      // g/mol [origin=calculated method=formula-sum]
Tc          770.00;      // K   [origin=predictive method=joback]
Pc          15.561;      // bar [origin=predictive method=joback]
omega       0.6880;      // -   [origin=predictive method=lee-kesler]
Tb          589.23;      // K   [origin=predictive method=joback]
HvapTb      55521.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.702 1.28582 -0.00072046 1.5528e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH2Cl; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group tC; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "15-chloranylpentadec-7-yne" "7-pentadecyne, 15-chloro-" );
standardThermochemistry
{
    dHf_298   -96370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     745.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=266290.0
}
