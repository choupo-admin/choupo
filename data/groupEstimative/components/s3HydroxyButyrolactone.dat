/*--------------------------------*- Choupo -*-----------------------*\
  Component: (S)-3-Hydroxy-γ-butyrolactone  (C4H6O3, CAS 7331-52-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s3HydroxyButyrolactone;
formula     C4H6O3;
CAS         7331-52-4;
InChIKey    FUDDLSHBRSNCBV-VKHMYHEASA-N;
MW          102.089;      // g/mol [origin=calculated method=formula-sum]
Tc          632.10;      // K   [origin=predictive method=joback]
Pc          52.893;      // bar [origin=predictive method=joback]
omega       0.8012;      // -   [origin=predictive method=lee-kesler]
Tb          448.26;      // K   [origin=predictive method=joback]
HvapTb      48497.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.29 0.5139 -0.0003498 8.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4S)-4-hydroxyoxolan-2-one" "(3S)-Hydroxy-γ-butyrolactone" "(4S)-Dihydro-4-hydroxy-2(3H)-furanone" "(S)-(-)-β-hydroxy-γ-butyrolactone" "(S)-3-hydroxybutyrolactone" "(S)-β-hydroxy-γ-butyrolactone" "2(3H)-Furanone, dihydro-4-hydroxy-, (4S)-" "2(3H)-Furanone, dihydro-4-hydroxy-, (S)-" "3s-hydroxy butyrolactone" "butyric acid, 3,4-dihydroxy-, γ-lactone, d-glycero-" "(S)-3-hydroxy-gamma-butyrolactone" "(S)-4-hydroxydihydrofuran-2(3h)-one" );
standardThermochemistry
{
    dHf_298   -522600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-403640.0
}
