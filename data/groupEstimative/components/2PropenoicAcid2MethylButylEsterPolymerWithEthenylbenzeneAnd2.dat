/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, butyl ester, polymer with ethenylbenzene and 2-methylpropyl 2-methyl-2-propenoate  (C24H36O4, CAS 69040-51-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2MethylButylEsterPolymerWithEthenylbenzeneAnd2;
formula     C24H36O4;
CAS         69040-51-3;
InChIKey    VPNXTONWKKAOOH-UHFFFAOYSA-N;
MW          388.548;      // g/mol [origin=calculated method=formula-sum]
Tc          1095.22;      // K   [origin=predictive method=joback]
Pc          9.687;      // bar [origin=predictive method=joback]
omega       0.8109;      // -   [origin=predictive method=lee-kesler]
Tb          884.00;      // K   [origin=predictive method=joback]
HvapTb      84458.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.584 1.6287 -0.0003707 -1.934e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 1; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 2-methylprop-2-enoate;ethenylbenzene;2-methylpropyl 2-methylprop-2-enoate" );
gibbsFormation
{
    dHf_298   -808530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1270.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-322670.0
    phase     gas;
}
