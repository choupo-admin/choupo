/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl laurate  (C14H28O2, CAS 106-33-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylLaurate;
formula     C14H28O2;
CAS         106-33-2;
InChIKey    MMXKVMNBHPAILY-UHFFFAOYSA-N;
MW          228.376;      // g/mol [origin=calculated method=formula-sum]
Tc          743.60;      // K   [origin=predictive method=joback]
Pc          15.295;      // bar [origin=predictive method=joback]
omega       0.8078;      // -   [origin=predictive method=lee-kesler]
Tb          578.14;      // K   [origin=predictive method=joback]
HvapTb      54165.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.571 1.27904 -0.0006432 9.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl dodecanoate" "dodecanoic acid, ethyl ester" "lauric acid, ethyl ester" "ethyl laurinate" "ethyl dodecylate" "lauric acid ethyl ester" "ethyl laurate (natural)" "lauric acid, ethyl ester (8ci)" "dodecanoic acid,ethyl ester" "e(r) paragraph signthorneaooo yen" "we(2:0/12:0)" );
standardThermochemistry
{
    dHf_298   -649570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     752.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-243370.0
}
