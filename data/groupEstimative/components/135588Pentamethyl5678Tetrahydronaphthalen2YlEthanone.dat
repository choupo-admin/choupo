/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(3,5,5,8,8-pentamethyl-5,6,7,8-tetrahydronaphthalen-2-yl)ethanone  (C17H24O, CAS 17610-24-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135588Pentamethyl5678Tetrahydronaphthalen2YlEthanone;
formula     C17H24O;
CAS         17610-24-1;
InChIKey    QZADYGNSQCABPT-UHFFFAOYSA-N;
MW          244.378;      // g/mol [origin=calculated method=formula-sum]
Tc          920.80;      // K   [origin=predictive method=joback]
Pc          19.086;      // bar [origin=predictive method=joback]
omega       0.6660;      // -   [origin=predictive method=lee-kesler]
Tb          690.87;      // K   [origin=predictive method=joback]
HvapTb      61918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-145.62 2.03212 -0.00189598 7.7006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 2; } { group AC; count 3; } { group ACCH3; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3,5,5,8,8-pentamethyl-6,7-dihydronaphthalen-2-yl)ethanone" "1-(5,6,7,8-tetrahydro-3,5,5,8,8-pentamethyl-2-naphthyl)ethan-1-one" "ethanone, 1-(5,6,7,8-tetrahydro-3,5,5,8,8-pentamethyl-2-naphthalenyl)-" "1-(3,5,5,8,8-pentamethyl-5,6,7,8-tetrahydronaphthalen-2-yl)ethan-1-one" "5',6',7',8'-tetrahydro-3',5',5',8',8'-pentamethyl-2'-acetonaphthone" );
standardThermochemistry
{
    dHf_298   -227890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     746.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76820.0
}
