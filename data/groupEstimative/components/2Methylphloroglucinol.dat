/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylphloroglucinol  (C7H8O3, CAS 88-03-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylphloroglucinol;
formula     C7H8O3;
CAS         88-03-9;
InChIKey    BPHYZRNTQNPLFI-UHFFFAOYSA-N;
MW          140.138;      // g/mol [origin=calculated method=formula-sum]
Tc          881.69;      // K   [origin=predictive method=joback]
Pc          80.871;      // bar [origin=predictive method=joback]
omega       1.0326;      // -   [origin=predictive method=lee-kesler]
Tb          628.30;      // K   [origin=predictive method=joback]
HvapTb      72494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.14 1.05372 -0.00115728 4.969e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 1; } { group ACOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbenzene-1,3,5-triol" "2,4,6-trihydroxytoluene" "1,3,5-benzenetriol, 2-methyl-" "methylphloroglucinol" "toluene-2,6-triol" "2,6-trihydroxytoluene" "phloroglucinol, methyl-" "1,5-benzenetriol, 2-methyl-" "aspidinol a" "o-methylphloroglucinol" "toluene-2,4,6-triol" "2-methyl-1,3,5-benzenetriol" );
gibbsFormation
{
    dHf_298   -483210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-343390.0
    phase     gas;
}
