/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-2-butyne  (C4H5Cl, CAS 3355-17-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro2Butyne;
formula     C4H5Cl;
CAS         3355-17-7;
InChIKey    OKWUYBGGPXXFLS-UHFFFAOYSA-N;
MW          88.534;      // g/mol [origin=calculated method=formula-sum]
Tc          537.86;      // K   [origin=predictive method=joback]
Pc          45.716;      // bar [origin=predictive method=joback]
omega       0.1839;      // -   [origin=predictive method=lee-kesler]
Tb          337.55;      // K   [origin=predictive method=joback]
HvapTb      31035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.701 0.24082 -0.00012206 2.438e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2Cl; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group tC; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylbut-2-yne" "2-butyne, 1-chloro-" "1-chlorobut-2-yne" "2-butynyl chloride" "2-butyne, 1-chloro-(8ci,9ci)" "2-butyne,chloro- (6ci,7ci); 1-chloro-2-butyne; g-methylpropargyl chloride" );
standardThermochemistry
{
    dHf_298   130670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     316.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173670.0
}
