/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[4.3.1.12,5]undec-3-ene, (1.alpha.,2.beta.,5.beta.,6.alpha.)-  (C11H16, CAS 85523-04-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo431125Undec3Ene1Alpha2Beta5Beta6Alpha;
formula     C11H16;
CAS         85523-04-2;
InChIKey    JPAKHMXDXKQUSA-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          695.90;      // K   [origin=predictive method=joback]
Pc          29.828;      // bar [origin=predictive method=joback]
omega       0.3446;      // -   [origin=predictive method=lee-kesler]
Tb          474.53;      // K   [origin=predictive method=joback]
HvapTb      40146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-154.36 1.3998 -0.00107428 3.338e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 4; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 4; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -26850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     273.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222040.0
    phase     gas;
}
