/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-diethylamino-6,8-dimethylfluorene  (C19H23N, CAS 68259-18-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Diethylamino68Dimethylfluorene;
formula     C19H23N;
CAS         68259-18-7;
InChIKey    RIZOSLSFFFSXDV-UHFFFAOYSA-N;
MW          265.4;      // g/mol [origin=calculated method=formula-sum]
Tc          947.44;      // K   [origin=predictive method=joback]
Pc          18.201;      // bar [origin=predictive method=joback]
omega       0.8220;      // -   [origin=predictive method=lee-kesler]
Tb          727.89;      // K   [origin=predictive method=joback]
HvapTb      67671.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.328 1.67408 -0.001218 3.661e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 5; } { group AC; count 4; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH2_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 7; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-6,8-dimethyl-9h-fluoren-3-amine" "9h-fluoren-3-amine, n,n-diethyl-6,8-dimethyl-" );
standardThermochemistry
{
    dHf_298   153210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=489210.0
}
