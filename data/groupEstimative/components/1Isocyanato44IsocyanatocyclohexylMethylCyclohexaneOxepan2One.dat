name        1Isocyanato44IsocyanatocyclohexylMethylCyclohexaneOxepan2One;
formula     C21H32N2O4;
CAS         52136-47-7;
InChIKey    SWXIYTJQEZGPLG-UHFFFAOYSA-N;
MW          376.497;      // g/mol [origin=calculated method=formula-sum]
Tc          1162.55;      // K   [origin=predictive method=joback]
Pc          14.657;      // bar [origin=predictive method=joback]
omega       0.9744;      // -   [origin=predictive method=lee-kesler]
Tb          922.75;      // K   [origin=predictive method=joback]
HvapTb      89911.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 13; } { group CH; count 4; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 1; } { group dCd; count 2; } { group CH2_ring; count 13; } { group CH_ring; count 4; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane; oxepan-2-one" );
