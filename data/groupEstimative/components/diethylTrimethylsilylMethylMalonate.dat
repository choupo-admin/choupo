/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl((trimethylsilyl)methyl)malonate  (C11H22O4Si, CAS 17962-38-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H22O4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diethylTrimethylsilylMethylMalonate;
formula     C11H22O4Si;
CAS         17962-38-8;
InChIKey    ZEOGFXACYDZIKN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          246.378;      // g/mol [origin=calculated method=formula-sum]
Tc          750.33;      // K   [origin=predictive method=joback]
Pc          17.714;      // bar [origin=predictive method=joback]
omega       0.6957;      // -   [origin=predictive method=lee-kesler]
Tb          568.68;      // K   [origin=predictive method=joback]
HvapTb      54800.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (82.843 0.739 2.62e-05 -2.122e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 1; } { group COO; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-(trimethylsilylmethyl)propanedioate" "propanedioic acid, ((trimethylsilyl)methyl)-, diethyl ester" "propanedioic acid, [(trimethylsilyl)methyl]-, diethyl ester" "propanedioic acid, 2-((trimethylsilyl)methyl)-, 1,3-diethyl ester" "propanedioic acid, 2-[(trimethylsilyl)methyl]-, 1,3-diethyl ester" "diethyl ((trimethylsilyl)methyl)malonate" "diethyl [(trimethylsilyl)methyl]propanedioate" "propanedioic acid,2-[(trimethylsilyl)methyl]-, 1,3-diethyl ester" "malonicacid, [(trimethylsilyl)methyl]-, diethyl ester (6ci,8ci); propanedioic acid,[(trimethylsilyl)methyl]-, diethyl ester (9ci); diethyl2-(trimethylsilylmethyl)malonate" );
gibbsFormation
{
    dHf_298   -1021830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     804.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-686200.0
    phase     gas;
}
