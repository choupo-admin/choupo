/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5beta-cholestan-3-one  (C27H46O, CAS 601-53-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5betaCholestan3One;
formula     C27H46O;
CAS         601-53-6;
InChIKey    PESKGJQREUXSRR-JDIFZLMISA-N;
MW          386.664;      // g/mol [origin=calculated method=formula-sum]
Tc          1150.77;      // K   [origin=predictive method=joback]
Pc          10.253;      // bar [origin=predictive method=joback]
omega       0.7543;      // -   [origin=predictive method=lee-kesler]
Tb          919.08;      // K   [origin=predictive method=joback]
HvapTb      76450.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-297.327 3.4723 -0.0027552 9.552e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 11; } { group CH; count 7; } { group C; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 9; } { group CH_ring; count 5; } { group C_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5r,8r,9s,10s,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-1,2,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydrocyclopenta[a]phenanthren-3-one" "coprostan-3-one" "5beta-cholestanone" "(5" "a)-cholestan-3-one" "5beta cholestanone" "beta-cholestan-3-one" "5b-cholestan-3-one" "(5b)-coprostan-3-one" "5-beta-cholestan-3-one" "cholestan-3-one, (5beta)- (9ci)" );
standardThermochemistry
{
    dHf_298   -519010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     860.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197380.0
}
