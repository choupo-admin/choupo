/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid, polymer with 1,4-cyclohexanedimethanol and 1,2-ethanediol  (C16H32O8, CAS 81972-46-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcidPolymerWith14CyclohexanedimethanolAnd12Ethane;
formula     C16H32O8;
CAS         81972-46-5;
InChIKey    ILZJPXZAKYCLCJ-UHFFFAOYSA-N;
MW          352.424;      // g/mol [origin=calculated method=formula-sum]
Tc          1590.51;      // K   [origin=predictive method=joback]
Pc          20.438;      // bar [origin=predictive method=joback]
omega       1.0620;      // -   [origin=predictive method=lee-kesler]
Tb          1243.10;      // K   [origin=predictive method=joback]
HvapTb      152962.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.678 1.4446 -0.0003094 -1.786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 2; } { group OH; count 2; } { group COOH; count 2; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-diol;hexanedioic acid;[4-(hydroxymethyl)cyclohexyl]methanol" "adipic acid, 1,4-cyclohexanedimethanol, ethylene glycol polyester" );
standardThermochemistry
{
    dHf_298   -1872290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1231.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1344040.0
}
