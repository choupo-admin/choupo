/*--------------------------------*- Choupo -*-----------------------*\
  Component: 16,16-diethoxyhexadeca-3,5-diene  (C20H38O2, CAS 71673-23-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1616Diethoxyhexadeca35Diene;
formula     C20H38O2;
CAS         71673-23-9;
InChIKey    CBJGIKWGCGTVMA-UHFFFAOYSA-N;
MW          310.522;      // g/mol [origin=calculated method=formula-sum]
Tc          882.65;      // K   [origin=predictive method=joback]
Pc          10.680;      // bar [origin=predictive method=joback]
omega       0.8570;      // -   [origin=predictive method=lee-kesler]
Tb          709.92;      // K   [origin=predictive method=joback]
HvapTb      64462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.662 1.82336 -0.001013 2.115e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 1; } { group CH=CH; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } { group dCH; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z,z)-11,13-hexadecadienal diethyl acetal" "3,5-hexadecadiene, 16,16-diethoxy-, (3z,5z)-" "agn-pc-00le39" "(3z,5z)-16,16-diethoxyhexadeca-3,5-diene" );
standardThermochemistry
{
    dHf_298   -491410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     934.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65520.0
}
