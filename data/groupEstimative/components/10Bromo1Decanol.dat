/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-bromo-1-decanol  (C10H21BrO, CAS 53463-68-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10Bromo1Decanol;
formula     C10H21BrO;
CAS         53463-68-6;
InChIKey    LGZMUUBPTDRQQM-UHFFFAOYSA-N;
MW          237.181;      // g/mol [origin=calculated method=formula-sum]
Tc          757.74;      // K   [origin=predictive method=joback]
Pc          24.580;      // bar [origin=predictive method=joback]
omega       1.0958;      // -   [origin=predictive method=lee-kesler]
Tb          586.74;      // K   [origin=predictive method=joback]
HvapTb      60968.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.28 1.026 -0.000622 1.517e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-bromanyldecan-1-ol" "10-bromodecanol" "10-bromodecan-1-ol" "1-decanol, 10-bromo-" "decamethylene bromohydrin" "10-bromo-1-decanol;10-bromodecanol;" "k915" );
standardThermochemistry
{
    dHf_298   -375630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-89180.0
}
