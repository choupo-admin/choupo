/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-menthyl propionate  (C13H24O2, CAS 4951-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lMenthylPropionate;
formula     C13H24O2;
CAS         4951-48-8;
InChIKey    PELLUIPPBKHUAB-UHFFFAOYSA-N;
MW          212.333;      // g/mol [origin=calculated method=formula-sum]
Tc          762.96;      // K   [origin=predictive method=joback]
Pc          18.676;      // bar [origin=predictive method=joback]
omega       0.5648;      // -   [origin=predictive method=lee-kesler]
Tb          565.03;      // K   [origin=predictive method=joback]
HvapTb      51362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.929 1.25908 -0.0005622 3.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 4; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5-methyl-2-propan-2-yl-cyclohexyl) propanoate" "cyclohexanol, 5-methyl-2-(1-methylethyl)-, propanoate, (1r,2s,5r)-" "cyclohexanol, 5-methyl-2-(1-methylethyl)-, propanoate, (1s,2r,5r)-" "cyclohexanol, 5-methyl-2-(1-methylethyl)-, 1-propanoate, (1r,2s,5r)-" "cyclohexanol, 5-methyl-2-(1-methylethyl)-, 1-propanoate, (1s,2r,5r)-" "mentyl propionate" "d-isomenthyl propionate" "(-)-menthyl propionate" "menthol, propionate, (-)-" "(5-methyl-2-propan-2-ylcyclohexyl) propanoate" "[(1s,2r,5r)-5-methyl-2-propan-2-ylcyclohexyl] propanoate" "(1s-(1alpha,2beta,5beta))-2-(isopropyl)-5-methylcyclohexyl propionate" );
gibbsFormation
{
    dHf_298   -620570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-245200.0
    phase     gas;
}
