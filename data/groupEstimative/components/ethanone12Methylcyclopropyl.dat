/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanone, 1-(2-methylcyclopropyl)-  (C6H10O, CAS 930-56-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanone12Methylcyclopropyl;
formula     C6H10O;
CAS         930-56-3;
InChIKey    CSEAGYCTZLEZON-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          585.46;      // K   [origin=predictive method=joback]
Pc          37.454;      // bar [origin=predictive method=joback]
omega       0.3614;      // -   [origin=predictive method=lee-kesler]
Tb          392.82;      // K   [origin=predictive method=joback]
HvapTb      35300.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.51 0.67024 -0.0004487 1.2226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methylcyclopropyl)ethanone" "ketone, methyl 2-methylcyclopropyl" );
gibbsFormation
{
    dHf_298   -227290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     283.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76240.0
    phase     gas;
}
