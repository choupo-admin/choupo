/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-{2-[2-(4-aminophenoxy)ethoxy]ethoxy}ethanol  (C12H19NO4, CAS 18790-97-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2224AminophenoxyEthoxyEthoxyEthanol;
formula     C12H19NO4;
CAS         18790-97-1;
InChIKey    LQGLNHNBYCRXIT-UHFFFAOYSA-N;
MW          241.287;      // g/mol [origin=calculated method=formula-sum]
Tc          932.07;      // K   [origin=predictive method=joback]
Pc          26.137;      // bar [origin=predictive method=joback]
omega       1.3876;      // -   [origin=predictive method=lee-kesler]
Tb          737.79;      // K   [origin=predictive method=joback]
HvapTb      79794.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.656 0.9117 -0.00033396 -1.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 2; } { group ACNH2; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-(4-azanylphenoxy)ethoxy]ethoxy]ethanol" "2-[2-[2-(4-aminophenoxy)ethoxy]ethoxy]ethanol" "ethanol, 2-(2-(2-(4-aminophenoxy)ethoxy)ethoxy)-" "ethanol, 2-[2-[2-(4-aminophenoxy)ethoxy]ethoxy]-" );
standardThermochemistry
{
    dHf_298   -581050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-232430.0
}
