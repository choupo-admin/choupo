/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dihydronaphthalene  (C10H10, CAS 447-53-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dihydronaphthalene;
formula     C10H10;
CAS         447-53-0;
InChIKey    KEIFWROAQVVDBN-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          710.06;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       0.3461;      // -   [origin=predictive method=lee-kesler]
Tb          474.90;      // K   [origin=predictive method=joback]
HvapTb      41478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.33 0.9272 -0.00070084 2.102e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dialin" "1,2-dialin" "diolin" "delta1-dialin" "naphthalene, 1,2-dihydro-" "dialin (van)" "dihydronaphthalene" "1,2-dihydro-naphthalene" "naphthalene, dihydro-" "delta(1)-dialin" " currency1-dialin" "naphthalene,2-dihydro-" );
gibbsFormation
{
    dHf_298   120090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     367.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222420.0
    phase     gas;
}
