/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dichlorobutane  (C4H8Cl2, CAS 110-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dichlorobutane;
formula     C4H8Cl2;
CAS         110-56-5;
InChIKey    KJDRSWPQXHESDQ-UHFFFAOYSA-N;
MW          127.008;      // g/mol [origin=calculated method=formula-sum]
Tc          547.97;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.3237;      // -   [origin=predictive method=lee-kesler]
Tb          365.98;      // K   [origin=predictive method=joback]
HvapTb      33268.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.034 0.3974 -0.0002346 5.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(chloranyl)butane" "butane, 1,4-dichloro-" "tetramethylene dichloride" "butane,4-dichloro-" "tetramethylene chloride" "i851" );
standardThermochemistry
{
    dHf_298   -157370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41060.0
}
