/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4,5-trimethoxyphenol  (C9H12O4, CAS 642-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        345Trimethoxyphenol;
formula     C9H12O4;
CAS         642-71-7;
InChIKey    VTCDZPUMZAZMSB-UHFFFAOYSA-N;
MW          184.191;      // g/mol [origin=calculated method=formula-sum]
Tc          806.70;      // K   [origin=predictive method=joback]
Pc          35.305;      // bar [origin=predictive method=joback]
omega       0.8205;      // -   [origin=predictive method=lee-kesler]
Tb          590.04;      // K   [origin=predictive method=joback]
HvapTb      59472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.98 0.62596 -0.00028628 4.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "antiarol" "phenol, 3,4,5-trimethoxy-" "3,4,5-trimethoxy phenol" "brd-k28698314-001-01-3" );
gibbsFormation
{
    dHf_298   -589470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-351570.0
    phase     gas;
}
