/*--------------------------------*- Choupo -*-----------------------*\
  Component: aqua cera  (C22H44O4, CAS 106-11-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aquaCera;
formula     C22H44O4;
CAS         106-11-6;
InChIKey    PWVUXRBUUYZMKM-UHFFFAOYSA-N;
MW          372.59;      // g/mol [origin=calculated method=formula-sum]
Tc          1075.31;      // K   [origin=predictive method=joback]
Pc          9.467;      // bar [origin=predictive method=joback]
omega       0.8862;      // -   [origin=predictive method=lee-kesler]
Tb          875.78;      // K   [origin=predictive method=joback]
HvapTb      91062.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.09 2.00982 -0.0009978 1.485e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CH2COO; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 20; } { group OH; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyethyloxy)ethyl octadecanoate" "diglycol monostearate" "cerasynt" "glyco stearin" "cerasynt special" "diethylene glycol monostearate" "clindrol sdg" "diethylene glycol stearate" "emcol ets" "peg-2 stearate" "octadecanoic acid, 2-(2-hydroxyethoxy)ethyl ester" "diglycol stearate" );
standardThermochemistry
{
    dHf_298   -1099140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1126.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-417830.0
}
