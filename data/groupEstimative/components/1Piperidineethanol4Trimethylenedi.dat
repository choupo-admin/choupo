/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-piperidineethanol,4'-trimethylenedi-  (C17H34N2O2, CAS 18073-84-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Piperidineethanol4Trimethylenedi;
formula     C17H34N2O2;
CAS         18073-84-2;
InChIKey    VSSGEWPIFHKREK-UHFFFAOYSA-N;
MW          298.471;      // g/mol [origin=calculated method=formula-sum]
Tc          1019.22;      // K   [origin=predictive method=joback]
Pc          18.740;      // bar [origin=predictive method=joback]
omega       1.4669;      // -   [origin=predictive method=lee-kesler]
Tb          828.36;      // K   [origin=predictive method=joback]
HvapTb      91394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.333 2.198 -0.0014418 3.645e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 13; } { group CH; count 2; } { group OH; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group CH2_ring; count 8; } { group CH_ring; count 2; } { group OH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-[3-[1-(2-hydroxyethyl)piperidin-4-yl]propyl]piperidin-1-yl]ethanol" "1,3-bis[1-(2-hydroxyethyl)-4-piperidyl]propane" "1-piperidineethanol, 4,4'-(1,3-propanediyl)bis-" "2-(4-{3-[1-(2-hydroxyethyl)-4-piperidyl]propyl}piperidyl)ethan-1-ol" "2-(4-{3-[1-(2-hydroxyethyl)piperidin-4-yl]propyl}piperidin-1-yl)ethanol" "1-piperidineethanol, 4,4'-trimethylenedi-" "4,4'-trimethylenebis-(n-piperidineethanol)" "1-piperidineethanol,4'-(1,3-propanediyl)bis-" "1,3-di(n-.beta.-hydroxyethyl-4-piperidyl)propane" "1-piperidineethanol,4,4'-(1,3-propanediyl)bis-" "4,4'-(propane-1,3-diyl)bis(piperidine-1-ethanol)" "1,3-di(n-beta-hydroxyethyl-4-piperidyl)-propane" );
gibbsFormation
{
    dHf_298   -442650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     851.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113280.0
    phase     gas;
}
