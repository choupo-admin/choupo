/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(1-ethoxyethoxy)pentane  (C9H20O2, CAS 13442-89-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11EthoxyethoxyPentane;
formula     C9H20O2;
CAS         13442-89-2;
InChIKey    QMLYOIJQQWWNKE-UHFFFAOYSA-N;
MW          160.257;      // g/mol [origin=calculated method=formula-sum]
Tc          616.86;      // K   [origin=predictive method=joback]
Pc          22.504;      // bar [origin=predictive method=joback]
omega       0.5678;      // -   [origin=predictive method=lee-kesler]
Tb          449.92;      // K   [origin=predictive method=joback]
HvapTb      40060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.025 0.73836 -0.000247 -1.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "acetaldehyde ethyl amyl acetal" "pentane, 1-(1-ethoxyethoxy)-" "1-ethoxy-1-pentyloxyethane" );
standardThermochemistry
{
    dHf_298   -498810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-187540.0
}
