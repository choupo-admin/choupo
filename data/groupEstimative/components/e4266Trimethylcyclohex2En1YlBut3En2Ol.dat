/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-4-(2,6,6-trimethylcyclohex-2-en-1-yl)but-3-en-2-ol  (C13H22O, CAS 211241-68-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e4266Trimethylcyclohex2En1YlBut3En2Ol;
formula     C13H22O;
CAS         211241-68-8;
InChIKey    PWDOJWCZWKWKSE-UHFFFAOYSA-N;
MW          194.318;      // g/mol [origin=calculated method=formula-sum]
Tc          812.09;      // K   [origin=predictive method=joback]
Pc          23.203;      // bar [origin=predictive method=joback]
omega       0.8176;      // -   [origin=predictive method=lee-kesler]
Tb          612.20;      // K   [origin=predictive method=joback]
HvapTb      60704.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.08 1.57078 -0.00127924 4.589e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2,6,6-trimethylcyclohex-2-en-1-yl)but-3-en-2-ol" "agn-pc-03dtbz" "3-buten-2-ol, 4-(2,6,6-trimethyl-2-cyclohexen-1-yl)-, (3e)-" "3-buten-2-ol,4-(2,6,6-trimethyl-2-cyclohexen-1-yl)- (8ci);(3e)-4-(2,6,6-trimethyl-2-cyclohexenyl)-3-buten-2-ol;latilure;a-ionol;" );
standardThermochemistry
{
    dHf_298   -256410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31120.0
}
