/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloroethene, methyl 2-propenoate, ethyl 2-propenoate polymer  (C12H19ClO3, CAS 58295-64-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloroetheneMethyl2PropenoateEthyl2PropenoatePolymer;
formula     C12H19ClO3;
CAS         58295-64-0;
InChIKey    NQNYJNZDXSSYCV-UHFFFAOYSA-N;
MW          246.731;      // g/mol [origin=calculated method=formula-sum]
Tc          842.07;      // K   [origin=predictive method=joback]
Pc          18.773;      // bar [origin=predictive method=joback]
omega       0.9014;      // -   [origin=predictive method=lee-kesler]
Tb          651.27;      // K   [origin=predictive method=joback]
HvapTb      68845.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (105.861 0.63724 0.0001482 -2.679e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2=CH; count 2; } { group CH2=C; count 2; } { group OH; count 1; } { group Cl_C=C_; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 4; } { group dCH; count 2; } { group dC; count 2; } { group Cl; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranylethene;ethyl prop-2-enoate;3-methylbuta-1,3-dien-2-ol" "2-propenoic acid, ethyl ester, polymer with chloroethene and methyl 2-propenoate" "chloroethene; ethyl prop-2-enoate; 3-methylbuta-1,3-dien-2-ol" );
gibbsFormation
{
    dHf_298   -517360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     947.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-284220.0
    phase     gas;
}
