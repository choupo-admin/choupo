/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylenecyclopentane  (C6H10, CAS 1528-30-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylenecyclopentane;
formula     C6H10;
CAS         1528-30-9;
InChIKey    NFJPEKRRHIYYES-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          553.64;      // K   [origin=predictive method=joback]
Pc          40.986;      // bar [origin=predictive method=joback]
omega       0.2297;      // -   [origin=predictive method=lee-kesler]
Tb          355.99;      // K   [origin=predictive method=joback]
HvapTb      29675.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.7 0.6145 -0.000393 9.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 4; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylidenecyclopentane" "cyclopentane, methylene-" "cyclopentylmethyl" "methylcyclopentyl" "cyclopentane,methylene-" );
standardThermochemistry
{
    dHf_298   -2110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=96980.0
}
