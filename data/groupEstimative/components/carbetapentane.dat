/*--------------------------------*- Choupo -*-----------------------*\
  Component: carbetapentane  (C20H31NO3, CAS 77-23-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carbetapentane;
formula     C20H31NO3;
CAS         77-23-6;
InChIKey    CFJMRBQWBDQYMK-UHFFFAOYSA-N;
MW          333.472;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.45;      // K   [origin=predictive method=joback]
Pc          14.839;      // bar [origin=predictive method=joback]
omega       0.9527;      // -   [origin=predictive method=lee-kesler]
Tb          792.48;      // K   [origin=predictive method=joback]
HvapTb      73356.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.454 2.25444 -0.0016624 5.153e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(diethylamino)ethoxy]ethyl 1-phenylcyclopentane-1-carboxylate" "pentoxyverine" "pentoxiverin" "pentoxiverinum" "pentoxyverin" "atussil" "pentoxyverinum [inn-latin]" "1-phenyl-1-cyclopentanecarboxylate" "sedotussin (tn)" "1-phenylcyclopentanecarboxylic acid,2-(2-(diethylamino)ethoxy)ethyl ester" "2-(2-diethylaminoethoxy)ethyl 1-phenylcyclopentanecarboxylate" "2-(diethylaminoethoxy)ethyl 1-phenyl-1-cyclopentanecarboxylate" );
standardThermochemistry
{
    dHf_298   -525850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     926.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-43600.0
}
