/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,2-dibromoethyl)benzene  (C8H8Br2, CAS 93-52-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12DibromoethylBenzene;
formula     C8H8Br2;
CAS         93-52-7;
InChIKey    SHKKTLSDGJRCTR-UHFFFAOYSA-N;
MW          263.96;      // g/mol [origin=calculated method=formula-sum]
Tc          791.97;      // K   [origin=predictive method=joback]
Pc          43.916;      // bar [origin=predictive method=joback]
omega       0.5069;      // -   [origin=predictive method=lee-kesler]
Tb          541.20;      // K   [origin=predictive method=joback]
HvapTb      48160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.589 0.7672 -0.0005886 1.772e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)ethylbenzene" "dowspray 9" "benzene, (1,2-dibromoethyl)-" "1,2-dibromo-1-phenylethane" "1,2-dibromo-2-phenylethane" "vic-styrene dibromide" ".alpha.,.beta.-dibromoethylbenzene" "1,2-dibromo(phenyl)ethane" "alpha,beta-dibromoethylbenzene" "(1,2-dibromoethyl)-benzene" "phenylethylene bromide" "1,2-dibromoethylbenzene" );
gibbsFormation
{
    dHf_298   75460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=155090.0
    phase     gas;
}
