/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexyl valerate  (C11H20O2, CAS 1551-43-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylValerate;
formula     C11H20O2;
CAS         1551-43-5;
InChIKey    YLCHTSSXNSNXSW-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          728.75;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.5606;      // -   [origin=predictive method=lee-kesler]
Tb          529.05;      // K   [origin=predictive method=joback]
HvapTb      47916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.307 1.11612 -0.000561 7.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexyl pentanoate" "pentanoic acid, cyclohexyl ester" "1-cyclohexyl pentanoate" "cyclohexyl n-valerate" "valeric acid cyclohexyl ester" "pentanoic acid,cyclohexyl ester" );
gibbsFormation
{
    dHf_298   -533330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-244180.0
    phase     gas;
}
