/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethoxybenzyl chloride  (C9H11ClO2, CAS 7306-46-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34DimethoxybenzylChloride;
formula     C9H11ClO2;
CAS         7306-46-9;
InChIKey    WWHJLVMBXXXUFO-UHFFFAOYSA-N;
MW          186.635;      // g/mol [origin=calculated method=formula-sum]
Tc          736.60;      // K   [origin=predictive method=joback]
Pc          29.155;      // bar [origin=predictive method=joback]
omega       0.5508;      // -   [origin=predictive method=lee-kesler]
Tb          524.43;      // K   [origin=predictive method=joback]
HvapTb      48433.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.291 0.54134 -0.00016132 -2.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(chloromethyl)-1,2-dimethoxy-benzene" "veratryl chloride" "4-(chloromethyl)-1,2-dimethoxybenzene" "veratryl chlorid [german]" "alpha-chloro-3,4-dimethoxytoluene" "3,4-bis(methoxy)-benzyl chloride" "toluene, alpha-chloro-3,4-dimethoxy-" "4-(chloromethyl)-1,2-dimethoxy benzene" "benzene, 4-(chloromethyl)-1,2-dimethoxy-" "veratryl chlorid" "i260" "4-chloromethyl-1,2-dimethoxy benzene; 3,4-bis(methoxy)-benzyl chloride" );
standardThermochemistry
{
    dHf_298   -295680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-103880.0
}
