/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butoxyethanol  (C6H14O2, CAS 111-76-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butoxyethanol;
formula     C6H14O2;
CAS         111-76-2;
InChIKey    POAOYUHQDCAZBD-UHFFFAOYSA-N;
MW          118.176;      // g/mol [origin=calculated method=formula-sum]
Tc          612.83;      // K   [origin=predictive method=joback]
Pc          33.841;      // bar [origin=predictive method=joback]
omega       0.8520;      // -   [origin=predictive method=lee-kesler]
Tb          451.48;      // K   [origin=predictive method=joback]
HvapTb      48039.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.225 0.54462 -0.000222 1.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl glycol" "butyl cellosolve" "butoxyethanol" "ethylene glycol monobutyl ether" "ethanol, 2-butoxy-" "n-butoxyethanol" "butyl oxitol" "glycol butyl ether" "3-oxa-1-heptanol" "ethylene glycol butyl ether" "o-butyl ethylene glycol" "dowanol eb" );
gibbsFormation
{
    dHf_298   -451620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-242180.0
    phase     gas;
}
