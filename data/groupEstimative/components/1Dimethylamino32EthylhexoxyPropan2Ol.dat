/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(dimethylamino)-3-(2-ethylhexoxy)propan-2-ol  (C13H29NO2, CAS 184181-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Dimethylamino32EthylhexoxyPropan2Ol;
formula     C13H29NO2;
CAS         184181-27-9;
InChIKey    GZNYCROFCICNNW-UHFFFAOYSA-N;
MW          231.38;      // g/mol [origin=calculated method=formula-sum]
Tc          785.54;      // K   [origin=predictive method=joback]
Pc          17.699;      // bar [origin=predictive method=joback]
omega       1.1148;      // -   [origin=predictive method=lee-kesler]
Tb          623.20;      // K   [origin=predictive method=joback]
HvapTb      64888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.807 1.34538 -0.0007218 1.349e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group CH3N; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 2; } { group OH; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propanol, 1-(dimethylamino)-3-((2-ethylhexyl)oxy)-" "2-propanol, 1-(dimethylamino)-3-[(2-ethylhexyl)oxy]-" );
standardThermochemistry
{
    dHf_298   -539130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77340.0
}
