/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromononane  (C9H18Br2, CAS 73642-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromononane;
formula     C9H18Br2;
CAS         73642-91-8;
InChIKey    AHPKTOXLYWQNST-UHFFFAOYSA-N;
MW          286.051;      // g/mol [origin=calculated method=formula-sum]
Tc          735.26;      // K   [origin=predictive method=joback]
Pc          26.680;      // bar [origin=predictive method=joback]
omega       0.6695;      // -   [origin=predictive method=lee-kesler]
Tb          537.40;      // K   [origin=predictive method=joback]
HvapTb      48110.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.407 0.94112 -0.0006118 1.636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)nonane" );
gibbsFormation
{
    dHf_298   -181710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=51100.0
    phase     gas;
}
