/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-3-buten-1-ol  (C5H10O, CAS 763-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl3Buten1Ol;
formula     C5H10O;
CAS         763-32-6;
InChIKey    CPJRRXSHAYUTGL-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          570.79;      // K   [origin=predictive method=joback]
Pc          41.144;      // bar [origin=predictive method=joback]
omega       0.6553;      // -   [origin=predictive method=lee-kesler]
Tb          402.74;      // K   [origin=predictive method=joback]
HvapTb      42813.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.952 0.49272 -0.0003038 7.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbut-3-en-1-ol" "isobutenylcarbinol" "3-buten-1-ol, 3-methyl-" "methallylcarbinol" "isoprenol" "3-isopentenyl alcohol" "isopropenylethyl alcohol" "2-methyl-1-buten-4-ol" "methallyl carbinol" "3-methyl-3-butenol" "delta(3)-isopentenyl alcohol" "2-methyl-4-hydroxy-1-butene" );
standardThermochemistry
{
    dHf_298   -183120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-66310.0
}
