/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propylcyclohexanol  (C9H18O, CAS 90676-25-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propylcyclohexanol;
formula     C9H18O;
CAS         90676-25-8;
InChIKey    VZBNUCDUQJCIDP-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          700.74;      // K   [origin=predictive method=joback]
Pc          30.256;      // bar [origin=predictive method=joback]
omega       0.7405;      // -   [origin=predictive method=lee-kesler]
Tb          512.58;      // K   [origin=predictive method=joback]
HvapTb      52427.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.668 0.98842 -0.0005218 8.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propylcyclohexan-1-ol" "cyclohexanol, 2-propyl-" "2-n-propylcyclohexanol" "2-propyl-1-cyclohexanol" "cyclohexanol, 2-propyl-," "agn-pc-00ng63" "cyclohexanol, 2-propyl-, cis-" );
gibbsFormation
{
    dHf_298   -347340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-95180.0
    phase     gas;
}
