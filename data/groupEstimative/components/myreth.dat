/*--------------------------------*- Choupo -*-----------------------*\
  Component: myreth  (C16H34O2, CAS 2136-70-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        myreth;
formula     C16H34O2;
CAS         2136-70-1;
InChIKey    QHERURXKGFABNZ-UHFFFAOYSA-N;
MW          258.446;      // g/mol [origin=calculated method=formula-sum]
Tc          841.96;      // K   [origin=predictive method=joback]
Pc          13.933;      // bar [origin=predictive method=joback]
omega       1.1320;      // -   [origin=predictive method=lee-kesler]
Tb          680.28;      // K   [origin=predictive method=joback]
HvapTb      70299.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.135 1.49462 -0.000766 1.342e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tetradecoxyethanol" "ethoxylated tetradecanol" "2-(tetradecyloxy)ethanol" "myreth-5" "lipocol m 4" "ethanol, 2-(tetradecyloxy)-" "myreth-10" "peg-5 myristyl ether" "myristyl monoethoxylate" "peg-10 myristyl ether" "ethoxylated myristyl alcohol" "myristyl alcohol, ethoxylated" );
gibbsFormation
{
    dHf_298   -658020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     841.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-157980.0
    phase     gas;
}
