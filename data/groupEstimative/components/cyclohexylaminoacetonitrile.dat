/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexylaminoacetonitrile  (C8H14N2, CAS 1074-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylaminoacetonitrile;
formula     C8H14N2;
CAS         1074-58-4;
InChIKey    PIYOTHVPNLMMFD-UHFFFAOYSA-N;
MW          138.214;      // g/mol [origin=calculated method=formula-sum]
Tc          777.69;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.5889;      // -   [origin=predictive method=lee-kesler]
Tb          554.44;      // K   [origin=predictive method=joback]
HvapTb      50745.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.199 0.8969 -0.00051 9.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CHNH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(cyclohexylamino)ethanenitrile" "(cyclohexylamino)acetonitrile" "2-(cyclohexylamino)acetonitrile" "2-(cyclohexylamino)-acetonitrile" "acetonitrile, (cyclohexylamino)-" );
standardThermochemistry
{
    dHf_298   64220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=263500.0
}
