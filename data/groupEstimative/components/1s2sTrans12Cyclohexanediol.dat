/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1s,2s)-trans-1,2-cyclohexanediol  (C6H12O2, CAS 57794-08-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1s2sTrans12Cyclohexanediol;
formula     C6H12O2;
CAS         57794-08-8;
InChIKey    PFURGBBHAOXLIO-WDSKDSINSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          720.63;      // K   [origin=predictive method=joback]
Pc          48.360;      // bar [origin=predictive method=joback]
omega       1.1304;      // -   [origin=predictive method=lee-kesler]
Tb          536.12;      // K   [origin=predictive method=joback]
HvapTb      62428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.65 0.7374 -0.000389 6.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,2s)-cyclohexane-1,2-diol" "(1s)-trans-1,2-cyclohexanediol" "trans-1,2-cyclohexanediol" "trans-2-hydroxycyclohexanol" "ambap1460-57-7" "(1r,2r)-rel-1,2-cyclohexanediol" );
gibbsFormation
{
    dHf_298   -437650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-257260.0
    phase     gas;
}
