/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentafluorophenol  (C6HF5O, CAS 771-61-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentafluorophenol;
formula     C6HF5O;
CAS         771-61-9;
InChIKey    XBNGYFFABRKICK-UHFFFAOYSA-N;
MW          184.063;      // g/mol [origin=calculated method=formula-sum]
Tc          642.92;      // K   [origin=predictive method=joback]
Pc          39.111;      // bar [origin=predictive method=joback]
omega       0.7256;      // -   [origin=predictive method=lee-kesler]
Tb          460.45;      // K   [origin=predictive method=joback]
HvapTb      42803.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.26 0.4705 -0.000404 1.472e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACOH; count 1; } { group ACF; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group F; count 5; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5,6-pentakis(fluoranyl)phenol" "2,3,4,5,6-pentafluorophenol" "phenol, pentafluoro-" "2,3,4,5,6-pentafluoro-phenol" "phenol, 2,3,4,5,6-pentafluoro-" "hopfp" "perfluorophenol" "xbngyffabrkick-uhfffaoysa-" "4615-85-4 (potassium salt)" "2,3,4,5,6-pentafluorohydroxybenzene" "i552" );
gibbsFormation
{
    dHf_298   -1134380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1055140.0
    phase     gas;
}
