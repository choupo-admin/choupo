/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexadecane  (C16H32, CAS 295-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexadecane;
formula     C16H32;
CAS         295-65-8;
InChIKey    JJWIOXUMXIOXQN-UHFFFAOYSA-N;
MW          224.432;      // g/mol [origin=calculated method=formula-sum]
Tc          887.49;      // K   [origin=predictive method=joback]
Pc          19.475;      // bar [origin=predictive method=joback]
omega       0.3689;      // -   [origin=predictive method=lee-kesler]
Tb          632.60;      // K   [origin=predictive method=joback]
HvapTb      53668.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-134.41 1.5764 -0.000519 -8.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 16; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 16; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -360510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     990.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5000.0
    phase     gas;
}
