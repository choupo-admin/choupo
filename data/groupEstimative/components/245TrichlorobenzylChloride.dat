/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,5-trichlorobenzyl chloride  (C7H4Cl4, CAS 3955-26-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        245TrichlorobenzylChloride;
formula     C7H4Cl4;
CAS         3955-26-8;
InChIKey    UBJKMVAYDQUJSJ-UHFFFAOYSA-N;
MW          229.909;      // g/mol [origin=calculated method=formula-sum]
Tc          792.15;      // K   [origin=predictive method=joback]
Pc          32.579;      // bar [origin=predictive method=joback]
omega       0.4752;      // -   [origin=predictive method=lee-kesler]
Tb          551.10;      // K   [origin=predictive method=joback]
HvapTb      52978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.081 0.4386 -0.00026868 5.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group CH2Cl; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4-tris(chloranyl)-5-(chloromethyl)benzene" "1,2,4-trichloro-5-(chloromethyl)benzene" "benzene, 1,2,4-trichloro-5-(chloromethyl)-" "2,5-trichlorobenzyl chloride" "benzene,2,4-trichloro-5-(chloromethyl)-" "benzene,1,2,4-trichloro-5-(chloromethyl)-" "toluene, a,2,4,5-tetrachloro- (6ci,7ci);2,4,5-trichlorobenzyl chloride" );
standardThermochemistry
{
    dHf_298   -48650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=43860.0
}
