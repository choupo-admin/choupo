/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butene, 1-iodo-3-methyl-  (C5H9I, CAS 41004-19-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butene1Iodo3Methyl;
formula     C5H9I;
CAS         41004-19-7;
InChIKey    SWDGKAOKYFIAHW-UHFFFAOYSA-N;
MW          196.027;      // g/mol [origin=calculated method=formula-sum]
Tc          629.11;      // K   [origin=predictive method=joback]
Pc          36.159;      // bar [origin=predictive method=joback]
omega       0.2462;      // -   [origin=predictive method=lee-kesler]
Tb          411.18;      // K   [origin=predictive method=joback]
HvapTb      36135.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.839 0.53774 -0.0004157 1.374e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyl-3-methyl-but-2-ene" "1-iodo-3-methyl-2-butene" "1-iodo-3-methylbut-2-ene" );
gibbsFormation
{
    dHf_298   37770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=121010.0
    phase     gas;
}
