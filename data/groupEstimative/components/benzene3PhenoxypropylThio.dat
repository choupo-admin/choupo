/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, ((3-phenoxypropyl)thio)-  (C15H16OS, CAS 59950-10-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene3PhenoxypropylThio;
formula     C15H16OS;
CAS         59950-10-6;
InChIKey    DYESPVOVFYSSGL-UHFFFAOYSA-N;
MW          244.352;      // g/mol [origin=calculated method=formula-sum]
Tc          935.53;      // K   [origin=predictive method=joback]
Pc          25.100;      // bar [origin=predictive method=joback]
omega       0.6725;      // -   [origin=predictive method=lee-kesler]
Tb          687.36;      // K   [origin=predictive method=joback]
HvapTb      62763.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.457 1.20219 -0.0007034 1.359e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenoxypropylsulfanylbenzene" "benzene,[(3-phenoxypropyl)thio]-" "[(3-phenoxypropyl)sulfanyl]benzene" );
standardThermochemistry
{
    dHf_298   29780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     600.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=228360.0
}
