/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-propylbenzaldehyde diethyl acetal  (C14H22O2, CAS 89557-35-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4PropylbenzaldehydeDiethylAcetal;
formula     C14H22O2;
CAS         89557-35-7;
InChIKey    FMARRBDLJSOXHA-UHFFFAOYSA-N;
MW          222.328;      // g/mol [origin=calculated method=formula-sum]
Tc          791.79;      // K   [origin=predictive method=joback]
Pc          19.372;      // bar [origin=predictive method=joback]
omega       0.6981;      // -   [origin=predictive method=lee-kesler]
Tb          595.98;      // K   [origin=predictive method=joback]
HvapTb      54128.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.874 1.07496 -0.00048316 4.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(diethoxymethyl)-4-propyl-benzene" "1-(diethoxymethyl)-4-propylbenzene" "diethoxy(4-propylphenyl)methane" "4-(diethoxymethyl)propylbenzene" "benzene,1-(diethoxymethyl)-4-propyl-" );
standardThermochemistry
{
    dHf_298   -376950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42660.0
}
