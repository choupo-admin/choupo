/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethylenediamine, monooleate  (C24H46N2O2, CAS 67633-85-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triethylenediamineMonooleate;
formula     C24H46N2O2;
CAS         67633-85-6;
InChIKey    SUAAJVZCFQNMRS-KVVVOXFISA-N;
MW          394.644;      // g/mol [origin=calculated method=formula-sum]
Tc          1160.03;      // K   [origin=predictive method=joback]
Pc          10.097;      // bar [origin=predictive method=joback]
omega       0.9768;      // -   [origin=predictive method=lee-kesler]
Tb          947.49;      // K   [origin=predictive method=joback]
HvapTb      90964.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.436 2.75102 -0.0017998 4.624e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CH=CH; count 1; } { group CH2N; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group dCH; count 2; } { group CH2_ring; count 6; } { group COOH; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-diazabicyclo[2.2.2]octane;(z)-octadec-9-enoic acid" "1,4-diazabicyclo[2.2.2]octane; (z)-octadec-9-enoic acid" "oleic acid, compound with 1,4-diazabicyclo(2.2.2)octane (1:1)" "9-octadecenoic acid (9z)-, compd. with 1,4-diazabicyclo(2.2.2)octane (1:1)" );
gibbsFormation
{
    dHf_298   -562020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1181.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=141230.0
    phase     gas;
}
