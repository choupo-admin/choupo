/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hexyn-3-ol, 3-methyl-6-(2-piperidinoethoxy)-,  (C14H25NO2, CAS 16464-38-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hexyn3Ol3Methyl62Piperidinoethoxy;
formula     C14H25NO2;
CAS         16464-38-3;
InChIKey    RVIQXFQDUFBZSM-UHFFFAOYSA-N;
MW          239.359;      // g/mol [origin=calculated method=formula-sum]
Tc          870.65;      // K   [origin=predictive method=joback]
Pc          22.741;      // bar [origin=predictive method=joback]
omega       1.0212;      // -   [origin=predictive method=lee-kesler]
Tb          672.68;      // K   [origin=predictive method=joback]
HvapTb      69312.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.076 1.56274 -0.00103226 2.6638e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group C; count 1; } { group OH; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group tC; count 2; } { group CH2_ring; count 5; } { group OH; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-6-(2-piperidin-1-ylethoxy)hex-4-yn-3-ol" );
gibbsFormation
{
    dHf_298   -204840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185860.0
    phase     gas;
}
