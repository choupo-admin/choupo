/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-cyclohexylhexanoic acid  (C12H22O2, CAS 4354-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6CyclohexylhexanoicAcid;
formula     C12H22O2;
CAS         4354-56-7;
InChIKey    FIDNHQYXZUPELG-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          845.59;      // K   [origin=predictive method=joback]
Pc          23.203;      // bar [origin=predictive method=joback]
omega       0.8399;      // -   [origin=predictive method=lee-kesler]
Tb          639.22;      // K   [origin=predictive method=joback]
HvapTb      59899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.025 1.3167 -0.0007826 1.692e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexanehexanoic acid" "6-cyclohexyl-hexanoic acid" "cyclohexane-caproic acid" "wt756" "6283-88-1 6-cyclohexylhexanoic acid" );
standardThermochemistry
{
    dHf_298   -586960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-269300.0
}
