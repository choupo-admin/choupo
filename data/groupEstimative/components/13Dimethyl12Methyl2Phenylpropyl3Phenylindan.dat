/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dimethyl-1-(2-methyl-2-phenylpropyl)-3-phenylindan  (C27H30, CAS 41906-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dimethyl12Methyl2Phenylpropyl3Phenylindan;
formula     C27H30;
CAS         41906-71-2;
InChIKey    UXZZHVLZNFQJMN-UHFFFAOYSA-N;
MW          354.537;      // g/mol [origin=calculated method=formula-sum]
Tc          1167.00;      // K   [origin=predictive method=joback]
Pc          14.501;      // bar [origin=predictive method=joback]
omega       0.7186;      // -   [origin=predictive method=lee-kesler]
Tb          901.70;      // K   [origin=predictive method=joback]
HvapTb      79192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-277.829 3.10668 -0.00287336 1.1007e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 3; } { group ACH; count 14; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH2_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 14; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dimethyl-1-(2-methyl-2-phenyl-propyl)-3-phenyl-2h-indene" "1h-indene, 2,3-dihydro-1,3-dimethyl-1-(2-methyl-2-phenylpropyl)-3-phenyl-" "1,3-dimethyl-1-(2-methyl-2-phenylpropyl)-3-phenyl-2h-indene" );
standardThermochemistry
{
    dHf_298   171700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     849.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=548960.0
}
