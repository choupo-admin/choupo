/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-isopropylpiperazine  (C7H16N2, CAS 4318-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Isopropylpiperazine;
formula     C7H16N2;
CAS         4318-42-7;
InChIKey    WHKWMTXTYKVFLK-UHFFFAOYSA-N;
MW          128.219;      // g/mol [origin=calculated method=formula-sum]
Tc          646.13;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.4245;      // -   [origin=predictive method=lee-kesler]
Tb          440.26;      // K   [origin=predictive method=joback]
HvapTb      40155.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.35 0.94344 -0.000595 1.438e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propan-2-ylpiperazine" "n-isopropylpiperazine" "1-isopropyl-piperazine" "piperazine, 1-isopropyl-" "1-(propan-2-yl)piperazine" "isopropyl piperazine" "n-isopropyl piperazine" "1-(1-methylethyl)piperazine" "(methylethyl)piperazine" "n-isopropylpiperizine" "1-(isopropyl)piperazine" "(1-isopropyl)piperazine" );
gibbsFormation
{
    dHf_298   -6930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=248370.0
    phase     gas;
}
