/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(dimethylamino)-3-methylphenol  (C9H13NO, CAS 14143-25-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Dimethylamino3Methylphenol;
formula     C9H13NO;
CAS         14143-25-0;
InChIKey    SZBIKNXBDIVHKY-UHFFFAOYSA-N;
MW          151.209;      // g/mol [origin=calculated method=formula-sum]
Tc          750.29;      // K   [origin=predictive method=joback]
Pc          38.151;      // bar [origin=predictive method=joback]
omega       0.6309;      // -   [origin=predictive method=lee-kesler]
Tb          530.24;      // K   [origin=predictive method=joback]
HvapTb      53623.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.51 0.99896 -0.00079892 2.67e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(dimethylamino)-3-methyl-phenol" "aminocarb phenol" "phenol, 4-(dimethylamino)-3-methyl-" "4-(dimethylamino)-m-cresol" "4-(dimethylamino)-3-cresol" "phenol,4-(dimethylamino)-3-methyl-" );
standardThermochemistry
{
    dHf_298   -113810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83840.0
}
