/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethoxy-2,2,2-trifluoroethanol  (C4H7F3O2, CAS 433-27-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethoxy222Trifluoroethanol;
formula     C4H7F3O2;
CAS         433-27-2;
InChIKey    KLXJPQNHFFMLIG-UHFFFAOYSA-N;
MW          144.092;      // g/mol [origin=calculated method=formula-sum]
Tc          551.17;      // K   [origin=predictive method=joback]
Pc          37.408;      // bar [origin=predictive method=joback]
omega       0.7914;      // -   [origin=predictive method=lee-kesler]
Tb          399.86;      // K   [origin=predictive method=joback]
HvapTb      39452.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.161 0.52172 -0.0003374 7.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2O; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group F; count 3; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxy-2,2,2-tris(fluoranyl)ethanol" "trifluoroacetaldehyde ethyl hemiacetal" "fluoral ethyl hemiacetal" "ethanol, 1-ethoxy-2,2,2-trifluoro-" "1-ethoxy-2,2,2-trifluoroethan-1-ol" "1-ethoxy-2,2-trifluoroethanol" "trifluoroacetaldehyde ethylhemiacetal" "trifluoroacetaldehyde hemiethylacetal" "perfluoroacetaldehyde ethyl hemiacetal" "t245" "2-ethoxy-2-hydroxy-1,1,1-trifluoroethane" "trifluoroacetaldehyde ethyl hemiacetal, tech" );
standardThermochemistry
{
    dHf_298   -1012700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-843050.0
}
