/*--------------------------------*- Choupo -*-----------------------*\
  Component: gepefrine  (C9H13NO, CAS 1075-61-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gepefrine;
formula     C9H13NO;
CAS         1075-61-2;
InChIKey    WTDGMHYYGNJEKQ-UHFFFAOYSA-N;
MW          151.209;      // g/mol [origin=calculated method=formula-sum]
Tc          821.25;      // K   [origin=predictive method=joback]
Pc          42.330;      // bar [origin=predictive method=joback]
omega       0.7267;      // -   [origin=predictive method=lee-kesler]
Tb          584.91;      // K   [origin=predictive method=joback]
HvapTb      61171.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.309 1.00232 -0.00079996 2.65e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-azanylpropyl)phenol" "3-(2-aminopropyl)phenol" "alpha-methyl-m-tyramine" "alpha-mmtyr" "m-(2-aminopropyl)phenol" "phenol, m-(2-aminopropyl)-" "3-[(2s)-2-aminopropyl]phenol" "phenol,3-(2-aminopropyl)-" "phenol,m-(2-aminopropyl)- (6ci,7ci,8ci); (?a'a a'a currency)-desoxymetaraminol; 3-(2-aminopropyl)phenol; 3-hydroxy-a-methylphenethylamine;dl-m-hydroxyamphetamine; a-methyl-m-tyramine" );
standardThermochemistry
{
    dHf_298   -141360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46700.0
}
