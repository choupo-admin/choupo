/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-4-oxidanyl-hex-3-en-2-one  (C8H14O2, CAS 59892-35-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl4OxidanylHex3En2One;
formula     C8H14O2;
CAS         59892-35-2;
InChIKey    ADKXSDNPFKCVRC-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          718.56;      // K   [origin=predictive method=joback]
Pc          32.467;      // bar [origin=predictive method=joback]
omega       0.8314;      // -   [origin=predictive method=lee-kesler]
Tb          529.50;      // K   [origin=predictive method=joback]
HvapTb      55569.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.08 0.91558 -0.000681 2.0586e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -374580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-174750.0
}
