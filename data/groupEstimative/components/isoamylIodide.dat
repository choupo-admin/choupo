/*--------------------------------*- Choupo -*-----------------------*\
  Component: isoamyl iodide  (C5H11I, CAS 541-28-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isoamylIodide;
formula     C5H11I;
CAS         541-28-6;
InChIKey    BUZZUHJODKQYTF-UHFFFAOYSA-N;
MW          198.043;      // g/mol [origin=calculated method=formula-sum]
Tc          614.24;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.2744;      // -   [origin=predictive method=lee-kesler]
Tb          406.70;      // K   [origin=predictive method=joback]
HvapTb      35709.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.352 0.52374 -0.0003328 8.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyl-3-methyl-butane" "1-iodo-3-methylbutane" "isopentyl iodide" "butane, 1-iodo-3-methyl-" "iso-amyliodide" "3-methylbutyliodide" "1-iodo-3-methyl butane" "1-jod-3-methylbutan" "isoamyl iodide; isopentyl iodide" "buzzuhjodkqytf-uhfffaoysa-" "1-iodo-3-methylbutane;3-methyl-1-iodobutane;3-methylbutyliodide;4-iodo-2-methylbutane;iso-amyliodide;isoamyl iodide;isopentyl iodide;" );
standardThermochemistry
{
    dHf_298   -74940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46900.0
}
