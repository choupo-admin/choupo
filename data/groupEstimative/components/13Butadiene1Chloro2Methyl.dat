/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-butadiene, 1-chloro-2-methyl-  (C5H7Cl, CAS 35383-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Butadiene1Chloro2Methyl;
formula     C5H7Cl;
CAS         35383-51-8;
InChIKey    ITQIRXSIZVCCPM-SNAWJCMRSA-N;
MW          102.561;      // g/mol [origin=calculated method=formula-sum]
Tc          542.23;      // K   [origin=predictive method=joback]
Pc          37.362;      // bar [origin=predictive method=joback]
omega       0.2344;      // -   [origin=predictive method=lee-kesler]
Tb          352.15;      // K   [origin=predictive method=joback]
HvapTb      30477.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.63 0.48552 -0.0003776 1.239e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1e)-1-chloranyl-2-methyl-buta-1,3-diene" "(1e)-1-chloro-2-methylbuta-1,3-diene" );
standardThermochemistry
{
    dHf_298   70590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=138800.0
}
