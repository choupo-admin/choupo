/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[3.2.2]nona-6,8-diene  (C9H12, CAS 7164-08-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo322Nona68Diene;
formula     C9H12;
CAS         7164-08-1;
InChIKey    SSAZIYAFEXRJHA-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          651.18;      // K   [origin=predictive method=joback]
Pc          35.643;      // bar [origin=predictive method=joback]
omega       0.2806;      // -   [origin=predictive method=lee-kesler]
Tb          430.13;      // K   [origin=predictive method=joback]
HvapTb      36554.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.58 1.0198 -0.00074156 2.132e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo(3.2.2)nona-6,8-diene" );
gibbsFormation
{
    dHf_298   13590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     311.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=170020.0
    phase     gas;
}
