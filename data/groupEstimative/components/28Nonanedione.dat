/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,8-nonanedione  (C9H16O2, CAS 30502-73-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        28Nonanedione;
formula     C9H16O2;
CAS         30502-73-9;
InChIKey    APAPZQYXOGNKGH-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          697.11;      // K   [origin=predictive method=joback]
Pc          26.137;      // bar [origin=predictive method=joback]
omega       0.7085;      // -   [origin=predictive method=lee-kesler]
Tb          513.26;      // K   [origin=predictive method=joback]
HvapTb      49120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.425 0.80284 -0.0004284 7.782e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonane-2,8-dione" );
standardThermochemistry
{
    dHf_298   -454250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-232940.0
}
