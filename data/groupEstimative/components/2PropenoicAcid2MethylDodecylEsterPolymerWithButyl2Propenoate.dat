/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, dodecyl ester, polymer with butyl 2-propenoate and (1-methylethenyl)benzene  (C32H52O4, CAS 69898-54-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2MethylDodecylEsterPolymerWithButyl2Propenoate;
formula     C32H52O4;
CAS         69898-54-0;
InChIKey    YFUQNZGWPWWKST-UHFFFAOYSA-N;
MW          500.764;      // g/mol [origin=calculated method=formula-sum]
Tc          1312.72;      // K   [origin=predictive method=joback]
Pc          6.285;      // bar [origin=predictive method=joback]
omega       0.5059;      // -   [origin=predictive method=lee-kesler]
Tb          1067.48;      // K   [origin=predictive method=joback]
HvapTb      102654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.994 2.38278 -0.0008027 -9.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 14; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 14; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate;dodecyl 2-methylprop-2-enoate;prop-1-en-2-ylbenzene" "alpha-methylstyrene, butyl acrylate, dodecyl methacrylate polymer" );
standardThermochemistry
{
    dHf_298   -968370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1591.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-252870.0
}
