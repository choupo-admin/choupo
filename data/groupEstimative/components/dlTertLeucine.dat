/*--------------------------------*- Choupo -*-----------------------*\
  Component: dl-tert-leucine  (C6H13NO2, CAS 33105-81-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dlTertLeucine;
formula     C6H13NO2;
CAS         33105-81-6;
InChIKey    NPDBDJFLKKQMCM-UHFFFAOYSA-N;
MW          131.175;      // g/mol [origin=calculated method=formula-sum]
Tc          767.33;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.7327;      // -   [origin=predictive method=lee-kesler]
Tb          551.25;      // K   [origin=predictive method=joback]
HvapTb      55071.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.63 0.81826 -0.0005936 1.706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-3,3-dimethyl-butanoic acid" "2-amino-3,3-dimethylbutanoic acid" "t-butylglycine" "tert-butylglycine" "3-methyl valine" "dl-tert-butylglycine" "tert-leucine" "3-methylvaline" "dl-t-butylglycine" "2-amino-3,3-dimethyl-butyric acid" "h-dl-tle-oh" "h-tbu-dl-gly-oh" );
standardThermochemistry
{
    dHf_298   -497680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-277420.0
}
