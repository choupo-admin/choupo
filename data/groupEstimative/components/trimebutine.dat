/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimebutine  (C22H29NO5, CAS 39133-31-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimebutine;
formula     C22H29NO5;
CAS         39133-31-8;
InChIKey    LORDFXWUHHSAQU-UHFFFAOYSA-N;
MW          387.476;      // g/mol [origin=calculated method=formula-sum]
Tc          1125.54;      // K   [origin=predictive method=joback]
Pc          13.300;      // bar [origin=predictive method=joback]
omega       1.0482;      // -   [origin=predictive method=lee-kesler]
Tb          905.95;      // K   [origin=predictive method=joback]
HvapTb      86488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.722 1.76292 -0.00089108 1.147e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 7; } { group AC; count 5; } { group CH3O; count 3; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group O; count 3; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(dimethylamino)-2-phenyl-butyl] 3,4,5-trimethoxybenzoate" "debridat" "trimedat" "trimebutinum [inn-latin]" "benzoic acid, 3,4,5-trimethoxy-, 2-(dimethylamino)-2-phenylbutyl ester" "2-(dimethylamino)-2-phenylbutyl 3,4,5-trimethoxybenzoate" "2-dimethylamino-2-phenylbutyl 3,4,5-trimethoxybenzoat" "3,4,5-trimethoxybenzoic acid 2-(dimethylamino)-2-phenylbutyl ester" "trimebutino" "trimebutinum" "trimebutina (tn)" "trimebutine (inn)" );
standardThermochemistry
{
    dHf_298   -713920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     843.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-181460.0
}
