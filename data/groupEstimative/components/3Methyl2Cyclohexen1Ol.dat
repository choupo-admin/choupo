/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-2-cyclohexen-1-ol  (C7H12O, CAS 21378-21-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl2Cyclohexen1Ol;
formula     C7H12O;
CAS         21378-21-2;
InChIKey    XNDZQQSKSQTQQD-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          671.63;      // K   [origin=predictive method=joback]
Pc          40.466;      // bar [origin=predictive method=joback]
omega       0.6700;      // -   [origin=predictive method=lee-kesler]
Tb          475.63;      // K   [origin=predictive method=joback]
HvapTb      49238.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.71 0.70942 -0.00038864 7.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylcyclohex-2-en-1-ol" "seudenol" "2-cyclohexen-1-ol, 3-methyl-" "1-methyl-1-cyclohexen-3-ol" "3-methylcyclohex-2-enol" "agn-pc-00g6xi" "3-methyl-1-cyclohex-2-enol" "2-cyclohexen-1-ol,3-methyl-" "3-methyl-cyclohex-2-en-1-ol" "xndzqqsksqtqqd-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -239410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83980.0
    phase     gas;
}
