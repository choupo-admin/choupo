/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hepten-2-one, 3-ethyl-4-methyl-  (C10H18O, CAS 54244-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hepten2One3Ethyl4Methyl;
formula     C10H18O;
CAS         54244-90-5;
InChIKey    PUHMMKUISPITSC-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          673.45;      // K   [origin=predictive method=joback]
Pc          23.726;      // bar [origin=predictive method=joback]
omega       0.5328;      // -   [origin=predictive method=lee-kesler]
Tb          486.19;      // K   [origin=predictive method=joback]
HvapTb      44718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.407 0.94568 -0.0005899 1.4976e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH3CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group dC; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-4-methyl-hept-3-en-2-one" );
gibbsFormation
{
    dHf_298   -264670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32480.0
    phase     gas;
}
