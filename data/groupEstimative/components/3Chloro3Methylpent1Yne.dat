/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-3-methylpent-1-yne  (C6H9Cl, CAS 14179-94-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro3Methylpent1Yne;
formula     C6H9Cl;
CAS         14179-94-3;
InChIKey    WTNNDYSRQSOJKB-UHFFFAOYSA-N;
MW          116.588;      // g/mol [origin=calculated method=formula-sum]
Tc          559.29;      // K   [origin=predictive method=joback]
Pc          36.115;      // bar [origin=predictive method=joback]
omega       0.2042;      // -   [origin=predictive method=lee-kesler]
Tb          361.20;      // K   [origin=predictive method=joback]
HvapTb      31897.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.369 0.61254 -0.00049073 1.5949e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-3-methyl-pent-1-yne" "3-chloro-3-methyl-1-pentyne" "1-pentyne, 3-chloro-3-methyl-" "3-chloro-3-ethylbutyne" );
standardThermochemistry
{
    dHf_298   100240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     353.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213620.0
}
