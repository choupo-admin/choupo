/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopentyl hexanoate  (C11H22O2, CAS 2198-61-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopentylHexanoate;
formula     C11H22O2;
CAS         2198-61-0;
InChIKey    XVSZRAWFCDHCBP-UHFFFAOYSA-N;
MW          186.295;      // g/mol [origin=calculated method=formula-sum]
Tc          680.56;      // K   [origin=predictive method=joback]
Pc          19.561;      // bar [origin=predictive method=joback]
omega       0.6585;      // -   [origin=predictive method=lee-kesler]
Tb          509.06;      // K   [origin=predictive method=joback]
HvapTb      47099.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.616 0.99996 -0.0004832 6.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutyl hexanoate" "isoamyl hexanoate" "isoamyl caproate" "hexanoic acid, 3-methylbutyl ester" "isopentyl caproate" "isopentyl-n-hexanoate" "isoamyl hexanoate (natural)" "isopentyl alcohol, hexanoate" "hexanoic acid, isopentyl ester" "hexanoic acid isoamyl ester" "hexanoic acid isopentyl ester" "hexanoicacid, isopentyl ester (7ci,8ci);isopentyl alcohol, hexanoate (8ci);3-methylbutyl hexanoate;isoamyl caproate;isoamyl hexanoate;isopentyl hexanoate;" );
gibbsFormation
{
    dHf_298   -592930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     626.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-271070.0
    phase     gas;
}
