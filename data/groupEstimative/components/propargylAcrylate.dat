/*--------------------------------*- Choupo -*-----------------------*\
  Component: propargyl acrylate  (C6H6O2, CAS 10477-47-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propargylAcrylate;
formula     C6H6O2;
CAS         10477-47-1;
InChIKey    WPBNLDNIZUGLJL-UHFFFAOYSA-N;
MW          110.112;      // g/mol [origin=calculated method=formula-sum]
Tc          572.27;      // K   [origin=predictive method=joback]
Pc          39.111;      // bar [origin=predictive method=joback]
omega       0.3544;      // -   [origin=predictive method=lee-kesler]
Tb          381.90;      // K   [origin=predictive method=joback]
HvapTb      35545.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.631 0.4051 -0.00022683 3.889e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH_C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group tCH; count 1; } { group tC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-ynyl prop-2-enoate" "prop-2-yn-1-yl acrylate" "acrylic acid propargyl ester" "2-propenoic acid, 2-propynyl ester" "2-propenoic acid, 2-propyn-1-yl ester" "2-propynyl acrylate" "2-propenoic acid,2-propyn-1-yl ester" );
gibbsFormation
{
    dHf_298   -67120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=180.0
    phase     gas;
}
