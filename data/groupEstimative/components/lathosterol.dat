/*--------------------------------*- Choupo -*-----------------------*\
  Component: lathosterol  (C27H46O, CAS 80-99-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lathosterol;
formula     C27H46O;
CAS         80-99-9;
InChIKey    IZVFFXVYBHFIHY-SKCNUYALSA-N;
MW          386.664;      // g/mol [origin=calculated method=formula-sum]
Tc          1168.48;      // K   [origin=predictive method=joback]
Pc          10.785;      // bar [origin=predictive method=joback]
omega       0.9537;      // -   [origin=predictive method=lee-kesler]
Tb          947.58;      // K   [origin=predictive method=joback]
HvapTb      89836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-306.387 3.5591 -0.00294984 1.0573e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 11; } { group CH; count 7; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,5s,9r,10s,13r,14r,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,5,6,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-ol" "gamma-cholesterol" "5alpha-cholest-7-en-3beta-ol" "cholest-7-en-3-ol" "7-cholesten-3-beta-ol" "cholesterin [german]" "5-alpha-cholest-7-en-3-beta-ol" "cholest-7-en-3beta-ol" "delta(sup 7)-cholestenol" "(3-beta,5-alpha)-cholest-7-en-3-ol" "7-cholesterol" "5" "a-cholest-7-en-3" "a-ol" );
gibbsFormation
{
    dHf_298   -487230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     946.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=203480.0
    phase     gas;
}
