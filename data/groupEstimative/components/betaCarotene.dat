/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-carotene  (C40H56, CAS 7235-40-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaCarotene;
formula     C40H56;
CAS         7235-40-7;
InChIKey    OENHQHLEOONYIE-JLTXGRSLSA-N;
MW          536.888;      // g/mol [origin=calculated method=formula-sum]
Tc          1481.11;      // K   [origin=predictive method=joback]
Pc          6.073;      // bar [origin=predictive method=joback]
omega       0.5129;      // -   [origin=predictive method=lee-kesler]
Tb          1209.58;      // K   [origin=predictive method=joback]
HvapTb      106364.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-318.31 4.4616 -0.0038492 1.4226e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group CH2; count 6; } { group C; count 2; } { group CH=CH; count 5; } { group CH=C; count 4; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group dCH; count 14; } { group dC; count 4; } { group CH2_ring; count 6; } { group C_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,3-trimethyl-2-[(1e,3e,5e,7e,9e,11e,13e,15e,17e)-3,7,12,16-tetramethyl-18-(2,6,6-trimethylcyclohexen-1-yl)octadeca-1,3,5,7,9,11,13,15,17-nonaenyl]cyclohexene" "beta carotene" "beta,beta-carotene" "solatene" "provitamin a" "carotaben" "all-trans-beta-carotene" "betacarotene" "provatene" "serlabo" "food orange 5" "kpmk" );
standardThermochemistry
{
    dHf_298   355690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1616.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1033020.0
}
