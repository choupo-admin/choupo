/*--------------------------------*- Choupo -*-----------------------*\
  Component: leucoglucosan  (C6H10O5, CAS 498-07-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        leucoglucosan;
formula     C6H10O5;
CAS         498-07-7;
InChIKey    TWNIBLMWSKIRAT-VFUOTHLCSA-N;
MW          162.141;      // g/mol [origin=calculated method=formula-sum]
Tc          856.97;      // K   [origin=predictive method=joback]
Pc          56.960;      // bar [origin=predictive method=joback]
omega       1.9137;      // -   [origin=predictive method=lee-kesler]
Tb          675.33;      // K   [origin=predictive method=joback]
HvapTb      87250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.96 0.8729 -0.0005474 1.264e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 4; } { group OH; count 3; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 5; } { group OH; count 3; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2s,3s,4r,5r)-6,8-dioxabicyclo[3.2.1]octane-2,3,4-triol" "levoglucosan" "1,6-anhydro-beta-d-glucose" "1,6-anhydro-beta-d-glucopyranose" "1,6-anhydro-beta-glucopyranose" "1,6-anhydroglucose" "glucosan" "1,6-anhydro-d-glucose" "anhydro-d-mannosan" "1,6-anhydro-d-glucopyranose" "beta-d-glucopyranose, 1,6-anhydro-" "levoglucosan (8ci)" );
gibbsFormation
{
    dHf_298   -815600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     171.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-508890.0
    phase     gas;
}
