/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetylenedicarboxylic acid  (C4H2O4, CAS 142-45-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetylenedicarboxylicAcid;
formula     C4H2O4;
CAS         142-45-0;
InChIKey    YTIVTFGABIZHHX-UHFFFAOYSA-N;
MW          114.056;      // g/mol [origin=calculated method=formula-sum]
Tc          827.68;      // K   [origin=predictive method=joback]
Pc          62.590;      // bar [origin=predictive method=joback]
omega       0.9293;      // -   [origin=predictive method=lee-kesler]
Tb          591.14;      // K   [origin=predictive method=joback]
HvapTb      60978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.01 0.3356 -0.00024686 7.138e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-2-ynedioic acid" "2-butynedioic acid" "butynedioic acid" "acetylenedicarboxylate" "acetylenedicarboxylic acid (8ci)" "928-04-1 (potassium salt)" "acetylenedicarboxylate;but-2-ynedioate;but-2-ynedioic acid;butynedioic acid;acetylenedicarboxylicacid;2-butynedioic acid;acetylenedicarboxylic acid;" );
gibbsFormation
{
    dHf_298   -554130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-502220.0
    phase     gas;
}
