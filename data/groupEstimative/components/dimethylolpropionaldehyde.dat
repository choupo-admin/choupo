/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylolpropionaldehyde  (C5H10O3, CAS 18516-18-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylolpropionaldehyde;
formula     C5H10O3;
CAS         18516-18-2;
InChIKey    CBIFNLUPCWCNQT-UHFFFAOYSA-N;
MW          118.132;      // g/mol [origin=calculated method=formula-sum]
Tc          715.27;      // K   [origin=predictive method=joback]
Pc          49.524;      // bar [origin=predictive method=joback]
omega       1.3596;      // -   [origin=predictive method=lee-kesler]
Tb          543.79;      // K   [origin=predictive method=joback]
HvapTb      65506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.148 0.64712 -0.0004738 1.377e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group OH; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group OH; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(hydroxymethyl)-2-methyl-3-oxidanyl-propanal" "propanal, 3-hydroxy-2-(hydroxymethyl)-2-methyl-" "2,2-bis(hydroxymethyl)propanal" "3-hydroxy-2-(hydroxymethyl)-2-methylpropanal" "propanal,3-hydroxy-2-(hydroxymethyl)-2-methyl-" "3-hydroxy-2-(hydroxymethyl)-2-methylpropionaldehyde" "propionaldehyde,2,2-bis(hydroxymethyl)- (8ci); 2,2-bis(hydroxymethyl)propanal;2,2-bis(hydroxymethyl)propionaldehyde; 2,2-dihydroxymethylpropionaldehyde;2,2-dimethylolpropanal; 2,2-dimethylolpropionaldehyde;3-hydroxy-2-hydroxymethyl-2-methylpropanal" );
gibbsFormation
{
    dHf_298   -545320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-379100.0
    phase     gas;
}
