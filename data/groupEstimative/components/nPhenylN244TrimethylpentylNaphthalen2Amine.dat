/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-phenyl-n-(2,4,4-trimethylpentyl)naphthalen-2-amine  (C24H29N, CAS 68845-34-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nPhenylN244TrimethylpentylNaphthalen2Amine;
formula     C24H29N;
CAS         68845-34-1;
InChIKey    NOSNNQQNOPZHMH-UHFFFAOYSA-N;
MW          331.503;      // g/mol [origin=calculated method=formula-sum]
Tc          1070.72;      // K   [origin=predictive method=joback]
Pc          14.736;      // bar [origin=predictive method=joback]
omega       0.8066;      // -   [origin=predictive method=lee-kesler]
Tb          834.81;      // K   [origin=predictive method=joback]
HvapTb      76231.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.728 2.31848 -0.00170148 4.904e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group ACH; count 12; } { group AC; count 4; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentanamine, 2,4,4-trimethyl-n-1-naphthalenyl-n-phenyl-" "2,4,4-trimethyl-n-1-naphthyl-n-phenylpentylamine" );
standardThermochemistry
{
    dHf_298   167470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     730.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=584220.0
}
