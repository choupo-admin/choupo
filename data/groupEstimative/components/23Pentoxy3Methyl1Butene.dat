/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-pentoxy)-3-methyl-1-butene  (C10H20O, CAS 56798-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Pentoxy3Methyl1Butene;
formula     C10H20O;
CAS         56798-18-6;
InChIKey    GCRGZVPKBFFPEY-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          622.61;      // K   [origin=predictive method=joback]
Pc          22.000;      // bar [origin=predictive method=joback]
omega       0.4583;      // -   [origin=predictive method=lee-kesler]
Tb          446.50;      // K   [origin=predictive method=joback]
HvapTb      38898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.252 0.88238 -0.0004408 7.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3-methylbut-1-en-2-yloxy)pentane" "pentane,3-(2-methyl-1-methylenepropoxy)-" );
gibbsFormation
{
    dHf_298   -276870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=2730.0
    phase     gas;
}
