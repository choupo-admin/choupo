/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisobutyl adipate  (C14H26O4, CAS 141-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisobutylAdipate;
formula     C14H26O4;
CAS         141-04-8;
InChIKey    RDOFJDLLWVCMRU-UHFFFAOYSA-N;
MW          258.358;      // g/mol [origin=calculated method=formula-sum]
Tc          811.53;      // K   [origin=predictive method=joback]
Pc          15.549;      // bar [origin=predictive method=joback]
omega       0.8846;      // -   [origin=predictive method=lee-kesler]
Tb          635.48;      // K   [origin=predictive method=joback]
HvapTb      60796.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.616 1.23608 -0.000555 4.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-methylpropyl) hexanedioate" "isobutyl adipate" "adipic acid, diisobutyl ester" "ftaflex diba" "diba" "plasthall diba" "hexanedioic acid, bis(2-methylpropyl) ester" "diisobutyl hexanedioate" "adipic acid bis(2-methylpropyl) ester" "hexanedioic acid, diisobutyl ester" "hexanedioic acid, 1,6-bis(2-methylpropyl) ester" "di2-methylpropyl hexane-1,6-dioate" );
gibbsFormation
{
    dHf_298   -977410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     784.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-558620.0
    phase     gas;
}
