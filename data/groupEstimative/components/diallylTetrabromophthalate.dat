/*--------------------------------*- Choupo -*-----------------------*\
  Component: diallyl tetrabromophthalate  (C14H10Br4O4, CAS 49693-09-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diallylTetrabromophthalate;
formula     C14H10Br4O4;
CAS         49693-09-6;
InChIKey    FZGLNDYBTGMDDR-UHFFFAOYSA-N;
MW          561.846;      // g/mol [origin=calculated method=formula-sum]
Tc          1196.10;      // K   [origin=predictive method=joback]
Pc          26.680;      // bar [origin=predictive method=joback]
omega       1.3922;      // -   [origin=predictive method=lee-kesler]
Tb          945.94;      // K   [origin=predictive method=joback]
HvapTb      91558.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (105.352 0.9606 -0.000576 1.134e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 2; } { group AC; count 6; } { group Br; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group dC_ring; count 6; } { group Br; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(prop-2-enyl) 3,4,5,6-tetrakis(bromanyl)benzene-1,2-dicarboxylate" "diallyl 3,4,5,6-tetrabromophthalate" "1,2-benzenedicarboxylic acid, 3,4,5,6-tetrabromo-, di-2-propenyl ester" "1,2-benzenedicarboxylic acid, 3,4,5,6-tetrabromo-, 1,2-di-2-propen-1-yl ester" "bis(prop-2-enyl) 3,4,5,6-tetrabromobenzene-1,2-dicarboxylate" );
standardThermochemistry
{
    dHf_298   -431490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     861.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-256520.0
}
