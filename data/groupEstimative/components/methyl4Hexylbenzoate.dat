/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-hexylbenzoate  (C14H20O2, CAS 38409-63-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4Hexylbenzoate;
formula     C14H20O2;
CAS         38409-63-1;
InChIKey    RTTGTHPEVMEHEK-UHFFFAOYSA-N;
MW          220.312;      // g/mol [origin=calculated method=formula-sum]
Tc          808.59;      // K   [origin=predictive method=joback]
Pc          19.912;      // bar [origin=predictive method=joback]
omega       0.7291;      // -   [origin=predictive method=lee-kesler]
Tb          609.80;      // K   [origin=predictive method=joback]
HvapTb      57103.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.035 1.14064 -0.00060736 9.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl p-hexylbenzoate" "benzoic acid, 4-hexyl-, methyl ester" "4-hexylbenzoic acid methyl ester" );
gibbsFormation
{
    dHf_298   -424510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-140590.0
    phase     gas;
}
