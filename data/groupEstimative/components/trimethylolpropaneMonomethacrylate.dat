/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolpropane monomethacrylate  (C10H18O4, CAS 7024-09-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolpropaneMonomethacrylate;
formula     C10H18O4;
CAS         7024-09-1;
InChIKey    HGOUNPXIJSDIKV-UHFFFAOYSA-N;
MW          202.25;      // g/mol [origin=calculated method=formula-sum]
Tc          837.20;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       1.4447;      // -   [origin=predictive method=lee-kesler]
Tb          664.31;      // K   [origin=predictive method=joback]
HvapTb      76733.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.634 1.07274 -0.0006834 1.614e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group CH2=C; count 1; } { group OH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)butyl 2-methylprop-2-enoate" "2,2-bis(hydroxymethyl)butyl methacrylate" "methacrylic acid 2,2-bis(hydroxymethyl)butyl ester" "2-propenoic acid, 2-methyl-, 2,2-bis(hydroxymethyl)butyl ester" "2-propenoic acid,2-methyl-, 2,2-bis(hydroxymethyl)butyl ester" "methacrylicacid, 2,2-bis(hydroxymethyl)butyl ester (7ci,8ci);2-methacryloyloxymethyl-2-ethyl-1,3-propanediol; trimethylolpropanemonomethacrylate" );
gibbsFormation
{
    dHf_298   -764580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-468560.0
    phase     gas;
}
