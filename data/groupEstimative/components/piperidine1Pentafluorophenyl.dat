/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperidine, 1-pentafluorophenyl-  (C11H10F5N, CAS 15445-66-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperidine1Pentafluorophenyl;
formula     C11H10F5N;
CAS         15445-66-6;
InChIKey    OXZRZCYNYRTPFT-UHFFFAOYSA-N;
MW          251.198;      // g/mol [origin=calculated method=formula-sum]
Tc          716.86;      // K   [origin=predictive method=joback]
Pc          24.219;      // bar [origin=predictive method=joback]
omega       0.7177;      // -   [origin=predictive method=lee-kesler]
Tb          531.60;      // K   [origin=predictive method=joback]
HvapTb      44190.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.18 1.0135 -0.000648 1.538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group AC; count 1; } { group CH2N; count 1; } { group ACF; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group dC_ring; count 6; } { group F; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,3,4,5,6-pentakis(fluoranyl)phenyl]piperidine" "1-(pentafluorophenyl)piperidine" "1-(2,3,4,5,6-pentafluorophenyl)piperidine" );
standardThermochemistry
{
    dHf_298   -923390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-713010.0
}
