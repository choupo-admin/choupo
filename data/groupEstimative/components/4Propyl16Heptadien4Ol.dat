/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-propyl-1,6-heptadien-4-ol  (C10H18O, CAS 52939-61-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Propyl16Heptadien4Ol;
formula     C10H18O;
CAS         52939-61-4;
InChIKey    UPDFVVLBKBYBOG-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          683.39;      // K   [origin=predictive method=joback]
Pc          25.430;      // bar [origin=predictive method=joback]
omega       0.8028;      // -   [origin=predictive method=lee-kesler]
Tb          510.71;      // K   [origin=predictive method=joback]
HvapTb      51897.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.366 1.07362 -0.0007682 2.243e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group CH2=CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-propylhepta-1,6-dien-4-ol" "1,6-heptadien-4-ol, 4-propyl-" "1, 4-propyl-" "agn-pc-00l5i1" "1,6-heptadien-4-ol,4-propyl-" );
standardThermochemistry
{
    dHf_298   -159850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75020.0
}
