/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-erythrose  (C4H8O4, CAS 533-49-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lErythrose;
formula     C4H8O4;
CAS         533-49-3;
InChIKey    YTBSYETUWUMLBZ-DMTCNVIQSA-N;
MW          120.104;      // g/mol [origin=calculated method=formula-sum]
Tc          781.31;      // K   [origin=predictive method=joback]
Pc          65.458;      // bar [origin=predictive method=joback]
omega       2.0107;      // -   [origin=predictive method=lee-kesler]
Tb          615.44;      // K   [origin=predictive method=joback]
HvapTb      80479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.161 0.4721 -0.0002844 6.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group OH; count 3; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 2; } { group OH; count 3; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,3s)-2,3,4-tris(oxidanyl)butanal" "(2s,3s)-2,3,4-trihydroxybutanal" "l(+)-erythrose" "l-(+)-erythrose" "l-erythro-tetrose" "butanal,2,3,4-trihydroxy-, (2s,3s)-" "butanal,2,3,4-trihydroxy-, [s-(r*,r*)]-;erythrose, l- (8ci);(+)-erythrose;l-(+)-erythrose;l-erythrose;" );
gibbsFormation
{
    dHf_298   -678720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-532060.0
    phase     gas;
}
