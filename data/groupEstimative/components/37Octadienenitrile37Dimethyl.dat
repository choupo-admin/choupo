/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-octadienenitrile, 3,7-dimethyl-  (C10H15N, CAS 31945-18-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Octadienenitrile37Dimethyl;
formula     C10H15N;
CAS         31945-18-3;
InChIKey    HXWCEYZTTHUVCC-UHFFFAOYSA-N;
MW          149.237;      // g/mol [origin=calculated method=formula-sum]
Tc          730.95;      // K   [origin=predictive method=joback]
Pc          22.697;      // bar [origin=predictive method=joback]
omega       0.5486;      // -   [origin=predictive method=lee-kesler]
Tb          531.08;      // K   [origin=predictive method=joback]
HvapTb      47780.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.757 0.88844 -0.0006005 1.699e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=C; count 1; } { group CH=C; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group dC; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethylocta-3,7-dienenitrile" );
gibbsFormation
{
    dHf_298   138220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=317460.0
    phase     gas;
}
