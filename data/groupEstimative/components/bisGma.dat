/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis-gma  (C29H36O8, CAS 1565-94-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisGma;
formula     C29H36O8;
CAS         1565-94-2;
InChIKey    AMFGWXWBFGVCKG-UHFFFAOYSA-N;
MW          512.599;      // g/mol [origin=calculated method=formula-sum]
Tc          1579.59;      // K   [origin=predictive method=joback]
Pc          10.535;      // bar [origin=predictive method=joback]
omega       0.7725;      // -   [origin=predictive method=lee-kesler]
Tb          1261.09;      // K   [origin=predictive method=joback]
HvapTb      135764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.514 2.41148 -0.00136032 2.402e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CH2=C; count 2; } { group ACH; count 8; } { group AC; count 4; } { group COO; count 2; } { group C2H4O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group dCH2; count 2; } { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-[4-[2-[4-[3-(2-methylprop-2-enoyloxy)-2-oxidanyl-propoxy]phenyl]propan-2-yl]phenoxy]-2-oxidanyl-propyl] 2-methylprop-2-enoate" "bisphenol a-glycidyl methacrylate" "bisphenol a glycidylmethacrylate" "bisphenol a glycerolate dimethacrylate" "bisphenol(a)glycidylmethacrylate" "bisphenol a-diglycidyl-dimethyl acrylate" "2-propenoic acid, 2-methyl-, (1-methylethylidene)bis(4,1-phenyleneoxy(2-hydroxy-3,1-propanediyl)) ester" "1565-94-2 (parent)" "2,2-bis[4-(2-hydroxy-3-methacryloxypropoxy)phenyl]propane" "silux" "panavia opaque" "(1-methylethylidene)bis(4,1-phenyleneoxy(2-hydroxy-3,1-propanediyl)) bismethacrylate" );
standardThermochemistry
{
    dHf_298   -1183260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1211.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-548980.0
}
