/*--------------------------------*- Choupo -*-----------------------*\
  Component: propargyl acetate  (C5H6O2, CAS 627-09-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propargylAcetate;
formula     C5H6O2;
CAS         627-09-8;
InChIKey    RIZZXCJMFIGMON-UHFFFAOYSA-N;
MW          98.101;      // g/mol [origin=calculated method=formula-sum]
Tc          549.47;      // K   [origin=predictive method=joback]
Pc          41.893;      // bar [origin=predictive method=joback]
omega       0.3300;      // -   [origin=predictive method=lee-kesler]
Tb          362.34;      // K   [origin=predictive method=joback]
HvapTb      33989.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.531 0.33012 -0.00014953 9.59e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3COO; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group tCH; count 1; } { group tC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-ynyl ethanoate" "2-propyn-1-ol, acetate" "3-acetoxypropyne" "2-propynyl acetate" "prop-2-ynyl acetate" "propargyl alcohol acetate" "prop-2-yn-1-yl acetate" "2-propyn-1-ol, 1-acetate" );
gibbsFormation
{
    dHf_298   -171910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     371.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96080.0
    phase     gas;
}
