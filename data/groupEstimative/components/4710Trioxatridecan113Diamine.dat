/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7,10-trioxatridecan-1,13-diamine  (C10H24N2O3, CAS 4246-51-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4710Trioxatridecan113Diamine;
formula     C10H24N2O3;
CAS         4246-51-9;
InChIKey    JCEZOHLWDIONSP-UHFFFAOYSA-N;
MW          220.313;      // g/mol [origin=calculated method=formula-sum]
Tc          822.52;      // K   [origin=predictive method=joback]
Pc          22.355;      // bar [origin=predictive method=joback]
omega       1.0913;      // -   [origin=predictive method=lee-kesler]
Tb          640.72;      // K   [origin=predictive method=joback]
HvapTb      66366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (83.28 0.888 -0.000274 -3.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2O; count 3; } { group CH2NH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group O; count 3; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-[2-(3-azanylpropoxy)ethoxy]ethoxy]propan-1-amine" "4,7,10-trioxa-1,13-tridecanediamine" "diethylene glycol, di(3-aminopropyl) ether" "3,3'-oxybis(ethyleneoxy)bis(propylamine)" "3,3'-((oxybis(ethane-2,1-diyl))bis(oxy))bis(propan-1-amine)" "di(3-aminopropyl) ether of diethylene glycol" "3,3'-(oxybis(2,1-ethanediyloxy))bis-1-propanamine" "1-propanamine, 3,3'-(oxybis(2,1-ethanediyloxy))bis-" "1-propanamine, 3,3'-[oxybis(2,1-ethanediyloxy)]bis-" "3,3'-[oxybis(ethane-2,1-diyloxy)]dipropan-1-amine" "1-propylamine, 3,3'-(oxybis(ethyleneoxy))bis- (6ci,7ci,8ci)" "o,o'-bis(3-aminopropyl)diethylene glycol" );
standardThermochemistry
{
    dHf_298   -578810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     682.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-148780.0
}
