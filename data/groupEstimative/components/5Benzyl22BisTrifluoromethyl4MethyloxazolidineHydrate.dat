/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-benzyl-2,2-bis(trifluoromethyl)-4-methyloxazolidine hydrate  (C13H13F6NO, CAS 101834-51-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Benzyl22BisTrifluoromethyl4MethyloxazolidineHydrate;
formula     C13H13F6NO;
CAS         101834-51-9;
InChIKey    JIYSFOLVTTWLAP-UHFFFAOYSA-N;
MW          313.241;      // g/mol [origin=calculated method=formula-sum]
Tc          795.14;      // K   [origin=predictive method=joback]
Pc          20.812;      // bar [origin=predictive method=joback]
omega       0.6917;      // -   [origin=predictive method=lee-kesler]
Tb          594.56;      // K   [origin=predictive method=joback]
HvapTb      49070.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.589 1.83652 -0.0016313 5.859e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH-O; count 1; } { group CHNH; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group F; count 6; } { group O_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-5-(phenylmethyl)-2,2-bis(trifluoromethyl)-1,3-oxazolidine" "oxazolidine, 5-benzyl-2,2-bis(trifluoromethyl)-4-methyl-, hydrate" "5-benzyl-4-methyl-2,2-bis(trifluoromethyl)-1,3-oxazolidine" );
standardThermochemistry
{
    dHf_298   -1328430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-974960.0
}
