/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl 3,3-dimethylbutyrate  (C13H18O2, CAS 61066-88-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzyl33Dimethylbutyrate;
formula     C13H18O2;
CAS         61066-88-4;
InChIKey    WLTKXQISYPBOSS-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          791.27;      // K   [origin=predictive method=joback]
Pc          22.440;      // bar [origin=predictive method=joback]
omega       0.5834;      // -   [origin=predictive method=lee-kesler]
Tb          578.71;      // K   [origin=predictive method=joback]
HvapTb      52919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.898 1.23096 -0.0007918 1.838e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl) 3,3-dimethylbutanoate" "benzyl 3,3-dimethylbutanoate" "butanoic acid, 3,3-dimethyl-, phenylmethyl ester" "benzyl neocaproate" "3,3-dimethylbutyric acid benzyl ester" );
gibbsFormation
{
    dHf_298   -401150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-136540.0
    phase     gas;
}
