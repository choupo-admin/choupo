/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,5-trimethyl-4-isopropylhexane  (C12H26, CAS 62199-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        235Trimethyl4Isopropylhexane;
formula     C12H26;
CAS         62199-85-3;
InChIKey    VBRDSJSWPGXVIR-UHFFFAOYSA-N;
MW          170.34;      // g/mol [origin=calculated method=formula-sum]
Tc          650.33;      // K   [origin=predictive method=joback]
Pc          18.420;      // bar [origin=predictive method=joback]
omega       0.4363;      // -   [origin=predictive method=lee-kesler]
Tb          471.96;      // K   [origin=predictive method=joback]
HvapTb      40366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.43 1.17344 -0.000645 1.291e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,5-trimethyl-4-propan-2-yl-hexane" "2,3,5-trimethyl-4-propan-2-ylhexane" );
gibbsFormation
{
    dHf_298   -317410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37960.0
    phase     gas;
}
