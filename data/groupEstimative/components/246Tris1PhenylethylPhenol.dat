/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-tris(1-phenylethyl)phenol  (C30H30O, CAS 18254-13-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Tris1PhenylethylPhenol;
formula     C30H30O;
CAS         18254-13-2;
InChIKey    BYLSIPUARIZAHZ-UHFFFAOYSA-N;
MW          406.569;      // g/mol [origin=calculated method=formula-sum]
Tc          1351.55;      // K   [origin=predictive method=joback]
Pc          14.446;      // bar [origin=predictive method=joback]
omega       1.0551;      // -   [origin=predictive method=lee-kesler]
Tb          1081.98;      // K   [origin=predictive method=joback]
HvapTb      104652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-145.37 2.59156 -0.00186488 5.296e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 17; } { group AC; count 3; } { group ACCH; count 3; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 3; } { group dCH_ring; count 17; } { group dC_ring; count 7; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 2,4,6-tris(1-phenylethyl)-" "2,4,6-tris(1-phenylethyl)-phenol" );
standardThermochemistry
{
    dHf_298   67500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     884.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=470160.0
}
