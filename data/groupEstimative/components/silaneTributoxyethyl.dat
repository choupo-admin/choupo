/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, tributoxyethyl-  (C14H32O3Si, CAS 17957-38-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H32O3Si (delta H+3Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneTributoxyethyl;
formula     C14H32O3Si;
CAS         17957-38-9;
InChIKey    ZXRABZPICOUDNJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          276.492;      // g/mol [origin=calculated method=formula-sum]
Tc          748.59;      // K   [origin=predictive method=joback]
Pc          13.944;      // bar [origin=predictive method=joback]
omega       0.7616;      // -   [origin=predictive method=lee-kesler]
Tb          583.25;      // K   [origin=predictive method=joback]
HvapTb      52545.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.78 1.37316 -0.000784 1.715e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group C; count 1; } { group CH2O; count 3; } { group SiH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group C; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2-tributoxyethylsilane" );
gibbsFormation
{
    dHf_298   -681890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     857.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-192780.0
    phase     gas;
}
