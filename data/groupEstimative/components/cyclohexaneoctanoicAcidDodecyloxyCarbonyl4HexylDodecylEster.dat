/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexaneoctanoic acid, ((dodecyloxy)carbonyl)-4-hexyl-, dodecyl ester  (C45H86O4, CAS 72245-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexaneoctanoicAcidDodecyloxyCarbonyl4HexylDodecylEster;
formula     C45H86O4;
CAS         72245-41-1;
InChIKey    JWKMYQVTPMFTTP-KWDKOVGYSA-N;
MW          691.179;      // g/mol [origin=calculated method=formula-sum]
Tc          1983.87;      // K   [origin=predictive method=joback]
Pc          3.443;      // bar [origin=predictive method=joback]
omega       -0.4989;      // -   [origin=predictive method=lee-kesler]
Tb          1355.85;      // K   [origin=predictive method=joback]
HvapTb      130389.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.926 4.23836 -0.0022052 3.633e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 36; } { group CH; count 3; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 34; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecyl (1r,2s,5s)-5-(8-dodecoxy-8-oxidanylidene-octyl)-2-hexyl-cyclohexane-1-carboxylate" "dodecyl (1r,2s,5s)-5-(8-dodecoxy-8-oxooctyl)-2-hexylcyclohexane-1-carboxylate" );
standardThermochemistry
{
    dHf_298   -1593050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1896.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-283690.0
}
