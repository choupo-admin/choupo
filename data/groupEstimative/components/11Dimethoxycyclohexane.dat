/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethoxycyclohexane  (C8H16O2, CAS 933-40-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dimethoxycyclohexane;
formula     C8H16O2;
CAS         933-40-4;
InChIKey    XPIJMQVLTXAGME-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          655.36;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       0.3750;      // -   [origin=predictive method=lee-kesler]
Tb          447.27;      // K   [origin=predictive method=joback]
HvapTb      37500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.98 1.05144 -0.000803 2.82e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane, 1,1-dimethoxy-" "cyclohexanone dimethyl ketal" "cyclohexanone, dimethyl acetal" "cyclohexanone dimethylketal" "cyclohexane, dimethoxy-" "1,1-dimethoxy-cyclohexane" );
gibbsFormation
{
    dHf_298   -403330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-174560.0
    phase     gas;
}
