/*--------------------------------*- Choupo -*-----------------------*\
  Component: doxylamine  (C17H22N2O, CAS 469-21-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        doxylamine;
formula     C17H22N2O;
CAS         469-21-6;
InChIKey    HCFDWZZGGLSKEP-UHFFFAOYSA-N;
MW          270.376;      // g/mol [origin=calculated method=formula-sum]
Tc          964.84;      // K   [origin=predictive method=joback]
Pc          20.908;      // bar [origin=predictive method=joback]
omega       0.7542;      // -   [origin=predictive method=lee-kesler]
Tb          727.25;      // K   [origin=predictive method=joback]
HvapTb      67355.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.978 1.68132 -0.00114606 2.984e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 2; } { group O; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-2-(1-phenyl-1-pyridin-2-yl-ethoxy)ethanamine" "dossilamina" "doxilminio" "doxylaminum" "dossilamina [dcit]" "doxylaminum [inn-latin]" "doxilamina" "doxylamine (inn)" "2-dimethylaminoethoxyphenylmethyl-2-picoline" "doxylamine [inn:ban]" "phenyl-2-pyridylmethyl-beta-n,n-dimethylaminoethyl ether" "n,n-dimethyl-2-(1-phenyl-1-(2-pyridinyl)ethoxy)ethanamine" );
gibbsFormation
{
    dHf_298   38200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     606.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=402750.0
    phase     gas;
}
