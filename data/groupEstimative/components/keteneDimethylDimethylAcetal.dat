/*--------------------------------*- Choupo -*-----------------------*\
  Component: ketene, dimethyl-, dimethyl acetal  (C6H12O2, CAS 5634-54-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        keteneDimethylDimethylAcetal;
formula     C6H12O2;
CAS         5634-54-8;
InChIKey    XRKJKGHUGRBZRE-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          566.64;      // K   [origin=predictive method=joback]
Pc          32.064;      // bar [origin=predictive method=joback]
omega       0.3643;      // -   [origin=predictive method=lee-kesler]
Tb          385.64;      // K   [origin=predictive method=joback]
HvapTb      33888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.87 0.46728 -0.000169 1.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH3O; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethoxy-2-methyl-prop-1-ene" "1,1-dimethoxy-2-methylprop-1-ene" "1-propene, 1,1-dimethoxy-2-methyl-" );
gibbsFormation
{
    dHf_298   -333970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147240.0
    phase     gas;
}
