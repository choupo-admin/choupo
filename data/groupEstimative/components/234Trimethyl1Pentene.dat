/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4-trimethyl-1-pentene  (C8H16, CAS 565-76-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        234Trimethyl1Pentene;
formula     C8H16;
CAS         565-76-4;
InChIKey    FAWUHEYSSPPNSH-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          556.61;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       0.2926;      // -   [origin=predictive method=lee-kesler]
Tb          378.32;      // K   [origin=predictive method=joback]
HvapTb      32036.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.43 0.75558 -0.000443 1.022e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4-trimethylpent-1-ene" "1-pentene, 2,3,4-trimethyl-" "agn-pc-0cpr2x" "pentene, 2,3,4-trimethyl-" );
gibbsFormation
{
    dHf_298   -103370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90890.0
    phase     gas;
}
