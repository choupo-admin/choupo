/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethylethylenediamine  (C6H16N2, CAS 100-36-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethylethylenediamine;
formula     C6H16N2;
CAS         100-36-7;
InChIKey    UDGSVBYJWHOHNN-UHFFFAOYSA-N;
MW          116.208;      // g/mol [origin=calculated method=formula-sum]
Tc          600.16;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.5361;      // -   [origin=predictive method=lee-kesler]
Tb          421.85;      // K   [origin=predictive method=joback]
HvapTb      41634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.766 0.75964 -0.0004586 1.086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2NH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n',n'-diethylethane-1,2-diamine" "(diethylamino)ethylamino" "2-(diethylamino)ethylamine" "ethylenediamine, n,n-diethyl-" "2-aminoethyldiethylamine" "n,n-diethylethanediamine" "1,2-ethanediamine, n,n-diethyl-" "n,n-(diethylethyl)diamine" "usaf am-1" "(2-aminoethyl)diethylamine" "n,n-(diethylamino)ethylamine" "n,n-(diethylethylene)diamine" );
gibbsFormation
{
    dHf_298   -65850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176870.0
    phase     gas;
}
