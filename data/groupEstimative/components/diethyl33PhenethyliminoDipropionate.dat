/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl 3,3'-(phenethylimino)dipropionate  (C18H27NO4, CAS 57958-47-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl33PhenethyliminoDipropionate;
formula     C18H27NO4;
CAS         57958-47-1;
InChIKey    NSGQKWOLICRDEV-UHFFFAOYSA-N;
MW          321.417;      // g/mol [origin=calculated method=formula-sum]
Tc          960.36;      // K   [origin=predictive method=joback]
Pc          14.714;      // bar [origin=predictive method=joback]
omega       1.0436;      // -   [origin=predictive method=lee-kesler]
Tb          767.00;      // K   [origin=predictive method=joback]
HvapTb      74795.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.252 1.64924 -0.00091 1.517e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-[(3-ethoxy-3-oxidanylidene-propyl)-(2-phenylethyl)amino]propanoate" "ethyl 3-[(3-ethoxy-3-oxopropyl)-phenethylamino]propanoate" "diethyl 3,3 inverted exclamation marka-(phenethylimino)dipropionate" "b-alanine,n-(3-ethoxy-3-oxopropyl)-n-(2-phenylethyl)-, ethyl ester" "propionicacid, 3,3'-(phenethylimino)di-, diethyl ester (6ci); diethyl3,3'-(phenethylimino)dipropionate" );
standardThermochemistry
{
    dHf_298   -745350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     869.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-296870.0
}
