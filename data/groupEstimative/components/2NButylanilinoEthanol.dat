/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(n-butylanilino)ethanol  (C12H19NO, CAS 3046-94-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2NButylanilinoEthanol;
formula     C12H19NO;
CAS         3046-94-4;
InChIKey    PMRRSCWLXKOMSK-UHFFFAOYSA-N;
MW          193.29;      // g/mol [origin=calculated method=formula-sum]
Tc          791.45;      // K   [origin=predictive method=joback]
Pc          26.325;      // bar [origin=predictive method=joback]
omega       1.0231;      // -   [origin=predictive method=lee-kesler]
Tb          605.46;      // K   [origin=predictive method=joback]
HvapTb      63304.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.325 1.22282 -0.0008032 2.043e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[butyl(phenyl)amino]ethanol" "ethanol, 2-(butylphenylamino)-" "2-(butyl(phenyl)amino)ethanol" "ethanol,2-(butylphenylamino)-" "ethanol, 2-(n-butylanilino)-" "ethanol,2-(n-butylanilino)- (6ci,7ci,8ci);2-(n-butylanilino)ethanol;n-butyl-n-(2-hydroxyethyl)aniline;n-hydroxyethyl-n-butylaniline;" );
standardThermochemistry
{
    dHf_298   -139180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136530.0
}
