/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl bis(4-hydroxyphenyl)acetate  (C18H20O4, CAS 71077-33-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylBis4HydroxyphenylAcetate;
formula     C18H20O4;
CAS         71077-33-3;
InChIKey    RFAHZZDUNWEBLG-UHFFFAOYSA-N;
MW          300.354;      // g/mol [origin=calculated method=formula-sum]
Tc          1124.90;      // K   [origin=predictive method=joback]
Pc          25.689;      // bar [origin=predictive method=joback]
omega       1.2850;      // -   [origin=predictive method=lee-kesler]
Tb          883.82;      // K   [origin=predictive method=joback]
HvapTb      93261.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.397 1.81632 -0.00143912 4.626e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 1; } { group ACOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 2,2-bis(4-hydroxyphenyl)ethanoate" "butyl 2,2-bis(4-hydroxyphenyl)acetate" "benzeneacetic acid,4-hydroxy-a-(4-hydroxyphenyl)-, butyl ester" "benzeneacetic acid, 4-hydroxy-alpha-(4-hydroxyphenyl)-, butyl ester" "butylbis(4-hydroxyphenyl)acetate;butyl bis(p-hydroxyphenyl)acetate;" "benzeneacetic acid, 4-hydroxy-.alpha.-(4-hydroxyphenyl)-, butyl ester" );
standardThermochemistry
{
    dHf_298   -618970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     739.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-296550.0
}
