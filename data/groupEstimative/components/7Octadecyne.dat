/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-octadecyne  (C18H34, CAS 64183-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Octadecyne;
formula     C18H34;
CAS         64183-49-9;
InChIKey    JNRZVQIBDMWBHF-UHFFFAOYSA-N;
MW          250.47;      // g/mol [origin=calculated method=formula-sum]
Tc          793.08;      // K   [origin=predictive method=joback]
Pc          12.884;      // bar [origin=predictive method=joback]
omega       0.7408;      // -   [origin=predictive method=lee-kesler]
Tb          620.44;      // K   [origin=predictive method=joback]
HvapTb      57814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.084 1.56404 -0.00086326 1.8198e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadec-7-yne" "agn-pc-00njy3" );
gibbsFormation
{
    dHf_298   -142550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     828.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=303480.0
    phase     gas;
}
