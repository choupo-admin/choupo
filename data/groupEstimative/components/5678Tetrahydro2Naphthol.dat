/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,6,7,8-tetrahydro-2-naphthol  (C10H12O, CAS 1125-78-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5678Tetrahydro2Naphthol;
formula     C10H12O;
CAS         1125-78-6;
InChIKey    UMKXSOXZAXIOPJ-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          802.13;      // K   [origin=predictive method=joback]
Pc          42.999;      // bar [origin=predictive method=joback]
omega       0.5761;      // -   [origin=predictive method=lee-kesler]
Tb          556.36;      // K   [origin=predictive method=joback]
HvapTb      54200.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.03 1.1378 -0.00096992 3.391e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 3; } { group ACCH2; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,6,7,8-tetrahydronaphthalen-2-ol" "6-tetralinol" "6-hydroxytetralin" "2-naphthalenol, 5,6,7,8-tetrahydro-" "ac-beta-tetralol" "2-naphthol, 5,6,7,8-tetrahydro-" "5,6,7,8-tetrahydro-beta-naphthol" "5,6,7,8-tetrahydro-2-hydroxynaphthalene" "5,6,7,8-tetrahydro-2-napthol" "tetrahydro-.beta.-naphthol" "5,7,8-tetrahydro-2-naphthol" "2-naphthol,6,7,8-tetrahydro-" );
gibbsFormation
{
    dHf_298   -115000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37840.0
    phase     gas;
}
