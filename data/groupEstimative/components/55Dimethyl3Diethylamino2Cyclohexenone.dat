/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-3-(diethylamino)-2-cyclohexenone  (C12H21NO, CAS 65115-73-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl3Diethylamino2Cyclohexenone;
formula     C12H21NO;
CAS         65115-73-3;
InChIKey    RLYBIMBNGUMPMK-UHFFFAOYSA-N;
MW          195.306;      // g/mol [origin=calculated method=formula-sum]
Tc          793.33;      // K   [origin=predictive method=joback]
Pc          23.428;      // bar [origin=predictive method=joback]
omega       0.5855;      // -   [origin=predictive method=lee-kesler]
Tb          578.35;      // K   [origin=predictive method=joback]
HvapTb      48828.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.798 1.39798 -0.00103144 3.429e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(diethylamino)-5,5-dimethyl-cyclohex-2-en-1-one" "5,5-dimethyl-3-(diethylamino)-cyclohex-2-en-1-one" "5,5-dimethyl-3-(diethylamino)cyclohex-2-enone" "3-(diethylamino)-5,5-dimethylcyclohex-2-en-1-one" "5,5-dimethyl-3-(diethylamino)cyclohex-2-en-1-one" "2-cyclohexen-1-one,3-(diethylamino)-5,5-dimethyl-" );
gibbsFormation
{
    dHf_298   -245310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77640.0
    phase     gas;
}
