/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2734908  (C15H24ClNO, CAS 40136-65-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2734908;
formula     C15H24ClNO;
CAS         40136-65-0;
InChIKey    LUVNMPBZTZUIHH-UHFFFAOYSA-N;
MW          269.813;      // g/mol [origin=calculated method=formula-sum]
Tc          848.76;      // K   [origin=predictive method=joback]
Pc          17.289;      // bar [origin=predictive method=joback]
omega       0.7783;      // -   [origin=predictive method=lee-kesler]
Tb          651.29;      // K   [origin=predictive method=joback]
HvapTb      61034.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.964 1.30438 -0.00071452 1.341e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(5-chloranyl-2-ethoxy-phenyl)-n,n-dimethyl-pentan-1-amine" "5-chloro-n,n-dimethyl-2-ethoxy-beta-propylphenethylamine" "phenethylamine, 5-chloro-n,n-dimethyl-2-ethoxy-beta-propyl-" "2-(5-chloro-2-ethoxyphenyl)-n,n-dimethyl-1-pentanamine" );
gibbsFormation
{
    dHf_298   -225050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     672.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=159980.0
    phase     gas;
}
