/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-ethylisopropylamine  (C5H13N, CAS 19961-27-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nEthylisopropylamine;
formula     C5H13N;
CAS         19961-27-4;
InChIKey    RIVIDPPYRINTTH-UHFFFAOYSA-N;
MW          87.166;      // g/mol [origin=calculated method=formula-sum]
Tc          538.16;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.3736;      // -   [origin=predictive method=lee-kesler]
Tb          363.73;      // K   [origin=predictive method=joback]
HvapTb      32772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.549 0.56096 -0.0003 5.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethylpropan-2-amine" "ethylisopropylamine" "2-propanamine, n-ethyl-" "diethylamine, 1-methyl-" "isopropylamine, n-ethyl-" "isopropylethylamine" "ethyl isopropylamine" "1-methyldiethylamine" "ethyl(propan-2-yl)amine" "n-ethyl-n-isopropylamine" "rividppyrintth-uhfffaoysa-" "diethylamine, 1-methyl- (8ci)" );
gibbsFormation
{
    dHf_298   -98340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78170.0
    phase     gas;
}
