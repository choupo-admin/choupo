/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraethylene glycol dimethacrylate  (C16H26O7, CAS 109-17-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraethyleneGlycolDimethacrylate;
formula     C16H26O7;
CAS         109-17-1;
InChIKey    LTHJXDSHSVNJKG-UHFFFAOYSA-N;
MW          330.377;      // g/mol [origin=calculated method=formula-sum]
Tc          922.82;      // K   [origin=predictive method=joback]
Pc          13.707;      // bar [origin=predictive method=joback]
omega       1.0690;      // -   [origin=predictive method=lee-kesler]
Tb          742.50;      // K   [origin=predictive method=joback]
HvapTb      72074.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (110.298 1.18444 -0.0003748 -6.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH2=C; count 2; } { group CH2O; count 3; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH2; count 2; } { group dC; count 2; } { group O; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-(2-methylprop-2-enoyloxy)ethoxy]ethoxy]ethoxy]ethyl 2-methylprop-2-enoate" "te egdma" "tetraethyleneglycol dimethacrylate" "tetraethylene glycol, dimethacrylate" "methacrylic acid, diester with tetraethylene glycol" "tgm 4" "methacrylic acid, oxybis(ethyleneoxyethylene) ester" "3,6,9-trioxaundecamethylene dimethacrylate" "2-propenoic acid, 2-methyl-, oxybis(2,1-ethanediyloxy-2,1-ethanediyl) ester" "2-propenoic acid, 2-methyl-, 3,6,9-trioxaundecane-1,11-diyl ester" "((oxybis(ethane-2,1-diyl))bis(oxy))bis(ethane-2,1-diyl) bis(2-methylacrylate)" "2-propenoic acid, 2-methyl-, 1,1'-(oxybis(2,1-ethanediyloxy-2,1-ethanediyl)) ester" );
gibbsFormation
{
    dHf_298   -1173510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     898.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-693320.0
    phase     gas;
}
