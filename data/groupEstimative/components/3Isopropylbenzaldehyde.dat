/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-isopropylbenzaldehyde  (C10H12O, CAS 34246-57-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H12O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Isopropylbenzaldehyde;
formula     C10H12O;
CAS         34246-57-6;
InChIKey    FFQXEFNKZVGJDI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          645.93;      // K   [origin=predictive method=joback]
Pc          30.524;      // bar [origin=predictive method=joback]
omega       0.3107;      // -   [origin=predictive method=lee-kesler]
Tb          436.04;      // K   [origin=predictive method=joback]
HvapTb      38031.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.99 0.82944 -0.00064056 2.046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-propan-2-ylbenzaldehyde" "benzaldehyde,3-(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   46500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=177620.0
    phase     gas;
}
