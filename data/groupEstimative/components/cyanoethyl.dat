/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyanoethyl  (C3H4N, CAS 3264-99-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        cyanoethyl;
formula     C3H4N;
CAS         3264-99-1;
InChIKey    VQGISNOMGHCEPX-UHFFFAOYSA-N;
role        radical;
MW          54.072;      // g/mol [origin=calculated method=formula-sum]
Tc          571.12;      // K   [origin=predictive method=joback]
Pc          44.150;      // bar [origin=predictive method=joback]
omega       0.3041;      // -   [origin=predictive method=lee-kesler]
Tb          372.40;      // K   [origin=predictive method=joback]
HvapTb      32729.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.07 0.23362 -0.0001503 4.19e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propanenitrile" "1-cyanoethyl" );
standardThermochemistry
{
    dHf_298   118240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     275.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147670.0
}
