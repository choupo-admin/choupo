/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-iodoisophthalic acid  (C8H5IO4, CAS 51839-16-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5IodoisophthalicAcid;
formula     C8H5IO4;
CAS         51839-16-8;
InChIKey    QMDFYAWUWIIQFM-UHFFFAOYSA-N;
MW          292.024;      // g/mol [origin=calculated method=formula-sum]
Tc          1065.14;      // K   [origin=predictive method=joback]
Pc          42.775;      // bar [origin=predictive method=joback]
omega       1.1893;      // -   [origin=predictive method=lee-kesler]
Tb          803.44;      // K   [origin=predictive method=joback]
HvapTb      80703.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.2 0.7065 -0.00053512 1.556e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group COOH; count 2; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group I; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-iodanylbenzene-1,3-dicarboxylic acid" "1,3-benzenedicarboxylic acid, 5-iodo-" "5-iodoisophthalicacid" "qmdfyawuwiiqfm-uhfffaoysa-" "5-iodobenzene-1,3-dicarboxylic acid" "1,3-benzenedicarboxylicacid, 5-iodo-" );
gibbsFormation
{
    dHf_298   -618530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-520070.0
    phase     gas;
}
