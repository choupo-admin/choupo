/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-indanol  (C9H10O, CAS 1641-41-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Indanol;
formula     C9H10O;
CAS         1641-41-4;
InChIKey    DPHNJPUOMLRELT-UHFFFAOYSA-N;
MW          134.178;      // g/mol [origin=calculated method=formula-sum]
Tc          770.90;      // K   [origin=predictive method=joback]
Pc          47.301;      // bar [origin=predictive method=joback]
omega       0.5599;      // -   [origin=predictive method=lee-kesler]
Tb          529.21;      // K   [origin=predictive method=joback]
HvapTb      51802.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.0 1.0524 -0.00096192 3.571e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group ACCH2; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydro-1h-inden-4-ol" "indan-4-ol" "1h-inden-4-ol,2,3-dihydro-" "1h-inden-4-ol, 2,3-dihydro-" "1h-inden-4-ol, 2,3-dihydro- (9ci)" "indan-4-ol; 4-hydroxyindane; 2,3-dihydro-1hinden-4-ol; 1hinden-4-ol,2,3-dihydro-" );
gibbsFormation
{
    dHf_298   -88200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41520.0
    phase     gas;
}
