/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, isodecyl ester, polymer with methyl 2-methyl-2-propenoate  (C19H34O4, CAS 70632-13-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2MethylIsodecylEsterPolymerWithMethyl2Methyl2P;
formula     C19H34O4;
CAS         70632-13-2;
InChIKey    FZLZYZGFUZFHSN-UHFFFAOYSA-N;
MW          326.477;      // g/mol [origin=calculated method=formula-sum]
Tc          928.56;      // K   [origin=predictive method=joback]
Pc          10.979;      // bar [origin=predictive method=joback]
omega       0.8523;      // -   [origin=predictive method=lee-kesler]
Tb          744.84;      // K   [origin=predictive method=joback]
HvapTb      71428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (70.207 1.4588 -0.0004594 -7.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 7; } { group CH; count 1; } { group CH2=C; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 7; } { group CH; count 1; } { group dCH2; count 2; } { group dC; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-methylprop-2-enoate;8-methylnonyl 2-methylprop-2-enoate" "methyl methacrylate, isodecyl methacrylate polymer" );
gibbsFormation
{
    dHf_298   -955670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1079.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-460260.0
    phase     gas;
}
