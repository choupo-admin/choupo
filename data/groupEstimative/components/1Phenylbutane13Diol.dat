/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylbutane-1,3-diol  (C10H14O2, CAS 118100-60-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenylbutane13Diol;
formula     C10H14O2;
CAS         118100-60-0;
InChIKey    QTYZWFQTOYXFBL-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          827.85;      // K   [origin=predictive method=joback]
Pc          36.865;      // bar [origin=predictive method=joback]
omega       1.3282;      // -   [origin=predictive method=lee-kesler]
Tb          638.56;      // K   [origin=predictive method=joback]
HvapTb      72712.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.889 0.95472 -0.0006186 1.519e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-butanediol, 1-phenyl-, (1r,3r)-" "1,3-butanediol, 1-phenyl-" );
standardThermochemistry
{
    dHf_298   -328220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-132790.0
}
