/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3,3-tetramethoxycyclobutane  (C8H16O4, CAS 152897-19-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1133Tetramethoxycyclobutane;
formula     C8H16O4;
CAS         152897-19-3;
InChIKey    JZVULSQIDDDMGK-UHFFFAOYSA-N;
MW          176.212;      // g/mol [origin=calculated method=formula-sum]
Tc          677.16;      // K   [origin=predictive method=joback]
Pc          29.473;      // bar [origin=predictive method=joback]
omega       0.5210;      // -   [origin=predictive method=lee-kesler]
Tb          479.14;      // K   [origin=predictive method=joback]
HvapTb      40516.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.79 1.20968 -0.001151 5.02e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 2; } { group CH3O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobutane,1,1,3,3-tetramethoxy-" "1,3-cyclobutanedione bis(dimethyl acetal)" "1,1,3,3-tetramethoxycyclobutane;1,3-cyclobutanedione bis(dimethyl acetal);1,1,3,3-tetramethoxycyclobutane 98.5+%;" );
standardThermochemistry
{
    dHf_298   -660550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-373560.0
}
