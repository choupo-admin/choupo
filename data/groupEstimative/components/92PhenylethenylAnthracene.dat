/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-(2-phenylethenyl)anthracene  (C22H16, CAS 1895-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        92PhenylethenylAnthracene;
formula     C22H16;
CAS         1895-98-3;
InChIKey    HCSGQHDONHRJCM-UHFFFAOYSA-N;
MW          280.37;      // g/mol [origin=calculated method=formula-sum]
Tc          1076.12;      // K   [origin=predictive method=joback]
Pc          21.513;      // bar [origin=predictive method=joback]
omega       0.7454;      // -   [origin=predictive method=lee-kesler]
Tb          808.40;      // K   [origin=predictive method=joback]
HvapTb      73680.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.39 1.8296 -0.00145856 4.614e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 14; } { group AC; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 14; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "anthracene,9-(2-phenylethenyl)-" "anthracene,9-styryl- (6ci,7ci,8ci);9-(2-phenylethenyl)anthracene;9-styrylanthracene;" );
standardThermochemistry
{
    dHf_298   452070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=633440.0
}
