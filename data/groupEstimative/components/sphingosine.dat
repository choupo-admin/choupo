/*--------------------------------*- Choupo -*-----------------------*\
  Component: sphingosine  (C18H37NO2, CAS 123-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sphingosine;
formula     C18H37NO2;
CAS         123-78-4;
InChIKey    WWUZIQQURGPMPG-KRWOKUGFSA-N;
MW          299.499;      // g/mol [origin=calculated method=formula-sum]
Tc          1067.19;      // K   [origin=predictive method=joback]
Pc          14.381;      // bar [origin=predictive method=joback]
omega       1.2979;      // -   [origin=predictive method=lee-kesler]
Tb          871.61;      // K   [origin=predictive method=joback]
HvapTb      98843.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.947 1.87552 -0.0011498 2.8e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 2; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 2; } { group dCH; count 2; } { group OH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e,2s,3r)-2-azanyloctadec-4-ene-1,3-diol" "4-sphingenine" "d-erythro-sphingosine" "d-sphingosine" "sphing-4-enine" "cerebroside" "sphingenine" "sphingoid" "trans-d-erythro-2-amino-4-octadecene-1,3-diol" "erythrosphingosine" "(4e)-sphingenine" "4-trans-sphingenine" );
standardThermochemistry
{
    dHf_298   -578860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     984.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31170.0
}
