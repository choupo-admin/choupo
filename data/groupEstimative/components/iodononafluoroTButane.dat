/*--------------------------------*- Choupo -*-----------------------*\
  Component: iodononafluoro-t-butane  (C4F9I, CAS 4459-18-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iodononafluoroTButane;
formula     C4F9I;
CAS         4459-18-1;
InChIKey    WIKBZUXHNPONPP-UHFFFAOYSA-N;
MW          345.926;      // g/mol [origin=calculated method=formula-sum]
Tc          524.84;      // K   [origin=predictive method=joback]
Pc          26.218;      // bar [origin=predictive method=joback]
omega       0.3784;      // -   [origin=predictive method=lee-kesler]
Tb          364.77;      // K   [origin=predictive method=joback]
HvapTb      21334.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.13 1.0322 -0.00111 4.143e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group I; count 1; } { group CF3; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 4; } { group F; count 9; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,3,3,3-hexakis(fluoranyl)-2-iodanyl-2-(trifluoromethyl)propane" "1,1,1,3,3,3-hexafluoro-2-iodo-2-(trifluoromethyl)propane" "iodoperfluoro-tert-butane" "nonafluoro-tert-butyl iodide" "perfluoro(2-iodo-2-methylpropane)" );
standardThermochemistry
{
    dHf_298   -1849010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1701010.0
}
