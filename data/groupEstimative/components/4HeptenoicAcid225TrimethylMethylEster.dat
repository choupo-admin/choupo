/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-heptenoic acid, 2,2,5-trimethyl-, methyl ester  (C11H20O2, CAS 68891-90-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HeptenoicAcid225TrimethylMethylEster;
formula     C11H20O2;
CAS         68891-90-7;
InChIKey    KKMHPBMLAANVOR-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          699.15;      // K   [origin=predictive method=joback]
Pc          20.793;      // bar [origin=predictive method=joback]
omega       0.5314;      // -   [origin=predictive method=lee-kesler]
Tb          510.31;      // K   [origin=predictive method=joback]
HvapTb      46229.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.048 1.1398 -0.0007379 1.837e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,2,5-trimethylhept-4-enoate" );
gibbsFormation
{
    dHf_298   -488970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-194120.0
    phase     gas;
}
