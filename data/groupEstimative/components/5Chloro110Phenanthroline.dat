/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-chloro-1,10-phenanthroline  (C12H7ClN2, CAS 4199-89-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Chloro110Phenanthroline;
formula     C12H7ClN2;
CAS         4199-89-7;
InChIKey    XDUUQOQFSWSZSM-UHFFFAOYSA-N;
MW          214.652;      // g/mol [origin=calculated method=formula-sum]
Tc          976.25;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.6657;      // -   [origin=predictive method=lee-kesler]
Tb          693.59;      // K   [origin=predictive method=joback]
HvapTb      65991.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.2 1.01282 -0.00083848 2.821e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group C5H3N; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 7; } { group dC_ring; count 5; } { group Cl; count 1; } { group Nd_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-chloranyl-1,10-phenanthroline" "1,10-phenanthroline, 5-chloro-" "5-chloropyridino[3,2-h]quinoline" "1,10-phenanthroline,5-chloro-" "5-chloro-[1,10]phenanthroline" "5-chloro-1, 10-phenanthroline" );
gibbsFormation
{
    dHf_298   354560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     345.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=498780.0
    phase     gas;
}
