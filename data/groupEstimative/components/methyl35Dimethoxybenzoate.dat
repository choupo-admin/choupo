/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3,5-dimethoxybenzoate  (C10H12O4, CAS 2150-37-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl35Dimethoxybenzoate;
formula     C10H12O4;
CAS         2150-37-0;
InChIKey    YXUIOVUOFQKWDM-UHFFFAOYSA-N;
MW          196.202;      // g/mol [origin=calculated method=formula-sum]
Tc          775.96;      // K   [origin=predictive method=joback]
Pc          27.527;      // bar [origin=predictive method=joback]
omega       0.6971;      // -   [origin=predictive method=lee-kesler]
Tb          568.10;      // K   [origin=predictive method=joback]
HvapTb      53681.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.9 0.57476 -0.00010072 -8.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-dimethoxybenzoic acid methyl ester" "benzoic acid, 3,5-dimethoxy-, methyl ester" "benzoic acid,5-dimethoxy-, methyl ester" "p762" );
gibbsFormation
{
    dHf_298   -617860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-393900.0
    phase     gas;
}
