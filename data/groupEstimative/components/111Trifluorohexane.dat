/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1-trifluorohexane  (C6H11F3, CAS 17337-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Trifluorohexane;
formula     C6H11F3;
CAS         17337-12-1;
InChIKey    XRKOOHTZZDPJNE-UHFFFAOYSA-N;
MW          140.148;      // g/mol [origin=calculated method=formula-sum]
Tc          478.75;      // K   [origin=predictive method=joback]
Pc          27.412;      // bar [origin=predictive method=joback]
omega       0.3790;      // -   [origin=predictive method=lee-kesler]
Tb          331.46;      // K   [origin=predictive method=joback]
HvapTb      25203.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.766 0.73502 -0.0005236 1.489e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(fluoranyl)hexane" "hexane, 1,1,1-trifluoro-" );
gibbsFormation
{
    dHf_298   -764250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-581950.0
    phase     gas;
}
