/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-shisool  (C10H18O, CAS 22451-48-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        transShisool;
formula     C10H18O;
CAS         22451-48-5;
InChIKey    GMYHXOPIKMGWOM-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          724.96;      // K   [origin=predictive method=joback]
Pc          28.689;      // bar [origin=predictive method=joback]
omega       0.7353;      // -   [origin=predictive method=lee-kesler]
Tb          532.02;      // K   [origin=predictive method=joback]
HvapTb      54063.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.259 1.06332 -0.0006014 1.182e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 2; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-prop-1-en-2-ylcyclohexyl)methanol" "(4-isopropenylcyclohexyl)methanol" "cyclohexanemethanol, 4-(1-methylethenyl)-, cis-" "cyclohexanemethanol, 4-(1-methylethenyl)-, trans-" );
standardThermochemistry
{
    dHf_298   -252340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-7470.0
}
