/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-tris(2-cyanoethoxy)propane  (C12H17N3O3, CAS 2465-93-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Tris2CyanoethoxyPropane;
formula     C12H17N3O3;
CAS         2465-93-2;
InChIKey    ALGVJKNIAOBBBJ-UHFFFAOYSA-N;
MW          251.286;      // g/mol [origin=calculated method=formula-sum]
Tc          1054.52;      // K   [origin=predictive method=joback]
Pc          16.155;      // bar [origin=predictive method=joback]
omega       1.1883;      // -   [origin=predictive method=lee-kesler]
Tb          847.22;      // K   [origin=predictive method=joback]
HvapTb      80582.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (117.798 0.7645 -0.0002062 -5.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2O; count 3; } { group CH2CN; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group CH; count 1; } { group O; count 3; } { group CN; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2,3-bis(2-cyanoethoxy)propoxy]propanenitrile" "propanenitrile, 3,3',3''-(1,2,3-propanetriyltris(oxy))tris-" "propanenitrile, 3,3',3''-[1,2,3-propanetriyltris(oxy)]tris-" "tris(beta-cyanoethoxy)propane" "tris(.beta.-cyanoethoxy)propane" "1,3-tris(2-cyanoethoxy)propane" "glycerol tris(2-cyanoethyl) ether" "1,2,3-tris(2'-cyanoethoxy)propane" "1,2,3-tris(beta-cyanoethoxy)propane" "1,3-tris(.beta.-cyanoethoxy)propane" "1,2,3-tris-(2-cyanoethoxy)-propane" "3,3',3''-propane-1,2,3-triyltrioxytripropiononitrile" );
gibbsFormation
{
    dHf_298   -198310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     666.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132260.0
    phase     gas;
}
