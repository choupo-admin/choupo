/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-carbomethoxyadamantane  (C12H18O2, CAS 711-01-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Carbomethoxyadamantane;
formula     C12H18O2;
CAS         711-01-3;
InChIKey    CLYOOVNORYNXMD-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          772.94;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.5304;      // -   [origin=predictive method=lee-kesler]
Tb          552.44;      // K   [origin=predictive method=joback]
HvapTb      48164.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-182.51 1.79752 -0.0016258 6.123e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl adamantane-1-carboxylate" "methyl 1-adamantanecarboxylate" "adamantane-1-carboxylic acid methyl ester" "1-adamantanecarboxylic acid methyl ester" "1-adamantanecarboxylic acid, methyl ester" "methyl 1-adamantylformate" "methyl adamantanecarboxylate" "ambap711-01-3" "methyl 1-adamantylcarboxylate" "1-(methoxycarbonyl)adamantane" "1-adamantyl carboxylic acid methyl ester" "adamantan-1-carboxylic acid, methyl ester" );
standardThermochemistry
{
    dHf_298   -401150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-103260.0
}
