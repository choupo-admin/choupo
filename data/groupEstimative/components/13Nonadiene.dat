/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-nonadiene  (C9H16, CAS 56700-77-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Nonadiene;
formula     C9H16;
CAS         56700-77-7;
InChIKey    CLNYHERYALISIR-FNORWQNLSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          581.10;      // K   [origin=predictive method=joback]
Pc          25.303;      // bar [origin=predictive method=joback]
omega       0.3926;      // -   [origin=predictive method=lee-kesler]
Tb          406.36;      // K   [origin=predictive method=joback]
HvapTb      34916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.466 0.85882 -0.0005725 1.607e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2=CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e)-nona-1,3-diene" "1,3-nonadiene, (e)-" "1,cis-3-nonadiene" "(e)-n-c5h11ch=chch=ch2" );
standardThermochemistry
{
    dHf_298   13560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192960.0
}
