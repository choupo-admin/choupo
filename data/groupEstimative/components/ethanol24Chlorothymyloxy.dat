/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanol, 2-(4-chlorothymyloxy)-  (C12H17ClO2, CAS 55129-22-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanol24Chlorothymyloxy;
formula     C12H17ClO2;
CAS         55129-22-1;
InChIKey    RBNBSCVJAOXORO-UHFFFAOYSA-N;
MW          228.716;      // g/mol [origin=calculated method=formula-sum]
Tc          864.15;      // K   [origin=predictive method=joback]
Pc          24.076;      // bar [origin=predictive method=joback]
omega       1.0554;      // -   [origin=predictive method=lee-kesler]
Tb          667.37;      // K   [origin=predictive method=joback]
HvapTb      69654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.972 0.86996 -0.00040208 4.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH; count 1; } { group ACCl; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chloranyl-5-methyl-2-propan-2-yl-phenoxy)ethanol" "ethanol, 2-(4-chlorothymyloxy)-," "2-(4-chloro-5-methyl-2-propan-2-ylphenoxy)ethanol" "2-[4-chloro-5-methyl-2-(propan-2-yl)phenoxy]ethanol" );
gibbsFormation
{
    dHf_298   -394360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122510.0
    phase     gas;
}
