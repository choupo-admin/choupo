/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-03vchr  (C24H43Cl7, CAS 108171-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc03vchr;
formula     C24H43Cl7;
CAS         108171-27-3;
InChIKey    FHKUUILMHIOLID-UHFFFAOYSA-N;
MW          579.758;      // g/mol [origin=calculated method=formula-sum]
Tc          1235.11;      // K   [origin=predictive method=joback]
Pc          7.176;      // bar [origin=predictive method=joback]
omega       0.6589;      // -   [origin=predictive method=lee-kesler]
Tb          1008.09;      // K   [origin=predictive method=joback]
HvapTb      97385.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.217 2.36682 -0.0014438 3.344e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH2Cl; count 1; } { group CHCl; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group CH; count 6; } { group Cl; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,7,11,15,19,23-heptakis(chloranyl)tetracosane" "chlorinated paraffins: c23, 43% chlorine" "1,3,7,11,15,19,23-heptachlorotetracosane" );
standardThermochemistry
{
    dHf_298   -680550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1267.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53050.0
}
