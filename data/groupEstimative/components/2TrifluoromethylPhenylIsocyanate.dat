/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(trifluoromethyl)phenyl isocyanate  (C8H4F3NO, CAS 2285-12-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TrifluoromethylPhenylIsocyanate;
formula     C8H4F3NO;
CAS         2285-12-3;
InChIKey    GZWGTVZRRFPVAS-UHFFFAOYSA-N;
MW          187.12;      // g/mol [origin=calculated method=formula-sum]
Tc          677.34;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.5435;      // -   [origin=predictive method=lee-kesler]
Tb          475.55;      // K   [origin=predictive method=joback]
HvapTb      42125.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group C; count 1; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-2-(trifluoromethyl)benzene" "alpha,alpha,alpha-trifluoro-o-tolyl isocyanate" "benzene, 1-isocyanato-2-(trifluoromethyl)-" "o-trifluoromethylphenylisocyanate" "2-(trifluoromethyl)benzenisocyanate" "isocyanic acid, (alpha,alpha,alpha-trifluoro-o-tolyl) ester" "isocyanic acid, .alpha.,.alpha.,.alpha.-trifluoro-o-tolyl ester" "2-(isocyanato)benzotrifluoride" "a," "a," "a-trifluoro-o-tolyl isocyanate" "2-trifluoro methyl phenyl isocyanate" "isocyanic acid 2-(trifluoromethyl)phenyl ester" "2-trifluoromethylphenylaisocyanate;isocyanic acid, alpha,alpha,alpha-trifluoro-o-tolyl ester;" );
