/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-thiopheneacetic acid  (C6H6O2S, CAS 6964-21-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ThiopheneaceticAcid;
formula     C6H6O2S;
CAS         6964-21-2;
InChIKey    RCNOGGGBSSVMAS-UHFFFAOYSA-N;
MW          142.172;      // g/mol [origin=calculated method=formula-sum]
Tc          792.17;      // K   [origin=predictive method=joback]
Pc          48.158;      // bar [origin=predictive method=joback]
omega       0.6657;      // -   [origin=predictive method=lee-kesler]
Tb          553.47;      // K   [origin=predictive method=joback]
HvapTb      53738.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.709 0.62571 -0.00048422 1.482e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group COOH; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group COOH; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-thiophen-3-ylethanoic acid" "3-thienylacetic acid" "thiophene-3-acetic acid" "thien-3-ylacetic acid" "thiophen-3-yl-acetic acid" "2-(thiophen-3-yl)acetic acid" "3-thiopheneethanoic acid" "thiophen-3-ylacetic acid" "3-(carboxymethyl)thiophene" "2-(3-thienyl)acetic acid" "2-thiophen-3-ylacetic acid" "3-thiopheneacetic" );
gibbsFormation
{
    dHf_298   -287270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209860.0
    phase     gas;
}
