/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-aminopropan-2-ol; 16-methylheptadecanoic acid  (C21H45NO3, CAS 55738-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Aminopropan2Ol16MethylheptadecanoicAcid;
formula     C21H45NO3;
CAS         55738-53-9;
InChIKey    SYBPBPOAZUOLID-UHFFFAOYSA-N;
MW          359.595;      // g/mol [origin=calculated method=formula-sum]
Tc          1217.32;      // K   [origin=predictive method=joback]
Pc          10.624;      // bar [origin=predictive method=joback]
omega       0.9821;      // -   [origin=predictive method=lee-kesler]
Tb          990.82;      // K   [origin=predictive method=joback]
HvapTb      106342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.635 1.95116 -0.0008566 6.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 14; } { group CH; count 2; } { group OH; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 15; } { group CH; count 2; } { group OH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azanylpropan-2-ol;16-methylheptadecanoic acid" "16-methylheptadecanoic acid - 1-aminopropan-2-ol (1:1)" "isooctadecanoic acid, compound with 1-aminopropan-2-ol (1:1)" );
gibbsFormation
{
    dHf_298   -1067660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1218.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-397980.0
    phase     gas;
}
