/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butene-1,4-diamine, n1,n4-dimethyl-  (C6H14N2, CAS 111-72-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butene14DiamineN1N4Dimethyl;
formula     C6H14N2;
CAS         111-72-8;
InChIKey    QXDVFQAKOKIPCM-UHFFFAOYSA-N;
MW          114.192;      // g/mol [origin=calculated method=formula-sum]
Tc          624.49;      // K   [origin=predictive method=joback]
Pc          33.960;      // bar [origin=predictive method=joback]
omega       0.5789;      // -   [origin=predictive method=lee-kesler]
Tb          441.38;      // K   [origin=predictive method=joback]
HvapTb      41780.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.168 0.74624 -0.0004836 1.286e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group CH3NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-dimethylbut-2-ene-1,4-diamine" );
gibbsFormation
{
    dHf_298   56990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=258640.0
    phase     gas;
}
