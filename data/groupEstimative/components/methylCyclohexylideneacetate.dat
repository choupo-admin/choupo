/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl cyclohexylideneacetate  (C9H14O2, CAS 40203-74-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylCyclohexylideneacetate;
formula     C9H14O2;
CAS         40203-74-5;
InChIKey    SSYXINHPLNNOSJ-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          707.49;      // K   [origin=predictive method=joback]
Pc          30.524;      // bar [origin=predictive method=joback]
omega       0.4722;      // -   [origin=predictive method=lee-kesler]
Tb          494.60;      // K   [origin=predictive method=joback]
HvapTb      44560.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.33 0.87512 -0.0004761 7.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-cyclohexylideneethanoate" "methyl 2-cyclohexylideneacetate" "cyclohexylideneacetic acid methyl ester" "acetic acid, cyclohexylidene-, methyl ester" );
gibbsFormation
{
    dHf_298   -395680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-207850.0
    phase     gas;
}
