/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-3,5-dimethoxyaniline  (C8H10BrNO2, CAS 70277-99-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo35Dimethoxyaniline;
formula     C8H10BrNO2;
CAS         70277-99-5;
InChIKey    XVEXDSJIDAIIAP-UHFFFAOYSA-N;
MW          232.077;      // g/mol [origin=calculated method=formula-sum]
Tc          842.96;      // K   [origin=predictive method=joback]
Pc          38.675;      // bar [origin=predictive method=joback]
omega       0.7651;      // -   [origin=predictive method=lee-kesler]
Tb          607.79;      // K   [origin=predictive method=joback]
HvapTb      59560.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (70.29 0.48014 -0.00013428 -2.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group CH3O; count 2; } { group ACNH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group O; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-3,5-dimethoxy-aniline" );
standardThermochemistry
{
    dHf_298   -210650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29230.0
}
