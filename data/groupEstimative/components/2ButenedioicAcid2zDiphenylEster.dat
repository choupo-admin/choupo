/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenedioic acid (2z)-, diphenyl ester  (C16H12O4, CAS 7242-17-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenedioicAcid2zDiphenylEster;
formula     C16H12O4;
CAS         7242-17-3;
InChIKey    WTIFDVLCDRBEJK-UHFFFAOYSA-N;
MW          268.268;      // g/mol [origin=calculated method=formula-sum]
Tc          980.49;      // K   [origin=predictive method=joback]
Pc          24.267;      // bar [origin=predictive method=joback]
omega       0.8498;      // -   [origin=predictive method=lee-kesler]
Tb          739.64;      // K   [origin=predictive method=joback]
HvapTb      70534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.83 1.2764 -0.0008036 1.634e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 10; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diphenyl but-2-enedioate" "2-butenedioic acid (2z)-, 1,4-diphenyl ester" );
standardThermochemistry
{
    dHf_298   -417850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     662.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-231860.0
}
