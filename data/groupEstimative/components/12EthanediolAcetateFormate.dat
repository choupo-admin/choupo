/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-ethanediol, acetate formate  (C5H8O4, CAS 29776-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H8O4 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        12EthanediolAcetateFormate;
formula     C5H8O4;
CAS         29776-97-4;
InChIKey    LFGXUAPUBQKJIQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          132.115;      // g/mol [origin=calculated method=formula-sum]
Tc          519.97;      // K   [origin=predictive method=joback]
Pc          35.389;      // bar [origin=predictive method=joback]
omega       0.3376;      // -   [origin=predictive method=lee-kesler]
Tb          348.64;      // K   [origin=predictive method=joback]
HvapTb      31758.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.252 0.43212 -0.0003066 8.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3COO; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methanoyloxyethyl ethanoate" "1,2-ethanediol, 1-acetate 2-formate" "2-formyloxyethyl acetate" );
standardThermochemistry
{
    dHf_298   -387360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-275190.0
}
