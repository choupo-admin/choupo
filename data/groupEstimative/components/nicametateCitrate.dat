/*--------------------------------*- Choupo -*-----------------------*\
  Component: nicametate citrate  (C18H26N2O9, CAS 1641-74-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nicametateCitrate;
formula     C18H26N2O9;
CAS         1641-74-3;
InChIKey    IABBAGAOMDWOCW-UHFFFAOYSA-N;
MW          414.411;      // g/mol [origin=calculated method=formula-sum]
Tc          1597.24;      // K   [origin=predictive method=joback]
Pc          18.563;      // bar [origin=predictive method=joback]
omega       1.3651;      // -   [origin=predictive method=lee-kesler]
Tb          1289.36;      // K   [origin=predictive method=joback]
HvapTb      140767.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.836 1.8438 -0.00101906 1.591e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C; count 1; } { group OH; count 1; } { group CH2N; count 1; } { group C5H4N; count 1; } { group COOH; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 3; } { group COO; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethyl pyridine-3-carboxylate;2-oxidanylpropane-1,2,3-tricarboxylic acid" "euclidan" "manlate" "provasan" "soclidan" "eucast" "euclidan, citrate" "nicametate dihydrogen citrate" "2-diethylaminoethyl nicotinate citrate" "2-(diethylamino)ethyl nicotinate 2-hydroxypropane-1,2,3-tricarboxylate" "53-11 c" "nicotinic acid, 2-(diethylamino)ethyl ester, citrate (1:1)" );
gibbsFormation
{
    dHf_298   -1718690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1109.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1179920.0
    phase     gas;
}
