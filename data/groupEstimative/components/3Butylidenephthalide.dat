/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-butylidenephthalide  (C12H12O2, CAS 551-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Butylidenephthalide;
formula     C12H12O2;
CAS         551-08-6;
InChIKey    WMBOCUXXNSOQHM-UHFFFAOYSA-N;
MW          188.226;      // g/mol [origin=calculated method=formula-sum]
Tc          785.22;      // K   [origin=predictive method=joback]
Pc          27.498;      // bar [origin=predictive method=joback]
omega       0.6809;      // -   [origin=predictive method=lee-kesler]
Tb          573.55;      // K   [origin=predictive method=joback]
HvapTb      53316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.058 1.06972 -0.00083546 2.633e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-butylidene-2-benzofuran-1-one" "1(3h)-isobenzofuranone, 3-butylidene-" "1(3h)-isobenzofuranone, 3-butylidene-, (3z)-" "3-butylidene-2-benzofuran-1(3h)-one" );
gibbsFormation
{
    dHf_298   -201740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19310.0
    phase     gas;
}
