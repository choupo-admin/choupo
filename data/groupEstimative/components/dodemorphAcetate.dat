/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodemorph acetate  (C20H39NO3, CAS 31717-87-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodemorphAcetate;
formula     C20H39NO3;
CAS         31717-87-0;
InChIKey    YLJLLELGHSWIDU-UHFFFAOYSA-N;
MW          341.536;      // g/mol [origin=calculated method=formula-sum]
Tc          1140.28;      // K   [origin=predictive method=joback]
Pc          14.283;      // bar [origin=predictive method=joback]
omega       0.8902;      // -   [origin=predictive method=lee-kesler]
Tb          899.28;      // K   [origin=predictive method=joback]
HvapTb      85534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.12 2.03906 -0.0006953 -9.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 2; } { group CH-O; count 1; } { group CH2N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 13; } { group CH_ring; count 3; } { group O_ring; count 1; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-cyclododecyl-2,6-dimethyl-morpholine;ethanoic acid" "mehltaumittel" "cyclomorph" "meltox" "milban" "basf mehltaumittel" "dodemorfe [french]" "dodemorph acetate [bsi:iso]" "bas 238f" "acetate de dodemorphe [french]" "4-cyclododecyl-2,6-dimethylmorpholine acetate" "cyclododecyl-2,6-dimethylmorpholine acetate" );
standardThermochemistry
{
    dHf_298   -924990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1056.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-325800.0
}
