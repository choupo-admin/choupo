/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperoxan  (C14H19NO2, CAS 59-39-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperoxan;
formula     C14H19NO2;
CAS         59-39-2;
InChIKey    LYKMMUBOEFYJQG-UHFFFAOYSA-N;
MW          233.311;      // g/mol [origin=calculated method=formula-sum]
Tc          888.07;      // K   [origin=predictive method=joback]
Pc          27.759;      // bar [origin=predictive method=joback]
omega       0.6879;      // -   [origin=predictive method=lee-kesler]
Tb          648.88;      // K   [origin=predictive method=joback]
HvapTb      61410.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.279 1.6128 -0.00114336 3.131e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 4; } { group AC; count 2; } { group CH-O; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,3-dihydro-1,4-benzodioxin-3-ylmethyl)piperidine" "benodaine" "piperoxane" "piperoxane [inn-french]" "piperoxanum [inn-latin]" "f933" "1,4-benzodioxane, 2-(piperidinomethyl)-" "piperidine, 1-(1,4-benzodioxan-2-ylmethyl)-" "1,4-benzodioxan, 2-(piperidinomethyl)-" "benodain" "piperoxano" "piperoxanum" );
standardThermochemistry
{
    dHf_298   -156240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=201230.0
}
