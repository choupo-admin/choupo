/*--------------------------------*- Choupo -*-----------------------*\
  Component: propionic acid, 2,2-bis(hydroxymethyl)-, methyl ester  (C6H12O4, CAS 17872-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propionicAcid22BisHydroxymethylMethylEster;
formula     C6H12O4;
CAS         17872-55-8;
InChIKey    RQEPEDPOJQCJJT-UHFFFAOYSA-N;
MW          148.158;      // g/mol [origin=calculated method=formula-sum]
Tc          747.16;      // K   [origin=predictive method=joback]
Pc          39.755;      // bar [origin=predictive method=joback]
omega       1.3768;      // -   [origin=predictive method=lee-kesler]
Tb          576.23;      // K   [origin=predictive method=joback]
HvapTb      68419.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.952 0.71284 -0.0004406 9.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group OH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-(hydroxymethyl)-2-methyl-3-oxidanyl-propanoate" "propanoic acid, 3-hydroxy-2-(hydroxymethyl)-2-methyl-, methyl ester" "methyl 2,2-(hydroxymethyl)propionate" "methyl 2,2-bis(hydroxymethyl)propionate" );
gibbsFormation
{
    dHf_298   -797660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-581530.0
    phase     gas;
}
