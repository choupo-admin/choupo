/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,3-trimethyl-1-butene  (C7H14, CAS 594-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        233Trimethyl1Butene;
formula     C7H14;
CAS         594-56-9;
InChIKey    AUYRUAVCWOAHQN-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          535.25;      // K   [origin=predictive method=joback]
Pc          30.057;      // bar [origin=predictive method=joback]
omega       0.2165;      // -   [origin=predictive method=lee-kesler]
Tb          353.09;      // K   [origin=predictive method=joback]
HvapTb      29290.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.63 0.77458 -0.000554 1.632e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,3-trimethylbut-1-ene" "triptene" "1-butene, 2,3,3-trimethyl-" "2,3-trimethyl-1-butene" "agn-pc-00jdfj" "1-butene,3,3-trimethyl-" "1-butene,2,3,3-trimethyl-" );
gibbsFormation
{
    dHf_298   -80920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90190.0
    phase     gas;
}
