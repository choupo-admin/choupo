/*--------------------------------*- Choupo -*-----------------------*\
  Component: propyl bromoacetate  (C5H9BrO2, CAS 35223-80-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propylBromoacetate;
formula     C5H9BrO2;
CAS         35223-80-4;
InChIKey    ISYUCUGTDNJIHV-UHFFFAOYSA-N;
MW          181.029;      // g/mol [origin=calculated method=formula-sum]
Tc          631.58;      // K   [origin=predictive method=joback]
Pc          37.916;      // bar [origin=predictive method=joback]
omega       0.5272;      // -   [origin=predictive method=lee-kesler]
Tb          438.38;      // K   [origin=predictive method=joback]
HvapTb      40566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.943 0.46222 -0.000225 2.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2COO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propyl 2-bromanylethanoate" "n-propyl bromoacetate" "acetic acid, bromo-, propyl ester" "propyl bromo acetate" "propyl 2-bromoacetate" "acetic acid, 2-bromo-,propyl ester" "u694" "aceticacid, bromo-, propyl ester (9ci);bromoacetic acid propyl ester;propylbromoacetate;" );
gibbsFormation
{
    dHf_298   -437480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-304830.0
    phase     gas;
}
