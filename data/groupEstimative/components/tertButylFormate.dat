/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl formate  (C5H10O2, CAS 762-75-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H10O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tertButylFormate;
formula     C5H10O2;
CAS         762-75-4;
InChIKey    RUPAXCPQAAOIPB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          456.67;      // K   [origin=predictive method=joback]
Pc          35.986;      // bar [origin=predictive method=joback]
omega       0.1203;      // -   [origin=predictive method=lee-kesler]
Tb          287.19;      // K   [origin=predictive method=joback]
HvapTb      23055.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.63 0.61276 -0.000573 2.169e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tert-butyl methanoate" "t-butyl formate" "formic acid, 1,1-dimethylethyl ester" "formate, t-butyl-" "formic acid, tert-butyl ester" "tert-butyloxycarbonyl group" "formic acid tert-butylester" "1,1-dimethylethyl ester" "tet.-butyl formate" "formic acid tert-butyl ester" "formic acid,1,1-dimethylethyl ester" );
gibbsFormation
{
    dHf_298   -78830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38020.0
    phase     gas;
}
