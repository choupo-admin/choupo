/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-chlorobenzoate  (C8H7ClO2, CAS 610-96-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Chlorobenzoate;
formula     C8H7ClO2;
CAS         610-96-8;
InChIKey    JAVRNIFMYIJXIE-UHFFFAOYSA-N;
MW          170.592;      // g/mol [origin=calculated method=formula-sum]
Tc          733.29;      // K   [origin=predictive method=joback]
Pc          34.521;      // bar [origin=predictive method=joback]
omega       0.4976;      // -   [origin=predictive method=lee-kesler]
Tb          509.95;      // K   [origin=predictive method=joback]
HvapTb      48132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.31 0.57742 -0.00030136 3.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-chloranylbenzoate" "methyl o-chlorobenzoate" "benzoic acid, 2-chloro-, methyl ester" "2-chlorobenzoic acid methyl ester" "methyl-2-chlorobenzoate" "benzoic acid, o-chloro-, methyl ester" "o-chloro-benzoic acid methylester" "o-chloro-benzoic acid methyl ester" "benzoic acid, o-chloro-, methyl ester (8ci)" );
standardThermochemistry
{
    dHf_298   -316410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203040.0
}
