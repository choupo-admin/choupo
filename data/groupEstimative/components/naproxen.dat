/*--------------------------------*- Choupo -*-----------------------*\
  Component: naproxen  (C14H14O3, CAS 22204-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naproxen;
formula     C14H14O3;
CAS         22204-53-1;
InChIKey    CMWTZPSULFXXJA-VIFPVBQESA-N;
MW          230.263;      // g/mol [origin=calculated method=formula-sum]
Tc          976.00;      // K   [origin=predictive method=joback]
Pc          26.680;      // bar [origin=predictive method=joback]
omega       0.9868;      // -   [origin=predictive method=lee-kesler]
Tb          743.03;      // K   [origin=predictive method=joback]
HvapTb      71184.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.17 1.12574 -0.00073644 1.849e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 6; } { group AC; count 3; } { group ACCH; count 1; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-(6-methoxynaphthalen-2-yl)propanoic acid" "naproxene" "(s)-naproxen" "naproxenum" "naprosyn" "naproxeno" "(+)-naproxen" "equiproxen" "naprosyne" "apronax" "calosen" "congex" );
gibbsFormation
{
    dHf_298   -415400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-184550.0
    phase     gas;
}
