/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-diphenylpentane  (C17H20, CAS 1718-50-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Diphenylpentane;
formula     C17H20;
CAS         1718-50-9;
InChIKey    AZZHCIXSZZXEAS-UHFFFAOYSA-N;
MW          224.347;      // g/mol [origin=calculated method=formula-sum]
Tc          867.63;      // K   [origin=predictive method=joback]
Pc          20.888;      // bar [origin=predictive method=joback]
omega       0.6200;      // -   [origin=predictive method=lee-kesler]
Tb          641.92;      // K   [origin=predictive method=joback]
HvapTb      57988.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.375 1.461 -0.0009634 2.421e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 10; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-phenylpentylbenzene" "(5-phenylpentyl)benzene" "1,1'-pentane-1,5-diyldibenzene" "benzene, 1,1'-(1,5-pentanediyl)bis-" );
gibbsFormation
{
    dHf_298   78850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=317080.0
    phase     gas;
}
