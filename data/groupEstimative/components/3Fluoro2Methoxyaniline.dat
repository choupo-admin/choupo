/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-fluoro-2-methoxyaniline  (C7H8FNO, CAS 437-83-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Fluoro2Methoxyaniline;
formula     C7H8FNO;
CAS         437-83-2;
InChIKey    RCYMPYMITUEHOJ-UHFFFAOYSA-N;
MW          141.145;      // g/mol [origin=calculated method=formula-sum]
Tc          705.71;      // K   [origin=predictive method=joback]
Pc          39.357;      // bar [origin=predictive method=joback]
omega       0.5515;      // -   [origin=predictive method=lee-kesler]
Tb          490.62;      // K   [origin=predictive method=joback]
HvapTb      47010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.3 0.48142 -0.00020292 9.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CH3O; count 1; } { group ACNH2; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-fluoranyl-2-methoxy-aniline" "3-fluoro-o-anisidine" "3-fluoro-2-methoxy-phenylamine" "2-amino-6-fluoroanisole" "3-fluoro-2-methoxy-benzenamine" "3-fluoro-2-methoxyphenylamine" "benzenamine, 3-fluoro-2-methoxy-" "3-fluoro-2-methoxybenzenenamine" "zr cf bo1" "3-fuloro-2-methoxyaniline" "437-83-2 3-fluoro-2-methoxyaniline" "n664" );
gibbsFormation
{
    dHf_298   -268760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-132150.0
    phase     gas;
}
