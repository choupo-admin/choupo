/*--------------------------------*- Choupo -*-----------------------*\
  Component: methanamine, n,n-di((2-trimethylsilyloxy)propyl)-  (C13H33NO2Si2, CAS 81729-37-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H33NO2Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methanamineNNDi2TrimethylsilyloxyPropyl;
formula     C13H33NO2Si2;
CAS         81729-37-5;
InChIKey    VOUUUAOWACSAOJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          291.582;      // g/mol [origin=calculated method=formula-sum]
Tc          730.15;      // K   [origin=predictive method=joback]
Pc          13.457;      // bar [origin=predictive method=joback]
omega       0.5626;      // -   [origin=predictive method=lee-kesler]
Tb          556.24;      // K   [origin=predictive method=joback]
HvapTb      51207.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (109.652 0.83588 0.0002492 -3.641e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 2; } { group CH-O; count 2; } { group CH3N; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group CH2; count 2; } { group CH; count 2; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-2-trimethylsilyloxy-n-(2-trimethylsilyloxypropyl)propan-1-amine" "methanamine, n,n-di[(2-trimethylsilyloxy)propyl]-" "n-methyl-2-[(trimethylsilyl)oxy]-n-{2-[(trimethylsilyl)oxy]propyl}propan-1-amine" );
gibbsFormation
{
    dHf_298   -742360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     934.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255040.0
    phase     gas;
}
