/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexyl methyl ketone  (C8H14O, CAS 823-76-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylMethylKetone;
formula     C8H14O;
CAS         823-76-7;
InChIKey    RIFKADJTWUGDOV-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          669.46;      // K   [origin=predictive method=joback]
Pc          33.881;      // bar [origin=predictive method=joback]
omega       0.3901;      // -   [origin=predictive method=lee-kesler]
Tb          456.06;      // K   [origin=predictive method=joback]
HvapTb      40577.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.63 0.85792 -0.0004737 8.456e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexylethanone" "acetylcyclohexane" "ethanone, 1-cyclohexyl-" "1-cyclohexylethan-1-one" "cyclohexylethanone" "ketone, cyclohexyl methyl" "1-acetylcyclohexane" "cyclohexane, acetyl-" "methyl cyclohexyl ketone" "acetophenone, hexahydro-" "acetyl cyclohexane" "1-cyclohexyl-ethanone" );
gibbsFormation
{
    dHf_298   -266710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87990.0
    phase     gas;
}
