/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 3,3'-piperazine-1,4-diyldipropanoate  (C12H22N2O4, CAS 4038-90-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl33Piperazine14Diyldipropanoate;
formula     C12H22N2O4;
CAS         4038-90-8;
InChIKey    ZNYIVYFFZCEWDY-UHFFFAOYSA-N;
MW          258.318;      // g/mol [origin=calculated method=formula-sum]
Tc          816.24;      // K   [origin=predictive method=joback]
Pc          21.119;      // bar [origin=predictive method=joback]
omega       0.9791;      // -   [origin=predictive method=lee-kesler]
Tb          631.16;      // K   [origin=predictive method=joback]
HvapTb      61600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.886 1.44984 -0.0008942 1.898e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2COO; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH2_ring; count 4; } { group COO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-[4-(3-methoxy-3-oxidanylidene-propyl)piperazin-1-yl]propanoate" "1,4-piperazinedipropionic acid, dimethyl ester" "dimethyl piperazine-1,4-dipropionate" "1,4-piperazinedipropanoicacid, 1,4-dimethyl ester" "methyl 3-[4-(3-methoxy-3-oxopropyl)piperazin-1-yl]propanoate" "1,4-piperazinedipropanoicacid, dimethyl ester (9ci); 1,4-piperazinedipropionic acid, dimethyl ester(7ci,8ci); 1,4-bis[2-(methoxycarbonyl)ethyl]piperazine;1,4-bismethoxycarbonylethylpiperazine; dimethyl piperazine-1,4-dipropanoate;n,n'-bis(2-methoxycarbonylethyl)piperazine" );
gibbsFormation
{
    dHf_298   -703530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     730.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-292660.0
    phase     gas;
}
