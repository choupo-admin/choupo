/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-bromodecanoate  (C12H23BrO2, CAS 6974-85-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Bromodecanoate;
formula     C12H23BrO2;
CAS         6974-85-2;
InChIKey    IOOXHTJCOQWOJW-UHFFFAOYSA-N;
MW          279.218;      // g/mol [origin=calculated method=formula-sum]
Tc          780.76;      // K   [origin=predictive method=joback]
Pc          19.102;      // bar [origin=predictive method=joback]
omega       0.8288;      // -   [origin=predictive method=lee-kesler]
Tb          598.10;      // K   [origin=predictive method=joback]
HvapTb      55760.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.898 1.13314 -0.000609 1.081e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-bromanyldecanoate" "decanoic acid, 2-bromoethyl ester" "ethyl 2-bromocaprate" "ethyl alpha-bromocaprate" "2-bromodecanoic acid ethyl ester" );
standardThermochemistry
{
    dHf_298   -587240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     716.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-248330.0
}
