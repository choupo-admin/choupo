/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylhexyl acrylate, methyl methacrylate, 1,3-butadiene, styrene, acrylonitrile polymer  (C31H45NO4, CAS 41585-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylhexylAcrylateMethylMethacrylate13ButadieneStyreneAcryl;
formula     C31H45NO4;
CAS         41585-11-9;
InChIKey    SWAVLYPJCFZYKK-UHFFFAOYSA-N;
MW          495.704;      // g/mol [origin=calculated method=formula-sum]
Tc          1396.23;      // K   [origin=predictive method=joback]
Pc          6.361;      // bar [origin=predictive method=joback]
omega       0.5465;      // -   [origin=predictive method=lee-kesler]
Tb          1139.20;      // K   [origin=predictive method=joback]
HvapTb      109016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (152.575 1.75618 4.27e-05 -5.004e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 4; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group ACRY; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 6; } { group dCH; count 5; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "buta-1,3-diene;ethenylbenzene;2-ethylhexyl prop-2-enoate;methyl 2-methylprop-2-enoate;prop-2-enenitrile" "buta-1,3-diene; 2-ethylhexyl prop-2-enoate; methyl 2-methylprop-2-enoate; prop-2-enenitrile; styrene" "2-propenoic acid, 2-methyl-, methyl ester, polymer with 1,3-butadiene, ethenylbenzene, 2-ethylhexyl 2-propenoate and 2-propenenitrile" "2-ethylhexyl acrylate, methyl methacrylate, 1,3-butadiene, styrene, acrylonitrile polymer;2-propenoic acid, 2-methyl-, methyl ester, polymer with 1,3-butadiene, ethenylbenzene, 2-ethylhexyl 2-propenoate and 2-propenenitrile" );
gibbsFormation
{
    dHf_298   -625290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1755.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68000.0
    phase     gas;
}
