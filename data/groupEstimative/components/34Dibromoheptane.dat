/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dibromoheptane  (C7H14Br2, CAS 21266-90-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dibromoheptane;
formula     C7H14Br2;
CAS         21266-90-0;
InChIKey    JZGBICDPBLLXKB-UHFFFAOYSA-N;
MW          257.997;      // g/mol [origin=calculated method=formula-sum]
Tc          699.29;      // K   [origin=predictive method=joback]
Pc          33.182;      // bar [origin=predictive method=joback]
omega       0.5339;      // -   [origin=predictive method=lee-kesler]
Tb          491.20;      // K   [origin=predictive method=joback]
HvapTb      43270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.543 0.75704 -0.0005062 1.393e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-bis(bromanyl)heptane" );
gibbsFormation
{
    dHf_298   -145710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31820.0
    phase     gas;
}
