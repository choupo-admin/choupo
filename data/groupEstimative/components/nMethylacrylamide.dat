/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylacrylamide  (C4H7NO, CAS 1187-59-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylacrylamide;
formula     C4H7NO;
CAS         1187-59-3;
InChIKey    YPHQUSNPXDGUHL-UHFFFAOYSA-N;
MW          85.106;      // g/mol [origin=calculated method=formula-sum]
Tc          580.59;      // K   [origin=predictive method=joback]
Pc          45.408;      // bar [origin=predictive method=joback]
omega       0.4594;      // -   [origin=predictive method=lee-kesler]
Tb          391.84;      // K   [origin=predictive method=joback]
HvapTb      37010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.41 0.41202 -0.0002466 5.526e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methylprop-2-enamide" "2-propenamide, n-methyl-" "acrylamide, n-methyl-" "n-methyl-2-propenamide" "agn-pc-0cyzjy" "2-propenamide,n-methyl-" "acrylamide,n-methyl- (6ci,7ci,8ci); n-methylacrylamide" );
gibbsFormation
{
    dHf_298   -59570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31110.0
    phase     gas;
}
