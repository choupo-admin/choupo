/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydrogeranyl butyrate  (C14H28O2, CAS 67874-80-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydrogeranylButyrate;
formula     C14H28O2;
CAS         67874-80-0;
InChIKey    MHOJKRQFONEPRN-UHFFFAOYSA-N;
MW          228.376;      // g/mol [origin=calculated method=formula-sum]
Tc          748.25;      // K   [origin=predictive method=joback]
Pc          15.488;      // bar [origin=predictive method=joback]
omega       0.7502;      // -   [origin=predictive method=lee-kesler]
Tb          577.26;      // K   [origin=predictive method=joback]
HvapTb      53389.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.207 1.29088 -0.0006496 9.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyloctyl butanoate" "3,7-dimethyloctyl butyrate" "3,7-dimethyloctanyl butyrate" "butanoic acid, 3,7-dimethyloctyl ester" "butanoic acid 3,7-dimethyloctyl ester" );
standardThermochemistry
{
    dHf_298   -660130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     733.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-248250.0
}
