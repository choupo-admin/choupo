/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene,[1-(1-methylethyl)cyclopropyl]-  (C12H16, CAS 63339-99-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene11MethylethylCyclopropyl;
formula     C12H16;
CAS         63339-99-1;
InChIKey    UAZCFEANXCTOCG-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          737.09;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       0.3759;      // -   [origin=predictive method=lee-kesler]
Tb          507.38;      // K   [origin=predictive method=joback]
HvapTb      42956.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.84 1.51364 -0.0014162 5.539e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-propan-2-ylcyclopropyl)benzene" "benzene, (1-(1-methylethyl)cyclopropyl)-" );
gibbsFormation
{
    dHf_298   28280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=215390.0
    phase     gas;
}
