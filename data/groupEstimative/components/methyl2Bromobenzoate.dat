/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-bromobenzoate  (C8H7BrO2, CAS 610-94-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Bromobenzoate;
formula     C8H7BrO2;
CAS         610-94-6;
InChIKey    SWGQITQOBPXVRC-UHFFFAOYSA-N;
MW          215.046;      // g/mol [origin=calculated method=formula-sum]
Tc          772.45;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.5673;      // -   [origin=predictive method=lee-kesler]
Tb          538.68;      // K   [origin=predictive method=joback]
HvapTb      50182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.61 0.60882 -0.00035236 6.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-bromanylbenzoate" "methyl o-bromobenzoate" "methyl-2-bromobenzoate" "2-bromobenzoic acid methyl ester" "benzoic acid, 2-bromo-, methyl ester" "methyl bromobenzoate" "o-bromobenzoic acid, methyl ester" "2-(methoxycarbonyl)bromobenzene" "benzoic acid, o-bromo-, methyl ester (8ci)" );
gibbsFormation
{
    dHf_298   -274340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-176790.0
    phase     gas;
}
