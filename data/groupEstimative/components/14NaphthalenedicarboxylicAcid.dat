/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-naphthalenedicarboxylic acid  (C12H8O4, CAS 605-70-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14NaphthalenedicarboxylicAcid;
formula     C12H8O4;
CAS         605-70-9;
InChIKey    ABMFBCRYHDZLRD-UHFFFAOYSA-N;
MW          216.192;      // g/mol [origin=calculated method=formula-sum]
Tc          1066.91;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       1.3000;      // -   [origin=predictive method=lee-kesler]
Tb          820.80;      // K   [origin=predictive method=joback]
HvapTb      81874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.57 1.0438 -0.00080804 2.444e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene-1,4-dicarboxylic acid" "1,4-naphthalenedicarboxylicacid" "1,4-naphthalicacid" "1,4-naphthalic acid" "naphthalene-1,4-dicarboxlic acid" );
gibbsFormation
{
    dHf_298   -586890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-437860.0
    phase     gas;
}
