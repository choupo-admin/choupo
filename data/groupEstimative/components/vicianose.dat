/*--------------------------------*- Choupo -*-----------------------*\
  Component: vicianose  (C11H20O10, CAS 14116-69-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vicianose;
formula     C11H20O10;
CAS         14116-69-9;
InChIKey    QYNRIDLOTGRNML-ULAALWPKSA-N;
MW          312.271;      // g/mol [origin=calculated method=formula-sum]
Tc          1527.24;      // K   [origin=predictive method=joback]
Pc          45.286;      // bar [origin=predictive method=joback]
omega       1.4781;      // -   [origin=predictive method=lee-kesler]
Tb          1179.27;      // K   [origin=predictive method=joback]
HvapTb      166958.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.431 1.2763 -0.0004228 -6.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 8; } { group OH; count 7; } { group CH2O; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 9; } { group OH; count 7; } { group O; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,4s,5s,6r)-6-[[(2s,3r,4s,5s)-3,4,5-tris(oxidanyl)oxan-2-yl]oxymethyl]oxane-2,3,4,5-tetrol" "6-o-alpha-l-arabinopyranosyl-d-glucopyranose" "o-alpha-l-arabinopyranosyl-(1-6)-d-glucopyranose" "alpha-l-arabinopyranosyl-(1->-6)-beta-d-glucopyranose" "(3r,4s,5s,6r)-6-[[(2s,3r,4s,5s)-3,4,5-trihydroxyoxan-2-yl]oxymethyl]oxane-2,3,4,5-tetrol" );
gibbsFormation
{
    dHf_298   -1765940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1198310.0
    phase     gas;
}
