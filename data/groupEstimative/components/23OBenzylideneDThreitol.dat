/*--------------------------------*- Choupo -*-----------------------*\
  Component: (+)-2,3-o-benzylidene-d-threitol  (C11H14O4, CAS 58383-35-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23OBenzylideneDThreitol;
formula     C11H14O4;
CAS         58383-35-0;
InChIKey    AEJRVTSEJAYBNR-NXEZZACHSA-N;
MW          210.229;      // g/mol [origin=calculated method=formula-sum]
Tc          922.79;      // K   [origin=predictive method=joback]
Pc          36.159;      // bar [origin=predictive method=joback]
omega       1.4855;      // -   [origin=predictive method=lee-kesler]
Tb          722.16;      // K   [origin=predictive method=joback]
HvapTb      84373.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.398 1.1106 -0.0006554 1.305e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 2; } { group CH-O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(4r,5r)-5-(hydroxymethyl)-2-phenyl-1,3-dioxolan-4-yl]methanol" "(4r,5r)-(+)-2-phenyl-1,3-dioxolane-4,5-dimethanol" "2,3-o-benzylidene-d-threitol" "(-)-2,3-o-benzylidene-d-threitol" "[(4r,5r)-5-(hydroxymethyl)-2-phenyl-1,3-dioxolan-4-yl]methan-1-ol" );
gibbsFormation
{
    dHf_298   -582500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-270600.0
    phase     gas;
}
