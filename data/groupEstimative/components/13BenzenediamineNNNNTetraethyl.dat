/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenediamine, n,n,n',n'-tetraethyl-  (C14H24N2, CAS 64287-26-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BenzenediamineNNNNTetraethyl;
formula     C14H24N2;
CAS         64287-26-9;
InChIKey    LOBSLLOTZXAAPI-UHFFFAOYSA-N;
MW          220.36;      // g/mol [origin=calculated method=formula-sum]
Tc          766.95;      // K   [origin=predictive method=joback]
Pc          19.753;      // bar [origin=predictive method=joback]
omega       0.6991;      // -   [origin=predictive method=lee-kesler]
Tb          576.46;      // K   [origin=predictive method=joback]
HvapTb      53782.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.826 1.44328 -0.00092716 2.308e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n1,n3,n3-tetraethylbenzene-1,3-diamine" "agn-pc-02ce5x" );
standardThermochemistry
{
    dHf_298   27830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=391340.0
}
