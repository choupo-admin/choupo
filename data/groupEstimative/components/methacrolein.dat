/*--------------------------------*- Choupo -*-----------------------*\
  Component: methacrolein  (C4H6O, CAS 78-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methacrolein;
formula     C4H6O;
CAS         78-85-3;
InChIKey    STNJBCKSHOAVAJ-UHFFFAOYSA-N;
MW          70.091;      // g/mol [origin=calculated method=formula-sum]
Tc          516.85;      // K   [origin=predictive method=joback]
Pc          45.592;      // bar [origin=predictive method=joback]
omega       0.3071;      // -   [origin=predictive method=lee-kesler]
Tb          336.34;      // K   [origin=predictive method=joback]
HvapTb      30628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.97 0.33822 -0.000212 5.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylprop-2-enal" "methacrylaldehyde" "2-propenal, 2-methyl-" "isobutenal" "2-methyl-2-propenal" "2-methylacrolein" "2-methylpropenal" "methylacrylaldehyde" "2-methylenepropanal" "methacrylic aldehyde" "acrolein, 2-methyl-" "alpha-methylacrolein" );
gibbsFormation
{
    dHf_298   -95830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     321.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-37430.0
    phase     gas;
}
