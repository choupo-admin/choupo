/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-(bromomethyl)acrylate  (C6H9BrO2, CAS 17435-72-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2BromomethylAcrylate;
formula     C6H9BrO2;
CAS         17435-72-2;
InChIKey    MTCMFVTVXAOHNQ-UHFFFAOYSA-N;
MW          193.04;      // g/mol [origin=calculated method=formula-sum]
Tc          656.89;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       0.5238;      // -   [origin=predictive method=lee-kesler]
Tb          457.82;      // K   [origin=predictive method=joback]
HvapTb      42202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.352 0.53712 -0.0003046 5.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-(bromomethyl)prop-2-enoate" "2-bromomethyl-acrylic acid ethyl ester" "2-(bromomethyl)acrylic acid ethyl ester" "2-(bromomethyl)-acrylic acid ethyl ester" "propenoic acid, 2-(bromomethyl)-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -342480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-217120.0
}
