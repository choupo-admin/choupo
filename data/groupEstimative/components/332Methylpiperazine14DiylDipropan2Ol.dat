/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3'-(2-methylpiperazine-1,4-diyl)dipropan-2-ol  (C11H24N2O2, CAS 94-72-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        332Methylpiperazine14DiylDipropan2Ol;
formula     C11H24N2O2;
CAS         94-72-4;
InChIKey    GPXSTLAIBOEFST-UHFFFAOYSA-N;
MW          216.325;      // g/mol [origin=calculated method=formula-sum]
Tc          842.88;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       1.4805;      // -   [origin=predictive method=lee-kesler]
Tb          670.65;      // K   [origin=predictive method=joback]
HvapTb      76833.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.638 1.51776 -0.0010408 2.825e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 3; } { group OH; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group OH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[3-methyl-4-(2-oxidanylpropyl)piperazin-1-yl]propan-2-ol" "1, .alpha.,.alpha.',2-trimethyl-" ".alpha.,2-trimethyl-1,4-piperazinediethanol" "n,n'-bis(2-hydroxypropyl)-2-methylpiperazine" "1,4-bis-(2-hydroxypropyl)-2-methylpiperazine" "1-[4-(2-hydroxypropyl)-2-methylpiperazin-1-yl]propan-2-ol" "1-[4-(2-hydroxypropyl)-3-methylpiperazin-1-yl]propan-2-ol" );
standardThermochemistry
{
    dHf_298   -383690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     629.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=33430.0
}
