/*--------------------------------*- Choupo -*-----------------------*\
  Component: iodoalphionic acid  (C15H12I2O3, CAS 577-91-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iodoalphionicAcid;
formula     C15H12I2O3;
CAS         577-91-3;
InChIKey    IKYIXZSIKOYSLD-UHFFFAOYSA-N;
MW          494.058;      // g/mol [origin=calculated method=formula-sum]
Tc          1311.69;      // K   [origin=predictive method=joback]
Pc          30.057;      // bar [origin=predictive method=joback]
omega       1.2586;      // -   [origin=predictive method=lee-kesler]
Tb          1018.09;      // K   [origin=predictive method=joback]
HvapTb      103396.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.579 1.4413 -0.00121548 4.089e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group COOH; count 1; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group I; count 2; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[3,5-bis(iodanyl)-4-oxidanyl-phenyl]-2-phenyl-propanoic acid" "biliselectan" "biliselktan" "biliognost" "bilitrast" "biselectan" "coletrast" "iodobil" "jodobil" "pheniodol" "priodax" "tenamid" );
gibbsFormation
{
    dHf_298   -281930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     696.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-103750.0
    phase     gas;
}
