/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxydiethane-2,1-diyl bisabiet-8(14)-en-18-oate  (C44H70O5, CAS 116-22-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxydiethane21DiylBisabiet814En18Oate;
formula     C44H70O5;
CAS         116-22-3;
InChIKey    QSWONYVPBOBZDL-UHFFFAOYSA-N;
MW          679.039;      // g/mol [origin=calculated method=formula-sum]
Tc          1770.83;      // K   [origin=predictive method=joback]
Pc          5.376;      // bar [origin=predictive method=joback]
omega       0.2547;      // -   [origin=predictive method=lee-kesler]
Tb          1418.00;      // K   [origin=predictive method=joback]
HvapTb      127252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-448.866 5.66296 -0.00468248 1.677e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 17; } { group CH; count 8; } { group C; count 4; } { group CH=C; count 2; } { group CH2O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 4; } { group CH; count 2; } { group CH2_ring; count 14; } { group CH_ring; count 6; } { group C_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[(1,4a-dimethyl-7-propan-2-yl-2,3,4,4b,5,6,7,9,10,10a-decahydrophenanthren-1-yl)carbonyloxy]ethoxy]ethyl 1,4a-dimethyl-7-propan-2-yl-2,3,4,4b,5,6,7,9,10,10a-decahydrophenanthrene-1-carboxylate" "1-phenanthrenecarboxylic acid, 1,2,3,4,4a,4b,5,6,7,9,10,10a-dodecahydro-1,4a-dimethyl-7-(1-methylethyl)-, 1,1'-(oxydi-2,1-ethanediyl) ester, (1r,1'r,4as,4'as,4bs,4'bs,7s,7's,10ar,10'ar)-" "1-phenanthrenecarboxylic acid, 1,2,3,4,4a,4b,5,6,7,9,10,10a-dodecahydro-1,4a-dimethyl-7-(1-methylethyl)-, oxydi-2,1-ethanediyl ester, (1r,1'r,4as,4'as,4bs,4'bs,7s,7's,10ar,10'ar)-" "2-[2-(1,4a-dimethyl-7-propan-2-yl-2,3,4,4b,5,6,7,9,10,10a-decahydrophenanthrene-1-carbonyl)oxyethoxy]ethyl 1,4a-dimethyl-7-propan-2-yl-2,3,4,4b,5,6,7,9,10,10a-decahydrophenanthrene-1-carboxylate" );
standardThermochemistry
{
    dHf_298   -1281410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1643.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-179660.0
}
