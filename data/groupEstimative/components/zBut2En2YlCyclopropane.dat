/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(z)-but-2-en-2-yl]cyclopropane  (C7H12, CAS 20479-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        zBut2En2YlCyclopropane;
formula     C7H12;
CAS         20479-71-4;
InChIKey    RCURIBPJGNVYPF-UTCJRWHESA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          562.45;      // K   [origin=predictive method=joback]
Pc          34.480;      // bar [origin=predictive method=joback]
omega       0.2591;      // -   [origin=predictive method=lee-kesler]
Tb          370.54;      // K   [origin=predictive method=joback]
HvapTb      31127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.59 0.83964 -0.0006633 2.206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -7580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     327.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140480.0
    phase     gas;
}
