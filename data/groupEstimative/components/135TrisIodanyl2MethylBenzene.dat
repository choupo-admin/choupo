/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-tris(iodanyl)-2-methyl-benzene  (C7H5I3, CAS 36994-79-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135TrisIodanyl2MethylBenzene;
formula     C7H5I3;
CAS         36994-79-3;
InChIKey    NYCTYFCAZRQRGO-UHFFFAOYSA-N;
MW          469.817;      // g/mol [origin=calculated method=formula-sum]
Tc          1006.16;      // K   [origin=predictive method=joback]
Pc          35.856;      // bar [origin=predictive method=joback]
omega       0.3816;      // -   [origin=predictive method=lee-kesler]
Tb          680.80;      // K   [origin=predictive method=joback]
HvapTb      63557.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.59 0.52842 -0.00043128 1.426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACCH3; count 1; } { group I; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group I; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   244920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=265940.0
    phase     gas;
}
