/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3'-dihydroxybenzidine  (C12H12N2O2, CAS 2373-98-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dihydroxybenzidine;
formula     C12H12N2O2;
CAS         2373-98-0;
InChIKey    ZGDMDBHLKNQPSD-UHFFFAOYSA-N;
MW          216.24;      // g/mol [origin=calculated method=formula-sum]
Tc          1119.29;      // K   [origin=predictive method=joback]
Pc          56.874;      // bar [origin=predictive method=joback]
omega       1.3540;      // -   [origin=predictive method=lee-kesler]
Tb          843.78;      // K   [origin=predictive method=joback]
HvapTb      95492.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.09 1.3 -0.00115684 4.21e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACOH; count 2; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-5-(4-azanyl-3-oxidanyl-phenyl)phenol" "4,4'-diamino-3,3'-biphenyldiol" "benzidine, 3,3'-dihydroxy-" "3,3'-dioxybenzidine" "3,3-dihydroxybenzidine" "3,3'-biphenyldiol, 4,4'-diamino-" "3,3'-dihydroxy-4,4'-diaminobiphenyl" "2-amino-5-(4-amino-3-hydroxyphenyl)phenol" "3,3'-dwuoksybenzydyna [polish]" "m,m'-biphenol, 6,6'-diamino-" "(1,1'-biphenyl)-3,3'-diol, 4,4'-diamino-" "(1,1'-biphenyl)-4,4'-diamine, 3,3'-dihydroxy-" );
standardThermochemistry
{
    dHf_298   -127930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79380.0
}
