/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-ethyl-n-(2-phenoxyethyl)aniline  (C16H19NO, CAS 41378-51-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nEthylN2PhenoxyethylAniline;
formula     C16H19NO;
CAS         41378-51-2;
InChIKey    KKHWAYLPKGKYTI-UHFFFAOYSA-N;
MW          241.334;      // g/mol [origin=calculated method=formula-sum]
Tc          877.36;      // K   [origin=predictive method=joback]
Pc          22.440;      // bar [origin=predictive method=joback]
omega       0.7111;      // -   [origin=predictive method=lee-kesler]
Tb          653.90;      // K   [origin=predictive method=joback]
HvapTb      60215.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.657 1.42672 -0.0009106 2.128e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzenamine, n-ethyl-n-(2-phenoxyethyl)-" "benzenamine,n-ethyl-n-(2-phenoxyethyl)-" "n-ethyl-n-(2-phenoxyethyl)aniline;n-ethyl-n-phenoxyethylaminobenzene" );
gibbsFormation
{
    dHf_298   34800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=314440.0
    phase     gas;
}
