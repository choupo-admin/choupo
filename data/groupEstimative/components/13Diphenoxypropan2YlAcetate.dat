/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diphenoxypropan-2-yl acetate  (C17H18O4, CAS 71159-31-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diphenoxypropan2YlAcetate;
formula     C17H18O4;
CAS         71159-31-4;
InChIKey    ZDBQRKQOKLVMIN-UHFFFAOYSA-N;
MW          286.327;      // g/mol [origin=calculated method=formula-sum]
Tc          970.00;      // K   [origin=predictive method=joback]
Pc          20.493;      // bar [origin=predictive method=joback]
omega       0.8915;      // -   [origin=predictive method=lee-kesler]
Tb          744.54;      // K   [origin=predictive method=joback]
HvapTb      69827.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.648 1.28572 -0.00065 7.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH3COO; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diphenoxypropan-2-yl ethanoate" );
gibbsFormation
{
    dHf_298   -508150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     669.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-205730.0
    phase     gas;
}
