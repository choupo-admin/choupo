/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(3-bromopropyl)-3-methoxybenzene  (C10H13BrO, CAS 6943-97-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Bromopropyl3Methoxybenzene;
formula     C10H13BrO;
CAS         6943-97-1;
InChIKey    LISAIUHOJQKVHK-UHFFFAOYSA-N;
MW          229.117;      // g/mol [origin=calculated method=formula-sum]
Tc          768.10;      // K   [origin=predictive method=joback]
Pc          30.524;      // bar [origin=predictive method=joback]
omega       0.5913;      // -   [origin=predictive method=lee-kesler]
Tb          548.64;      // K   [origin=predictive method=joback]
HvapTb      49637.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.883 0.79042 -0.00044476 8.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-bromanylpropyl)-3-methoxy-benzene" "anisole, m-(3-bromopropyl)-" "anisole, m-(3-bromopropyl)-," );
standardThermochemistry
{
    dHf_298   -130560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45420.0
}
