/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, (nonylthio)-  (C15H24S, CAS 500041-11-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneNonylthio;
formula     C15H24S;
CAS         500041-11-2;
InChIKey    JXASPOITXHFJLW-UHFFFAOYSA-N;
MW          236.417;      // g/mol [origin=calculated method=formula-sum]
Tc          846.15;      // K   [origin=predictive method=joback]
Pc          18.740;      // bar [origin=predictive method=joback]
omega       0.6942;      // -   [origin=predictive method=lee-kesler]
Tb          638.26;      // K   [origin=predictive method=joback]
HvapTb      58077.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.052 1.34431 -0.0007832 1.652e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 5; } { group AC; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonylsulfanylbenzene" "nonylphenyl sulfide" "agn-pc-00fbry" );
standardThermochemistry
{
    dHf_298   -74530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     695.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=220950.0
}
