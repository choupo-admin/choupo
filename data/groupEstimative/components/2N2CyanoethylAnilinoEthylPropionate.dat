/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(n-(2-cyanoethyl)anilino)ethyl propionate  (C14H18N2O2, CAS 68444-10-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2N2CyanoethylAnilinoEthylPropionate;
formula     C14H18N2O2;
CAS         68444-10-0;
InChIKey    PDBRFOXCYVZTAU-UHFFFAOYSA-N;
MW          246.31;      // g/mol [origin=calculated method=formula-sum]
Tc          927.95;      // K   [origin=predictive method=joback]
Pc          19.701;      // bar [origin=predictive method=joback]
omega       0.9555;      // -   [origin=predictive method=lee-kesler]
Tb          719.34;      // K   [origin=predictive method=joback]
HvapTb      68962.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.025 1.25882 -0.000756 1.549e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-cyanoethyl(phenyl)amino]ethyl propanoate" "propanenitrile, 3-((2-(1-oxopropoxy)ethyl)phenylamino)-" "propanenitrile, 3-[[2-(1-oxopropoxy)ethyl]phenylamino]-" "propanenitrile, 3-((2-(propionyloxy)ethyl)phenylamino)-" "2-[n-(2-cyanoethyl)anilino]ethyl propanoate" "2-[(2-cyanoethyl)(phenyl)amino]ethyl propanoate" "propanenitrile, 3-(n-(2-(propionyloxy)ethyl)phenylamino)-" );
standardThermochemistry
{
    dHf_298   -180630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     668.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113000.0
}
