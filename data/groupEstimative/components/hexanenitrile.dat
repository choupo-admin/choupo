/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanenitrile  (C6H11N, CAS 628-73-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanenitrile;
formula     C6H11N;
CAS         628-73-9;
InChIKey    AILKHAQXUAOOFU-UHFFFAOYSA-N;
MW          97.161;      // g/mol [origin=calculated method=formula-sum]
Tc          627.96;      // K   [origin=predictive method=joback]
Pc          30.223;      // bar [origin=predictive method=joback]
omega       0.4674;      // -   [origin=predictive method=lee-kesler]
Tb          438.96;      // K   [origin=predictive method=joback]
HvapTb      39428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.434 0.50862 -0.0002716 5.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "capronitrile" "hexanonitrile" "tricapronile" "n-capronitrile" "pentyl cyanide" "1-cyanopentane" "n-amyl cyanide" "nitriles, c6-12" "amyl cyanide" "(c6-c12)alkylnitrile" );
standardThermochemistry
{
    dHf_298   -2290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132820.0
}
