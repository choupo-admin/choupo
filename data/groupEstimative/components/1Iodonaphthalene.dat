/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodonaphthalene  (C10H7I, CAS 90-14-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodonaphthalene;
formula     C10H7I;
CAS         90-14-2;
InChIKey    NHPPIJMARIVBGU-UHFFFAOYSA-N;
MW          254.066;      // g/mol [origin=calculated method=formula-sum]
Tc          846.57;      // K   [origin=predictive method=joback]
Pc          37.226;      // bar [origin=predictive method=joback]
omega       0.3909;      // -   [origin=predictive method=lee-kesler]
Tb          572.18;      // K   [origin=predictive method=joback]
HvapTb      51805.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.56 0.8507 -0.00070248 2.294e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 7; } { group dC_ring; count 3; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanylnaphthalene" "naphthalene, 1-iodo-" "1-naphthyl iodide" ".alpha.-iodonaphthalene" "alpha-iodonaphthalene" "1-iodo-naphthalene" "1-naphthyliodide" "agn-pc-00d0fa" );
gibbsFormation
{
    dHf_298   243270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=300870.0
    phase     gas;
}
