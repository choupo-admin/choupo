/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptadecane, 9-phenethyl-  (C25H44, CAS 5637-96-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptadecane9Phenethyl;
formula     C25H44;
CAS         5637-96-7;
InChIKey    YFDREPVYVBGJDD-UHFFFAOYSA-N;
MW          344.627;      // g/mol [origin=calculated method=formula-sum]
Tc          984.53;      // K   [origin=predictive method=joback]
Pc          9.301;      // bar [origin=predictive method=joback]
omega       0.8170;      // -   [origin=predictive method=lee-kesler]
Tb          797.84;      // K   [origin=predictive method=joback]
HvapTb      73132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.424 2.30584 -0.0013706 3.113e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-octylundecylbenzene" "benzene, (3-octylundecyl)-" "(3-octylundecyl)benzene" "9-(2-phenylethyl)heptadecane" "9-(2'-phenylethyl)heptadecane" );
standardThermochemistry
{
    dHf_298   -328080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1013.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=269590.0
}
