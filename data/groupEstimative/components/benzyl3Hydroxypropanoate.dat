/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl 3-hydroxypropanoate  (C10H12O3, CAS 14464-10-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzyl3Hydroxypropanoate;
formula     C10H12O3;
CAS         14464-10-9;
InChIKey    RDRDBYYUPACJJT-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          801.80;      // K   [origin=predictive method=joback]
Pc          32.653;      // bar [origin=predictive method=joback]
omega       1.0375;      // -   [origin=predictive method=lee-kesler]
Tb          605.48;      // K   [origin=predictive method=joback]
HvapTb      64216.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.407 0.8541 -0.0004872 8.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl) 3-oxidanylpropanoate" "benzyl 3-hydroxypropionate" "propanoic acid, 3-hydroxy-, phenylmethyl ester" "hydracrylic acid benzyl ester" "3-hydroxy-propanoic acid phenylmethyl ester" );
standardThermochemistry
{
    dHf_298   -482710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-301460.0
}
