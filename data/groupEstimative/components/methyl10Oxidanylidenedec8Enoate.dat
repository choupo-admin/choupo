/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 10-oxidanylidenedec-8-enoate  (C11H18O3, CAS 65114-83-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl10Oxidanylidenedec8Enoate;
formula     C11H18O3;
CAS         65114-83-2;
InChIKey    MRYISIMMTIXZMC-UHFFFAOYSA-N;
MW          198.262;      // g/mol [origin=calculated method=formula-sum]
Tc          742.18;      // K   [origin=predictive method=joback]
Pc          21.775;      // bar [origin=predictive method=joback]
omega       0.8197;      // -   [origin=predictive method=lee-kesler]
Tb          562.32;      // K   [origin=predictive method=joback]
HvapTb      54165.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.516 0.98852 -0.0005568 1.079e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=CH; count 1; } { group CHO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH; count 2; } { group OdCH_al; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-decenoic acid, 10-oxo-, methyl ester, (e)-" );
standardThermochemistry
{
    dHf_298   -556010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-287930.0
}
