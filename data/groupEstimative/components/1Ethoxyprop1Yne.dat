/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethoxyprop-1-yne  (C5H8O, CAS 14273-06-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethoxyprop1Yne;
formula     C5H8O;
CAS         14273-06-4;
InChIKey    AEENFMCEQQAULS-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          535.61;      // K   [origin=predictive method=joback]
Pc          41.356;      // bar [origin=predictive method=joback]
omega       0.2428;      // -   [origin=predictive method=lee-kesler]
Tb          345.42;      // K   [origin=predictive method=joback]
HvapTb      31286.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.401 0.26584 -4.506e-05 -2.752e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2O; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group tC; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propynylethyl ether" "1-propyne, 1-ethoxy-" );
standardThermochemistry
{
    dHf_298   -6450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     333.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89020.0
}
