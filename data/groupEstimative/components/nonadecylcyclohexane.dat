/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonadecylcyclohexane  (C25H50, CAS 22349-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonadecylcyclohexane;
formula     C25H50;
CAS         22349-03-7;
InChIKey    YVTPTBVYGTYTKP-UHFFFAOYSA-N;
MW          350.675;      // g/mol [origin=calculated method=formula-sum]
Tc          973.78;      // K   [origin=predictive method=joback]
Pc          8.585;      // bar [origin=predictive method=joback]
omega       0.7732;      // -   [origin=predictive method=lee-kesler]
Tb          791.15;      // K   [origin=predictive method=joback]
HvapTb      71673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.442 2.50092 -0.0014172 2.959e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 23; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane, nonadecyl-" "1-cyclohexylnonadecane" "nonadecane,1-cyclohexyl- (6ci,8ci); nonadecylcyclohexane; n-nonadecylcyclohexane" );
gibbsFormation
{
    dHf_298   -505010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1099.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184070.0
    phase     gas;
}
