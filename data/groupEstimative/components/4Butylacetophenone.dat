/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-butylacetophenone  (C12H16O, CAS 37920-25-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Butylacetophenone;
formula     C12H16O;
CAS         37920-25-5;
InChIKey    MQESVSITPLILCO-UHFFFAOYSA-N;
MW          176.259;      // g/mol [origin=calculated method=formula-sum]
Tc          768.93;      // K   [origin=predictive method=joback]
Pc          25.227;      // bar [origin=predictive method=joback]
omega       0.6136;      // -   [origin=predictive method=lee-kesler]
Tb          559.69;      // K   [origin=predictive method=joback]
HvapTb      51990.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.267 0.97744 -0.00057446 1.2316e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-butylphenyl)ethanone" "p-n-butylacetophenone" "p-butylacetophenone" "ethanone, 1-(4-butylphenyl)-" "4'-n-butylacetophenone" "1-(4-butylphenyl)ethan-1-one" "1-acetyl-4-butylbenzene" "4-n-butylacetophenone;acetophenone,4'-butyl- (6ci);1-(4-butylphenyl)ethanone;4'-butylacetophenone;p-butylacetophenone;" );
standardThermochemistry
{
    dHf_298   -178530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24020.0
}
