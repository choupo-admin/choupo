/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, (propylthio)-  (C9H12S, CAS 874-79-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenePropylthio;
formula     C9H12S;
CAS         874-79-3;
InChIKey    NWYDLOBJQIJDGH-UHFFFAOYSA-N;
MW          152.255;      // g/mol [origin=calculated method=formula-sum]
Tc          731.63;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       0.4064;      // -   [origin=predictive method=lee-kesler]
Tb          500.98;      // K   [origin=predictive method=joback]
HvapTb      44721.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.598 0.77431 -0.0004568 9.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propylsulfanylbenzene" "(propylthio)benzene" "phenyl propyl sulfide" "sulfide, phenyl propyl" "propyl phenyl sulfide" "(1-thiabutyl)benzene" "n-propyl phenyl sulfide" "fenyl-propylsulfid" "(propylsulfanyl)benzene" "phenyl n-propyl sulfide" "phenyl n-propyl sulphide" "benzene, (propylthio)- (9ci)" );
gibbsFormation
{
    dHf_298   49310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=170430.0
    phase     gas;
}
