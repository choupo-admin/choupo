/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane,(3-bromophenyl)methoxydimethyl-  (C9H13BrOSi, CAS 62244-46-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H13BrOSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silane3BromophenylMethoxydimethyl;
formula     C9H13BrOSi;
CAS         62244-46-6;
InChIKey    NJBZFZDSRKLCND-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          245.191;      // g/mol [origin=calculated method=formula-sum]
Tc          758.27;      // K   [origin=predictive method=joback]
Pc          29.730;      // bar [origin=predictive method=joback]
omega       0.4329;      // -   [origin=predictive method=lee-kesler]
Tb          527.16;      // K   [origin=predictive method=joback]
HvapTb      47705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.61 0.48926 2.444e-05 -1.414e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group Br; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-bromophenyl)-methoxy-dimethyl-silane" "(3-bromophenyl)-methoxy-dimethylsilane" "silane, (3-bromophenyl)methoxydimethyl-" );
standardThermochemistry
{
    dHf_298   -221540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-67760.0
}
