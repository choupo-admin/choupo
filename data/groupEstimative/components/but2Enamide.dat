/*--------------------------------*- Choupo -*-----------------------*\
  Component: but-2-enamide  (C4H7NO, CAS 31110-30-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        but2Enamide;
formula     C4H7NO;
CAS         31110-30-2;
InChIKey    NQQRXZOPZBKCNF-UHFFFAOYSA-N;
MW          85.106;      // g/mol [origin=calculated method=formula-sum]
Tc          627.33;      // K   [origin=predictive method=joback]
Pc          48.902;      // bar [origin=predictive method=joback]
omega       0.4682;      // -   [origin=predictive method=lee-kesler]
Tb          421.68;      // K   [origin=predictive method=joback]
HvapTb      41843.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.08 0.43772 -0.0003023 8.576e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trans-2-butenamide" "2-butenamide, (2e)-" "2-butenamide, (2z)-" );
gibbsFormation
{
    dHf_298   -87460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=550.0
    phase     gas;
}
