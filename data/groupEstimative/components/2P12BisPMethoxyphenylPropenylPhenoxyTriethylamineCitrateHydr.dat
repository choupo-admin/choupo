/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(p-(1,2-bis(p-methoxyphenyl)propenyl)phenoxy)triethylamine citrate hydrate  (C29H35NO3, CAS 2041-74-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2P12BisPMethoxyphenylPropenylPhenoxyTriethylamineCitrateHydr;
formula     C29H35NO3;
CAS         2041-74-9;
InChIKey    AOJMEENUWYXESO-IADYIPOJSA-N;
MW          445.603;      // g/mol [origin=calculated method=formula-sum]
Tc          1281.29;      // K   [origin=predictive method=joback]
Pc          10.785;      // bar [origin=predictive method=joback]
omega       0.9826;      // -   [origin=predictive method=lee-kesler]
Tb          1041.72;      // K   [origin=predictive method=joback]
HvapTb      98353.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.046 2.2978 -0.00131428 2.597e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group ACH; count 12; } { group AC; count 6; } { group CH3O; count 2; } { group CH2O; count 1; } { group CH2N; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group dC; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group O; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-[(z)-1,2-bis(4-methoxyphenyl)prop-1-enyl]phenoxy]-n,n-diethyl-ethanamine" "triethylamine, 2-(p-(1,2-bis(p-methoxyphenyl)propenyl)phenoxy)-, citrate, monohydrate" "2-[4-[(z)-1,2-bis(4-methoxyphenyl)prop-1-enyl]phenoxy]-n,n-diethylethanamine" );
gibbsFormation
{
    dHf_298   -198200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     982.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=360540.0
    phase     gas;
}
