/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenolic acid  (C17H18O4, CAS 126-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diphenolicAcid;
formula     C17H18O4;
CAS         126-00-1;
InChIKey    VKOUCJUTMGHNOR-UHFFFAOYSA-N;
MW          286.327;      // g/mol [origin=calculated method=formula-sum]
Tc          1202.04;      // K   [origin=predictive method=joback]
Pc          31.491;      // bar [origin=predictive method=joback]
omega       1.4478;      // -   [origin=predictive method=lee-kesler]
Tb          945.44;      // K   [origin=predictive method=joback]
HvapTb      99884.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-118.088 1.94682 -0.00172052 6.082e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4-bis(4-hydroxyphenyl)pentanoic acid" "4,4-bis(4-hydroxyphenyl)valeric acid" "4,4-bis(p-hydroxyphenyl)pentanoic acid" "4,4-bis(p-hydroxyphenyl)valeric acid" "gamma,gamma-bis(p-hydroxyphenyl)valeric acid" "benzenebutanoic acid, 4-hydroxy-.gamma.-(4-hydroxyphenyl)-.gamma.-methyl-" "4-hydroxy-gamma-(4-hydroxyphenyl)-gamma-methylbenzenebutanoic acid" "benzenebutanoic acid, 4-hydroxy-gamma-(4-hydroxyphenyl)-gamma-methyl-" "valeric acid,4-bis(p-hydroxyphenyl)-" ".gamma.,.gamma.-bis(p-hydroxyphenyl)valeric acid" "o503" "valeric acid, 4,4-bis(p-hydroxyphenyl)-" );
standardThermochemistry
{
    dHf_298   -634790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     672.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-333230.0
}
