/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetylethylenimine  (C4H7NO, CAS 460-07-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetylethylenimine;
formula     C4H7NO;
CAS         460-07-1;
InChIKey    OTIXUSNHAKOJBX-UHFFFAOYSA-N;
MW          85.106;      // g/mol [origin=calculated method=formula-sum]
Tc          550.74;      // K   [origin=predictive method=joback]
Pc          50.802;      // bar [origin=predictive method=joback]
omega       0.4131;      // -   [origin=predictive method=lee-kesler]
Tb          364.57;      // K   [origin=predictive method=joback]
HvapTb      33337.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.14 0.66672 -0.0006097 2.2216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(aziridin-1-yl)ethanone" "1-acetylaziridine" "acetylethyleneimine" "aziridine, 1-acetyl-" "n-acetylethyleneimine" "ethanone, 1-(1-aziridinyl)-" "acetylethylenimide" "n-acetylaziridine" "n-acetylethylenimine" "1-(1-aziridinyl)ethanone" "n-acetylethylenimine, contains 30% benzene" "aziridine,1-acetyl- (6ci,7ci,8ci,9ci); 1-acetylaziridine; 1-acetylethylenimine;acetylethylenimide; acetylethylenimine; n-acetylaziridine; n-acetylethylenimine" );
standardThermochemistry
{
    dHf_298   -71640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     286.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45220.0
}
