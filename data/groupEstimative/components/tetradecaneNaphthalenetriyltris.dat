/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecane, naphthalenetriyltris-  (C52H92, CAS 224051-16-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecaneNaphthalenetriyltris;
formula     C52H92;
CAS         224051-16-5;
InChIKey    CZNFBUXHERRVTD-UHFFFAOYSA-N;
MW          717.308;      // g/mol [origin=calculated method=formula-sum]
Tc          2233.46;      // K   [origin=predictive method=joback]
Pc          3.101;      // bar [origin=predictive method=joback]
omega       -0.5804;      // -   [origin=predictive method=lee-kesler]
Tb          1449.96;      // K   [origin=predictive method=joback]
HvapTb      137248.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.831 4.68276 -0.0027718 6.395e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 36; } { group ACH; count 5; } { group AC; count 2; } { group ACCH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 39; } { group dCH_ring; count 5; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,7-tri(tetradecyl)naphthalene" );
gibbsFormation
{
    dHf_298   -723420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1947.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=577130.0
    phase     gas;
}
