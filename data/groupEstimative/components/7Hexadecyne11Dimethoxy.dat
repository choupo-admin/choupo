/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-hexadecyne, 1,1-dimethoxy-  (C18H34O2, CAS 41862-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Hexadecyne11Dimethoxy;
formula     C18H34O2;
CAS         41862-85-5;
InChIKey    RCTGSQGPAGWZKX-UHFFFAOYSA-N;
MW          282.468;      // g/mol [origin=calculated method=formula-sum]
Tc          840.08;      // K   [origin=predictive method=joback]
Pc          12.646;      // bar [origin=predictive method=joback]
omega       0.8317;      // -   [origin=predictive method=lee-kesler]
Tb          664.84;      // K   [origin=predictive method=joback]
HvapTb      62246.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.402 1.44356 -0.00064446 7.188e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH; count 1; } { group CH3O; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } { group tC; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethoxyhexadec-7-yne" "7-hexadecynal diethyl acetal" "7-hexadecynal dimethyl acetal" );
gibbsFormation
{
    dHf_298   -412270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     841.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91040.0
    phase     gas;
}
