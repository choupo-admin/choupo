/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-3-isopropyl-4-methylbenzene  (C10H13Cl, CAS 63831-93-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro3Isopropyl4Methylbenzene;
formula     C10H13Cl;
CAS         63831-93-6;
InChIKey    ISPBEETWYSGCDQ-UHFFFAOYSA-N;
MW          168.664;      // g/mol [origin=calculated method=formula-sum]
Tc          720.04;      // K   [origin=predictive method=joback]
Pc          27.527;      // bar [origin=predictive method=joback]
omega       0.4144;      // -   [origin=predictive method=lee-kesler]
Tb          502.03;      // K   [origin=predictive method=joback]
HvapTb      45451.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.3 0.76866 -0.00044092 9.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-1-methyl-2-propan-2-yl-benzene" "4-chloro-1-methyl-2-propan-2-ylbenzene" "4-chloro-1-methyl-2-(propan-2-yl)benzene" );
gibbsFormation
{
    dHf_298   -57160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112100.0
    phase     gas;
}
