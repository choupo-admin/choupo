/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4-trimethyl-4-heptanol  (C10H22O, CAS 57233-31-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224Trimethyl4Heptanol;
formula     C10H22O;
CAS         57233-31-5;
InChIKey    KNACVESXMPHLNM-UHFFFAOYSA-N;
MW          158.285;      // g/mol [origin=calculated method=formula-sum]
Tc          690.01;      // K   [origin=predictive method=joback]
Pc          23.842;      // bar [origin=predictive method=joback]
omega       0.7434;      // -   [origin=predictive method=lee-kesler]
Tb          514.12;      // K   [origin=predictive method=joback]
HvapTb      51941.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.857 1.2395 -0.0008942 2.614e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group C; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4-trimethylheptan-4-ol" );
standardThermochemistry
{
    dHf_298   -419460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-97820.0
}
