/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzo[fg,ij]phenanthro[2,1,10,9,8,7-pqrstuv]pentaphene  (C34H16, CAS 187-94-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzoFgIjPhenanthro2110987PqrstuvPentaphene;
formula     C34H16;
CAS         187-94-0;
InChIKey    RKRZAQAOKNVQQO-UHFFFAOYSA-N;
MW          424.502;      // g/mol [origin=calculated method=formula-sum]
Tc          1465.44;      // K   [origin=predictive method=joback]
Pc          17.217;      // bar [origin=predictive method=joback]
omega       1.3132;      // -   [origin=predictive method=lee-kesler]
Tb          1184.06;      // K   [origin=predictive method=joback]
HvapTb      111066.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-220.67 2.9464 -0.00297324 1.172e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 16; } { group AC; count 18; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 16; } { group dC_ring; count 18; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibenzo(fg,ij)phenanthro(2,1,10,9,8,7-pqrstuv)pentaphene" "3,4:11,12-dibenzobisanthene;dibenzo[cd,pq]bisanthene" );
standardThermochemistry
{
    dHf_298   937470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1207580.0
}
