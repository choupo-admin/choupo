/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-carene  (C10H16, CAS 29050-33-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Carene;
formula     C10H16;
CAS         29050-33-7;
InChIKey    LGNSZMLHOYDATP-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          643.68;      // K   [origin=predictive method=joback]
Pc          28.354;      // bar [origin=predictive method=joback]
omega       0.2986;      // -   [origin=predictive method=lee-kesler]
Tb          436.21;      // K   [origin=predictive method=joback]
HvapTb      36375.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.14 1.42896 -0.00132328 5.223e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 3; } { group C; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7,7-trimethylbicyclo[4.1.0]hept-4-ene" "4,7,7-trimethylbicyclo[4.1.0]hept-2-ene" "4-carene, (1s,3r,6r)-(-)-" "(+)-4-carene" "(1r,4r)-4,7,7-trimethylbicyclo[4.1.0]hept-2-ene" "(1r,4s)-4,7,7-trimethylbicyclo[4.1.0]hept-2-ene" "4-carene, (1s,3s,6r)-(-)-" );
gibbsFormation
{
    dHf_298   -77950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     332.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=151770.0
    phase     gas;
}
