/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1-hydroxy-1-methylethyl-2-methyl-1,3-dioxane  (C8H16O3, CAS 39239-96-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        21Hydroxy1Methylethyl2Methyl13Dioxane;
formula     C8H16O3;
CAS         39239-96-8;
InChIKey    JTBUTVUSECYYFH-UHFFFAOYSA-N;
MW          160.213;      // g/mol [origin=calculated method=formula-sum]
Tc          753.76;      // K   [origin=predictive method=joback]
Pc          37.045;      // bar [origin=predictive method=joback]
omega       0.7666;      // -   [origin=predictive method=lee-kesler]
Tb          545.28;      // K   [origin=predictive method=joback]
HvapTb      57083.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.52 1.33166 -0.0011994 4.559e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 2; } { group OH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methyl-1,3-dioxan-2-yl)propan-2-ol" );
gibbsFormation
{
    dHf_298   -563870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-270780.0
    phase     gas;
}
