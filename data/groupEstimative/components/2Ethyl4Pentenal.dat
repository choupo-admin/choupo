/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-4-pentenal  (C7H12O, CAS 5204-80-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl4Pentenal;
formula     C7H12O;
CAS         5204-80-8;
InChIKey    UADJTDURPOSPRM-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          584.07;      // K   [origin=predictive method=joback]
Pc          32.064;      // bar [origin=predictive method=joback]
omega       0.4477;      // -   [origin=predictive method=lee-kesler]
Tb          404.66;      // K   [origin=predictive method=joback]
HvapTb      36838.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.252 0.62922 -0.0003761 8.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylpent-4-enal" "4-pentenal, 2-ethyl-" );
gibbsFormation
{
    dHf_298   -153240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6060.0
    phase     gas;
}
