/*--------------------------------*- Choupo -*-----------------------*\
  Component: rutinose  (C12H22O10, CAS 90-74-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        rutinose;
formula     C12H22O10;
CAS         90-74-4;
InChIKey    OVVGHDNPYGTYIT-ZLJAYJTQSA-N;
MW          326.298;      // g/mol [origin=calculated method=formula-sum]
Tc          1565.32;      // K   [origin=predictive method=joback]
Pc          38.340;      // bar [origin=predictive method=joback]
omega       1.2643;      // -   [origin=predictive method=lee-kesler]
Tb          1197.48;      // K   [origin=predictive method=joback]
HvapTb      168875.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.461 1.34482 -0.0004218 -7.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 8; } { group OH; count 7; } { group CH2O; count 1; } { group CH-O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH_ring; count 10; } { group OH; count 7; } { group O; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3s,4s,5s)-6-[[(2r,3r,4r,5r,6s)-6-methyl-3,4,5-tris(oxidanyl)oxan-2-yl]oxymethyl]oxane-2,3,4,5-tetrol" "(5xi)-6-o-(6-deoxy-" "a-l-mannopyranosyl)-" "a-d-lyxo-hexopyranose" "6-o-(alpha-l-rhamnosyl)-d-glucose" "6-o-(alpha-l-rhamnopyranosyl)-d-glucopyranose" "(2r,3s,4s,5s)-6-[[(2r,3r,4r,5r,6s)-3,4,5-trihydroxy-6-methyloxan-2-yl]oxymethyl]oxane-2,3,4,5-tetrol" );
gibbsFormation
{
    dHf_298   -1806920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1197600.0
    phase     gas;
}
