/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(4-hydroxy-3-isopropylphenyl)propane  (C21H28O2, CAS 127-54-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Bis4Hydroxy3IsopropylphenylPropane;
formula     C21H28O2;
CAS         127-54-8;
InChIKey    IJWIRZQYWANBMP-UHFFFAOYSA-N;
MW          312.453;      // g/mol [origin=calculated method=formula-sum]
Tc          1145.65;      // K   [origin=predictive method=joback]
Pc          19.424;      // bar [origin=predictive method=joback]
omega       1.0846;      // -   [origin=predictive method=lee-kesler]
Tb          900.53;      // K   [origin=predictive method=joback]
HvapTb      92172.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.09 2.16892 -0.00173784 5.77e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 1; } { group ACH; count 6; } { group AC; count 2; } { group ACCH; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 2; } { group C; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(4-oxidanyl-3-propan-2-yl-phenyl)propan-2-yl]-2-propan-2-yl-phenol" "4,4'-isopropylidenebis(2-isopropylphenol)" "4,4'-propane-2,2-diylbis(2-isopropylphenol)" "bisphenol g" "phenol,4'-isopropylidenebis[2-isopropyl-" "phenol,4'-(1-methylethylidene)bis[2-(1-methylethyl)-" "4-[2-(4-hydroxy-3-propan-2-yl-phenyl)propan-2-yl]-2-propan-2-yl-phenol" "4-[2-(4-hydroxy-3-propan-2-ylphenyl)propan-2-yl]-2-propan-2-ylphenol" "2,2-bis(4-hydroxy-3-isopropylphenyl)propane;4,4a'a inverted exclamation marka'a -isopropylidenebis(2-isopropylphenol)" );
gibbsFormation
{
    dHf_298   -400580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     743.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20220.0
    phase     gas;
}
