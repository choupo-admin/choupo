/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-cyclotetradecadiyne  (C14H20, CAS 1540-80-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Cyclotetradecadiyne;
formula     C14H20;
CAS         1540-80-3;
InChIKey    BVTCHBNCNJEJTD-UHFFFAOYSA-N;
MW          188.314;      // g/mol [origin=calculated method=formula-sum]
Tc          856.13;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       0.2814;      // -   [origin=predictive method=lee-kesler]
Tb          579.22;      // K   [origin=predictive method=joback]
HvapTb      52488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.75 1.1444 -0.00050432 3.156e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 4; } { group CH2_ring; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclotetradeca-1,8-diyne" );
standardThermochemistry
{
    dHf_298   262330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     736.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=456360.0
}
