  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        einecs2716900;
formula     C15H18O2;
CAS         68604-39-7;
InChIKey    AGHWLRVHEXUTPZ-ISFAVVKVSA-N;
MW          230.307;      // g/mol [origin=calculated method=formula-sum]
Tc          818.99;      // K   [origin=predictive method=joback]
Pc          18.092;      // bar [origin=predictive method=joback]
omega       0.6818;      // -   [origin=predictive method=lee-kesler]
Tb          618.50;      // K   [origin=predictive method=joback]
HvapTb      55511.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.239 1.45402 -0.0011395 3.646e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 5; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 11; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (3e,5e,7e,9e,11e)-tetradeca-3,5,7,9,11,13-hexaenoate" "stillbottoms from distillation of (c8-c18) and c18 unsaturated alkyl carboxylic acid methyl ester" "fatty acids, c8-18 and c18-unsatd, me esters, distn. residues" );
standardThermochemistry
{
    dHf_298   41320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     754.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=253990.0
}
