/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentanecarboxylic acid, 1-methyl-, methyl ester  (C8H14O2, CAS 4630-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentanecarboxylicAcid1MethylMethylEster;
formula     C8H14O2;
CAS         4630-83-5;
InChIKey    SUCGJXDLZCDFRV-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          665.51;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.4032;      // -   [origin=predictive method=lee-kesler]
Tb          456.38;      // K   [origin=predictive method=joback]
HvapTb      39915.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.45 1.13264 -0.0009768 3.644e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 1-methylcyclopentane-1-carboxylate" "cyclopentanoic acid, 1-methyl, methyl ester" "methyl 1-methylcyclopentanecarboxylate" );
standardThermochemistry
{
    dHf_298   -450010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-262830.0
}
