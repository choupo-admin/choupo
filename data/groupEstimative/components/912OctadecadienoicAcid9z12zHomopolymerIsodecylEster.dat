/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,12-octadecadienoic acid (9z,12z)-, homopolymer, isodecyl ester  (C28H52O2, CAS 64059-72-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        912OctadecadienoicAcid9z12zHomopolymerIsodecylEster;
formula     C28H52O2;
CAS         64059-72-9;
InChIKey    WLKDGTSPGJVXQE-MURFETPASA-N;
MW          420.722;      // g/mol [origin=calculated method=formula-sum]
Tc          1111.28;      // K   [origin=predictive method=joback]
Pc          6.965;      // bar [origin=predictive method=joback]
omega       0.6248;      // -   [origin=predictive method=lee-kesler]
Tb          906.34;      // K   [origin=predictive method=joback]
HvapTb      84857.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.201 2.65496 -0.0015756 3.592e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 18; } { group CH; count 1; } { group CH=CH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 19; } { group CH; count 1; } { group dCH; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-methylnonyl (9z,12z)-octadeca-9,12-dienoate" );
standardThermochemistry
{
    dHf_298   -709370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1275.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32510.0
}
