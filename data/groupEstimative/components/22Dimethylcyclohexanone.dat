/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethylcyclohexanone  (C8H14O, CAS 1193-47-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethylcyclohexanone;
formula     C8H14O;
CAS         1193-47-1;
InChIKey    KNSPBSQWRKKAPI-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          700.70;      // K   [origin=predictive method=joback]
Pc          34.561;      // bar [origin=predictive method=joback]
omega       0.3327;      // -   [origin=predictive method=lee-kesler]
Tb          470.25;      // K   [origin=predictive method=joback]
HvapTb      36927.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.55 1.00954 -0.000781 2.786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylcyclohexan-1-one" "cyclohexanone, 2,2-dimethyl-" "dimethylcyclohexanone" "cyclohexanone, dimethyl-" "cyclohexanone,2-dimethyl-" "agn-pc-04y21n" "2,2-dimethyl-cyclohexan-1-one" "2,2-dimethyl cyclohexan-1-one" "2,2-dimethyl cyclohexanone" );
standardThermochemistry
{
    dHf_298   -276590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87150.0
}
