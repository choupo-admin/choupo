/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,5,5-tetramethylcyclopentadiene  (C9H14, CAS 4249-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1455Tetramethylcyclopentadiene;
formula     C9H14;
CAS         4249-11-0;
InChIKey    LSFQBLLDQCVIGF-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          636.26;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.3067;      // -   [origin=predictive method=lee-kesler]
Tb          429.32;      // K   [origin=predictive method=joback]
HvapTb      36642.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.61 1.05148 -0.00096628 3.92e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,5,5-tetramethylcyclopenta-1,3-diene" );
gibbsFormation
{
    dHf_298   -60750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=96620.0
    phase     gas;
}
