/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyldodecane  (C14H30, CAS 49598-54-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyldodecane;
formula     C14H30;
CAS         49598-54-1;
InChIKey    ATWISEHEXAEGKB-UHFFFAOYSA-N;
MW          198.394;      // g/mol [origin=calculated method=formula-sum]
Tc          684.67;      // K   [origin=predictive method=joback]
Pc          15.463;      // bar [origin=predictive method=joback]
omega       0.5821;      // -   [origin=predictive method=lee-kesler]
Tb          516.69;      // K   [origin=predictive method=joback]
HvapTb      45462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.311 1.45968 -0.0009096 2.273e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 9; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 9; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecane, 2,2-dimethyl-" "agn-pc-02q74x" );
standardThermochemistry
{
    dHf_298   -341040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     662.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69840.0
}
