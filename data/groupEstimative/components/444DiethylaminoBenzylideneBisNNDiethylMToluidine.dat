/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-(4-(diethylamino)benzylidene)bis(n,n-diethyl-m-toluidine)  (C33H47N3, CAS 68582-45-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        444DiethylaminoBenzylideneBisNNDiethylMToluidine;
formula     C33H47N3;
CAS         68582-45-6;
InChIKey    JDEVVVLLEIZNAL-UHFFFAOYSA-N;
MW          485.76;      // g/mol [origin=calculated method=formula-sum]
Tc          1342.46;      // K   [origin=predictive method=joback]
Pc          8.324;      // bar [origin=predictive method=joback]
omega       0.8007;      // -   [origin=predictive method=lee-kesler]
Tb          1096.46;      // K   [origin=predictive method=joback]
HvapTb      104931.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.084 2.98236 -0.0018708 4.452e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 3; } { group ACH; count 10; } { group AC; count 5; } { group ACCH3; count 2; } { group ACCH; count 1; } { group CH2N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 6; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[4-(diethylamino)-2-methyl-phenyl]-[4-(diethylamino)phenyl]methyl]-n,n-diethyl-3-methyl-aniline" "benzenamine, 4,4'-((4-(diethylamino)phenyl)methylene)bis(n,n-diethyl-3-methyl-" "benzenamine, 4,4'-[[4-(diethylamino)phenyl]methylene]bis[n,n-diethyl-3-methyl-" "agn-pc-03w779" "4-[[4-(diethylamino)-2-methylphenyl]-[4-(diethylamino)phenyl]methyl]-n,n-diethyl-3-methylaniline" "4-[deuterio-[4-(diethylamino)-2-methylphenyl]-[4-(diethylamino)phenyl]methyl]-n,n-diethyl-3-methylaniline" );
gibbsFormation
{
    dHf_298   125100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1130.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=845960.0
    phase     gas;
}
