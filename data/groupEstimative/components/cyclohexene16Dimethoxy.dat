/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene, 1,6-dimethoxy-  (C8H14O2, CAS 61860-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene16Dimethoxy;
formula     C8H14O2;
CAS         61860-71-7;
InChIKey    ROYPENREPGTGPB-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          653.80;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.4153;      // -   [origin=predictive method=lee-kesler]
Tb          451.17;      // K   [origin=predictive method=joback]
HvapTb      39605.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.09 0.64404 -0.00019064 -3.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH=C; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6-dimethoxycyclohexene" );
gibbsFormation
{
    dHf_298   -372260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-148740.0
    phase     gas;
}
