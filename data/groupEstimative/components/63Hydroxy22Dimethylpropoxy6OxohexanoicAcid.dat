/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-(3-hydroxy-2,2-dimethylpropoxy)-6-oxohexanoic acid  (C11H20O5, CAS 70247-79-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        63Hydroxy22Dimethylpropoxy6OxohexanoicAcid;
formula     C11H20O5;
CAS         70247-79-9;
InChIKey    UEGQJTSGVSBXCN-UHFFFAOYSA-N;
MW          232.276;      // g/mol [origin=calculated method=formula-sum]
Tc          930.95;      // K   [origin=predictive method=joback]
Pc          23.360;      // bar [origin=predictive method=joback]
omega       1.4218;      // -   [origin=predictive method=lee-kesler]
Tb          743.96;      // K   [origin=predictive method=joback]
HvapTb      80034.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.716 1.20464 -0.0007548 1.723e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C; count 1; } { group OH; count 1; } { group CH2COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-(2,2-dimethyl-3-oxidanyl-propoxy)-6-oxidanylidene-hexanoic acid" "hexanedioic acid, ester with 2,2-dimethyl-1,3-propanediol" "6-(3-hydroxy-2,2-dimethyl-propoxy)-6-oxo-hexanoic acid" );
gibbsFormation
{
    dHf_298   -1098900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     700.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-746520.0
    phase     gas;
}
