/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-morpholin-4-yl-phenol  (C10H13NO2, CAS 6291-23-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Morpholin4YlPhenol;
formula     C10H13NO2;
CAS         6291-23-2;
InChIKey    GPPRMDWJKBFBMZ-UHFFFAOYSA-N;
MW          179.219;      // g/mol [origin=calculated method=formula-sum]
Tc          840.88;      // K   [origin=predictive method=joback]
Pc          44.682;      // bar [origin=predictive method=joback]
omega       0.7104;      // -   [origin=predictive method=lee-kesler]
Tb          595.04;      // K   [origin=predictive method=joback]
HvapTb      60263.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.82 1.3086 -0.00108926 3.628e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-morpholin-4-ylphenol" "4-morpholinophenol" "4-p-hydroxyphenylmorpholine" "phenol,4-(4-morpholinyl)-" );
gibbsFormation
{
    dHf_298   -174160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60030.0
    phase     gas;
}
