/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperidine, 1,1'-(1,4-phenylenedicarbonyl)bis-  (C18H24N2O2, CAS 15088-30-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperidine1114PhenylenedicarbonylBis;
formula     C18H24N2O2;
CAS         15088-30-9;
InChIKey    ZHHMFDCUOHNPTM-UHFFFAOYSA-N;
MW          300.402;      // g/mol [origin=calculated method=formula-sum]
Tc          1056.29;      // K   [origin=predictive method=joback]
Pc          23.070;      // bar [origin=predictive method=joback]
omega       1.0251;      // -   [origin=predictive method=lee-kesler]
Tb          815.62;      // K   [origin=predictive method=joback]
HvapTb      77310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-172.59 2.0836 -0.00147296 3.9572e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group ACH; count 4; } { group AC; count 2; } { group CON_CH2_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperidin-1-yl-(4-piperidin-1-ylcarbonylphenyl)methanone" "piperidine, 1,1'-terephthaloyldi-" "piperidyl 4-(piperidylcarbonyl)phenyl ketone" "benzene-1,4-diylbis(piperidin-1-ylmethanone)" "1,1'-[1,4-phenylenedi(carbonyl)]dipiperidine" "brd-k47901417-001-01-4" "[4-(piperidine-1-carbonyl)phenyl]-piperidin-1-ylmethanone" );
gibbsFormation
{
    dHf_298   -118250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     813.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=255700.0
    phase     gas;
}
