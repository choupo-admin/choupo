/*--------------------------------*- Choupo -*-----------------------*\
  Component: mboea  (C17H22N2, CAS 19900-65-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mboea;
formula     C17H22N2;
CAS         19900-65-3;
InChIKey    CBEVWPCAHIAUOD-UHFFFAOYSA-N;
MW          254.377;      // g/mol [origin=calculated method=formula-sum]
Tc          1046.55;      // K   [origin=predictive method=joback]
Pc          21.959;      // bar [origin=predictive method=joback]
omega       0.9779;      // -   [origin=predictive method=lee-kesler]
Tb          806.90;      // K   [origin=predictive method=joback]
HvapTb      81918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.197 1.34684 -0.00078204 1.645e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 6; } { group AC; count 1; } { group ACCH2; count 3; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(4-azanyl-3-ethyl-phenyl)methyl]-2-ethyl-aniline" "4,4'-methylenebis(2-ethylaniline)" "4,4'-methylenebis(2-ethylbenzenamine)" "bis(4-amino-3-ethylphenyl)methane" "4,4'-methylenebis(o-ethylaniline)" "aniline, 4,4'-methylenebis(o-ethyl-" "benzenamine, 4,4'-methylenebis(2-ethyl-" "benzenamine, 4,4'-methylenebis[2-ethyl-" "4,4'-methylene-bis(2-ethylbenzeneamine) [me-ddm]" "4,4'-methylene-bis(2-ethylaniline)" "4-[(4-amino-3-ethylphenyl)methyl]-2-ethylaniline" "aniline,4,4'-methylenebis[2-ethyl- (8ci);3,3'-diethyl-4,4'-diaminodiphenylmethane;4,4'-diamino-3,3'-diethyldiphenylmethane;4,4'-methylenebis(2-ethylaniline);4,4'-methylenebis(o-ethylaniline);4,4'-methylenebis[2-ethylbenzamine];araldite hy 350;c 100s (amine);h 256 (amine);hy 450;kayaharda-a;" );
standardThermochemistry
{
    dHf_298   100550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     683.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=411460.0
}
