/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(trifluoromethyl)benzene  (C8H4F6, CAS 402-31-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BisTrifluoromethylBenzene;
formula     C8H4F6;
CAS         402-31-3;
InChIKey    SJBBXFLOLUTGCW-UHFFFAOYSA-N;
MW          214.108;      // g/mol [origin=calculated method=formula-sum]
Tc          576.00;      // K   [origin=predictive method=joback]
Pc          27.643;      // bar [origin=predictive method=joback]
omega       0.4392;      // -   [origin=predictive method=lee-kesler]
Tb          403.46;      // K   [origin=predictive method=joback]
HvapTb      28846.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.39 0.9478 -0.00081756 2.62e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene, 1,3-bis(trifluoromethyl)-" "1,3-di(trifluoromethyl)benzene" "m-ditrifluoromethylbenzene" "alpha,alpha,alpha,alpha',alpha',alpha'-hexafluoro-m-xylene" "mtf-tfm" "1,3-bis(trifluoromethyl)-benzene" "a,a,a,a',a',a'-hexafluoro-m-xylene" "m-bis(trifluoromethyl)benzene" "alpha,alpha,alpha,beta,beta,beta-hexafluoro-m-xylene" "m-xylene, .alpha.,.alpha.,.alpha.,.alpha.',.alpha.',.alpha.'-hexafluoro-" "m-ditrifluorotoluene" "hexafluoro-m-xylene" );
gibbsFormation
{
    dHf_298   -1177550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1043920.0
    phase     gas;
}
