/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1'-hydroxymethyleugenol  (C11H14O3, CAS 31706-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hydroxymethyleugenol;
formula     C11H14O3;
CAS         31706-95-3;
InChIKey    DFQDENBMPURIHD-UHFFFAOYSA-N;
MW          194.23;      // g/mol [origin=calculated method=formula-sum]
Tc          817.42;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       1.0170;      // -   [origin=predictive method=lee-kesler]
Tb          621.18;      // K   [origin=predictive method=joback]
HvapTb      64121.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.2 0.74444 -0.00030622 1.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH; count 1; } { group OH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3,4-dimethoxyphenyl)prop-2-en-1-ol" "alpha-ethenyl-3,4-dimethoxybenzenemethanol" "veratryl alcohol, alpha-vinyl- (6ci,8ci)" "benzenemethanol, alpha-ethenyl-3,4-dimethoxy-" "agn-pc-04x3rg" "(1r)-1-(3,4-dimethoxyphenyl)prop-2-en-1-ol" );
standardThermochemistry
{
    dHf_298   -353300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-126530.0
}
