/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyl 3-phenylpropyl sulphide  (C15H16S, CAS 30134-12-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenyl3PhenylpropylSulphide;
formula     C15H16S;
CAS         30134-12-4;
InChIKey    UJRJBPIWQWWQMB-UHFFFAOYSA-N;
MW          228.353;      // g/mol [origin=calculated method=formula-sum]
Tc          917.39;      // K   [origin=predictive method=joback]
Pc          25.533;      // bar [origin=predictive method=joback]
omega       0.5933;      // -   [origin=predictive method=lee-kesler]
Tb          664.94;      // K   [origin=predictive method=joback]
HvapTb      60353.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.957 1.26539 -0.0008144 1.907e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylpropylsulfanylbenzene" "(3-phenylpropylthio)benzene" "sulfide, phenyl 3-phenylpropyl," "[(3-phenylpropyl)sulfanyl]benzene" "benzene,[(3-phenylpropyl)thio]-" );
standardThermochemistry
{
    dHf_298   162000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=333360.0
}
