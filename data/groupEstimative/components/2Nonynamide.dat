/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-nonynamide  (C9H15NO, CAS 3910-40-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Nonynamide;
formula     C9H15NO;
CAS         3910-40-5;
InChIKey    BXJPDSYWRJBHOS-UHFFFAOYSA-N;
MW          153.225;      // g/mol [origin=calculated method=formula-sum]
Tc          749.00;      // K   [origin=predictive method=joback]
Pc          30.796;      // bar [origin=predictive method=joback]
omega       0.6637;      // -   [origin=predictive method=lee-kesler]
Tb          540.92;      // K   [origin=predictive method=joback]
HvapTb      55167.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.115 0.74292 -0.00039836 7.684e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C_C; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group tC; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "non-2-ynamide" "amide hexylpropiolique [french]" "amide hexylpropiolique" );
gibbsFormation
{
    dHf_298   -35580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=165230.0
    phase     gas;
}
