/*--------------------------------*- Choupo -*-----------------------*\
  Component: ddnu  (C14H10Cl2, CAS 2642-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ddnu;
formula     C14H10Cl2;
CAS         2642-81-1;
InChIKey    IEAUXBMXWDAYID-UHFFFAOYSA-N;
MW          249.134;      // g/mol [origin=calculated method=formula-sum]
Tc          912.88;      // K   [origin=predictive method=joback]
Pc          26.111;      // bar [origin=predictive method=joback]
omega       0.5404;      // -   [origin=predictive method=lee-kesler]
Tb          654.66;      // K   [origin=predictive method=joback]
HvapTb      60814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.95 1.0505 -0.00073212 1.938e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-[1-(4-chlorophenyl)ethenyl]benzene" "dmc ethylene" "1,1-bis(p-chlorophenyl)ethylene" "1,1-bis(4-chlorophenyl)ethylene" "1,1-bis(p-chlorophenyl)ethene" "unsym-bis(p-chlorophenyl)ethylene" "ethylene, 1,1-bis(p-chlorophenyl)-" "benzene, 1,1'-ethenylidenebis[4-chloro-" "1-chloro-4-[1-(4-chlorophenyl)ethenyl]benzene" "ddnu (van)" "1,1-bis(4-chlorophenyl)ethyl ene" "unsym-bis(4'-chlorophenyl)ethylene" );
gibbsFormation
{
    dHf_298   201990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=327990.0
    phase     gas;
}
