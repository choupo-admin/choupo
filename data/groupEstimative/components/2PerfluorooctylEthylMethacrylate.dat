/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(perfluorooctyl)ethyl methacrylate  (C14H9F17O2, CAS 1996-88-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PerfluorooctylEthylMethacrylate;
formula     C14H9F17O2;
CAS         1996-88-9;
InChIKey    HBZFBSFGXQBQTB-UHFFFAOYSA-N;
MW          532.19;      // g/mol [origin=calculated method=formula-sum]
Tc          668.00;      // K   [origin=predictive method=joback]
Pc          10.253;      // bar [origin=predictive method=joback]
omega       0.8076;      // -   [origin=predictive method=lee-kesler]
Tb          536.45;      // K   [origin=predictive method=joback]
HvapTb      29318.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.348 2.46592 -0.0023216 7.879e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group CF3; count 1; } { group CF2; count 7; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 8; } { group dCH2; count 1; } { group dC; count 1; } { group F; count 17; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,10-heptadecakis(fluoranyl)decyl 2-methylprop-2-enoate" "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,10-heptadecafluorodecyl methacrylate" "1h,1h,2h,2h-perfluorodecyl methacrylate" "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,10-heptadecafluorodecyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,10-heptadecafluorodecyl ester" "1h,1h,2h,2h-perfluorodecylmethacrylate" "1h,1h,2h,2h-heptadecafluorodecyl methacrylate" "2-methyl-2-propenoic acid 3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,10-heptadecafluorodecyl ester" );
standardThermochemistry
{
    dHf_298   -3937800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     971.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3453130.0
}
