/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(methylthio)aniline  (C7H9NS, CAS 1783-81-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethylthioAniline;
formula     C7H9NS;
CAS         1783-81-9;
InChIKey    KCHLDNLIJVSRPK-UHFFFAOYSA-N;
MW          139.216;      // g/mol [origin=calculated method=formula-sum]
Tc          784.22;      // K   [origin=predictive method=joback]
Pc          44.444;      // bar [origin=predictive method=joback]
omega       0.4822;      // -   [origin=predictive method=lee-kesler]
Tb          532.73;      // K   [origin=predictive method=joback]
HvapTb      51572.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.01 0.58671 -0.00032436 5.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylsulfanylaniline" "3-aminothioanisole" "m-aminothioanisole" "benzenamine, 3-(methylthio)-" "m-(methylthio)aniline" "3-(methylmercapto)aniline" "3-methylmercaptoaniline" "3-methylthiobenzenamine" "m-aminophenyl methyl sulfide" "aniline, m-(methylthio)-" "3-(methylsulfanyl)aniline" "m-thioanisidine" );
standardThermochemistry
{
    dHf_298   112910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=210410.0
}
