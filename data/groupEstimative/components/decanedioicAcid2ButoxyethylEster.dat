/*--------------------------------*- Choupo -*-----------------------*\
  Component: decanedioic acid, 2-butoxyethyl ester  (C16H30O5, CAS 68186-66-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decanedioicAcid2ButoxyethylEster;
formula     C16H30O5;
CAS         68186-66-3;
InChIKey    ZGCXNQBDICMZNA-UHFFFAOYSA-N;
MW          302.411;      // g/mol [origin=calculated method=formula-sum]
Tc          976.83;      // K   [origin=predictive method=joback]
Pc          13.954;      // bar [origin=predictive method=joback]
omega       1.1733;      // -   [origin=predictive method=lee-kesler]
Tb          791.83;      // K   [origin=predictive method=joback]
HvapTb      78191.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.853 1.45662 -0.0007136 9.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH2COO; count 1; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group O; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-(2-butoxyethoxy)-10-oxidanylidene-decanoic acid" "10-(2-butoxyethoxy)-10-oxodecanoic acid" "decanedioic acid 2-butoxyethyl ester" "sebacic acid, butyl cellosolve reaction product" );
standardThermochemistry
{
    dHf_298   -1173340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     894.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-675440.0
}
