/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-1,3,5-triisopropylbenzene  (C15H23Br, CAS 21524-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo135Triisopropylbenzene;
formula     C15H23Br;
CAS         21524-34-5;
InChIKey    FUMMYHVKFAHQST-UHFFFAOYSA-N;
MW          283.253;      // g/mol [origin=calculated method=formula-sum]
Tc          867.68;      // K   [origin=predictive method=joback]
Pc          19.254;      // bar [origin=predictive method=joback]
omega       0.6518;      // -   [origin=predictive method=lee-kesler]
Tb          649.26;      // K   [origin=predictive method=joback]
HvapTb      58517.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.39 1.22742 -0.00070328 1.507e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group ACH; count 2; } { group AC; count 1; } { group ACCH; count 3; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-1,3,5-tri(propan-2-yl)benzene" "1-bromo-2,4,6-triisopropylbenzene" "2,4,6-triisopropylbromobenzene" "2-bromo-1,3,5-tri(propan-2-yl)benzene" "2-bromo-1,3,5-tris(propan-2-yl)benzene" "fummyhvkfahqst-uhfffaoysa-" "1,3,5-triisopropyl-2-bromobenzene" "2-bromo-1,3,5-triisopropyl-benzene" "2-bromo-1,3,5-tris(methylethyl)benzene" "2-bromo-1,3,5-tris(1-methylethyl)-benzene" "benzene,2-bromo-1,3,5-triisopropyl- (6ci,7ci,8ci);1-bromo-2,4,6-triisopropylbenzene;2,4,6-triisopropyl-1-bromobenzene;2,4,6-triisopropylbromobenzene;2,4,6-triisopropylphenyl bromide;" );
standardThermochemistry
{
    dHf_298   -140320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     637.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=165940.0
}
