/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzyloctadecanamide  (C25H43NO, CAS 5327-45-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzyloctadecanamide;
formula     C25H43NO;
CAS         5327-45-7;
InChIKey    IXODJGLAVBPVSW-UHFFFAOYSA-N;
MW          373.625;      // g/mol [origin=calculated method=formula-sum]
Tc          1105.49;      // K   [origin=predictive method=joback]
Pc          9.699;      // bar [origin=predictive method=joback]
omega       0.9323;      // -   [origin=predictive method=lee-kesler]
Tb          902.32;      // K   [origin=predictive method=joback]
HvapTb      86702.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.593 2.34812 -0.0013973 3.1326e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group ACH; count 5; } { group AC; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(phenylmethyl)octadecanamide" "n-benzylstearamide" "n-octadecanoyl benzylamine" );
gibbsFormation
{
    dHf_298   -381910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1090.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=232500.0
    phase     gas;
}
