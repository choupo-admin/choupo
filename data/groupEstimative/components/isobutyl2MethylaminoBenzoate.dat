/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutyl 2-(methylamino)benzoate  (C12H17NO2, CAS 65505-24-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutyl2MethylaminoBenzoate;
formula     C12H17NO2;
CAS         65505-24-0;
InChIKey    WKYZGTHZBSYUFI-UHFFFAOYSA-N;
MW          207.273;      // g/mol [origin=calculated method=formula-sum]
Tc          822.63;      // K   [origin=predictive method=joback]
Pc          24.314;      // bar [origin=predictive method=joback]
omega       0.7647;      // -   [origin=predictive method=lee-kesler]
Tb          613.77;      // K   [origin=predictive method=joback]
HvapTb      58699.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.109 1.03276 -0.00055036 8.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3NH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropyl 2-(methylamino)benzoate" "benzoic acid, 2-(methylamino)-, 2-methylpropyl ester" "iso-butyl n-methyl anthranilate" "isobutyl n-methylanthranilate" "isobutyl 2-n-methylaminobenzoate" "2-methylpropyl 2-n-methylaminobenzoate" "2-(methylamino)-benzoic acid 2-methylpropyl ester" );
standardThermochemistry
{
    dHf_298   -335040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-70480.0
}
