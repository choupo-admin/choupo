/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyethyl methyl terephthalate  (C11H12O5, CAS 3645-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyethylMethylTerephthalate;
formula     C11H12O5;
CAS         3645-00-9;
InChIKey    DJQMYWWZWUOCBQ-UHFFFAOYSA-N;
MW          224.212;      // g/mol [origin=calculated method=formula-sum]
Tc          889.76;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       1.2499;      // -   [origin=predictive method=lee-kesler]
Tb          691.56;      // K   [origin=predictive method=joback]
HvapTb      74511.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.392 0.83482 -0.00037996 1.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o4-(2-hydroxyethyl) o1-methyl benzene-1,4-dicarboxylate" "1,4-benzenedicarboxylic acid, 1-(2-hydroxyethyl) 4-methyl ester" "terephthalic acid, 2-hydroxyethyl methyl ester" "djqmywwzwuocbq-uhfffaoysa-" "terephthalic acid 2-hydroxyethyl methyl ester" "1,4-benzenedicarboxylic acid, 2-hydroxyethyl methyl ester" "4-o-(2-hydroxyethyl) 1-o-methyl benzene-1,4-dicarboxylate" "o1-(2-hydroxyethyl) o4-methyl benzene-1,4-dicarboxylate" "1,4-benzenedicarboxylicacid, 1-(2-hydroxyethyl) 4-methyl ester" "1,4-benzenedicarboxylicacid, 2-hydroxyethyl methyl ester (9ci); terephthalic acid, 2-hydroxyethylmethyl ester (6ci,7ci,8ci); ethylene glycol, mono(methyl terephthalate) (8ci);2-hydroxyethyl methyl terephthalate; methyl 2-hydroxyethyl terephthalate;monoglycol monomethyl terephthalate; b-hydroxyethyl methyl terephthalate" );
gibbsFormation
{
    dHf_298   -832100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-613040.0
    phase     gas;
}
