/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,6-dibromo-1,10,11,12,13,13-hexachlorotricyclo[8.2.1.02,9]tridec-11-ene  (C13H12Br2Cl6, CAS 51936-55-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        56Dibromo11011121313Hexachlorotricyclo821029Tridec11Ene;
formula     C13H12Br2Cl6;
CAS         51936-55-1;
InChIKey    XRFONNJUMOCNHA-UHFFFAOYSA-N;
MW          540.747;      // g/mol [origin=calculated method=formula-sum]
Tc          1180.17;      // K   [origin=predictive method=joback]
Pc          23.772;      // bar [origin=predictive method=joback]
omega       0.7678;      // -   [origin=predictive method=lee-kesler]
Tb          882.40;      // K   [origin=predictive method=joback]
HvapTb      81066.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-176.25 2.365 -0.002653 1.1796e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 4; } { group CCl2; count 1; } { group Br; count 2; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 4; } { group C_ring; count 3; } { group dC_ring; count 2; } { group Cl; count 6; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-methanobenzocyclooctene, 7,8-dibromo-1,2,3,4,11,11-hexachloro-1,4,4a,5,6,7,8,9,10,10a-decahydro-" "7,8-dibromo-1,2,3,4,11,11-hexachloro-1,4,4a,5,6,7,8,9,10,10a-decahydro-1,4-methanobenzocyclooctene" );
standardThermochemistry
{
    dHf_298   -160470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     763.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112880.0
}
