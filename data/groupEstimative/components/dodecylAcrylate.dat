/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecyl acrylate  (C15H28O2, CAS 2156-97-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecylAcrylate;
formula     C15H28O2;
CAS         2156-97-0;
InChIKey    PBOSTUDLECTMNL-UHFFFAOYSA-N;
MW          240.387;      // g/mol [origin=calculated method=formula-sum]
Tc          764.92;      // K   [origin=predictive method=joback]
Pc          14.669;      // bar [origin=predictive method=joback]
omega       0.8230;      // -   [origin=predictive method=lee-kesler]
Tb          597.70;      // K   [origin=predictive method=joback]
HvapTb      55721.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.671 1.35402 -0.0007205 1.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH2=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecyl prop-2-enoate" "lauryl acrylate" "n-lauryl acrylate" "n-dodecyl acrylate" "2-propenoic acid, dodecyl ester" "acrylic acid, dodecyl ester" "acrylic acid lauryl ester" "acrylic acid dodecyl ester" "2-propenoic acid dodecyl ester" "2-propenoic acid,dodecyl ester" );
standardThermochemistry
{
    dHf_298   -544780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     786.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147110.0
}
