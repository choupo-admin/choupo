/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclopropylethanamine  (C5H11N, CAS 1621-24-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclopropylethanamine;
formula     C5H11N;
CAS         1621-24-5;
InChIKey    IXCXVGWKYIDNOS-UHFFFAOYSA-N;
MW          85.15;      // g/mol [origin=calculated method=formula-sum]
Tc          594.85;      // K   [origin=predictive method=joback]
Pc          44.267;      // bar [origin=predictive method=joback]
omega       0.3550;      // -   [origin=predictive method=lee-kesler]
Tb          392.83;      // K   [origin=predictive method=joback]
HvapTb      36890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.09 0.69752 -0.000515 1.581e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-cyclopropylethyl)amine" "1-cyclopropyl-ethylamine" "1-cyclopropylethylamine" "(s)-1-cyclopropylethylamine" "1-cyclopropyl-ethylamine hydrochloride" "1-amino-1-cyclopropylethane" "cyclopropanemethanamine,a-methyl-" "cyclopropanemethylamine,a-methyl- (7ci);1-cyclopropylethanamine; 1-cyclopropylethylamine" );
gibbsFormation
{
    dHf_298   -45220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     302.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=115980.0
    phase     gas;
}
