/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-aminoethanol; (9z,12z)-octadeca-9,12-dienoic acid  (C38H71NO5, CAS 68299-13-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Aminoethanol9z12zOctadeca912DienoicAcid;
formula     C38H71NO5;
CAS         68299-13-8;
InChIKey    HBYKLXANDGKJGK-GRVYQHKQSA-N;
MW          621.988;      // g/mol [origin=calculated method=formula-sum]
Tc          2342.28;      // K   [origin=predictive method=joback]
Pc          4.923;      // bar [origin=predictive method=joback]
omega       -0.4106;      // -   [origin=predictive method=lee-kesler]
Tb          1544.21;      // K   [origin=predictive method=joback]
HvapTb      162250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.236 3.47894 -0.001768 2.73e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 25; } { group CH=CH; count 4; } { group OH; count 1; } { group CH2NH2; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 26; } { group dCH; count 8; } { group OH; count 1; } { group COOH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanylethanol;(9z,12z)-octadeca-9,12-dienoic acid" "9,12-octadecadienoic acid (9z,12z)-, dimer, compd. with 2-aminoethanol (1:?)" "(9z,12z)-octadeca-9,12-dienoic acid, dimer, compound with 2-aminoethanol" );
standardThermochemistry
{
    dHf_298   -1400990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     2033.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-377750.0
}
