/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4,5-trimethoxybenzaldehyde dimethyl acetal  (C12H18O5, CAS 59276-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        345TrimethoxybenzaldehydeDimethylAcetal;
formula     C12H18O5;
CAS         59276-37-8;
InChIKey    PEZMUQHWXSFOIK-UHFFFAOYSA-N;
MW          242.271;      // g/mol [origin=calculated method=formula-sum]
Tc          825.40;      // K   [origin=predictive method=joback]
Pc          21.414;      // bar [origin=predictive method=joback]
omega       0.8365;      // -   [origin=predictive method=lee-kesler]
Tb          627.44;      // K   [origin=predictive method=joback]
HvapTb      58230.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (126.79 0.5764 9.272e-05 -1.921e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACCH; count 1; } { group CH3O; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(dimethoxymethyl)-1,2,3-trimethoxy-benzene" "5-(dimethoxymethyl)-1,2,3-trimethoxybenzene" "benzene,5-(dimethoxymethyl)-1,2,3-trimethoxy-" );
standardThermochemistry
{
    dHf_298   -755270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-393760.0
}
