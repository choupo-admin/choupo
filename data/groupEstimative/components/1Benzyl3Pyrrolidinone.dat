/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-benzyl-3-pyrrolidinone  (C11H13NO, CAS 775-16-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Benzyl3Pyrrolidinone;
formula     C11H13NO;
CAS         775-16-6;
InChIKey    DHGMDHQNUNRMIN-UHFFFAOYSA-N;
MW          175.231;      // g/mol [origin=calculated method=formula-sum]
Tc          812.98;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       0.5687;      // -   [origin=predictive method=lee-kesler]
Tb          573.90;      // K   [origin=predictive method=joback]
HvapTb      49040.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.579 1.0933 -0.0007036 1.672e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(phenylmethyl)pyrrolidin-3-one" "1-benzylpyrrolidin-3-one" "n-benzyl-3-pyrrolidinone" "1-benzyl-3-pyrrolidone" "1-(phenylmethyl)-3-pyrrolidinone" "1-(benzyl)pyrrolidin-3-one" "n-benzyl-3-pyrrolidone" "3-pyrrolidinone, 1-(phenylmethyl)-" );
gibbsFormation
{
    dHf_298   -17030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=198700.0
    phase     gas;
}
