/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo(3.3.1)non-1-ene  (C9H14, CAS 17530-61-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo331Non1Ene;
formula     C9H14;
CAS         17530-61-9;
InChIKey    SIVKZPBURVINMX-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          661.18;      // K   [origin=predictive method=joback]
Pc          34.889;      // bar [origin=predictive method=joback]
omega       0.3076;      // -   [origin=predictive method=lee-kesler]
Tb          440.62;      // K   [origin=predictive method=joback]
HvapTb      37233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.0 1.0428 -0.00074264 2.123e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[3.3.1]non-4-ene" "bicyclo[3.3.1]non-1-ene" );
standardThermochemistry
{
    dHf_298   -35320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=138140.0
}
