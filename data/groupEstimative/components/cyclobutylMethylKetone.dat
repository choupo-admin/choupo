/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutyl methyl ketone  (C6H10O, CAS 3019-25-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobutylMethylKetone;
formula     C6H10O;
CAS         3019-25-8;
InChIKey    JPJOOTWNILDNAW-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          603.15;      // K   [origin=predictive method=joback]
Pc          40.261;      // bar [origin=predictive method=joback]
omega       0.3571;      // -   [origin=predictive method=lee-kesler]
Tb          401.76;      // K   [origin=predictive method=joback]
HvapTb      35781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.57 0.68712 -0.0004577 1.2056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclobutylethanone" "acetylcyclobutane" "ethanone, 1-cyclobutyl-" "ketone, cyclobutyl methyl" "1-cyclobutylethan-1-one" "ketone,cyclobutyl methyl (6ci,7ci,8ci);1-cyclobutylethan-1-one;1-cyclobutylethanone;acetylcyclobutane;cyclobutane, acetyl-;cyclobutyl methyl ketone;methylcyclobutyl ketone;" );
standardThermochemistry
{
    dHf_298   -213110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-80630.0
}
