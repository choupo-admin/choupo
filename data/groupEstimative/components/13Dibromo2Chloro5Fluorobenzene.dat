/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dibromo-2-chloro-5-fluorobenzene  (C6H2Br2ClF, CAS 179897-90-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dibromo2Chloro5Fluorobenzene;
formula     C6H2Br2ClF;
CAS         179897-90-6;
InChIKey    PZKDJJMHRYNBOR-UHFFFAOYSA-N;
MW          288.338;      // g/mol [origin=calculated method=formula-sum]
Tc          797.32;      // K   [origin=predictive method=joback]
Pc          47.431;      // bar [origin=predictive method=joback]
omega       0.5627;      // -   [origin=predictive method=lee-kesler]
Tb          547.52;      // K   [origin=predictive method=joback]
HvapTb      49650.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.79 0.4114 -0.00031228 9.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCl; count 1; } { group Br; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 1; } { group Cl; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(bromanyl)-2-chloranyl-5-fluoranyl-benzene" "2,6-dibromo-4-fluorochlorobenzene" "1-chloro-2,6-dibromo-4-fluorobenzene" "2-chloro-1,3-dibromo-5-fluorobenzene" "4-chloro-3,5-dibromo-1-fluorobenzene" "benzene,1,3-dibromo-2-chloro-5-fluoro-" "benzene, 1,3-dibromo-2-chloro-5-fluoro-" "1,3-dibromo-2-chloro-5-fluorobenzene;1-chloro-2,6-dibromo-4-fluorobenzene;" );
standardThermochemistry
{
    dHf_298   -124240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94940.0
}
