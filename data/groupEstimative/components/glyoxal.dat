/*--------------------------------*- Choupo -*-----------------------*\
  Component: glyoxal  (C2H2O2, CAS 107-22-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glyoxal;
formula     C2H2O2;
CAS         107-22-2;
InChIKey    LEQAOMBKQFMDFZ-UHFFFAOYSA-N;
MW          58.036;      // g/mol [origin=calculated method=formula-sum]
Tc          526.07;      // K   [origin=predictive method=joback]
Pc          62.789;      // bar [origin=predictive method=joback]
omega       0.4168;      // -   [origin=predictive method=lee-kesler]
Tb          342.68;      // K   [origin=predictive method=joback]
HvapTb      33486.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.87 0.1428 -7.1e-05 8.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group OdCH_al; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanedial" "oxalaldehyde" "1,2-ethanedione" "glyoxylaldehyde" "biformal" "biformyl" "diformal" "diformyl" "ethanedial, trimer" "glyoxal, 40%" "oxaldehyde" "glyoxal solution" );
standardThermochemistry
{
    dHf_298   -255770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     271.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-233080.0
}
