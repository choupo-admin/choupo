/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butanethiol  (C4H10S, CAS 109-79-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butanethiol;
formula     C4H10S;
CAS         109-79-5;
InChIKey    WQAQPCDUOCURKW-UHFFFAOYSA-N;
MW          90.184;      // g/mol [origin=calculated method=formula-sum]
Tc          544.71;      // K   [origin=predictive method=joback]
Pc          42.275;      // bar [origin=predictive method=joback]
omega       0.2772;      // -   [origin=predictive method=lee-kesler]
Tb          353.98;      // K   [origin=predictive method=joback]
HvapTb      31235.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.143 0.41112 -0.0002162 4.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1-thiol" "butanethiol" "butyl mercaptan" "n-butanethiol" "n-butyl mercaptan" "thiobutyl alcohol" "butylthiol" "bear skunk" "n-butylmercaptan" "1-butanthiol" "1-mercaptobutane" "mercaptan c4" );
gibbsFormation
{
    dHf_298   -87410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12190.0
    phase     gas;
}
