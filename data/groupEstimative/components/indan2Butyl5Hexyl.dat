/*--------------------------------*- Choupo -*-----------------------*\
  Component: indan, 2-butyl-5-hexyl-  (C19H30, CAS 25446-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        indan2Butyl5Hexyl;
formula     C19H30;
CAS         25446-32-6;
InChIKey    JAUZOZVMGVOYCU-UHFFFAOYSA-N;
MW          258.449;      // g/mol [origin=calculated method=formula-sum]
Tc          873.96;      // K   [origin=predictive method=joback]
Pc          14.669;      // bar [origin=predictive method=joback]
omega       0.7562;      // -   [origin=predictive method=lee-kesler]
Tb          677.70;      // K   [origin=predictive method=joback]
HvapTb      61401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.932 1.76184 -0.00112712 2.899e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group ACH; count 3; } { group ACCH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butyl-5-hexyl-2,3-dihydro-1h-indene" "2-n-butyl-5-n-hexyl-(2,3-dihydroindene)" "2-n-butyl-5-n-hexyl-[2,3-dihydroindene]" "2-n-butyl-5-n-hexylindan" "1h-indene,2-butyl-5-hexyl-2,3-dihydro-" );
standardThermochemistry
{
    dHf_298   -149100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     687.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=263000.0
}
