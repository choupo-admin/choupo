/*--------------------------------*- Choupo -*-----------------------*\
  Component: di-tert-butyl acetylenedicarboxylate  (C12H18O4, CAS 66086-33-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diTertButylAcetylenedicarboxylate;
formula     C12H18O4;
CAS         66086-33-7;
InChIKey    FBCRUXRGQFLOMC-UHFFFAOYSA-N;
MW          226.272;      // g/mol [origin=calculated method=formula-sum]
Tc          805.92;      // K   [origin=predictive method=joback]
Pc          21.394;      // bar [origin=predictive method=joback]
omega       0.5984;      // -   [origin=predictive method=lee-kesler]
Tb          593.14;      // K   [origin=predictive method=joback]
HvapTb      56680.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.41 1.13612 -0.00069126 1.4018e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group C_C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group tC; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ditert-butyl but-2-ynedioate" "di-tert-butyl 2-butynedioate" "2-butynedioic acid di-tert-butyl ester" "fbcruxrgqflomc-uhfffaoysa-" "ditert-butyl but-2-yne-1,4-dioate" "2-butynedioic acid, bis(1,1-dimethylethyl) ester" );
gibbsFormation
{
    dHf_298   -670770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-362100.0
    phase     gas;
}
