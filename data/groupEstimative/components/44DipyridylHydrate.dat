/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-dipyridyl hydrate  (C10H10N2O, CAS 123333-55-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H10N2O (delta H+2O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        44DipyridylHydrate;
formula     C10H10N2O;
CAS         123333-55-1;
InChIKey    JJRKHJXMBCYHSH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          174.203;      // g/mol [origin=calculated method=formula-sum]
Tc          867.76;      // K   [origin=predictive method=joback]
Pc          38.579;      // bar [origin=predictive method=joback]
omega       0.4251;      // -   [origin=predictive method=lee-kesler]
Tb          589.16;      // K   [origin=predictive method=joback]
HvapTb      54826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.89 0.86352 -0.00060112 1.624e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group H2O; count 1; } { group C5H4N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 2; } { group Nd_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-pyridin-4-ylpyridine;hydrate" "bipyridine hydrate" "4,4'-bipyridine hydrate" "4,4-dipyridyl hydrate" "4-(4-pyridyl)pyridine, hydrate" "gamma,gamma'-dipyridyl hydrate" );
gibbsFormation
{
    dHf_298   288910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=412240.0
    phase     gas;
}
