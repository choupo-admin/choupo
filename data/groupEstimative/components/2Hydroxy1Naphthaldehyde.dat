/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxy-1-naphthaldehyde  (C11H8O2, CAS 708-06-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H8O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Hydroxy1Naphthaldehyde;
formula     C11H8O2;
CAS         708-06-5;
InChIKey    NTCCNERMXRIPTR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          172.183;      // g/mol [origin=calculated method=formula-sum]
Tc          806.78;      // K   [origin=predictive method=joback]
Pc          43.283;      // bar [origin=predictive method=joback]
omega       0.5728;      // -   [origin=predictive method=lee-kesler]
Tb          558.96;      // K   [origin=predictive method=joback]
HvapTb      55299.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.58 1.0694 -0.00108484 4.312e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACOH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylnaphthalene-1-carbaldehyde" "1-naphthalenecarboxaldehyde, 2-hydroxy-" "1-formyl-2-naphthol" "2-hydroxynaphthaldehyde" "1-naphthaldehyde, 2-hydroxy-" "2-hydroxy-1-napthaldehyde" "2-naphthol 1-carboxaldehyde" "2-hydroxy-1-naphthalenecarboxaldehyde" "2-hydroxy-1-naphthalaldehyde" "2-hydroxy-1-naphthylaldehyde" "2-hydroxynaphthalene-1-carbaldehyde" "beta-hydroxynaphthaldehyde" );
gibbsFormation
{
    dHf_298   44900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140510.0
    phase     gas;
}
