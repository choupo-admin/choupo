/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethoxybenzyl alcohol  (C9H12O3, CAS 93-03-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34DimethoxybenzylAlcohol;
formula     C9H12O3;
CAS         93-03-8;
InChIKey    OEGPRYNGFWGMMV-UHFFFAOYSA-N;
MW          168.192;      // g/mol [origin=calculated method=formula-sum]
Tc          773.17;      // K   [origin=predictive method=joback]
Pc          33.684;      // bar [origin=predictive method=joback]
omega       0.9847;      // -   [origin=predictive method=lee-kesler]
Tb          579.18;      // K   [origin=predictive method=joback]
HvapTb      60727.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.691 0.56854 -0.00017132 -2.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3,4-dimethoxyphenyl)methanol" "veratryl alcohol" "benzenemethanol, 3,4-dimethoxy-" "veratrole alcohol" "3,4-dimethoxyphenylmethyl alcohol" "(3,4-dimethoxyphenyl)methan-1-ol" "veratryl alcohol (8ci)" "3,4-dimethoxybenzenemethanol" "benzenemethanol,4-dimethoxy-" "3, 4-dimethoxybenzyl alcohol" "(3,4-dimethoxyphenyl)-methanol" "3,4-dimethoxy-benzenemethano;3,4-dimethoxy-benzenemethanol" );
gibbsFormation
{
    dHf_298   -432170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-228770.0
    phase     gas;
}
