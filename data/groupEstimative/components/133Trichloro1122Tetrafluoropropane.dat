/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,3-trichloro-1,1,2,2-tetrafluoropropane  (C3HCl3F4, CAS 422-54-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        133Trichloro1122Tetrafluoropropane;
formula     C3HCl3F4;
CAS         422-54-8;
InChIKey    WWNLOOSSVHRIFJ-UHFFFAOYSA-N;
MW          219.383;      // g/mol [origin=calculated method=formula-sum]
Tc          549.34;      // K   [origin=predictive method=joback]
Pc          32.616;      // bar [origin=predictive method=joback]
omega       0.3342;      // -   [origin=predictive method=lee-kesler]
Tb          370.71;      // K   [origin=predictive method=joback]
HvapTb      29179.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.57 0.6139 -0.000613 2.172e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl2; count 1; } { group CF2; count 1; } { group CClF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 2; } { group F; count 4; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,3-tris(chloranyl)-1,1,2,2-tetrakis(fluoranyl)propane" "propane, 1,3,3-trichloro-1,1,2,2-tetrafluoro-" "propane,1,3,3-trichloro-1,1,2,2-tetrafluoro-" );
standardThermochemistry
{
    dHf_298   -959690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-837410.0
}
