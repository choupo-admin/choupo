/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydrocoerulignone  (C16H18O6, CAS 612-69-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydrocoerulignone;
formula     C16H18O6;
CAS         612-69-1;
InChIKey    NRTOUGPMXLJETQ-UHFFFAOYSA-N;
MW          306.314;      // g/mol [origin=calculated method=formula-sum]
Tc          1126.42;      // K   [origin=predictive method=joback]
Pc          27.070;      // bar [origin=predictive method=joback]
omega       1.3899;      // -   [origin=predictive method=lee-kesler]
Tb          889.88;      // K   [origin=predictive method=joback]
HvapTb      94078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.89 1.18448 -0.00070956 1.776e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 6; } { group ACOH; count 2; } { group CH3O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3,5-dimethoxy-4-oxidanyl-phenyl)-2,6-dimethoxy-phenol" "3,3',5,5'-tetramethoxy(1,1'-biphenyl)-4,4'-diol" "3,3',5,5'-tetramethoxy[1,1'-biphenyl]-4,4'-diol" "4-(4-hydroxy-3,5-dimethoxyphenyl)-2,6-dimethoxyphenol" "ghl.pd_mitscher_leg0.943" "3,3',5,5'-tetramethoxybiphenyl-4,4'-diol" "1,1'-biphenyl, 3,3',5,5'-tetramethoxy-4,4'-dihydroxy" );
standardThermochemistry
{
    dHf_298   -829890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-459100.0
}
