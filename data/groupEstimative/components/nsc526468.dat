/*--------------------------------*- Choupo -*-----------------------*\
  Component: nsc 526468  (C13H12O5, CAS 73839-65-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nsc526468;
formula     C13H12O5;
CAS         73839-65-3;
InChIKey    ULTWKORORDEMCL-UHFFFAOYSA-N;
MW          248.234;      // g/mol [origin=calculated method=formula-sum]
Tc          995.48;      // K   [origin=predictive method=joback]
Pc          31.526;      // bar [origin=predictive method=joback]
omega       1.1760;      // -   [origin=predictive method=lee-kesler]
Tb          764.36;      // K   [origin=predictive method=joback]
HvapTb      78885.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.01 1.11144 -0.00080842 2.3816e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3CO; count 1; } { group CH3O; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group O; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethanoyl-3-(3-methoxy-4-oxidanyl-phenyl)-2h-furan-5-one" "2(5h)-furanone, 3-acetyl-4-(4-hydroxy-3-methoxyphenyl)-" "alpha-acetyl-4-hydroxy-beta-(hydroxymethyl)-3-methoxy-cinnamic acid gamma-lactone" "4-acetyl-3-(4-hydroxy-3-methoxyphenyl)-2h-furan-5-one" ".alpha.-acetyl-4-hydroxy-.beta.-(hydroxymethyl)-3-methoxy-cinnamic acid .gamma.-lactone" "cinnamic acid, alpha-acetyl-4-hydroxy-beta-(hydroxymethyl)-3-methoxy-,gamma-lactone" );
gibbsFormation
{
    dHf_298   -698000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-458390.0
    phase     gas;
}
