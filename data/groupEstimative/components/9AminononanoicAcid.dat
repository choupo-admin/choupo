/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-aminononanoic acid  (C9H19NO2, CAS 1120-12-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9AminononanoicAcid;
formula     C9H19NO2;
CAS         1120-12-3;
InChIKey    VWPQCOZMXULHDM-UHFFFAOYSA-N;
MW          173.256;      // g/mol [origin=calculated method=formula-sum]
Tc          815.25;      // K   [origin=predictive method=joback]
Pc          26.680;      // bar [origin=predictive method=joback]
omega       1.0300;      // -   [origin=predictive method=lee-kesler]
Tb          623.56;      // K   [origin=predictive method=joback]
HvapTb      63433.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.798 0.9715 -0.0005818 1.349e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-azanylnonanoic acid" "9-amino-nonanoic acid" "nonanoic acid, 9-amino-" "9-aminononanoicacid; 9-aminopelargonic acid; aminopelargonic acid" );
gibbsFormation
{
    dHf_298   -545570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     611.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-252560.0
    phase     gas;
}
