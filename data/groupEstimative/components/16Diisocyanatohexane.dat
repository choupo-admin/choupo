/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-diisocyanatohexane  (C8H12N2O2, CAS 822-06-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Diisocyanatohexane;
formula     C8H12N2O2;
CAS         822-06-0;
InChIKey    RRAMGCGOFNQTLD-UHFFFAOYSA-N;
MW          168.196;      // g/mol [origin=calculated method=formula-sum]
Tc          701.08;      // K   [origin=predictive method=joback]
Pc          29.601;      // bar [origin=predictive method=joback]
omega       0.7726;      // -   [origin=predictive method=lee-kesler]
Tb          515.98;      // K   [origin=predictive method=joback]
HvapTb      52466.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 6; } { group dCd; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexamethylene diisocyanate" "1,6-hexamethylene diisocyanate" "hmdi" "hexane, 1,6-diisocyanato-" "hexane 1,6-diisocyanate" "1,6-hexylene diisocyanate" "hexamethylene-1,6-diisocyanate" "1,6-hexanediol diisocyanate" "isocyanic acid, hexamethylene ester" "tl 78" "hdi" "szesciometylenodwuizocyjanian" );
