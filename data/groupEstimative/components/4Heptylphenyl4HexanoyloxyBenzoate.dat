/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-heptylphenyl 4-(hexanoyloxy)benzoate  (C26H34O4, CAS 38444-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Heptylphenyl4HexanoyloxyBenzoate;
formula     C26H34O4;
CAS         38444-29-0;
InChIKey    ZFRGBMGYFWSSJR-UHFFFAOYSA-N;
MW          410.554;      // g/mol [origin=calculated method=formula-sum]
Tc          1195.88;      // K   [origin=predictive method=joback]
Pc          10.596;      // bar [origin=predictive method=joback]
omega       0.9901;      // -   [origin=predictive method=lee-kesler]
Tb          974.24;      // K   [origin=predictive method=joback]
HvapTb      94160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.14 2.08744 -0.00112972 1.852e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-heptylphenyl) 4-hexanoyloxybenzoate" "benzoic acid, 4-((1-oxohexyl)oxy)-, 4-heptylphenyl ester" "benzoic acid, 4-[(1-oxohexyl)oxy]-, 4-heptylphenyl ester" "4-heptylphenyl 4-((1-oxohexyl)oxy)benzoate" "4-n-hexanoyloxybenzoic acid 4-n-heptylphenyl ester" "benzoic acid,4-[(1-oxohexyl)oxy]-, 4-heptylphenyl ester" );
gibbsFormation
{
    dHf_298   -764410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1046.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-247140.0
    phase     gas;
}
