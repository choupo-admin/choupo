/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3'-fluoroacetophenone  (C8H7FO, CAS 455-36-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Fluoroacetophenone;
formula     C8H7FO;
CAS         455-36-7;
InChIKey    HCEKGPAHZCYRBZ-UHFFFAOYSA-N;
MW          138.141;      // g/mol [origin=calculated method=formula-sum]
Tc          678.71;      // K   [origin=predictive method=joback]
Pc          36.642;      // bar [origin=predictive method=joback]
omega       0.4732;      // -   [origin=predictive method=lee-kesler]
Tb          467.44;      // K   [origin=predictive method=joback]
HvapTb      42269.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.54 0.60922 -0.00037326 8.116e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH3CO; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-fluorophenyl)ethanone" "m-fluoroacetophenone" "ethanone, 1-(3-fluorophenyl)-" "3-fluoroacetophenone" "1-(3-fluorophenyl)ethan-1-one" "acetophenone, 3'-fluoro-" "fr cv1" "1-acetyl-3-fluorobenzene" "3'-fluoro-acetophenone" );
standardThermochemistry
{
    dHf_298   -292080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-204470.0
}
