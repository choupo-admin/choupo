/*--------------------------------*- Choupo -*-----------------------*\
  Component: edda  (C6H12N2O4, CAS 5657-17-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        edda;
formula     C6H12N2O4;
CAS         5657-17-0;
InChIKey    IFQUWYZCAGRUJN-UHFFFAOYSA-N;
MW          176.172;      // g/mol [origin=calculated method=formula-sum]
Tc          932.66;      // K   [origin=predictive method=joback]
Pc          39.555;      // bar [origin=predictive method=joback]
omega       1.5213;      // -   [origin=predictive method=lee-kesler]
Tb          728.24;      // K   [origin=predictive method=joback]
HvapTb      76150.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.214 0.8278 -0.000545 1.372e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2NH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group COOH; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-hydroxy-2-oxoethylamino)ethylamino]ethanoic acid" "glycine, n,n'-1,2-ethanediylbis-" "n,n'-ethylenediglycine" "ethylenediamine-n,n'-diacetic acid" "glycine, n,n'-ethylenedi-" "2-[2-(carboxymethylamino)ethylamino]acetic acid" "ethylene-n,n'-diglycine" "ethylenediamine-n,n'-di(acetic acid)" "38011-25-5 (di-hydrochloride salt)" "32575-57-8 (unspecified copper salt)" "({2-[(carboxymethyl)amino]ethyl}amino)acetic acid" "2-({2-[(carboxymethyl)amino]ethyl}amino)acetic acid" );
gibbsFormation
{
    dHf_298   -760770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-509400.0
    phase     gas;
}
