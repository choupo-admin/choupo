/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-mercaptoethyl isooctyl phthalate  (C18H26O4S, CAS 67907-16-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MercaptoethylIsooctylPhthalate;
formula     C18H26O4S;
CAS         67907-16-8;
InChIKey    KWNLPAQLPZUUKG-UHFFFAOYSA-N;
MW          338.462;      // g/mol [origin=calculated method=formula-sum]
Tc          1032.86;      // K   [origin=predictive method=joback]
Pc          15.403;      // bar [origin=predictive method=joback]
omega       1.0408;      // -   [origin=predictive method=lee-kesler]
Tb          821.96;      // K   [origin=predictive method=joback]
HvapTb      79763.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.947 1.49904 -0.00075596 9.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2SH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-(6-methylheptyl) o2-(2-sulfanylethyl) benzene-1,2-dicarboxylate" "6-methylheptyl 2-sulfanylethyl benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid isooctyl 2-mercaptoethyl ester" "1,2-benzenedicarboxylic acid, 1-isooctyl 2-(2-mercaptoethyl) ester" "isooctyl 2-mercaptoethyl phthalate" "1,2-benzenedicarboxylic acid, isooctyl 2-mercaptoethyl ester" "1-o-(6-methylheptyl) 2-o-(2-sulfanylethyl) benzene-1,2-dicarboxylate" );
standardThermochemistry
{
    dHf_298   -791150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     900.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-390330.0
}
