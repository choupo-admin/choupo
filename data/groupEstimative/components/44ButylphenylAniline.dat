/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(4-butylphenyl)aniline  (C16H19N, CAS 60040-13-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44ButylphenylAniline;
formula     C16H19N;
CAS         60040-13-3;
InChIKey    NWGXDVIQTAEFBO-UHFFFAOYSA-N;
MW          225.335;      // g/mol [origin=calculated method=formula-sum]
Tc          939.39;      // K   [origin=predictive method=joback]
Pc          23.451;      // bar [origin=predictive method=joback]
omega       0.7510;      // -   [origin=predictive method=lee-kesler]
Tb          701.53;      // K   [origin=predictive method=joback]
HvapTb      67727.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.377 1.30892 -0.00081832 1.914e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[1,1'-biphenyl]-4-amine, 4'-butyl-" );
gibbsFormation
{
    dHf_298   110340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=355850.0
    phase     gas;
}
