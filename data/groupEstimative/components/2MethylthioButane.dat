/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(methylthio)butane  (C5H12S, CAS 10359-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylthioButane;
formula     C5H12S;
CAS         10359-64-5;
InChIKey    IJRCRFQMYAJPPO-UHFFFAOYSA-N;
MW          104.211;      // g/mol [origin=calculated method=formula-sum]
Tc          577.24;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       0.2919;      // -   [origin=predictive method=lee-kesler]
Tb          382.34;      // K   [origin=predictive method=joback]
HvapTb      33153.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.261 0.47915 -0.0002112 2.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylsulfanylbutane" "butane, 2-(methylthio)-" "sec-butyl methyl sulfide" "sulfide, sec-butyl methyl" "methyl sec-butyl sulfide" "sulfide,sec-butyl methyl (6ci,7ci,8ci); 2-(methylthio)butane; sec-butyl methyl sulfide" );
standardThermochemistry
{
    dHf_298   -109940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21900.0
}
