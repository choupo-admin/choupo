/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,4,6-tetra-o-benzoylhex-2-ulofuranose  (C34H28O10, CAS 6276-99-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1346TetraOBenzoylhex2Ulofuranose;
formula     C34H28O10;
CAS         6276-99-9;
InChIKey    ZYJUUZKDMZKDIS-UHFFFAOYSA-N;
MW          596.588;      // g/mol [origin=calculated method=formula-sum]
Tc          1779.31;      // K   [origin=predictive method=joback]
Pc          11.656;      // bar [origin=predictive method=joback]
omega       0.9806;      // -   [origin=predictive method=lee-kesler]
Tb          1437.76;      // K   [origin=predictive method=joback]
HvapTb      149378.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.048 3.0741 -0.0020825 5.21e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group ACH; count 20; } { group AC; count 4; } { group OH; count 1; } { group CH-O; count 1; } { group COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 20; } { group dC_ring; count 4; } { group OH; count 1; } { group O_ring; count 1; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[5-oxidanyl-3,4-bis(phenylcarbonyloxy)-5-(phenylcarbonyloxymethyl)oxolan-2-yl]methyl benzoate" "[3,4-dibenzoyloxy-5-(benzoyloxymethyl)-5-hydroxyoxolan-2-yl]methyl benzoate" "[3,4-dibenzoyloxy-5-(benzoyloxymethyl)-2-hydroxy-oxolan-2-yl]methyl benzoate" );
standardThermochemistry
{
    dHf_298   -1337620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1151.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-771450.0
}
