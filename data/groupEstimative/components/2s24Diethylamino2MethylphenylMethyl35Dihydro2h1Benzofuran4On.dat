/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2s)-2-[[4-(diethylamino)-2-methylphenyl]methyl]-3,5-dihydro-2h-1-benzofuran-4-one  (C20H25NO2, CAS 71156-00-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2s24Diethylamino2MethylphenylMethyl35Dihydro2h1Benzofuran4On;
formula     C20H25NO2;
CAS         71156-00-8;
InChIKey    DOOUNRXJJWJQHF-KRWDZBQOSA-N;
MW          311.425;      // g/mol [origin=calculated method=formula-sum]
Tc          1073.08;      // K   [origin=predictive method=joback]
Pc          17.318;      // bar [origin=predictive method=joback]
omega       0.9623;      // -   [origin=predictive method=lee-kesler]
Tb          840.29;      // K   [origin=predictive method=joback]
HvapTb      77073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.167 1.72706 -0.0010131 2.139e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH2CO; count 1; } { group CH-O; count 1; } { group CH2N; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group O_ring; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-[[4-(diethylamino)-2-methyl-phenyl]methyl]-3,5-dihydro-2h-1-benzofuran-4-one" );
gibbsFormation
{
    dHf_298   -204630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=246310.0
    phase     gas;
}
