/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanol, 2,2'-((octahydro-4,7-methano-5h-inden-5-ylidene)bis(4,1-phenyleneoxy))bis-  (C26H32O4, CAS 99377-83-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanol22Octahydro47Methano5hInden5YlideneBis41PhenyleneoxyB;
formula     C26H32O4;
CAS         99377-83-0;
InChIKey    XOLXPZNXLQIMJN-UHFFFAOYSA-N;
MW          408.538;      // g/mol [origin=calculated method=formula-sum]
Tc          1349.64;      // K   [origin=predictive method=joback]
Pc          15.524;      // bar [origin=predictive method=joback]
omega       1.3687;      // -   [origin=predictive method=lee-kesler]
Tb          1102.39;      // K   [origin=predictive method=joback]
HvapTb      115666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-192.336 2.8206 -0.00219372 7.19e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 4; } { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group C2H5O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 5; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanol, 2,2'-[(octahydro-4,7-methano-5h-inden-5-ylidene)bis(4,1-phenyleneoxy)]bis-" "agn-pc-01vv2h" );
gibbsFormation
{
    dHf_298   -511950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39200.0
    phase     gas;
}
