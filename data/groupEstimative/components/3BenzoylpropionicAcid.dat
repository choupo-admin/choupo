/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-benzoylpropionic acid  (C10H10O3, CAS 2051-95-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3BenzoylpropionicAcid;
formula     C10H10O3;
CAS         2051-95-8;
InChIKey    KMQLIDDEQAJAGJ-UHFFFAOYSA-N;
MW          178.187;      // g/mol [origin=calculated method=formula-sum]
Tc          881.24;      // K   [origin=predictive method=joback]
Pc          34.807;      // bar [origin=predictive method=joback]
omega       0.9309;      // -   [origin=predictive method=lee-kesler]
Tb          654.46;      // K   [origin=predictive method=joback]
HvapTb      64040.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.148 0.8977 -0.0006053 1.5226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylidene-4-phenyl-butanoic acid" "4-oxo-4-phenylbutanoic acid" "4-oxo-4-phenylbutyric acid" "3-benzoylpropanoic acid" "beta-benzoylpropionic acid" "benzoylpropionic acid" "benzenebutanoic acid, .gamma.-oxo-" "propanoic acid, 3-benzoyl-" "propionic acid, 3-benzoyl-" ".beta.-benzoylpropionic acid" "4-phenyl-4-oxobutyric acid" "agn-pc-00f3pq" );
standardThermochemistry
{
    dHf_298   -476050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-327100.0
}
