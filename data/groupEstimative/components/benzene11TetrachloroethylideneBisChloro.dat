/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,1'-(tetrachloroethylidene)bis(chloro-  (C14H8Cl6, CAS 68631-02-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene11TetrachloroethylideneBisChloro;
formula     C14H8Cl6;
CAS         68631-02-7;
InChIKey    ICPHWKKRDMBTDV-UHFFFAOYSA-N;
MW          388.918;      // g/mol [origin=calculated method=formula-sum]
Tc          1088.00;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.6276;      // -   [origin=predictive method=lee-kesler]
Tb          801.36;      // K   [origin=predictive method=joback]
HvapTb      76352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.65 1.3494 -0.00113212 3.544e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group CCl3; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group C; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-[1,2,2,2-tetrakis(chloranyl)-1-(3-chlorophenyl)ethyl]benzene" "1,1-bis(chlorophenyl)-1,2,2,2-tetrachloroethylene" "benzene, 1,1'-(tetrachloroethylidene)bis[chloro-" "1,1'-bis(chlorophenyl)-1,2,2,2-tetrachloroethylene" "1,1'-(1,2,2,2-tetrachloroethane-1,1-diyl)bis(3-chlorobenzene)" "1-chloro-3-[1,2,2,2-tetrachloro-1-(3-chlorophenyl)ethyl]benzene" );
standardThermochemistry
{
    dHf_298   5890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     598.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=206660.0
}
