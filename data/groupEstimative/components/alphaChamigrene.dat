/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-chamigrene  (C15H24, CAS 19912-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaChamigrene;
formula     C15H24;
CAS         19912-83-5;
InChIKey    SIBCECUUMHIAAM-OAHLLOKOSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          822.81;      // K   [origin=predictive method=joback]
Pc          21.816;      // bar [origin=predictive method=joback]
omega       0.4210;      // -   [origin=predictive method=lee-kesler]
Tb          586.39;      // K   [origin=predictive method=joback]
HvapTb      49276.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-192.66 2.03548 -0.00190628 7.71e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group C; count 2; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6r)-1,5,5,9-tetramethylspiro[5.5]undeca-1,9-diene" "(6r)-3,7,11,11-tetramethylspiro[5.5]undeca-3,7-diene" );
gibbsFormation
{
    dHf_298   -115030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     711.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=166100.0
    phase     gas;
}
