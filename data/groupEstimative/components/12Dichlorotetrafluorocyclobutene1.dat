/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dichlorotetrafluorocyclobutene-1  (C4Cl2F4, CAS 377-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dichlorotetrafluorocyclobutene1;
formula     C4Cl2F4;
CAS         377-93-5;
InChIKey    KAHIKRWJVIBASP-UHFFFAOYSA-N;
MW          194.936;      // g/mol [origin=calculated method=formula-sum]
Tc          563.71;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       0.3683;      // -   [origin=predictive method=lee-kesler]
Tb          379.00;      // K   [origin=predictive method=joback]
HvapTb      29090.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.63 0.9682 -0.001337 6.684e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Cl_C=C_; count 2; } { group C=C; count 1; } { group CF2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 2; } { group dC_ring; count 2; } { group F; count 4; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)-3,3,4,4-tetrakis(fluoranyl)cyclobutene" "1,2-dichlorotetrafluorocyclobut-1-ene" "1,2-dichloro-3,3,4,4-tetrafluorocyclobutene" "1,2-dichloro-3,3,4,4-tetrafluorocyclobut-1-ene" "1,2-dichlorotetrafluorocyclobutene" "cyclobutene, 1,2-dichloro-3,3,4,4-tetrafluoro-" );
gibbsFormation
{
    dHf_298   -830190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-779640.0
    phase     gas;
}
