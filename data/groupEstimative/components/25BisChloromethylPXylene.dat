/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-bis(chloromethyl)-p-xylene  (C10H12Cl2, CAS 6298-72-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25BisChloromethylPXylene;
formula     C10H12Cl2;
CAS         6298-72-2;
InChIKey    UYRPOMMBPQHVMN-UHFFFAOYSA-N;
MW          203.106;      // g/mol [origin=calculated method=formula-sum]
Tc          764.01;      // K   [origin=predictive method=joback]
Pc          25.872;      // bar [origin=predictive method=joback]
omega       0.5047;      // -   [origin=predictive method=lee-kesler]
Tb          544.88;      // K   [origin=predictive method=joback]
HvapTb      50886.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.572 0.71004 -0.00039108 7.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 2; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(chloromethyl)-2,5-dimethyl-benzene" "2,5-di(chloromethyl)-p-xylene" "1,4-bis(chloromethyl)-2,5-dimethylbenzene" "alpha(1),alpha(4)-dichlorodurene" "benzene, 1,4-bis(chloromethyl)-2,5-dimethyl-" "agn-pc-0d8uke" ".alpha.(1),.alpha.(4)-dichlorodurene" "benzene,4-bis(chloromethyl)-2,5-dimethyl-" );
standardThermochemistry
{
    dHf_298   -79090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=92980.0
}
