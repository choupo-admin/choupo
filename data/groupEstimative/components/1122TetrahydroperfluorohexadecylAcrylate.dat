/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2,2-tetrahydroperfluorohexadecyl acrylate  (C19H7F29O2, CAS 34362-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1122TetrahydroperfluorohexadecylAcrylate;
formula     C19H7F29O2;
CAS         34362-49-7;
InChIKey    KLOHTAIHCCMZIL-UHFFFAOYSA-N;
MW          818.205;      // g/mol [origin=calculated method=formula-sum]
Tc          764.27;      // K   [origin=predictive method=joback]
Pc          6.145;      // bar [origin=predictive method=joback]
omega       0.5047;      // -   [origin=predictive method=lee-kesler]
Tb          622.83;      // K   [origin=predictive method=joback]
HvapTb      22788.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-157.948 3.8374 -0.0038189 1.3442e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CF3; count 1; } { group CF2; count 13; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 14; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 29; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,16-nonacosakis(fluoranyl)hexadecyl prop-2-enoate" "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,16-nonacosafluorohexadecyl acrylate" "2-propenoic acid, 3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,16-nonacosafluorohexadecyl ester" "2-propenoic acid,3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,16-nonacosafluorohexadecylester" "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,16-nonacosafluorohexadecyl prop-2-enoate" "acrylicacid, 3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,13,13,14,14,15,15,16,16,16-nonacosafluorohexadecylester (8ci); 2-(perfluorotetradecyl)ethyl acrylate" );
gibbsFormation
{
    dHf_298   -6437030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1317.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5723160.0
    phase     gas;
}
