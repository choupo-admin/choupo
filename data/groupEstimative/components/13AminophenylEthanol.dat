/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(3-aminophenyl)ethanol  (C8H11NO, CAS 2454-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13AminophenylEthanol;
formula     C8H11NO;
CAS         2454-37-7;
InChIKey    QPKNDHZQPGMLCJ-UHFFFAOYSA-N;
MW          137.182;      // g/mol [origin=calculated method=formula-sum]
Tc          791.02;      // K   [origin=predictive method=joback]
Pc          43.684;      // bar [origin=predictive method=joback]
omega       0.9317;      // -   [origin=predictive method=lee-kesler]
Tb          578.57;      // K   [origin=predictive method=joback]
HvapTb      63272.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.89 0.72722 -0.00045256 1.049e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "m-(1-hydroxyethyl)aniline" "3-(1-hydroxyethyl)aniline" "(m-aminophenyl)methyl carbinol" "m-amino-alpha-methylbenzyl alcohol" "(3-aminophenyl)-1-ethanol" "3-(.alpha.-hydroxyethyl)-aniline" "3-amino-alpha-methylbenzyl alcohol" "benzyl alcohol, m-amino-alpha-methyl-" "benzenemethanol, 3-amino-alpha-methyl-" "1-(3-aminophenyl)ethan-1-ol" "m-amino-.alpha.-methylbenzyl alcohol" "3-amino-.alpha.-methylbenzyl alcohol" );
gibbsFormation
{
    dHf_298   -107110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46450.0
    phase     gas;
}
