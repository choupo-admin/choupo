/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-acetyl-4-(4-hydroxyphenyl)piperazine  (C12H16N2O2, CAS 67914-60-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Acetyl44HydroxyphenylPiperazine;
formula     C12H16N2O2;
CAS         67914-60-7;
InChIKey    AGVNLFCRZULMKK-UHFFFAOYSA-N;
MW          220.272;      // g/mol [origin=calculated method=formula-sum]
Tc          909.36;      // K   [origin=predictive method=joback]
Pc          37.045;      // bar [origin=predictive method=joback]
omega       0.9724;      // -   [origin=predictive method=lee-kesler]
Tb          675.89;      // K   [origin=predictive method=joback]
HvapTb      68822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.17 1.60712 -0.00135226 4.5356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH2N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-(4-hydroxyphenyl)piperazin-1-yl]ethanone" "4-(1-acetylpiperazin-4-yl)phenol" "4-(4-acetyl-1-piperazinyl)phenol" "1-acetyl-4-(4-hydroxyphenyl)-piperazine" "1-4-(4-hydroxyphenyl)piperazin-1-ylethanone" "1-(4-(4-hydroxyphenyl)piperazin-1-yl)ethanone" "4-(4-acetylpiperazin-4-yl)phenol" "sdccgmls-0066236.p001" "1-acetyl-4-(4'-hydroxyphenyl)piperazine" "k919" "n-acetyl-4-(4-hydroxyphenyl)-piperazine" "1-[4-(4-hydroxyphenyl)piperazin-1-yl]ethan-1-one" );
standardThermochemistry
{
    dHf_298   -122330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=156950.0
}
