/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethylpropane-1,3-diyl dioctadecanoate  (C41H80O4, CAS 15196-51-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethylpropane13DiylDioctadecanoate;
formula     C41H80O4;
CAS         15196-51-7;
InChIKey    WZZRCFLIGSUOOC-UHFFFAOYSA-N;
MW          637.087;      // g/mol [origin=calculated method=formula-sum]
Tc          1750.01;      // K   [origin=predictive method=joback]
Pc          3.807;      // bar [origin=predictive method=joback]
omega       -0.3893;      // -   [origin=predictive method=lee-kesler]
Tb          1250.89;      // K   [origin=predictive method=joback]
HvapTb      120378.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.036 3.91508 -0.0021892 4.344e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 32; } { group C; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 34; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,2-dimethyl-3-octadecanoyloxy-propyl) octadecanoate" "octadecanoic acid, 2,2-dimethyl-1,3-propanediyl ester" "octadecanoic acid, 1,1'-(2,2-dimethyl-1,3-propanediyl) ester" "(2,2-dimethyl-3-octadecanoyloxypropyl) octadecanoate" );
gibbsFormation
{
    dHf_298   -1532880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1816.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-323560.0
    phase     gas;
}
