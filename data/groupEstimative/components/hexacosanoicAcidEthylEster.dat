/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexacosanoic acid, ethyl ester  (C28H56O2, CAS 29030-81-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexacosanoicAcidEthylEster;
formula     C28H56O2;
CAS         29030-81-7;
InChIKey    VFWXXMBQXSOLQQ-UHFFFAOYSA-N;
MW          424.754;      // g/mol [origin=calculated method=formula-sum]
Tc          1105.92;      // K   [origin=predictive method=joback]
Pc          6.571;      // bar [origin=predictive method=joback]
omega       0.5370;      // -   [origin=predictive method=lee-kesler]
Tb          898.46;      // K   [origin=predictive method=joback]
HvapTb      85329.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.845 2.60904 -0.0014048 2.649e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 24; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 25; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl hexacosanoate" "ethyl hexacosanate" "agn-pc-00lxig" );
standardThermochemistry
{
    dHf_298   -938530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1297.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125490.0
}
