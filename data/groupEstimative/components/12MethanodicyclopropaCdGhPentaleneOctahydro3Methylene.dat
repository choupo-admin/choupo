/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-methanodicyclopropa[cd,gh]pentalene,octahydro-3-methylene-  (C10H10, CAS 64630-96-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12MethanodicyclopropaCdGhPentaleneOctahydro3Methylene;
formula     C10H10;
CAS         64630-96-2;
InChIKey    OYPVCPRRHGOFAI-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          613.09;      // K   [origin=predictive method=joback]
Pc          32.357;      // bar [origin=predictive method=joback]
omega       0.4156;      // -   [origin=predictive method=lee-kesler]
Tb          421.63;      // K   [origin=predictive method=joback]
HvapTb      35619.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-186.58 1.5689 -0.001641 6.7e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 8; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH_ring; count 8; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylideneoctahydro-1,2-methanodicyclopropa[cd,gh]pentalene" "1,2-methanodicyclopropa(cd,gh)pentalene, octahydro-3-methylene-" );
standardThermochemistry
{
    dHf_298   174450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     -178.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=439620.0
}
