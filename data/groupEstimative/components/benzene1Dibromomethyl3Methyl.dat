/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-(dibromomethyl)-3-methyl-  (C8H8Br2, CAS 63512-59-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1Dibromomethyl3Methyl;
formula     C8H8Br2;
CAS         63512-59-4;
InChIKey    JFCIOYXEHZUIHD-UHFFFAOYSA-N;
MW          263.96;      // g/mol [origin=calculated method=formula-sum]
Tc          798.15;      // K   [origin=predictive method=joback]
Pc          43.056;      // bar [origin=predictive method=joback]
omega       0.5060;      // -   [origin=predictive method=lee-kesler]
Tb          546.18;      // K   [origin=predictive method=joback]
HvapTb      48822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.29 0.70772 -0.00052156 1.523e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[bis(bromanyl)methyl]-3-methyl-benzene" "1-(dibromomethyl)-3-methylbenzene" "3-(dibromomethyl)-1-methylbenzene" );
gibbsFormation
{
    dHf_298   63990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=145460.0
    phase     gas;
}
