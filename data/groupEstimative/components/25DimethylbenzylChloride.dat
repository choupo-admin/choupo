/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethylbenzyl chloride  (C9H11Cl, CAS 824-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DimethylbenzylChloride;
formula     C9H11Cl;
CAS         824-45-3;
InChIKey    PECXPZGFZFGDRD-UHFFFAOYSA-N;
MW          154.637;      // g/mol [origin=calculated method=formula-sum]
Tc          695.99;      // K   [origin=predictive method=joback]
Pc          30.256;      // bar [origin=predictive method=joback]
omega       0.3976;      // -   [origin=predictive method=lee-kesler]
Tb          479.59;      // K   [origin=predictive method=joback]
HvapTb      43613.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.291 0.66774 -0.00038332 8.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(chloromethyl)-1,4-dimethyl-benzene" "2-(chloromethyl)-1,4-dimethylbenzene" "1-chloromethyl-2,5-dimethylbenzene" "benzene, 2-(chloromethyl)-1,4-dimethyl-" "2-chloromethyl-p-xylene" "benzenemethanol,2-bromo-5-fluoro-" "2 5-dimethylbenzyl chloride" "(2-bromo-5-fluorophenyl)methanol;" );
gibbsFormation
{
    dHf_298   -31240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=106120.0
    phase     gas;
}
