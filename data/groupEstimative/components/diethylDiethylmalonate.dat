/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl diethylmalonate  (C11H20O4, CAS 77-25-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylDiethylmalonate;
formula     C11H20O4;
CAS         77-25-8;
InChIKey    ZKBBUZRGPULIRN-UHFFFAOYSA-N;
MW          216.277;      // g/mol [origin=calculated method=formula-sum]
Tc          747.17;      // K   [origin=predictive method=joback]
Pc          19.841;      // bar [origin=predictive method=joback]
omega       0.7405;      // -   [origin=predictive method=lee-kesler]
Tb          564.49;      // K   [origin=predictive method=joback]
HvapTb      53598.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.234 1.06508 -0.0005572 7.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2,2-diethylpropanedioate" "diethylmalonic ester" "diethylmalonic acid diethyl ester" "propanedioic acid, diethyl-, diethyl ester" "diethylmalonic acid, diethyl ester" "diethyl 2,2-diethylmalonate" "diethylmalonate diethyl ester" "propanedioic acid, 2,2-diethyl-, 1,3-diethyl ester" "agn-pc-00srti" "diethyl-diethylmalonate" "diethyl diethylmalonate diethyl" "diethyl 3,3-pentanedicarboxylate" );
gibbsFormation
{
    dHf_298   -913680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-576160.0
    phase     gas;
}
