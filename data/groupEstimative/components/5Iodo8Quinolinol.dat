/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-iodo-8-quinolinol  (C9H6INO, CAS 13207-63-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Iodo8Quinolinol;
formula     C9H6INO;
CAS         13207-63-1;
InChIKey    SUQZNPQQZDQDPJ-UHFFFAOYSA-N;
MW          271.053;      // g/mol [origin=calculated method=formula-sum]
Tc          979.71;      // K   [origin=predictive method=joback]
Pc          51.534;      // bar [origin=predictive method=joback]
omega       0.6872;      // -   [origin=predictive method=lee-kesler]
Tb          683.62;      // K   [origin=predictive method=joback]
HvapTb      68803.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.51 0.94406 -0.0009137 3.524e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 1; } { group C5H3N; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 5; } { group dC_ring; count 4; } { group I; count 1; } { group OH_phenol; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-iodanylquinolin-8-ol" "5-iodoquinolin-8-ol" "8-quinolinol, 5-iodo-" "8-hydroxy-5-iodoquinoline" );
standardThermochemistry
{
    dHf_298   119390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=214880.0
}
