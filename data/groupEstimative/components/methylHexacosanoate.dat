/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl hexacosanoate  (C27H54O2, CAS 5802-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylHexacosanoate;
formula     C27H54O2;
CAS         5802-82-4;
InChIKey    VHUJBYYFFWDLNM-UHFFFAOYSA-N;
MW          410.727;      // g/mol [origin=calculated method=formula-sum]
Tc          1074.91;      // K   [origin=predictive method=joback]
Pc          6.907;      // bar [origin=predictive method=joback]
omega       0.6053;      // -   [origin=predictive method=lee-kesler]
Tb          875.58;      // K   [origin=predictive method=joback]
HvapTb      83103.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.754 2.51404 -0.0013504 2.53e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 23; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 24; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexacosanoic acid methyl ester" "hexacosanoic acid, methyl ester" "hexacosanoic acid,methyl ester" "hexacosanoic acid methyl ester (fame mix)" "ceroticacid, methyl ester;methyl cerotate;methyl hexacosanoate;methyln-hexacosanoate;" );
standardThermochemistry
{
    dHf_298   -917890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1259.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133910.0
}
