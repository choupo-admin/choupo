/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-1-(p-tolyl)ethanamine  (C9H13N, CAS 27298-98-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s1PTolylEthanamine;
formula     C9H13N;
CAS         27298-98-2;
InChIKey    UZDDXUMOXKDXNE-QMMMGPOBSA-N;
MW          135.21;      // g/mol [origin=calculated method=formula-sum]
Tc          735.13;      // K   [origin=predictive method=joback]
Pc          34.561;      // bar [origin=predictive method=joback]
omega       0.4785;      // -   [origin=predictive method=lee-kesler]
Tb          509.27;      // K   [origin=predictive method=joback]
HvapTb      48819.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.09 0.78824 -0.00047656 1.07e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s)-1-(4-methylphenyl)ethanamine" "(s)-(-)-1-(p-tolyl)ethylamine" "(s)-(-)-alpha,4-dimethylbenzylamine" "(r)-(+)-1-(p-tolyl)ethylamine" "(s)-(-)-4-(1-aminoethyl)toluene" "(s)-1-(p-tolyl)ethylamine" "(1s)-1-(4-methylphenyl)ethan-1-amine" "(s)-(+)-1-(4-methylphenyl)ethylamine" );
gibbsFormation
{
    dHf_298   24480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191690.0
    phase     gas;
}
