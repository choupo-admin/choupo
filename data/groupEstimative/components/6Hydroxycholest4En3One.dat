/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-hydroxycholest-4-en-3-one  (C27H44O2, CAS 69853-71-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Hydroxycholest4En3One;
formula     C27H44O2;
CAS         69853-71-0;
InChIKey    VUCDSTCRVYGRSG-QWEYYJNOSA-N;
MW          400.647;      // g/mol [origin=calculated method=formula-sum]
Tc          1248.29;      // K   [origin=predictive method=joback]
Pc          11.037;      // bar [origin=predictive method=joback]
omega       1.0089;      // -   [origin=predictive method=lee-kesler]
Tb          1015.40;      // K   [origin=predictive method=joback]
HvapTb      94083.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-269.957 3.3908 -0.00270584 9.443e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 9; } { group CH; count 7; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-6-oxidanyl-1,2,6,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-3-one" "cholest-4-en-3-one, 6-hydroxy-" "(8s,9s,10r,13r,14s,17r)-6-hydroxy-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-1,2,6,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-3-one" );
gibbsFormation
{
    dHf_298   -624930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     867.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80890.0
    phase     gas;
}
