/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, (heptyloxy)-  (C13H20O, CAS 32395-96-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneHeptyloxy;
formula     C13H20O;
CAS         32395-96-3;
InChIKey    VKFMYOVXGQWPHE-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          741.26;      // K   [origin=predictive method=joback]
Pc          21.593;      // bar [origin=predictive method=joback]
omega       0.6104;      // -   [origin=predictive method=lee-kesler]
Tb          546.14;      // K   [origin=predictive method=joback]
HvapTb      49218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.334 1.09672 -0.0006036 1.142e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptoxybenzene" "heptoxy-benzene" "(heptyloxy)benzene" );
standardThermochemistry
{
    dHf_298   -207340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65990.0
}
