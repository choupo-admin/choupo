/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-diphenyl-1-butene  (C16H16, CAS 14213-84-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Diphenyl1Butene;
formula     C16H16;
CAS         14213-84-4;
InChIKey    NJJOGKAVAWZLAU-UHFFFAOYSA-N;
MW          208.304;      // g/mol [origin=calculated method=formula-sum]
Tc          863.45;      // K   [origin=predictive method=joback]
Pc          24.029;      // bar [origin=predictive method=joback]
omega       0.5375;      // -   [origin=predictive method=lee-kesler]
Tb          623.20;      // K   [origin=predictive method=joback]
HvapTb      55720.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.648 1.386 -0.0009928 2.776e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenylbut-1-enylbenzene" "benzene, 1,1'-(butene-1,4-diyl)bis-" "benzene, 1,1'-(1-butene-1,4-diyl)bis-" );
gibbsFormation
{
    dHf_298   216710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=388880.0
    phase     gas;
}
