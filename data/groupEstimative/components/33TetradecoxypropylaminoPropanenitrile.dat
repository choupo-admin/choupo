/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(3-tetradecoxypropylamino)propanenitrile  (C20H40N2O, CAS 180389-78-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33TetradecoxypropylaminoPropanenitrile;
formula     C20H40N2O;
CAS         180389-78-0;
InChIKey    XDDXXOGSAJFOCB-UHFFFAOYSA-N;
MW          324.553;      // g/mol [origin=calculated method=formula-sum]
Tc          1019.74;      // K   [origin=predictive method=joback]
Pc          9.970;      // bar [origin=predictive method=joback]
omega       0.9509;      // -   [origin=predictive method=lee-kesler]
Tb          831.87;      // K   [origin=predictive method=joback]
HvapTb      79438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.998 1.85162 -0.0009708 1.762e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH2O; count 1; } { group CH2NH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group O; count 1; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propanenitrile, 3-((3-(tetradecyloxy)propyl)amino)-" "propanenitrile, 3-[[3-(tetradecyloxy)propyl]amino]-" );
gibbsFormation
{
    dHf_298   -370000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     993.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=235090.0
    phase     gas;
}
