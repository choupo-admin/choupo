/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3134837  (C19H16, CAS 7129-91-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3134837;
formula     C19H16;
CAS         7129-91-1;
InChIKey    UDLWLEYTFPJTFL-UHFFFAOYSA-N;
MW          244.337;      // g/mol [origin=calculated method=formula-sum]
Tc          997.19;      // K   [origin=predictive method=joback]
Pc          25.125;      // bar [origin=predictive method=joback]
omega       0.7672;      // -   [origin=predictive method=lee-kesler]
Tb          742.41;      // K   [origin=predictive method=joback]
HvapTb      67026.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.92 1.7894 -0.00157684 5.63e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 6; } { group AC; count 4; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group dCH_ring; count 6; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h-cyclopent(j)aceanthrylene, 2,7,8,9-tetrahydro-" );
gibbsFormation
{
    dHf_298   318270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=535680.0
    phase     gas;
}
