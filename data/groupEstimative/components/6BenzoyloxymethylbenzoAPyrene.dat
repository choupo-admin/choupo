/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-benzoyloxymethylbenzo(a)pyrene  (C28H18O2, CAS 42978-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6BenzoyloxymethylbenzoAPyrene;
formula     C28H18O2;
CAS         42978-42-7;
InChIKey    MEGZLHDPOVJNPI-UHFFFAOYSA-N;
MW          386.45;      // g/mol [origin=calculated method=formula-sum]
Tc          1305.10;      // K   [origin=predictive method=joback]
Pc          17.289;      // bar [origin=predictive method=joback]
omega       1.1463;      // -   [origin=predictive method=lee-kesler]
Tb          1039.96;      // K   [origin=predictive method=joback]
HvapTb      98453.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.079 2.2736 -0.00185144 5.963e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 16; } { group AC; count 9; } { group ACCH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 16; } { group dC_ring; count 10; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzo[b]pyren-6-ylmethyl benzoate" "benzo(a)pyrene, 6-benzoyloxymethyl-" "6-benzoyloxymethylbenzo[a]pyrene" );
gibbsFormation
{
    dHf_298   207470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=481650.0
    phase     gas;
}
