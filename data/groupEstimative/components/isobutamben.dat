/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutamben  (C11H15NO2, CAS 94-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutamben;
formula     C11H15NO2;
CAS         94-14-4;
InChIKey    PUYOAVGNCWPANW-UHFFFAOYSA-N;
MW          193.246;      // g/mol [origin=calculated method=formula-sum]
Tc          833.82;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       0.7388;      // -   [origin=predictive method=lee-kesler]
Tb          613.25;      // K   [origin=predictive method=joback]
HvapTb      60678.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.501 0.92344 -0.00049076 7.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropyl 4-azanylbenzoate" "isobutyl 4-aminobenzoate" "isocaine" "isobutyl p-aminobenzoate" "isobutylcaine" "benzamelid" "cicloforme" "cyclocaine" "cyclogesin" "isobutyl keloform" "cycloform" "2-methylpropyl 4-aminobenzoate" );
gibbsFormation
{
    dHf_298   -334080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-101840.0
    phase     gas;
}
