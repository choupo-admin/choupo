/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromoethanol  (C2H5BrO, CAS 540-51-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromoethanol;
formula     C2H5BrO;
CAS         540-51-2;
InChIKey    LDLCZOVUSADOIV-UHFFFAOYSA-N;
MW          124.965;      // g/mol [origin=calculated method=formula-sum]
Tc          585.80;      // K   [origin=predictive method=joback]
Pc          64.103;      // bar [origin=predictive method=joback]
omega       0.7046;      // -   [origin=predictive method=lee-kesler]
Tb          403.70;      // K   [origin=predictive method=joback]
HvapTb      43160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.552 0.266 -0.0001868 5.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylethanol" "ethylene bromohydrin" "ethanol, 2-bromo-" "bromoethanol" "2-bromo-1-ethanol" "glycol bromohydrin" "2-bromoethan-1-ol" "1-bromo-2-ethanol" "2-hydroxyethyl bromide" "ethylenebromohydrin" "2-bromoethyl alcohol" "brj" );
standardThermochemistry
{
    dHf_298   -210510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     335.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-156540.0
}
