/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-(2,4-dichlorophenoxy)butanoate  (C11H12Cl2O3, CAS 18625-12-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl424DichlorophenoxyButanoate;
formula     C11H12Cl2O3;
CAS         18625-12-2;
InChIKey    NKXSNMCGZZWMMW-UHFFFAOYSA-N;
MW          263.114;      // g/mol [origin=calculated method=formula-sum]
Tc          857.79;      // K   [origin=predictive method=joback]
Pc          23.588;      // bar [origin=predictive method=joback]
omega       0.7878;      // -   [origin=predictive method=lee-kesler]
Tb          643.42;      // K   [origin=predictive method=joback]
HvapTb      62267.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.273 0.74652 -0.00030692 1.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CH2COO; count 1; } { group CH2O; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-[2,4-bis(chloranyl)phenoxy]butanoate" "butanoic acid, 4-(2,4-dichlorophenoxy)-, methyl ester" "butyric acid, 4-(2,4-dichlorophenoxy)-, methyl ester" "methyldichlorophenoxybutanoate" "butanoic acid,4-(2,4-dichlorophenoxy)-, methyl ester" );
standardThermochemistry
{
    dHf_298   -537760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-304340.0
}
