/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, (3-methyl-2-butenyl)-  (C11H14, CAS 4489-84-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene3Methyl2Butenyl;
formula     C11H14;
CAS         4489-84-3;
InChIKey    XGADZHWYGCKKJF-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          698.12;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       0.3766;      // -   [origin=predictive method=lee-kesler]
Tb          482.00;      // K   [origin=predictive method=joback]
HvapTb      42394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.889 0.98984 -0.0006919 1.944e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbut-2-enylbenzene" "(3-methyl-2-butenyl)benzene" "2-butene, 3-methyl-1-phenyl-" "(3-methylbut-2-enyl)benzene" "3-methyl-1-phenyl-2-butene" "2-methyl-4-phenyl-2-butene" "benzene,(3-methyl-2-buten-1-yl)-" "2-butene,3-methyl-1-phenyl- (6ci,7ci,8ci); benzene, (3-methyl-2-butenyl)- (9ci);(3-methyl-2-butenyl)benzene; 2-methyl-4-phenyl-2-butene;3-methyl-1-phenyl-2-butene" );
standardThermochemistry
{
    dHf_298   73590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225820.0
}
