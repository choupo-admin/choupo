/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3,5-dibenzyloxybenzoate  (C22H20O4, CAS 58605-10-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl35Dibenzyloxybenzoate;
formula     C22H20O4;
CAS         58605-10-0;
InChIKey    GBQCMRLPXFXVIN-UHFFFAOYSA-N;
MW          348.398;      // g/mol [origin=calculated method=formula-sum]
Tc          1137.61;      // K   [origin=predictive method=joback]
Pc          17.419;      // bar [origin=predictive method=joback]
omega       1.0253;      // -   [origin=predictive method=lee-kesler]
Tb          896.02;      // K   [origin=predictive method=joback]
HvapTb      84945.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.818 1.55692 -0.00081592 1.106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 13; } { group AC; count 5; } { group CH2O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3,5-bis(phenylmethoxy)benzoate" "methyl 3,5-bis(benzyloxy)benzoate" "gbqcmrlpxfxvin-uhfffaoysa-" "3,5-dibenzyloxybenzoic acid methyl ester" "benzeneacetic acid,3,5-bis(phenylmethoxy)-" "3,5-bis(benzyloxy)benzoic acid methyl ester" "3,5-bis(phenylmethoxy)benzoic acid methyl ester" "benzoic acid, 3,5-bis(phenylmethoxy)-, methyl ester" "acetic acid,[3,5-bis(benzyloxy)phenyl]- (7ci,8ci);3,5-bis(benzyloxy)phenylacetic acid;3,5-dibenzyloxyphenylacetic acid;" );
gibbsFormation
{
    dHf_298   -392480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     755.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68040.0
    phase     gas;
}
