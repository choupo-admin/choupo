/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-methylenebis(4,6-di-tert-butylphenol)  (C29H44O2, CAS 14362-12-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Methylenebis46DiTertButylphenol;
formula     C29H44O2;
CAS         14362-12-0;
InChIKey    LXWZXEJDKYWBOW-UHFFFAOYSA-N;
MW          424.669;      // g/mol [origin=calculated method=formula-sum]
Tc          1336.58;      // K   [origin=predictive method=joback]
Pc          10.921;      // bar [origin=predictive method=joback]
omega       0.9731;      // -   [origin=predictive method=lee-kesler]
Tb          1084.72;      // K   [origin=predictive method=joback]
HvapTb      108192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-149.819 3.17564 -0.00254796 8.391e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group C; count 4; } { group ACH; count 4; } { group AC; count 5; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group CH2; count 1; } { group C; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-ditert-butyl-6-[(3,5-ditert-butyl-2-oxidanyl-phenyl)methyl]phenol" "2,2'-methylenebis[4,6-di-tert-butylphenol]" "phenol, 2,2'-methylenebis(4,6-bis(1,1-dimethylethyl)-" "phenol, 2,2'-methylenebis[4,6-bis(1,1-dimethylethyl)-" "2,2'-methanediylbis(4,6-di-tert-butylphenol)" "2,4-bis(tert-butyl)-6-{[3,5-bis(tert-butyl)-2-hydroxyphenyl]methyl}phenol" "2,4-ditert-butyl-6-[(3,5-ditert-butyl-2-hydroxyphenyl)methyl]phenol" );
standardThermochemistry
{
    dHf_298   -604330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     945.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=81720.0
}
