/*--------------------------------*- Choupo -*-----------------------*\
  Component: formic acid, cycloheptyl ester  (C8H14O2, CAS 75024-32-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H14O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        formicAcidCycloheptylEster;
formula     C8H14O2;
CAS         75024-32-7;
InChIKey    KQPTVERBLKLHLD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          590.44;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.1875;      // -   [origin=predictive method=lee-kesler]
Tb          382.88;      // K   [origin=predictive method=joback]
HvapTb      31630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.61 0.8844 -0.000599 1.604e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloheptyl methanoate" "cycloheptyl formate" "cycloheptanol,1-formate" );
gibbsFormation
{
    dHf_298   -83840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72790.0
    phase     gas;
}
