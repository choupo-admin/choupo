/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-(4-chlorophenylthio)-2-methylpropionate  (C11H13ClO2S, CAS 55009-84-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl34Chlorophenylthio2Methylpropionate;
formula     C11H13ClO2S;
CAS         55009-84-2;
InChIKey    LQTPIEYMBJPFQS-UHFFFAOYSA-N;
MW          244.733;      // g/mol [origin=calculated method=formula-sum]
Tc          880.92;      // K   [origin=predictive method=joback]
Pc          25.899;      // bar [origin=predictive method=joback]
omega       0.6859;      // -   [origin=predictive method=lee-kesler]
Tb          646.93;      // K   [origin=predictive method=joback]
HvapTb      61239.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.501 0.86273 -0.00042756 4.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group COO; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-(4-chlorophenyl)sulfanyl-2-methyl-propanoate" "methyl 3-[(4-chlorophenyl)thio]-2-methylpropanoate" "methyl 3-[(4-chlorophenyl)sulfanyl]-2-methylpropanoate" "methyl 3-(4-chlorophenyl)sulfanyl-2-methylpropanoate" );
gibbsFormation
{
    dHf_298   -341740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147100.0
    phase     gas;
}
