/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, (3-cyclohexyl-1,1-dimethylbutyl)-  (C18H28, CAS 63302-58-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene3Cyclohexyl11Dimethylbutyl;
formula     C18H28;
CAS         63302-58-9;
InChIKey    VLFGLKBCRKWFFQ-UHFFFAOYSA-N;
MW          244.422;      // g/mol [origin=calculated method=formula-sum]
Tc          886.16;      // K   [origin=predictive method=joback]
Pc          17.610;      // bar [origin=predictive method=joback]
omega       0.5108;      // -   [origin=predictive method=lee-kesler]
Tb          654.00;      // K   [origin=predictive method=joback]
HvapTb      56683.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-139.139 1.88876 -0.0012426 3.095e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-cyclohexyl-2-methyl-pentan-2-yl)benzene" "(4-cyclohexyl-2-methylpentan-2-yl)benzene" );
gibbsFormation
{
    dHf_298   -138030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     671.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=237940.0
    phase     gas;
}
