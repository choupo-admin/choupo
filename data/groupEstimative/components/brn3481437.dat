/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3481437  (C28H28O2, CAS 63041-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3481437;
formula     C28H28O2;
CAS         63041-56-5;
InChIKey    FRQSMRFSNSDREC-UHFFFAOYSA-N;
MW          396.53;      // g/mol [origin=calculated method=formula-sum]
Tc          1388.63;      // K   [origin=predictive method=joback]
Pc          16.418;      // bar [origin=predictive method=joback]
omega       1.4181;      // -   [origin=predictive method=lee-kesler]
Tb          1134.12;      // K   [origin=predictive method=joback]
HvapTb      118890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-224.646 3.04644 -0.00290428 1.1522e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 2; } { group ACH; count 12; } { group AC; count 8; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C_ring; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 8; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,14-dipropylnaphtho[1,2-b]phenanthrene-7,14-diol" "9,10-di-n-propyl-9-10-dihydroxy-9,10-dihydro-1,2,5,6-dibenzanthracene" "9,10-dihydro-9,10-dihydroxy-9,10-di-n-propyl-1,2:5,6-dibenzanthracene" "9,10-dihydroxy-9,10-di-n-propyl-9,10-dihydro-1,2:5,6-dibenzanthracene" "dibenz(a,h)anthracene-7,14-diol, 7,14-dihydro-7,14-dipropyl-" );
gibbsFormation
{
    dHf_298   -27290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     879.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=365000.0
    phase     gas;
}
