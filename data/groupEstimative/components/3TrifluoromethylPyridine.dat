/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(trifluoromethyl)pyridine  (C6H4F3N, CAS 3796-23-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3TrifluoromethylPyridine;
formula     C6H4F3N;
CAS         3796-23-4;
InChIKey    JTZSFNHHVULOGJ-UHFFFAOYSA-N;
MW          147.099;      // g/mol [origin=calculated method=formula-sum]
Tc          617.35;      // K   [origin=predictive method=joback]
Pc          40.159;      // bar [origin=predictive method=joback]
omega       0.3625;      // -   [origin=predictive method=lee-kesler]
Tb          411.84;      // K   [origin=predictive method=joback]
HvapTb      33689.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.61 0.68986 -0.00056406 1.762e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C5H4N; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group F; count 3; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-trifluoromethylpyridine" "pyridine, 3-(trifluoromethyl)-" "alpha,alpha,alpha-trifluoro-3-picoline" "3-trifluoromethyl pyridine" "3-trifluoromethyl-pyridine" "3-(trifluoromethyl)-pyridine" "m-trifluoromethylpyridine" "3-(trifluoromethyl)pyridine;5-(trifluoromethyl)pyridine;" );
standardThermochemistry
{
    dHf_298   -494930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-392490.0
}
