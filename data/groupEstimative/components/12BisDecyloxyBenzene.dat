/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(decyloxy)benzene  (C26H46O2, CAS 25934-47-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12BisDecyloxyBenzene;
formula     C26H46O2;
CAS         25934-47-8;
InChIKey    YDBAUWPGWGYZTF-UHFFFAOYSA-N;
MW          390.652;      // g/mol [origin=calculated method=formula-sum]
Tc          1066.80;      // K   [origin=predictive method=joback]
Pc          8.490;      // bar [origin=predictive method=joback]
omega       0.8146;      // -   [origin=predictive method=lee-kesler]
Tb          870.98;      // K   [origin=predictive method=joback]
HvapTb      81228.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.648 2.20904 -0.00113276 1.892e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-didecoxybenzene" "benzene, 1,2-di(decyloxy)-" "1-[2-(decyloxy)phenoxy]decane" "1,2-(didecyloxy)benzene" );
standardThermochemistry
{
    dHf_298   -619350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1078.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60820.0
}
