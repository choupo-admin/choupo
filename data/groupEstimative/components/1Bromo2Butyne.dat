/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2-butyne  (C4H5Br, CAS 3355-28-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo2Butyne;
formula     C4H5Br;
CAS         3355-28-0;
InChIKey    LNNXOEHOXSYWLD-UHFFFAOYSA-N;
MW          132.988;      // g/mol [origin=calculated method=formula-sum]
Tc          581.39;      // K   [origin=predictive method=joback]
Pc          53.047;      // bar [origin=predictive method=joback]
omega       0.2397;      // -   [origin=predictive method=lee-kesler]
Tb          366.28;      // K   [origin=predictive method=joback]
HvapTb      33085.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.001 0.27222 -0.00017306 4.948e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group Br; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group tC; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylbut-2-yne" "1-bromobut-2-yne" "2-butynyl bromide" "1-bromo-but-2-yne" "2-butyne, 1-bromo-" "b237" "2-butyne,bromo- (6ci,7ci);1-bromo-2-butyne;1-bromo-3-methyl-2-butyne;2-butyn-1-ylbromide;2-butynyl bromide;4-bromobut-2-yne;" );
standardThermochemistry
{
    dHf_298   172740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=199920.0
}
