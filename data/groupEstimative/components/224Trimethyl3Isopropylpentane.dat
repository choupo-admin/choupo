/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4-trimethyl-3-isopropylpentane  (C11H24, CAS 61868-90-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224Trimethyl3Isopropylpentane;
formula     C11H24;
CAS         61868-90-4;
InChIKey    SZPCILWZDHUKLW-UHFFFAOYSA-N;
MW          156.313;      // g/mol [origin=calculated method=formula-sum]
Tc          629.83;      // K   [origin=predictive method=joback]
Pc          20.091;      // bar [origin=predictive method=joback]
omega       0.3589;      // -   [origin=predictive method=lee-kesler]
Tb          446.73;      // K   [origin=predictive method=joback]
HvapTb      37620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.63 1.19244 -0.000756 1.901e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH; count 3; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH; count 3; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4-trimethyl-3-propan-2-yl-pentane" );
gibbsFormation
{
    dHf_298   -294960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37260.0
    phase     gas;
}
