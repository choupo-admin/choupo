/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-diethyl-m-toluidine  (C11H17N, CAS 67330-61-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DiethylMToluidine;
formula     C11H17N;
CAS         67330-61-4;
InChIKey    OXYMEFWXAVMOEB-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          780.89;      // K   [origin=predictive method=joback]
Pc          26.819;      // bar [origin=predictive method=joback]
omega       0.6116;      // -   [origin=predictive method=lee-kesler]
Tb          565.43;      // K   [origin=predictive method=joback]
HvapTb      54983.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.372 0.85336 -0.00044808 8.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 2; } { group ACCH3; count 1; } { group ACCH2; count 2; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-diethyl-3-methyl-aniline" "m-toluidine, 2,6-diethyl-" "2,6-diethyl-3-methylaniline" "benzenamine, 2,6-diethyl-3-methyl-" );
gibbsFormation
{
    dHf_298   -34460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191710.0
    phase     gas;
}
