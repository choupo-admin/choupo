/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(hydroxymethyl)propane-1,3-diol; butyric acid; heptanoic acid  (C16H34O8, CAS 68937-22-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BisHydroxymethylPropane13DiolButyricAcidHeptanoicAcid;
formula     C16H34O8;
CAS         68937-22-4;
InChIKey    BKRSVSWPEAFCKQ-UHFFFAOYSA-N;
MW          354.44;      // g/mol [origin=calculated method=formula-sum]
Tc          1589.61;      // K   [origin=predictive method=joback]
Pc          17.879;      // bar [origin=predictive method=joback]
omega       0.8365;      // -   [origin=predictive method=lee-kesler]
Tb          1224.99;      // K   [origin=predictive method=joback]
HvapTb      151546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (75.871 1.47484 -0.0004556 -8.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group C; count 1; } { group OH; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group C; count 1; } { group OH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)propane-1,3-diol;butanoic acid;heptanoic acid" "heptanoic acid, mixed esters with butyric acid and pentaerythritol" "2,2-bis(hydroxymethyl)propane-1,3-diol; butanoic acid; heptanoic acid" );
gibbsFormation
{
    dHf_298   -1915020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1265.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1357940.0
    phase     gas;
}
