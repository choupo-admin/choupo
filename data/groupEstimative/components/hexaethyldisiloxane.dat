/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexaethyldisiloxane  (C12H30OSi2, CAS 994-49-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H30OSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        hexaethyldisiloxane;
formula     C12H30OSi2;
CAS         994-49-0;
InChIKey    WILBTFWIBAOWLN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          246.541;      // g/mol [origin=calculated method=formula-sum]
Tc          670.18;      // K   [origin=predictive method=joback]
Pc          14.490;      // bar [origin=predictive method=joback]
omega       0.4616;      // -   [origin=predictive method=lee-kesler]
Tb          499.38;      // K   [origin=predictive method=joback]
HvapTb      45304.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (99.116 0.66832 0.0003116 -3.576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 6; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethyl(triethylsilyloxy)silane" "disiloxane, hexaethyl-" "hexaethyl disiloxane" "disiloxane, 1,1,1,3,3,3-hexaethyl-" "1,1,3,3,3-hexaethyldisiloxane" "1,1,1,3,3,3-hexaethyldisiloxane" );
gibbsFormation
{
    dHf_298   -646470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     887.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-264360.0
    phase     gas;
}
