/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,9,10,10-tetramethyl-9,10-dihydroanthracene-2,3,6,7-tetrol  (C18H20O4, CAS 68527-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        991010Tetramethyl910Dihydroanthracene2367Tetrol;
formula     C18H20O4;
CAS         68527-81-1;
InChIKey    OVYOPMBBXJXHQV-UHFFFAOYSA-N;
MW          300.354;      // g/mol [origin=calculated method=formula-sum]
Tc          1265.99;      // K   [origin=predictive method=joback]
Pc          41.303;      // bar [origin=predictive method=joback]
omega       1.6449;      // -   [origin=predictive method=lee-kesler]
Tb          995.52;      // K   [origin=predictive method=joback]
HvapTb      110724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-227.53 2.77328 -0.00318556 1.4336e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group ACH; count 4; } { group AC; count 4; } { group ACOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,9,10,10-tetramethylanthracene-2,3,6,7-tetrol" "9,10-dihydro-9,9,10,10-tetramethylanthracene-2,3,6,7-tetrol" "2,3,6,7-anthracenetetrol, 9,10-dihydro-9,9,10,10-tetramethyl-" "2,3,6,7-tetrahydroxy-9,9,10,10-tetramethyl-9, 10-dihydroanthracene" );
standardThermochemistry
{
    dHf_298   -584870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     724.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-258080.0
}
