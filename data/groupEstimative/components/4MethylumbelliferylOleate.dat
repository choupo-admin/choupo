/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylumbelliferyl oleate  (C28H40O4, CAS 18323-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethylumbelliferylOleate;
formula     C28H40O4;
CAS         18323-58-5;
InChIKey    NKQFKJYKCVDLPT-UHFFFAOYSA-N;
MW          440.624;      // g/mol [origin=calculated method=formula-sum]
Tc          1235.76;      // K   [origin=predictive method=joback]
Pc          8.733;      // bar [origin=predictive method=joback]
omega       0.8384;      // -   [origin=predictive method=lee-kesler]
Tb          1008.76;      // K   [origin=predictive method=joback]
HvapTb      97298.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.216 2.44784 -0.00153336 3.676e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH=CH; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methyl-2-oxidanylidene-chromen-7-yl) octadec-9-enoate" "4-methylumbelliferyl elaidate" "(4-methyl-2-oxochromen-7-yl) octadec-9-enoate" "9-octadecenoicacid (z)-, 4-methyl-2-oxo-2h-1-benzopyran-7-yl ester; oleic acid, ester with 7-hydroxy-4-methylcoumarin(8ci); coumarin, 7-hydroxy-4-methyl-, oleate (8ci); 4-methylumbelliferoneoleate; 4-methylumbelliferyl oleate; oleoyl 4-methylumbelliferone" "9-octadecenoicacid, 4-methyl-2-oxo-2h-1-benzopyran-7-yl ester, (e)-; 4-methylumbelliferone elaidate" );
gibbsFormation
{
    dHf_298   -779390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1112.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-161600.0
    phase     gas;
}
