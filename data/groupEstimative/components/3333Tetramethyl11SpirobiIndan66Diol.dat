/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,3',3'-tetramethyl-1,1'-spirobi(indan)-6,6'-diol  (C21H24O2, CAS 1568-80-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3333Tetramethyl11SpirobiIndan66Diol;
formula     C21H24O2;
CAS         1568-80-5;
InChIKey    SICLLPHPVFCNTJ-UHFFFAOYSA-N;
MW          308.421;      // g/mol [origin=calculated method=formula-sum]
Tc          1177.87;      // K   [origin=predictive method=joback]
Pc          25.846;      // bar [origin=predictive method=joback]
omega       1.1058;      // -   [origin=predictive method=lee-kesler]
Tb          909.90;      // K   [origin=predictive method=joback]
HvapTb      90136.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-312.65 3.19188 -0.00358884 1.6004e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 3; } { group ACH; count 6; } { group AC; count 4; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group C_ring; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1',1'-tetramethyl-3,3'-spirobi[2h-indene]-5,5'-diol" "1,1'-spirobi(1h-indene)-6,6'-diol, 2,2',3,3'-tetrahydro-3,3,3',3'-tetramethyl-" "2,2',3,3'-tetrahydro-3,3,3',3'-tetramethyl-1,1'-spirobi(1h-indene)-6,6'-diol" "1,1'-spirobi[1h-indene]-6,6'-diol, 2,2',3,3'-tetrahydro-3,3,3',3'-tetramethyl-" "3,3'-spirobis(1,1-dimethylindan-5-ol)" "1,1'-spirobi[1h-indene]-6,6'-diol,2,2',3,3'-tetrahydro-3,3,3',3'-tetramethyl-" "1,1'-spirobi[indan]-6,6'-diol,3,3,3',3'-tetramethyl- (6ci,7ci,8ci); 2,2',3,3'-tetrahydro-3,3,3',3'-tetramethyl-1,1'-spirobi[1h-indene]-6,6'-diol;3,3,3',3'-tetramethyl-1,1'-spirobi[indane]-6,6'-diol;6,6'-dihydroxy-3,3,3',3'-tetramethyl-1,1'-spirobiindane; si; si (diol)" );
gibbsFormation
{
    dHf_298   -204130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     767.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=131680.0
    phase     gas;
}
