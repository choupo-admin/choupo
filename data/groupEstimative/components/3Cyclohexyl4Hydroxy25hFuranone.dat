/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cyclohexyl-4-hydroxy-2(5h)furanone  (C10H14O3, CAS 78128-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Cyclohexyl4Hydroxy25hFuranone;
formula     C10H14O3;
CAS         78128-81-1;
InChIKey    UOHNVACTBABRQJ-UHFFFAOYSA-N;
MW          182.219;      // g/mol [origin=calculated method=formula-sum]
Tc          825.76;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       0.9998;      // -   [origin=predictive method=lee-kesler]
Tb          618.88;      // K   [origin=predictive method=joback]
HvapTb      64207.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.91 1.0575 -0.0006658 1.52e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 1; } { group dC_ring; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-cyclohexyl-3-oxidanyl-2h-furan-5-one" "2(5h)furanone, 3-cyclohexyl-4-hydroxy-" "4-cyclohexyl-5-hydroxyfuran-3-one" "alpha-cyclohexyl-beta-hydroxy-delta(sup alpha,beta)-butenolid [german]" "alpha-cyclohexyl-beta-hydroxy-delta(sup alpha,beta)-butenolid" );
standardThermochemistry
{
    dHf_298   -536940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-310260.0
}
