/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dimethylcyclopentane  (C7H14, CAS 2453-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dimethylcyclopentane;
formula     C7H14;
CAS         2453-00-1;
InChIKey    XAZKFISIRYLAEE-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          563.83;      // K   [origin=predictive method=joback]
Pc          32.916;      // bar [origin=predictive method=joback]
omega       0.2326;      // -   [origin=predictive method=lee-kesler]
Tb          370.37;      // K   [origin=predictive method=joback]
HvapTb      31124.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.02 0.77404 -0.000429 8.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentane, 1,3-dimethyl-" "cis-1,3-dimethylcyclopentane" "trans-1,3-dimethylcyclopentane" "cyclopentane, 1,3-dimethyl-, cis-" "cyclopentane, 1,3-dimethyl-, (e)-" "cyclopentane, 1,3-dimethyl-, trans-" "cyclopentane, 1,3-dimethyl-, (1r,3s)-rel-" "agn-pc-00kzij" "cyclopentane,1,3-dimethyl-" "1,3-dimethylcyclopentane, cis-trans" );
standardThermochemistry
{
    dHf_298   -147670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     335.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36900.0
}
