/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloheneicosane  (C21H42, CAS 296-78-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloheneicosane;
formula     C21H42;
CAS         296-78-6;
InChIKey    JQPXEQQDYZHEDV-UHFFFAOYSA-N;
MW          294.567;      // g/mol [origin=calculated method=formula-sum]
Tc          1034.75;      // K   [origin=predictive method=joback]
Pc          14.557;      // bar [origin=predictive method=joback]
omega       0.4431;      // -   [origin=predictive method=lee-kesler]
Tb          768.35;      // K   [origin=predictive method=joback]
HvapTb      65658.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-164.56 2.0034 -0.000559 -1.72e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 21; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 21; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohenicosane" "agn-pc-00ni2m" );
gibbsFormation
{
    dHf_298   -494510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1284.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23400.0
    phase     gas;
}
