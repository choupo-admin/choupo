/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 2-methylprop-2-enoate; 3-trimethoxysilylpropyl 2-methylprop-2-enoate  (C18H34O7Si, CAS 61803-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C18H34O7Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        butyl2Methylprop2Enoate3Trimethoxysilylpropyl2Methylprop2Eno;
formula     C18H34O7Si;
CAS         61803-98-3;
InChIKey    KARBZFAQMABQHH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          390.548;      // g/mol [origin=calculated method=formula-sum]
Tc          978.60;      // K   [origin=predictive method=joback]
Pc          10.399;      // bar [origin=predictive method=joback]
omega       0.8871;      // -   [origin=predictive method=lee-kesler]
Tb          791.06;      // K   [origin=predictive method=joback]
HvapTb      77114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (190.116 0.96212 0.000346 -4.716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH2=C; count 2; } { group CH3O; count 3; } { group COO; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group dCH2; count 2; } { group dC; count 2; } { group O; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 2-methylprop-2-enoate;3-trimethoxysilylpropyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, butyl ester, polymer with 3-(trimethoxysilyl)propyl 2-methyl-2-propenoate" );
standardThermochemistry
{
    dHf_298   -1438030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1210.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-886000.0
}
