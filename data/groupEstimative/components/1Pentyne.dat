/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentyne  (C5H8, CAS 627-19-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pentyne;
formula     C5H8;
CAS         627-19-0;
InChIKey    IBXNCJKFFQIKKY-UHFFFAOYSA-N;
MW          68.119;      // g/mol [origin=calculated method=formula-sum]
Tc          478.62;      // K   [origin=predictive method=joback]
Pc          41.623;      // bar [origin=predictive method=joback]
omega       0.1951;      // -   [origin=predictive method=lee-kesler]
Tb          304.12;      // K   [origin=predictive method=joback]
HvapTb      26582.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.122 0.38492 -0.00024413 6.669e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-1-yne" "acetylene, propyl-" "propylacetylene" "pentyne" "agn-pc-0cqajg" "1-pentine(3ci); propylacetylene" );
gibbsFormation
{
    dHf_298   145370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     320.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=214290.0
    phase     gas;
}
