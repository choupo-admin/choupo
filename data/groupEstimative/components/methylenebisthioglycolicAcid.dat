/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylenebisthioglycolic acid  (C5H8O4S2, CAS 2068-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylenebisthioglycolicAcid;
formula     C5H8O4S2;
CAS         2068-24-8;
InChIKey    CZEVAMMETWVBOD-UHFFFAOYSA-N;
MW          196.235;      // g/mol [origin=calculated method=formula-sum]
Tc          980.47;      // K   [origin=predictive method=joback]
Pc          45.286;      // bar [origin=predictive method=joback]
omega       1.2644;      // -   [origin=predictive method=lee-kesler]
Tb          742.58;      // K   [origin=predictive method=joback]
HvapTb      74686.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.743 0.56918 -0.000313 4.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group COOH; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group COOH; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxy-2-oxoethylsulfanylmethylsulfanyl)ethanoic acid" "methylenedithiodiacetic acid" "acetic acid, 2,2'-[methylenebis(thio)]bis-" "acetic acid, (methylenedithio)di-" "2-({[(carboxymethyl)thio]methyl}thio)acetic acid" "acetic acid, 2,2'-(methylenebis(thio))bis-" "methylenebis-(thioglycollic acid)" "2,2'-(methylenebis(thio))bisacetic acid" "acetic acid,2'-[methylenebis(thio)]bis-" "acetic acid,2,2'-[methylenebis(thio)]bis-" "2-(carboxymethylsulfanylmethylsulfanyl)acetic acid" "({[(carboxymethyl)sulfanyl]methyl}sulfanyl)acetic acid" );
gibbsFormation
{
    dHf_298   -763330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-630360.0
    phase     gas;
}
