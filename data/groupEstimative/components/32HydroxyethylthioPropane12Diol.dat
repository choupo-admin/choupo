/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-hydroxyethylthio)propane-1,2-diol  (C5H12O3S, CAS 1468-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32HydroxyethylthioPropane12Diol;
formula     C5H12O3S;
CAS         1468-40-2;
InChIKey    RFEMNKMKESLWMT-UHFFFAOYSA-N;
MW          152.208;      // g/mol [origin=calculated method=formula-sum]
Tc          831.52;      // K   [origin=predictive method=joback]
Pc          51.240;      // bar [origin=predictive method=joback]
omega       1.9171;      // -   [origin=predictive method=lee-kesler]
Tb          658.88;      // K   [origin=predictive method=joback]
HvapTb      83190.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.134 0.58109 -0.0003024 4.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group OH; count 3; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 1; } { group OH; count 3; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-hydroxyethylsulfanyl)propane-1,2-diol" "1,2-propanediol, 3-((2-hydroxyethyl)thio)-" "1,2-propanediol, 3-[(2-hydroxyethyl)thio]-" "3-((2-hydroxyethyl)thio)propane-1,2-diol" "3-[(2-hydroxyethyl)sulfanyl]propane-1,2-diol" );
standardThermochemistry
{
    dHf_298   -566630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-388560.0
}
