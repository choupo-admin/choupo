/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-indene, 2-decyl-2,3-dihydro-  (C19H30, CAS 66292-05-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1hIndene2Decyl23Dihydro;
formula     C19H30;
CAS         66292-05-5;
InChIKey    QSLCYKGOSTVZKJ-UHFFFAOYSA-N;
MW          258.449;      // g/mol [origin=calculated method=formula-sum]
Tc          868.13;      // K   [origin=predictive method=joback]
Pc          14.839;      // bar [origin=predictive method=joback]
omega       0.7583;      // -   [origin=predictive method=lee-kesler]
Tb          672.72;      // K   [origin=predictive method=joback]
HvapTb      60739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.231 1.82132 -0.00119416 3.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-decyl-2,3-dihydro-1h-indene" );
standardThermochemistry
{
    dHf_298   -137630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     693.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=272630.0
}
