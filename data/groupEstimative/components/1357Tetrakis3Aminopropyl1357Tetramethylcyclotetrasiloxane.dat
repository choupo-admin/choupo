/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5,7-tetrakis(3-aminopropyl)-1,3,5,7-tetramethylcyclotetrasiloxane  (C16H44N4O4Si4, CAS 85191-11-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H44N4O4Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1357Tetrakis3Aminopropyl1357Tetramethylcyclotetrasiloxane;
formula     C16H44N4O4Si4;
CAS         85191-11-3;
InChIKey    IXPFJHYWZBIMEI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          468.892;      // g/mol [origin=calculated method=formula-sum]
Tc          1211.64;      // K   [origin=predictive method=joback]
Pc          12.277;      // bar [origin=predictive method=joback]
omega       1.0947;      // -   [origin=predictive method=lee-kesler]
Tb          984.88;      // K   [origin=predictive method=joback]
HvapTb      113384.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (185.562 1.10248 0.0004654 -5.828e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CH2NH2; count 4; } { group SiO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group O_ring; count 4; } { group NH2; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[4,6,8-tris(3-azanylpropyl)-2,4,6,8-tetramethyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocan-2-yl]propan-1-amine" "3-[4,6,8-tris(3-aminopropyl)-2,4,6,8-tetramethyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocan-2-yl]propan-1-amine" );
gibbsFormation
{
    dHf_298   -1125910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1258.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-357520.0
    phase     gas;
}
