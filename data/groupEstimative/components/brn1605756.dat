/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1605756  (C21H26N2O5, CAS 17766-70-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1605756;
formula     C21H26N2O5;
CAS         17766-70-0;
InChIKey    IYHLPFHSSALZLY-UHFFFAOYSA-N;
MW          386.448;      // g/mol [origin=calculated method=formula-sum]
Tc          1165.66;      // K   [origin=predictive method=joback]
Pc          16.619;      // bar [origin=predictive method=joback]
omega       1.2242;      // -   [origin=predictive method=lee-kesler]
Tb          937.47;      // K   [origin=predictive method=joback]
HvapTb      90406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.14 1.73788 -0.00090454 1.3426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 6; } { group AC; count 6; } { group CH3O; count 4; } { group CH2N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 4; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(4-methoxyphenyl)piperazin-1-yl]-(3,4,5-trimethoxyphenyl)methanone" "1-(p-methoxyphenyl)-4-(3,4,5-trimethoxybenzoyl)piperazine" "piperazine, 1-(p-methoxyphenyl)-4-(3,4,5-trimethoxybenzoyl)-" "ketone, 4-(p-methoxyphenyl)piperazinyl 3,4,5-trimethoxyphenyl" "[4-(4-methoxyphenyl)piperazin-1-yl](3,4,5-trimethoxyphenyl)methanone" );
standardThermochemistry
{
    dHf_298   -469010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     812.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41240.0
}
