/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-naphthamide  (C11H9NO, CAS 2243-81-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Naphthamide;
formula     C11H9NO;
CAS         2243-81-4;
InChIKey    RMHJJUOPOWPRBP-UHFFFAOYSA-N;
MW          171.199;      // g/mol [origin=calculated method=formula-sum]
Tc          879.42;      // K   [origin=predictive method=joback]
Pc          39.407;      // bar [origin=predictive method=joback]
omega       0.7135;      // -   [origin=predictive method=lee-kesler]
Tb          628.32;      // K   [origin=predictive method=joback]
HvapTb      62045.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.31 0.9406 -0.00070018 2.0336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 7; } { group dC_ring; count 3; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene-1-carboxamide" "1-naphthalenecarboxamide" "1-naphthalimide" "1-naphthylamide" "naphthalenecarboxamide" "a-naphthamide" "alpha-naphthamide" "alpha-napthoic acid amide" "naphthalene-1-carboxylic acid amide" );
standardThermochemistry
{
    dHf_298   66970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=188700.0
}
