/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pent-2-enylcyclopentan-1-one  (C10H16O, CAS 51608-18-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Pent2Enylcyclopentan1One;
formula     C10H16O;
CAS         51608-18-5;
InChIKey    ZIJOSCABGITYIL-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          731.31;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       0.4692;      // -   [origin=predictive method=lee-kesler]
Tb          515.66;      // K   [origin=predictive method=joback]
HvapTb      42316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.438 0.93722 -0.0004874 8.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentanone, 2-(2e)-2-pentenyl-" "cyclopentanone, 2-(2e)-2-penten-1-yl-" "agn-pc-00l3g2" "cyclopentanone, 2-(2-pentenyl)-" "cyclopentanone,2-(2e)-2-penten-1-yl-" "cyclopentanone,2-(2-pentenyl)-, (e)-; cyclopentanone, 2-(2e)-2-pentenyl- (9ci);2-(trans-2-pentenyl)cyclopentanone" );
standardThermochemistry
{
    dHf_298   -209730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=27500.0
}
