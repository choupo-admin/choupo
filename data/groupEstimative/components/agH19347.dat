/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-h-19347  (C13H18O2, CAS 79637-74-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agH19347;
formula     C13H18O2;
CAS         79637-74-4;
InChIKey    LSAQODYZOZWHRI-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          779.73;      // K   [origin=predictive method=joback]
Pc          23.338;      // bar [origin=predictive method=joback]
omega       0.5688;      // -   [origin=predictive method=lee-kesler]
Tb          567.09;      // K   [origin=predictive method=joback]
HvapTb      50562.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-130.48 1.5541 -0.0011151 3.154e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 5; } { group CH2=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid,octahydro-4,7-methano-1h-inden-5-yl ester" "acrylicacid, hexahydro-4,7-methanoindan-5-yl ester (7ci,8ci); 4,7-methanoindan-5-ol,hexahydro-, acrylate (8ci); dicyclopentanyl acrylate; fa 513a; fa 513as;fancryl 513a; fancryl fa 513a; mpl 209s; tetrahydrodicyclopentadienyl acrylate;tricyclo[5.2.1.02,6]decanyl acrylate; tricyclodecanyl acrylate" );
standardThermochemistry
{
    dHf_298   -331940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9220.0
}
