/*--------------------------------*- Choupo -*-----------------------*\
  Component: (dispiro[bicyclo[2.2.1]hepta-2,5-diene-7,1'- cyclopropane-2',7''-bicyclo[2.2.1]hepta[2,5]diene])  (C15H14, CAS 73045-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dispiroBicyclo221Hepta25Diene71Cyclopropane27Bicyclo221Hepta;
formula     C15H14;
CAS         73045-27-9;
InChIKey    YVIYAEURKSYKGY-UHFFFAOYSA-N;
MW          194.277;      // g/mol [origin=calculated method=formula-sum]
Tc          819.20;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.4405;      // -   [origin=predictive method=lee-kesler]
Tb          568.95;      // K   [origin=predictive method=joback]
HvapTb      47106.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-324.88 2.5166 -0.00285212 1.2484e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group C; count 2; } { group CH=CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(dispiro(bicyclo(2.2.1)hepta-2,5-diene-7,1'- cyclopropane-2',7''-bicyclo(2.2.1)hepta(2,5)diene))" );
gibbsFormation
{
    dHf_298   252330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     236.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=480320.0
    phase     gas;
}
