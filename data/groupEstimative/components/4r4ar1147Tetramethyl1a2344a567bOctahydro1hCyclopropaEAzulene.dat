/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4r,4ar)-1,1,4,7-tetramethyl-1a,2,3,4,4a,5,6,7b-octahydro-1h-cyclopropa[e]azulene  (C15H24, CAS 489-40-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4r4ar1147Tetramethyl1a2344a567bOctahydro1hCyclopropaEAzulene;
formula     C15H24;
CAS         489-40-7;
InChIKey    SPCXZDDGSGTVAW-XUWDKUNYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          789.38;      // K   [origin=predictive method=joback]
Pc          20.055;      // bar [origin=predictive method=joback]
omega       0.4664;      // -   [origin=predictive method=lee-kesler]
Tb          571.58;      // K   [origin=predictive method=joback]
HvapTb      48914.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-173.45 1.92628 -0.001635 6.014e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 4; } { group C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,4ar)-1,1,4,7-tetramethyl-1a,2,3,4,4a,5,6,7b-octahydrocyclopropa[e]azulene" "1h-cycloprop(e)azulene, 1a,2,3,4,4a,5,6,7b-octahydro-1,1,4,7-tetramethyl-, (1ar,4r,4ar,7bs)-" "(1ar-(1aalpha,4alpha,4abeta,7balpha))-1a,2,3,4,4a,5,6,7b-octahydro-1,1,4,7-tetramethyl-1h-cycloprop(e)azulene" );
gibbsFormation
{
    dHf_298   -137450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=223260.0
    phase     gas;
}
