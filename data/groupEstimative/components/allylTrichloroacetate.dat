/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl trichloroacetate  (C5H5Cl3O2, CAS 6304-34-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylTrichloroacetate;
formula     C5H5Cl3O2;
CAS         6304-34-3;
InChIKey    LJQCONXCOYBYIE-UHFFFAOYSA-N;
MW          203.443;      // g/mol [origin=calculated method=formula-sum]
Tc          690.57;      // K   [origin=predictive method=joback]
Pc          32.916;      // bar [origin=predictive method=joback]
omega       0.4536;      // -   [origin=predictive method=lee-kesler]
Tb          477.96;      // K   [origin=predictive method=joback]
HvapTb      45320.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.961 0.5502 -0.0004095 1.075e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CCl3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl 2,2,2-tris(chloranyl)ethanoate" "trichloroacetic acid 2-propenyl ester" "trichloroacetic acid allyl ester" "prop-2-en-1-yl trichloroacetate" "prop-2-enyl 2,2,2-trichloroacetate" );
gibbsFormation
{
    dHf_298   -394350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-264260.0
    phase     gas;
}
