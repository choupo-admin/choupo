/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl benzene-1,4-dicarboxylate;2,2-dimethylpentanedioic acid;ethane-1,2-diol  (C19H28O10, CAS 65072-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylBenzene14Dicarboxylate22DimethylpentanedioicAcidEtha;
formula     C19H28O10;
CAS         65072-11-9;
InChIKey    SMDRFMNPDLHSTH-UHFFFAOYSA-N;
MW          416.423;      // g/mol [origin=calculated method=formula-sum]
Tc          1567.09;      // K   [origin=predictive method=joback]
Pc          15.860;      // bar [origin=predictive method=joback]
omega       1.1573;      // -   [origin=predictive method=lee-kesler]
Tb          1257.37;      // K   [origin=predictive method=joback]
HvapTb      142618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (93.774 1.44388 -0.00033296 -1.856e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 2; } { group _CH2OH_2; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-benzenedicarboxylic acid, 1,4-dimethyl ester, polymer with 1,5-dimethyl pentanedioate and 1,2-ethanediol" "1,4-benzenedicarboxylic acid, dimethyl ester, polymer with dimethyl pentanedioate and 1,2-ethanediol" "dimethyl benzene-1,4-dicarboxylate; 2,2-dimethylpentanedioic acid; ethane-1,2-diol" );
standardThermochemistry
{
    dHf_298   -2081980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1270.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1577000.0
}
