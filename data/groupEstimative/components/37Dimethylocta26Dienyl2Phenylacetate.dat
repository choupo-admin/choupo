/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethylocta-2,6-dienyl 2-phenylacetate  (C18H24O2, CAS 102-22-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethylocta26Dienyl2Phenylacetate;
formula     C18H24O2;
CAS         102-22-7;
InChIKey    UXAIJXIHZDZMSK-UHFFFAOYSA-N;
MW          272.388;      // g/mol [origin=calculated method=formula-sum]
Tc          912.62;      // K   [origin=predictive method=joback]
Pc          16.051;      // bar [origin=predictive method=joback]
omega       0.7782;      // -   [origin=predictive method=lee-kesler]
Tb          704.42;      // K   [origin=predictive method=joback]
HvapTb      65421.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.716 1.61996 -0.0010642 2.698e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH=C; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH; count 2; } { group dC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethylocta-2,6-dienyl 2-phenylethanoate" "(z)-3,7-dimethylocta-2,6-dienyl phenylacetate" "benzeneacetic acid, (2e)-3,7-dimethyl-2,6-octadien-1-yl ester" "benzeneacetic acid,(2e)-3,7-dimethyl-2,6-octadien-1-yl ester" "benzeneacetic acid,(2z)-3,7-dimethyl-2,6-octadien-1-yl ester" "aceticacid, phenyl-, (z)-3,7-dimethyl-2,6-octadienyl ester (8ci); benzeneacetic acid,(2z)-3,7-dimethyl-2,6-octadienyl ester (9ci); benzeneacetic acid,3,7-dimethyl-2,6-octadienyl ester, (z)-; 2,6-octadien-1-ol, 3,7-dimethyl-,phenylacetate, (z)- (8ci); (z)-3,7-dimethylocta-2,6-dienyl phenylacetate" );
gibbsFormation
{
    dHf_298   -280740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     780.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46060.0
    phase     gas;
}
