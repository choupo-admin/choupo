/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-2,5-dibutoxybenzene  (C14H21ClO2, CAS 68052-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro25Dibutoxybenzene;
formula     C14H21ClO2;
CAS         68052-10-8;
InChIKey    YXZPUUPBQVIBTL-UHFFFAOYSA-N;
MW          256.77;      // g/mol [origin=calculated method=formula-sum]
Tc          835.92;      // K   [origin=predictive method=joback]
Pc          18.388;      // bar [origin=predictive method=joback]
omega       0.7845;      // -   [origin=predictive method=lee-kesler]
Tb          638.83;      // K   [origin=predictive method=joback]
HvapTb      59563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.746 1.01634 -0.00043332 3.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 3; } { group AC; count 2; } { group CH2O; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dibutoxy-2-chloranyl-benzene" "1,4-dibutoxy-2-chlorobenzene" "benzene, 1,4-dibutoxy-2-chloro-" "2,5-dibutoxychlorobenzene" "2,5-dibutoxy-1-chlorobenzene" "1,4-dibutoxy-2-chloro-benzene" "yxzpuupbqvibtl-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -398880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-61780.0
    phase     gas;
}
