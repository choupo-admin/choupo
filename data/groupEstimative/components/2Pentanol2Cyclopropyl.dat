/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pentanol, 2-cyclopropyl-  (C8H16O, CAS 24230-08-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Pentanol2Cyclopropyl;
formula     C8H16O;
CAS         24230-08-8;
InChIKey    WEXFBWATVRHNFT-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          660.04;      // K   [origin=predictive method=joback]
Pc          32.840;      // bar [origin=predictive method=joback]
omega       0.7184;      // -   [origin=predictive method=lee-kesler]
Tb          478.33;      // K   [origin=predictive method=joback]
HvapTb      48698.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.808 1.07454 -0.0008338 2.65e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyclopropylpentan-2-ol" "cyclopropanemethanol, .alpha.-methyl-.alpha.-propyl-" "2-cyclopropyl-2-pentanol" );
standardThermochemistry
{
    dHf_298   -296630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-56750.0
}
