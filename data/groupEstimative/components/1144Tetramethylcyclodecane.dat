/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,4,4-tetramethylcyclodecane  (C14H28, CAS 15841-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1144Tetramethylcyclodecane;
formula     C14H28;
CAS         15841-11-9;
InChIKey    FTJLDAFUIYCCRB-UHFFFAOYSA-N;
MW          196.378;      // g/mol [origin=calculated method=formula-sum]
Tc          785.98;      // K   [origin=predictive method=joback]
Pc          20.661;      // bar [origin=predictive method=joback]
omega       0.3275;      // -   [origin=predictive method=lee-kesler]
Tb          552.36;      // K   [origin=predictive method=joback]
HvapTb      45264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-189.97 1.97488 -0.001643 6.132e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 8; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,4,4-tetramethyl-cyclodecane" "cyclodecane,1,1,4,4-tetramethyl-" );
gibbsFormation
{
    dHf_298   -292470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     847.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24360.0
    phase     gas;
}
