/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecyl sulfide  (C24H50S, CAS 2469-45-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecylSulfide;
formula     C24H50S;
CAS         2469-45-6;
InChIKey    UPYPTOCXMIWHSG-UHFFFAOYSA-N;
MW          370.724;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.72;      // K   [origin=predictive method=joback]
Pc          8.140;      // bar [origin=predictive method=joback]
omega       0.7719;      // -   [origin=predictive method=lee-kesler]
Tb          817.50;      // K   [origin=predictive method=joback]
HvapTb      75835.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.672 2.27823 -0.0012416 2.468e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 21; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 22; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-dodecylsulfanyldodecane" "dilauryl sulfide" "didodecyl sulfide" "dodecane, 1,1'-thiobis-" "n-dodecyl sulfide" "bis(dodecyl)sulfide" "bis(n-dodecyl)sulfide" "dodecylthiododecane" "lauryl sulfide" "didodecyl sulphide" "dodecane,1'-thiobis-" "dodecyl sulfide (8ci)" );
gibbsFormation
{
    dHf_298   -496820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1152.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184320.0
    phase     gas;
}
