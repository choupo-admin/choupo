/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-diphenylmethane diisocyanate  (C15H10N2O2, CAS 101-68-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44DiphenylmethaneDiisocyanate;
formula     C15H10N2O2;
CAS         101-68-8;
InChIKey    UPMLOUAZCHDJJD-UHFFFAOYSA-N;
MW          250.257;      // g/mol [origin=calculated method=formula-sum]
Tc          984.28;      // K   [origin=predictive method=joback]
Pc          28.354;      // bar [origin=predictive method=joback]
omega       0.9085;      // -   [origin=predictive method=lee-kesler]
Tb          739.46;      // K   [origin=predictive method=joback]
HvapTb      73924.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 1; } { group dCd; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene" "diphenylmethane diisocyanate" "p,p'-diphenylmethane diisocyanate" "4,4'-methylenebis(phenyl isocyanate)" "bis(4-isocyanatophenyl)methane" "1,1'-methylenebis(4-isocyanatobenzene)" "methylbisphenyl isocyanate" "isonate" "4,4'-diisocyanatodiphenylmethane" "polymeric mdi" "methylene bisphenyl isocyanate" "bis(p-isocyanatophenyl)methane" );
