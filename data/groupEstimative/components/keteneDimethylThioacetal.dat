/*--------------------------------*- Choupo -*-----------------------*\
  Component: ketene dimethyl thioacetal  (C4H8S2, CAS 51102-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        keteneDimethylThioacetal;
formula     C4H8S2;
CAS         51102-74-0;
InChIKey    GGCGAESAURTGKY-UHFFFAOYSA-N;
MW          120.228;      // g/mol [origin=calculated method=formula-sum]
Tc          653.46;      // K   [origin=predictive method=joback]
Pc          43.226;      // bar [origin=predictive method=joback]
omega       0.2896;      // -   [origin=predictive method=lee-kesler]
Tb          425.24;      // K   [origin=predictive method=joback]
HvapTb      37542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.77 0.35252 -0.0001386 4e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group CH3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(methylsulfanyl)ethene" "1,1-bis(methylthio)ethylene" "1,1-(dimethylthio)ethene" "ethene,1,1-bis(methylthio)-" "ch2=c(sch3)2" "1,1-bis(methylsulfanyl)-ethene" "1,1-bis(methylthio)ethene;1,1-bis(methylthio)ethylene" );
gibbsFormation
{
    dHf_298   73490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128330.0
    phase     gas;
}
