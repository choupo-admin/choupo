/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, polymer with 5-amino-1,3,3-trimethylcyclohexanemethanamine and butyl 2-propenoate  (C20H38N2O4, CAS 72089-02-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcidPolymerWith5Amino133Trimethylcyclohexanemethan;
formula     C20H38N2O4;
CAS         72089-02-2;
InChIKey    FPRUVZRIZVVRRH-UHFFFAOYSA-N;
MW          370.534;      // g/mol [origin=calculated method=formula-sum]
Tc          1248.76;      // K   [origin=predictive method=joback]
Pc          12.819;      // bar [origin=predictive method=joback]
omega       1.1063;      // -   [origin=predictive method=lee-kesler]
Tb          1012.84;      // K   [origin=predictive method=joback]
HvapTb      102724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.356 2.22418 -0.0013806 3.693e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group C; count 2; } { group CH2=CH; count 2; } { group CH2NH2; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group dCH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(aminomethyl)-3,5,5-trimethyl-cyclohexan-1-amine;butyl prop-2-enoate;prop-2-enoic acid" "butyl acrylate, acrylic acid, isophoronediamine polymer" );
standardThermochemistry
{
    dHf_298   -984360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1372.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-439650.0
}
