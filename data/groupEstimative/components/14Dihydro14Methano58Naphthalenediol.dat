/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dihydro-1,4-methano-5,8-naphthalenediol  (C11H10O2, CAS 3090-47-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dihydro14Methano58Naphthalenediol;
formula     C11H10O2;
CAS         3090-47-9;
InChIKey    PQZMLJBZPCMYDX-UHFFFAOYSA-N;
MW          174.199;      // g/mol [origin=calculated method=formula-sum]
Tc          905.51;      // K   [origin=predictive method=joback]
Pc          51.832;      // bar [origin=predictive method=joback]
omega       0.9049;      // -   [origin=predictive method=lee-kesler]
Tb          652.55;      // K   [origin=predictive method=joback]
HvapTb      68992.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.14 1.475 -0.00152556 6.192e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 2; } { group ACCH; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-methanonaphthalene-5,8-diol, 1,4-dihydro-" "1,4-dihydro-1,4-methanonaphthalene-5,8-diol" "5,8-endomethylene-5,8-dihydro-1,4-naphthohydroquinone" );
gibbsFormation
{
    dHf_298   -190390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     287.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1160.0
    phase     gas;
}
