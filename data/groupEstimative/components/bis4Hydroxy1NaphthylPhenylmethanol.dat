/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(4-hydroxy-1-naphthyl)phenylmethanol  (C27H20O3, CAS 6948-88-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis4Hydroxy1NaphthylPhenylmethanol;
formula     C27H20O3;
CAS         6948-88-5;
InChIKey    OUYLDJXFDLBCTQ-UHFFFAOYSA-N;
MW          392.454;      // g/mol [origin=calculated method=formula-sum]
Tc          1476.89;      // K   [origin=predictive method=joback]
Pc          26.353;      // bar [origin=predictive method=joback]
omega       1.7051;      // -   [origin=predictive method=lee-kesler]
Tb          1195.51;      // K   [origin=predictive method=joback]
HvapTb      128539.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-194.68 2.6747 -0.00239288 8.469e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 17; } { group AC; count 7; } { group OH; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 17; } { group dC_ring; count 9; } { group OH; count 1; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[oxidanyl-(4-oxidanylnaphthalen-1-yl)-phenyl-methyl]naphthalen-1-ol" "4,4'-[hydroxy(phenyl)methylene]di(1-naphthol)" "bis(4-hydroxynaphthyl)phenylmethan-1-ol" "4,4 -[alpha-hydroxybenzylidene]di-1-naphthol" "bis(4-hydroxy-naphthalen-1-yl)phenylmethanol" "4-[hydroxy(4-hydroxynaphthalen-1-yl)benzyl]naphthalen-1-ol" "4-[hydroxy-(4-hydroxynaphthalen-1-yl)-phenyl-methyl]naphthalen-1-ol" "4-[hydroxy-(4-hydroxynaphthalen-1-yl)-phenylmethyl]naphthalen-1-ol" "4-hydroxy-alpha-(4-hydroxynaphthyl)-alpha-phenylnaphthalene-1-methanol" );
gibbsFormation
{
    dHf_298   -47420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     723.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=264510.0
    phase     gas;
}
