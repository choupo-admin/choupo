/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxymyristic acid  (C14H28O3, CAS 2507-55-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxymyristicAcid;
formula     C14H28O3;
CAS         2507-55-3;
InChIKey    JYZJYKOZGGEXSX-UHFFFAOYSA-N;
MW          244.375;      // g/mol [origin=calculated method=formula-sum]
Tc          936.46;      // K   [origin=predictive method=joback]
Pc          17.758;      // bar [origin=predictive method=joback]
omega       1.3487;      // -   [origin=predictive method=lee-kesler]
Tb          757.17;      // K   [origin=predictive method=joback]
HvapTb      80213.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.629 1.42452 -0.000844 1.927e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanyltetradecanoic acid" "2-hydroxytetradecanoic acid" "alpha-hydroxymyristic acid" ".alpha.-hydroxymyristic acid" "dl-alpha-hydroxymyristic acid" "tetradecanoic acid, 2-hydroxy-" "alpha-hydroxy-n-tetradecylic acid" "tetradecanoic acid, 2-hydroxy" "2-hydroxymyristate" "alpha-hydroxymyristate" "a-hydroxymyristate" "a-hydroxymyristate" );
gibbsFormation
{
    dHf_298   -840070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     795.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-416170.0
    phase     gas;
}
