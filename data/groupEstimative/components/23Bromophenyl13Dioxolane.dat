/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-bromophenyl)-1,3-dioxolane  (C9H9BrO2, CAS 17789-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Bromophenyl13Dioxolane;
formula     C9H9BrO2;
CAS         17789-14-9;
InChIKey    VYPYKCPWNPPBBX-UHFFFAOYSA-N;
MW          229.073;      // g/mol [origin=calculated method=formula-sum]
Tc          829.65;      // K   [origin=predictive method=joback]
Pc          42.441;      // bar [origin=predictive method=joback]
omega       0.5433;      // -   [origin=predictive method=lee-kesler]
Tb          572.52;      // K   [origin=predictive method=joback]
HvapTb      54278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.55 0.8843 -0.00060096 1.527e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group FCH2O; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromobenzaldehyde ethylene acetal" "1,3-dioxolane, 2-(3-bromophenyl)-" "1-bromo-3-(1,3-dioxolan-2-yl)benzene" "m-bromobenzaldehyde ethylene acetal" "2-(m-bromophenyl)-1,3-dioxolane" "1,3-dioxolane,2-(m-bromophenyl)- (8ci);2-(3-bromophenyl)dioxolane;3-(1,3-dioxolan-2-yl)phenyl bromide;3-bromobenzaldehyde ethylene acetal;m-bromobenzaldehyde ethylene acetal;" );
gibbsFormation
{
    dHf_298   -181220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     291.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6310.0
    phase     gas;
}
