/*--------------------------------*- Choupo -*-----------------------*\
  Component: menogene  (C10H16, CAS 586-63-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        menogene;
formula     C10H16;
CAS         586-63-0;
InChIKey    CIPXOBMYVWRNLL-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          664.03;      // K   [origin=predictive method=joback]
Pc          27.614;      // bar [origin=predictive method=joback]
omega       0.3222;      // -   [origin=predictive method=lee-kesler]
Tb          453.63;      // K   [origin=predictive method=joback]
HvapTb      39442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.62 0.94236 -0.00055928 1.243e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-6-propan-2-ylidene-cyclohexene" "p-mentha-2,4(8)-diene" "cyclohexene, 3-methyl-6-(1-methylethylidene)-" "3-methyl-6-(1-methylethylidene)cyclohexene" "isoterpinolene" "2,4(8)-p-menthadiene" "3-methyl-6-propan-2-ylidenecyclohexene" "cyclohexene,3-methyl-6-(1-methylethylidene)-" "p-mentha-2,4(8)-diene(8ci); 2,4(8)-p-menthadiene; isoterpinolene" );
standardThermochemistry
{
    dHf_298   -71390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124640.0
}
