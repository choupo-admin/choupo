/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-3-methoxy-2-pentene  (C6H12O, CAS 53260-03-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans3Methoxy2Pentene;
formula     C6H12O;
CAS         53260-03-0;
InChIKey    SDCXDHFQQVVBEN-GQCTYLIASA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          540.30;      // K   [origin=predictive method=joback]
Pc          32.504;      // bar [origin=predictive method=joback]
omega       0.3184;      // -   [origin=predictive method=lee-kesler]
Tb          363.34;      // K   [origin=predictive method=joback]
HvapTb      31398.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.061 0.53056 -0.0002777 5.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-methoxypent-2-ene" "2-pentene, 3-methoxy-, (z)-" );
standardThermochemistry
{
    dHf_298   -191960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-33690.0
}
