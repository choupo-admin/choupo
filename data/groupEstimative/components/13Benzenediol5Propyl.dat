/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenediol, 5-propyl-  (C9H12O2, CAS 500-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Benzenediol5Propyl;
formula     C9H12O2;
CAS         500-49-2;
InChIKey    FRNQLQRBNSSJBK-UHFFFAOYSA-N;
MW          152.193;      // g/mol [origin=calculated method=formula-sum]
Tc          827.07;      // K   [origin=predictive method=joback]
Pc          47.366;      // bar [origin=predictive method=joback]
omega       0.8298;      // -   [origin=predictive method=lee-kesler]
Tb          593.44;      // K   [origin=predictive method=joback]
HvapTb      63932.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.038 1.08912 -0.00100972 3.876e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-propylbenzene-1,3-diol" "divarin" "5-propylresorcinol" "agn-pc-0coh8j" );
gibbsFormation
{
    dHf_298   -347180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-171930.0
    phase     gas;
}
