/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-cyclohexanedimethanamine,1-ethyl-  (C10H22N2, CAS 65122-18-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Cyclohexanedimethanamine1Ethyl;
formula     C10H22N2;
CAS         65122-18-1;
InChIKey    RQZPVTJKRKQPGB-UHFFFAOYSA-N;
MW          170.3;      // g/mol [origin=calculated method=formula-sum]
Tc          814.37;      // K   [origin=predictive method=joback]
Pc          29.313;      // bar [origin=predictive method=joback]
omega       0.6441;      // -   [origin=predictive method=lee-kesler]
Tb          588.58;      // K   [origin=predictive method=joback]
HvapTb      58105.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.877 1.46512 -0.0011652 4.092e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group CH2NH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(aminomethyl)-4-ethyl-cyclohexyl]methanamine" "1,4-cyclohexanedimethanamine, 1-ethyl-" "1-ethylcyclohexanedimethylamine" "1,4-cyclohexanebis(methylamine), 1-ethyl-" "[4-(aminomethyl)-4-ethylcyclohexyl]methanamine" );
gibbsFormation
{
    dHf_298   -132930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     645.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=177470.0
    phase     gas;
}
