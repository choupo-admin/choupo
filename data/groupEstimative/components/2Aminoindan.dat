/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-aminoindan  (C9H11N, CAS 2975-41-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Aminoindan;
formula     C9H11N;
CAS         2975-41-9;
InChIKey    LMHHFZAXSANGGM-UHFFFAOYSA-N;
MW          133.194;      // g/mol [origin=calculated method=formula-sum]
Tc          755.18;      // K   [origin=predictive method=joback]
Pc          40.108;      // bar [origin=predictive method=joback]
omega       0.4747;      // -   [origin=predictive method=lee-kesler]
Tb          516.45;      // K   [origin=predictive method=joback]
HvapTb      49120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.65 0.9332 -0.00069356 2.068e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 2; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydro-1h-inden-2-amine" "indan-2-amine" "2-aminoindane" "2-indanamine" "2,3-dihydro-1h-inden-2-ylamine" "indane-2-ylamine" "1h-inden-2-amine, 2,3-dihydro-" "2-aminoindanehydrochloride" "2-indanylamine" "2-amino indane" "indan-2-ylamine" "2-indanamine,indan-2-amine" );
gibbsFormation
{
    dHf_298   102560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=254880.0
    phase     gas;
}
