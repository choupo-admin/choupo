/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[3.2.0]hept-1-ene  (C7H10, CAS 22630-75-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo320Hept1Ene;
formula     C7H10;
CAS         22630-75-7;
InChIKey    PKCMTAKKGOCYFF-UHFFFAOYSA-N;
MW          94.157;      // g/mol [origin=calculated method=formula-sum]
Tc          593.88;      // K   [origin=predictive method=joback]
Pc          41.570;      // bar [origin=predictive method=joback]
omega       0.2753;      // -   [origin=predictive method=lee-kesler]
Tb          386.32;      // K   [origin=predictive method=joback]
HvapTb      32437.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.94 0.872 -0.00072664 2.483e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[3.2.0]hept-4-ene" "bicyclo(3.2.0)hept-1-ene" "agn-pc-00q40a" );
standardThermochemistry
{
    dHf_298   18280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     266.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=145500.0
}
