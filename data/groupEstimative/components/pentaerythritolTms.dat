/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentaerythritol, tms  (C17H44O4Si4, CAS 2114-25-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C17H44O4Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pentaerythritolTms;
formula     C17H44O4Si4;
CAS         2114-25-2;
InChIKey    DCRQMOJXJXVZFC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          424.875;      // g/mol [origin=calculated method=formula-sum]
Tc          861.56;      // K   [origin=predictive method=joback]
Pc          8.758;      // bar [origin=predictive method=joback]
omega       0.5373;      // -   [origin=predictive method=lee-kesler]
Tb          680.61;      // K   [origin=predictive method=joback]
HvapTb      62956.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (228.234 0.66724 0.0010304 -8.25e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group C; count 1; } { group CH2O; count 4; } { group Si; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group CH2; count 4; } { group C; count 1; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[3-trimethylsilyloxy-2,2-bis(trimethylsilyloxymethyl)propoxy]silane" "2,2,8,8-tetramethyl-5,5-bis{[(trimethylsilyl)oxy]methyl}-3,7-dioxa-2,8-disilanonane" "2,2,8,8-tetramethyl-5,5-bis(((trimethylsilyl)oxy)methyl)-3,7-dioxa-2,8-disilanonane" "2,2,8,8-tetramethyl-5,5-bis[[(trimethylsilyl)oxy]methyl]-3,7-dioxa-2,8-disilanonane" "3,7-dioxa-2,8-disilanonane,2,2,8,8-tetramethyl-5,5-bis[[(trimethylsilyl)oxy]methyl]-" "3,7-dioxa-2,8-disilanonane,2,2,8,8-tetramethyl-5,5-bis[(trimethylsiloxy)methyl]- (7ci,8ci);(neopentanetetrayltetraoxy)tetrakis(trimethylsilane);1,3-bis[(trimethylsilyl)oxy]-2,2-bis[[(trimethylsilyl)oxy]methyl]propane" );
gibbsFormation
{
    dHf_298   -1378320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1330.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-743940.0
    phase     gas;
}
