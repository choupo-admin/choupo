/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethyl-1,3-dioxane  (C6H12O2, CAS 766-20-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dimethyl13Dioxane;
formula     C6H12O2;
CAS         766-20-1;
InChIKey    VREPYGYMOSZTKJ-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          610.50;      // K   [origin=predictive method=joback]
Pc          37.180;      // bar [origin=predictive method=joback]
omega       0.3186;      // -   [origin=predictive method=lee-kesler]
Tb          405.66;      // K   [origin=predictive method=joback]
HvapTb      38090.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.59 0.66344 -0.0003004 2.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxane, 2,4-dimethyl-" "2,4-dimethyl-m-dioxane" "m-dioxane, 2,4-dimethyl-" "cis-2,4-dimethyl-1,3-dioxane" "2,4-dimethyl-[1,3]dioxane" "1,3-dioxane,2,4-dimethyl-" "trans-2,4-dimethyl-1,3-dioxane" "m-dioxane, 2,4-dimethyl- (8ci)" "m-dioxane, 2,4-dimethyl-, trans-" );
gibbsFormation
{
    dHf_298   -397190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     214.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-155860.0
    phase     gas;
}
