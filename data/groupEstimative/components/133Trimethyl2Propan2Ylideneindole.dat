/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,3-trimethyl-2-propan-2-ylideneindole  (C14H19N, CAS 82458-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        133Trimethyl2Propan2Ylideneindole;
formula     C14H19N;
CAS         82458-41-1;
InChIKey    YXIRXGTXIVOOCN-UHFFFAOYSA-N;
MW          201.313;      // g/mol [origin=calculated method=formula-sum]
Tc          791.02;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.5501;      // -   [origin=predictive method=lee-kesler]
Tb          573.25;      // K   [origin=predictive method=joback]
HvapTb      51196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.84 1.6942 -0.00158456 6.233e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dC; count 1; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,3-trimethyl-2-propan-2-ylidene-indole" "1,3,3-trimethyl-2-isopropylideneindolenine" "1,3,3-trimethyl-2-(1-methylethylidene)-2,3-1h-indole" "1,3,3-trimethyl-2-(propan-2-ylidene)-2,3-dihydro-1h-indole" "1h-indole, 2,3-dihydro-1,3,3-trimethyl-2-(1-methylethylidene)-" );
gibbsFormation
{
    dHf_298   120740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=384830.0
    phase     gas;
}
