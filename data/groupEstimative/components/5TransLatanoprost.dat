/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-trans latanoprost  (C26H40O5, CAS 130209-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5TransLatanoprost;
formula     C26H40O5;
CAS         130209-82-4;
InChIKey    GGXICVAJURFBLW-UHFFFAOYSA-N;
MW          432.601;      // g/mol [origin=calculated method=formula-sum]
Tc          1455.67;      // K   [origin=predictive method=joback]
Pc          11.468;      // bar [origin=predictive method=joback]
omega       0.8261;      // -   [origin=predictive method=lee-kesler]
Tb          1160.47;      // K   [origin=predictive method=joback]
HvapTb      131702.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.582 2.52614 -0.0014698 2.973e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 6; } { group CH=CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 3; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 2; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl 7-[3,5-bis(oxidanyl)-2-(3-oxidanyl-5-phenyl-pentyl)cyclopentyl]hept-5-enoate" "15(s)-latanoprost" "propan-2-yl 7-[3,5-dihydroxy-2-(3-hydroxy-5-phenylpentyl)cyclopentyl]hept-5-enoate" "agn-pc-04d9f1" "propan-2-yl (e)-7-[(1r,2s,3r,5s)-3,5-dihydroxy-2-[(3r)-3-hydroxy-5-phenylpentyl]cyclopentyl]hept-5-enoate" );
standardThermochemistry
{
    dHf_298   -1011290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1063.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-351620.0
}
