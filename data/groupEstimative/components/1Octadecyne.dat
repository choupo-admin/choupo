/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octadecyne  (C18H34, CAS 629-89-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octadecyne;
formula     C18H34;
CAS         629-89-0;
InChIKey    IYDNQWWOZQLMRH-UHFFFAOYSA-N;
MW          250.47;      // g/mol [origin=calculated method=formula-sum]
Tc          766.97;      // K   [origin=predictive method=joback]
Pc          12.773;      // bar [origin=predictive method=joback]
omega       0.7570;      // -   [origin=predictive method=lee-kesler]
Tb          601.56;      // K   [origin=predictive method=joback]
HvapTb      55520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.305 1.61992 -0.00095133 2.2139e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadec-1-yne" "octadecyne" "octadec-1-in" "cetylacetylene" "hexadecylacetylene" "cetylacetylene;1-octadecyne;timtec-bb sbb009112;n-hexadecylacetylene;octadec-1-yne;octadecyne;1-octadecyne 90%;1-octadecyne tech 85%" );
standardThermochemistry
{
    dHf_298   -122950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     826.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=323750.0
}
