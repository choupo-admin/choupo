/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-2-methylpropanal  (C4H7BrO, CAS 13206-46-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo2Methylpropanal;
formula     C4H7BrO;
CAS         13206-46-7;
InChIKey    KLTWFFAVGWWIKL-UHFFFAOYSA-N;
MW          151.003;      // g/mol [origin=calculated method=formula-sum]
Tc          610.47;      // K   [origin=predictive method=joback]
Pc          48.225;      // bar [origin=predictive method=joback]
omega       0.3802;      // -   [origin=predictive method=lee-kesler]
Tb          402.71;      // K   [origin=predictive method=joback]
HvapTb      36357.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.63 0.52234 -0.00043 1.403e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CHO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group Br; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-2-methyl-propanal" "propanal,2-bromo-2-methyl-" "propanal, 2-bromo-2-methyl-" "propionaldehyde,2-bromo-2-methyl- (6ci,7ci,8ci); 2-bromo-2-methylpropanal;2-bromo-2-methylpropionaldehyde; 2-bromoisobutyraldehyde; a-bromoisobutyraldehyde" );
gibbsFormation
{
    dHf_298   -193890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99560.0
    phase     gas;
}
