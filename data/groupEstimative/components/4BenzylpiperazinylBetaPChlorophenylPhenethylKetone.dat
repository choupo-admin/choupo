/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-benzylpiperazinyl beta-(p-chlorophenyl)phenethyl ketone  (C26H27ClN2O, CAS 25174-65-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BenzylpiperazinylBetaPChlorophenylPhenethylKetone;
formula     C26H27ClN2O;
CAS         25174-65-6;
InChIKey    ORMJQSPHTHSBLF-UHFFFAOYSA-N;
MW          418.965;      // g/mol [origin=calculated method=formula-sum]
Tc          1265.47;      // K   [origin=predictive method=joback]
Pc          15.772;      // bar [origin=predictive method=joback]
omega       1.1019;      // -   [origin=predictive method=lee-kesler]
Tb          1010.92;      // K   [origin=predictive method=joback]
HvapTb      96183.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-172.278 2.5779 -0.00187646 5.2166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 14; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group Cl; count 1; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-chlorophenyl)-3-phenyl-1-[4-(phenylmethyl)piperazin-1-yl]propan-1-one" "1-benzyl-4-(3-(p-chlorophenyl)-3-phenylpropionyl)piperazine" "piperazine, 1-benzyl-4-(p-chloro-beta-phenylhydrocinnamoyl)-" "ketone, 4-benzylpiperazinyl beta-(p-chlorophenyl)phenethyl" "piperazine, 1-benzyl-4-(3-(p-chlorophenyl)-3-phenylpropionyl)-" "1-(4-benzylpiperazin-1-yl)-3-(4-chlorophenyl)-3-phenylpropan-1-one" );
standardThermochemistry
{
    dHf_298   206590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     898.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=630270.0
}
