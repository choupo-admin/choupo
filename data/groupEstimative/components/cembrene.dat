/*--------------------------------*- Choupo -*-----------------------*\
  Component: cembrene  (C20H32, CAS 1898-13-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cembrene;
formula     C20H32;
CAS         1898-13-1;
InChIKey    DMHADBQKVWXPPM-HPKGDXISSA-N;
MW          272.476;      // g/mol [origin=calculated method=formula-sum]
Tc          956.92;      // K   [origin=predictive method=joback]
Pc          14.501;      // bar [origin=predictive method=joback]
omega       0.5425;      // -   [origin=predictive method=lee-kesler]
Tb          722.05;      // K   [origin=predictive method=joback]
HvapTb      64685.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.53 1.5526 -0.0005252 -6.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 2; } { group CH=CH; count 1; } { group CH=C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1e,3z,6e,10e)-3,7,11-trimethyl-14-propan-2-yl-cyclotetradeca-1,3,6,10-tetraene" "cembrene c" "(+)-cembrene" "thunbergen" "(+)-thunbergen" );
standardThermochemistry
{
    dHf_298   -259660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     886.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133680.0
}
