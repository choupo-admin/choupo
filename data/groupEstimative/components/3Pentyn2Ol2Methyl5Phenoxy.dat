/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pentyn-2-ol, 2-methyl-5-phenoxy-  (C12H14O2, CAS 16488-98-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Pentyn2Ol2Methyl5Phenoxy;
formula     C12H14O2;
CAS         16488-98-5;
InChIKey    YQBNDHADCCFJJQ-UHFFFAOYSA-N;
MW          190.242;      // g/mol [origin=calculated method=formula-sum]
Tc          840.33;      // K   [origin=predictive method=joback]
Pc          31.385;      // bar [origin=predictive method=joback]
omega       0.8373;      // -   [origin=predictive method=lee-kesler]
Tb          621.21;      // K   [origin=predictive method=joback]
HvapTb      64527.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.049 1.01174 -0.00065926 1.6298e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH2O; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-5-phenoxy-pent-3-yn-2-ol" "2-methyl-5-phenoxypent-3-yn-2-ol" "3-pentyn-2-ol, 2-methyl-5-phenoxy-," );
standardThermochemistry
{
    dHf_298   -75380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=126390.0
}
