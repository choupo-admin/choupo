/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-chlorophenyl)ethylamine  (C8H10ClN, CAS 13078-80-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22ChlorophenylEthylamine;
formula     C8H10ClN;
CAS         13078-80-3;
InChIKey    RZBOMSOHMOVUES-UHFFFAOYSA-N;
MW          155.625;      // g/mol [origin=calculated method=formula-sum]
Tc          753.95;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       0.5234;      // -   [origin=predictive method=lee-kesler]
Tb          524.26;      // K   [origin=predictive method=joback]
HvapTb      51366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.608 0.6941 -0.00043936 1.046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group CH2NH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-chlorophenyl)ethanamine" "o-chlorophenethylamine" "2-chlorophenethylamine" "benzeneethanamine, 2-chloro-" "2-(2-chloro-phenyl)-ethylamine" "2'-chlorophenethylamine" "2-(2-chlorophenyl)ethan-1-amine" "1-amino-2-(2-chlorophenyl)ethane" "o-chloro-" "a-phenylethylamine" "ocpam" "2-chloro-2-phenethylamine" "2-(o-chlorophenyl)ethylamine" );
standardThermochemistry
{
    dHf_298   34660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173780.0
}
