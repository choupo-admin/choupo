/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethenoxypropan-1-amine  (C5H11NO, CAS 66415-55-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethenoxypropan1Amine;
formula     C5H11NO;
CAS         66415-55-2;
InChIKey    JPVNTYZOJCDQBK-UHFFFAOYSA-N;
MW          101.149;      // g/mol [origin=calculated method=formula-sum]
Tc          590.57;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.4775;      // -   [origin=predictive method=lee-kesler]
Tb          405.63;      // K   [origin=predictive method=joback]
HvapTb      39105.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.343 0.4575 -0.0002035 2.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH2O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(vinyloxy)propan-1-amine" "3-(ethenyloxy)propan-1-amine" "3-amino-1-propanol vinyl ether" "1-propanamine, 3-(ethenyloxy)-" );
standardThermochemistry
{
    dHf_298   -119530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40510.0
}
