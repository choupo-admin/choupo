/*--------------------------------*- Choupo -*-----------------------*\
  Component: triallyl trimesate  (C18H18O6, CAS 17832-16-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triallylTrimesate;
formula     C18H18O6;
CAS         17832-16-5;
InChIKey    VOSUIKFOFHZNED-UHFFFAOYSA-N;
MW          330.336;      // g/mol [origin=calculated method=formula-sum]
Tc          1020.04;      // K   [origin=predictive method=joback]
Pc          15.949;      // bar [origin=predictive method=joback]
omega       1.0821;      // -   [origin=predictive method=lee-kesler]
Tb          812.78;      // K   [origin=predictive method=joback]
HvapTb      79473.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.473 1.2915 -0.00063742 5.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 3; } { group ACH; count 3; } { group AC; count 3; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 3; } { group dCH; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(prop-2-enyl) benzene-1,3,5-tricarboxylate" "triallyl 1,3,5-benzenetricarboxylate" "triallyl benzene-1,3,5-tricarboxylate" "1,3,5-benzenetricarboxylic acid, tri-2-propenyl ester" "1,3,5-benzenetricarboxylic acid, 1,3,5-tri-2-propen-1-yl ester" "trimesic acid triallyl ester" "1,3,5-benzenetricarboxylic acid triallyl ester" );
gibbsFormation
{
    dHf_298   -776810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     878.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-473760.0
    phase     gas;
}
