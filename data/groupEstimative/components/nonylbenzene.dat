/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonylbenzene  (C15H24, CAS 1081-77-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonylbenzene;
formula     C15H24;
CAS         1081-77-2;
InChIKey    LIXVMPBOGDCSRM-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          761.12;      // K   [origin=predictive method=joback]
Pc          18.467;      // bar [origin=predictive method=joback]
omega       0.6272;      // -   [origin=predictive method=lee-kesler]
Tb          569.48;      // K   [origin=predictive method=joback]
HvapTb      51260.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.652 1.34992 -0.0008234 1.928e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylnonane" "benzene, nonyl-" "nonane, 1-phenyl-" "benzene, c6-12-alkyl derivs." "nonyl-benzene" "phenyl-nonane" "n-nonylbenzene" "n-nonyl benzene" "nonylbenzene (dodecylbenzene (123-01-3))" );
standardThermochemistry
{
    dHf_298   -116400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=187830.0
}
