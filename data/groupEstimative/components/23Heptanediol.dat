/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-heptanediol  (C7H16O2, CAS 21508-07-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Heptanediol;
formula     C7H16O2;
CAS         21508-07-6;
InChIKey    VUVZASHBYYMLRC-UHFFFAOYSA-N;
MW          132.203;      // g/mol [origin=calculated method=formula-sum]
Tc          705.61;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       1.2731;      // -   [origin=predictive method=lee-kesler]
Tb          543.24;      // K   [origin=predictive method=joback]
HvapTb      63758.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.743 0.74864 -0.0004242 9.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptane-2,3-diol" );
gibbsFormation
{
    dHf_298   -502830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-270460.0
    phase     gas;
}
