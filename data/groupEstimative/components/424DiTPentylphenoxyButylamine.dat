/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2,4-di-t-pentylphenoxy)butylamine  (C20H35NO, CAS 51959-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        424DiTPentylphenoxyButylamine;
formula     C20H35NO;
CAS         51959-14-9;
InChIKey    OZYOAOYHMMDTNZ-UHFFFAOYSA-N;
MW          305.506;      // g/mol [origin=calculated method=formula-sum]
Tc          989.79;      // K   [origin=predictive method=joback]
Pc          13.137;      // bar [origin=predictive method=joback]
omega       0.8486;      // -   [origin=predictive method=lee-kesler]
Tb          782.33;      // K   [origin=predictive method=joback]
HvapTb      74173.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.554 1.95632 -0.00123732 3.025e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 4; } { group C; count 2; } { group ACH; count 3; } { group AC; count 3; } { group CH2O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2,4-bis(2-methylbutan-2-yl)phenoxy]butan-1-amine" "4-(2,4-di-tert-pentylphenoxy)butan-1-amine" "4-(2,4-di-tert-amylphenoxy)-butylamine" "4-(2,4-di-tert-pentylphenoxy)butylamine" "4-(2,4-bis(1,1-dimethylpropyl)phenoxy)-1-butanamine" "1-butanamine, 4-(2,4-bis(1,1-dimethylpropyl)phenoxy)-" "1-butanamine, 4-[2,4-bis(1,1-dimethylpropyl)phenoxy]-" "4-[2,4-bis(1,1-dimethylpropyl)phenoxy]butylamine" "1-(4-aminobutoxy)-2,4-bis(2-methylbutan-2-yl)benzene" "1-butanamine,4-[2,4-bis(1,1-dimethylpropyl)phenoxy]-" "4-[2,4-bis(2-methylbutan-2-yl)phenoxy]-1-butanamine" "4-(2,4-di-tert-amylphenoxy)butylamine;4-(2,4-di-tert-pentylphenoxy)butylamine;d-(2,4-di-tert-amylphenoxy)butylamine;" );
standardThermochemistry
{
    dHf_298   -358470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=177800.0
}
