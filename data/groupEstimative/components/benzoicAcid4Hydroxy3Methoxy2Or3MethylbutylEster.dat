/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 4-hydroxy-3-methoxy-, 2(or 3)-methylbutyl ester  (C13H18O4, CAS 73309-44-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid4Hydroxy3Methoxy2Or3MethylbutylEster;
formula     C13H18O4;
CAS         73309-44-1;
InChIKey    MGUNLPSBYNKZKS-SECBINFHSA-N;
MW          238.283;      // g/mol [origin=calculated method=formula-sum]
Tc          902.41;      // K   [origin=predictive method=joback]
Pc          24.875;      // bar [origin=predictive method=joback]
omega       0.9758;      // -   [origin=predictive method=lee-kesler]
Tb          689.52;      // K   [origin=predictive method=joback]
HvapTb      69913.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.772 1.14296 -0.00070152 1.648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2r)-2-methylbutyl] 3-methoxy-4-oxidanyl-benzoate" "[(2r)-2-methylbutyl] 4-hydroxy-3-methoxybenzoate" );
standardThermochemistry
{
    dHf_298   -718680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     629.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-411070.0
}
