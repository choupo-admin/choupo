/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanoic acid, 4-methyl-5-oxo-  (C7H12O3, CAS 6818-07-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanoicAcid4Methyl5Oxo;
formula     C7H12O3;
CAS         6818-07-1;
InChIKey    IEHMHYAHHVRZIF-UHFFFAOYSA-N;
MW          144.17;      // g/mol [origin=calculated method=formula-sum]
Tc          758.36;      // K   [origin=predictive method=joback]
Pc          33.412;      // bar [origin=predictive method=joback]
omega       0.8452;      // -   [origin=predictive method=lee-kesler]
Tb          558.70;      // K   [origin=predictive method=joback]
HvapTb      54698.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.802 0.69754 -0.0004141 9.056e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH3CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-5-oxidanylidene-hexanoic acid" );
standardThermochemistry
{
    dHf_298   -655940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-467210.0
}
