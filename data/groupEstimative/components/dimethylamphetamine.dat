/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylamphetamine  (C11H17N, CAS 4075-96-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylamphetamine;
formula     C11H17N;
CAS         4075-96-1;
InChIKey    OBDSVYOSYSKVMX-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          693.88;      // K   [origin=predictive method=joback]
Pc          26.653;      // bar [origin=predictive method=joback]
omega       0.4645;      // -   [origin=predictive method=lee-kesler]
Tb          489.96;      // K   [origin=predictive method=joback]
HvapTb      44011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.389 1.09976 -0.0007216 1.821e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-1-phenyl-propan-2-amine" "n,n-dimethyl-1-phenylpropan-2-amine" "1-phenyl-2-dimethylaminopropane" "2-dimethylamino-1-phenylpropane" "n,n,alpha-trimethylphenethylamine" "n,n,alpha-trimethylbenzeneethanamine" "alpha-phenyl-beta-dimethyl amino propane" "phenethylamine, n,n,.alpha.-trimethyl-" "1-phenyl-2-dimethylamino-propan [german]" "benzeneethanamine, n,n,.alpha.-trimethyl-" "phenethylamine, n,n,alpha-trimethyl-" "(2s)-n,n-dimethyl-1-phenylpropan-2-amine" );
standardThermochemistry
{
    dHf_298   28410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=262490.0
}
