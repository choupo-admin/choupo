/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-di-tert-butylbenzaldehyde  (C15H22O, CAS 17610-00-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H22O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        35DiTertButylbenzaldehyde;
formula     C15H22O;
CAS         17610-00-3;
InChIKey    BRUITYMDHWNCIG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          218.34;      // g/mol [origin=calculated method=formula-sum]
Tc          766.98;      // K   [origin=predictive method=joback]
Pc          19.321;      // bar [origin=predictive method=joback]
omega       0.3901;      // -   [origin=predictive method=lee-kesler]
Tb          549.40;      // K   [origin=predictive method=joback]
HvapTb      47619.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.5 1.49072 -0.00118592 3.835e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 3; } { group AC; count 3; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-ditert-butylbenzaldehyde" "3,5-bis(tert-butyl)benzaldehyde" "3,5-di-tert-butyl-benzaldehyde" "3,5-bis(tert-butyl)-1-formylbenzene" "3,5-di-t-butylbenzaldehyde" "upcmld0enat5605088:001" "benzaldehyde,3,5-di-tert-butyl- (6ci,7ci,8ci);3,5-bis(1,1-dimethylethyl)benzaldehyde;3,5-di-tert-butylbenzaldehyde;" );
standardThermochemistry
{
    dHf_298   -80390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=218210.0
}
