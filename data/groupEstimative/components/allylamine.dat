/*--------------------------------*- Choupo -*-----------------------*\
  Component: allylamine  (C3H7N, CAS 107-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylamine;
formula     C3H7N;
CAS         107-11-9;
InChIKey    VVJKKWFAADXIJK-UHFFFAOYSA-N;
MW          57.096;      // g/mol [origin=calculated method=formula-sum]
Tc          523.59;      // K   [origin=predictive method=joback]
Pc          50.514;      // bar [origin=predictive method=joback]
omega       0.3042;      // -   [origin=predictive method=lee-kesler]
Tb          337.45;      // K   [origin=predictive method=joback]
HvapTb      32243.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.661 0.3307 -0.0002057 5.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-en-1-amine" "2-propen-1-amine" "monoallylamine" "3-amino-1-propene" "3-aminopropylene" "3-aminopropene" "2-propenamine" "2-propenylamine" "allyl amine" "2-propen-1-ylamine" "poly(allylamine) solution" "prop-2-en-1-amine hydrochloride" );
standardThermochemistry
{
    dHf_298   53970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     319.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128670.0
}
