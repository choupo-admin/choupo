/*--------------------------------*- Choupo -*-----------------------*\
  Component: isophthalamide  (C8H8N2O2, CAS 1740-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isophthalamide;
formula     C8H8N2O2;
CAS         1740-57-4;
InChIKey    QZUPTXGVPYNUIT-UHFFFAOYSA-N;
MW          164.164;      // g/mol [origin=calculated method=formula-sum]
Tc          915.22;      // K   [origin=predictive method=joback]
Pc          48.902;      // bar [origin=predictive method=joback]
omega       0.9628;      // -   [origin=predictive method=lee-kesler]
Tb          667.10;      // K   [origin=predictive method=joback]
HvapTb      71114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.71 0.6932 -0.00042496 8.852e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CONH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxamide" "1,3-benzenedicarboxamide" "isophthaldiamide" "m-phthalamide" "m-carbamoylbenzamide" "isophthalic acid diamide" "zvr cvz" "1,3-benzene dicarboxamide" "qzuptxgvpynuit-uhfffaoysa-" "isophthalamide(6ci,7ci,8ci);isophthalic acid diamide;m-carbamoylbenzamide;m-phthalamide;" );
gibbsFormation
{
    dHf_298   -140970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5680.0
    phase     gas;
}
