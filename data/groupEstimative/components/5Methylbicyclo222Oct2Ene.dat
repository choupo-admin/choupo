/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methylbicyclo[2.2.2]oct-2-ene  (C9H14, CAS 14803-42-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methylbicyclo222Oct2Ene;
formula     C9H14;
CAS         14803-42-0;
InChIKey    XOGBWGJGWDPLQZ-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          631.52;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.2869;      // -   [origin=predictive method=lee-kesler]
Tb          422.03;      // K   [origin=predictive method=joback]
HvapTb      35781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.3 1.05892 -0.00074528 2.107e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 3; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo(2.2.2)oct-2-ene, 5-methyl-,  (1alpha,4alpha,5beta)-" "(1s,4r,5s)-5-methylbicyclo[2.2.2]oct-2-ene" "bicyclo(2.2.2)oct-2-ene, 5-methyl-,  (1alpha,4alpha,5alpha)-" "bicyclo[2.2.2]oct-2-ene, 5-methyl-, (1.alpha.,4.alpha.,5.alpha.)-" "bicyclo[2.2.2]oct-2-ene, 5-methyl-, (1.alpha.,4.alpha.,5.beta.)-" );
standardThermochemistry
{
    dHf_298   -58370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     286.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=144450.0
}
