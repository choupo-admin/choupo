/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-amino-3-bromobenzoate  (C8H8BrNO2, CAS 106896-49-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4Amino3Bromobenzoate;
formula     C8H8BrNO2;
CAS         106896-49-5;
InChIKey    AIUWAOALZYWQBX-UHFFFAOYSA-N;
MW          230.061;      // g/mol [origin=calculated method=formula-sum]
Tc          858.86;      // K   [origin=predictive method=joback]
Pc          41.409;      // bar [origin=predictive method=joback]
omega       0.7646;      // -   [origin=predictive method=lee-kesler]
Tb          616.19;      // K   [origin=predictive method=joback]
HvapTb      61485.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.4 0.61122 -0.00032872 4.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACNH2; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-azanyl-3-bromanyl-benzoate" "4-amino-3-bromo-benzoic acid methyl ester" "methyl4-amino-3-bromobenzoate" "4-amino-3-bromobenzoic acid methyl ester" "benzoic acid,4-amino-3-bromo-, methyl ester" "benzoic acid, 4-amino-3-bromo-, methyl ester" "2-bromo-4-methoxycarbonylaniline;4-amino-3-bromobenzoic acid methyl ester;" );
gibbsFormation
{
    dHf_298   -252020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-119970.0
    phase     gas;
}
