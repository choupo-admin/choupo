/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylthiomorpholine-1,1-dioxide  (C5H11NO2S, CAS 25343-91-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H11NO2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Methylthiomorpholine11Dioxide;
formula     C5H11NO2S;
CAS         25343-91-3;
InChIKey    ULZCOWMSBOJCLT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          149.208;      // g/mol [origin=calculated method=formula-sum]
Tc          479.14;      // K   [origin=predictive method=joback]
Pc          50.586;      // bar [origin=predictive method=joback]
omega       0.4669;      // -   [origin=predictive method=lee-kesler]
Tb          321.12;      // K   [origin=predictive method=joback]
HvapTb      40979.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.01 0.80972 -0.0005646 1.477e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3N; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dO_oth; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-1,4-thiazinane 1,1-dioxide" "4-methylthiomorpholine 1,1-dioxide" "n-methyltetrahydro-1,4-thiazine-s-oxide" "thiomorpholine, 4-methyl-, 1,1-dioxide" "thiomorpholine,4-methyl-, 1,1-dioxide" "4-methyl-1,4-thiazaperhydroine-1,1-dione" "4-methyl-1lambda~6~,4-thiazinane-1,1-dione" "4-methyl-1$l^{6},4-thiomorpholine-1,1-dione" );
gibbsFormation
{
    dHf_298   -487240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-343300.0
    phase     gas;
}
