/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-diazabicyclo[6.5.3]hexadecane  (C14H28N2, CAS 84905-04-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Diazabicyclo653Hexadecane;
formula     C14H28N2;
CAS         84905-04-4;
InChIKey    ICKDKENKQFLDMK-UHFFFAOYSA-N;
MW          224.392;      // g/mol [origin=calculated method=formula-sum]
Tc          834.06;      // K   [origin=predictive method=joback]
Pc          24.029;      // bar [origin=predictive method=joback]
omega       0.5355;      // -   [origin=predictive method=lee-kesler]
Tb          601.78;      // K   [origin=predictive method=joback]
HvapTb      52664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-184.55 1.8596 -0.001143 2.46e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 14; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,8-diazabicyclo(6.5.3)hexadecane" );
standardThermochemistry
{
    dHf_298   -60230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     797.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=328680.0
}
