/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-iodobenzyl alcohol  (C7H7IO, CAS 5159-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2IodobenzylAlcohol;
formula     C7H7IO;
CAS         5159-41-1;
InChIKey    WZCXOBMFBKSSFA-UHFFFAOYSA-N;
MW          234.032;      // g/mol [origin=calculated method=formula-sum]
Tc          808.24;      // K   [origin=predictive method=joback]
Pc          44.208;      // bar [origin=predictive method=joback]
omega       0.7594;      // -   [origin=predictive method=lee-kesler]
Tb          576.74;      // K   [origin=predictive method=joback]
HvapTb      60166.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.099 0.6034 -0.00043296 1.224e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-iodanylphenyl)methanol" "(2-iodophenyl)methanol" "o-iodobenzyl alcohol" "2-iodobenzylalcohol" "benzenemethanol, 2-iodo-" "2-jod-benzylalkohol" "2-iodobenzylic alcohol" "benzyl alcohol, o-iodo-" "(2-iodo-phenyl)-methanol" "(2-iodophenyl)methan-1-ol" "benzylalcohol, o-iodo- (6ci,7ci,8ci);1-hydroxymethyl-2-iodobenzene;2-(hydroxymethyl)-1-iodobenzene;2-(hydroxymethyl)iodobenzene;2-iodobenzenemethanol;2-iodophenylmethanol;o-iodobenzyl alcohol;" );
gibbsFormation
{
    dHf_298   -38110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32140.0
    phase     gas;
}
