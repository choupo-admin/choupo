/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-3-(1,1,3,3-tetramethylbutyl)pyrocatechol  (C15H24O2, CAS 2213-68-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl31133TetramethylbutylPyrocatechol;
formula     C15H24O2;
CAS         2213-68-5;
InChIKey    KEUANYXDVWBCRM-UHFFFAOYSA-N;
MW          236.355;      // g/mol [origin=calculated method=formula-sum]
Tc          962.99;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.8963;      // -   [origin=predictive method=lee-kesler]
Tb          729.24;      // K   [origin=predictive method=joback]
HvapTb      75358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.139 1.85132 -0.00161268 5.779e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 2; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-3-(2,4,4-trimethylpentan-2-yl)benzene-1,2-diol" "1,2-benzenediol, 5-methyl-3-(1,1,3,3-tetramethylbutyl)-" "1,2-benzenediol,5-methyl-3-(1,1,3,3-tetramethylbutyl)-" );
standardThermochemistry
{
    dHf_298   -499990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125360.0
}
