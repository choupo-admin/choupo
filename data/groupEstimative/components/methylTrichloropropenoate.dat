/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl trichloropropenoate  (C4H3Cl3O2, CAS 17640-12-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylTrichloropropenoate;
formula     C4H3Cl3O2;
CAS         17640-12-9;
InChIKey    LUAABZPMDXDUBN-UHFFFAOYSA-N;
MW          189.416;      // g/mol [origin=calculated method=formula-sum]
Tc          681.34;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.4377;      // -   [origin=predictive method=lee-kesler]
Tb          465.55;      // K   [origin=predictive method=joback]
HvapTb      45178.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.77 0.36922 -0.0002488 5.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group Cl_C=C_; count 3; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dC; count 2; } { group Cl; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,3,3-tris(chloranyl)prop-2-enoate" "methyl 2,3,3-trichloroacrylate" "methyl 2,3,3-trichloroprop-2-enoate" "2,3,3-trichloro-acrylic acid methyl ester" "2-propenoic acid, 2,3,3-trichloro-, methyl ester" );
gibbsFormation
{
    dHf_298   -392750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-300240.0
    phase     gas;
}
