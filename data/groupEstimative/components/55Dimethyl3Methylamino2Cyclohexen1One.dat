/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-3-(methylamino)-2-cyclohexen-1-one  (C9H15NO, CAS 701-58-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl3Methylamino2Cyclohexen1One;
formula     C9H15NO;
CAS         701-58-6;
InChIKey    KRTIOMAPNBTFRN-UHFFFAOYSA-N;
MW          153.225;      // g/mol [origin=calculated method=formula-sum]
Tc          777.42;      // K   [origin=predictive method=joback]
Pc          32.173;      // bar [origin=predictive method=joback]
omega       0.5339;      // -   [origin=predictive method=lee-kesler]
Tb          547.44;      // K   [origin=predictive method=joback]
HvapTb      46543.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.59 1.06526 -0.00080424 2.803e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethyl-3-(methylamino)cyclohex-2-en-1-one" "5,5-dimethyl-3-(methylamino)cyclohex-2-enone" "2-cyclohexenone,3-(n-methylamino),5,5-dimethyl" "2-cyclohexenone, 3-(n-methylamino)-5,5-dimethyl" );
standardThermochemistry
{
    dHf_298   -197450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=30990.0
}
