/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-(ethylamino)coumarin  (C11H11NO2, CAS 71173-56-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7EthylaminoCoumarin;
formula     C11H11NO2;
CAS         71173-56-3;
InChIKey    LQDAIRJFZNQMNK-UHFFFAOYSA-N;
MW          189.214;      // g/mol [origin=calculated method=formula-sum]
Tc          821.15;      // K   [origin=predictive method=joback]
Pc          31.526;      // bar [origin=predictive method=joback]
omega       0.7853;      // -   [origin=predictive method=lee-kesler]
Tb          602.61;      // K   [origin=predictive method=joback]
HvapTb      57865.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.499 1.00332 -0.000735 2.104e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH2NH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(ethylamino)chromen-2-one" "7-(ethylamino)-2-benzopyrone" "2h-1-benzopyran-2-one,7-(ethylamino)-" );
gibbsFormation
{
    dHf_298   -163510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24430.0
    phase     gas;
}
