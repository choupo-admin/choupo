/*--------------------------------*- Choupo -*-----------------------*\
  Component: fumaric acid  (C4H4O4, CAS 110-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fumaricAcid;
formula     C4H4O4;
CAS         110-17-8;
InChIKey    VZCYOOQTPOCHFL-OWOJBTEDSA-N;
MW          116.072;      // g/mol [origin=calculated method=formula-sum]
Tc          805.68;      // K   [origin=predictive method=joback]
Pc          53.124;      // bar [origin=predictive method=joback]
omega       0.9923;      // -   [origin=predictive method=lee-kesler]
Tb          586.30;      // K   [origin=predictive method=joback]
HvapTb      58784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.73 0.5054 -0.0004228 1.398e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-but-2-enedioic acid" "trans-butenedioic acid" "2-butenedioic acid" "allomaleic acid" "lichenic acid" "boletic acid" "fumarate" "tumaric acid" "2-butenedioic acid (e)-" "trans-1,2-ethylenedicarboxylic acid" "(2e)-but-2-enedioic acid" "allomalenic acid" );
standardThermochemistry
{
    dHf_298   -709210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-624800.0
}
