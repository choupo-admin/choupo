/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl cyclohexyl phthalate  (C18H24O4, CAS 84-64-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylCyclohexylPhthalate;
formula     C18H24O4;
CAS         84-64-0;
InChIKey    BHKLONWXRPJNAE-UHFFFAOYSA-N;
MW          304.386;      // g/mol [origin=calculated method=formula-sum]
Tc          998.86;      // K   [origin=predictive method=joback]
Pc          17.146;      // bar [origin=predictive method=joback]
omega       0.9172;      // -   [origin=predictive method=lee-kesler]
Tb          779.09;      // K   [origin=predictive method=joback]
HvapTb      73843.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.867 1.58792 -0.00081136 9.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-butyl o2-cyclohexyl benzene-1,2-dicarboxylate" "phthalic acid, butyl cyclohexyl ester" "cyclohexyl butyl phthalate" "1,2-benzenedicarboxylic acid, butyl cyclohexyl ester" "butyl cyclohexyl benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid, 1-butyl 2-cyclohexyl ester" "1, butyl cyclohexyl ester" "phthalic acid, butyl cyclohexyl ester (8ci)" "1-o-butyl 2-o-cyclohexyl benzene-1,2-dicarboxylate" );
standardThermochemistry
{
    dHf_298   -770030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     816.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-392830.0
}
