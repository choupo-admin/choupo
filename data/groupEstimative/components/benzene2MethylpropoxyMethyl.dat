/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene,((2-methylpropoxy)methyl)-  (C11H16O, CAS 940-49-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene2MethylpropoxyMethyl;
formula     C11H16O;
CAS         940-49-8;
InChIKey    ADHMUPZYLITZIH-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          704.91;      // K   [origin=predictive method=joback]
Pc          26.245;      // bar [origin=predictive method=joback]
omega       0.4808;      // -   [origin=predictive method=lee-kesler]
Tb          499.94;      // K   [origin=predictive method=joback]
HvapTb      44378.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.198 0.91264 -0.000498 8.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropoxymethylbenzene" "alpha-isobutoxytoluene" "benzene, ((2-methylpropoxy)methyl)-" );
standardThermochemistry
{
    dHf_298   -171340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46710.0
}
