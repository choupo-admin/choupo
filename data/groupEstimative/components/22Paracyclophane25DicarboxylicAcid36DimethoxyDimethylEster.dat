/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2.2)-paracyclophane-2,5-dicarboxylic acid, 3',6'-dimethoxy-, dimethyl ester  (C22H24O6, CAS 66212-59-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Paracyclophane25DicarboxylicAcid36DimethoxyDimethylEster;
formula     C22H24O6;
CAS         66212-59-7;
InChIKey    XDNCMAOZIUCNTK-UHFFFAOYSA-N;
MW          384.428;      // g/mol [origin=calculated method=formula-sum]
Tc          1196.62;      // K   [origin=predictive method=joback]
Pc          14.861;      // bar [origin=predictive method=joback]
omega       1.1410;      // -   [origin=predictive method=lee-kesler]
Tb          963.16;      // K   [origin=predictive method=joback]
HvapTb      93118.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.39 1.51088 -0.00065116 2.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 4; } { group ACCH2; count 4; } { group CH3O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2.2]-paracyclophane-2,5-dicarboxylic acid, 3',6'-dimethoxy-, dimethyl ester" "dimethyl 11,13-dimethoxytricyclo[8.2.2.24,7]hexadeca-1(12),4,6,10,13,15-hexaene-5,15-dicarboxylate" );
standardThermochemistry
{
    dHf_298   -905190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     860.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-472980.0
}
