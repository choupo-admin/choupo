/*--------------------------------*- Choupo -*-----------------------*\
  Component: tripelennamine citrate  (C22H29N3O7, CAS 6138-56-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tripelennamineCitrate;
formula     C22H29N3O7;
CAS         6138-56-3;
InChIKey    GGRBYIUPUOYRLQ-UHFFFAOYSA-N;
MW          447.488;      // g/mol [origin=calculated method=formula-sum]
Tc          1689.14;      // K   [origin=predictive method=joback]
Pc          17.639;      // bar [origin=predictive method=joback]
omega       1.3049;      // -   [origin=predictive method=lee-kesler]
Tb          1361.78;      // K   [origin=predictive method=joback]
HvapTb      146583.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.805 2.3236 -0.00147506 3.267e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } { group C5H4N; count 1; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group C; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 2; } { group OH; count 1; } { group COOH; count 3; } { group N; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-n'-(phenylmethyl)-n'-pyridin-2-yl-ethane-1,2-diamine;2-oxidanylpropane-1,2,3-tricarboxylic acid" "pyribenzamine citrate" "1,2-ethanediamine, n,n-dimethyl-n'-(phenylmethyl)-n'-2-pyridinyl-, 2-hydroxy-1,2,3-propanetricarboxylate (1:1)" "pyridine, 2-(benzyl(2-(dimethylamino)ethyl)amino)-, citrate (1:1)" "pbz (tn)" "tripelennamine citrate [usan]" "c16h21n3.c6h8o7" "1,2-ethanediamine, n1,n1-dimethyl-n2-(phenylmethyl)-n2-2-pyridinyl-, 2-hydroxy-1,2,3-propanetricarboxylate (1:1)" "2-(benzyl(2-(dimethylamino)ethyl)amino)pyridine citrate (1:1)" "n'-benzyl-n,n-dimethyl-n'-pyridin-2-ylethane-1,2-diamine; 2-hydroxypropane-1,2,3-tricarboxylic acid" );
gibbsFormation
{
    dHf_298   -1179910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1124.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-612680.0
    phase     gas;
}
