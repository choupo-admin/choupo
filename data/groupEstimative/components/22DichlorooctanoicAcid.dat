/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dichlorooctanoic acid  (C8H14Cl2O2, CAS 102272-30-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DichlorooctanoicAcid;
formula     C8H14Cl2O2;
CAS         102272-30-0;
InChIKey    UTUNURLNZXJIEN-UHFFFAOYSA-N;
MW          213.098;      // g/mol [origin=calculated method=formula-sum]
Tc          804.57;      // K   [origin=predictive method=joback]
Pc          26.245;      // bar [origin=predictive method=joback]
omega       0.8017;      // -   [origin=predictive method=lee-kesler]
Tb          599.78;      // K   [origin=predictive method=joback]
HvapTb      58040.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.525 0.95402 -0.0006966 2.019e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group COOH; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group Cl; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)octanoic acid" "octanoic acid,2,2-dichloro-" "2,2-dichlorooctanoicacid" );
standardThermochemistry
{
    dHf_298   -598950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-348450.0
}
