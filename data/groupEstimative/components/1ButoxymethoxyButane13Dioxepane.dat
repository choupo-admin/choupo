/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(butoxymethoxy)butane;1,3-dioxepane  (C14H30O4, CAS 170617-34-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1ButoxymethoxyButane13Dioxepane;
formula     C14H30O4;
CAS         170617-34-2;
InChIKey    OUAHAFRDJQBTFG-UHFFFAOYSA-N;
MW          262.39;      // g/mol [origin=calculated method=formula-sum]
Tc          843.44;      // K   [origin=predictive method=joback]
Pc          16.810;      // bar [origin=predictive method=joback]
omega       0.7770;      // -   [origin=predictive method=lee-kesler]
Tb          648.55;      // K   [origin=predictive method=joback]
HvapTb      61802.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.957 1.13424 -0.0001632 -1.809e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH2O; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH2_ring; count 5; } { group O; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxepane, telomer with 1,1'-(methylenebis(oxy))bis(butane)" );
standardThermochemistry
{
    dHf_298   -903850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     760.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-399940.0
}
