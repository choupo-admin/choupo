/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-benzylquinoline  (C16H13N, CAS 54884-99-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Benzylquinoline;
formula     C16H13N;
CAS         54884-99-0;
InChIKey    GMGJJCVVIGBOAJ-UHFFFAOYSA-N;
MW          219.287;      // g/mol [origin=calculated method=formula-sum]
Tc          964.79;      // K   [origin=predictive method=joback]
Pc          28.874;      // bar [origin=predictive method=joback]
omega       0.6313;      // -   [origin=predictive method=lee-kesler]
Tb          696.70;      // K   [origin=predictive method=joback]
HvapTb      64274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.549 1.33656 -0.00098794 2.882e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH2; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 4; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-(phenylmethyl)quinoline" "quinoline, 6-(phenylmethyl)-" );
gibbsFormation
{
    dHf_298   311880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=482730.0
    phase     gas;
}
