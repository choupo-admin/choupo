/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl propylmalonate  (C10H18O4, CAS 2163-48-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylPropylmalonate;
formula     C10H18O4;
CAS         2163-48-6;
InChIKey    GRRSDGHTSMJICM-UHFFFAOYSA-N;
MW          202.25;      // g/mol [origin=calculated method=formula-sum]
Tc          722.68;      // K   [origin=predictive method=joback]
Pc          21.433;      // bar [origin=predictive method=joback]
omega       0.7644;      // -   [origin=predictive method=lee-kesler]
Tb          544.40;      // K   [origin=predictive method=joback]
HvapTb      52280.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.934 0.85016 -0.0003342 -6.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-propylpropanedioate" "diethyl 2-propylmalonate" "diethylpropylmalonate" "diethyl n-propylmalonate" "1,3-diethyl 2-propylpropanedioate" "malonic acid, propyl-, diethyl ester" "propylmalonic acid diethyl ester" "grrsdghtsmjicm-uhfffaoysa-" "m290" );
standardThermochemistry
{
    dHf_298   -889570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-589860.0
}
