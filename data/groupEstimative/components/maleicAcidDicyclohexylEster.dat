/*--------------------------------*- Choupo -*-----------------------*\
  Component: maleic acid, dicyclohexyl ester  (C16H24O4, CAS 621-13-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        maleicAcidDicyclohexylEster;
formula     C16H24O4;
CAS         621-13-6;
InChIKey    BLKQQTCUGZJWLN-QXMHVHEDSA-N;
MW          280.364;      // g/mol [origin=calculated method=formula-sum]
Tc          953.11;      // K   [origin=predictive method=joback]
Pc          19.203;      // bar [origin=predictive method=joback]
omega       0.7782;      // -   [origin=predictive method=lee-kesler]
Tb          725.38;      // K   [origin=predictive method=joback]
HvapTb      66840.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.23 1.6784 -0.0009032 1.316e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 2; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group CH2_ring; count 10; } { group CH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dicyclohexyl (z)-but-2-enedioate" "dicyclohexyl maleate" "2-butenedioic acid (z)-, dicyclohexyl ester" "2-butenedioic acid (2z)-, dicyclohexyl ester" "2-butenedioic acid (z)-, bis(cyclohexyl) ester" "2-butenedioic acid (2z)-, 1,4-dicyclohexyl ester" "dicyclohexyl (2z)-but-2-enedioate" "dicyclohexyl (2z)but-2-ene-1,4-dioate" "2-butenedioic acid (z)-, dicyclohexyl ester (9ci)" );
gibbsFormation
{
    dHf_298   -782270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     814.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-407780.0
    phase     gas;
}
