/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dichloro-1,3,3,3-tetrafluoropropane  (C3H2Cl2F4, CAS 64712-27-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichloro1333Tetrafluoropropane;
formula     C3H2Cl2F4;
CAS         64712-27-2;
InChIKey    JBSUEXFKGWKQFC-UHFFFAOYSA-N;
MW          184.941;      // g/mol [origin=calculated method=formula-sum]
Tc          499.03;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       0.3092;      // -   [origin=predictive method=lee-kesler]
Tb          333.72;      // K   [origin=predictive method=joback]
HvapTb      25182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.361 0.6012 -0.0005894 2.087e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CF3; count 1; } { group CCl2F; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 2; } { group F; count 4; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)-1,3,3,3-tetrakis(fluoranyl)propane" "propane, 1,1-dichloro-1,3,3,3-tetrafluoro-" "3,3-dichloro-1,1,1,3-tetrafluoropropane" "propane,1,1-dichloro-1,3,3,3-tetrafluoro-" );
standardThermochemistry
{
    dHf_298   -938670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-823040.0
}
