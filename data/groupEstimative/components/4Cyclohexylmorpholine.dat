/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-cyclohexylmorpholine  (C10H19NO, CAS 6425-41-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Cyclohexylmorpholine;
formula     C10H19NO;
CAS         6425-41-8;
InChIKey    BRKHZWFIIVVNTA-UHFFFAOYSA-N;
MW          169.268;      // g/mol [origin=calculated method=formula-sum]
Tc          733.32;      // K   [origin=predictive method=joback]
Pc          31.883;      // bar [origin=predictive method=joback]
omega       0.4379;      // -   [origin=predictive method=lee-kesler]
Tb          507.29;      // K   [origin=predictive method=joback]
HvapTb      45402.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.6 1.355 -0.0008827 2.138e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group CH_ring; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexylmorpholine" "morpholine, 4-cyclohexyl-" "n-cyclohexylmorpholine" "n-(1-cyclohexenyl)morpholine" "n-cyclohexylmorpholine aerosol" "morpholine, 4-cyclohexyl-, (aerosol)" "morpholine, (aerosol)" "4-cyclohexyl-morpholine" "n-cyclohexyl morpholine" );
standardThermochemistry
{
    dHf_298   -179060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=126690.0
}
