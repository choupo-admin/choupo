/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-iodo-4-methylbenzoic acid  (C8H7IO2, CAS 82998-57-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Iodo4MethylbenzoicAcid;
formula     C8H7IO2;
CAS         82998-57-0;
InChIKey    LDDHMKANNXWUAK-UHFFFAOYSA-N;
MW          262.042;      // g/mol [origin=calculated method=formula-sum]
Tc          916.87;      // K   [origin=predictive method=joback]
Pc          38.198;      // bar [origin=predictive method=joback]
omega       0.7270;      // -   [origin=predictive method=lee-kesler]
Tb          657.93;      // K   [origin=predictive method=joback]
HvapTb      63539.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.6 0.65572 -0.00046252 1.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group COOH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group I; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-iodanyl-4-methyl-benzoic acid" "3-iodo-p-toluic acid" "benzoic acid, 3-iodo-4-methyl-" "4-carboxy-2-iodotoluene" "3-iodo-4-methyl-benzoic acid" "benzoicacid, 3-iodo-4-methyl-" );
gibbsFormation
{
    dHf_298   -268260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-176160.0
    phase     gas;
}
