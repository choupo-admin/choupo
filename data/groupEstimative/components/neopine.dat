/*--------------------------------*- Choupo -*-----------------------*\
  Component: neopine  (C18H21NO3, CAS 467-14-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        neopine;
formula     C18H21NO3;
CAS         467-14-1;
InChIKey    NNDKZTBFZTWKLA-QISBLDNZSA-N;
MW          299.37;      // g/mol [origin=calculated method=formula-sum]
Tc          1054.15;      // K   [origin=predictive method=joback]
Pc          24.147;      // bar [origin=predictive method=joback]
omega       1.3228;      // -   [origin=predictive method=lee-kesler]
Tb          834.12;      // K   [origin=predictive method=joback]
HvapTb      84849.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-190.82 2.33774 -0.00218362 8.419e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3O; count 1; } { group CH-O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group OH; count 1; } { group O; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,7s,7ar,12bs)-9-methoxy-3-methyl-2,4,6,7,7a,13-hexahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-7-ol" "neopin" "beta-codeine" "brd-k34252131-001-02-0" "(5alpha,6alpha)-8,14-didehydro-4,5-epoxy-3-methoxy-17-methylmorphinan-6-ol" );
standardThermochemistry
{
    dHf_298   -202740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=236980.0
}
