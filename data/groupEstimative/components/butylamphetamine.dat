/*--------------------------------*- Choupo -*-----------------------*\
  Component: butylamphetamine  (C13H21N, CAS 51799-33-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylamphetamine;
formula     C13H21N;
CAS         51799-33-8;
InChIKey    VIAVBPFRYASSKF-UHFFFAOYSA-N;
MW          191.318;      // g/mol [origin=calculated method=formula-sum]
Tc          775.14;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.6573;      // -   [origin=predictive method=lee-kesler]
Tb          573.45;      // K   [origin=predictive method=joback]
HvapTb      52856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.726 1.24204 -0.0007664 1.79e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(1-phenylpropan-2-yl)butan-1-amine" "n-n-butylamphetamine" "d-n-butylamphetamine" "1-phenyl-2-butylaminopropane" "phenethylamine, n-butyl-alpha-methyl-" "1-phenyl-2-n-butylamino-propan [german]" "1-phenyl-2-n-butylamino-propan" "benzeneethanamine,n-butyl-a-methyl-" "benzeneethanamine, n-butyl-alpha-methyl-" "benzeneethanamine, n-butyl-.alpha.-methyl-" "benzeneethanamine, n-butyl-alpha-methyl- (9ci)" );
gibbsFormation
{
    dHf_298   -26930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=257940.0
    phase     gas;
}
