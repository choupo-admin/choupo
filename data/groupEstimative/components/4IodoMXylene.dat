/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-iodo-m-xylene  (C8H9I, CAS 4214-28-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4IodoMXylene;
formula     C8H9I;
CAS         4214-28-2;
InChIKey    BUNKQJAMHYKQIM-UHFFFAOYSA-N;
MW          232.06;      // g/mol [origin=calculated method=formula-sum]
Tc          762.07;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       0.3382;      // -   [origin=predictive method=lee-kesler]
Tb          512.42;      // K   [origin=predictive method=joback]
HvapTb      46375.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.0 0.60494 -0.00038992 9.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyl-2,4-dimethyl-benzene" "1-iodo-2,4-dimethylbenzene" "m-xylene, 4-iodo-" "1,3-dimethyl-4-iodobenzene" "2,4-dimethyliodobenzene" "benzene, 1-iodo-2,4-dimethyl-" "2,4-dimethyl-1-iodobenzene" "2-iodo-1,5-dimethylbenzene" "agn-pc-00accx" "4-iodo-meta-xylene" "m-xylene, 4-iodo- (8ci)" "1-iodanyl-2,4-dimethylbenzene" );
standardThermochemistry
{
    dHf_298   82010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=167750.0
}
