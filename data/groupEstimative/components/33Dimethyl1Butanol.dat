/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyl-1-butanol  (C6H14O, CAS 624-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyl1Butanol;
formula     C6H14O;
CAS         624-95-3;
InChIKey    DUXCSEISVMREAX-UHFFFAOYSA-N;
MW          102.177;      // g/mol [origin=calculated method=formula-sum]
Tc          596.92;      // K   [origin=predictive method=joback]
Pc          35.305;      // bar [origin=predictive method=joback]
omega       0.6521;      // -   [origin=predictive method=lee-kesler]
Tb          425.83;      // K   [origin=predictive method=joback]
HvapTb      44333.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.748 0.73366 -0.0005048 1.419e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylbutan-1-ol" "3,3-dimethylbutanol" "1-butanol, 3,3-dimethyl-" "tert-hexyl alcohol" "neohexanol" "tert-hexanol" "1-butanol,3-dimethyl-" "1-butanol, 3,3-dimethyl" "33d" );
gibbsFormation
{
    dHf_298   -328150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-134340.0
    phase     gas;
}
