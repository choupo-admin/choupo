/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenethyl acetate  (C10H12O2, CAS 103-45-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenethylAcetate;
formula     C10H12O2;
CAS         103-45-7;
InChIKey    MDHYEMXUFSJLGV-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          723.22;      // K   [origin=predictive method=joback]
Pc          29.473;      // bar [origin=predictive method=joback]
omega       0.5381;      // -   [origin=predictive method=lee-kesler]
Tb          513.30;      // K   [origin=predictive method=joback]
HvapTb      47537.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.698 0.82012 -0.0004568 7.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylethyl ethanoate" "2-phenylethyl acetate" "2-phenethyl acetate" "acetic acid, 2-phenylethyl ester" "benzylcarbinyl acetate" "acetic acid, phenethyl ester" "beta-phenylethyl acetate" "phenethyl alcohol, acetate" "acetic acid phenethyl ester" "beta-phenethyl acetate" "phenethyl acetate (natural)" "ethanol, 2-phenyl-, acetate" );
standardThermochemistry
{
    dHf_298   -330480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-164640.0
}
