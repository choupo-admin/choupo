/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 2-chloroterephthalate  (C10H9ClO4, CAS 18643-84-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl2Chloroterephthalate;
formula     C10H9ClO4;
CAS         18643-84-0;
InChIKey    FUFFCPIFRICMFH-UHFFFAOYSA-N;
MW          228.628;      // g/mol [origin=calculated method=formula-sum]
Tc          838.23;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       0.7578;      // -   [origin=predictive method=lee-kesler]
Tb          618.91;      // K   [origin=predictive method=joback]
HvapTb      60653.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.2 0.65314 -0.00024852 -2.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACCl; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-chloranylbenzene-1,4-dicarboxylate" "dimethyl chloroterephthalate" "1,4-dimethyl 2-chlorobenzene-1,4-dicarboxylate" "1,4-benzenedicarboxylic acid, 2-chloro-, dimethyl ester" "dimethyl 2-chlorobenzene-1,4-dicarboxylate" "1,4-benzenedicarboxylicacid, 2-chloro-, 1,4-dimethyl ester" );
gibbsFormation
{
    dHf_298   -686440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-506200.0
    phase     gas;
}
