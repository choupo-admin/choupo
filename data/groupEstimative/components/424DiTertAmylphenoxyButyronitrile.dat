/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2,4-di-tert-amylphenoxy)butyronitrile  (C20H31NO, CAS 36268-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        424DiTertAmylphenoxyButyronitrile;
formula     C20H31NO;
CAS         36268-65-2;
InChIKey    JEWCXPGDBLFXNE-UHFFFAOYSA-N;
MW          301.474;      // g/mol [origin=calculated method=formula-sum]
Tc          1024.53;      // K   [origin=predictive method=joback]
Pc          12.390;      // bar [origin=predictive method=joback]
omega       0.8285;      // -   [origin=predictive method=lee-kesler]
Tb          811.88;      // K   [origin=predictive method=joback]
HvapTb      74010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.045 1.82922 -0.00116292 2.852e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 3; } { group C; count 2; } { group ACH; count 3; } { group AC; count 3; } { group CH2O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 5; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2,4-bis(2-methylbutan-2-yl)phenoxy]butanenitrile" "4-(2,4-di-tert-pentylphenoxy)butyronitrile" "4-(2,4-di-tert-pentylphenoxy)butanenitrile" "4-[2,4-bis(1,1-dimethylpropyl)phenoxy]butanenitrile" "butanenitrile, 4-(2,4-bis(1,1-dimethylpropyl)phenoxy)-" "butanenitrile, 4-[2,4-bis(1,1-dimethylpropyl)phenoxy]-" "4-(2,4-bis(tert-pentyl)phenoxy)butyronitrile" "butanenitrile,4-[2,4-bis(1,1-dimethylpropyl)phenoxy]-" "4-(2,4-di-tert-pentylphenoxy)butyronitrile;4-[2,4-bis(1,1-dimethylpropyl)phenoxy]-butanenitril;4-[2,4-bis(1,1-dimethylpropyl)phenoxy]-butanenitrile;butanenitrile,4-[2,4-bis(1,1-dimethylpropyl)phenoxy]-;4-(2,4-di-tert-amylphenoxy)butyronitrile;labotest-bb lt00847748;4-[2,4-bis(tert-pentyl)phenoxy]butyronitrile;2,4-di-tert-amylphenoxybutyronitrile" );
standardThermochemistry
{
    dHf_298   -227380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     755.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=244530.0
}
