/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-1-fluoroethane  (C2H4ClF, CAS 110587-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro1Fluoroethane;
formula     C2H4ClF;
CAS         110587-14-9;
InChIKey    YACLCMMBHTUQON-UHFFFAOYSA-N;
MW          82.502;      // g/mol [origin=calculated method=formula-sum]
Tc          445.91;      // K   [origin=predictive method=joback]
Pc          45.408;      // bar [origin=predictive method=joback]
omega       0.2017;      // -   [origin=predictive method=lee-kesler]
Tb          281.62;      // K   [origin=predictive method=joback]
HvapTb      23226.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.37 0.21832 -0.000125 2.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group HCClF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group F; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-1-fluoranyl-ethane" "ethane, chlorofluoro-" "ethane, 1-chloro-1-fluoro-" "1-chlorofluoroethane" "monochloromonofluoroethane" "chlorofluoroethane" );
gibbsFormation
{
    dHf_298   -301740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     289.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-243220.0
    phase     gas;
}
