/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 3-mercaptopropionate  (C7H14O2S, CAS 16215-21-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl3Mercaptopropionate;
formula     C7H14O2S;
CAS         16215-21-7;
InChIKey    MGFFVSDRCRVHLC-UHFFFAOYSA-N;
MW          162.247;      // g/mol [origin=calculated method=formula-sum]
Tc          674.70;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       0.5723;      // -   [origin=predictive method=lee-kesler]
Tb          480.84;      // K   [origin=predictive method=joback]
HvapTb      45320.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.825 0.64132 -0.0002848 2.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2COO; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group COO; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 3-sulfanylpropanoate" "butyl mercaptopropionate" "propanoic acid, 3-mercapto-, butyl ester" "beta-mercaptopropionic acid, butyl ester" "propanoic acid,3-mercapto-, butyl ester" ".beta.-mercaptopropionic acid, butyl ester" "propionic acid, 3-mercapto-, butyl ester (8ci)" );
gibbsFormation
{
    dHf_298   -466610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     542.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-272920.0
    phase     gas;
}
