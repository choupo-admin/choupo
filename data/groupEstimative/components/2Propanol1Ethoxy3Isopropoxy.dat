/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propanol, 1-ethoxy-3-isopropoxy-  (C8H18O3, CAS 13021-50-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propanol1Ethoxy3Isopropoxy;
formula     C8H18O3;
CAS         13021-50-6;
InChIKey    ZATQNAGGARBGCM-UHFFFAOYSA-N;
MW          162.229;      // g/mol [origin=calculated method=formula-sum]
Tc          684.63;      // K   [origin=predictive method=joback]
Pc          27.354;      // bar [origin=predictive method=joback]
omega       0.9606;      // -   [origin=predictive method=lee-kesler]
Tb          518.78;      // K   [origin=predictive method=joback]
HvapTb      54125.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.543 0.68326 -0.0002262 -1.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxy-3-propan-2-yloxy-propan-2-ol" "2-propanol, 1-ethoxy-3-(1-methylethoxy)-" "1-ethoxy-3-isopropoxypropan-2-ol" "1-ethoxy-3-isopropoxy-2-propanol" "1-ethoxy-3-propan-2-yloxypropan-2-ol" "2-propanol, 1-ethoxy-3-(1-methylethoxy)- (9ci)" );
gibbsFormation
{
    dHf_298   -635680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-335220.0
    phase     gas;
}
