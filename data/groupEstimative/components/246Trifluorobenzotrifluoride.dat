/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trifluorobenzotrifluoride  (C7H2F6, CAS 122030-04-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trifluorobenzotrifluoride;
formula     C7H2F6;
CAS         122030-04-0;
InChIKey    SGPXFVDJRSZIPK-UHFFFAOYSA-N;
MW          200.081;      // g/mol [origin=calculated method=formula-sum]
Tc          559.19;      // K   [origin=predictive method=joback]
Pc          29.061;      // bar [origin=predictive method=joback]
omega       0.4887;      // -   [origin=predictive method=lee-kesler]
Tb          393.77;      // K   [origin=predictive method=joback]
HvapTb      29240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.59 0.608 -0.00045728 1.284e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACF; count 3; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-tris(fluoranyl)-2-(trifluoromethyl)benzene" "1,3,5-trifluoro-2-(trifluoromethyl)benzene" "2,4,6-trifluorobenzotrifluorode" "benzene, 1,3,5-trifluoro-2-(trifluoromethyl)-" "alpha,alpha,alpha,2,4,6-hexafluorotoluene" "alpha,alpha,alpha,2,4,6-hexafluorotoluene;1,3,5-trifluoro-2-(trifluoromethyl)benzene" );
standardThermochemistry
{
    dHf_298   -1171100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1074440.0
}
