/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-[3-(dimethylamino)propyl]-3-[3-(dimethylamino)propylamino]-2-methylpropanamide  (C14H32N4O, CAS 55910-12-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3DimethylaminoPropyl33DimethylaminoPropylamino2Methylpropan;
formula     C14H32N4O;
CAS         55910-12-8;
InChIKey    MGTPQUHIJZMPRF-UHFFFAOYSA-N;
MW          272.437;      // g/mol [origin=calculated method=formula-sum]
Tc          874.03;      // K   [origin=predictive method=joback]
Pc          16.404;      // bar [origin=predictive method=joback]
omega       1.1392;      // -   [origin=predictive method=lee-kesler]
Tb          698.57;      // K   [origin=predictive method=joback]
HvapTb      70074.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.963 1.712 -0.0010447 2.4166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CH2NH; count 1; } { group CH3N; count 2; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 7; } { group CH; count 1; } { group CdO; count 1; } { group NH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[3-(dimethylamino)propyl]-3-[3-(dimethylamino)propylamino]-2-methyl-propanamide" "n-[3-(dimethylamino)propyl]-3-{[3-(dimethylamino)propyl]amino}-2-methylpropanamide" "n-[3-(dimethylamino)propyl]-3-[[3-(dimethylamino)propyl]amino]-2-methylpropionamide" "n-(3-(dimethylamino)propyl)-3-((3-(dimethylamino)propyl)amino)-2-methylpropionamide" "propanamide, n-(3-(dimethylamino)propyl)-3-((3-(dimethylamino)propyl)amino)-2-methyl-" "propanamide, n-[3-(dimethylamino)propyl]-3-[[3-(dimethylamino)propyl]amino]-2-methyl-" );
standardThermochemistry
{
    dHf_298   -208150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     831.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=335980.0
}
