/*--------------------------------*- Choupo -*-----------------------*\
  Component: cetyldimethylamine  (C18H39N, CAS 112-69-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cetyldimethylamine;
formula     C18H39N;
CAS         112-69-6;
InChIKey    NHLUVTZJQOJKCC-UHFFFAOYSA-N;
MW          269.517;      // g/mol [origin=calculated method=formula-sum]
Tc          782.53;      // K   [origin=predictive method=joback]
Pc          11.507;      // bar [origin=predictive method=joback]
omega       0.8294;      // -   [origin=predictive method=lee-kesler]
Tb          623.88;      // K   [origin=predictive method=joback]
HvapTb      57705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.165 1.83776 -0.001068 2.404e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 15; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylhexadecan-1-amine" "n,n-dimethylhexadecylamine" "hexadecyldimethylamine" "dimethylcetylamine" "dimethyl palmitamine" "n,n-dimethylcetylamine" "1-hexadecanamine, n,n-dimethyl-" "n,n-dimethylpalmitylamine" "1-(dimethylamino)hexadecane" "dimethylhexadecylamine" "palmityl dimethyl amine" "dimethyl-n-hexadecylamine" );
gibbsFormation
{
    dHf_298   -347320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     873.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=211460.0
    phase     gas;
}
