/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butanol, 2,2-bis[(2-propenyloxy)methyl]-, acetate  (C14H24O4, CAS 67385-21-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butanol22Bis2PropenyloxyMethylAcetate;
formula     C14H24O4;
CAS         67385-21-1;
InChIKey    CDEFSZKWSZBPPQ-UHFFFAOYSA-N;
MW          256.342;      // g/mol [origin=calculated method=formula-sum]
Tc          813.04;      // K   [origin=predictive method=joback]
Pc          16.418;      // bar [origin=predictive method=joback]
omega       0.8004;      // -   [origin=predictive method=lee-kesler]
Tb          628.07;      // K   [origin=predictive method=joback]
HvapTb      57605.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.734 1.31848 -0.0007606 1.554e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group CH=CH; count 2; } { group CH3COO; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group dCH; count 4; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-ethyl-5-methoxy-2-(3-methoxyprop-2-enyl)pent-4-enyl] ethanoate" "1-butanol, 2,2-bis[(2-propen-1-yloxy)methyl]-, 1-acetate" );
gibbsFormation
{
    dHf_298   -688320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     723.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-290090.0
    phase     gas;
}
