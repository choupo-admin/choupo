/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, [[(2-methyl-2-propenyl)thio]methyl]-  (C11H14S, CAS 101561-50-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene2Methyl2PropenylThioMethyl;
formula     C11H14S;
CAS         101561-50-6;
InChIKey    VLHHDQFPXFJJAP-UHFFFAOYSA-N;
MW          178.293;      // g/mol [origin=calculated method=formula-sum]
Tc          775.11;      // K   [origin=predictive method=joback]
Pc          28.323;      // bar [origin=predictive method=joback]
omega       0.4532;      // -   [origin=predictive method=lee-kesler]
Tb          543.30;      // K   [origin=predictive method=joback]
HvapTb      48583.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.098 0.94421 -0.0005908 1.368e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylprop-2-enylsulfanylmethylbenzene" );
standardThermochemistry
{
    dHf_298   123670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=266560.0
}
