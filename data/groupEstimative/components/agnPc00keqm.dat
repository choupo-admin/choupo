/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-00keqm  (C24H50N2, CAS 68715-87-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc00keqm;
formula     C24H50N2;
CAS         68715-87-7;
InChIKey    BTLOXYBWVZTCMD-UHFFFAOYSA-N;
MW          366.678;      // g/mol [origin=calculated method=formula-sum]
Tc          953.00;      // K   [origin=predictive method=joback]
Pc          8.286;      // bar [origin=predictive method=joback]
omega       0.7882;      // -   [origin=predictive method=lee-kesler]
Tb          777.76;      // K   [origin=predictive method=joback]
HvapTb      73062.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.492 2.55168 -0.0015908 3.966e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 18; } { group CH=CH; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 18; } { group dCH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,n'-trimethyl-n'-octadec-9-enyl-propane-1,3-diamine" "1,3-propanediamine, n,n,n'-trimethyl-n'-(9z)-9-octadecenyl-" "1,3-propanediamine, n1,n1,n3-trimethyl-n3-(9z)-9-octadecen-1-yl-" "n,n,n'-trimethyl-n'-octadec-9-enylpropane-1,3-diamine" "n,n,n'-trimethyl-n'-[(e)-octadec-9-enyl]propane-1,3-diamine" );
gibbsFormation
{
    dHf_298   -286410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1116.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=452980.0
    phase     gas;
}
