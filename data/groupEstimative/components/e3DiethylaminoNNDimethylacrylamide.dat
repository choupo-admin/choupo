/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-3-(diethylamino)-n,n-dimethylacrylamide  (C9H18N2O, CAS 60715-98-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e3DiethylaminoNNDimethylacrylamide;
formula     C9H18N2O;
CAS         60715-98-2;
InChIKey    ZXAVESLBKNGZGY-UHFFFAOYSA-N;
MW          170.256;      // g/mol [origin=calculated method=formula-sum]
Tc          666.98;      // K   [origin=predictive method=joback]
Pc          25.741;      // bar [origin=predictive method=joback]
omega       0.6635;      // -   [origin=predictive method=lee-kesler]
Tb          488.43;      // K   [origin=predictive method=joback]
HvapTb      46418.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.498 1.09868 -0.0007561 2.0906e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 1; } { group CH2N; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dCH; count 2; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(diethylamino)-n,n-dimethyl-prop-2-enamide" "2-propenamide, 3-(diethylamino)-n,n-dimethyl-, (2e)-" );
gibbsFormation
{
    dHf_298   -89390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197760.0
    phase     gas;
}
