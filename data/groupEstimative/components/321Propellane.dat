/*--------------------------------*- Choupo -*-----------------------*\
  Component: [3.2.1]propellane  (C8H12, CAS 19074-25-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        321Propellane;
formula     C8H12;
CAS         19074-25-0;
InChIKey    FYWVNXHGOQXBTP-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          625.64;      // K   [origin=predictive method=joback]
Pc          44.563;      // bar [origin=predictive method=joback]
omega       0.2689;      // -   [origin=predictive method=lee-kesler]
Tb          403.74;      // K   [origin=predictive method=joback]
HvapTb      30976.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-255.91 1.8364 -0.002239 1.036e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[3.2.1.0(1,5)]octane" "tricyclo(3.2.1.01,5)octane" "tricyclo[3.2.1.01,5]octane" );
gibbsFormation
{
    dHf_298   66930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=207560.0
    phase     gas;
}
