/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylenecyclopropane  (C4H6, CAS 6142-73-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylenecyclopropane;
formula     C4H6;
CAS         6142-73-0;
InChIKey    XSGHLZBESSREDT-UHFFFAOYSA-N;
MW          54.092;      // g/mol [origin=calculated method=formula-sum]
Tc          481.99;      // K   [origin=predictive method=joback]
Pc          49.593;      // bar [origin=predictive method=joback]
omega       0.1992;      // -   [origin=predictive method=lee-kesler]
Tb          301.69;      // K   [origin=predictive method=joback]
HvapTb      24879.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.64 0.4437 -0.000377 1.348e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylidenecyclopropane" "cyclopropane, methylene-" "cyclopropylmethyl" "methylene-cyclopropane" "cyclopropane,methylene-" "methylenecyclopropane;methylidenecyclopropane" );
gibbsFormation
{
    dHf_298   51490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     237.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104340.0
    phase     gas;
}
