/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-decyltetrahydro-2h-pyran-2-one  (C15H28O2, CAS 68922-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Decyltetrahydro2hPyran2One;
formula     C15H28O2;
CAS         68922-03-2;
InChIKey    WYUWHCDYSJXTHL-UHFFFAOYSA-N;
MW          240.387;      // g/mol [origin=calculated method=formula-sum]
Tc          791.20;      // K   [origin=predictive method=joback]
Pc          16.026;      // bar [origin=predictive method=joback]
omega       0.7957;      // -   [origin=predictive method=lee-kesler]
Tb          612.03;      // K   [origin=predictive method=joback]
HvapTb      56476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.701 1.51532 -0.0008714 1.796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-decyloxan-2-one" "2h-pyran-2-one, 5-decyltetrahydro-" "2-oxo-5-decyl pyran" "2h-pyran-2-one,5-decyltetrahydro-" );
gibbsFormation
{
    dHf_298   -603570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-186300.0
    phase     gas;
}
