/*--------------------------------*- Choupo -*-----------------------*\
  Component: di-isopropyl tartrate  (C10H18O6, CAS 2217-15-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diIsopropylTartrate;
formula     C10H18O6;
CAS         2217-15-4;
InChIKey    XEBCWEDRGPSHQH-UHFFFAOYSA-N;
MW          234.248;      // g/mol [origin=calculated method=formula-sum]
Tc          905.53;      // K   [origin=predictive method=joback]
Pc          26.245;      // bar [origin=predictive method=joback]
omega       1.5883;      // -   [origin=predictive method=lee-kesler]
Tb          727.44;      // K   [origin=predictive method=joback]
HvapTb      84474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.47 0.93588 -0.0004046 1.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 4; } { group OH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 4; } { group OH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipropan-2-yl 2,3-bis(oxidanyl)butanedioate" "tartaric acid, diisopropyl ester" "diisopropyl tartrate" "diisopropyl tartarate" "butanedioic acid, 2,3-dihydroxy-, bis(1-methylethyl) ester, [s-(r*,r*)]-" "(-)-diisopropyl d-tartrate" "(+)-diisopropyl tartrate" "diisopropyl l-(+)-tartarate" "butanedioic acid, 2,3-dihydroxy-, bis(1-methylethyl) ester, (2s,3s)-" "d-tartaric acid diisopropyl ester" "l-tartaric acid diisopropyl ester" "butanedioic acid, 2,3-dihydroxy-, 1,4-bis(1-methylethyl) ester, (2s,3s)-" );
gibbsFormation
{
    dHf_298   -1209870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     711.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-870820.0
    phase     gas;
}
