/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6b,12b,12c-tetrahydrocyclobuta[1,2-a:3,4-a']diacenaphthylene  (C24H16, CAS 14620-98-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6b12b12cTetrahydrocyclobuta12A34ADiacenaphthylene;
formula     C24H16;
CAS         14620-98-5;
InChIKey    TVMWOWUBPJVYIC-UHFFFAOYSA-N;
MW          304.392;      // g/mol [origin=calculated method=formula-sum]
Tc          1112.17;      // K   [origin=predictive method=joback]
Pc          20.699;      // bar [origin=predictive method=joback]
omega       0.9032;      // -   [origin=predictive method=lee-kesler]
Tb          854.16;      // K   [origin=predictive method=joback]
HvapTb      78068.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-211.61 2.3548 -0.00218668 8.072e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 4; } { group ACCH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 4; } { group dCH_ring; count 12; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobuta[1,4-a']diacenaphthylene, 6b,6c,12b,12c-tetrahydro-" "6b,6c,12b,12c-tetrahydrocyclobuta(1,2-a:3,4-a')diacenaphthylene" "cyclobuta(1,2-a:3,4-a')diacenaphthylene, 6b,6c,12b,12c-tetrahydro-" "cyclobuta(1,2-a:3,4-a')diacenaphthylene, 6b,6c,12b,12c-tetrahydro- (6balpha,6calpha,12balpha,12calpha)-" "cyclobuta(1,2-a:3,4-a')diacenaphthylene, 6b,6c,12b,12c-tetrahydro- (6balpha,6cbeta,12bbeta,12calpha)-" "cyclobuta[1,2,-a:3,4-a']diacenaphthalene, 6b,6c,12b,12c-tetrahydro-(6b.alpha.,6c.alpha.,12b.alpha.,12c.alpha)-" "cyclobuta[1,2-a:3,4-a']diacenaphthalene, 6b,6c,12b,12c-tetrahydro-(6b.alpha.,6c.beta.,12b.beta.,12c.alpha.)-" "cyclobuta[1,2-a:3,4-a']diacenaphthylene, 6b,6c,12b,12c-tetrahydro- (6b.alpha.,6c.alpha.,12b.alpha.,12c.alpha.)-" "cyclobuta[1,2-a:3,4-a']diacenaphthylene, 6b,6c,12b,12c-tetrahydro- (6b.alpha.,6c.beta.,12b.beta.,12c.alpha.)-" );
gibbsFormation
{
    dHf_298   499490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     222.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=785840.0
    phase     gas;
}
