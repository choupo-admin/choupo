/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-5-ethylnonane  (C11H25N, CAS 10024-78-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino5Ethylnonane;
formula     C11H25N;
CAS         10024-78-9;
InChIKey    TYUUCUBAWUQCSY-UHFFFAOYSA-N;
MW          171.328;      // g/mol [origin=calculated method=formula-sum]
Tc          702.80;      // K   [origin=predictive method=joback]
Pc          20.642;      // bar [origin=predictive method=joback]
omega       0.6521;      // -   [origin=predictive method=lee-kesler]
Tb          522.93;      // K   [origin=predictive method=joback]
HvapTb      49945.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.984 1.12256 -0.0006244 1.297e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethylnonan-2-amine" "1-methyl-4-ethyloctylamine" "4-ethyl-1-methyloctylamine" "octylamine, 4-ethyl-1-methyl-" "2-nonanamine, 5-ethyl-" );
standardThermochemistry
{
    dHf_298   -247140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     617.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103310.0
}
