/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethoxypropionaldehyde  (C5H10O2, CAS 2806-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethoxypropionaldehyde;
formula     C5H10O2;
CAS         2806-85-1;
InChIKey    RKSGQXSDRYHVTM-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          558.61;      // K   [origin=predictive method=joback]
Pc          37.135;      // bar [origin=predictive method=joback]
omega       0.4833;      // -   [origin=predictive method=lee-kesler]
Tb          385.08;      // K   [origin=predictive method=joback]
HvapTb      35854.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.243 0.39012 -0.0001302 -8.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group O; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethoxypropanal" "propanal, 3-ethoxy-" "propionaldehyde, 3-ethoxy-" "ethoxy propionaldehyde" "propionaldehyde, ethoxy-" "beta-ethoxypropionaldehyde" ".beta.-ethoxypropionaldehyde" "propanal, 3-ethoxy- (9ci)" );
gibbsFormation
{
    dHf_298   -364330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-213300.0
    phase     gas;
}
