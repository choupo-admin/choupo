/*--------------------------------*- Choupo -*-----------------------*\
  Component: gamma-nonalactone  (C9H16O2, CAS 104-61-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gammaNonalactone;
formula     C9H16O2;
CAS         104-61-0;
InChIKey    OALYTRUKMRCXNH-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          654.22;      // K   [origin=predictive method=joback]
Pc          26.380;      // bar [origin=predictive method=joback]
omega       0.5618;      // -   [origin=predictive method=lee-kesler]
Tb          470.48;      // K   [origin=predictive method=joback]
HvapTb      42948.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.126 0.95492 -0.0005914 1.381e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-pentyloxolan-2-one" "gamma-nonanolactone" "gamma-nonanolide" "2(3h)-furanone, dihydro-5-pentyl-" "aldehyde c-18" "apricolin" "prunolide" "coconut aldehyde" "4-nonalactone" "4-nonanolide" "gamma-nonylactone" "gamma-nonyllactone" );
gibbsFormation
{
    dHf_298   -473570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-224720.0
    phase     gas;
}
