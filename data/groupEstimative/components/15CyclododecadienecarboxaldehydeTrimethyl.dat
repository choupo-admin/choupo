/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-cyclododecadienecarboxaldehyde, trimethyl-  (C16H26O, CAS 71735-87-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15CyclododecadienecarboxaldehydeTrimethyl;
formula     C16H26O;
CAS         71735-87-0;
InChIKey    YBOGEXCTIGZRAX-AUJXPEQHSA-N;
MW          234.383;      // g/mol [origin=calculated method=formula-sum]
Tc          893.29;      // K   [origin=predictive method=joback]
Pc          18.643;      // bar [origin=predictive method=joback]
omega       0.5793;      // -   [origin=predictive method=lee-kesler]
Tb          663.12;      // K   [origin=predictive method=joback]
HvapTb      60990.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.49 1.30536 -0.00042728 -6.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 2; } { group CH=C; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1e,5e,9r,10s)-6,9,10-trimethylcyclododeca-1,5-diene-1-carbaldehyde" );
standardThermochemistry
{
    dHf_298   -369510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     757.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-30880.0
}
