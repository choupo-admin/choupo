/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6,10,14-tetramethyl-2-hexadecene  (C20H40, CAS 56554-34-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        261014Tetramethyl2Hexadecene;
formula     C20H40;
CAS         56554-34-8;
InChIKey    VUODLTHTSSVQSK-UHFFFAOYSA-N;
MW          280.54;      // g/mol [origin=calculated method=formula-sum]
Tc          832.09;      // K   [origin=predictive method=joback]
Pc          10.701;      // bar [origin=predictive method=joback]
omega       0.7234;      // -   [origin=predictive method=lee-kesler]
Tb          659.92;      // K   [origin=predictive method=joback]
HvapTb      58988.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.211 1.94152 -0.0011599 2.745e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 9; } { group CH; count 3; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 9; } { group CH; count 3; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6,10,14-tetramethylhexadec-2-ene" "2-hexadecene, 2,6,10,14-tetramethyl-" );
gibbsFormation
{
    dHf_298   -364540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     895.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=181870.0
    phase     gas;
}
