/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(methylthio)benzyl alcohol  (C8H10OS, CAS 3446-90-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethylthioBenzylAlcohol;
formula     C8H10OS;
CAS         3446-90-0;
InChIKey    MTXQKSQYMREAGJ-UHFFFAOYSA-N;
MW          154.227;      // g/mol [origin=calculated method=formula-sum]
Tc          792.87;      // K   [origin=predictive method=joback]
Pc          41.039;      // bar [origin=predictive method=joback]
omega       0.8387;      // -   [origin=predictive method=lee-kesler]
Tb          575.26;      // K   [origin=predictive method=joback]
HvapTb      59836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.901 0.65381 -0.00036576 6.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methylsulfanylphenyl)methanol" "[4-(methylthio)phenyl]methanol" "[4-(methylsulfanyl)phenyl]methanol" "(4-methylthiophenyl)methan-1-ol" "4-methylthio benzyl alcohol" "p-(methylthio)benzyl alcohol" "p-methylthiobenzyl alcohol" "4-(hydroxymethyl)thioanisole" "4-(methylmercapto)benzyl alcohol" "4-(hydroxymethyl)thioanisole; 4-(methylmercapto)benzyl alcohol" "benzylalcohol, p-(methylthio)- (7ci,8ci); 4-(hydroxymethyl)phenyl methyl sulfide;4-(methylmercapto)benzyl alcohol; 4-(methylthio)benzenemethanol;4-(methylthio)benzyl alcohol; 4-methylsulfanylbenzyl alcohol;[4-(methylsulfanyl)phenyl]methanol; p-(methylthio)benzyl alcohol" );
standardThermochemistry
{
    dHf_298   -93750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15560.0
}
