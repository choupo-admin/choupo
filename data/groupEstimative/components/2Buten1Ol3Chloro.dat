/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-buten-1-ol, 3-chloro-  (C4H7ClO, CAS 40605-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Buten1Ol3Chloro;
formula     C4H7ClO;
CAS         40605-42-3;
InChIKey    SRQGZQPUPABHCN-UHFFFAOYSA-N;
MW          106.549;      // g/mol [origin=calculated method=formula-sum]
Tc          605.95;      // K   [origin=predictive method=joback]
Pc          45.043;      // bar [origin=predictive method=joback]
omega       0.6564;      // -   [origin=predictive method=lee-kesler]
Tb          424.77;      // K   [origin=predictive method=joback]
HvapTb      45600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.561 0.44452 -0.0003307 1.044e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylbut-2-en-1-ol" "3-chloro-2-buten-1-ol" );
gibbsFormation
{
    dHf_298   -186430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94280.0
    phase     gas;
}
