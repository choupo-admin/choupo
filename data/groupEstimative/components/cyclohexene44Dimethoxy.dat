/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene, 4,4-dimethoxy-  (C8H14O2, CAS 16831-48-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene44Dimethoxy;
formula     C8H14O2;
CAS         16831-48-4;
InChIKey    LOWABUUFTUKXON-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          656.68;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       0.3737;      // -   [origin=predictive method=lee-kesler]
Tb          446.43;      // K   [origin=predictive method=joback]
HvapTb      37792.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.2 0.99544 -0.00079028 2.862e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4-dimethoxycyclohexene" );
gibbsFormation
{
    dHf_298   -345550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144600.0
    phase     gas;
}
