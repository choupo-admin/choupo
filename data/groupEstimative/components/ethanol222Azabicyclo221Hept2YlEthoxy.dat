/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanol, 2-[2-(2-azabicyclo[2.2.1]hept-2-yl)ethoxy]-  (C10H19NO2, CAS 116230-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanol222Azabicyclo221Hept2YlEthoxy;
formula     C10H19NO2;
CAS         116230-20-7;
InChIKey    XHCXVEOOEJMFIP-UHFFFAOYSA-N;
MW          185.267;      // g/mol [origin=calculated method=formula-sum]
Tc          746.89;      // K   [origin=predictive method=joback]
Pc          29.377;      // bar [origin=predictive method=joback]
omega       1.0524;      // -   [origin=predictive method=lee-kesler]
Tb          568.92;      // K   [origin=predictive method=joback]
HvapTb      58812.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.586 1.3503 -0.0009926 2.988e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group CH2N; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(3-azabicyclo[2.2.1]heptan-3-yl)ethoxy]ethanol" "ethanol, 2-(2-(2-azabicyclo(2.2.1)hept-2-yl)ethoxy)-" "agn-pc-02l1gh" );
standardThermochemistry
{
    dHf_298   -321050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23780.0
}
