/*--------------------------------*- Choupo -*-----------------------*\
  Component: myralact  (C19H41NO4, CAS 12040-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        myralact;
formula     C19H41NO4;
CAS         12040-67-4;
InChIKey    HLFJBIVEMZFFOG-UHFFFAOYSA-N;
MW          347.54;      // g/mol [origin=calculated method=formula-sum]
Tc          1259.20;      // K   [origin=predictive method=joback]
Pc          12.433;      // bar [origin=predictive method=joback]
omega       1.0114;      // -   [origin=predictive method=lee-kesler]
Tb          1015.32;      // K   [origin=predictive method=joback]
HvapTb      114752.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.725 1.80354 -0.0007802 5.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group CH; count 1; } { group OH; count 2; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 1; } { group OH; count 2; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylpropanoic acid;2-(tetradecylamino)ethanol" "2-hydroxypropanoic acid- 2-(tetradecylamino)ethanol(1:1)" "myralactum" "miralacto" "miralat" "miralat [dcit]" "propanoic acid, 2-hydroxy-, compd. with 2-(tetradecylamino)ethanol (1:1)" "myralactum [inn-latin]" "2-hydroxypropanoic acid; 2-(tetradecylamino)ethanol" "2-hydroxypropanoic acid - 2-(tetradecylamino)ethanol (1:1)" );
standardThermochemistry
{
    dHf_298   -1153650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1189.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-526260.0
}
