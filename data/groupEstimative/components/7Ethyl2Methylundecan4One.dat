/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-ethyl-2-methylundecan-4-one  (C14H28O, CAS 6976-00-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Ethyl2Methylundecan4One;
formula     C14H28O;
CAS         6976-00-7;
InChIKey    RLGPVWMQXJXBGR-UHFFFAOYSA-N;
MW          212.377;      // g/mol [origin=calculated method=formula-sum]
Tc          746.87;      // K   [origin=predictive method=joback]
Pc          16.220;      // bar [origin=predictive method=joback]
omega       0.7339;      // -   [origin=predictive method=lee-kesler]
Tb          572.91;      // K   [origin=predictive method=joback]
HvapTb      52728.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.843 1.31768 -0.0007255 1.4536e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-ethyl-2-methyl-undecan-4-one" "7-ethyl-2-methyl-4-undecanone" "4-undecanone, 7-ethyl-2-methyl-" "4-undecanone,7-ethyl-2-methyl-" );
gibbsFormation
{
    dHf_298   -455430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     708.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-66800.0
    phase     gas;
}
