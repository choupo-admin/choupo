/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethoxy-2-cyclopentenone  (C7H10O2, CAS 22627-70-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethoxy2Cyclopentenone;
formula     C7H10O2;
CAS         22627-70-9;
InChIKey    SUQNVCCJLBQVEI-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          691.19;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       0.4599;      // -   [origin=predictive method=lee-kesler]
Tb          474.09;      // K   [origin=predictive method=joback]
HvapTb      39353.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.111 0.48002 -0.00010504 -4.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethoxycyclopent-2-en-1-one" "2-cyclopenten-1-one,3-ethoxy-" );
gibbsFormation
{
    dHf_298   -330600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     309.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154940.0
    phase     gas;
}
