/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-thienyl)propan-2-ol  (C7H10OS, CAS 62119-81-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12ThienylPropan2Ol;
formula     C7H10OS;
CAS         62119-81-7;
InChIKey    FQOLCQNLKZBNMM-UHFFFAOYSA-N;
MW          142.216;      // g/mol [origin=calculated method=formula-sum]
Tc          730.31;      // K   [origin=predictive method=joback]
Pc          42.943;      // bar [origin=predictive method=joback]
omega       0.7642;      // -   [origin=predictive method=lee-kesler]
Tb          522.58;      // K   [origin=predictive method=joback]
HvapTb      55091.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.609 0.70983 -0.00049962 1.414e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group OH; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-thiophen-2-ylpropan-2-ol" "1-thiophen-2-yl-propan-2-ol" "agn-pc-01ze2w" "alpha-methylthiophen-2-ethanol" "2-thiopheneethanol, a-methyl-" "1-(thiophen-2-yl)propan-2-ol" "2-thiopheneethanol, alpha-methyl-" "(2s)-1-thiophen-2-ylpropan-2-ol" );
gibbsFormation
{
    dHf_298   -115150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=3210.0
    phase     gas;
}
