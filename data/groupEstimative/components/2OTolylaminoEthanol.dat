/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(o-tolylamino)ethanol  (C9H13NO, CAS 136-80-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OTolylaminoEthanol;
formula     C9H13NO;
CAS         136-80-1;
InChIKey    DHZZPKMVVSTYLF-UHFFFAOYSA-N;
MW          151.209;      // g/mol [origin=calculated method=formula-sum]
Tc          776.58;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.9943;      // -   [origin=predictive method=lee-kesler]
Tb          579.53;      // K   [origin=predictive method=joback]
HvapTb      61681.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.818 0.83062 -0.00050896 1.168e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(2-methylphenyl)amino]ethanol" "o-toluidino ethanol" "o-tolyl ethanolamine" "2-o-tolylaminoethanol" "2-(o-toluidino)ethanol" "ethanol, 2-[(2-methylphenyl)amino]-" "ethanol, 2-toluidino-" "2-o-toluidinoethanol" "n-(2-hydroxyethyl)-o-toluidine" "n-(o-tolyl)ethanolamine" "ethanol, 2-o-toluidino-" "n-beta-hydroxyethyl-o-toluidine" );
standardThermochemistry
{
    dHf_298   -102790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80250.0
}
