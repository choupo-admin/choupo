/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(8.2.2.24,7)hexadeca-4,6,10,12,13,15-hexaen-5-amine  (C16H17N, CAS 10122-95-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo822247Hexadeca4610121315Hexaen5Amine;
formula     C16H17N;
CAS         10122-95-9;
InChIKey    BPBOJZFNHXUUNG-UHFFFAOYSA-N;
MW          223.319;      // g/mol [origin=calculated method=formula-sum]
Tc          985.10;      // K   [origin=predictive method=joback]
Pc          27.936;      // bar [origin=predictive method=joback]
omega       0.7141;      // -   [origin=predictive method=lee-kesler]
Tb          722.19;      // K   [origin=predictive method=joback]
HvapTb      68783.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.38 1.4172 -0.00098048 2.641e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group ACCH2; count 4; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[8.2.2.24,7]hexadeca-4,6,10,12,13,15-hexaen-5-amine" "tricyclo[8.2.2.24,7]hexadeca-1(12),4,6,10,13,15-hexaen-5-amine" );
standardThermochemistry
{
    dHf_298   185850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=402580.0
}
