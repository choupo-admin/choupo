/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-p-coumaric acid  (C9H8O3, CAS 4501-31-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cisPCoumaricAcid;
formula     C9H8O3;
CAS         4501-31-9;
InChIKey    NGSWKAQJJWESNS-UTCJRWHESA-N;
MW          164.16;      // g/mol [origin=calculated method=formula-sum]
Tc          905.75;      // K   [origin=predictive method=joback]
Pc          46.849;      // bar [origin=predictive method=joback]
omega       0.9682;      // -   [origin=predictive method=lee-kesler]
Tb          662.49;      // K   [origin=predictive method=joback]
HvapTb      68040.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.7 1.0053 -0.00090976 3.299e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-3-(4-hydroxyphenyl)prop-2-enoic acid" "cis-4-hydroxycinnamic acid" "(z)-p-coumaric acid" "cis-p-hydroxycinnamic acid" "cis-p-cumaric acid" "cis-p-coumarinic acid" "(z)-3-(4-hydroxyphenyl)-2-propenoic acid" "(z)-p-hydroxycinnamic acid" "cis-p-coumarate" "(2z)-3-(4-hydroxyphenyl)acrylic acid" "cinnamic acid, p-hydroxy-, (z)-" "2-propenoic acid, 3-(4-hydroxyphenyl)-, (z)-" );
gibbsFormation
{
    dHf_298   -402920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-281000.0
    phase     gas;
}
