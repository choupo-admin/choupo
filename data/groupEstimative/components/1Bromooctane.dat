/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromooctane  (C8H17Br, CAS 111-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromooctane;
formula     C8H17Br;
CAS         111-83-1;
InChIKey    VMKOFRJSULQZRM-UHFFFAOYSA-N;
MW          193.128;      // g/mol [origin=calculated method=formula-sum]
Tc          629.80;      // K   [origin=predictive method=joback]
Pc          27.212;      // bar [origin=predictive method=joback]
omega       0.5238;      // -   [origin=predictive method=lee-kesler]
Tb          448.80;      // K   [origin=predictive method=joback]
HvapTb      39837.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.807 0.80202 -0.0004828 1.181e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyloctane" "n-octyl bromide" "octyl bromide" "octane, 1-bromo-" "1-octylbromide" "bromooctane" "1-bromo octane" "1-bromo-octane" "1-bromo-n-octane" "capryl bromide" "i860" "1-bromo octane;1-octylbromide;octyl bromide;octane, 1-bromo-;n-bromooctane;" );
standardThermochemistry
{
    dHf_298   -182120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=30800.0
}
