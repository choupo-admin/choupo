/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-propylthiophene  (C7H10S, CAS 1518-75-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Propylthiophene;
formula     C7H10S;
CAS         1518-75-8;
InChIKey    QZNFRMXKQCIPQY-UHFFFAOYSA-N;
MW          126.217;      // g/mol [origin=calculated method=formula-sum]
Tc          648.01;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.3271;      // -   [origin=predictive method=lee-kesler]
Tb          430.84;      // K   [origin=predictive method=joback]
HvapTb      38800.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.218 0.66993 -0.00046602 1.321e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thiophene, 3-propyl-" "3-propylthiophene;" );
gibbsFormation
{
    dHf_298   42360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=142470.0
    phase     gas;
}
