/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-4-benzyloxymethyl-2,2-dimethyl-1,3-dioxolane  (C13H18O3, CAS 15028-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r4Benzyloxymethyl22Dimethyl13Dioxolane;
formula     C13H18O3;
CAS         15028-56-5;
InChIKey    DBFDSKSLTCMIPB-UHFFFAOYSA-N;
MW          222.284;      // g/mol [origin=calculated method=formula-sum]
Tc          839.41;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       0.6193;      // -   [origin=predictive method=lee-kesler]
Tb          610.89;      // K   [origin=predictive method=joback]
HvapTb      57035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.228 1.48784 -0.0011804 4.061e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyl-4-(phenylmethoxymethyl)-1,3-dioxolane" "4-[(benzyloxy)methyl]-2,2-dimethyl-1,3-dioxolane" "1-benzyl-2,3-isopropylidene-rac-glycerol" "4-((benzyloxy)methyl)-2,2-dimethyl-1,3-dioxolane" "dl-" "a," "a-isopropylideneglycerol, polymer-bound" "4-benzyloxymethyl-2,2-dimethyl-[1,3]dioxolane" "dl-" "a," "a-isopropylideneglycerol-" "a-benzyl ether" "4-(benzyloxymethyl)-2,2-dimethyl-1,3-dioxolane" "(+/-)-1-(2,3-isopropylidene)glycerol polystyrene" "dl-alpha,beta-isopropylideneglycerol, polymer-bound" "(+/-)-4-benzyloxymethyl-2,2-dimethyl-1,3-dioxolane" "dl-alpha,beta-isopropylideneglycerol-gamma-benzyl ether" );
standardThermochemistry
{
    dHf_298   -415960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-82900.0
}
