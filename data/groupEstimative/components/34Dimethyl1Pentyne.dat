/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethyl-1-pentyne  (C7H12, CAS 61064-08-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dimethyl1Pentyne;
formula     C7H12;
CAS         61064-08-2;
InChIKey    JDQKSTIAVKXRSK-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          533.12;      // K   [origin=predictive method=joback]
Pc          33.567;      // bar [origin=predictive method=joback]
omega       0.2270;      // -   [origin=predictive method=lee-kesler]
Tb          349.00;      // K   [origin=predictive method=joback]
HvapTb      30258.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.94 0.58676 -0.00035933 8.949e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 2; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 2; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dimethylpent-1-yne" "1-pentyne, 3,4-dimethyl" "1-pentyne, 3,4-dimethyl-" "(2e)-2-[(4-chlorophenyl)sulfonyl]-3-(3-fluoroanilino)-2-propenenitrile" );
gibbsFormation
{
    dHf_298   93530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=226250.0
    phase     gas;
}
