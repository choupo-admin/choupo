/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyldecanol  (C12H26O, CAS 2370-15-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyldecanol;
formula     C12H26O;
CAS         2370-15-2;
InChIKey    OSJLCOMCKUOKDD-UHFFFAOYSA-N;
MW          186.339;      // g/mol [origin=calculated method=formula-sum]
Tc          728.04;      // K   [origin=predictive method=joback]
Pc          19.596;      // bar [origin=predictive method=joback]
omega       0.9310;      // -   [origin=predictive method=lee-kesler]
Tb          563.11;      // K   [origin=predictive method=joback]
HvapTb      57689.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.202 1.30366 -0.0008312 2.133e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group C; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyldecan-1-ol" "1-decanol, 2,2-dimethyl-" "1-hydroxy-2,2-dimethyldecane" );
standardThermochemistry
{
    dHf_298   -451990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83820.0
}
