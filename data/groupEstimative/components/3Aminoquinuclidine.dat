/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-aminoquinuclidine  (C7H14N2, CAS 6238-14-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Aminoquinuclidine;
formula     C7H14N2;
CAS         6238-14-8;
InChIKey    REUAXQZIRFXQML-UHFFFAOYSA-N;
MW          126.203;      // g/mol [origin=calculated method=formula-sum]
Tc          677.93;      // K   [origin=predictive method=joback]
Pc          41.623;      // bar [origin=predictive method=joback]
omega       0.4773;      // -   [origin=predictive method=lee-kesler]
Tb          462.48;      // K   [origin=predictive method=joback]
HvapTb      43858.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.28 1.1468 -0.000907 2.892e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CHNH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azabicyclo[2.2.2]octan-3-amine" "quinuclidin-3-amine" "1-azabicyclo[2.2.2]oct-3-ylamine" "quinuclidine-3-ylamine" "1-azabicyclo(2.2.2)octan-3-amine" "3-aminoquinuclidine dihydrochloride dihydrochloride" "3-amino-1-azabicyclo[2.2.2]octane dihydrochloride" "1-azabicyclo[2.2.2]octan-3-amine, (r)-" "1-azabicyclo[2.2.2]octan-3-amine, (s)-" "(1s,4s)-quinuclidin-3-amine" "6530-09-2 (di-hydrochloride)" "3-amino-1-azabicyclo[2.2.2]octane" );
gibbsFormation
{
    dHf_298   52950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     335.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=294690.0
    phase     gas;
}
