/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-5-cyclohexadecen-1-one  (C17H30O, CAS 72785-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl5Cyclohexadecen1One;
formula     C17H30O;
CAS         72785-14-9;
InChIKey    GBCSDBVICWZSEG-UHFFFAOYSA-N;
MW          250.426;      // g/mol [origin=calculated method=formula-sum]
Tc          980.73;      // K   [origin=predictive method=joback]
Pc          18.515;      // bar [origin=predictive method=joback]
omega       0.4873;      // -   [origin=predictive method=lee-kesler]
Tb          717.79;      // K   [origin=predictive method=joback]
HvapTb      60124.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.17 1.42062 -0.00026128 -2.071e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 12; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylcyclohexadec-5-en-1-one" "5-cyclohexadecen-1-one, 3-methyl-" "5-cyclohexadecen-1-one,3-methyl-" );
gibbsFormation
{
    dHf_298   -481410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     870.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96920.0
    phase     gas;
}
