/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-propanediol  (C3H8O2, CAS 504-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Propanediol;
formula     C3H8O2;
CAS         504-63-2;
InChIKey    YPFDHNVEDLHUCE-UHFFFAOYSA-N;
MW          76.095;      // g/mol [origin=calculated method=formula-sum]
Tc          611.83;      // K   [origin=predictive method=joback]
Pc          57.219;      // bar [origin=predictive method=joback]
omega       1.1720;      // -   [origin=predictive method=lee-kesler]
Tb          452.60;      // K   [origin=predictive method=joback]
HvapTb      55630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.743 0.3568 -0.0002002 4.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propane-1,3-diol" "trimethylene glycol" "1,3-dihydroxypropane" "2-deoxyglycerol" "1,3-propylenediol" "omega-propanediol" "1,3-propylene glycol" "2-(hydroxymethyl)ethanol" "1,3-propandiol" "beta-propylene glycol" ".beta.-propylene glycol" "pg" );
standardThermochemistry
{
    dHf_298   -409710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-299260.0
}
