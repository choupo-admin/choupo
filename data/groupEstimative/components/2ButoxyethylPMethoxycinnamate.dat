/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butoxyethyl p-methoxycinnamate  (C16H22O4, CAS 72845-39-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButoxyethylPMethoxycinnamate;
formula     C16H22O4;
CAS         72845-39-7;
InChIKey    LUPLDBUGMCGYST-UHFFFAOYSA-N;
MW          278.348;      // g/mol [origin=calculated method=formula-sum]
Tc          902.86;      // K   [origin=predictive method=joback]
Pc          17.146;      // bar [origin=predictive method=joback]
omega       0.9218;      // -   [origin=predictive method=lee-kesler]
Tb          704.56;      // K   [origin=predictive method=joback]
HvapTb      66333.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.965 1.22424 -0.00057796 6.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butoxyethyl 3-(4-methoxyphenyl)prop-2-enoate" "2-propenoic acid, 3-(4-methoxyphenyl)-, 2-butoxyethyl ester" );
standardThermochemistry
{
    dHf_298   -613010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     733.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-253530.0
}
