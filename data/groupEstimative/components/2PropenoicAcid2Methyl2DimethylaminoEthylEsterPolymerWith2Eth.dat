/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, 2-(dimethylamino)ethyl ester, polymer with 2-ethylhexyl 2-propenoate and methyl 2-methyl-2-propenoate  (C24H43NO6, CAS 72783-16-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2Methyl2DimethylaminoEthylEsterPolymerWith2Eth;
formula     C24H43NO6;
CAS         72783-16-5;
InChIKey    FBEAXWWMDYIOJH-UHFFFAOYSA-N;
MW          441.609;      // g/mol [origin=calculated method=formula-sum]
Tc          1136.13;      // K   [origin=predictive method=joback]
Pc          7.975;      // bar [origin=predictive method=joback]
omega       0.7623;      // -   [origin=predictive method=lee-kesler]
Tb          927.98;      // K   [origin=predictive method=joback]
HvapTb      91632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (118.207 1.77674 -0.0003575 -2.386e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 7; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group CH3N; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 7; } { group CH; count 1; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group COO; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)ethyl 2-methylprop-2-enoate;2-ethylhexyl prop-2-enoate;methyl 2-methylprop-2-enoate" );
gibbsFormation
{
    dHf_298   -1294810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1444.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-634670.0
    phase     gas;
}
