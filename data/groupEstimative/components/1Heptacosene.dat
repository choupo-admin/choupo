/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-heptacosene  (C27H54, CAS 15306-27-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Heptacosene;
formula     C27H54;
CAS         15306-27-1;
InChIKey    YYLACZAXCCJCJO-UHFFFAOYSA-N;
MW          378.729;      // g/mol [origin=calculated method=formula-sum]
Tc          996.72;      // K   [origin=predictive method=joback]
Pc          7.043;      // bar [origin=predictive method=joback]
omega       0.6483;      // -   [origin=predictive method=lee-kesler]
Tb          814.04;      // K   [origin=predictive method=joback]
HvapTb      75026.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.646 2.54882 -0.0014679 3.275e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 24; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 24; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptacos-1-ene" "heptacosene" );
gibbsFormation
{
    dHf_298   -475180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1203.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=264300.0
    phase     gas;
}
