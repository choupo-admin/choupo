/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-2-(1-piperidinylmethyl)phenol  (C13H19NO, CAS 21236-74-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl21PiperidinylmethylPhenol;
formula     C13H19NO;
CAS         21236-74-8;
InChIKey    SMZFAZCVXCKGAC-UHFFFAOYSA-N;
MW          205.301;      // g/mol [origin=calculated method=formula-sum]
Tc          876.57;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.7624;      // -   [origin=predictive method=lee-kesler]
Tb          641.71;      // K   [origin=predictive method=joback]
HvapTb      63093.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.569 1.53712 -0.00119932 3.823e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-(piperidin-1-ylmethyl)phenol" "phenol, 4-methyl-2-(1-piperidinylmethyl)-" "4-methyl-2-(piperidylmethyl)phenol" "alpha2-piperidino-2,4-xylenol" "4-methyl-2-(piperidinomethyl)phenol" );
standardThermochemistry
{
    dHf_298   -115550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161780.0
}
