/*--------------------------------*- Choupo -*-----------------------*\
  Component: emetine  (C29H40N2O4, CAS 483-18-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        emetine;
formula     C29H40N2O4;
CAS         483-18-1;
InChIKey    AUVVAXYIELKVAI-CKBKHPSWSA-N;
MW          480.649;      // g/mol [origin=calculated method=formula-sum]
Tc          1373.31;      // K   [origin=predictive method=joback]
Pc          10.624;      // bar [origin=predictive method=joback]
omega       1.0170;      // -   [origin=predictive method=lee-kesler]
Tb          1121.12;      // K   [origin=predictive method=joback]
HvapTb      106887.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.288 2.5088 -0.00133436 2.307e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 4; } { group ACCH2; count 2; } { group ACCH; count 2; } { group CH3O; count 4; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group O; count 4; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,3r,11bs)-2-[[(1r)-6,7-dimethoxy-1,2,3,4-tetrahydroisoquinolin-1-yl]methyl]-3-ethyl-9,10-dimethoxy-2,3,4,6,7,11b-hexahydro-1h-benzo[a]quinolizine" "emetin" "cephaeline methyl ether" "methyl cephaeline" "emetine [ban]" "cephaline-o-methyl ether" "emetine hydrochloride" "emetan, 6',7',10,11-tetramethoxy-" "6',7',10,11-tetramethoxyemetan" "ipecine" "methylcephaeline" "emetine dihydrochloride hydrate" );
standardThermochemistry
{
    dHf_298   -475450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     817.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=289170.0
}
