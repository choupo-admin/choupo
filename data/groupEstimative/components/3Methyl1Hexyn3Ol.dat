/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-1-hexyn-3-ol  (C7H12O, CAS 4339-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl1Hexyn3Ol;
formula     C7H12O;
CAS         4339-05-3;
InChIKey    DTGUZRPEDLHAAO-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          620.48;      // K   [origin=predictive method=joback]
Pc          37.592;      // bar [origin=predictive method=joback]
omega       0.6286;      // -   [origin=predictive method=lee-kesler]
Tb          438.83;      // K   [origin=predictive method=joback]
HvapTb      46417.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.878 0.73474 -0.00055513 1.7219e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylhex-1-yn-3-ol" "1-hexyn-3-ol, 3-methyl-" "ethynylmethylpropylcarbinol" "3-methyl-hexin-(1)-ol-(3) [german]" "(3r)-3-methylhex-1-yn-3-ol" "methylpropylethynylcarbinol" "3-methyl-hexin-(1)-ol-(3)" );
standardThermochemistry
{
    dHf_298   -56890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97150.0
}
