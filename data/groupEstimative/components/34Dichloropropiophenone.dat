/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4'-dichloropropiophenone  (C9H8Cl2O, CAS 3946-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dichloropropiophenone;
formula     C9H8Cl2O;
CAS         3946-29-0;
InChIKey    AYFJBHFMQODYBC-UHFFFAOYSA-N;
MW          203.062;      // g/mol [origin=calculated method=formula-sum]
Tc          795.22;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       0.5866;      // -   [origin=predictive method=lee-kesler]
Tb          565.91;      // K   [origin=predictive method=joback]
HvapTb      54082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.242 0.706 -0.00045206 1.0546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 1; } { group CH2Cl; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-1-(4-chlorophenyl)propan-1-one" "3-chloro-1-(4-chlorophenyl)propan-1-one" "1-propanone,3-chloro-1-(4-chlorophenyl)-" "1-propanone, 3-chloro-1-(4-chlorophenyl)-" );
gibbsFormation
{
    dHf_298   -148090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-25100.0
    phase     gas;
}
