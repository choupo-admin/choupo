/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclooctyne,3,3,8,8-tetramethyl-  (C12H20, CAS 53561-46-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclooctyne3388Tetramethyl;
formula     C12H20;
CAS         53561-46-9;
InChIKey    WVECPOSSBHZOOS-UHFFFAOYSA-N;
MW          164.292;      // g/mol [origin=calculated method=formula-sum]
Tc          736.20;      // K   [origin=predictive method=joback]
Pc          26.353;      // bar [origin=predictive method=joback]
omega       0.2675;      // -   [origin=predictive method=lee-kesler]
Tb          498.52;      // K   [origin=predictive method=joback]
HvapTb      42276.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-150.11 1.67348 -0.00162766 6.8798e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group tC; count 2; } { group CH2_ring; count 4; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,8,8-tetramethylcyclooctyne" "cyclooctyne, 3,3,8,8-tetramethyl-" );
gibbsFormation
{
    dHf_298   45750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     661.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=258720.0
    phase     gas;
}
