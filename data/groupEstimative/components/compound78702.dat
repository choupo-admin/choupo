/*--------------------------------*- Choupo -*-----------------------*\
  Component: compound 78/702  (C21H26O2, CAS 74886-24-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        compound78702;
formula     C21H26O2;
CAS         74886-24-1;
InChIKey    MXQCYBHGKOKYGH-HEHNFIMWSA-N;
MW          310.437;      // g/mol [origin=calculated method=formula-sum]
Tc          1014.47;      // K   [origin=predictive method=joback]
Pc          15.093;      // bar [origin=predictive method=joback]
omega       0.8372;      // -   [origin=predictive method=lee-kesler]
Tb          792.16;      // K   [origin=predictive method=joback]
HvapTb      73154.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.977 1.61548 -0.00091332 1.813e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(e)-2-ethyl-3-(4-methoxyphenyl)pent-2-enyl]-4-methoxy-benzene" "1,2-diethyl-1,3-bis(4-methoxyphenyl)-1-propene" "1,2-diethyl-1,3-bis-(p-methoxyphenyl)-1-propene" "3-hexene, 3-(p-methoxybenzyl)-4-(p-methoxyphenyl)-" "1-[(e)-2-ethyl-3-(4-methoxyphenyl)pent-2-enyl]-4-methoxybenzene" );
gibbsFormation
{
    dHf_298   -193450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     756.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184620.0
    phase     gas;
}
