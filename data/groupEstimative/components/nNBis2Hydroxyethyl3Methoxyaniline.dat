/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(2-hydroxyethyl)-3-methoxyaniline  (C11H17NO3, CAS 17126-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis2Hydroxyethyl3Methoxyaniline;
formula     C11H17NO3;
CAS         17126-75-9;
InChIKey    FAMIFVQDRQPFPH-UHFFFAOYSA-N;
MW          211.261;      // g/mol [origin=calculated method=formula-sum]
Tc          883.82;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       1.5695;      // -   [origin=predictive method=lee-kesler]
Tb          702.16;      // K   [origin=predictive method=joback]
HvapTb      80829.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.326 1.03912 -0.00060116 1.225e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 2; } { group CH3O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-hydroxyethyl-(3-methoxyphenyl)amino]ethanol" "2,2'-((3-methoxyphenyl)azanediyl)diethanol" "2-[(2-hydroxyethyl)(3-methoxyphenyl)amino]ethan-1-ol" "ethanol,2,2'-[(3-methoxyphenyl)imino]bis-" "2-[n-(2-hydroxyethyl)-3-methoxyanilino]ethanol" "ethanol,2,2'-[(m-methoxyphenyl)imino]di- (6ci,8ci);n,n-bis(2-hydroxyethyl)-3-methoxyaniline;" );
gibbsFormation
{
    dHf_298   -414460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-123340.0
    phase     gas;
}
