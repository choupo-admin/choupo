/*--------------------------------*- Choupo -*-----------------------*\
  Component: copaene  (C15H24, CAS 3856-25-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        copaene;
formula     C15H24;
CAS         3856-25-5;
InChIKey    VLXDPFLIRFYIME-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          775.80;      // K   [origin=predictive method=joback]
Pc          20.019;      // bar [origin=predictive method=joback]
omega       0.4669;      // -   [origin=predictive method=lee-kesler]
Tb          561.89;      // K   [origin=predictive method=joback]
HvapTb      47692.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-184.31 2.00128 -0.00175164 6.557e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 5; } { group C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ylangene" "(-)-alpha-copaene" ".alpha.-copaene" "agn-pc-02lrxj" "8-isopropyl-1,3-dimethyltricyclo(4.4.0.02,7)dec-3-ene" "(&#8722;)-alpha-copaene" "tricyclo(4.4.0.0(2,7))dec-3-ene, 1,3-dimethyl-8-(1-methylethyl)-, stereoisomer" "tricyclo[4.4.0.0(2,7)]dec-3-ene, 1,3-dimethyl-8-(1-methylethyl)-, stereoisomer" "tricyclo[4.4.0.02,7]dec-3-ene, 1,3-dimethyl-8-(1-methylethyl)-" "tricyclo[4.4.0.02,7]dec-3-ene, 1,3-dimethyl-8-(1-methylethyl)-, stereoisomer" );
standardThermochemistry
{
    dHf_298   -125100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=242550.0
}
