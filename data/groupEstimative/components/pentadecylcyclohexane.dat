/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentadecylcyclohexane  (C21H42, CAS 6006-95-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentadecylcyclohexane;
formula     C21H42;
CAS         6006-95-7;
InChIKey    ZNUABQHWFGTOCO-UHFFFAOYSA-N;
MW          294.567;      // g/mol [origin=calculated method=formula-sum]
Tc          878.10;      // K   [origin=predictive method=joback]
Pc          10.899;      // bar [origin=predictive method=joback]
omega       0.7804;      // -   [origin=predictive method=lee-kesler]
Tb          699.63;      // K   [origin=predictive method=joback]
HvapTb      62769.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.806 2.12092 -0.0011996 2.483e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 19; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane, pentadecyl-" "n-pentadecylcyclohexane" "1-cyclohexylpentadecane" );
standardThermochemistry
{
    dHf_298   -422450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     943.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=150390.0
}
