/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraiodomethane  (CI4, CAS 507-25-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraiodomethane;
formula     CI4;
CAS         507-25-5;
InChIKey    JOHCVVJGGSABQY-UHFFFAOYSA-N;
MW          519.611;      // g/mol [origin=calculated method=formula-sum]
Tc          961.41;      // K   [origin=predictive method=joback]
Pc          52.282;      // bar [origin=predictive method=joback]
omega       0.1637;      // -   [origin=predictive method=lee-kesler]
Tb          591.81;      // K   [origin=predictive method=joback]
HvapTb      54016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.27 0.3806 -0.000528 2.322e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group I; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group I; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrakis(iodanyl)methane" "carbon tetraiodide" "methane, tetraiodo-" "carbon iodide" "periodomethane" "tetraiodo methane" "carbontetraiodide (6ci,8ci);carbon iodide (ci4);tetraiodomethane;" );
gibbsFormation
{
    dHf_298   234760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192860.0
    phase     gas;
}
