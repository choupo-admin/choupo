/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-4,6-dimethylaniline  (C8H10ClN, CAS 63133-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro46Dimethylaniline;
formula     C8H10ClN;
CAS         63133-82-4;
InChIKey    LKAQFOKMMXWRRQ-UHFFFAOYSA-N;
MW          155.625;      // g/mol [origin=calculated method=formula-sum]
Tc          766.28;      // K   [origin=predictive method=joback]
Pc          35.431;      // bar [origin=predictive method=joback]
omega       0.5218;      // -   [origin=predictive method=lee-kesler]
Tb          534.22;      // K   [origin=predictive method=joback]
HvapTb      52690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.99 0.57514 -0.00030528 5.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 2; } { group ACNH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-4,6-dimethyl-aniline" "benzenamine, 2-chloro-4,6-dimethyl-" "2-chloro-4,6-dimethylphenylamine" "2-chloro-4,6-xylidine" "2,4-dimethyl-6-chloroaniline" "benzenamine,2-chloro-4,6-dimethyl-" "benzenamine, 2-chloro-4.6-dimethyl-" );
gibbsFormation
{
    dHf_298   11720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=154520.0
    phase     gas;
}
