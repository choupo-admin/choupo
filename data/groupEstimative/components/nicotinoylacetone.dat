/*--------------------------------*- Choupo -*-----------------------*\
  Component: nicotinoylacetone  (C9H9NO2, CAS 3594-37-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nicotinoylacetone;
formula     C9H9NO2;
CAS         3594-37-4;
InChIKey    OVPXWZQQDUKDFN-UHFFFAOYSA-N;
MW          163.176;      // g/mol [origin=calculated method=formula-sum]
Tc          829.40;      // K   [origin=predictive method=joback]
Pc          37.916;      // bar [origin=predictive method=joback]
omega       0.7067;      // -   [origin=predictive method=lee-kesler]
Tb          593.64;      // K   [origin=predictive method=joback]
HvapTb      57606.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.419 0.75768 -0.00046886 1.0512e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 1; } { group CH2CO; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group CdO; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pyridin-3-ylbutane-1,3-dione" "1-(pyridin-3-yl)butane-1,3-dione" "1-(3-pyridinyl)-1,3-butanedione" "1,3-butanedione, 1-(3-pyridinyl)-" "1, 1-(3-pyridinyl)-" "1, 1-(3-pyridyl)-" "1-(3-pyridyl)-1,3-butanedione" "1,3-butanedione, 1-(3-pyridyl)-" "1-(3-pyridinyl)-1,3-butanedione;3-acetoacetylpyridine;nicotinoylacetone;1-(pyridin-3-yl)butane-1,3-dione" );
standardThermochemistry
{
    dHf_298   -184930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-43480.0
}
