/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-Diphenyl-4-methyl-1-pentene  (C18H20, CAS 6362-80-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Diphenyl4Methyl1Pentene;
formula     C18H20;
CAS         6362-80-7;
InChIKey    ZOKCNEIWFQCSCM-UHFFFAOYSA-N;
MW          236.358;      // g/mol [origin=calculated method=formula-sum]
Tc          901.89;      // K   [origin=predictive method=joback]
Pc          20.327;      // bar [origin=predictive method=joback]
omega       0.5183;      // -   [origin=predictive method=lee-kesler]
Tb          658.13;      // K   [origin=predictive method=joback]
HvapTb      58328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.439 1.66174 -0.0012148 3.451e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH2=C; count 1; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-4-phenylpent-4-en-2-yl)benzene" "1,1′-(1,1-Dimethyl-3-methylene-1,3-propanediyl)bis[benzene]" "1-pentene, 4-methyl-2,4-diphenyl-" "4,4-dimethyl-2,4-diphenyl-1-butene" "4-methyl-2,4-diphenyl-1-pentene" "Benzene, 1,1′-(1,1-dimethyl-3-methylene-1,3-propanediyl)bis-" "dk 80" "dk 81" "dk 86" "nofmer msd" "α-(2-Methyl-2-phenylpropyl)styrene" "(4-Methylpent-1-ene-2,4-diyl)dibenzene" );
gibbsFormation
{
    dHf_298   165100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=407630.0
    phase     gas;
}
