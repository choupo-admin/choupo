/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3,4-dimethoxycinnamate  (C12H14O4, CAS 5396-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl34Dimethoxycinnamate;
formula     C12H14O4;
CAS         5396-64-5;
InChIKey    JXRYDOZRPYFBKO-FNORWQNLSA-N;
MW          222.24;      // g/mol [origin=calculated method=formula-sum]
Tc          827.92;      // K   [origin=predictive method=joback]
Pc          23.888;      // bar [origin=predictive method=joback]
omega       0.7584;      // -   [origin=predictive method=lee-kesler]
Tb          618.02;      // K   [origin=predictive method=joback]
HvapTb      58091.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.9 0.78476 -0.00029332 -1.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (e)-3-(3,4-dimethoxyphenyl)prop-2-enoate" "3,4-o-dimethylcaffeic acid methyl ester" "methyl 3-(3,4-dimethoxyphenyl)acrylate" "2-propenoic acid, 3-(3,4-dimethoxyphenyl)-, methyl ester" "cinnamic acid, 3,4-dimethoxy-, methyl ester" "methyl (2e)-3-(3,4-dimethoxyphenyl)prop-2-enoate" "2-propenoic acid, 3-(3,4-dimethoxyphenyl)-, methyl ester, trans" "methyl 3-(3',4'-dimethoxyphenyl)propenoate" "methyl 3,4-dimethyoxycinnamate" "cinnamic acid,4-dimethoxy-, methyl ester" "2-propenoic acid,4-dimethoxyphenyl)-, methyl ester" "cinnamic acid, 3,4-dimethoxy-, methyl ester (8ci)" );
standardThermochemistry
{
    dHf_298   -541920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-296840.0
}
