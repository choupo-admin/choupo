/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopent[cd]azulene,2a,8b-dihydro-  (C12H10, CAS 38310-40-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentCdAzulene2a8bDihydro;
formula     C12H10;
CAS         38310-40-6;
InChIKey    HXHFTTRCEKEWIZ-UHFFFAOYSA-N;
MW          154.212;      // g/mol [origin=calculated method=formula-sum]
Tc          756.33;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       0.4094;      // -   [origin=predictive method=lee-kesler]
Tb          517.62;      // K   [origin=predictive method=joback]
HvapTb      45654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.55 1.1952 -0.00100812 3.392e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH=CH; count 3; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopent(cd)azulene, 2a,8b-dihydro-" );
gibbsFormation
{
    dHf_298   195210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     255.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=334360.0
    phase     gas;
}
