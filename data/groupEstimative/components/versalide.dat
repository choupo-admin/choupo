/*--------------------------------*- Choupo -*-----------------------*\
  Component: versalide  (C18H26O, CAS 88-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        versalide;
formula     C18H26O;
CAS         88-29-9;
InChIKey    KSEZPRJUTHMFGZ-UHFFFAOYSA-N;
MW          258.405;      // g/mol [origin=calculated method=formula-sum]
Tc          939.53;      // K   [origin=predictive method=joback]
Pc          17.580;      // bar [origin=predictive method=joback]
omega       0.7089;      // -   [origin=predictive method=lee-kesler]
Tb          713.75;      // K   [origin=predictive method=joback]
HvapTb      64144.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.529 2.12712 -0.00195038 7.8196e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-ethyl-5,5,8,8-tetramethyl-6,7-dihydronaphthalen-2-yl)ethanone" "polycyclic musk" "acetylethyltetramethyltetralin" "aett" "musk 36a" "7-acetyl-6-ethyl-1,1,4,4-tetramethyltetralin" "ethanone, 1-(3-ethyl-5,6,7,8-tetrahydro-5,5,8,8-tetramethyl-2-naphthalenyl)-" "6-acetyl-1,1,4,4-tetramethyl-7-ethyl-1,2,3,4-tetralin" "7-acetyl-6-ethyl-1,1,4,4-tetramethyl-1,2,3,4-tetrahydronaphthalene" "7-acetyl-6-ethyl-1,2,3,4-tetrahydro-1,1,4,4-tetramethylnaphthalene" "1-(3-ethyl-5,5,8,8-tetramethyl-5,6,7,8-tetrahydronaphthalen-2-yl)ethanone" "1-(3-ethyl-5,6,7,8-tetrahydro-5,5,8,8-tetramethyl-2-naphthalenyl)-ethanone" );
standardThermochemistry
{
    dHf_298   -248530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     785.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85240.0
}
