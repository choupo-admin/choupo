/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxy-4-methyl-d3-benzene  (C8H13D3O, CAS 14202-49-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H13D3O (delta D+3H-3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Methoxy4MethylD3Benzene;
formula     C8H13D3O;
CAS         14202-49-4;
InChIKey    VBAPYXHNMYKBKN-FIBGUPNXSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          131.233;      // g/mol [origin=calculated method=formula-sum]
Tc          619.74;      // K   [origin=predictive method=joback]
Pc          29.828;      // bar [origin=predictive method=joback]
omega       0.3176;      // -   [origin=predictive method=lee-kesler]
Tb          419.94;      // K   [origin=predictive method=joback]
HvapTb      35932.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.55 0.79624 -0.000326 1.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-4-(trideuteriomethyl)cyclohexane" );
gibbsFormation
{
    dHf_298   -306690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-71780.0
    phase     gas;
}
