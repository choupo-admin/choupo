/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylformamide dipropyl acetal  (C9H21NO2, CAS 6006-65-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylformamideDipropylAcetal;
formula     C9H21NO2;
CAS         6006-65-1;
InChIKey    NSLGQFIDCADTAS-UHFFFAOYSA-N;
MW          175.272;      // g/mol [origin=calculated method=formula-sum]
Tc          627.88;      // K   [origin=predictive method=joback]
Pc          22.461;      // bar [origin=predictive method=joback]
omega       0.6281;      // -   [origin=predictive method=lee-kesler]
Tb          462.36;      // K   [origin=predictive method=joback]
HvapTb      42103.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.334 0.86228 -0.0003596 2.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2O; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-1,1-dipropoxy-methanamine" "1,1-dipropoxytrimethylamine" "1,1-dipropoxy-n,n-dimethylmethylamine" "n,n-dimethyl-1,1-dipropoxymethanamine" "n,n-dimethylformamide di-n-propyl acetal" "(dipropoxymethyl)dimethylamine" "nslgqfidcadtas-uhfffaoysa-" "methanamine,n,n-dimethyl-1,1-dipropoxy-" );
standardThermochemistry
{
    dHf_298   -431280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76760.0
}
