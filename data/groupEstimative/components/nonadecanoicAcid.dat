/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonadecanoic acid  (C19H38O2, CAS 646-30-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonadecanoicAcid;
formula     C19H38O2;
CAS         646-30-0;
InChIKey    ISYWECDDZWTKFF-UHFFFAOYSA-N;
MW          298.511;      // g/mol [origin=calculated method=formula-sum]
Tc          960.17;      // K   [origin=predictive method=joback]
Pc          11.468;      // bar [origin=predictive method=joback]
omega       1.0248;      // -   [origin=predictive method=lee-kesler]
Tb          779.83;      // K   [origin=predictive method=joback]
HvapTb      75052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.783 1.85962 -0.0010824 2.429e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-nonadecanoic acid" "nonadecylic acid" "nonadecanoate" "fatty acids, c16-22" "n-nonadecanoate" "n-nonadecylate" "n-nonadecylic acid" "nonadecans&#xe4;ure" "agn-pc-00smjc" "(c16-c22)alkylcarboxylic acid" "(c16-c22) alkylcarboxylic acid" "c19:0" );
gibbsFormation
{
    dHf_298   -785760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     949.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-234810.0
    phase     gas;
}
