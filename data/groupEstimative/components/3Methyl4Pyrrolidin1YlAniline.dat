/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-4-(pyrrolidin-1-yl)aniline  (C11H16N2, CAS 16089-43-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl4Pyrrolidin1YlAniline;
formula     C11H16N2;
CAS         16089-43-3;
InChIKey    HXGBHCCAZHQXQV-UHFFFAOYSA-N;
MW          176.263;      // g/mol [origin=calculated method=formula-sum]
Tc          823.64;      // K   [origin=predictive method=joback]
Pc          33.412;      // bar [origin=predictive method=joback]
omega       0.6367;      // -   [origin=predictive method=lee-kesler]
Tb          588.57;      // K   [origin=predictive method=joback]
HvapTb      56758.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.92 1.20452 -0.00085692 2.414e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-4-pyrrolidin-1-yl-aniline" "3-methyl-4-pyrrolidin-1-ylaniline" "benzenamine, 3-methyl-4-(1-pyrrolidinyl)-" "n-(4-amino-2-methylphenyl)pyrrolidine" "3-methyl-4-pyrrolidin-1-yl-phenylamine" "3-methyl-4-(1-pyrrolidinyl)-benzenamine" "benzenamine,3-methyl-4-(1-pyrrolidinyl)-" "pyrrolidine,1-(4-amino-o-tolyl)- (8ci);n-(p-amino-o-methylphenyl)pyrrolidine;" );
gibbsFormation
{
    dHf_298   131520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=368480.0
    phase     gas;
}
