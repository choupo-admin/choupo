/*--------------------------------*- Choupo -*-----------------------*\
  Component: [3.3.3]propellane-2,8-dione  (C11H14O2, CAS 112138-34-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333Propellane28Dione;
formula     C11H14O2;
CAS         112138-34-8;
InChIKey    AJSCTGYMIJHROB-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          891.76;      // K   [origin=predictive method=joback]
Pc          37.135;      // bar [origin=predictive method=joback]
omega       0.5344;      // -   [origin=predictive method=lee-kesler]
Tb          620.83;      // K   [origin=predictive method=joback]
HvapTb      46664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-201.14 1.756 -0.001775 7.56e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 2; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group C_ring; count 2; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3.3.3)-propellane-2,8-dione" );
standardThermochemistry
{
    dHf_298   -288870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-48660.0
}
