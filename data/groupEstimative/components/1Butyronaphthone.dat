/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1'-butyronaphthone  (C14H14O, CAS 2876-62-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butyronaphthone;
formula     C14H14O;
CAS         2876-62-2;
InChIKey    HHEPNSXKXOXNQV-UHFFFAOYSA-N;
MW          198.265;      // g/mol [origin=calculated method=formula-sum]
Tc          853.78;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.6727;      // -   [origin=predictive method=lee-kesler]
Tb          624.43;      // K   [origin=predictive method=joback]
HvapTb      58082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.528 1.16372 -0.00081998 2.2806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 7; } { group AC; count 3; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-naphthalen-1-ylbutan-1-one" "1-butanone,1-(1-naphthalenyl)-" "1'-butyronaphthone(6ci,7ci,8ci); 1-(1-naphthalenyl)-1-butanone; 1-butyrylnaphthalene" );
standardThermochemistry
{
    dHf_298   -28740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147510.0
}
