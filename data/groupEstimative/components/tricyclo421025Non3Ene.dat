/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[4.2.1.02,5]non-3-ene  (C9H12, CAS 16529-76-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo421025Non3Ene;
formula     C9H12;
CAS         16529-76-3;
InChIKey    XSKXEKKIOLQKBQ-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          630.21;      // K   [origin=predictive method=joback]
Pc          35.054;      // bar [origin=predictive method=joback]
omega       0.3116;      // -   [origin=predictive method=lee-kesler]
Tb          420.23;      // K   [origin=predictive method=joback]
HvapTb      35350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.3 1.229 -0.00105828 3.698e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 4; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 4; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[4.2.1.0(2,5)]non-7-ene" "tricyclo(4.2.1.02,5)non-3-ene" "tricyclo[4.2.1.0<2,5>]non-3-ene" "tricyclo[4.2.1.02,5]non-7-ene,exo-" "tricyclo(4.2.1.02,5)non-7-ene, exo-" "tricyclo(4.2.1.02,5)non-3-ene, (1alpha,2beta,5beta,6alpha)-" "tricyclo[4.2.1.02,5]non-3-ene,(1.alpha.,2.beta.,5.beta.,6.alpha.)-" );
standardThermochemistry
{
    dHf_298   26750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     156.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=229400.0
}
