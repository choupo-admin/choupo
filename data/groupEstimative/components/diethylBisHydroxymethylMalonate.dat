/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl bis(hydroxymethyl)malonate  (C9H16O6, CAS 20605-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylBisHydroxymethylMalonate;
formula     C9H16O6;
CAS         20605-01-0;
InChIKey    WIOHBOKEUIHYIC-UHFFFAOYSA-N;
MW          220.221;      // g/mol [origin=calculated method=formula-sum]
Tc          878.29;      // K   [origin=predictive method=joback]
Pc          28.627;      // bar [origin=predictive method=joback]
omega       1.6095;      // -   [origin=predictive method=lee-kesler]
Tb          703.09;      // K   [origin=predictive method=joback]
HvapTb      82504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.634 0.94304 -0.0005092 7.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group OH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group OH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2,2-bis(hydroxymethyl)propanedioate" "diethyl 2,2-bis(hydroxymethyl)malonate" "2,2-bis(hydroxymethyl) malonic acid diethyl ester" "diethyl 2,2-bis(hydroxymethyl)propane-1,3-dioate" "diethyl bis(hydroxymetyl)malonate" "wiohbokeuihyic-uhfffaoysa-" "o511" "bis(hydroxymethyl)malonic acid diethyl ester" "1,3-diethyl 2,2-bis(hydroxymethyl)propanedioate" );
gibbsFormation
{
    dHf_298   -1176860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     672.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-866640.0
    phase     gas;
}
