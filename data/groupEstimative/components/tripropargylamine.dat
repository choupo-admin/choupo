/*--------------------------------*- Choupo -*-----------------------*\
  Component: tripropargylamine  (C9H9N, CAS 6921-29-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tripropargylamine;
formula     C9H9N;
CAS         6921-29-5;
InChIKey    ZHOBJWVNWMQMLF-UHFFFAOYSA-N;
MW          131.178;      // g/mol [origin=calculated method=formula-sum]
Tc          587.53;      // K   [origin=predictive method=joback]
Pc          37.180;      // bar [origin=predictive method=joback]
omega       0.2976;      // -   [origin=predictive method=lee-kesler]
Tb          388.32;      // K   [origin=predictive method=joback]
HvapTb      37245.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.353 0.701 -0.00056619 1.8847e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2N; count 1; } { group CH_C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group tCH; count 3; } { group tC; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(prop-2-ynyl)prop-2-yn-1-amine" "tri-2-propynylamine" "tris(propyn-2-yl)amine" "2-propyn-1-amine, n,n-di-2-propynyl-" "n,n-di-2-propynyl-2-propyn-1-amine" "n,n-diprop-2-yn-1-ylprop-2-yn-1-amine" "tripropargyl amine" "2-propyn-1-amine,n-di-2-propynyl-" "2-propyn-1-amine,n,n-di-2-propyn-1-yl-" "2-propyn-1-amine, n,n-di-2-propynyl- (9ci)" );
gibbsFormation
{
    dHf_298   714140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=804890.0
    phase     gas;
}
