/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-octadecenoic acid (9z)-, ester with 2-ethyl-2-(hydroxymethyl)-1,3-propanediol nonanoate  (C33H62O5, CAS 67762-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9OctadecenoicAcid9zEsterWith2Ethyl2Hydroxymethyl13Propanedio;
formula     C33H62O5;
CAS         67762-68-9;
InChIKey    SGHUDFAPFZDGMX-UHFFFAOYSA-N;
MW          538.854;      // g/mol [origin=calculated method=formula-sum]
Tc          1528.74;      // K   [origin=predictive method=joback]
Pc          5.634;      // bar [origin=predictive method=joback]
omega       0.0134;      // -   [origin=predictive method=lee-kesler]
Tb          1164.19;      // K   [origin=predictive method=joback]
HvapTb      119207.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.655 3.20906 -0.0018682 3.964e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 23; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 25; } { group C; count 1; } { group dCH; count 2; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(hydroxymethyl)-2-(nonanoyloxymethyl)butyl] octadec-9-enoate" );
standardThermochemistry
{
    dHf_298   -1402770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1549.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-447520.0
}
