/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-2-(hydroxymethyl)-1,3-propanediyl diacrylate  (C12H18O5, CAS 37275-47-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl2Hydroxymethyl13PropanediylDiacrylate;
formula     C12H18O5;
CAS         37275-47-1;
InChIKey    TUOBEAZXHLTYLF-UHFFFAOYSA-N;
MW          242.271;      // g/mol [origin=calculated method=formula-sum]
Tc          853.10;      // K   [origin=predictive method=joback]
Pc          21.335;      // bar [origin=predictive method=joback]
omega       1.1924;      // -   [origin=predictive method=lee-kesler]
Tb          672.91;      // K   [origin=predictive method=joback]
HvapTb      71163.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.634 1.15402 -0.0006878 1.339e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group CH2=CH; count 2; } { group OH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(hydroxymethyl)-2-(prop-2-enoyloxymethyl)butyl] prop-2-enoate" "2-[(acryloyloxy)methyl]-2-(hydroxymethyl)butyl acrylate" "2-propenoic acid, 2-ethyl-2-(hydroxymethyl)-1,3-propanediyl ester" "2-propenoic acid, 1,1'-(2-ethyl-2-(hydroxymethyl)-1,3-propanediyl) ester" "2-propenoic acid, 1,1'-[2-ethyl-2-(hydroxymethyl)-1,3-propanediyl] ester" "2-propenoic acid,1,1'-[2-ethyl-2-(hydroxymethyl)-1,3-propanediyl] ester" "2-propenoicacid, 2-ethyl-2-(hydroxymethyl)-1,3-propanediyl ester (9ci); trimethylolpropanediacrylate" );
gibbsFormation
{
    dHf_298   -835690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     728.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-528880.0
    phase     gas;
}
