/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-azabicyclo[3.2.1]oct-2-ene  (C7H11N, CAS 5632-85-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Azabicyclo321Oct2Ene;
formula     C7H11N;
CAS         5632-85-9;
InChIKey    SURHOQQBDZIWSO-UHFFFAOYSA-N;
MW          109.172;      // g/mol [origin=calculated method=formula-sum]
Tc          652.87;      // K   [origin=predictive method=joback]
Pc          43.340;      // bar [origin=predictive method=joback]
omega       0.3321;      // -   [origin=predictive method=lee-kesler]
Tb          429.49;      // K   [origin=predictive method=joback]
HvapTb      38396.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.5 0.882 -0.00063128 1.822e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH=CH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-azabicyclo[3.2.1]oct-3-ene" "8-azabicyclo(3.2.1)oct-2-ene" "agn-pc-03g7tp" "8-aza-bicyclo[3.2.1]oct-2-ene" "nortropane,2,3-didehydro- (8ci); 2-nortropene; nortropidine" );
gibbsFormation
{
    dHf_298   41060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     244.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=223030.0
    phase     gas;
}
