/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecane, trimethyl-  (C15H32, CAS 61869-04-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecaneTrimethyl;
formula     C15H32;
CAS         61869-04-3;
InChIKey    NVEUWWMNWPNXOC-UHFFFAOYSA-N;
MW          212.421;      // g/mol [origin=calculated method=formula-sum]
Tc          706.50;      // K   [origin=predictive method=joback]
Pc          14.359;      // bar [origin=predictive method=joback]
omega       0.6217;      // -   [origin=predictive method=lee-kesler]
Tb          539.57;      // K   [origin=predictive method=joback]
HvapTb      47688.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.22 1.55468 -0.000964 2.392e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 10; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyltridecane" "agn-pc-01zmey" );
gibbsFormation
{
    dHf_298   -361680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     701.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78260.0
    phase     gas;
}
