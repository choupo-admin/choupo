/*--------------------------------*- Choupo -*-----------------------*\
  Component: methoxinine  (C5H11NO3, CAS 4385-91-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methoxinine;
formula     C5H11NO3;
CAS         4385-91-5;
InChIKey    KFHRMMHGGBCRIV-UHFFFAOYSA-N;
MW          133.147;      // g/mol [origin=calculated method=formula-sum]
Tc          758.55;      // K   [origin=predictive method=joback]
Pc          41.039;      // bar [origin=predictive method=joback]
omega       0.8880;      // -   [origin=predictive method=lee-kesler]
Tb          554.02;      // K   [origin=predictive method=joback]
HvapTb      56551.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.252 0.53422 -0.0002564 3.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3O; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group O; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-4-methoxy-butanoic acid" "homoserine, o-methyl-" "methoxine" "o-methylhomoserine" "2-amino-4-methoxybutanoic acid" "oxymethionine" "2-amino-4-methoxybutyric acid" "2-amino-4-methoxy-butyric acid" "butyric acid, 2-amino-4-methoxy-" "dl-2-amino-4-methoxybutanoic acid" "7757-91-7 (calcium[2:1] salt)" "butyric acid, 2-amino-4-methoxy-, dl-" );
standardThermochemistry
{
    dHf_298   -600510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-393680.0
}
