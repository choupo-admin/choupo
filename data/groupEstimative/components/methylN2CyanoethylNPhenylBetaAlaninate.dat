/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl n-(2-cyanoethyl)-n-phenyl-beta-alaninate  (C13H16N2O2, CAS 67892-95-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylN2CyanoethylNPhenylBetaAlaninate;
formula     C13H16N2O2;
CAS         67892-95-9;
InChIKey    CWCYJRVQCBCDTJ-UHFFFAOYSA-N;
MW          232.283;      // g/mol [origin=calculated method=formula-sum]
Tc          907.89;      // K   [origin=predictive method=joback]
Pc          21.493;      // bar [origin=predictive method=joback]
omega       0.9174;      // -   [origin=predictive method=lee-kesler]
Tb          696.46;      // K   [origin=predictive method=joback]
HvapTb      66736.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.116 1.16382 -0.0007016 1.43e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-[2-cyanoethyl(phenyl)amino]propanoate" "methyl n-(2-cyanoethyl)-n-phenyl-" "a-alaninate" "3-((2-(carbomethoxy)ethyl)phenylamino)propanenitrile" "methyl 3-[n-(2-cyanoethyl)anilino]propanoate" "beta-alanine, n-(2-cyanoethyl)-n-phenyl-, methyl ester" ".beta.-alanine, n-(2-cyanoethyl)-n-phenyl-, methyl ester" );
gibbsFormation
{
    dHf_298   -159990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     629.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104580.0
    phase     gas;
}
