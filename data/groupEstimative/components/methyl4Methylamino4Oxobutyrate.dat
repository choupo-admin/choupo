/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-(methylamino)-4-oxobutyrate  (C6H11NO3, CAS 68758-86-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4Methylamino4Oxobutyrate;
formula     C6H11NO3;
CAS         68758-86-1;
InChIKey    DLCZEMNBMNTMGI-UHFFFAOYSA-N;
MW          145.158;      // g/mol [origin=calculated method=formula-sum]
Tc          687.27;      // K   [origin=predictive method=joback]
Pc          34.079;      // bar [origin=predictive method=joback]
omega       0.7519;      // -   [origin=predictive method=lee-kesler]
Tb          499.14;      // K   [origin=predictive method=joback]
HvapTb      49539.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.992 0.56724 -0.0002379 4.56e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2COO; count 1; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CdO; count 1; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-(methylamino)-4-oxidanylidene-butanoate" "methyl n-methyl succinamate" "butanoic acid, 4-(methylamino)-4-oxo-, methyl ester" "methyl 4-(methylamino)-4-oxobutanoate" "n-methyl-3-(methoxycarbonyl)propionamide" );
standardThermochemistry
{
    dHf_298   -543560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-350260.0
}
