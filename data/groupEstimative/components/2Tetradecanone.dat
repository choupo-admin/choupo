/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tetradecanone  (C14H28O, CAS 2345-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Tetradecanone;
formula     C14H28O;
CAS         2345-27-9;
InChIKey    POQLVOYRGNFGRM-UHFFFAOYSA-N;
MW          212.377;      // g/mol [origin=calculated method=formula-sum]
Tc          741.93;      // K   [origin=predictive method=joback]
Pc          16.013;      // bar [origin=predictive method=joback]
omega       0.7933;      // -   [origin=predictive method=lee-kesler]
Tb          573.79;      // K   [origin=predictive method=joback]
HvapTb      53504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.479 1.30584 -0.0007191 1.4636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecan-2-one" "tetradecanone" "dodecyl methyl ketone" );
gibbsFormation
{
    dHf_298   -444870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     728.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-61920.0
    phase     gas;
}
