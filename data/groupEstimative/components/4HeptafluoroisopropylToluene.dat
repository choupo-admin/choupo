/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(heptafluoroisopropyl)toluene  (C10H7F7, CAS 2396-26-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HeptafluoroisopropylToluene;
formula     C10H7F7;
CAS         2396-26-1;
InChIKey    XEFRSBQTXVJYKZ-UHFFFAOYSA-N;
MW          260.152;      // g/mol [origin=calculated method=formula-sum]
Tc          617.39;      // K   [origin=predictive method=joback]
Pc          22.250;      // bar [origin=predictive method=joback]
omega       0.4952;      // -   [origin=predictive method=lee-kesler]
Tb          445.26;      // K   [origin=predictive method=joback]
HvapTb      31185.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.59 1.27542 -0.00111456 3.633e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CF3; count 2; } { group CF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[1,1,1,2,3,3,3-heptakis(fluoranyl)propan-2-yl]-4-methyl-benzene" "1-(1,1,1,2,3,3,3-heptafluoropropan-2-yl)-4-methylbenzene" "p-(heptafluoroisopropyl)toluene" "1-(heptafluoropropan-2-yl)-4-methylbenzene" "4-methyl-1-[1,2,2,2-tetrafluoro-1-(trifluoromethyl)ethyl]benzene" );
gibbsFormation
{
    dHf_298   -1423690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1219050.0
    phase     gas;
}
