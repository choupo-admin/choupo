/*--------------------------------*- Choupo -*-----------------------*\
  Component: sulfide, isobutyl isopropyl  (C7H16S, CAS 10359-65-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sulfideIsobutylIsopropyl;
formula     C7H16S;
CAS         10359-65-6;
InChIKey    NAPBMSIZYSDRMH-UHFFFAOYSA-N;
MW          132.265;      // g/mol [origin=calculated method=formula-sum]
Tc          623.96;      // K   [origin=predictive method=joback]
Pc          28.999;      // bar [origin=predictive method=joback]
omega       0.3560;      // -   [origin=predictive method=lee-kesler]
Tb          427.66;      // K   [origin=predictive method=joback]
HvapTb      37217.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.761 0.67507 -0.0003232 4.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-1-propan-2-ylsulfanyl-propane" "2-methyl-1-(propan-2-ylsulfanyl)propane" "propane, 2-methyl-1-[(1-methylethyl)thio]-" "2-methyl-1-propan-2-ylsulfanylpropane" "propane,2-methyl-1-[(1-methylethyl)thio]-" );
gibbsFormation
{
    dHf_298   -156500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36300.0
    phase     gas;
}
