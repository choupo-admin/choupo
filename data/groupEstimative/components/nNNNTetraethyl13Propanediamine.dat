/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,n',n'-tetraethyl-1,3-propanediamine  (C11H26N2, CAS 60558-96-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNNNTetraethyl13Propanediamine;
formula     C11H26N2;
CAS         60558-96-5;
InChIKey    RCZLVPFECJNLMZ-UHFFFAOYSA-N;
MW          186.343;      // g/mol [origin=calculated method=formula-sum]
Tc          635.55;      // K   [origin=predictive method=joback]
Pc          19.270;      // bar [origin=predictive method=joback]
omega       0.6612;      // -   [origin=predictive method=lee-kesler]
Tb          476.16;      // K   [origin=predictive method=joback]
HvapTb      44166.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.493 1.29668 -0.0007998 1.945e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,n',n'-tetraethylpropane-1,3-diamine" "n,n,n',n'-tetraethyl trimethylene diamine" "n,n,n',n'-tetraethyl-1,3-propanediamine;" "the 1,3-propanediamine,n1,n1,n3,n3-tetraethyl-," "n,n,n inverted exclamation marka,n inverted exclamation marka-tetraethyl-1,3-propanediamine" );
gibbsFormation
{
    dHf_298   -135310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     616.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=263300.0
    phase     gas;
}
