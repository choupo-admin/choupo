/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethyl-cyclohexanemethanol  (C9H18O, CAS 70289-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DimethylCyclohexanemethanol;
formula     C9H18O;
CAS         70289-32-6;
InChIKey    PYXCSABYHVRYEK-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          695.81;      // K   [origin=predictive method=joback]
Pc          29.187;      // bar [origin=predictive method=joback]
omega       0.7074;      // -   [origin=predictive method=lee-kesler]
Tb          507.91;      // K   [origin=predictive method=joback]
HvapTb      52118.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.729 0.96194 -0.0004664 5.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,6-dimethylcyclohexyl)methanol" "cyclohexanemethanol, 2,6-dimethyl-," "2,6-dimethylcyclohexylmethanol" );
standardThermochemistry
{
    dHf_298   -367680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-102890.0
}
