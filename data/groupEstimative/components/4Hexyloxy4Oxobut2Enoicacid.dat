/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(hexyloxy)-4-oxobut-2-enoicacid  (C10H16O4, CAS 68512-10-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hexyloxy4Oxobut2Enoicacid;
formula     C10H16O4;
CAS         68512-10-7;
InChIKey    RNERBJNDXXEXTK-VOTSOKGWSA-N;
MW          200.234;      // g/mol [origin=calculated method=formula-sum]
Tc          828.49;      // K   [origin=predictive method=joback]
Pc          24.219;      // bar [origin=predictive method=joback]
omega       1.0059;      // -   [origin=predictive method=lee-kesler]
Tb          636.29;      // K   [origin=predictive method=joback]
HvapTb      62383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.625 0.96982 -0.000582 1.261e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=CH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-4-hexoxy-4-oxidanylidene-but-2-enoic acid" "(c6-c8)alcohol, fumaric acid ester" "2-butenedioic acid (2e)-, c6-8-alkyl esters" "(e)-4-hexoxy-4-oxobut-2-enoic acid" );
standardThermochemistry
{
    dHf_298   -800060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     643.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-540740.0
}
