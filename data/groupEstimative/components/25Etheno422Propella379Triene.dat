/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-etheno[4.2.2]propella-3,7,9-triene  (C12H10, CAS 88090-38-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Etheno422Propella379Triene;
formula     C12H10;
CAS         88090-38-4;
InChIKey    RDIUVVQMLJOTAO-UHFFFAOYSA-N;
MW          154.212;      // g/mol [origin=calculated method=formula-sum]
Tc          744.45;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.3589;      // -   [origin=predictive method=lee-kesler]
Tb          498.24;      // K   [origin=predictive method=joback]
HvapTb      40824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-277.85 2.1072 -0.00252412 1.1416e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group C; count 2; } { group CH=CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-etheno(4.2.2)propella-3,7,9-triene" );
standardThermochemistry
{
    dHf_298   261790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     251.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=402020.0
}
