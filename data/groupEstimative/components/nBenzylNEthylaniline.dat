/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzyl-n-ethylaniline  (C15H17N, CAS 92-59-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzylNEthylaniline;
formula     C15H17N;
CAS         92-59-1;
InChIKey    HSZCJVZRHXPCIA-UHFFFAOYSA-N;
MW          211.308;      // g/mol [origin=calculated method=formula-sum]
Tc          839.52;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.5847;      // -   [origin=predictive method=lee-kesler]
Tb          608.60;      // K   [origin=predictive method=joback]
HvapTb      55579.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.248 1.39492 -0.0009672 2.557e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-n-(phenylmethyl)aniline" "n-ethyl-n-phenylbenzylamine" "benzenemethanamine, n-ethyl-n-phenyl-" "n-ethyl-n-phenyl benzylamine" "ethylbenzylaniline" "benzylamine, n-ethyl-n-phenyl-" "benzylethylphenylamine" "phenylethylbenzylamine" "n-ethyl-n-benzylaniline" "amine, benzyl ethyl phenyl" "n-ethyl-n-phenylbenzenemethanamine" "n,n-benzylethylaniline" );
standardThermochemistry
{
    dHf_298   187660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     543.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=411020.0
}
