/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclobutabenzene  (C12H12, CAS 60323-52-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclobutabenzene;
formula     C12H12;
CAS         60323-52-6;
InChIKey    MTPUNWSZJLTTLU-UHFFFAOYSA-N;
MW          156.228;      // g/mol [origin=calculated method=formula-sum]
Tc          777.84;      // K   [origin=predictive method=joback]
Pc          34.602;      // bar [origin=predictive method=joback]
omega       0.5604;      // -   [origin=predictive method=lee-kesler]
Tb          547.16;      // K   [origin=predictive method=joback]
HvapTb      48042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.61 1.3284 -0.001291 5.048e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACCH2; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclobutenobenzene" "tetracyclo[8.2.0.02,5.06,9]dodeca-1,5,9-triene" );
standardThermochemistry
{
    dHf_298   186070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     282.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=356100.0
}
