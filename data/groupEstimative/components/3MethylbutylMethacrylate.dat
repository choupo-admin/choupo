/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylbutyl methacrylate  (C9H16O2, CAS 7336-27-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethylbutylMethacrylate;
formula     C9H16O2;
CAS         7336-27-8;
InChIKey    ULYIFEQRRINMJQ-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          640.79;      // K   [origin=predictive method=joback]
Pc          24.459;      // bar [origin=predictive method=joback]
omega       0.5131;      // -   [origin=predictive method=lee-kesler]
Tb          459.86;      // K   [origin=predictive method=joback]
HvapTb      42057.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.752 0.78986 -0.0003996 5.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 3-methylbutyl ester" "isopentyl methacrylate" );
gibbsFormation
{
    dHf_298   -436010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-208620.0
    phase     gas;
}
