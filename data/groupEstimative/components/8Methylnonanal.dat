/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-methylnonanal  (C10H20O, CAS 1321-89-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Methylnonanal;
formula     C10H20O;
CAS         1321-89-7;
InChIKey    WDMOXLRWVGEXJV-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          648.76;      // K   [origin=predictive method=joback]
Pc          22.762;      // bar [origin=predictive method=joback]
omega       0.6199;      // -   [origin=predictive method=lee-kesler]
Tb          476.62;      // K   [origin=predictive method=joback]
HvapTb      44186.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.516 0.93424 -0.0005164 1.052e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "isodecanal" "nonanal, 8-methyl-" "isodecylaldehyde" "isodecaldehyde" "isoaldehyde c-10" );
gibbsFormation
{
    dHf_298   -340590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68640.0
    phase     gas;
}
