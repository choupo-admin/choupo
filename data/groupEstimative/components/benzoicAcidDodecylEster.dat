/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, dodecyl ester  (C19H30O2, CAS 2915-72-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcidDodecylEster;
formula     C19H30O2;
CAS         2915-72-2;
InChIKey    DLAHAXOYRFRPFQ-UHFFFAOYSA-N;
MW          290.447;      // g/mol [origin=calculated method=formula-sum]
Tc          907.96;      // K   [origin=predictive method=joback]
Pc          13.657;      // bar [origin=predictive method=joback]
omega       0.8993;      // -   [origin=predictive method=lee-kesler]
Tb          719.22;      // K   [origin=predictive method=joback]
HvapTb      67571.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.879 1.67512 -0.0009464 1.833e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecyl benzoate" "lauryl benzoate" "alkyl (c12-15) benzoate" "benzoic acid, c12-15-alkyl esters" "benzoic acid dodecylester" "c12-15 alkyl benzoate" "benzoic acid dodecyl ester" "benzoic acid, dodecylester" "benzoic acid c12-15-alkyl esters" "benzoic acid, c12-15 alkyl esters" "alkyl (c12-15) benzoate [usan]" "dodecylalcohol, benzoate;dodecyl benzoate;lauryl benzoate;n-dodecyl benzoate;" );
gibbsFormation
{
    dHf_298   -516240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     840.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-88860.0
    phase     gas;
}
