/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexadecanoic acid, 2-methoxyethyl ester  (C19H38O3, CAS 111-07-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexadecanoicAcid2MethoxyethylEster;
formula     C19H38O3;
CAS         111-07-9;
InChIKey    XSZLSYXBQSOQJE-UHFFFAOYSA-N;
MW          314.51;      // g/mol [origin=calculated method=formula-sum]
Tc          883.50;      // K   [origin=predictive method=joback]
Pc          10.722;      // bar [origin=predictive method=joback]
omega       0.9251;      // -   [origin=predictive method=lee-kesler]
Tb          714.96;      // K   [origin=predictive method=joback]
HvapTb      67705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.526 1.69084 -0.0008042 1.03e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH2COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxyethyl hexadecanoate" "2-methoxyethyl palmitate" "hexadecanoic acid,2-methoxyethyl ester" "hexadecanoic acid 2-methoxyethyl ester" "palmiticacid, 2-methoxyethyl ester (8ci); ethanol, 2-methoxy-, palmitate (8ci);2-methoxyethyl palmitate; methyl cellosolve palmitate" );
standardThermochemistry
{
    dHf_298   -884990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     958.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-306270.0
}
