/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butyl-n,n-bis(2-hydroxyethyl)benzamide  (C15H23NO3, CAS 68368-33-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylNNBis2HydroxyethylBenzamide;
formula     C15H23NO3;
CAS         68368-33-2;
InChIKey    MOXXEYNPPNSCTN-UHFFFAOYSA-N;
MW          265.353;      // g/mol [origin=calculated method=formula-sum]
Tc          1017.10;      // K   [origin=predictive method=joback]
Pc          23.158;      // bar [origin=predictive method=joback]
omega       1.5682;      // -   [origin=predictive method=lee-kesler]
Tb          821.90;      // K   [origin=predictive method=joback]
HvapTb      92773.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.576 1.58016 -0.00108286 2.8776e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzamide, 4-(1,1-dimethylethyl)-n,n-bis(2-hydroxyethyl)-" "p-t-butylbenzoic acid diethanolamide" "4-(1,1-dimethylethyl)-n,n-bis(2-hydroxyethyl)benzamide" );
gibbsFormation
{
    dHf_298   -486130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     733.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-110740.0
    phase     gas;
}
