/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4-trimethylhexane-1,6-diol  (C9H20O2, CAS 3089-24-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224Trimethylhexane16Diol;
formula     C9H20O2;
CAS         3089-24-5;
InChIKey    GZZLQUBMUXEOBE-UHFFFAOYSA-N;
MW          160.257;      // g/mol [origin=calculated method=formula-sum]
Tc          752.09;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       1.2701;      // -   [origin=predictive method=lee-kesler]
Tb          586.21;      // K   [origin=predictive method=joback]
HvapTb      67302.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.866 1.05856 -0.0007016 1.869e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6-hexanediol, 2,2,4-trimethyl-" );
gibbsFormation
{
    dHf_298   -547580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-248340.0
    phase     gas;
}
