/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloranyl-2,3-dimethyl-but-2-ene  (C6H11Cl, CAS 37866-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloranyl23DimethylBut2Ene;
formula     C6H11Cl;
CAS         37866-06-1;
InChIKey    DPUWHUZIEIQTQQ-UHFFFAOYSA-N;
MW          118.604;      // g/mol [origin=calculated method=formula-sum]
Tc          567.29;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.2778;      // -   [origin=predictive method=lee-kesler]
Tb          378.23;      // K   [origin=predictive method=joback]
HvapTb      33453.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.239 0.60046 -0.0004114 1.202e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2Cl; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dC; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -85270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50830.0
}
