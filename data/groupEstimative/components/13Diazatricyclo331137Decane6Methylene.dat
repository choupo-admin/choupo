/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diazatricyclo[3.3.1.13,7]decane,6-methylene-  (C9H14N2, CAS 51500-09-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diazatricyclo331137Decane6Methylene;
formula     C9H14N2;
CAS         51500-09-5;
InChIKey    UWOWAGDGTZPQRH-UHFFFAOYSA-N;
MW          150.225;      // g/mol [origin=calculated method=formula-sum]
Tc          647.54;      // K   [origin=predictive method=joback]
Pc          35.899;      // bar [origin=predictive method=joback]
omega       0.5126;      // -   [origin=predictive method=lee-kesler]
Tb          450.18;      // K   [origin=predictive method=joback]
HvapTb      39749.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-155.93 1.4779 -0.001361 4.976e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group CH2=C; count 1; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group dC_ring; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diazatricyclo(3.3.1.13,7)decane, 6-methylene-" );
standardThermochemistry
{
    dHf_298   235110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     264.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=501600.0
}
