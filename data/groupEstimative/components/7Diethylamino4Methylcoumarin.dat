/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-diethylamino-4-methylcoumarin  (C14H17NO2, CAS 91-44-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Diethylamino4Methylcoumarin;
formula     C14H17NO2;
CAS         91-44-1;
InChIKey    AFYCEAFSNDLKSX-UHFFFAOYSA-N;
MW          231.295;      // g/mol [origin=calculated method=formula-sum]
Tc          845.02;      // K   [origin=predictive method=joback]
Pc          22.697;      // bar [origin=predictive method=joback]
omega       0.8229;      // -   [origin=predictive method=lee-kesler]
Tb          638.50;      // K   [origin=predictive method=joback]
HvapTb      60812.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.408 1.27656 -0.00089516 2.481e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(diethylamino)-4-methyl-chromen-2-one" "coumarin 1" "4-methyl-7-diethylaminocoumarin" "coumarin 47" "coumarin, 7-(diethylamino)-4-methyl-" "7-(diethylamino)-4-methyl-2h-chromen-2-one" "blancophor aw" "blancophor ffg" "4-methyl-7-(diethylamino)coumarin" "hakkol p" "uvitex wgs" "calcofluor white rw" );
standardThermochemistry
{
    dHf_298   -222840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61450.0
}
