/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 4-(2-carboxyethenyl)-, methyl ester  (C11H10O4, CAS 19473-96-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid42CarboxyethenylMethylEster;
formula     C11H10O4;
CAS         19473-96-2;
InChIKey    PVHMYONDAPXJSB-UHFFFAOYSA-N;
MW          206.197;      // g/mol [origin=calculated method=formula-sum]
Tc          918.30;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.9622;      // -   [origin=predictive method=lee-kesler]
Tb          690.83;      // K   [origin=predictive method=joback]
HvapTb      67547.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.89 0.92642 -0.00060056 1.386e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-methoxycarbonylphenyl)prop-2-enoic acid" "benzoic acid, 4-(2-carboxyethenyl)-, 1-methyl ester" "1-methyl 4-(2-carboxyvinyl)benzoate" "4-(2-carboxy-vinyl)benzoic acid methyl ester" "(z)-3-[4-(methoxycarbonyl)phenyl]-2-propenoic acid" );
standardThermochemistry
{
    dHf_298   -595640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-429540.0
}
