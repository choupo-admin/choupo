/*--------------------------------*- Choupo -*-----------------------*\
  Component: but-3-en-1-ol;propanoic acid  (C7H14O3, CAS 27819-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        but3En1OlPropanoicAcid;
formula     C7H14O3;
CAS         27819-06-3;
InChIKey    GLOSZEARSVYHEX-UHFFFAOYSA-N;
MW          146.186;      // g/mol [origin=calculated method=formula-sum]
Tc          781.63;      // K   [origin=predictive method=joback]
Pc          32.467;      // bar [origin=predictive method=joback]
omega       1.1176;      // -   [origin=predictive method=lee-kesler]
Tb          595.53;      // K   [origin=predictive method=joback]
HvapTb      64643.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.243 0.52742 -6.81e-05 -8.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -676500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-489590.0
}
