/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl benzoate  (C10H10O2, CAS 583-04-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylBenzoate;
formula     C10H10O2;
CAS         583-04-0;
InChIKey    LYJHVEDILOKZCG-UHFFFAOYSA-N;
MW          162.188;      // g/mol [origin=calculated method=formula-sum]
Tc          724.50;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.5134;      // -   [origin=predictive method=lee-kesler]
Tb          509.98;      // K   [origin=predictive method=joback]
HvapTb      46867.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.689 0.8001 -0.0004797 9.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl benzoate" "benzoic acid, 2-propenyl ester" "benzoic acid, allyl ester" "2-propenyl benzoate" "benzoic acid allyl ester" "prop-2-en-1-yl benzoate" "benzoic acid, allyl ester (8ci)" );
gibbsFormation
{
    dHf_298   -205050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76800.0
    phase     gas;
}
