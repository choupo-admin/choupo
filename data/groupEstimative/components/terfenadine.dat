/*--------------------------------*- Choupo -*-----------------------*\
  Component: terfenadine  (C32H41NO2, CAS 50679-08-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        terfenadine;
formula     C32H41NO2;
CAS         50679-08-8;
InChIKey    GUGOEEXESWIERI-UHFFFAOYSA-N;
MW          471.685;      // g/mol [origin=calculated method=formula-sum]
Tc          1498.35;      // K   [origin=predictive method=joback]
Pc          11.858;      // bar [origin=predictive method=joback]
omega       1.1041;      // -   [origin=predictive method=lee-kesler]
Tb          1221.96;      // K   [origin=predictive method=joback]
HvapTb      126994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-224.837 3.32876 -0.00239116 6.61e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group C; count 2; } { group ACH; count 14; } { group AC; count 3; } { group ACCH; count 1; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-tert-butylphenyl)-4-[4-[oxidanyl(diphenyl)methyl]piperidin-1-yl]butan-1-ol" "seldane" "triludan" "teldane" "ternadin" "allerplus" "teldanex" "aldaban" "terdin" "terfenadina" "terfenadinum" "terfenidine" );
gibbsFormation
{
    dHf_298   -204920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1057.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=423090.0
    phase     gas;
}
