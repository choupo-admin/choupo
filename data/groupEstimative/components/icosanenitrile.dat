/*--------------------------------*- Choupo -*-----------------------*\
  Component: icosanenitrile  (C20H39N, CAS 4616-73-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        icosanenitrile;
formula     C20H39N;
CAS         4616-73-3;
InChIKey    BYCIKRXQXRFYED-UHFFFAOYSA-N;
MW          293.539;      // g/mol [origin=calculated method=formula-sum]
Tc          936.66;      // K   [origin=predictive method=joback]
Pc          9.995;      // bar [origin=predictive method=joback]
omega       0.8830;      // -   [origin=predictive method=lee-kesler]
Tb          759.28;      // K   [origin=predictive method=joback]
HvapTb      70592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.708 1.83862 -0.0010332 2.205e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "eicosanenitrile" "eicosanonitrile" );
standardThermochemistry
{
    dHf_298   -291250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     941.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=250700.0
}
