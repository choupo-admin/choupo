/*--------------------------------*- Choupo -*-----------------------*\
  Component: diglyme  (C6H14O3, CAS 111-96-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diglyme;
formula     C6H14O3;
CAS         111-96-6;
InChIKey    SBZXBUIDTXKZTM-UHFFFAOYSA-N;
MW          134.175;      // g/mol [origin=calculated method=formula-sum]
Tc          569.99;      // K   [origin=predictive method=joback]
Pc          29.377;      // bar [origin=predictive method=joback]
omega       0.5309;      // -   [origin=predictive method=lee-kesler]
Tb          404.14;      // K   [origin=predictive method=joback]
HvapTb      36180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.934 0.38424 3.04e-05 -1.042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH3O; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2-(2-methoxyethoxy)ethane" "bis(2-methoxyethyl) ether" "2-methoxyethyl ether" "diethylene glycol dimethyl ether" "di(2-methoxyethyl) ether" "dimethyldiglycol" "ether, bis(2-methoxyethyl)" "dimethyl carbitol" "poly-solv" "2,5,8-trioxanonane" "methyldiglyme" "(2-methoxyethyl) ether" );
standardThermochemistry
{
    dHf_298   -563830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-315360.0
}
