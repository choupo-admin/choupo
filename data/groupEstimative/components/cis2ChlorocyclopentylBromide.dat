/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-2-chlorocyclopentyl bromide  (C5H8BrCl, CAS 14376-82-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis2ChlorocyclopentylBromide;
formula     C5H8BrCl;
CAS         14376-82-0;
InChIKey    KMVDKCXPHPPHOI-UHFFFAOYSA-N;
MW          183.473;      // g/mol [origin=calculated method=formula-sum]
Tc          655.39;      // K   [origin=predictive method=joback]
Pc          43.340;      // bar [origin=predictive method=joback]
omega       0.3054;      // -   [origin=predictive method=lee-kesler]
Tb          428.20;      // K   [origin=predictive method=joback]
HvapTb      37492.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.12 0.629 -0.000412 1.027e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CHCl; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 2; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-chloranyl-cyclopentane" "1-bromo-2-chlorocyclopentane" "cyclopentane, 1-bromo-2-chloro-, cis-" "cyclopentane, 1-bromo-2-chloro-, trans-" "trans-2-chlorocyclopentyl bromide" "agn-pc-02zqr0" );
standardThermochemistry
{
    dHf_298   -95800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22450.0
}
