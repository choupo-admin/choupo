/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-diazabicyclo[6.3.3]tetradecane  (C12H24N2, CAS 82407-82-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Diazabicyclo633Tetradecane;
formula     C12H24N2;
CAS         82407-82-7;
InChIKey    BJIBQBADAXPVNF-UHFFFAOYSA-N;
MW          196.338;      // g/mol [origin=calculated method=formula-sum]
Tc          772.44;      // K   [origin=predictive method=joback]
Pc          27.759;      // bar [origin=predictive method=joback]
omega       0.5030;      // -   [origin=predictive method=lee-kesler]
Tb          547.48;      // K   [origin=predictive method=joback]
HvapTb      47868.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-172.49 1.6888 -0.001127 2.82e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 12; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,8-diazabicyclo(6.3.3)tetradecane" );
standardThermochemistry
{
    dHf_298   -6630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     679.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=336040.0
}
