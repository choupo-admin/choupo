/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-diethoxybut-1-ene  (C8H16O2, CAS 10602-36-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Diethoxybut1Ene;
formula     C8H16O2;
CAS         10602-36-5;
InChIKey    PRCYIYOCMALJCX-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          594.93;      // K   [origin=predictive method=joback]
Pc          25.767;      // bar [origin=predictive method=joback]
omega       0.4953;      // -   [origin=predictive method=lee-kesler]
Tb          423.72;      // K   [origin=predictive method=joback]
HvapTb      37164.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.943 0.62334 -0.0002155 -8.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-butenal diethyl acetal" "3-butenal diethylacetal" "4,4-diethoxy-1-butene" "1-butene, 4,4-diethoxy-" );
gibbsFormation
{
    dHf_298   -352740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-108120.0
    phase     gas;
}
