/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cinnamylpiperazine  (C13H18N2, CAS 18903-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cinnamylpiperazine;
formula     C13H18N2;
CAS         18903-01-0;
InChIKey    WGEIOMTZIIOUMA-UHFFFAOYSA-N;
MW          202.301;      // g/mol [origin=calculated method=formula-sum]
Tc          846.66;      // K   [origin=predictive method=joback]
Pc          29.313;      // bar [origin=predictive method=joback]
omega       0.6125;      // -   [origin=predictive method=lee-kesler]
Tb          608.82;      // K   [origin=predictive method=joback]
HvapTb      56133.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.209 1.4486 -0.0010332 2.886e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-phenylprop-2-enyl)piperazine" "1-(3-phenylallyl)piperazine" "piperazine,1-(3-phenyl-2-propen-1-yl)-" "piperazine, 1-[(2e)-3-phenyl-2-propen-1-yl]-" "piperazine, 1-(3-phenyl-2-propenyl)-, (e)-;piperazine, 1-[(2e)-3-phenyl-2-propenyl]- (9ci);(e)-n-cinnamylpiperazine;1-[(2e)-3-phenylprop-2-enyl]piperazine;1-[(e)-3-phenylprop-2-enyl]piperazine;1-trans-1-cinnamylpiperazine;n-((e)-cinnamyl)piperazine;r 520;r 520 (pharmaceutical);trans-1-cinnamylpiperazine;" "piperazine,1-(3-phenyl-2-propenyl)- (9ci);piperazine, 1-cinnamyl- (6ci,8ci);1-(3-phenyl-2-propenyl)piperazine;1-(3-phenylallyl)piperazine;1-cinnamylpiperazine;4-(3-phenylallyl)piperazine;4-cinnamylpiperazine;n-(3-phenyl-2-propenyl)piperazine;n-cinnamylpiperazine;" );
standardThermochemistry
{
    dHf_298   228260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=493960.0
}
