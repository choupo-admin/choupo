/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylvaleramide  (C6H13NO, CAS 6225-10-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylvaleramide;
formula     C6H13NO;
CAS         6225-10-1;
InChIKey    XKEKKGKDCHCOSA-UHFFFAOYSA-N;
MW          115.176;      // g/mol [origin=calculated method=formula-sum]
Tc          622.91;      // K   [origin=predictive method=joback]
Pc          33.881;      // bar [origin=predictive method=joback]
omega       0.5864;      // -   [origin=predictive method=lee-kesler]
Tb          440.92;      // K   [origin=predictive method=joback]
HvapTb      42132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.583 0.62204 -0.0003325 6.166e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methylpentanamide" "pentanamide, n-methyl" "pentanamide, n-methyl-" "valeramide,n-methyl- (7ci,8ci); n-methyl n-valerylamide; n-methylpentanamide;n-methylvaleramide" );
standardThermochemistry
{
    dHf_298   -226280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-39890.0
}
