/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tert-butyl-4,6-dimethyl-aniline  (C12H19N, CAS 35735-32-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TertButyl46DimethylAniline;
formula     C12H19N;
CAS         35735-32-1;
InChIKey    SJMVAOMOFSHXEH-UHFFFAOYSA-N;
MW          177.291;      // g/mol [origin=calculated method=formula-sum]
Tc          810.01;      // K   [origin=predictive method=joback]
Pc          24.801;      // bar [origin=predictive method=joback]
omega       0.5577;      // -   [origin=predictive method=lee-kesler]
Tb          585.08;      // K   [origin=predictive method=joback]
HvapTb      55913.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.01 1.0742 -0.00067428 1.653e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 2; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group C; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aniline, 2,4-dimethyl-6-tert-butyl-" "2-(tert-butyl)-4,6-dimethylphenylamine" "benzenamine, 2-(1,1-dimethylethyl)-4,6-dimethyl-" );
gibbsFormation
{
    dHf_298   -63850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=202970.0
    phase     gas;
}
