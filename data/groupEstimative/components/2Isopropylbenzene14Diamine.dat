/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropylbenzene-1,4-diamine  (C9H14N2, CAS 97902-52-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropylbenzene14Diamine;
formula     C9H14N2;
CAS         97902-52-8;
InChIKey    WNYJRJRHKRZXEO-UHFFFAOYSA-N;
MW          150.225;      // g/mol [origin=calculated method=formula-sum]
Tc          822.68;      // K   [origin=predictive method=joback]
Pc          36.334;      // bar [origin=predictive method=joback]
omega       0.6644;      // -   [origin=predictive method=lee-kesler]
Tb          586.78;      // K   [origin=predictive method=joback]
HvapTb      60122.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.7 0.79064 -0.00045292 9.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group ACCH; count 1; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-ylbenzene-1,4-diamine" "1,4-benzenediamine, 2-(1-methylethyl)-" "benzenediamine, ar-(1-methylethyl)-" "1,4-benzenediamine,2-(1-methylethyl)-" );
standardThermochemistry
{
    dHf_298   46800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=248510.0
}
