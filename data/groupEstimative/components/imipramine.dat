/*--------------------------------*- Choupo -*-----------------------*\
  Component: imipramine  (C19H24N2, CAS 50-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        imipramine;
formula     C19H24N2;
CAS         50-49-7;
InChIKey    BCGWQEUPMDMJNV-UHFFFAOYSA-N;
MW          280.415;      // g/mol [origin=calculated method=formula-sum]
Tc          950.12;      // K   [origin=predictive method=joback]
Pc          19.304;      // bar [origin=predictive method=joback]
omega       0.8571;      // -   [origin=predictive method=lee-kesler]
Tb          729.66;      // K   [origin=predictive method=joback]
HvapTb      67900.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.037 1.96684 -0.00148532 4.483e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(5,6-dihydrobenzo[b][1]benzazepin-11-yl)-n,n-dimethyl-propan-1-amine" "imidobenzyle" "antideprin" "melipramine" "berkomine" "dimipressin" "melipramin" "tofranil" "dynaprin" "intalpram" "janimine" "nelipramin" );
gibbsFormation
{
    dHf_298   248990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=616780.0
    phase     gas;
}
