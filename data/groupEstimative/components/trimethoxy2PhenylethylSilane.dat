/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethoxy(2-phenylethyl)silane  (C11H18O3Si, CAS 49539-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H18O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethoxy2PhenylethylSilane;
formula     C11H18O3Si;
CAS         49539-88-0;
InChIKey    UBMUZYGBAGFCDF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          226.347;      // g/mol [origin=calculated method=formula-sum]
Tc          750.05;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.5599;      // -   [origin=predictive method=lee-kesler]
Tb          546.62;      // K   [origin=predictive method=joback]
HvapTb      49880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (76.302 0.57416 0.000142 -2.364e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenethyltrimethoxysilane" "trimethoxy(phenethyl)silane" "silane, trimethoxy(2-phenylethyl)-" "benzene, (2-(trimethoxysilyl)ethyl)-" "benzene, [2-(trimethoxysilyl)ethyl]-" "(phenylethyl)trimethoxysilane" );
gibbsFormation
{
    dHf_298   -542120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-265610.0
    phase     gas;
}
