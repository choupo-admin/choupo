/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2,6-dimethylhept-5-enyl)-1,3-dioxolane  (C12H22O2, CAS 66512-92-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        226Dimethylhept5Enyl13Dioxolane;
formula     C12H22O2;
CAS         66512-92-3;
InChIKey    KCHXLUDCEMDEFL-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          746.88;      // K   [origin=predictive method=joback]
Pc          21.775;      // bar [origin=predictive method=joback]
omega       0.5757;      // -   [origin=predictive method=lee-kesler]
Tb          546.94;      // K   [origin=predictive method=joback]
HvapTb      51233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.417 1.29536 -0.0008179 2.024e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group CH=C; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 2-(2,6-dimethyl-5-heptenyl)-" "agn-pc-00izax" "1,3-dioxolane, 2-[(2s)-2,6-dimethyl-5-heptenyl]-" "1,3-dioxolane, 2-[(2s)-2,6-dimethyl-5-hepten-1-yl]-" "2-[(2s)-2,6-dimethylhept-5-en-1-yl]-1,3-dioxolane" );
gibbsFormation
{
    dHf_298   -392380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-16300.0
    phase     gas;
}
