/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-vinyl-1,3-dioxolane  (C5H8O2, CAS 3984-22-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Vinyl13Dioxolane;
formula     C5H8O2;
CAS         3984-22-3;
InChIKey    KKBHSBATGOQADJ-UHFFFAOYSA-N;
MW          100.117;      // g/mol [origin=calculated method=formula-sum]
Tc          583.00;      // K   [origin=predictive method=joback]
Pc          44.802;      // bar [origin=predictive method=joback]
omega       0.3061;      // -   [origin=predictive method=lee-kesler]
Tb          379.86;      // K   [origin=predictive method=joback]
HvapTb      35331.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.49 0.5845 -0.0003707 8.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH2=CH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethenyl-1,3-dioxolane" "1,3-dioxolane, 2-ethenyl-" "acrolein ethylene acetal" "1,3-dioxolane,2-ethenyl-" "1,3-dioxolane, 2-vinyl-" "wt605" "3984-22-3 2-vinyl-1,3-dioxolane" "1,3-dioxolane,2-vinyl- (6ci,7ci,8ci);2-vinyl-1,3-dioxolane;acrolein ethylene acetal;acrolein ethylene ketal;" );
gibbsFormation
{
    dHf_298   -224620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     193.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-56630.0
    phase     gas;
}
