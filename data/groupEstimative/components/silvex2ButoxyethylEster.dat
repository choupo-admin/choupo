/*--------------------------------*- Choupo -*-----------------------*\
  Component: silvex 2-butoxyethyl ester  (C15H19Cl3O4, CAS 30387-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        silvex2ButoxyethylEster;
formula     C15H19Cl3O4;
CAS         30387-70-3;
InChIKey    WERRVXJNLSIJED-UHFFFAOYSA-N;
MW          369.663;      // g/mol [origin=calculated method=formula-sum]
Tc          1006.61;      // K   [origin=predictive method=joback]
Pc          15.848;      // bar [origin=predictive method=joback]
omega       1.0454;      // -   [origin=predictive method=lee-kesler]
Tb          799.77;      // K   [origin=predictive method=joback]
HvapTb      78628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (113.327 1.01062 -0.00036688 -2.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 2; } { group AC; count 1; } { group CH2COO; count 1; } { group CH2O; count 2; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butoxyethyl 3-[2,4,5-tris(chloranyl)phenoxy]propanoate" "2-butoxyethyl 3-(2,4,5-trichlorophenoxy)propanoate" "2-butoxyethyl 3-(2,4,5-trichlorophenoxy)propionate" "propanoic acid, 3-(2,4,5-trichlorophenoxy)-, 2-butoxyethyl ester" "2,4,5-trichlorophenoxypropionic acid, butoxyethyl ester" "propanoic acid,3-(2,4,5-trichlorophenoxy)-, 2-butoxyethyl ester" "propionicacid, 3-(2,4,5-trichlorophenoxy)-, 2-butoxyethyl ester (8ci); ethanol,2-butoxy-, 3-(2,4,5-trichlorophenoxy)propionate (8ci); 2-butoxyethyl3-(2,4,5-trichlorophenoxy)propionate; silvex 2-butoxyethyl ester" );
gibbsFormation
{
    dHf_298   -779750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     789.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-397220.0
    phase     gas;
}
