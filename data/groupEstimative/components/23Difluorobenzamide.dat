/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-difluorobenzamide  (C7H5F2NO, CAS 18355-75-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Difluorobenzamide;
formula     C7H5F2NO;
CAS         18355-75-4;
InChIKey    DDAINDMVKSETGF-UHFFFAOYSA-N;
MW          157.119;      // g/mol [origin=calculated method=formula-sum]
Tc          736.80;      // K   [origin=predictive method=joback]
Pc          41.144;      // bar [origin=predictive method=joback]
omega       0.6724;      // -   [origin=predictive method=lee-kesler]
Tb          521.34;      // K   [origin=predictive method=joback]
HvapTb      50529.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.25 0.5284 -0.00031162 6.096e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACF; count 2; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(fluoranyl)benzamide" "benzamide, 2,3-difluoro-" );
standardThermochemistry
{
    dHf_298   -445230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-350880.0
}
