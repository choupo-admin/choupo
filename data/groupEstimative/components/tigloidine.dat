/*--------------------------------*- Choupo -*-----------------------*\
  Component: tigloidine  (C13H21NO2, CAS 495-83-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tigloidine;
formula     C13H21NO2;
CAS         495-83-0;
InChIKey    UVHGSMZRSVGWDJ-RUDMXATFSA-N;
MW          223.316;      // g/mol [origin=calculated method=formula-sum]
Tc          788.45;      // K   [origin=predictive method=joback]
Pc          21.553;      // bar [origin=predictive method=joback]
omega       0.6545;      // -   [origin=predictive method=lee-kesler]
Tb          584.82;      // K   [origin=predictive method=joback]
HvapTb      53709.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.75 1.59356 -0.0011261 3.135e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 3; } { group CH=C; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8-methyl-8-azabicyclo[3.2.1]octan-3-yl) (e)-2-methylbut-2-enoate" "tropigline" "tropiglina" "tropiglinum" "tropintiglinat" "tropyl 2,3-dimethylacrylate" "3alpha-tropanyl (e)-2-methylcrotonat" );
gibbsFormation
{
    dHf_298   -334870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32350.0
    phase     gas;
}
