/*--------------------------------*- Choupo -*-----------------------*\
  Component: id-1229  (C24H28FNO2, CAS 56390-16-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        id1229;
formula     C24H28FNO2;
CAS         56390-16-0;
InChIKey    SMDNOEGDKSJRPV-XTZPKPCCSA-N;
MW          381.491;      // g/mol [origin=calculated method=formula-sum]
Tc          1205.52;      // K   [origin=predictive method=joback]
Pc          16.619;      // bar [origin=predictive method=joback]
omega       1.1960;      // -   [origin=predictive method=lee-kesler]
Tb          967.29;      // K   [origin=predictive method=joback]
HvapTb      94246.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-208.837 2.83654 -0.00249438 9.1106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } { group CH2N; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group F; count 1; } { group OH_phenol; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butanone, 1-(4-fluorophenyl)-4-(1,4,5,6-tetrahydro-8-hydroxy-6,11-dimethyl-2,6-methano-3-benzazocin-3(2h)-yl)-, (2-alpha,6-alpha,11r*)-" );
gibbsFormation
{
    dHf_298   -366540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     813.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97490.0
    phase     gas;
}
