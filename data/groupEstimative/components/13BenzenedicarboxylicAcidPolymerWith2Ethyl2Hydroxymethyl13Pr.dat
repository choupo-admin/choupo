/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenedicarboxylic acid, polymer with 2-ethyl-2-(hydroxymethyl)-1,3-propanediol and 2,2,4-trimethyl-1,3-pentanediol  (C22H38O9, CAS 106906-27-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BenzenedicarboxylicAcidPolymerWith2Ethyl2Hydroxymethyl13Pr;
formula     C22H38O9;
CAS         106906-27-8;
InChIKey    SNSKVUFLOVIQOQ-UHFFFAOYSA-N;
MW          446.537;      // g/mol [origin=calculated method=formula-sum]
Tc          2072.23;      // K   [origin=predictive method=joback]
Pc          16.026;      // bar [origin=predictive method=joback]
omega       0.2932;      // -   [origin=predictive method=lee-kesler]
Tb          1482.00;      // K   [origin=predictive method=joback]
HvapTb      182447.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.265 2.0781 -0.00095476 6.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 2; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 5; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 2; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 5; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid;2-ethyl-2-(hydroxymethyl)propane-1,3-diol;2,2,4-trimethylpentane-1,3-diol" "trimethylpentanediol, trimethylol propane and isophthalic acid polymer" );
standardThermochemistry
{
    dHf_298   -1985340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1379.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1343500.0
}
