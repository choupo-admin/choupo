/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[4.5]dec-6-en-8-one  (C10H14O, CAS 14523-53-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro45Dec6En8One;
formula     C10H14O;
CAS         14523-53-6;
InChIKey    XKYBFVHJBMGXPO-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          783.77;      // K   [origin=predictive method=joback]
Pc          35.899;      // bar [origin=predictive method=joback]
omega       0.3865;      // -   [origin=predictive method=lee-kesler]
Tb          530.85;      // K   [origin=predictive method=joback]
HvapTb      42065.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.89 1.3113 -0.00110628 4.042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro[4.5]dec-9-en-8-one" "spiro[4.5]dec-6-ene-8-one" "spiro(4.5)dec-6-ene-8-one" "8-spiro[4.5]dec-9-enone" );
standardThermochemistry
{
    dHf_298   -173110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=16010.0
}
