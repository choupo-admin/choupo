/*--------------------------------*- Choupo -*-----------------------*\
  Component: cfc-212ca  (C3Cl6F2, CAS 3182-26-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cfc212ca;
formula     C3Cl6F2;
CAS         3182-26-1;
InChIKey    YXVCODVAPNKSMC-UHFFFAOYSA-N;
MW          286.729;      // g/mol [origin=calculated method=formula-sum]
Tc          714.09;      // K   [origin=predictive method=joback]
Pc          32.246;      // bar [origin=predictive method=joback]
omega       0.3281;      // -   [origin=predictive method=lee-kesler]
Tb          481.67;      // K   [origin=predictive method=joback]
HvapTb      43060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.27 0.7306 -0.00081 3.054e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl3; count 2; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group F; count 2; } { group Cl; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,3,3,3-hexakis(chloranyl)-2,2-bis(fluoranyl)propane" "1,1,1,3,3,3-hexachloro-2,2-difluoropropane" "2,2-difluoro-1,1,1,3,3,3-hexachloropropane" "propane, 1,1,1,3,3,3-hexachloro-2,2-difluoro-" "propane, 2,2-difluoro-1,1,1,3,3,3-hexachloro-" "propane,1,1,1,3,3,3-hexachloro-2,2-difluoro-" "1,1,1,3,3,3-hexachloro-2,2-difluoro-propane" "1,1,1,3,3,3-hexachloro-2,2-difluoropropane;1,1,1,3,3,3-hexachlorodifluoropropane" );
gibbsFormation
{
    dHf_298   -618160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-478300.0
    phase     gas;
}
