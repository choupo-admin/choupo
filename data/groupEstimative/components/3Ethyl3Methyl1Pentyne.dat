/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethyl-3-methyl-1-pentyne  (C8H14, CAS 919-12-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethyl3Methyl1Pentyne;
formula     C8H14;
CAS         919-12-0;
InChIKey    OVNWORSPZLORHV-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          556.58;      // K   [origin=predictive method=joback]
Pc          30.223;      // bar [origin=predictive method=joback]
omega       0.2419;      // -   [origin=predictive method=lee-kesler]
Tb          369.53;      // K   [origin=predictive method=joback]
HvapTb      31964.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.078 0.79576 -0.00057913 1.7429e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-3-methyl-pent-1-yne" "1-pentyne, 3-ethyl-3-methyl-" "3-ethyl-3-methylpent-1-yne" );
standardThermochemistry
{
    dHf_298   74700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=242390.0
}
