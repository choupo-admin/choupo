/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyruvamide  (C3H5NO2, CAS 631-66-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyruvamide;
formula     C3H5NO2;
CAS         631-66-3;
InChIKey    FPOLWERNILTNDK-UHFFFAOYSA-N;
MW          87.078;      // g/mol [origin=calculated method=formula-sum]
Tc          658.31;      // K   [origin=predictive method=joback]
Pc          57.132;      // bar [origin=predictive method=joback]
omega       0.5947;      // -   [origin=predictive method=lee-kesler]
Tb          448.51;      // K   [origin=predictive method=joback]
HvapTb      46405.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.37 0.29472 -0.0001454 1.742e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CdO; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylidenepropanamide" "2-oxopropanamide" "propanamide, 2-oxo-" "pym" );
gibbsFormation
{
    dHf_298   -296620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-217010.0
    phase     gas;
}
