/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-chloropropoxy)tetrahydro-2h-pyran  (C8H15ClO2, CAS 42330-88-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23ChloropropoxyTetrahydro2hPyran;
formula     C8H15ClO2;
CAS         42330-88-1;
InChIKey    QFXXARKSLAKVRL-UHFFFAOYSA-N;
MW          178.656;      // g/mol [origin=calculated method=formula-sum]
Tc          695.01;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.4894;      // -   [origin=predictive method=lee-kesler]
Tb          488.99;      // K   [origin=predictive method=joback]
HvapTb      45136.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.277 0.8265 -0.0003879 3.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Cl; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-chloranylpropoxy)oxane" "2-(3-chloropropoxy)oxane" "qfxxarkslakvrl-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -434090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-162120.0
    phase     gas;
}
