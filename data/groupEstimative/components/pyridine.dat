/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyridine  (C5H5N, CAS 110-86-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyridine;
formula     C5H5N;
CAS         110-86-1;
InChIKey    JUJWROOIHBZHMG-UHFFFAOYSA-N;
MW          79.102;      // g/mol [origin=calculated method=formula-sum]
Tc          618.77;      // K   [origin=predictive method=joback]
Pc          54.788;      // bar [origin=predictive method=joback]
omega       0.2456;      // -   [origin=predictive method=lee-kesler]
Tb          389.40;      // K   [origin=predictive method=joback]
HvapTb      34548.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.8 0.49316 -0.0003557 1.005e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C5H5N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 5; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "azabenzene" "azine" "pyridin" "piridina" "pirydyna" "pyridin [german]" "pirydyna [polish]" "pyridine-ring" "pyridine- d5" "pyridine fraction" "0py" "pyridine, acs" );
standardThermochemistry
{
    dHf_298   134260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     263.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=190310.0
}
