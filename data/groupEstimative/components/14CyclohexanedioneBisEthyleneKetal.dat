/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-cyclohexanedione bis(ethylene ketal)  (C10H16O4, CAS 183-97-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14CyclohexanedioneBisEthyleneKetal;
formula     C10H16O4;
CAS         183-97-1;
InChIKey    YSMVSEYPOBXSOK-UHFFFAOYSA-N;
MW          200.234;      // g/mol [origin=calculated method=formula-sum]
Tc          843.77;      // K   [origin=predictive method=joback]
Pc          40.261;      // bar [origin=predictive method=joback]
omega       0.5275;      // -   [origin=predictive method=lee-kesler]
Tb          582.92;      // K   [origin=predictive method=joback]
HvapTb      54500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-219.17 1.9568 -0.0020138 8.456e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 2; } { group FCH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group C_ring; count 2; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,9,12-tetraoxadispiro[4.2.4^{8}.2^{5}]tetradecane" "1,4,9,12-tetraoxadispiro[4.2.4.2]tetradecane" "1,4,9,12-tetraoxadispiro(4.2.4.2)tetradecane" "1,4-cyclohexanedione bis(ethyleneketal)" "1,4-cyclohexanedione bis-(ethyleneketal)" "p183" "1,4-cyclohexanedione bis(ethyl ene ketal)" "1,9,12-tetraoxadispiro[4.2.4.2]tetradecane" );
standardThermochemistry
{
    dHf_298   -539310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-192680.0
}
