/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,3-tetrachlorobutane  (C4H6Cl4, CAS 13138-51-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1233Tetrachlorobutane;
formula     C4H6Cl4;
CAS         13138-51-7;
InChIKey    NGAAIHKWQFLRDY-UHFFFAOYSA-N;
MW          195.892;      // g/mol [origin=calculated method=formula-sum]
Tc          653.43;      // K   [origin=predictive method=joback]
Pc          33.684;      // bar [origin=predictive method=joback]
omega       0.3106;      // -   [origin=predictive method=lee-kesler]
Tb          437.17;      // K   [origin=predictive method=joback]
HvapTb      40354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.661 0.54272 -0.0004504 1.438e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,3-tetrakis(chloranyl)butane" "butane,1,2,3,3-tetrachloro-" );
standardThermochemistry
{
    dHf_298   -202880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64520.0
}
