/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-2-methyloxane  (C6H11BrO, CAS 156051-16-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo2Methyloxane;
formula     C6H11BrO;
CAS         156051-16-0;
InChIKey    OHDMVYQDGADQIF-UHFFFAOYSA-N;
MW          179.057;      // g/mol [origin=calculated method=formula-sum]
Tc          669.98;      // K   [origin=predictive method=joback]
Pc          40.986;      // bar [origin=predictive method=joback]
omega       0.3503;      // -   [origin=predictive method=lee-kesler]
Tb          444.87;      // K   [origin=predictive method=joback]
HvapTb      40015.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.72 0.70462 -0.0003857 6.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 2; } { group FCH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group Br; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-2-methyl-oxane" "3-bromo-2-methyltetrahydro-2h-pyran" "2h-pyran,3-bromotetrahydro-2-methyl-" "3-bromotetrahydro-2-methyl-2h-pyran" "3-bromotetrahydro-2-methyl-2h-pyran, 99;3-bromotetrahydro-2-methyl-2h-pyran" );
standardThermochemistry
{
    dHf_298   -238860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     316.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55420.0
}
