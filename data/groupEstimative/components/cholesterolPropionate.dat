/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholesterol, propionate  (C30H50O2, CAS 633-31-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholesterolPropionate;
formula     C30H50O2;
CAS         633-31-8;
InChIKey    CCORPVHYPHHRKB-AOZQTVIPSA-N;
MW          442.728;      // g/mol [origin=calculated method=formula-sum]
Tc          1209.72;      // K   [origin=predictive method=joback]
Pc          8.550;      // bar [origin=predictive method=joback]
omega       0.7636;      // -   [origin=predictive method=lee-kesler]
Tb          982.26;      // K   [origin=predictive method=joback]
HvapTb      87242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-288.996 3.75532 -0.00298804 1.0261e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 11; } { group CH; count 7; } { group C; count 2; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,9s,14s,17r)-10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] propanoate" "cholesterol n-propionate" "cholesteryl n-propionate" "propionyloxy-3beta cholestene-5" "cholest-5-en-3beta-yl propionate" "cholest-5-en-3-ol (3beta)-, propanoate" "cholest-5-en-3-ol (3beta)-, 3-propanoate" "(1s,5s,11s,14r)-2,15-dimethyl-14-(6-methylheptan-2-yl)tetracyclo[8.7.0.0^{2,7}.0^{11,15}]heptadec-7-en-5-yl propanoate" );
gibbsFormation
{
    dHf_298   -714200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1063.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55190.0
    phase     gas;
}
