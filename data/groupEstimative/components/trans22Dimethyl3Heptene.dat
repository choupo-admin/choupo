/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-2,2-dimethyl-3-heptene  (C9H18, CAS 19550-75-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans22Dimethyl3Heptene;
formula     C9H18;
CAS         19550-75-5;
InChIKey    BQOCYCICSYUPRF-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          588.88;      // K   [origin=predictive method=joback]
Pc          24.727;      // bar [origin=predictive method=joback]
omega       0.3225;      // -   [origin=predictive method=lee-kesler]
Tb          406.45;      // K   [origin=predictive method=joback]
HvapTb      34290.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.948 1.00468 -0.0007214 2.152e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylhept-3-ene" );
gibbsFormation
{
    dHf_298   -120620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107960.0
    phase     gas;
}
