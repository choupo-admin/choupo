/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl 2-chlorobenzoate  (C10H9ClO2, CAS 7506-76-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allyl2Chlorobenzoate;
formula     C10H9ClO2;
CAS         7506-76-5;
InChIKey    QAPRPPQBBCRDKG-UHFFFAOYSA-N;
MW          196.63;      // g/mol [origin=calculated method=formula-sum]
Tc          772.80;      // K   [origin=predictive method=joback]
Pc          29.155;      // bar [origin=predictive method=joback]
omega       0.5738;      // -   [origin=predictive method=lee-kesler]
Tb          552.39;      // K   [origin=predictive method=joback]
HvapTb      51914.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.501 0.7474 -0.00043306 7.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl 2-chloranylbenzoate" "2-chlorobenzoic acid, allyl ester" "prop-2-enyl 2-chlorobenzoate" );
gibbsFormation
{
    dHf_298   -232260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98360.0
    phase     gas;
}
