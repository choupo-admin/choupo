/*--------------------------------*- Choupo -*-----------------------*\
  Component: dichlorophen  (C13H10Cl2O2, CAS 97-23-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dichlorophen;
formula     C13H10Cl2O2;
CAS         97-23-4;
InChIKey    MDNWOSOZYLHTCG-UHFFFAOYSA-N;
MW          269.121;      // g/mol [origin=calculated method=formula-sum]
Tc          1062.78;      // K   [origin=predictive method=joback]
Pc          38.579;      // bar [origin=predictive method=joback]
omega       1.0673;      // -   [origin=predictive method=lee-kesler]
Tb          796.46;      // K   [origin=predictive method=joback]
HvapTb      85206.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.199 1.2848 -0.00116524 4.289e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group Cl; count 2; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-2-[(5-chloranyl-2-oxidanyl-phenyl)methyl]phenol" "dichlorophene" "2,2'-methylenebis(4-chlorophenol)" "dichlorofen" "dichlorphen" "trivex" "anthiphen" "antiphen" "cordocel" "dicestal" "didroxan" "didroxane" );
standardThermochemistry
{
    dHf_298   -247630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68960.0
}
