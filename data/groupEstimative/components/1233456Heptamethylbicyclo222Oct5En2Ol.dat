/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,3,4,5,6-heptamethylbicyclo(2.2.2)oct-5-en-2-ol  (C15H26O, CAS 60362-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1233456Heptamethylbicyclo222Oct5En2Ol;
formula     C15H26O;
CAS         60362-71-2;
InChIKey    JFTZOJLENZMCHP-UHFFFAOYSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          868.74;      // K   [origin=predictive method=joback]
Pc          21.918;      // bar [origin=predictive method=joback]
omega       0.8180;      // -   [origin=predictive method=lee-kesler]
Tb          657.74;      // K   [origin=predictive method=joback]
HvapTb      62227.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-267.89 2.68514 -0.003043 1.4059e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 2; } { group C; count 4; } { group OH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2_ring; count 2; } { group C_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,2,3,4,5,6-heptamethylbicyclo[2.2.2]oct-5-en-3-ol" "bicyclo(2.2.2)oct-5-en-2-ol, 1,2,3,3,4,5,6-heptamethyl-" "bicyclo[2.2.2]oct-5-en-2-ol, 1,2,3,3,4,5,6-heptamethyl-" );
standardThermochemistry
{
    dHf_298   -316760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     794.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9220.0
}
