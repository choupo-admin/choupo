/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(aminomethyl)cyclohexanemethanol  (C8H17NO, CAS 1074-62-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4AminomethylCyclohexanemethanol;
formula     C8H17NO;
CAS         1074-62-0;
InChIKey    WWDKVICMJWBJKJ-UHFFFAOYSA-N;
MW          143.23;      // g/mol [origin=calculated method=formula-sum]
Tc          762.51;      // K   [origin=predictive method=joback]
Pc          36.072;      // bar [origin=predictive method=joback]
omega       0.8930;      // -   [origin=predictive method=lee-kesler]
Tb          562.23;      // K   [origin=predictive method=joback]
HvapTb      60842.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.268 0.9553 -0.0005108 8.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group OH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(aminomethyl)cyclohexyl]methanol" "cyclohexanemethanol, 4-(aminomethyl)-" "4-(aminomethyl)cyclohexylmethanol" "cyclohexanemethanol,4-(aminomethyl)-" "((1r,4r)-4-(aminomethyl)cyclohexyl)methanol" "cyclohexanemethanol, 4-(aminomethyl)-, trans-" );
standardThermochemistry
{
    dHf_298   -292910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-37150.0
}
