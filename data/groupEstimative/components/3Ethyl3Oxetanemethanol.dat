/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethyl-3-oxetanemethanol  (C6H12O2, CAS 3047-32-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethyl3Oxetanemethanol;
formula     C6H12O2;
CAS         3047-32-3;
InChIKey    UNMJLQGKEDTEKJ-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          655.53;      // K   [origin=predictive method=joback]
Pc          43.800;      // bar [origin=predictive method=joback]
omega       0.7479;      // -   [origin=predictive method=lee-kesler]
Tb          467.26;      // K   [origin=predictive method=joback]
HvapTb      49073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.308 1.03802 -0.0010255 4.287e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group OH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group OH; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-ethyloxetan-3-yl)methanol" "3-oxetanemethanol, 3-ethyl-" "3-hydroxymethyl-3-ethyloxetane" "2-hydroxymethyl-2-ethyl-1,3-epoxypropane" "3-ethyl-3-hydroxymethyloxetane" "3-ethyloxetane-3-methanol" "3-ethyl-3-hydroxymethyl oxetane" "(3-ethyl-oxetan-3-yl)-methanol" "3-ethyl-(hydroxymethyl)oxetane" "3-ethyl-3-hydroxylmethyl oxetane" "3-ethyl-3-(hydroxymethyl)-oxetane" );
standardThermochemistry
{
    dHf_298   -369520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180140.0
}
