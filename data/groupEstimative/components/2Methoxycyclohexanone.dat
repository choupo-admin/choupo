/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxycyclohexanone  (C7H12O2, CAS 7429-44-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxycyclohexanone;
formula     C7H12O2;
CAS         7429-44-9;
InChIKey    JYJURPHZXCLFDX-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          691.36;      // K   [origin=predictive method=joback]
Pc          35.986;      // bar [origin=predictive method=joback]
omega       0.3997;      // -   [origin=predictive method=lee-kesler]
Tb          469.55;      // K   [origin=predictive method=joback]
HvapTb      38262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.15 0.55942 -8.3e-05 -8.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH2CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxycyclohexan-1-one" "cyclohexanone, 2-methoxy-" "(s)-2-methoxycyclohexanone" "2-methoxy-1-cyclohexanone" );
standardThermochemistry
{
    dHf_298   -403410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-195080.0
}
