/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-(dimethylamino)fulvene  (C8H11N, CAS 696-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6DimethylaminoFulvene;
formula     C8H11N;
CAS         696-68-4;
InChIKey    UJXXVGXQTXQALL-UHFFFAOYSA-N;
MW          121.183;      // g/mol [origin=calculated method=formula-sum]
Tc          622.78;      // K   [origin=predictive method=joback]
Pc          35.685;      // bar [origin=predictive method=joback]
omega       0.3652;      // -   [origin=predictive method=lee-kesler]
Tb          419.99;      // K   [origin=predictive method=joback]
HvapTb      37382.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.84 0.85644 -0.00064986 1.984e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 2; } { group CH=C; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclopenta-2,4-dien-1-ylidene-n,n-dimethyl-methanamine" "6-(dimethylaminofulvene" "5-(dimethylaminomethylene)-1,3-cyclopentadiene" "1-(cyclopenta-2,4-dien-1-ylidene)-n,n-dimethylmethanamine" "methanamine, 1-(2,4-cyclopentadien-1-ylidene)-n,n-dimethyl-" "1-cyclopenta-2,4-dien-1-ylidene-n,n-dimethylmethanamine" "2,.alpha.-methylamine, n,n-dimethyl-" "(cyclopenta-2,4-dien-1-ylidenemethyl)dimethylamine" "n-cyclopenta-2,4-dienylidenmethyl-n,n-dimethylamine" "2,4-cyclopentadien-1-ylidene-n,n-dimethylmethanamine" "methanamine,4-cyclopentadien-1-ylidene)-n,n-dimethyl-" "1-(1-cyclopenta-2,4-dienylidene)-n,n-dimethylmethanamine" );
gibbsFormation
{
    dHf_298   131490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=276900.0
    phase     gas;
}
