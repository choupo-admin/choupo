/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(5-bromo-2,4-dimethoxyphenyl)propan-2-amine  (C11H16BrNO2, CAS 60917-67-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Bromo24DimethoxyphenylPropan2Amine;
formula     C11H16BrNO2;
CAS         60917-67-1;
InChIKey    YFSLPSITQIUFQK-UHFFFAOYSA-N;
MW          274.158;      // g/mol [origin=calculated method=formula-sum]
Tc          902.34;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       0.8790;      // -   [origin=predictive method=lee-kesler]
Tb          675.99;      // K   [origin=predictive method=joback]
HvapTb      65850.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (65.881 0.77106 -0.00030068 5.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 2; } { group CHNH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group O; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(5-bromanyl-2,4-dimethoxy-phenyl)propan-2-amine" "meta-dob" "benzeneethanamine-5-bromo-2,4-dimethoxy-.alpha.-methyl" "benzeneethanamine, 5-bromo-2,4-dimethoxy-alpha-methyl-" );
gibbsFormation
{
    dHf_298   -277850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6410.0
    phase     gas;
}
