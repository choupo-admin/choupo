/*--------------------------------*- Choupo -*-----------------------*\
  Component: (+)-delta-cadinene  (C15H24, CAS 483-76-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        deltaCadinene;
formula     C15H24;
CAS         483-76-1;
InChIKey    FUCYIEXQVQJBKY-ZFWWWQNUSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          802.71;      // K   [origin=predictive method=joback]
Pc          19.527;      // bar [origin=predictive method=joback]
omega       0.5018;      // -   [origin=predictive method=lee-kesler]
Tb          586.18;      // K   [origin=predictive method=joback]
HvapTb      51680.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.94 1.40768 -0.00082364 1.795e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 3; } { group CH=C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,8ar)-4,7-dimethyl-1-propan-2-yl-1,2,3,5,6,8a-hexahydronaphthalene" "delta-cadinene" "cadina-1(10),4-diene" "delta-amorphene" "(1s,8ar)-delta-cadinene" "(1s,8ar)-1-isopropyl-4,7-dimethyl-1,2,3,5,6,8a-hexahydronaphthalene" "(1s,8ar)-4,7-dimethyl-1-(propan-2-yl)-1,2,3,5,6,8a-hexahydronaphthalene" );
gibbsFormation
{
    dHf_298   -156100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=177110.0
    phase     gas;
}
