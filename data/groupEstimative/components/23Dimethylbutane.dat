/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethylbutane  (C6H14, CAS 79-29-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethylbutane;
formula     C6H14;
CAS         79-29-8;
InChIKey    ZFFMLCVRJBZUDZ-UHFFFAOYSA-N;
MW          86.178;      // g/mol [origin=calculated method=formula-sum]
Tc          507.46;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       0.2478;      // -   [origin=predictive method=lee-kesler]
Tb          336.00;      // K   [origin=predictive method=joback]
HvapTb      28174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.93 0.58568 -0.000309 5.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diisopropyl" "biisopropyl" "butane, 2,3-dimethyl-" "1,1,2,2-tetramethylethane" "2,3-dimethyl butane" "agn-pc-0cjy9t" );
gibbsFormation
{
    dHf_298   -177730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     370.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5240.0
    phase     gas;
}
