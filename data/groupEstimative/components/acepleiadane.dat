/*--------------------------------*- Choupo -*-----------------------*\
  Component: acepleiadane  (C16H16, CAS 518-02-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acepleiadane;
formula     C16H16;
CAS         518-02-5;
InChIKey    MODFRFVMVVZBAZ-UHFFFAOYSA-N;
MW          208.304;      // g/mol [origin=calculated method=formula-sum]
Tc          902.86;      // K   [origin=predictive method=joback]
Pc          27.354;      // bar [origin=predictive method=joback]
omega       0.6247;      // -   [origin=predictive method=lee-kesler]
Tb          654.08;      // K   [origin=predictive method=joback]
HvapTb      58218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.17 1.558 -0.00129756 4.412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,5,6,7,8-hexahydrocyclohepta[fg]acenaphthylene" );
gibbsFormation
{
    dHf_298   194430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=401300.0
    phase     gas;
}
