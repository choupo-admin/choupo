/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-piperazinediacetic acid, diethyl ester  (C12H22N2O4, CAS 40479-48-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14PiperazinediaceticAcidDiethylEster;
formula     C12H22N2O4;
CAS         40479-48-9;
InChIKey    LSIMQYAGYOYVKJ-UHFFFAOYSA-N;
MW          258.318;      // g/mol [origin=calculated method=formula-sum]
Tc          816.24;      // K   [origin=predictive method=joback]
Pc          21.119;      // bar [origin=predictive method=joback]
omega       0.9791;      // -   [origin=predictive method=lee-kesler]
Tb          631.16;      // K   [origin=predictive method=joback]
HvapTb      61600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.886 1.44984 -0.0008942 1.898e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2COO; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH2_ring; count 4; } { group COO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-[4-(2-ethoxy-2-oxidanylidene-ethyl)piperazin-1-yl]ethanoate" "ethyl 2-[4-(2-ethoxy-2-oxoethyl)piperazin-1-yl]acetate" );
standardThermochemistry
{
    dHf_298   -703530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     730.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-292660.0
}
