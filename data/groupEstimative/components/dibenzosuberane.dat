/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzosuberane  (C15H14, CAS 833-48-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzosuberane;
formula     C15H14;
CAS         833-48-7;
InChIKey    PJQCANLCUDUPRF-UHFFFAOYSA-N;
MW          194.277;      // g/mol [origin=calculated method=formula-sum]
Tc          872.09;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       0.5148;      // -   [origin=predictive method=lee-kesler]
Tb          617.53;      // K   [origin=predictive method=joback]
HvapTb      55082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.14 1.3294 -0.00099612 2.96e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,11-dihydro-5h-dibenzo[2,1-b:2',1'-f][7]annulene" "10,11-dihydro-5h-dibenzo(a,d)cycloheptene" "10,11-dihydro-5h-dibenzo[a,d]cycloheptene" "10,11-dihydro-5h-dibenzo[a,d][7]annulene" "5h-dibenzo[a,d]cycloheptene, 10,11-dihydro-" "dibenzocycloheptene" "dibenzocycloheptadiene" "2,3:6,7-dibenzosuberan" "1,2:4,5-dibenzocycloheptane" "dibenzo[a,d][1,4]cycloheptadiene" "10,11-dihydrodibenzo[a,d]cycloheptene" );
gibbsFormation
{
    dHf_298   190330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=349440.0
    phase     gas;
}
