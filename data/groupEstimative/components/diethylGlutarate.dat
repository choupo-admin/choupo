/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl glutarate  (C9H16O4, CAS 818-38-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylGlutarate;
formula     C9H16O4;
CAS         818-38-2;
InChIKey    OUWSNHWQZPEFEX-UHFFFAOYSA-N;
MW          188.223;      // g/mol [origin=calculated method=formula-sum]
Tc          698.44;      // K   [origin=predictive method=joback]
Pc          23.293;      // bar [origin=predictive method=joback]
omega       0.7524;      // -   [origin=predictive method=lee-kesler]
Tb          521.96;      // K   [origin=predictive method=joback]
HvapTb      50442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.525 0.74924 -0.0002766 -1.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl pentanedioate" "pentanedioic acid, diethyl ester" "glutaric acid diethyl ester" "ethyl glutarate" "glutaric acid, diethyl ester" "pentanedioic acid, 1,5-diethyl ester" "pentanedioic acid, c18-28-alkyl esters" "pentanedioic acid, di-c8-26-alkyl esters" "pentanedioic acid diethyl ester" "glutaric acid, diethyl ester (8ci)" "(c8-c26) alkylalcohol glutarate diester" "o394" );
gibbsFormation
{
    dHf_298   -863650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     609.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-595840.0
    phase     gas;
}
