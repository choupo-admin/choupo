/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylbenzenamine,2,4-di-t-butyl  (C16H27N, CAS 2909-76-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylbenzenamine24DiTButyl;
formula     C16H27N;
CAS         2909-76-4;
InChIKey    CQRQHMIMTXPFQJ-UHFFFAOYSA-N;
MW          233.399;      // g/mol [origin=calculated method=formula-sum]
Tc          818.84;      // K   [origin=predictive method=joback]
Pc          17.118;      // bar [origin=predictive method=joback]
omega       0.5364;      // -   [origin=predictive method=lee-kesler]
Tb          608.30;      // K   [origin=predictive method=joback]
HvapTb      54261.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.6 1.70156 -0.00119992 3.361e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group C; count 2; } { group ACH; count 3; } { group AC; count 3; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-ditert-butyl-n,n-dimethyl-aniline" "2,4-ditert-butyl-n,n-dimethylaniline" "n,n-dimethylbenzenamine, 2,4-di-t-butyl-" );
gibbsFormation
{
    dHf_298   -109950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     598.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=293450.0
    phase     gas;
}
