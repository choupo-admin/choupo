/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,4,4-tetrachlorobutan-1-ol  (C4H6Cl4O, CAS 3290-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2444Tetrachlorobutan1Ol;
formula     C4H6Cl4O;
CAS         3290-70-8;
InChIKey    PHPDBVLDVIRSHU-UHFFFAOYSA-N;
MW          211.891;      // g/mol [origin=calculated method=formula-sum]
Tc          731.68;      // K   [origin=predictive method=joback]
Pc          37.592;      // bar [origin=predictive method=joback]
omega       0.7745;      // -   [origin=predictive method=lee-kesler]
Tb          529.35;      // K   [origin=predictive method=joback]
HvapTb      57033.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.952 0.5767 -0.0004808 1.536e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 1; } { group CHCl; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group Cl; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,4,4-tetrakis(chloranyl)butan-1-ol" "1-butanol, 2,4,4,4-tetrachloro-" "2,4,4,4-tetrachlorobutanol" "butanol, 2,4,4,4-tetrachloro-" "2,4,4,4-tetrachloro-1-butanol" );
standardThermochemistry
{
    dHf_298   -355110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-201340.0
}
