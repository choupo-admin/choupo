/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-(3-heptyloxy)ethoxy)ethanol  (C11H24O3, CAS 10138-87-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        223HeptyloxyEthoxyEthanol;
formula     C11H24O3;
CAS         10138-87-1;
InChIKey    KBAWNJHIFOTMPH-UHFFFAOYSA-N;
MW          204.31;      // g/mol [origin=calculated method=formula-sum]
Tc          749.09;      // K   [origin=predictive method=joback]
Pc          20.512;      // bar [origin=predictive method=joback]
omega       1.1073;      // -   [origin=predictive method=lee-kesler]
Tb          587.86;      // K   [origin=predictive method=joback]
HvapTb      61191.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.498 0.96234 -0.0003862 1.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-heptan-3-yloxyethoxy)ethanol" "2-[2-(heptan-3-yloxy)ethoxy]ethanol" "2-(2-(1-ethylamyloxy)ethoxy)ethanol" "2-(((1-ethylpentyl)oxy)ethoxy)ethanol" "ethanol, 2-(((1-ethylpentyl)oxy)ethoxy)-" "7-ethyl-3,6-dioxa-1-undekanol" );
gibbsFormation
{
    dHf_298   -692320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-307520.0
    phase     gas;
}
