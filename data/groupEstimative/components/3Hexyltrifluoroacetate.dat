/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexyltrifluoroacetate  (C8H13F3O2, CAS 761-34-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexyltrifluoroacetate;
formula     C8H13F3O2;
CAS         761-34-2;
InChIKey    TXLRKFWFZMQEOY-UHFFFAOYSA-N;
MW          198.184;      // g/mol [origin=calculated method=formula-sum]
Tc          595.16;      // K   [origin=predictive method=joback]
Pc          22.915;      // bar [origin=predictive method=joback]
omega       0.5903;      // -   [origin=predictive method=lee-kesler]
Tb          435.00;      // K   [origin=predictive method=joback]
HvapTb      36674.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.143 0.87614 -0.000541 1.151e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group F; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexan-3-yl 2,2,2-tris(fluoranyl)ethanoate" "hexan-3-yl 2,2,2-trifluoroacetate" );
standardThermochemistry
{
    dHf_298   -1128090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-877920.0
}
