/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octanol  (C8H18O, CAS 111-87-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octanol;
formula     C8H18O;
CAS         111-87-5;
InChIKey    KBPLFHHGFOOTCA-UHFFFAOYSA-N;
MW          130.231;      // g/mol [origin=calculated method=formula-sum]
Tc          634.65;      // K   [origin=predictive method=joback]
Pc          27.877;      // bar [origin=predictive method=joback]
omega       0.8646;      // -   [origin=predictive method=lee-kesler]
Tb          474.82;      // K   [origin=predictive method=joback]
HvapTb      50081.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.907 0.79782 -0.0004418 9.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octan-1-ol" "octanol" "capryl alcohol" "octyl alcohol" "n-octanol" "caprylic alcohol" "n-octyl alcohol" "heptyl carbinol" "alcohol c-8" "1-hydroxyoctane" "primary octyl alcohol" "n-octan-1-ol" );
standardThermochemistry
{
    dHf_298   -360680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-120340.0
}
