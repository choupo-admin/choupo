/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylmaleic acid  (C10H8O4, CAS 16110-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylmaleicAcid;
formula     C10H8O4;
CAS         16110-98-8;
InChIKey    CQNPSIAJXGEDQS-UHFFFAOYSA-N;
MW          192.17;      // g/mol [origin=calculated method=formula-sum]
Tc          990.84;      // K   [origin=predictive method=joback]
Pc          38.483;      // bar [origin=predictive method=joback]
omega       1.1611;      // -   [origin=predictive method=lee-kesler]
Tb          750.14;      // K   [origin=predictive method=joback]
HvapTb      74496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.78 0.9964 -0.0007827 2.385e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylbut-2-enedioic acid" "2-butenedioic acid, 2-phenyl-, (2z)-" "2-phenyl-2-butenedioic acid" "2-butenedioic acid,2-phenyl-, (2z)-" "2-butenedioicacid, 2-phenyl-, (z)-; maleic acid, phenyl- (6ci,8ci); phenylmaleic acid" );
standardThermochemistry
{
    dHf_298   -606310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-470420.0
}
