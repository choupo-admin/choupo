/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-methoxyphenyl)-1-propanol  (C10H14O2, CAS 5349-60-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Methoxyphenyl1Propanol;
formula     C10H14O2;
CAS         5349-60-0;
InChIKey    RELLLNVFFUWXHI-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          770.06;      // K   [origin=predictive method=joback]
Pc          31.597;      // bar [origin=predictive method=joback]
omega       0.9095;      // -   [origin=predictive method=lee-kesler]
Tb          574.22;      // K   [origin=predictive method=joback]
HvapTb      59493.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.301 0.79214 -0.00040696 6.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methoxyphenyl)propan-1-ol" "benzenemethanol, .alpha.-ethyl-4-methoxy-" "benzyl alcohol, .alpha.-ethyl-p-methoxy-" "benzenemethanol, alpha-ethyl-4-methoxy-" "agn-pc-00k3hy" "rac-1-(4'-methoxyphenyl)propanol" "a-ethyl-p-methoxy-benzyl alcohol" "alpha-ethyl-p-methoxybenzyl alcohol" "benzenemethanol, a-ethyl-4-methoxy-" "benzyl alcohol, alpha-ethyl-p-methoxy- (8ci)" "2,2-dideuterio-1-(4-methoxyphenyl)propan-1-ol" );
standardThermochemistry
{
    dHf_298   -314400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-108160.0
}
