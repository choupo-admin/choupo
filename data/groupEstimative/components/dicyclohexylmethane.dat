/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicyclohexylmethane  (C13H24, CAS 3178-23-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicyclohexylmethane;
formula     C13H24;
CAS         3178-23-2;
InChIKey    XXKOQQBKBHUATC-UHFFFAOYSA-N;
MW          180.335;      // g/mol [origin=calculated method=formula-sum]
Tc          764.00;      // K   [origin=predictive method=joback]
Pc          23.657;      // bar [origin=predictive method=joback]
omega       0.3802;      // -   [origin=predictive method=lee-kesler]
Tb          536.14;      // K   [origin=predictive method=joback]
HvapTb      45390.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.139 1.483 -0.0008454 1.627e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexylmethylcyclohexane" "methane, dicyclohexyl-" "cyclohexane, 1,1'-methylenebis-" "cyclohexane,1'-methylenebis-" "methane, dicyclohexyl- (8ci)" "cyclohexane, 1,1'-methylenebis- (9ci)" );
gibbsFormation
{
    dHf_298   -203010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107480.0
    phase     gas;
}
