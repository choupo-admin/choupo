/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-oxidiisopropylbenzene  (C12H18O, CAS 3445-42-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pOxidiisopropylbenzene;
formula     C12H18O;
CAS         3445-42-9;
InChIKey    VBSMBCNJCBKQFP-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          797.49;      // K   [origin=predictive method=joback]
Pc          26.708;      // bar [origin=predictive method=joback]
omega       0.8094;      // -   [origin=predictive method=lee-kesler]
Tb          594.33;      // K   [origin=predictive method=joback]
HvapTb      60239.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.49 1.17118 -0.00079856 2.134e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-propan-2-ylphenyl)propan-2-ol" "p-hydroxydiisopropylbenzene" "alpha,alpha-dimethyl-p-isopropylbenzyl alcohol" "benzyl alcohol, .alpha.,.alpha.-dimethyl-p-isopropyl-" "benzyl alcohol, alpha,alpha-dimethyl-p-isopropyl-" "benzenemethanol, .alpha.,.alpha.-dimethyl-4-(1-methylethyl)-" "2-(4-iso-propylphenyl)-2-propanol" "2-[4-(methylethyl)phenyl]propan-2-ol" "4-isopropyl-alpha,alpha-dimethylbenzyl alcohol" "alpha-hydroxy-alpha'-(tert-butylperoxy)diisopropylbenzene" "benzenemethanol, alpha,alpha-dimethyl-4-(1-methylethyl)-" "benzenemethanol, alpha,alpha-dimethyl-4-(1-methylethyl)- (9ci)" );
gibbsFormation
{
    dHf_298   -232210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=16520.0
    phase     gas;
}
