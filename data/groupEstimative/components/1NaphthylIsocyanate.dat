/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-naphthyl isocyanate  (C11H7NO, CAS 86-84-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1NaphthylIsocyanate;
formula     C11H7NO;
CAS         86-84-0;
InChIKey    BDQNKCYCTYYMAA-UHFFFAOYSA-N;
MW          169.183;      // g/mol [origin=calculated method=formula-sum]
Tc          810.72;      // K   [origin=predictive method=joback]
Pc          37.226;      // bar [origin=predictive method=joback]
omega       0.5758;      // -   [origin=predictive method=lee-kesler]
Tb          568.59;      // K   [origin=predictive method=joback]
HvapTb      54190.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group dCd; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanatonaphthalene" "naphthalene, 1-isocyanato-" "isocyanatonaphthalene" "1-isocyanatonapthalene" "isocyanic acid, 1-naphthyl ester" "alpha naphthyl isocyanate" "isocyanic acid 1-naphthyl ester" "alpha-naphthylisocyanate" "1-isocyanato-naphthalene" ".alpha.-naphthyl isocyanate" "1-naphthyl carbimide" "a-naphthyl isocyanate" );
