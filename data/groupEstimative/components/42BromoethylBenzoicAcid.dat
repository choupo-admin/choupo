/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2-bromoethyl)benzoic acid  (C9H9BrO2, CAS 52062-92-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        42BromoethylBenzoicAcid;
formula     C9H9BrO2;
CAS         52062-92-7;
InChIKey    BKMRWJWLBHHGCF-UHFFFAOYSA-N;
MW          229.073;      // g/mol [origin=calculated method=formula-sum]
Tc          886.19;      // K   [origin=predictive method=joback]
Pc          38.675;      // bar [origin=predictive method=joback]
omega       0.8759;      // -   [origin=predictive method=lee-kesler]
Tb          648.85;      // K   [origin=predictive method=joback]
HvapTb      62165.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.108 0.8094 -0.00057396 1.586e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-bromoethyl)benzoicacid" "4'-(2-bromoethyl)benzoic acid" "p-(.beta.-bromoethyl)benzoic acid" "ambap52062-92-7" "benzoic acid,4-(2-bromoethyl)-" "p(beta-bromoethyl)benzoic acid" "benzoicacid, p-(2-bromoethyl)- (7ci);2-[4-carboxyphenyl]ethyl bromide;4-(2-bromoethyl)benzoic acid;p-(2-bromoethyl)benzoic acid;" );
gibbsFormation
{
    dHf_298   -327970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-201910.0
    phase     gas;
}
