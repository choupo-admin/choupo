/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trichloro-3,5-dimethylphenol  (C8H7Cl3O, CAS 6972-47-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trichloro35Dimethylphenol;
formula     C8H7Cl3O;
CAS         6972-47-0;
InChIKey    ZNEWEUWJXXZLAD-UHFFFAOYSA-N;
MW          225.493;      // g/mol [origin=calculated method=formula-sum]
Tc          865.49;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.7039;      // -   [origin=predictive method=lee-kesler]
Tb          622.15;      // K   [origin=predictive method=joback]
HvapTb      64495.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.66 0.62194 -0.000492 1.7e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACCH3; count 2; } { group ACOH; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC_ring; count 6; } { group Cl; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-tris(chloranyl)-3,5-dimethyl-phenol" "phenol, 2,4,6-trichloro-3,5-dimethyl-" "3, 2,4,6-trichloro-" "3,5-dimethyl-2,4,6-trichlorophenol" "phenol,4,6-trichloro-3,5-dimethyl-" "2,4,6-trichloro-3,5-dimethyl-phenol" "phenol,2,4,6-trichloro-3,5-dimethyl-" );
gibbsFormation
{
    dHf_298   -242330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-100040.0
    phase     gas;
}
