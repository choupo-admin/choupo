/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-eicosanethiol  (C20H42S, CAS 13373-97-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Eicosanethiol;
formula     C20H42S;
CAS         13373-97-2;
InChIKey    YYHYWOPDNMFEAV-UHFFFAOYSA-N;
MW          314.616;      // g/mol [origin=calculated method=formula-sum]
Tc          893.90;      // K   [origin=predictive method=joback]
Pc          10.583;      // bar [origin=predictive method=joback]
omega       0.8650;      // -   [origin=predictive method=lee-kesler]
Tb          720.06;      // K   [origin=predictive method=joback]
HvapTb      66851.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.401 1.93112 -0.0010866 2.324e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 19; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "icosane-1-thiol" "icosyl mercaptan" "eicosyl mercaptan" "n-eicosylmercaptan;" );
gibbsFormation
{
    dHf_298   -417650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     997.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=146910.0
    phase     gas;
}
