/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-chloroethyl)-3-phenyl-1-benzofuran-2-one  (C16H13ClO2, CAS 71173-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32Chloroethyl3Phenyl1Benzofuran2One;
formula     C16H13ClO2;
CAS         71173-19-8;
InChIKey    PDLKPOWUZKBSPE-UHFFFAOYSA-N;
MW          272.728;      // g/mol [origin=calculated method=formula-sum]
Tc          962.00;      // K   [origin=predictive method=joback]
Pc          24.654;      // bar [origin=predictive method=joback]
omega       0.7764;      // -   [origin=predictive method=lee-kesler]
Tb          718.11;      // K   [origin=predictive method=joback]
HvapTb      66634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.858 1.7205 -0.00161336 6.143e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group C; count 1; } { group ACH; count 9; } { group AC; count 3; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzofuranone, 3-(2-chloroethyl)-3-phenyl-2(3h)-," );
gibbsFormation
{
    dHf_298   -144640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56190.0
    phase     gas;
}
