/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenepentanol  (C11H16O, CAS 10521-91-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenepentanol;
formula     C11H16O;
CAS         10521-91-2;
InChIKey    DPZMVZIQRMVBBW-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          760.26;      // K   [origin=predictive method=joback]
Pc          29.187;      // bar [origin=predictive method=joback]
omega       0.9106;      // -   [origin=predictive method=lee-kesler]
Tb          570.14;      // K   [origin=predictive method=joback]
HvapTb      59035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.725 1.0039 -0.0006362 1.55e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-phenylpentan-1-ol" "5-phenyl-1-pentanol" "1-pentanol, 5-phenyl-" "5-phenylpentanol" "phenylamyl alcohol" "pentanol, 5-phenyl-" "phenylpentanol (van)" "1-pentanol, 5-phenyl- (8ci)" );
gibbsFormation
{
    dHf_298   -186070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17330.0
    phase     gas;
}
