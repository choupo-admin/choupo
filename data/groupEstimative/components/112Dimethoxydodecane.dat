/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,12-dimethoxydodecane  (C14H30O2, CAS 73120-52-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112Dimethoxydodecane;
formula     C14H30O2;
CAS         73120-52-2;
InChIKey    CFUFEIWWICPJOZ-UHFFFAOYSA-N;
MW          230.392;      // g/mol [origin=calculated method=formula-sum]
Tc          724.79;      // K   [origin=predictive method=joback]
Pc          14.839;      // bar [origin=predictive method=joback]
omega       0.8062;      // -   [origin=predictive method=lee-kesler]
Tb          564.76;      // K   [origin=predictive method=joback]
HvapTb      51578.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.162 1.20744 -0.0005158 4.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecane,1,12-dimethoxy-" "agn-pc-00h1zm" "dodecane, 1,12-dimethoxy-" );
gibbsFormation
{
    dHf_298   -596730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     723.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-143000.0
    phase     gas;
}
