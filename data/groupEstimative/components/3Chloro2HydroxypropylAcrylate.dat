/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-2-hydroxypropyl acrylate  (C6H9ClO3, CAS 3326-90-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro2HydroxypropylAcrylate;
formula     C6H9ClO3;
CAS         3326-90-7;
InChIKey    POTYORUTRLSAGZ-UHFFFAOYSA-N;
MW          164.585;      // g/mol [origin=calculated method=formula-sum]
Tc          701.00;      // K   [origin=predictive method=joback]
Pc          35.263;      // bar [origin=predictive method=joback]
omega       0.9436;      // -   [origin=predictive method=lee-kesler]
Tb          520.95;      // K   [origin=predictive method=joback]
HvapTb      56363.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.352 0.5457 -0.0002849 3.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-chloranyl-2-oxidanyl-propyl) prop-2-enoate" "2-hydroxy-3-chloropropyl acrylate" "2-propenoic acid, 3-chloro-2-hydroxypropyl ester" "(3-chloro-2-hydroxypropyl) prop-2-enoate" "2-propenoic acid,3-chloro-2-hydroxypropyl ester" "acrylicacid, 3-chloro-2-hydroxypropyl ester (7ci,8ci); 1,2-propanediol, 3-chloro-,1-acrylate (8ci); 2-hydroxy-3-chloropropyl acrylate;3-chloro-2-hydroxyprop-1-yl acrylate; 3-chloro-2-hydroxypropyl acrylate; b-hydroxy-g-chloropropyl acrylate; g-chloro-b-hydroxypropyl acrylate" );
standardThermochemistry
{
    dHf_298   -532270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-374080.0
}
