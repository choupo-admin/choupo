/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentane, isopentyl-  (C10H20, CAS 1005-68-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentaneIsopentyl;
formula     C10H20;
CAS         1005-68-1;
InChIKey    SAVJAOISDXUPNK-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          637.05;      // K   [origin=predictive method=joback]
Pc          25.252;      // bar [origin=predictive method=joback]
omega       0.3677;      // -   [origin=predictive method=lee-kesler]
Tb          443.24;      // K   [origin=predictive method=joback]
HvapTb      37723.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.368 1.09144 -0.0006508 1.468e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutylcyclopentane" "cyclopentane, (3-methylbutyl)-" );
gibbsFormation
{
    dHf_298   -194530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=67430.0
    phase     gas;
}
