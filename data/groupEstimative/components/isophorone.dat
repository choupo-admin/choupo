/*--------------------------------*- Choupo -*-----------------------*\
  Component: isophorone  (C9H14O, CAS 78-59-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isophorone;
formula     C9H14O;
CAS         78-59-1;
InChIKey    HJOVHMDZYOCNQW-UHFFFAOYSA-N;
MW          138.21;      // g/mol [origin=calculated method=formula-sum]
Tc          727.53;      // K   [origin=predictive method=joback]
Pc          31.704;      // bar [origin=predictive method=joback]
omega       0.3791;      // -   [origin=predictive method=lee-kesler]
Tb          497.27;      // K   [origin=predictive method=joback]
HvapTb      40107.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.38 0.98906 -0.00075564 2.698e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5,5-trimethylcyclohex-2-en-1-one" "isoacetophorone" "isoforone" "isooctopherone" "isoforon" "izoforon" ".alpha.-isophoron" "2-cyclohexen-1-one, 3,5,5-trimethyl-" "3,5,5-trimethyl-2-cyclohexen-1-one" "1,1,3-trimethyl-3-cyclohexene-5-one" "izoforon [polish]" "3,5,5-trimethylcyclohex-2-enone" );
gibbsFormation
{
    dHf_298   -250920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58400.0
    phase     gas;
}
