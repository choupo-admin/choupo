/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-acetyl-2-methoxyphenyl acetate  (C11H12O4, CAS 54771-60-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Acetyl2MethoxyphenylAcetate;
formula     C11H12O4;
CAS         54771-60-7;
InChIKey    GCVAEUQDYWOLCF-UHFFFAOYSA-N;
MW          208.213;      // g/mol [origin=calculated method=formula-sum]
Tc          836.58;      // K   [origin=predictive method=joback]
Pc          27.070;      // bar [origin=predictive method=joback]
omega       0.8043;      // -   [origin=predictive method=lee-kesler]
Tb          622.43;      // K   [origin=predictive method=joback]
HvapTb      60243.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.85 0.70496 -0.00024742 -2.554e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CH3CO; count 1; } { group CH3COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-ethanoyl-2-methoxy-phenyl) ethanoate" "4-acetoxy-3-methoxyacetophenone" "1-(4-acetoxy-3-methoxyphenyl)ethanone" "acetylated acetovanillone" "(4-acetyl-2-methoxyphenyl) acetate" "acetic acid (4-acetyl-2-methoxyphenyl) ester" );
gibbsFormation
{
    dHf_298   -618860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-409400.0
    phase     gas;
}
