/*--------------------------------*- Choupo -*-----------------------*\
  Component: mibp  (C12H14O4, CAS 30833-53-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mibp;
formula     C12H14O4;
CAS         30833-53-5;
InChIKey    RZJSUWQGFCHNFS-UHFFFAOYSA-N;
MW          222.24;      // g/mol [origin=calculated method=formula-sum]
Tc          928.49;      // K   [origin=predictive method=joback]
Pc          26.245;      // bar [origin=predictive method=joback]
omega       1.0055;      // -   [origin=predictive method=lee-kesler]
Tb          709.11;      // K   [origin=predictive method=joback]
HvapTb      69427.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.701 1.00734 -0.00057436 1.026e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methylpropoxycarbonyl)benzoic acid" "monoisobutyl phthalate" "mono-iso-butyl phthalate" "isobutyl hydrogen phthalate" "phthalic acid, monoisobutyl ester" "1,2-benzenedicarboxylic acid, mono(2-methylpropyl) ester" "monoisobutyl phthalic acid" "phthalic acid monoisobutyl ester" "2-[(2-methylpropoxy)carbonyl]benzoic acid" "1,2-benzenedicarboxylic acid 1-(2-methylpropyl) ester" "1,2-benzenedicarboxylic acid mono(2-methylpropyl) ester" "1,2-benzenedicarboxylicacid, 1-(2-methylpropyl) ester" );
standardThermochemistry
{
    dHf_298   -738780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-503780.0
}
