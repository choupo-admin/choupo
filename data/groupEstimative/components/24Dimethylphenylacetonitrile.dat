/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethylphenylacetonitrile  (C10H11N, CAS 68429-53-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dimethylphenylacetonitrile;
formula     C10H11N;
CAS         68429-53-8;
InChIKey    OOWISQLTVOZJJI-UHFFFAOYSA-N;
MW          145.205;      // g/mol [origin=calculated method=formula-sum]
Tc          792.63;      // K   [origin=predictive method=joback]
Pc          27.643;      // bar [origin=predictive method=joback]
omega       0.5543;      // -   [origin=predictive method=lee-kesler]
Tb          567.12;      // K   [origin=predictive method=joback]
HvapTb      51932.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.491 0.69074 -0.00038632 7.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,4-dimethylphenyl)ethanenitrile" "2-(2,4-dimethylphenyl)acetonitrile" "benzeneacetonitrile,2,4-dimethyl-" );
standardThermochemistry
{
    dHf_298   128740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=259650.0
}
