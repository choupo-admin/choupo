/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-tert-butyl(2,2-dimethoxyethoxy)benzene  (C14H22O3, CAS 72152-73-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pTertButyl22DimethoxyethoxyBenzene;
formula     C14H22O3;
CAS         72152-73-9;
InChIKey    RMRIGZDUZFDJNP-UHFFFAOYSA-N;
MW          238.327;      // g/mol [origin=calculated method=formula-sum]
Tc          820.07;      // K   [origin=predictive method=joback]
Pc          19.407;      // bar [origin=predictive method=joback]
omega       0.6743;      // -   [origin=predictive method=lee-kesler]
Tb          615.17;      // K   [origin=predictive method=joback]
HvapTb      55242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.901 1.1376 -0.00054396 6.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-4-(2,2-dimethoxyethoxy)benzene" "benzene, 1-(2,2-dimethoxyethoxy)-4-(1,1-dimethylethyl)-" "p-tert-butylphenoxyacetaldehyde dimethyl acetal" );
standardThermochemistry
{
    dHf_298   -517920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144820.0
}
