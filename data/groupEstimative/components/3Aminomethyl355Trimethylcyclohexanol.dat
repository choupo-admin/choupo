/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-aminomethyl-3,5,5-trimethylcyclohexanol  (C10H21NO, CAS 15647-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Aminomethyl355Trimethylcyclohexanol;
formula     C10H21NO;
CAS         15647-11-7;
InChIKey    YFEAYNIMJBHJCM-UHFFFAOYSA-N;
MW          171.284;      // g/mol [origin=calculated method=formula-sum]
Tc          813.02;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.8638;      // -   [origin=predictive method=lee-kesler]
Tb          603.80;      // K   [origin=predictive method=joback]
HvapTb      62683.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-148.129 1.70266 -0.0016294 6.778e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group OH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(aminomethyl)-3,5,5-trimethyl-cyclohexan-1-ol" "cyclohexanol, 3-(aminomethyl)-3,5,5-trimethyl-" "3-aminomethyl-3,5,5-trimethylcyclohexan-1-ol" "3-(aminomethyl)-3,5,5-trimethylcyclohexan-1-ol" "cyclohexanol,3-(aminomethyl)-3,5,5-trimethyl-" "1-hydroxy-3-(aminomethyl)-3,5,5-trimethylcyclohexane;3,3,5-trimethyl-5-aminomethyl-1-cyclohexanol; 3-(aminomethyl)-3,5,5-trimethylcyclohexanol;3-(aminomethyl)-3,5,5-trimethylcyclohexyl alcohol" );
gibbsFormation
{
    dHf_298   -324050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     671.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-39000.0
    phase     gas;
}
