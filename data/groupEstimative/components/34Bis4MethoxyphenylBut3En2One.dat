/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-bis(4-methoxyphenyl)but-3-en-2-one  (C18H18O3, CAS 56622-38-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Bis4MethoxyphenylBut3En2One;
formula     C18H18O3;
CAS         56622-38-9;
InChIKey    UFBJXEMRUMHJDW-UHFFFAOYSA-N;
MW          282.339;      // g/mol [origin=calculated method=formula-sum]
Tc          1012.55;      // K   [origin=predictive method=joback]
Pc          20.145;      // bar [origin=predictive method=joback]
omega       0.8839;      // -   [origin=predictive method=lee-kesler]
Tb          777.51;      // K   [origin=predictive method=joback]
HvapTb      73142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.2 1.30256 -0.00072912 1.3476e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3CO; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -234320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     670.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38990.0
    phase     gas;
}
