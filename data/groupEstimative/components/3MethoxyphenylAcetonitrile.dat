/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-methoxyphenyl)acetonitrile  (C9H9NO, CAS 19924-43-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethoxyphenylAcetonitrile;
formula     C9H9NO;
CAS         19924-43-7;
InChIKey    LXKNAUOWEJWGTE-UHFFFAOYSA-N;
MW          147.177;      // g/mol [origin=calculated method=formula-sum]
Tc          787.42;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.5843;      // -   [origin=predictive method=lee-kesler]
Tb          561.68;      // K   [origin=predictive method=joback]
HvapTb      51454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.601 0.59202 -0.00028796 3.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-methoxyphenyl)ethanenitrile" "3-methoxybenzyl cyanide" "2-(3-methoxyphenyl)acetonitrile" "3-methoxyphenylacetonitrile" "(m-methoxyphenyl)acetonitrile" "3-(cyanomethyl)anisole" "m-methoxybenzyl cyanide" "benzeneacetonitrile, 3-methoxy-" "m-methoxy phenylacetonitrile" "3-methoxy-benzeneacetonitrile" );
standardThermochemistry
{
    dHf_298   28630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=155860.0
}
