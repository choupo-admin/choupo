/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentaquine  (C18H27N3O, CAS 86-78-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentaquine;
formula     C18H27N3O;
CAS         86-78-2;
InChIKey    VKXQZROIIKPELG-UHFFFAOYSA-N;
MW          301.434;      // g/mol [origin=calculated method=formula-sum]
Tc          1060.14;      // K   [origin=predictive method=joback]
Pc          17.624;      // bar [origin=predictive method=joback]
omega       1.1387;      // -   [origin=predictive method=lee-kesler]
Tb          843.08;      // K   [origin=predictive method=joback]
HvapTb      82006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.765 1.64112 -0.0009879 2.273e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group ACH; count 2; } { group AC; count 2; } { group CH3O; count 1; } { group CH2NH; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 4; } { group O; count 1; } { group NH; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(6-methoxyquinolin-8-yl)-n'-propan-2-yl-pentane-1,5-diamine" "pentachinum" "pentachina [dcit]" "pentaquine [inn:ban]" "pentaquinum [inn-latin]" "1,5-pentanediamine, n-(6-methoxy-8-quinolinyl)-n'-(1-methylethyl)-" "pentachina" "pentaquina" "pentaquinum" "5428-64-8 (phosphate[1:1])" "n-(6-methoxyquinolin-8-yl)-n'-propan-2-ylpentane-1,5-diamine" "n-(6-methoxyquinolin-8-yl)-n'-(propan-2-yl)pentane-1,5-diamine" );
gibbsFormation
{
    dHf_298   -7960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     725.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=448870.0
    phase     gas;
}
