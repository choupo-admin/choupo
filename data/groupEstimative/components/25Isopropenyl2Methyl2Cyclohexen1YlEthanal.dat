/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(5-isopropenyl-2-methyl-2-cyclohexen-1-yl)ethanal  (C12H18O, CAS 72983-68-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Isopropenyl2Methyl2Cyclohexen1YlEthanal;
formula     C12H18O;
CAS         72983-68-7;
InChIKey    HZRBBXZWSHOZKT-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          745.51;      // K   [origin=predictive method=joback]
Pc          23.657;      // bar [origin=predictive method=joback]
omega       0.5333;      // -   [origin=predictive method=lee-kesler]
Tb          538.40;      // K   [origin=predictive method=joback]
HvapTb      49510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.889 1.07834 -0.00059304 1.094e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group CH2=C; count 1; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methyl-5-prop-1-en-2-yl-cyclohex-2-en-1-yl)ethanal" "2-methyl-5-(1-methylvinyl)-2-cyclohexene-1-acetaldehyde" "2-cyclohexene-1-acetaldehyde, 2-methyl-5-(1-methylethenyl)-" "[2-methyl-5-(prop-1-en-2-yl)cyclohex-2-en-1-yl]acetaldehyde" "2-(2-methyl-5-prop-1-en-2-ylcyclohex-2-en-1-yl)acetaldehyde" "2-cyclohexene-1-acetaldehyde,2-methyl-5-(1-methylethenyl)-" "2-[(5r)-2-methyl-5-prop-1-en-2-ylcyclohex-2-en-1-yl]acetaldehyde" );
standardThermochemistry
{
    dHf_298   -180660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=67000.0
}
