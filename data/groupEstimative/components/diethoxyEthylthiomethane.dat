/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethoxy ethylthiomethane  (C7H16O2S, CAS 25604-63-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethoxyEthylthiomethane;
formula     C7H16O2S;
CAS         25604-63-1;
InChIKey    IAEZPMPXTZNOLP-UHFFFAOYSA-N;
MW          164.263;      // g/mol [origin=calculated method=formula-sum]
Tc          662.96;      // K   [origin=predictive method=joback]
Pc          27.730;      // bar [origin=predictive method=joback]
omega       0.5388;      // -   [origin=predictive method=lee-kesler]
Tb          472.94;      // K   [origin=predictive method=joback]
HvapTb      42425.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (65.443 0.54275 -9.8e-05 -6.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH2O; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group O; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[ethoxy(ethylsulfanyl)methoxy]ethane" "orthoformicacid, thio-, triethyl ester (8ci)" "ethane,1,1'-[[(ethylthio)methylene]bis(oxy)]bis- (9ci)" );
gibbsFormation
{
    dHf_298   -415660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-171260.0
    phase     gas;
}
