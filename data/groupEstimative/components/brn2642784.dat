name        brn2642784;
formula     C13H15NO;
CAS         2889-58-9;
InChIKey    JRLLJITWABKEKE-UHFFFAOYSA-N;
MW          201.269;      // g/mol [origin=calculated method=formula-sum]
Tc          814.54;      // K   [origin=predictive method=joback]
Pc          24.752;      // bar [origin=predictive method=joback]
omega       0.5603;      // -   [origin=predictive method=lee-kesler]
Tb          588.70;      // K   [origin=predictive method=joback]
HvapTb      55116.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-isocyanatopropan-2-yl)-4-prop-1-en-2-yl-benzene" "benzene, 1-(1-isocyanato-1-methylethyl)-4-(1-methylethenyl)-" "alpha,alpha-dimethyl-para-isopropenyl benzyl isocyanate" "1-(1-isocyanato-1-methylethyl)-4-(1-methylethenyl)benzene" "isocyanic acid, p-isopropenyl-alpha,alpha-dimethylbenzyl ester" );
