/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,1'-(1,3,5,7,9,11,13-tetradecaheptaene-1,14-diyl)bis-  (C26H24, CAS 62622-57-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene11135791113Tetradecaheptaene114DiylBis;
formula     C26H24;
CAS         62622-57-5;
InChIKey    WJHNHVWHBKVGCS-UHFFFAOYSA-N;
MW          336.478;      // g/mol [origin=calculated method=formula-sum]
Tc          1124.00;      // K   [origin=predictive method=joback]
Pc          13.840;      // bar [origin=predictive method=joback]
omega       0.7684;      // -   [origin=predictive method=lee-kesler]
Tb          876.96;      // K   [origin=predictive method=joback]
HvapTb      77728.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-187.83 2.456 -0.0020396 6.81e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 7; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 14; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "14-phenyltetradeca-1,3,5,7,9,11,13-heptaenylbenzene" "(1e,3e,5e,7e,9e,11e,13e)-1,14-diphenyltetradeca-1,3,5,7,9,11,13-heptaene" );
gibbsFormation
{
    dHf_298   713630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     909.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=954400.0
    phase     gas;
}
