/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2295104  (C19H14O3, CAS 24684-58-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2295104;
formula     C19H14O3;
CAS         24684-58-0;
InChIKey    UFOXIANZOBFANL-UHFFFAOYSA-N;
MW          290.318;      // g/mol [origin=calculated method=formula-sum]
Tc          1110.91;      // K   [origin=predictive method=joback]
Pc          23.158;      // bar [origin=predictive method=joback]
omega       1.0112;      // -   [origin=predictive method=lee-kesler]
Tb          856.33;      // K   [origin=predictive method=joback]
HvapTb      77968.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.32 1.43882 -0.00098328 2.604e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 6; } { group ACCH2; count 1; } { group CH2CO; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 7; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(17-oxidanylidene-15,16-dihydrocyclopenta[a]phenanthren-11-yl) ethanoate" "11-acetoxy-15,16-dihydrocyclopenta(a)phenanthracen-17-one" "cyclopenta(a)phenanthracen-17-one, 11-hydroxy-15,16-dihydro-, acetate (ester)" "cyclopenta(a)phenanthracen-17-one, 15,16-dihydro-11-hydroxy-, acetate (ester)" "(17-oxo-15,16-dihydrocyclopenta[a]phenanthren-11-yl) acetate" );
standardThermochemistry
{
    dHf_298   -224540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31790.0
}
