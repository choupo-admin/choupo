/*--------------------------------*- Choupo -*-----------------------*\
  Component: cinnamaldehyde diethyl acetal  (C13H18O2, CAS 7148-78-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cinnamaldehydeDiethylAcetal;
formula     C13H18O2;
CAS         7148-78-9;
InChIKey    VYKDEWVAUWARRX-ZHACJKMWSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          778.24;      // K   [origin=predictive method=joback]
Pc          22.483;      // bar [origin=predictive method=joback]
omega       0.6194;      // -   [origin=predictive method=lee-kesler]
Tb          572.28;      // K   [origin=predictive method=joback]
HvapTb      51198.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.698 1.05944 -0.0005796 1.063e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-3,3-diethoxyprop-1-enyl]benzene" "(3,3-diethoxyprop-1-en-1-yl)benzene" "benzene, (3,3-diethoxy-1-propenyl)-" "benzene, (3,3-diethoxy-1-propen-1-yl)-" "benzene, ((1e)-3,3-diethoxy-1-propenyl)-" "benzene, ((1e)-3,3-diethoxy-1-propen-1-yl)-" "cinnamaldehyde, diethyl acetal" "benzene,3-diethoxy-1-propenyl)-" "(3,3-diethoxy-1-propenyl)benzene" "(e)-(3,3-diethoxy-1-propenyl)benzene" "h142" "benzene, (3,3-diethoxy-1-propenyl)-, (e)-" );
standardThermochemistry
{
    dHf_298   -227620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38770.0
}
