/*--------------------------------*- Choupo -*-----------------------*\
  Component: |a,|a-bis(4-(dimethylamino)phenyl)-4-(ethylamino)naphthalene-1-methanol  (C29H33N3O, CAS 1325-92-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aABis4DimethylaminoPhenyl4EthylaminoNaphthalene1Methanol;
formula     C29H33N3O;
CAS         1325-92-4;
InChIKey    POGFPZCWAIFSIW-UHFFFAOYSA-N;
MW          439.603;      // g/mol [origin=calculated method=formula-sum]
Tc          1403.77;      // K   [origin=predictive method=joback]
Pc          13.677;      // bar [origin=predictive method=joback]
omega       1.2470;      // -   [origin=predictive method=lee-kesler]
Tb          1146.06;      // K   [origin=predictive method=joback]
HvapTb      117169.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.209 2.7643 -0.00199196 5.589e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 14; } { group AC; count 8; } { group OH; count 1; } { group CH2NH; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 8; } { group OH; count 1; } { group NH; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[4-(dimethylamino)phenyl]-[4-(ethylamino)naphthalen-1-yl]methanol" "bis(4-dimethylaminophenyl)-[4-(ethylamino)naphthalen-1-yl]methanol" "bis[4-(dimethylamino)phenyl][4-(ethylamino)naphthalen-1-yl]methanol" "1-naphthalenemethanol, .alpha.,.alpha.-bis[4-(dimethylamino)phenyl]-4-(ethylamino)-" "1-naphthalenemethanol, alpha,alpha-bis(4-(dimethylamino)phenyl)-4-(ethylamino)-" "alpha,alpha-bis(4-(dimethylamino)phenyl)-4-(ethylamino)naphthalene-1-methanol" );
standardThermochemistry
{
    dHf_298   240440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     917.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=775630.0
}
