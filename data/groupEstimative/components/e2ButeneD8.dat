/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-2-butene-d8  (C4D8, CAS 1517-55-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4D8 (delta D+8H-8; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        e2ButeneD8;
formula     C4D8;
CAS         1517-55-1;
InChIKey    IAQRGUVFOMOMEM-BDYLZKADSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          64.156;      // g/mol [origin=calculated method=formula-sum]
Tc          466.33;      // K   [origin=predictive method=joback]
Pc          41.623;      // bar [origin=predictive method=joback]
omega       0.1840;      // -   [origin=predictive method=lee-kesler]
Tb          295.28;      // K   [origin=predictive method=joback]
HvapTb      24456.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.93 0.40384 -0.0002776 8.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1,1,1,2,3,4,4,4-octadeuteriobut-2-ene" );
gibbsFormation
{
    dHf_298   -8670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     305.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63020.0
    phase     gas;
}
