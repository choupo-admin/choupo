/*--------------------------------*- Choupo -*-----------------------*\
  Component: docosyl acrylate  (C25H48O2, CAS 18299-85-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        docosylAcrylate;
formula     C25H48O2;
CAS         18299-85-9;
InChIKey    KHAYCTOSKLIHEP-UHFFFAOYSA-N;
MW          380.657;      // g/mol [origin=calculated method=formula-sum]
Tc          1011.87;      // K   [origin=predictive method=joback]
Pc          7.842;      // bar [origin=predictive method=joback]
omega       0.7471;      // -   [origin=predictive method=lee-kesler]
Tb          826.50;      // K   [origin=predictive method=joback]
HvapTb      77981.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.581 2.30402 -0.0012645 2.466e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 21; } { group CH2=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 21; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "docosyl prop-2-enoate" "2-propenoic acid, docosyl ester" "behenyl acrylate" "2-propenoic acid docosyl ester" );
standardThermochemistry
{
    dHf_298   -751180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1176.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-62910.0
}
