/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl pentopyranoside  (C6H12O5, CAS 612-05-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylPentopyranoside;
formula     C6H12O5;
CAS         612-05-5;
InChIKey    ZBDGHWFPLXXWRD-UHFFFAOYSA-N;
MW          164.157;      // g/mol [origin=calculated method=formula-sum]
Tc          844.94;      // K   [origin=predictive method=joback]
Pc          48.360;      // bar [origin=predictive method=joback]
omega       1.8463;      // -   [origin=predictive method=lee-kesler]
Tb          668.33;      // K   [origin=predictive method=joback]
HvapTb      85409.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.34 0.65222 -0.0001837 -4.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 4; } { group OH; count 3; } { group CH3O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group OH; count 3; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxyoxane-3,4,5-triol" "methyl .beta.-d-ribopyranoside" ".beta.-d-ribopyranoside, methyl" ".beta.-d-xylopyranoside, methyl" ".beta.-l-arabinopyranoside, methyl" "beta-methyl-d-xyloside" "methyl xylopyranoside" "2-methoxytetrahydro-2h-pyran-3,4,5-triol" "methyl alpha-d-xylopyranoside" "methyl beta-l-arabinopyranoside" "methyl-beta-l-arabinopyranoside" "beta-d-xyloside, methyl" );
standardThermochemistry
{
    dHf_298   -894780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     344.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-600620.0
}
