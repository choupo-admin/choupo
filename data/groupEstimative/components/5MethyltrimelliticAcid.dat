/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyltrimellitic acid  (C10H8O6, CAS 34240-10-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5MethyltrimelliticAcid;
formula     C10H8O6;
CAS         34240-10-3;
InChIKey    YMYIEXNGMOGPDH-UHFFFAOYSA-N;
MW          224.168;      // g/mol [origin=calculated method=formula-sum]
Tc          1144.63;      // K   [origin=predictive method=joback]
Pc          37.870;      // bar [origin=predictive method=joback]
omega       1.6784;      // -   [origin=predictive method=lee-kesler]
Tb          906.55;      // K   [origin=predictive method=joback]
HvapTb      93608.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.59 0.84882 -0.00056808 1.426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACCH3; count 1; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group COOH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylbenzene-1,2,4-tricarboxylic acid" "1,2,4-benzenetricarboxylic acid, 5-methyl-" );
standardThermochemistry
{
    dHf_298   -1098420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-914890.0
}
