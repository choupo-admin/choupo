/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-1,4-dichlorocyclohexane  (C6H10Cl2, CAS 16890-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans14Dichlorocyclohexane;
formula     C6H10Cl2;
CAS         16890-91-8;
InChIKey    WQTINZDWAXJLGH-UHFFFAOYSA-N;
MW          153.046;      // g/mol [origin=calculated method=formula-sum]
Tc          647.26;      // K   [origin=predictive method=joback]
Pc          34.765;      // bar [origin=predictive method=joback]
omega       0.2638;      // -   [origin=predictive method=lee-kesler]
Tb          426.62;      // K   [origin=predictive method=joback]
HvapTb      37840.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.45 0.683 -0.000369 5.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CHCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(chloranyl)cyclohexane" "1,4-dichlorocyclohexane" "cyclohexane, 1,4-dichloro-, cis-" "cis-1,4-dichlorocyclohexane" "cyclohexane, 1,4-dichloro-, trans-" "cyclohexane, 1,4-dichloro-" );
gibbsFormation
{
    dHf_298   -164670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-7480.0
    phase     gas;
}
