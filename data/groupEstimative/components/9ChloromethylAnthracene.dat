/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-(chloromethyl)anthracene  (C15H11Cl, CAS 24463-19-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9ChloromethylAnthracene;
formula     C15H11Cl;
CAS         24463-19-2;
InChIKey    PCVRSXXPGXRVEZ-UHFFFAOYSA-N;
MW          226.703;      // g/mol [origin=calculated method=formula-sum]
Tc          906.88;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       0.6082;      // -   [origin=predictive method=lee-kesler]
Tb          654.83;      // K   [origin=predictive method=joback]
HvapTb      60249.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.049 1.2303 -0.00098316 3.142e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 5; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 5; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-chloromethylanthracene" "9-chloromethyanthracene" "9-anthracenylmethyl chloride" "anthracene, 9-(chloromethyl)-" "anthracene, 9-chloromethyl-" "9-chloromethyl anthracene" "pcvrsxxpgxrvez-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   227060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=369940.0
    phase     gas;
}
