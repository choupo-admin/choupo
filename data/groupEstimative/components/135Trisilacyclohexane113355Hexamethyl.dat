name        135Trisilacyclohexane113355Hexamethyl;
formula     C9H24Si3;
CAS         1627-99-2;
InChIKey    ICSWLKDKQBNKAY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          216.546;      // g/mol [origin=calculated method=formula-sum]
Tc          617.99;      // K   [origin=predictive method=joback]
Pc          19.254;      // bar [origin=predictive method=joback]
omega       0.1707;      // -   [origin=predictive method=lee-kesler]
Tb          421.13;      // K   [origin=predictive method=joback]
HvapTb      36732.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.98 0.41772 0.000503 -4.282e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 3; } { group Si; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,3,3,5,5-hexamethyl-1,3,5-trisilinane" "1,1,3,3,5,5-hexamethylcyclotrimethylenetrisilane" "1,1,3,3,5,5-hexamethyl-1,3,5-trisilacyclohexane" "1,3,5-trisilacyclohexane,1,1,3,3,5,5-hexamethyl-" "1,1,3,3,5,5-hexamethyl-1,3,5-trisilacyclohexane;1,1,3,3,5,5-hexamethylcyclotrimethylenetrisilane;cyclosilane;methylcyclosiloxane;1,1,3,3,5,5-hexamethyl-1,3,5-trisilinane;" );
standardThermochemistry
{
