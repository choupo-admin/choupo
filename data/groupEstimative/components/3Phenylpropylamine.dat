/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylpropylamine  (C9H13N, CAS 2038-57-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenylpropylamine;
formula     C9H13N;
CAS         2038-57-5;
InChIKey    LYUQWQRTDLVQGA-UHFFFAOYSA-N;
MW          135.21;      // g/mol [origin=calculated method=formula-sum]
Tc          724.20;      // K   [origin=predictive method=joback]
Pc          34.848;      // bar [origin=predictive method=joback]
omega       0.5131;      // -   [origin=predictive method=lee-kesler]
Tb          504.73;      // K   [origin=predictive method=joback]
HvapTb      48545.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.707 0.8418 -0.0005404 1.324e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylpropan-1-amine" "benzenepropanamine" "gamma-phenylpropylamine" "hydrocinnamylamine" "1-amino-3-phenylpropane" "propylamine, 3-phenyl-" "3-phenyl-n-propylamine" "3-phenyl-1-propanamine" "gamma-aminopropylbenzene" "3-phenyl-1-propylamine" "gamma-phenyl-n-propylamine" "benzenepropanamine, hydrochloride" );
gibbsFormation
{
    dHf_298   41230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=203760.0
    phase     gas;
}
