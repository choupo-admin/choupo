/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,7,10-tetrathiacyclododecane  (C8H16S4, CAS 25423-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14710Tetrathiacyclododecane;
formula     C8H16S4;
CAS         25423-56-7;
InChIKey    MULBAFLKPUVJKC-UHFFFAOYSA-N;
MW          240.456;      // g/mol [origin=calculated method=formula-sum]
Tc          943.92;      // K   [origin=predictive method=joback]
Pc          38.010;      // bar [origin=predictive method=joback]
omega       0.3048;      // -   [origin=predictive method=lee-kesler]
Tb          623.80;      // K   [origin=predictive method=joback]
HvapTb      58420.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.37 0.91244 -0.0003442 -2.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2S; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group S_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "12-ane-s4" "[12]anes4" "tetrathia-12-crown-4" "1,7,10-tetrathiacyclododecane" );
gibbsFormation
{
    dHf_298   10290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     799.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135480.0
    phase     gas;
}
