/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-chloro-3-(2-phenylethenyl)-  (C14H11Cl, CAS 24942-77-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1Chloro32Phenylethenyl;
formula     C14H11Cl;
CAS         24942-77-6;
InChIKey    LLSLQJAZJCNYQW-UHFFFAOYSA-N;
MW          214.692;      // g/mol [origin=calculated method=formula-sum]
Tc          875.20;      // K   [origin=predictive method=joback]
Pc          27.701;      // bar [origin=predictive method=joback]
omega       0.4980;      // -   [origin=predictive method=lee-kesler]
Tb          619.85;      // K   [origin=predictive method=joback]
HvapTb      56315.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.64 1.1433 -0.00083736 2.379e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-(2-phenylethenyl)benzene" "3-chlorostilbene" "agn-pc-00lbop" "1-chloro-3-(2-phenylethenyl)benzene" "benzene, 1-chloro-3-[(1e)-2-phenylethenyl]-" );
gibbsFormation
{
    dHf_298   230780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=350480.0
    phase     gas;
}
