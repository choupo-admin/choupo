/*--------------------------------*- Choupo -*-----------------------*\
  Component: nicofuranose  (C30H24N4O10, CAS 15351-13-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nicofuranose;
formula     C30H24N4O10;
CAS         15351-13-0;
InChIKey    FUWFSXZKBMCSKF-ZASNTINBSA-N;
MW          600.54;      // g/mol [origin=calculated method=formula-sum]
Tc          1932.41;      // K   [origin=predictive method=joback]
Pc          15.488;      // bar [origin=predictive method=joback]
omega       1.2200;      // -   [origin=predictive method=lee-kesler]
Tb          1561.04;      // K   [origin=predictive method=joback]
HvapTb      165314.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.168 2.82914 -0.00190194 4.806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } { group CH-O; count 1; } { group C5H4N; count 4; } { group COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 16; } { group dC_ring; count 4; } { group OH; count 1; } { group O_ring; count 1; } { group COO; count 4; } { group Nd_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2r,3r,4s,5r)-5-oxidanyl-3,4-bis(pyridin-3-ylcarbonyloxy)-5-(pyridin-3-ylcarbonyloxymethyl)oxolan-2-yl]methyl pyridine-3-carboxylate" "bradilan" "vasperdil" "tetranicotylfructose" "tetranicotinoylfructose" "nicofuranoso [dcit]" "tetranicotylfructofuranose" "nicofuranosum [inn-latin]" "fructofuranose, tetranicotinate" "d-fructofuranose 1,3,4,6-tetranicotinat" "1,3,4,6-tetra-o-nicotinoyl-d-fructofuranose" "nicofuranosa" );
standardThermochemistry
{
    dHf_298   -1123900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1046.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-496930.0
}
