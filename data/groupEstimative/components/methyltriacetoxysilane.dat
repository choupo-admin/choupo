/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyltriacetoxysilane  (C7H12O6Si, CAS 4253-34-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H12O6Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methyltriacetoxysilane;
formula     C7H12O6Si;
CAS         4253-34-3;
InChIKey    TVJPBVNWVPUZBM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          220.252;      // g/mol [origin=calculated method=formula-sum]
Tc          726.64;      // K   [origin=predictive method=joback]
Pc          25.125;      // bar [origin=predictive method=joback]
omega       0.6980;      // -   [origin=predictive method=lee-kesler]
Tb          535.82;      // K   [origin=predictive method=joback]
HvapTb      53691.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (113.57 0.29828 0.0003416 -3.164e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH3COO; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[diacetyloxy(methyl)silyl] ethanoate" "methylsilanetriyl triacetate" "silanetriol, methyl-, triacetate" "triacetoxy(methyl)silane" "silane, methyltriacetoxy-" "methylsilanetriol triacetate" "methyltrihydroxysilane triacetate" "apk 1 (silane derivative)" "k 10s" "silanetriol, 1-methyl-, 1,1,1-triacetate" "triacetoxy-methylsilane" "[diacetyloxy(methyl)silyl] acetate" );
standardThermochemistry
{
    dHf_298   -1251270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     709.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1027810.0
}
