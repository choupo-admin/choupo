/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanedioic acid, 1-dodecenyl-, 4-tridecyl ester  (C29H54O4, CAS 68140-46-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanedioicAcid1Dodecenyl4TridecylEster;
formula     C29H54O4;
CAS         68140-46-5;
InChIKey    GLFSIVIXYLULGR-UHFFFAOYSA-N;
MW          466.747;      // g/mol [origin=calculated method=formula-sum]
Tc          1338.76;      // K   [origin=predictive method=joback]
Pc          6.754;      // bar [origin=predictive method=joback]
omega       0.4296;      // -   [origin=predictive method=lee-kesler]
Tb          1070.57;      // K   [origin=predictive method=joback]
HvapTb      104289.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.328 2.78074 -0.0016188 3.517e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 21; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 22; } { group CH; count 1; } { group dCH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-oxidanylidene-2-tridecoxy-ethyl)tetradec-3-enoic acid" "butanedioic acid, 2-(1-dodecen-1-yl)-, 4-tridecyl ester" );
gibbsFormation
{
    dHf_298   -1197500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1373.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-383200.0
    phase     gas;
}
