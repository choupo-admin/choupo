/*--------------------------------*- Choupo -*-----------------------*\
  Component: (+-)-pmhi maleate  (C20H27NO5, CAS 53305-31-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pmhiMaleate;
formula     C20H27NO5;
CAS         53305-31-0;
InChIKey    GVXPAWFMZOZNLY-BTJKTKAUSA-N;
MW          361.438;      // g/mol [origin=calculated method=formula-sum]
Tc          1367.08;      // K   [origin=predictive method=joback]
Pc          20.568;      // bar [origin=predictive method=joback]
omega       1.5371;      // -   [origin=predictive method=lee-kesler]
Tb          1110.17;      // K   [origin=predictive method=joback]
HvapTb      113830.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.039 2.20892 -0.00154748 4.262e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 2; } { group ACCH2; count 3; } { group ACOH; count 1; } { group CH2N; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group COOH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-but-2-enedioic acid;6-[(2-methylpiperidin-1-yl)methyl]-2,3-dihydro-1h-inden-5-ol" "pipecolinomethylhydroxyindane maleate" "(+-)-6-((2-methylpiperidino)methyl)-5-indanol maleate" "dl-6-(n-alpha-pipecolinomethyl)-5-hydroxy-indane maleate" "5-indanol, 6-((2-methylpiperidino)methyl)-, maleate, (+-)-" "1h-inden-5-ol, 2,3-dihydro-6-((2-methyl-1-piperidinyl)methyl)-, (z)-2-butenedioate, (+-)-" "6-(n-alpha-pipecolinomethyl)-5-hydroxy-indane maleate" "(z)-but-2-enedioic acid; 6-[(2-methylpiperidin-1-yl)methyl]-2,3-dihydro-1h-inden-5-ol" "1h-inden-5-ol, 2,3-dihydro-6-((2-methyl-1-piperidinyl)methyl)-, (z)-2-butenedioate (1:1) (salt)" );
gibbsFormation
{
    dHf_298   -893640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     967.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-440520.0
    phase     gas;
}
