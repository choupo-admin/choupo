/*--------------------------------*- Choupo -*-----------------------*\
  Component: propionaldehyde  (C3H6O, CAS 123-38-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propionaldehyde;
formula     C3H6O;
CAS         123-38-6;
InChIKey    NBBJYMSMWIIQGU-UHFFFAOYSA-N;
MW          58.08;      // g/mol [origin=calculated method=formula-sum]
Tc          489.50;      // K   [origin=predictive method=joback]
Pc          48.766;      // bar [origin=predictive method=joback]
omega       0.3096;      // -   [origin=predictive method=lee-kesler]
Tb          316.90;      // K   [origin=predictive method=joback]
HvapTb      28992.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.561 0.26332 -0.0001324 2.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propanal" "propaldehyde" "methylacetaldehyde" "propionic aldehyde" "propanaldehyde" "propylaldehyde" "propional" "n-propanal" "propylic aldehyde" "aldehyde propionique" "propyl aldehyde" "n-propionaldehyde" );
gibbsFormation
{
    dHf_298   -190830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     291.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125140.0
    phase     gas;
}
