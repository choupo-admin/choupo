/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(16-methylheptadec-16-en-1-yl)butanedioic acid  (C22H40O4, CAS 152375-75-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        216Methylheptadec16En1YlButanedioicAcid;
formula     C22H40O4;
CAS         152375-75-2;
InChIKey    XZFVXANAQPHQBR-UHFFFAOYSA-N;
MW          368.558;      // g/mol [origin=calculated method=formula-sum]
Tc          1213.64;      // K   [origin=predictive method=joback]
Pc          10.426;      // bar [origin=predictive method=joback]
omega       0.9919;      // -   [origin=predictive method=lee-kesler]
Tb          990.10;      // K   [origin=predictive method=joback]
HvapTb      97916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.274 2.18122 -0.0013466 3.253e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH; count 1; } { group CH2=C; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(16-methylheptadec-16-enyl)butanedioic acid" "butanedioic acid, isooctadecenyl-" "butanedioic acid, 2-(isooctadecen-1-yl)-" "isooctadecenylsuccinic acid" );
gibbsFormation
{
    dHf_298   -1087590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1100.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-476610.0
    phase     gas;
}
