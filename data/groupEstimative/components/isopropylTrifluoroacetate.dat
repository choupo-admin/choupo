/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyl trifluoroacetate  (C5H7F3O2, CAS 400-38-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylTrifluoroacetate;
formula     C5H7F3O2;
CAS         400-38-4;
InChIKey    ASAXRKSDVDALDT-UHFFFAOYSA-N;
MW          156.103;      // g/mol [origin=calculated method=formula-sum]
Tc          527.56;      // K   [origin=predictive method=joback]
Pc          30.830;      // bar [origin=predictive method=joback]
omega       0.4428;      // -   [origin=predictive method=lee-kesler]
Tb          366.36;      // K   [origin=predictive method=joback]
HvapTb      29996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.87 0.59114 -0.0003778 7.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group C; count 1; } { group F; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl 2,2,2-tris(fluoranyl)ethanoate" "trifluoroacetic acid isopropyl ester" "acetic acid, trifluoro-, 1-methylethyl ester" "isopropyltrifluoroacetate" "iso-propyl trifluoroacetate" "isopropyl 2,2,2-trifluoroacetate" "methylethyl 2,2,2-trifluoroacetate" "propan-2-yl 2,2,2-trifluoroacetate" "2,2,2-trifluoroacetic acid propan-2-yl ester" "acetic acid,2,2,2-trifluoro-, 1-methylethyl ester" );
gibbsFormation
{
    dHf_298   -1066170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-903180.0
    phase     gas;
}
