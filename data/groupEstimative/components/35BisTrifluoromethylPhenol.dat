/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-bis(trifluoromethyl)phenol  (C8H4F6O, CAS 349-58-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35BisTrifluoromethylPhenol;
formula     C8H4F6O;
CAS         349-58-6;
InChIKey    ODSXJQYJADZFJX-UHFFFAOYSA-N;
MW          230.107;      // g/mol [origin=calculated method=formula-sum]
Tc          672.25;      // K   [origin=predictive method=joback]
Pc          32.541;      // bar [origin=predictive method=joback]
omega       0.6720;      // -   [origin=predictive method=lee-kesler]
Tb          484.08;      // K   [origin=predictive method=joback]
HvapTb      41860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.31 1.1024 -0.00107392 3.951e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 6; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-di(trifluoromethyl)phenol" "phenol, 3,5-bis(trifluoromethyl)-" "alpha,alpha,alpha,alpha',alpha',alpha'-hexafluoro-3,5-xylenol" "mbt-oh" "3,5-ditrifluoromethylphenol" "3,5-bis-trifluoromethylphenol" "3 5-bis(trifluoromethyl)phenol" "3,5-bis-(trifluoromethyl)phenol" "odsxjqyjadzfjx-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -1354860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1198540.0
}
