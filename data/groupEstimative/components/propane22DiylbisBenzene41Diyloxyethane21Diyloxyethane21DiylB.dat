/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane-2,2-diylbis(benzene-4,1-diyloxyethane-2,1-diyloxyethane-2,1-diyl) bisprop-2-enoate  (C29H36O8, CAS 56361-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propane22DiylbisBenzene41Diyloxyethane21Diyloxyethane21DiylB;
formula     C29H36O8;
CAS         56361-55-8;
InChIKey    DTCQGQSGPULSES-UHFFFAOYSA-N;
MW          512.599;      // g/mol [origin=calculated method=formula-sum]
Tc          1376.95;      // K   [origin=predictive method=joback]
Pc          9.045;      // bar [origin=predictive method=joback]
omega       0.8574;      // -   [origin=predictive method=lee-kesler]
Tb          1122.69;      // K   [origin=predictive method=joback]
HvapTb      107842.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.678 2.20544 -0.00106652 1.084e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group CH2=CH; count 2; } { group ACH; count 8; } { group AC; count 4; } { group CH2O; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[4-[2-[4-[2-(2-prop-2-enoyloxyethoxy)ethoxy]phenyl]propan-2-yl]phenoxy]ethoxy]ethyl prop-2-enoate" "2-propenoic acid, (1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyl) ester" "2-propenoic acid, 1,1'-((1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyl)) ester" "2-propenoic acid, 1,1'-[(1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyl)] ester" "2-propenoic acid,1,1'-[(1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyl)]ester" "2-propenoicacid, (1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyl)ester (9ci); 2,2-bis(4-acryloxyethoxyethoxyphenyl)propane;2,2-bis(4-acryloyloxydiethoxyphenyl)propane;2,2-bis[4-acryloyloxydi(ethyleneoxy)phenyl]propane; a-bpe 4; aronix to 1437;beam set 750; bisphenol a diethylene glycol diacrylate; nk ester a-bpe 4" );
standardThermochemistry
{
    dHf_298   -1113100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1160.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-463360.0
}
