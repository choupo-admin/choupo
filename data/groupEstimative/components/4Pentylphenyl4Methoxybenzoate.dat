/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pentylphenyl 4-methoxybenzoate  (C19H22O3, CAS 38444-13-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pentylphenyl4Methoxybenzoate;
formula     C19H22O3;
CAS         38444-13-2;
InChIKey    UISXVYOLBGBYCV-UHFFFAOYSA-N;
MW          298.382;      // g/mol [origin=calculated method=formula-sum]
Tc          997.38;      // K   [origin=predictive method=joback]
Pc          17.047;      // bar [origin=predictive method=joback]
omega       0.9172;      // -   [origin=predictive method=lee-kesler]
Tb          778.28;      // K   [origin=predictive method=joback]
HvapTb      73581.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.686 1.41404 -0.00073252 1.042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-pentylphenyl) 4-methoxybenzoate" "4-n-pentylphenyl p-anisate" "benzoic acid, 4-methoxy-, 4-pentylphenyl ester" "p-pentylphenyl p-anisate" "4-amylphenyl 4'-methoyxbenzoate" "4-pentylphenyl-4'-methoxylbenzoate" "4-methoxybenzoic acid 4-pentylphenyl ester" "benzoic acid,4-methoxy-, 4-pentylphenyl ester" "4-methoxybenzoic acid-4'-(n-pentyl)phenol ester" "4-amylphenyl 4 inverted exclamation marka-methoyxbenzoate" "4-amylphenyl4'-methoxybenzoate; 4-pentylphenyl 4-methoxybenzoate; 4-pentylphenyl4-methyloxybenzoate; 4-n-pentylphenyl p-anisate; me 10.5; n 86; nematel 105;p-amylphenyl p-methoxybenzoate; p-pentylphenyl p-anisate; p-pentylphenylp-methoxybenzoate" );
gibbsFormation
{
    dHf_298   -434870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     733.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-100710.0
    phase     gas;
}
