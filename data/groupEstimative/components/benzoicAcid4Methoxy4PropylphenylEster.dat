/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 4-methoxy-, 4-propylphenyl ester  (C17H18O3, CAS 50649-28-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid4Methoxy4PropylphenylEster;
formula     C17H18O3;
CAS         50649-28-0;
InChIKey    YQNHZOBOLKKSLP-UHFFFAOYSA-N;
MW          270.328;      // g/mol [origin=calculated method=formula-sum]
Tc          958.22;      // K   [origin=predictive method=joback]
Pc          20.109;      // bar [origin=predictive method=joback]
omega       0.8441;      // -   [origin=predictive method=lee-kesler]
Tb          732.52;      // K   [origin=predictive method=joback]
HvapTb      69129.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.868 1.22404 -0.00062372 8.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-propylphenyl) 4-methoxybenzoate" "4-propylphenyl p-anisate" "4-methoxybenzoic acid, 4-n-propylphenyl ester" );
gibbsFormation
{
    dHf_298   -393590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     655.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-117550.0
    phase     gas;
}
