/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dipropylnicotinamide  (C12H18N2O, CAS 10052-09-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDipropylnicotinamide;
formula     C12H18N2O;
CAS         10052-09-2;
InChIKey    WQTZSTUJSCNCBZ-UHFFFAOYSA-N;
MW          206.289;      // g/mol [origin=calculated method=formula-sum]
Tc          833.50;      // K   [origin=predictive method=joback]
Pc          25.585;      // bar [origin=predictive method=joback]
omega       0.7812;      // -   [origin=predictive method=lee-kesler]
Tb          620.85;      // K   [origin=predictive method=joback]
HvapTb      59581.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.196 1.1946 -0.00076336 1.8726e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C5H4N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group CdO; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dipropylpyridine-3-carboxamide" "nicotinamide, n,n-dipropyl-" "nicotinamide, n,n-dipropyl-," "3-pyridinecarboxamide,n,n-dipropyl-" );
gibbsFormation
{
    dHf_298   -66740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=221480.0
    phase     gas;
}
