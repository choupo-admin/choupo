/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-chlorobenzyl)pyridine  (C12H10ClN, CAS 4350-41-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24ChlorobenzylPyridine;
formula     C12H10ClN;
CAS         4350-41-8;
InChIKey    XSVWMIMFDMJQRL-UHFFFAOYSA-N;
MW          203.669;      // g/mol [origin=calculated method=formula-sum]
Tc          886.04;      // K   [origin=predictive method=joback]
Pc          32.320;      // bar [origin=predictive method=joback]
omega       0.5333;      // -   [origin=predictive method=lee-kesler]
Tb          623.63;      // K   [origin=predictive method=joback]
HvapTb      58115.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.579 0.96706 -0.00065402 1.685e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group C5H4N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group Cl; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(4-chlorophenyl)methyl]pyridine" "2-(para-chlorobenzyl)-pyridine" "2-(p-chlorobenzyl)pyridine" "2-(4'-chlorobenzyl)pyridine" "xsvwmimfdmjqrl-uhfffaoysa-" "pyridine,2-[(4-chlorophenyl)methyl]-" "k984" "pyridine,2-(p-chlorobenzyl)- (7ci,8ci);2-(p-chlorobenzyl)pyridine;" );
gibbsFormation
{
    dHf_298   187630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=330470.0
    phase     gas;
}
