/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(perfluorobutyl)-2-hydroxypropyl acrylate  (C10H9F9O3, CAS 98573-25-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Perfluorobutyl2HydroxypropylAcrylate;
formula     C10H9F9O3;
CAS         98573-25-2;
InChIKey    MMZXPRQMECEMRJ-UHFFFAOYSA-N;
MW          348.161;      // g/mol [origin=calculated method=formula-sum]
Tc          700.82;      // K   [origin=predictive method=joback]
Pc          17.955;      // bar [origin=predictive method=joback]
omega       1.1172;      // -   [origin=predictive method=lee-kesler]
Tb          555.55;      // K   [origin=predictive method=joback]
HvapTb      48345.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.248 1.5283 -0.0013169 4.154e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } { group CF3; count 1; } { group CF2; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group C; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 9; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4,4,5,5,6,6,7,7,7-nonakis(fluoranyl)-2-oxidanyl-heptyl] prop-2-enoate" "3-(nonafluorobutyl)-2-hydroxypropyl acrylate" "(4,4,5,5,6,6,7,7,7-nonafluoro-2-hydroxy-heptyl) prop-2-enoate" "(4,4,5,5,6,6,7,7,7-nonafluoro-2-hydroxyheptyl) prop-2-enoate" "4,4,5,5,6,6,7,7,7-nonafluoro-2-hydroxyheptyl prop-2-enoate" "2-propenoic acid (4,4,5,5,6,6,7,7,7-nonafluoro-2-hydroxyheptyl) ester" );
standardThermochemistry
{
    dHf_298   -2399080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     763.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2070400.0
}
