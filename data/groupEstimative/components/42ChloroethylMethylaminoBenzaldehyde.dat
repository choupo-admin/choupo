/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-((2-chloroethyl)methylamino)benzaldehyde  (C10H12ClNO, CAS 94-31-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H12ClNO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        42ChloroethylMethylaminoBenzaldehyde;
formula     C10H12ClNO;
CAS         94-31-5;
InChIKey    IYFULQJDHJGQKQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          197.662;      // g/mol [origin=calculated method=formula-sum]
Tc          694.81;      // K   [origin=predictive method=joback]
Pc          28.999;      // bar [origin=predictive method=joback]
omega       0.4565;      // -   [origin=predictive method=lee-kesler]
Tb          486.35;      // K   [origin=predictive method=joback]
HvapTb      44847.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.108 0.95422 -0.00077036 2.515e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH3N; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-chloroethyl(methyl)amino]benzaldehyde" "4-((2-chloroethyl)(methyl)amino)benzaldehyde" "benzaldehyde, 4-((2-chloroethyl)methylamino)-" "benzaldehyde, 4-[(2-chloroethyl)methylamino]-" "p-((2-chloroethyl)methylamino)benzaldehyde" "4-(n-methyl-n-(beta-chloroethyl))aminobenzaldehyde" );
standardThermochemistry
{
    dHf_298   103570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=278910.0
}
