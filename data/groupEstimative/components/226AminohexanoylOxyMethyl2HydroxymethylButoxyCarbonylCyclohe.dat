/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-{[2-{[(6-aminohexanoyl)oxy]methyl}-2-(hydroxymethyl)butoxy]carbonyl}cyclohexanecarboxylic acid  (C20H35NO7, CAS 69178-39-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        226AminohexanoylOxyMethyl2HydroxymethylButoxyCarbonylCyclohe;
formula     C20H35NO7;
CAS         69178-39-8;
InChIKey    CPEPBVDDMUAZAA-UHFFFAOYSA-N;
MW          401.5;      // g/mol [origin=calculated method=formula-sum]
Tc          1344.77;      // K   [origin=predictive method=joback]
Pc          13.728;      // bar [origin=predictive method=joback]
omega       1.2219;      // -   [origin=predictive method=lee-kesler]
Tb          1095.51;      // K   [origin=predictive method=joback]
HvapTb      118236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.231 2.16232 -0.0012188 2.147e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } { group CH2COO; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(6-azanylhexanoyloxymethyl)-2-(hydroxymethyl)butoxy]carbonylcyclohexane-1-carboxylic acid" "1,2-cyclohexanedicarboxylic acid, 1-(2-(((6-amino-1-oxohexyl)oxy)methyl)-2-(hydroxymethyl)butyl) ester" "1,2-cyclohexanedicarboxylic acid, 1-[2-[[(6-amino-1-oxohexyl)oxy]methyl]-2-(hydroxymethyl)butyl] ester" "1,2-cyclohexanedicarboxylic acid, mono(2-(((6-amino-1-oxohexyl)oxy)methyl)-2-(hydroxymethyl)butyl) ester" "1,2-cyclohexanedicarboxylic acid, mono[2-[[(6-amino-1-oxohexyl)oxy]methyl]-2-(hydroxymethyl)butyl] ester" "(2-(((6-amino-1-oxohexyl)oxy)methyl)-2-(hydroxymethyl)butyl) hydrogen cyclohexane-1,2-dicarboxylate" "2-[2-(6-aminohexanoyloxymethyl)-2-(hydroxymethyl)butoxy]carbonylcyclohexane-1-carboxylic acid" );
gibbsFormation
{
    dHf_298   -1534170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1081.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-897920.0
    phase     gas;
}
