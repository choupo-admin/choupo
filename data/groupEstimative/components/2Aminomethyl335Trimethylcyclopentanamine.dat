/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(aminomethyl)-3,3,5-trimethylcyclopentanamine  (C9H20N2, CAS 67907-32-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Aminomethyl335Trimethylcyclopentanamine;
formula     C9H20N2;
CAS         67907-32-8;
InChIKey    QKHWUKPTSMULMZ-UHFFFAOYSA-N;
MW          156.273;      // g/mol [origin=calculated method=formula-sum]
Tc          774.12;      // K   [origin=predictive method=joback]
Pc          29.473;      // bar [origin=predictive method=joback]
omega       0.5658;      // -   [origin=predictive method=lee-kesler]
Tb          552.09;      // K   [origin=predictive method=joback]
HvapTb      55089.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.969 1.32676 -0.0010464 3.708e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group CH2NH2; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group C_ring; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(aminomethyl)-3,3,5-trimethyl-cyclopentan-1-amine" "cyclopentanemethanamine, 5-amino-2,2,4-trimethyl-" "1-amino-2-aminomethyl-3,3,5-trimethylcyclopentane" "agn-pc-00hrde" "5-aminomethyl-2,4,4-trimethyl-1-cyclopentylamine" "2-(aminomethyl)-3,3,5-trimethylcyclopentan-1-amine" );
gibbsFormation
{
    dHf_298   -146810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=165730.0
    phase     gas;
}
