/*--------------------------------*- Choupo -*-----------------------*\
  Component: isoamyl mandelate  (C13H18O3, CAS 5421-04-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isoamylMandelate;
formula     C13H18O3;
CAS         5421-04-5;
InChIKey    KQQXUARABJGCMS-UHFFFAOYSA-N;
MW          222.284;      // g/mol [origin=calculated method=formula-sum]
Tc          869.50;      // K   [origin=predictive method=joback]
Pc          24.459;      // bar [origin=predictive method=joback]
omega       1.0919;      // -   [origin=predictive method=lee-kesler]
Tb          673.24;      // K   [origin=predictive method=joback]
HvapTb      70118.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.498 1.15094 -0.0006568 1.207e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutyl 2-oxidanyl-2-phenyl-ethanoate" "spasmostenyl" "atractyl" "mandaverm" "spasmol" "vermiparin" "mandelic acid isoamyl ester" "mandelic acid, isopentyl ester" "isopentyl phenylglycolate" "dl-mandelic acid isoamyl ester" "3-methylbutyl 2-hydroxy-2-phenylacetate" "alpha-hydroxy-3-methylbutyl benzeneacetate" );
standardThermochemistry
{
    dHf_298   -555190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-281080.0
}
