  Component: compound 77/735  (C21H28O2, CAS 4468-39-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        compound77735;
formula     C21H28O2;
CAS         4468-39-7;
InChIKey    VTMTVAPRBUVDRK-UHFFFAOYSA-N;
MW          312.453;      // g/mol [origin=calculated method=formula-sum]
Tc          1003.86;      // K   [origin=predictive method=joback]
Pc          14.568;      // bar [origin=predictive method=joback]
omega       0.8526;      // -   [origin=predictive method=lee-kesler]
Tb          787.36;      // K   [origin=predictive method=joback]
HvapTb      72260.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.777 1.60748 -0.00083132 1.293e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-ethyl-3-(4-methoxyphenyl)pentyl]-4-methoxy-benzene" "cdri 77/735" "3-(p-methoxybenzyl)-4-(p-methoxyphenyl)hexane" "hexane, 3-(p-methoxybenzyl)-4-(p-methoxyphenyl)-" "1-[2-ethyl-3-(4-methoxyphenyl)pentyl]-4-methoxybenzene" "3-(p-methoxybenzyl)-4-(p-methoxyphen-yl)hexane" "benzene, 1,1'-(1,2-diethyl-1,3-propanediyl)bis(4-methoxy-" "benzene, 1,1'-(1,2-diethyl-1,3-propanediyl)bis(4-methoxy- (9ci)" );
gibbsFormation
{
    dHf_298   -301650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     752.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116620.0
    phase     gas;
}
