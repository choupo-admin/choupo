/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hexatriacontanamine  (C36H75N, CAS 45313-33-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hexatriacontanamine;
formula     C36H75N;
CAS         45313-33-5;
InChIKey    SFIQSZSYVWZJPM-UHFFFAOYSA-N;
MW          522.003;      // g/mol [origin=calculated method=formula-sum]
Tc          1423.97;      // K   [origin=predictive method=joback]
Pc          4.691;      // bar [origin=predictive method=joback]
omega       -0.0593;      // -   [origin=predictive method=lee-kesler]
Tb          1095.81;      // K   [origin=predictive method=joback]
HvapTb      106371.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.345 3.48572 -0.001978 4.282e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 34; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 35; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexatriacontan-1-amine" );
standardThermochemistry
{
    dHf_298   -752580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1609.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=318690.0
}
