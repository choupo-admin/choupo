/*--------------------------------*- Choupo -*-----------------------*\
  Component: octyl trichloroacetate  (C10H17Cl3O2, CAS 16958-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octylTrichloroacetate;
formula     C10H17Cl3O2;
CAS         16958-78-4;
InChIKey    GNKXBEJZRKOBKI-UHFFFAOYSA-N;
MW          275.594;      // g/mol [origin=calculated method=formula-sum]
Tc          789.60;      // K   [origin=predictive method=joback]
Pc          19.492;      // bar [origin=predictive method=joback]
omega       0.7188;      // -   [origin=predictive method=lee-kesler]
Tb          595.68;      // K   [origin=predictive method=joback]
HvapTb      57120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.407 1.04522 -0.0006586 1.496e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CCl3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group C; count 1; } { group Cl; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octyl 2,2,2-tris(chloranyl)ethanoate" "trichloroacetic acid, octyl ester" "acetic acid, trichloro-, octyl ester" "octyl 2,2,2-trichloroacetate" "acetic acid,2,2,2-trichloro-, octyl ester" );
standardThermochemistry
{
    dHf_298   -622980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     658.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-310000.0
}
