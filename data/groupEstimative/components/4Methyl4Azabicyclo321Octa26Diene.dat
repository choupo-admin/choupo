/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-4-azabicyclo[3.2.1]octa-2,6-diene  (C8H11N, CAS 56125-88-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl4Azabicyclo321Octa26Diene;
formula     C8H11N;
CAS         56125-88-3;
InChIKey    BIOUIIIKCOKSDX-UHFFFAOYSA-N;
MW          121.183;      // g/mol [origin=calculated method=formula-sum]
Tc          614.46;      // K   [origin=predictive method=joback]
Pc          37.592;      // bar [origin=predictive method=joback]
omega       0.3511;      // -   [origin=predictive method=lee-kesler]
Tb          411.15;      // K   [origin=predictive method=joback]
HvapTb      36027.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.12 1.06792 -0.00089256 2.985e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group CH=CH; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azabicyclo(3.2.1)octa-3,6-diene, 2-methyl-" );
standardThermochemistry
{
    dHf_298   114080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     248.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=296580.0
}
