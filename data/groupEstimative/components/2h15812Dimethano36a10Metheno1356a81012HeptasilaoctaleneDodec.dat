/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-1,5:8,12-dimethano-3,6a,10-metheno-1,3,5,6a,8,10,12-heptasilaoctalene,dodecahydro-1,3,5,8,10,12-hexamethyl-  (C16H36Si7, CAS 26393-20-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H36Si7 (delta Si+7; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2h15812Dimethano36a10Metheno1356a81012HeptasilaoctaleneDodec;
formula     C16H36Si7;
CAS         26393-20-4;
InChIKey    RRANPQQLNBKFGG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          425.059;      // g/mol [origin=calculated method=formula-sum]
Tc          821.77;      // K   [origin=predictive method=joback]
Pc          12.040;      // bar [origin=predictive method=joback]
omega       0.2539;      // -   [origin=predictive method=lee-kesler]
Tb          600.44;      // K   [origin=predictive method=joback]
HvapTb      52606.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.17 1.16872 0.000143 -3.934e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 8; } { group CH; count 2; } { group Si; count 7; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2_ring; count 8; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,7,9,11,13-hexamethyl-1,3,5,7,9,11,13-heptasilahexacyclo[7.5.1.13,13.17,11.05,12.05,15]heptadecane (non-preferred name)" "2h-1,5:8,12-dimethano-3,6a,10-metheno-1,3,5,6a,8,10,12-heptasilaoctalene, dodecahydro-1,3,5,8,10,12-hexamethyl-" );
standardThermochemistry
{
    dHf_298   -587470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1133.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-157340.0
}
