/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethyl methyl ether  (C2H5ClO, CAS 107-30-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloromethylMethylEther;
formula     C2H5ClO;
CAS         107-30-2;
InChIKey    XJUZRXYOEPSWMB-UHFFFAOYSA-N;
MW          80.511;      // g/mol [origin=calculated method=formula-sum]
Tc          477.97;      // K   [origin=predictive method=joback]
Pc          46.657;      // bar [origin=predictive method=joback]
omega       0.2464;      // -   [origin=predictive method=lee-kesler]
Tb          305.21;      // K   [origin=predictive method=joback]
HvapTb      26841.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.461 0.13742 5.6e-06 -3.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranyl(methoxy)methane" "methane, chloromethoxy-" "methoxymethyl chloride" "chlorodimethyl ether" "cmme" "chloro(methoxy)methane" "chloromethoxymethane" "methoxychloromethane" "methyl chloromethyl ether" "ether, chloromethyl methyl" "dimethylchloroether" "ether, dimethyl chloro" );
standardThermochemistry
{
    dHf_298   -232570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     278.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-150970.0
}
