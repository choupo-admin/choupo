/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-isopropyl-n-methyl-tert-butylamine  (C8H19N, CAS 85523-00-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nIsopropylNMethylTertButylamine;
formula     C8H19N;
CAS         85523-00-8;
InChIKey    WYLLBTPEHIVUKV-UHFFFAOYSA-N;
MW          129.247;      // g/mol [origin=calculated method=formula-sum]
Tc          568.32;      // K   [origin=predictive method=joback]
Pc          26.004;      // bar [origin=predictive method=joback]
omega       0.3335;      // -   [origin=predictive method=lee-kesler]
Tb          391.41;      // K   [origin=predictive method=joback]
HvapTb      33761.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.23 1.01952 -0.000699 1.928e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH; count 1; } { group C; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 1; } { group C; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,2-dimethyl-n-propan-2-yl-propan-2-amine" "n,2-dimethyl-n-propan-2-ylpropan-2-amine" );
standardThermochemistry
{
    dHf_298   -154950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127660.0
}
