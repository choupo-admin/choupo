/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentamethyl benzenepentacarboxylate  (C16H16O10, CAS 3327-06-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentamethylBenzenepentacarboxylate;
formula     C16H16O10;
CAS         3327-06-8;
InChIKey    UVKUTUMTHIGYKO-UHFFFAOYSA-N;
MW          368.294;      // g/mol [origin=calculated method=formula-sum]
Tc          1117.52;      // K   [origin=predictive method=joback]
Pc          16.551;      // bar [origin=predictive method=joback]
omega       1.2857;      // -   [origin=predictive method=lee-kesler]
Tb          903.38;      // K   [origin=predictive method=joback]
HvapTb      93169.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (138.68 0.933 -0.00013664 -1.804e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group ACH; count 1; } { group AC; count 5; } { group COO; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group COO; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentamethyl benzene-1,2,3,4,5-pentacarboxylate" "benzenepentacarboxylic acid, pentamethyl ester" );
gibbsFormation
{
    dHf_298   -1769320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     904.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1394120.0
    phase     gas;
}
