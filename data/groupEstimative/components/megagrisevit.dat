/*--------------------------------*- Choupo -*-----------------------*\
  Component: megagrisevit  (C21H29ClO3, CAS 855-19-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        megagrisevit;
formula     C21H29ClO3;
CAS         855-19-6;
InChIKey    XYGMEFJSKQEBTO-KUJXMBTLSA-N;
MW          364.91;      // g/mol [origin=calculated method=formula-sum]
Tc          1141.27;      // K   [origin=predictive method=joback]
Pc          15.307;      // bar [origin=predictive method=joback]
omega       0.8569;      // -   [origin=predictive method=lee-kesler]
Tb          892.12;      // K   [origin=predictive method=joback]
HvapTb      77587.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-219.77 2.69396 -0.0022568 8.193e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 4; } { group C; count 2; } { group CH2CO; count 1; } { group CH3COO; count 1; } { group Cl_C=C_; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dC_ring; count 2; } { group Cl; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8r,9s,10r,13s,14s,17s)-4-chloranyl-10,13-dimethyl-3-oxidanylidene-1,2,6,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-17-yl] ethanoate" "stearanabol" "anabolit" "macrobin" "sterabol" "steranabol" "testomed" "test-anabol" "clostebol acetate" "4-chlorotestosterone acetate" "4-chlorotestosterone 17-acetate" "chlorotestosterone acetate" );
standardThermochemistry
{
    dHf_298   -662450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     723.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-152150.0
}
