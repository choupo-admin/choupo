/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyltriethoxysilane  (C8H20O3Si, CAS 78-07-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H20O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethyltriethoxysilane;
formula     C8H20O3Si;
CAS         78-07-9;
InChIKey    DENFJSAFJTVPJR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          192.33;      // g/mol [origin=calculated method=formula-sum]
Tc          620.99;      // K   [origin=predictive method=joback]
Pc          21.493;      // bar [origin=predictive method=joback]
omega       0.5225;      // -   [origin=predictive method=lee-kesler]
Tb          451.30;      // K   [origin=predictive method=joback]
HvapTb      40926.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (112.934 0.36808 0.0003364 -2.976e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH2O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethoxy(ethyl)silane" "silane, triethoxyethyl-" "a 15 (silane)" "triethoxy-ethylsilane" "union carbide a-15" "silane, ethyl triethoxy a-15" "silane, ethyltriethoxy-" "ethaneorthosiliconic acid, triethyl ester" "ethyl triethoxysilane" "silane,ethyl,trimethoxy" );
gibbsFormation
{
    dHf_298   -716730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-403280.0
    phase     gas;
}
