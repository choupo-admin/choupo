/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-acetoxy-2-methoxy-4-(1-propenyl)benzene  (C12H14O3, CAS 93-29-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Acetoxy2Methoxy41PropenylBenzene;
formula     C12H14O3;
CAS         93-29-8;
InChIKey    IUSBVFZKQJGVEP-UHFFFAOYSA-N;
MW          206.241;      // g/mol [origin=calculated method=formula-sum]
Tc          807.83;      // K   [origin=predictive method=joback]
Pc          24.290;      // bar [origin=predictive method=joback]
omega       0.6786;      // -   [origin=predictive method=lee-kesler]
Tb          595.60;      // K   [origin=predictive method=joback]
HvapTb      55681.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.4 0.84796 -0.00040432 4.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH3COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methoxy-4-prop-1-enyl-phenyl) ethanoate" "acetoisoeugenol" "acetyl iso-eugenol" "phenol, 2-methoxy-4-(1-propen-1-yl)-, 1-acetate" "(2-methoxy-4-prop-1-enylphenyl) acetate" );
gibbsFormation
{
    dHf_298   -409700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-191840.0
    phase     gas;
}
