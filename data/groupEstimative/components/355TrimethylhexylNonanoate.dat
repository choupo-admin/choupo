/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5,5-trimethylhexyl nonanoate  (C18H36O2, CAS 67923-51-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        355TrimethylhexylNonanoate;
formula     C18H36O2;
CAS         67923-51-7;
InChIKey    HSAPRRNIACHOPX-UHFFFAOYSA-N;
MW          284.484;      // g/mol [origin=calculated method=formula-sum]
Tc          839.03;      // K   [origin=predictive method=joback]
Pc          11.777;      // bar [origin=predictive method=joback]
omega       0.8053;      // -   [origin=predictive method=lee-kesler]
Tb          665.99;      // K   [origin=predictive method=joback]
HvapTb      61385.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.22 1.7908 -0.0010358 2.173e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 9; } { group CH; count 1; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 10; } { group CH; count 1; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonanoic acid 3,5,5-trimethylhexyl ester" "nonanoic acid, 3,5,5-trimethylhexyl ester" "3,5,5-trimethylhexyl nonan-1-oate" );
gibbsFormation
{
    dHf_298   -746160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     860.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209290.0
    phase     gas;
}
