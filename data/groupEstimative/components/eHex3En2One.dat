/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-hex-3-en-2-one  (C6H10O, CAS 4376-23-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eHex3En2One;
formula     C6H10O;
CAS         4376-23-2;
InChIKey    LPCWMYHBLXLJJQ-SNAWJCMRSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          581.85;      // K   [origin=predictive method=joback]
Pc          35.473;      // bar [origin=predictive method=joback]
omega       0.3912;      // -   [origin=predictive method=lee-kesler]
Tb          394.91;      // K   [origin=predictive method=joback]
HvapTb      35654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.389 0.56584 -0.0003677 9.856e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butenyl methyl ketone" "3-hexen-2-one" "(e)-3-hexen-2-one" "3-hexen-2-one(e)" "3e-hexene-2-one" );
gibbsFormation
{
    dHf_298   -162530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49060.0
    phase     gas;
}
