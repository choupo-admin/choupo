/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-methoxyphenoxy)acetic acid  (C9H10O4, CAS 2088-24-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethoxyphenoxyAceticAcid;
formula     C9H10O4;
CAS         2088-24-6;
InChIKey    AHDPQRIYMMZJTF-UHFFFAOYSA-N;
MW          182.175;      // g/mol [origin=calculated method=formula-sum]
Tc          846.91;      // K   [origin=predictive method=joback]
Pc          34.159;      // bar [origin=predictive method=joback]
omega       0.9020;      // -   [origin=predictive method=lee-kesler]
Tb          627.53;      // K   [origin=predictive method=joback]
HvapTb      60550.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.701 0.64482 -0.00028056 1.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-methoxyphenoxy)ethanoic acid" "3-methoxyphenoxyacetic acid" "2-(3-methoxyphenoxy)acetic acid" "m-methoxy phenoxy acetic acid" "m-methoxyphenoxyacetic acid" "acetic acid, (3-methoxyphenoxy)-" "acetic acid,2-(3-methoxyphenoxy)-" );
standardThermochemistry
{
    dHf_298   -618740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-426230.0
}
