/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2006947  (C24H12F2, CAS 61735-78-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2006947;
formula     C24H12F2;
CAS         61735-78-2;
InChIKey    VWZJCJJPDPIZMY-UHFFFAOYSA-N;
MW          338.356;      // g/mol [origin=calculated method=formula-sum]
Tc          1141.47;      // K   [origin=predictive method=joback]
Pc          20.073;      // bar [origin=predictive method=joback]
omega       1.0364;      // -   [origin=predictive method=lee-kesler]
Tb          891.02;      // K   [origin=predictive method=joback]
HvapTb      81196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.61 1.9282 -0.00173268 6.228e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 10; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 12; } { group dC_ring; count 12; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,10-difluorodibenzo(a,i)pyrene" "2,10-difluorobenzo(rst)pentaphene" "benzo(rst)pentaphene, 2,10-difluoro-" );
gibbsFormation
{
    dHf_298   146690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=343700.0
    phase     gas;
}
