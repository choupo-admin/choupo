/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-mentha-1(7),3-diene  (C10H16, CAS 99-84-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pMentha173Diene;
formula     C10H16;
CAS         99-84-3;
InChIKey    SCWPFSIZUZUCCE-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          662.66;      // K   [origin=predictive method=joback]
Pc          27.936;      // bar [origin=predictive method=joback]
omega       0.3537;      // -   [origin=predictive method=lee-kesler]
Tb          455.48;      // K   [origin=predictive method=joback]
HvapTb      39317.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.06 0.87534 -0.00048764 9.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylidene-1-propan-2-yl-cyclohexene" "cyclohexene, 4-methylene-1-(1-methylethyl)-" "b-terpinene" "4-methylidene-1-propan-2-ylcyclohexene" "4-methylidene-1-(propan-2-yl)cyclohexene" );
gibbsFormation
{
    dHf_298   -49800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136450.0
    phase     gas;
}
