/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-[(benzyloxy)methylene]bis(n,n-dimethylaniline)  (C24H28N2O, CAS 53370-57-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44BenzyloxyMethyleneBisNNDimethylaniline;
formula     C24H28N2O;
CAS         53370-57-3;
InChIKey    YBOBZZSJMAWFBX-UHFFFAOYSA-N;
MW          360.501;      // g/mol [origin=calculated method=formula-sum]
Tc          1120.24;      // K   [origin=predictive method=joback]
Pc          15.117;      // bar [origin=predictive method=joback]
omega       0.9565;      // -   [origin=predictive method=lee-kesler]
Tb          885.58;      // K   [origin=predictive method=joback]
HvapTb      83278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.609 2.11868 -0.00135872 3.206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 13; } { group AC; count 4; } { group ACCH; count 1; } { group CH2O; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group O; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[4-(dimethylamino)phenyl]-phenylmethoxy-methyl]-n,n-dimethyl-aniline" "benzenamine, 4,4'-((phenylmethoxy)methylene)bis(n,n-dimethyl-" "benzenamine, 4,4'-[(phenylmethoxy)methylene]bis[n,n-dimethyl-" "4,4'-((phenylmethoxy)methylene)bis(n,n'-dimethylbenzenamine)" "4,4'-[(benzyloxy)methanediyl]bis(n,n-dimethylaniline)" "4-[(4-dimethylaminophenyl)-phenylmethoxymethyl]-n,n-dimethylaniline" "4-[(4-dimethylaminophenyl)-phenylmethoxy-methyl]-n,n-dimethyl-aniline" );
gibbsFormation
{
    dHf_298   145520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     793.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=583290.0
    phase     gas;
}
