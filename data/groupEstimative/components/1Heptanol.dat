/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-heptanol  (C7H16O, CAS 111-70-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Heptanol;
formula     C7H16O;
CAS         111-70-6;
InChIKey    BBMCTIGTTCKYKF-UHFFFAOYSA-N;
MW          116.204;      // g/mol [origin=calculated method=formula-sum]
Tc          612.47;      // K   [origin=predictive method=joback]
Pc          30.933;      // bar [origin=predictive method=joback]
omega       0.8156;      // -   [origin=predictive method=lee-kesler]
Tb          451.94;      // K   [origin=predictive method=joback]
HvapTb      47855.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.816 0.70282 -0.0003874 8.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptan-1-ol" "heptanol" "n-heptanol" "enanthic alcohol" "n-heptyl alcohol" "gentanol" "1-hydroxyheptane" "n-heptan-1-ol" "hydroxyheptane" "hexyl carbinol" "hydroxy heptane" "enanthyl alcohol" );
gibbsFormation
{
    dHf_298   -340040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-128760.0
    phase     gas;
}
