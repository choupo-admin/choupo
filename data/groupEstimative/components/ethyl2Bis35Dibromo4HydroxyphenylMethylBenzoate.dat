/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-(bis(3,5-dibromo-4-hydroxyphenyl)methyl)benzoate  (C22H16Br4O4, CAS 61931-71-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Bis35Dibromo4HydroxyphenylMethylBenzoate;
formula     C22H16Br4O4;
CAS         61931-71-3;
InChIKey    KFSRWWJHWXPGQO-UHFFFAOYSA-N;
MW          663.982;      // g/mol [origin=calculated method=formula-sum]
Tc          1592.26;      // K   [origin=predictive method=joback]
Pc          30.024;      // bar [origin=predictive method=joback]
omega       1.8512;      // -   [origin=predictive method=lee-kesler]
Tb          1291.56;      // K   [origin=predictive method=joback]
HvapTb      133491.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.679 1.97272 -0.00163832 5.476e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 8; } { group AC; count 7; } { group ACCH; count 1; } { group ACOH; count 2; } { group Br; count 4; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 10; } { group Br; count 4; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-[bis[3,5-bis(bromanyl)-4-oxidanyl-phenyl]methyl]benzoate" "ethyl 2-[bis(3,5-dibromo-4-hydroxyphenyl)methyl]benzoate" "benzoic acid, 2-(bis(3,5-dibromo-4-hydroxyphenyl)methyl)-, ethyl ester" "benzoic acid, 2-[bis(3,5-dibromo-4-hydroxyphenyl)methyl]-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -417030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     961.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-141330.0
}
