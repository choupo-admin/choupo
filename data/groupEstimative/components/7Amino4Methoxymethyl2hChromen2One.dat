/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-amino-4-(methoxymethyl)-2h-chromen-2-one  (C11H11NO3, CAS 175205-10-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Amino4Methoxymethyl2hChromen2One;
formula     C11H11NO3;
CAS         175205-10-4;
InChIKey    QZZLLHOMMCKWIQ-UHFFFAOYSA-N;
MW          205.213;      // g/mol [origin=calculated method=formula-sum]
Tc          877.14;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.8948;      // -   [origin=predictive method=lee-kesler]
Tb          652.37;      // K   [origin=predictive method=joback]
HvapTb      65142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.001 0.86632 -0.00055176 1.312e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group CH3O; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-azanyl-4-(methoxymethyl)chromen-2-one" "7-amino-4-(methoxymethyl)coumarin" "7-amino-4-(methoxymethyl)chromen-2-one" "7-amino-4-methoxymethylcoumarin;" "sdccgmls-0066213.p001" "7-amino-4-(methoxymethyl)-1-benzopyran-2-one" "2h-1-benzopyran-2-one,7-amino-4-(methoxymethyl)-" );
gibbsFormation
{
    dHf_298   -326880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113140.0
    phase     gas;
}
