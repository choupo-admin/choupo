/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(ethylamino)propanenitrile  (C5H10N2, CAS 21539-47-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3EthylaminoPropanenitrile;
formula     C5H10N2;
CAS         21539-47-9;
InChIKey    RUVUQOOKKGVDNN-UHFFFAOYSA-N;
MW          98.149;      // g/mol [origin=calculated method=formula-sum]
Tc          660.24;      // K   [origin=predictive method=joback]
Pc          34.199;      // bar [origin=predictive method=joback]
omega       0.5772;      // -   [origin=predictive method=lee-kesler]
Tb          466.25;      // K   [origin=predictive method=joback]
HvapTb      43638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.133 0.48982 -0.0002658 5.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2NH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(ethylamino)propionitrile" "propionitrile, 3-(ethylamino)-" "propanenitrile, 3-(ethylamino)-" );
gibbsFormation
{
    dHf_298   71820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213790.0
    phase     gas;
}
