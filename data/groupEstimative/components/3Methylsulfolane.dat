/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylsulfolane  (C5H10O2S, CAS 872-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H10O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Methylsulfolane;
formula     C5H10O2S;
CAS         872-93-5;
InChIKey    CMJLMPKFQPJDKP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          134.193;      // g/mol [origin=calculated method=formula-sum]
Tc          461.52;      // K   [origin=predictive method=joback]
Pc          48.427;      // bar [origin=predictive method=joback]
omega       0.3757;      // -   [origin=predictive method=lee-kesler]
Tb          304.01;      // K   [origin=predictive method=joback]
HvapTb      38627.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.38 0.65932 -0.0003966 8.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylthiolane 1,1-dioxide" "3-methyl sulfolane" "thiophene, tetrahydro-3-methyl-, 1,1-dioxide" "3-methyltetrahydrothiophene 1,1-dioxide" "3-methylthiolane-1,1-dione" "thiophene,tetrahydro-3-methyl-, 1,1-dioxide" );
gibbsFormation
{
    dHf_298   -575110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-461790.0
    phase     gas;
}
