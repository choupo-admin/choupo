  Component: 1,1,5,5-tetramethyl-3,3-diphenyl-1,5-divinyltrisiloxane  (C20H28O2Si3, CAS 18586-22-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C20H28O2Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1155Tetramethyl33Diphenyl15Divinyltrisiloxane;
formula     C20H28O2Si3;
CAS         18586-22-6;
InChIKey    OOGRAMOPTBMVKO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          384.697;      // g/mol [origin=calculated method=formula-sum]
Tc          987.77;      // K   [origin=predictive method=joback]
Pc          12.884;      // bar [origin=predictive method=joback]
omega       0.5394;      // -   [origin=predictive method=lee-kesler]
Tb          752.96;      // K   [origin=predictive method=joback]
HvapTb      69028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (84.37 0.96108 0.000294 -4.486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2=CH; count 2; } { group ACH; count 10; } { group AC; count 2; } { group Si; count 1; } { group SiO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[[ethenyl(dimethyl)silyl]oxy]-diphenyl-silane" "trisiloxane, 1,5-diethenyl-1,1,5,5-tetramethyl-3,3-diphenyl-" "bis[[ethenyl(dimethyl)silyl]oxy]-diphenylsilane" "1,1,5,5-tetramethyl-3,3-diphenyl-1,5-divinyltrisiloxan;" "1,5-diethenyl-1,1,5,5-dimethyl-3,3-diphenyltrisiloxane" "trisiloxane,1,5-diethenyl-1,1,5,5-tetramethyl-3,3-diphenyl-" "1,5-divinyl-3,3-diphenyl-1,1,5,5-tetra-methyltrisiloxane" );
standardThermochemistry
{
    dHf_298   -331510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1115.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6260.0
}
