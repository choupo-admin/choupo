/*--------------------------------*- Choupo -*-----------------------*\
  Component: di-tert-butyl malonate  (C11H20O4, CAS 541-16-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diTertButylMalonate;
formula     C11H20O4;
CAS         541-16-2;
InChIKey    CLPHAYNBNTVRDI-UHFFFAOYSA-N;
MW          216.277;      // g/mol [origin=calculated method=formula-sum]
Tc          754.15;      // K   [origin=predictive method=joback]
Pc          20.181;      // bar [origin=predictive method=joback]
omega       0.6409;      // -   [origin=predictive method=lee-kesler]
Tb          561.26;      // K   [origin=predictive method=joback]
HvapTb      52302.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.239 1.19092 -0.000729 1.493e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ditert-butyl propanedioate" "malonic acid di-tert-butyl ester" "di-t-butylmalonate" "propanedioic acid, bis(1,1-dimethylethyl) ester" "propanedioic acid, 1,3-bis(1,1-dimethylethyl) ester" "di(tert-butyl) malonate" "1,3-di-tert-butyl propanedioate" "ditert-butyl propane-1,3-dioate" "bis(1,1-dimethylethyl) malonate" "propanedioic acid ditert-butyl ester" "u430" "di-tert-butyl malonate, stab. with potassium carbonate" );
standardThermochemistry
{
    dHf_298   -922430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     609.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-573320.0
}
