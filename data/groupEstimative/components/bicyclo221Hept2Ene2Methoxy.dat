/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.1]hept-2-ene, 2-methoxy-  (C8H12O, CAS 17190-90-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Hept2Ene2Methoxy;
formula     C8H12O;
CAS         17190-90-8;
InChIKey    QISDNYRVIVJFSJ-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          631.20;      // K   [origin=predictive method=joback]
Pc          34.725;      // bar [origin=predictive method=joback]
omega       0.3680;      // -   [origin=predictive method=lee-kesler]
Tb          426.95;      // K   [origin=predictive method=joback]
HvapTb      36764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.41 0.87732 -0.00061464 1.772e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group CH=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxybicyclo[2.2.1]hept-2-ene" "bicyclo(2.2.1)hept-2-ene, 2-methoxy-" "2-norbornene, 2-methoxy-" "agn-pc-00g6c8" "2-methoxybicyclo[2.2.1]hept-2-ene" "bicyclo[2.2.1]hept-2-ene,2-methoxy-" "2-norbornene,2-methoxy- (8ci); 2-methoxy-2-norbornene; 2-methoxynorbornene" );
standardThermochemistry
{
    dHf_298   -154920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     274.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41210.0
}
