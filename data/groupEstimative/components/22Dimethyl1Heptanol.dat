/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-1-heptanol  (C9H20O, CAS 14250-79-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl1Heptanol;
formula     C9H20O;
CAS         14250-79-4;
InChIKey    WENIXZFPXMQPQQ-UHFFFAOYSA-N;
MW          144.258;      // g/mol [origin=calculated method=formula-sum]
Tc          662.27;      // K   [origin=predictive method=joback]
Pc          25.741;      // bar [origin=predictive method=joback]
omega       0.8027;      // -   [origin=predictive method=lee-kesler]
Tb          494.47;      // K   [origin=predictive method=joback]
HvapTb      51011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.475 1.01866 -0.000668 1.776e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group C; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylheptan-1-ol" "2,2-dimethylheptanol" "2,2-dimethyl heptanol" "1-heptanol, 2,2-dimethyl-" );
standardThermochemistry
{
    dHf_298   -390070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-109080.0
}
