/*--------------------------------*- Choupo -*-----------------------*\
  Component: di-p-tolylacetylene  (C16H14, CAS 2789-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diPTolylacetylene;
formula     C16H14;
CAS         2789-88-0;
InChIKey    OFDOCXDLDQXWIX-UHFFFAOYSA-N;
MW          206.288;      // g/mol [origin=calculated method=formula-sum]
Tc          899.16;      // K   [origin=predictive method=joback]
Pc          25.978;      // bar [origin=predictive method=joback]
omega       0.4786;      // -   [origin=predictive method=lee-kesler]
Tb          638.00;      // K   [origin=predictive method=joback]
HvapTb      59238.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.31 1.09724 -0.00068278 1.5938e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group tC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-[2-(4-methylphenyl)ethynyl]benzene" "1-methyl-4-[2-(p-tolyl)-ethynyl]-benzene" "benzene, 1,1'-(1,2-ethynediyl)bis[4-methyl-" );
gibbsFormation
{
    dHf_298   348850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=492200.0
    phase     gas;
}
