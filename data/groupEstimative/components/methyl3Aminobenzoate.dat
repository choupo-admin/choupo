/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-aminobenzoate  (C8H9NO2, CAS 4518-10-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3Aminobenzoate;
formula     C8H9NO2;
CAS         4518-10-9;
InChIKey    VZDNXXPBYLGWOS-UHFFFAOYSA-N;
MW          151.165;      // g/mol [origin=calculated method=formula-sum]
Tc          773.29;      // K   [origin=predictive method=joback]
Pc          38.675;      // bar [origin=predictive method=joback]
omega       0.6214;      // -   [origin=predictive method=lee-kesler]
Tb          545.05;      // K   [origin=predictive method=joback]
HvapTb      54388.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.91 0.63252 -0.00032436 3.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-azanylbenzoate" "benzoic acid, 3-amino-, methyl ester" "m-aminobenzoic acid, methyl ester" "3-amino-benzoic acid methyl ester" "3-aminobenzoic acid methyl ester" "methyl m-aminobenzoate" "methyl-3-aminobenzoate" "m-aminobenzoic acid, mrthyl ester" "sdccgmls-0066265.p001" "benzoicacid, m-amino-, methyl ester (6ci,7ci,8ci); (3-(methoxycarbonyl)phenyl)amine;3-(methoxycarbonyl)aniline; 3-aminobenzoic acid methyl ester;3-carbomethoxyaniline; methyl 3-aminobenzoate; methyl 3-aminophenylcarboxylate;methyl m-aminobenzoate; m-aminobenzoic acid methyl ester" );
gibbsFormation
{
    dHf_298   -266880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124660.0
    phase     gas;
}
