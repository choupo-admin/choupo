/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenoxybutyric acid  (C10H12O3, CAS 13794-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PhenoxybutyricAcid;
formula     C10H12O3;
CAS         13794-14-4;
InChIKey    TVSPPYGAFOVROT-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          844.35;      // K   [origin=predictive method=joback]
Pc          32.028;      // bar [origin=predictive method=joback]
omega       0.8287;      // -   [origin=predictive method=lee-kesler]
Tb          622.57;      // K   [origin=predictive method=joback]
HvapTb      59316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.689 0.86842 -0.0005162 1.06e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH-O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenoxybutanoic acid" "alpha-phenoxybutyric acid" "butanoic acid, 2-phenoxy-" "2-phenoxy-butyric acid" "dl-2-phenoxybutyric acid" "butyric acid, 2-phenoxy-" ".alpha.-phenoxybutyric acid" "butanoic acid,2-phenoxy-" "butyricacid, 2-phenoxy- (6ci,7ci,8ci);butyric acid, a-phenoxy- (4ci);2-phenoxybutyric acid;dl-2-phenoxybutyric acid;a-phenoxybutyric acid;" );
standardThermochemistry
{
    dHf_298   -500970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-305620.0
}
