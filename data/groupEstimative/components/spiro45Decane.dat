/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[4.5]decane  (C10H18, CAS 176-63-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro45Decane;
formula     C10H18;
CAS         176-63-6;
InChIKey    CTDQAGUNKPRERK-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          696.47;      // K   [origin=predictive method=joback]
Pc          33.029;      // bar [origin=predictive method=joback]
omega       0.2856;      // -   [origin=predictive method=lee-kesler]
Tb          463.87;      // K   [origin=predictive method=joback]
HvapTb      37526.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-183.1 1.5356 -0.001363 5.13e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro[4.5]decan" "spiro(4-5)decane" "spirodecane" "spiro[4,5]decane" );
gibbsFormation
{
    dHf_298   -93190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108640.0
    phase     gas;
}
