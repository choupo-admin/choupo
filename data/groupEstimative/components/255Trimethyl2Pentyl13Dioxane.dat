/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5,5-trimethyl-2-pentyl-1,3-dioxane  (C12H24O2, CAS 13273-84-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        255Trimethyl2Pentyl13Dioxane;
formula     C12H24O2;
CAS         13273-84-2;
InChIKey    KZEIODCBVDXZSW-UHFFFAOYSA-N;
MW          200.322;      // g/mol [origin=calculated method=formula-sum]
Tc          749.23;      // K   [origin=predictive method=joback]
Pc          22.125;      // bar [origin=predictive method=joback]
omega       0.5253;      // -   [origin=predictive method=lee-kesler]
Tb          543.42;      // K   [origin=predictive method=joback]
HvapTb      49144.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.026 1.81728 -0.001692 6.916e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxane, 2,5,5-trimethyl-2-pentyl-" "m-dioxane,5,5-trimethyl-2-pentyl-" "methyl-n-amylketone-,2-dimethyl-1,3-propanediol ketal" "m-dioxane, 2,5,5-trimethyl-2-pentyl-" "methyl-n-amylketone-, 2,2-dimethyl-1,3-propanediol ketal" );
gibbsFormation
{
    dHf_298   -490550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116320.0
    phase     gas;
}
