/*--------------------------------*- Choupo -*-----------------------*\
  Component: succinic acid (tms)  (C10H22O4Si2, CAS 40309-57-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H22O4Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        succinicAcidTms;
formula     C10H22O4Si2;
CAS         40309-57-7;
InChIKey    QUUDZINXVRFXLB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          262.452;      // g/mol [origin=calculated method=formula-sum]
Tc          732.96;      // K   [origin=predictive method=joback]
Pc          17.246;      // bar [origin=predictive method=joback]
omega       0.5782;      // -   [origin=predictive method=lee-kesler]
Tb          547.64;      // K   [origin=predictive method=joback]
HvapTb      53256.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (126.252 0.43192 0.0004986 -4.408e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2COO; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(trimethylsilyl) butanedioate" "butanedioic acid, bis(trimethylsilyl) ester" );
standardThermochemistry
{
    dHf_298   -1107530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     901.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-796940.0
}
