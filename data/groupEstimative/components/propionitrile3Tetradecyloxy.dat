/*--------------------------------*- Choupo -*-----------------------*\
  Component: propionitrile, 3-tetradecyloxy-  (C17H33NO, CAS 68527-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propionitrile3Tetradecyloxy;
formula     C17H33NO;
CAS         68527-83-3;
InChIKey    NSEZEILPAFNORQ-UHFFFAOYSA-N;
MW          267.457;      // g/mol [origin=calculated method=formula-sum]
Tc          888.26;      // K   [origin=predictive method=joback]
Pc          11.956;      // bar [origin=predictive method=joback]
omega       0.9305;      // -   [origin=predictive method=lee-kesler]
Tb          713.06;      // K   [origin=predictive method=joback]
HvapTb      66324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.935 1.49042 -0.000759 1.3e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH2O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-tetradecoxypropanenitrile" "3-(tetradecyloxy)propanenitrile" "propanenitrile, 3-(tetradecyloxy)-" );
standardThermochemistry
{
    dHf_298   -361550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     835.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120440.0
}
