/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonane, 5-phenyl-  (C15H24, CAS 20216-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonane5Phenyl;
formula     C15H24;
CAS         20216-88-0;
InChIKey    ZUKGIZDDXAWABM-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          764.49;      // K   [origin=predictive method=joback]
Pc          18.595;      // bar [origin=predictive method=joback]
omega       0.5957;      // -   [origin=predictive method=lee-kesler]
Tb          569.04;      // K   [origin=predictive method=joback]
HvapTb      50872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.334 1.35584 -0.0008266 1.923e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonan-5-ylbenzene" "benzene, (1-butylpentyl)-" "1-butylpentylbenzene" );
gibbsFormation
{
    dHf_298   -121680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185390.0
    phase     gas;
}
