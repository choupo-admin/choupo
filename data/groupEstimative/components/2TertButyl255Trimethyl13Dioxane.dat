/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tert-butyl-2,5,5-trimethyl-1,3-dioxane  (C11H22O2, CAS 32362-65-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TertButyl255Trimethyl13Dioxane;
formula     C11H22O2;
CAS         32362-65-5;
InChIKey    WAFIPMPTSUISGI-UHFFFAOYSA-N;
MW          186.295;      // g/mol [origin=calculated method=formula-sum]
Tc          740.05;      // K   [origin=predictive method=joback]
Pc          24.727;      // bar [origin=predictive method=joback]
omega       0.3807;      // -   [origin=predictive method=lee-kesler]
Tb          517.31;      // K   [origin=predictive method=joback]
HvapTb      45622.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-156.59 1.84812 -0.0018094 7.516e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 3; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 1; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxane, 2-(1,1-dimethylethyl)-2,5,5-trimethyl-" );
gibbsFormation
{
    dHf_298   -478660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-121900.0
    phase     gas;
}
