/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-cyclopropylbenzylamine  (C10H13N, CAS 13324-66-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nCyclopropylbenzylamine;
formula     C10H13N;
CAS         13324-66-8;
InChIKey    USBAUXJPPHVCTF-UHFFFAOYSA-N;
MW          147.221;      // g/mol [origin=calculated method=formula-sum]
Tc          734.91;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       0.5060;      // -   [origin=predictive method=lee-kesler]
Tb          511.99;      // K   [origin=predictive method=joback]
HvapTb      46479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.559 1.102 -0.0008202 2.431e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(phenylmethyl)cyclopropanamine" "n-benzylcyclopropanamine" "n-benzylcyclopropylamine" "benzyl-cyclopropyl-amine" "n-benzyl-n-cyclopropylamine" "benzylamine, n-cyclopropyl-" "benzyl-cyclopropylamine" "n-cyclopropylbenzylamin" "benzenemethanamine,n-cyclopropyl-" "benzylamine,n-cyclopropyl- (7ci,8ci); benzylcyclopropylamine;n-benzyl-n-(cyclopropyl)amine; n-benzylcyclopropylamine; n-cyclopropylbenzylamine" );
standardThermochemistry
{
    dHf_298   113070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=295870.0
}
