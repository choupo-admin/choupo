/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-undecyne, 11-chloro-  (C11H19Cl, CAS 29043-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Undecyne11Chloro;
formula     C11H19Cl;
CAS         29043-93-4;
InChIKey    BPQCLPCMIRFKOJ-UHFFFAOYSA-N;
MW          186.723;      // g/mol [origin=calculated method=formula-sum]
Tc          657.30;      // K   [origin=predictive method=joback]
Pc          21.374;      // bar [origin=predictive method=joback]
omega       0.5339;      // -   [origin=predictive method=lee-kesler]
Tb          478.83;      // K   [origin=predictive method=joback]
HvapTb      44323.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.559 0.9617 -0.00059093 1.4709e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2Cl; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group tCH; count 1; } { group tC; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-chloranylundec-1-yne" "11-chloroundec-1-yne" "11-chloro-1-undecyne" );
standardThermochemistry
{
    dHf_298   5790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252880.0
}
