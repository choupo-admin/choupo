/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylindan  (C10H12, CAS 824-22-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylindan;
formula     C10H12;
CAS         824-22-6;
InChIKey    LNNSODHYZXCEJP-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          701.45;      // K   [origin=predictive method=joback]
Pc          34.039;      // bar [origin=predictive method=joback]
omega       0.3787;      // -   [origin=predictive method=lee-kesler]
Tb          476.45;      // K   [origin=predictive method=joback]
HvapTb      41676.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.69 0.93332 -0.00069292 2.11e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2,3-dihydro-1h-indene" "1h-indene, 2,3-dihydro-4-methyl-" "indan, 4-methyl-" "1h-indene,2,3-dihydro-4-methyl-" "indan,4-methyl- (6ci,7ci,8ci); 2,3-dihydro-4-methyl-1h-indene; 4-methylindan" );
standardThermochemistry
{
    dHf_298   57000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=194930.0
}
