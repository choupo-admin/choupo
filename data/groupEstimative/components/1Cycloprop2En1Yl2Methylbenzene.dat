/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(cycloprop-2-en-1-yl)-2-methylbenzene  (C10H10, CAS 65051-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cycloprop2En1Yl2Methylbenzene;
formula     C10H10;
CAS         65051-83-4;
InChIKey    QYZHPEQEBWHUCQ-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          691.73;      // K   [origin=predictive method=joback]
Pc          34.765;      // bar [origin=predictive method=joback]
omega       0.3506;      // -   [origin=predictive method=lee-kesler]
Tb          465.96;      // K   [origin=predictive method=joback]
HvapTb      40997.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.27 0.91032 -0.00069184 2.119e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cycloprop-2-en-1-yl-2-methyl-benzene" "1-(1-cycloprop-2-enyl)-2-methyl-benzene" "1-cycloprop-2-en-1-yl-2-methylbenzene" "benzene,(1-methyl-2-cyclopropen-1-yl)-" "1-methyl-1-phenyl-2-cyclopropene;3-methyl-3-phenyl-1-cyclopropene; 3-methyl-3-phenylcyclopropene" );
gibbsFormation
{
    dHf_298   105910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     305.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=226810.0
    phase     gas;
}
