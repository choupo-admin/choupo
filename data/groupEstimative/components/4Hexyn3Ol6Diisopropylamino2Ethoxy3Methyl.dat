/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hexyn-3-ol, 6-diisopropylamino-2-ethoxy-3-methyl-  (C15H29NO2, CAS 16498-05-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hexyn3Ol6Diisopropylamino2Ethoxy3Methyl;
formula     C15H29NO2;
CAS         16498-05-8;
InChIKey    IQMQEMUEZMXKRR-UHFFFAOYSA-N;
MW          255.402;      // g/mol [origin=calculated method=formula-sum]
Tc          856.73;      // K   [origin=predictive method=joback]
Pc          17.507;      // bar [origin=predictive method=joback]
omega       1.0281;      // -   [origin=predictive method=lee-kesler]
Tb          674.73;      // K   [origin=predictive method=joback]
HvapTb      70196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.926 1.51142 -0.00091026 2.0958e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group tC; count 2; } { group OH; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-[2-[di(propan-2-yl)amino]ethoxy]-3-methyl-hex-4-yn-3-ol" "4-hexyn-3-ol, 3-methyl-6-[2-(diisopropylamino)ethoxy]-" "6-[2-(dipropan-2-ylamino)ethoxy]-3-methylhex-4-yn-3-ol" "6-[2-[di(propan-2-yl)amino]ethoxy]-3-methylhex-4-yn-3-ol" );
standardThermochemistry
{
    dHf_298   -316860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     732.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=145140.0
}
