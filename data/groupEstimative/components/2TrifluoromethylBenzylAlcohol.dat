/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(trifluoromethyl)benzyl alcohol  (C8H7F3O, CAS 346-06-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TrifluoromethylBenzylAlcohol;
formula     C8H7F3O;
CAS         346-06-5;
InChIKey    TWQNSHZTQSLJEE-UHFFFAOYSA-N;
MW          176.137;      // g/mol [origin=calculated method=formula-sum]
Tc          682.82;      // K   [origin=predictive method=joback]
Pc          34.848;      // bar [origin=predictive method=joback]
omega       0.8377;      // -   [origin=predictive method=lee-kesler]
Tb          501.06;      // K   [origin=predictive method=joback]
HvapTb      49272.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.899 0.8206 -0.00062696 1.831e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(trifluoromethyl)phenyl]methanol" "o-trifluoromethylbenzyl alcohol" "2-trifluoromethylbenzyl alcohol" "(2-(trifluoromethyl)phenyl)methanol" "[2-(trifluoromethyl)phenyl]methan-1-ol" "q1r bxfff" "2-trifluoromethyl benzylalcohol" "2-(trifluoromethyl)benzylalcohol" "o-(trifluoromethyl)benzyl alcohol" "twqnshztqsljee-uhfffaoysa-" "2-(hydroxymethyl)benzotrifluoride" "2-trifluoromethyl benzene methanol" );
gibbsFormation
{
    dHf_298   -732700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-599150.0
    phase     gas;
}
