/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-octyloxybenzyl alcohol  (C15H24O2, CAS 67698-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pOctyloxybenzylAlcohol;
formula     C15H24O2;
CAS         67698-68-4;
InChIKey    BVSGXVHDNMPZSE-UHFFFAOYSA-N;
MW          236.355;      // g/mol [origin=calculated method=formula-sum]
Tc          872.65;      // K   [origin=predictive method=joback]
Pc          19.458;      // bar [origin=predictive method=joback]
omega       1.1350;      // -   [origin=predictive method=lee-kesler]
Tb          689.06;      // K   [origin=predictive method=joback]
HvapTb      71011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.438 1.26122 -0.00067576 1.229e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-octoxyphenyl)methanol" "[4-(octyloxy)phenyl]methanol" "(4-octyloxyphenyl)methan-1-ol" "4-octyloxybenzyl alcohol" );
standardThermochemistry
{
    dHf_298   -412320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-63620.0
}
