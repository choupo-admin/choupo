\*---------------------------------------------------------------------------*/

name        3a45677aHexahydro47Methano1hInden6OlTolueneDiisocyanateAlpha;
formula     C29H38N2O4;
CAS         68334-89-4;
InChIKey    VHKGVFBEOYSFAQ-UHFFFAOYSA-N;
MW          478.633;      // g/mol [origin=calculated method=formula-sum]
Tc          1541.85;      // K   [origin=predictive method=joback]
Pc          11.769;      // bar [origin=predictive method=joback]
omega       1.0739;      // -   [origin=predictive method=lee-kesler]
Tb          1255.03;      // K   [origin=predictive method=joback]
HvapTb      136430.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 6; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCd; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 6; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7-methano-1h-inden-6-ol, 3a,4,5,6,7,7a-hexahydro-, polymer with 1,3-diisocyanatomethylbenzene and alpha,alpha,4-trimethyl-3-cyclohexene-1-methanol" );
