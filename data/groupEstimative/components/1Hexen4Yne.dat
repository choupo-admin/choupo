/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hexen-4-yne  (C6H8, CAS 5009-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hexen4Yne;
formula     C6H8;
CAS         5009-11-0;
InChIKey    RIGMRFDIWRRSMS-UHFFFAOYSA-N;
MW          80.13;      // g/mol [origin=calculated method=formula-sum]
Tc          535.83;      // K   [origin=predictive method=joback]
Pc          39.456;      // bar [origin=predictive method=joback]
omega       0.1985;      // -   [origin=predictive method=lee-kesler]
Tb          342.56;      // K   [origin=predictive method=joback]
HvapTb      30432.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.001 0.40402 -0.00023336 5.658e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=CH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-1-en-4-yne" );
gibbsFormation
{
    dHf_298   230560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=290280.0
    phase     gas;
}
