/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-8-methyl-8-azabicyclo[3.2.1]octane  (C8H14ClN, CAS 13514-03-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro8Methyl8Azabicyclo321Octane;
formula     C8H14ClN;
CAS         13514-03-9;
InChIKey    WXRBWXUZUHYHQS-UHFFFAOYSA-N;
MW          159.657;      // g/mol [origin=calculated method=formula-sum]
Tc          651.43;      // K   [origin=predictive method=joback]
Pc          31.811;      // bar [origin=predictive method=joback]
omega       0.3838;      // -   [origin=predictive method=lee-kesler]
Tb          445.59;      // K   [origin=predictive method=joback]
HvapTb      39519.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.85 1.16022 -0.000883 2.709e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH3N; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-8-methyl-8-azabicyclo[3.2.1]octane" "8-azabicyclo[3.2.1]octane, 3-chloro-8-methyl-" "8-azabicyclo[3.2.1]octane,3-chloro-8-methyl-exo-" "8-azabicyclo[3.2.1]octane,3-chloro-8-methyl-endo-" "8-azabicyclo(3.2.1)octane, 3-chloro-8-methyl-, endo-" "8-azabicyclo(3.2.1)octane, 3-chloro-8-methyl-, exo-" );
gibbsFormation
{
    dHf_298   -37560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     314.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=217020.0
    phase     gas;
}
