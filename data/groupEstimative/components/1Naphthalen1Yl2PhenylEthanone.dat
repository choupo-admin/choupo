/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-naphthalen-1-yl-2-phenyl-ethanone  (C18H14O, CAS 605-85-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Naphthalen1Yl2PhenylEthanone;
formula     C18H14O;
CAS         605-85-6;
InChIKey    MIWBWVYSHZGCDQ-UHFFFAOYSA-N;
MW          246.309;      // g/mol [origin=calculated method=formula-sum]
Tc          998.28;      // K   [origin=predictive method=joback]
Pc          25.227;      // bar [origin=predictive method=joback]
omega       0.7635;      // -   [origin=predictive method=lee-kesler]
Tb          742.63;      // K   [origin=predictive method=joback]
HvapTb      69262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.069 1.4648 -0.00106878 3.0116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 4; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 4; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanone, 1-(1-naphthalenyl)-2-phenyl-" );
gibbsFormation
{
    dHf_298   125230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=293600.0
    phase     gas;
}
