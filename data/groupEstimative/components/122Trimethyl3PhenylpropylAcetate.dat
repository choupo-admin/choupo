/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,2-trimethyl-3-phenylpropyl acetate  (C14H20O2, CAS 72727-62-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        122Trimethyl3PhenylpropylAcetate;
formula     C14H20O2;
CAS         72727-62-9;
InChIKey    QLKMBJWEWZIWQJ-UHFFFAOYSA-N;
MW          220.312;      // g/mol [origin=calculated method=formula-sum]
Tc          814.55;      // K   [origin=predictive method=joback]
Pc          20.680;      // bar [origin=predictive method=joback]
omega       0.5981;      // -   [origin=predictive method=lee-kesler]
Tb          601.15;      // K   [origin=predictive method=joback]
HvapTb      54757.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.489 1.33188 -0.0008494 1.952e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3,3-dimethyl-4-phenyl-butan-2-yl) ethanoate" "(3,3-dimethyl-4-phenylbutan-2-yl) acetate" "benzenepropanol, a,b,b-trimethyl-, 1-acetate" "benzenepropanol,a,b,b-trimethyl-, acetate (9ci)" "benzenepropanol, alpha,beta,beta-trimethyl-, acetate" "benzenepropanol, alpha,beta,beta-trimethyl-, 1-acetate" );
standardThermochemistry
{
    dHf_298   -427070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130560.0
}
