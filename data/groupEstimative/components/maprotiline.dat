/*--------------------------------*- Choupo -*-----------------------*\
  Component: maprotiline  (C20H23N, CAS 10262-69-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        maprotiline;
formula     C20H23N;
CAS         10262-69-8;
InChIKey    QSLMDECMDJKHMQ-UHFFFAOYSA-N;
MW          277.411;      // g/mol [origin=calculated method=formula-sum]
Tc          1011.46;      // K   [origin=predictive method=joback]
Pc          19.965;      // bar [origin=predictive method=joback]
omega       0.8690;      // -   [origin=predictive method=lee-kesler]
Tb          775.87;      // K   [origin=predictive method=joback]
HvapTb      70757.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-195.947 2.31612 -0.00210692 7.949e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibencycladine" "maprotilina" "maprotilinum" "maprotylina" "deprilept" "maprotilin" "maprotylina [polish]" "maprotilinum [inn-latin]" "9,10-ethanoanthracene-9(10h)-propanamine, n-methyl-" "maprotiline (usan)" "ba-34,276" "n-methyl-9,10-ethanoanthracene-9(10h)-propylamine" );
gibbsFormation
{
    dHf_298   220620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=552680.0
    phase     gas;
}
