/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pentanone, 3,3,4,4-tetramethyl-  (C9H18O, CAS 865-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Pentanone3344Tetramethyl;
formula     C9H18O;
CAS         865-66-7;
InChIKey    VVCKMVBQLNBXOE-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          650.07;      // K   [origin=predictive method=joback]
Pc          25.482;      // bar [origin=predictive method=joback]
omega       0.3781;      // -   [origin=predictive method=lee-kesler]
Tb          452.93;      // K   [origin=predictive method=joback]
HvapTb      39782.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.88 1.08252 -0.0007907 2.3066e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group C; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4-tetramethylpentan-2-one" "3,3,4,4-tetramethyl-2-pentanone" );
gibbsFormation
{
    dHf_298   -359170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98340.0
    phase     gas;
}
