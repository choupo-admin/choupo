/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-hepten-2-ol, 3,6-dimethyl-, propanoate  (C12H22O2, CAS 63270-18-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Hepten2Ol36DimethylPropanoate;
formula     C12H22O2;
CAS         63270-18-8;
InChIKey    JGCNEUQIMYRBBG-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          719.23;      // K   [origin=predictive method=joback]
Pc          19.036;      // bar [origin=predictive method=joback]
omega       0.6114;      // -   [origin=predictive method=lee-kesler]
Tb          535.54;      // K   [origin=predictive method=joback]
HvapTb      48975.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.152 1.1208 -0.0006269 1.227e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 2; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 2; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-dimethylhept-5-en-2-yl propanoate" "5-hepten-2-ol, 3,6-dimethyl-, 2-propanoate" "2,5-dimethyl-2-hepten-6-yl propionate" "propanoic acid 1,2,5-trimethyl-4-hexenyl ester" );
standardThermochemistry
{
    dHf_298   -511420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     644.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-193420.0
}
