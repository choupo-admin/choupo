/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxycyclohexene  (C7H12O, CAS 15766-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxycyclohexene;
formula     C7H12O;
CAS         15766-93-5;
InChIKey    WKERHKCHQLXWPY-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          605.25;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       0.2949;      // -   [origin=predictive method=lee-kesler]
Tb          400.89;      // K   [origin=predictive method=joback]
HvapTb      34307.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.8 0.67172 -0.00031428 3.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH=CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexene, 4-methoxy-" "cyclohexene,4-methoxy-" );
gibbsFormation
{
    dHf_298   -207930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42530.0
    phase     gas;
}
