/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorotoluene  (C7H7Cl, CAS 95-49-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorotoluene;
formula     C7H7Cl;
CAS         95-49-8;
InChIKey    IBSQPLPBRSHTTG-UHFFFAOYSA-N;
MW          126.583;      // g/mol [origin=calculated method=formula-sum]
Tc          650.17;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       0.3020;      // -   [origin=predictive method=lee-kesler]
Tb          428.85;      // K   [origin=predictive method=joback]
HvapTb      38499.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.19 0.53722 -0.00034156 8.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH3; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-methyl-benzene" "1-chloro-2-methylbenzene" "o-chlorotoluene" "benzene, 1-chloro-2-methyl-" "toluene, o-chloro-" "o-tolyl chloride" "2-chloro-1-methylbenzene" "ortho-chlorotoluene" "2-methylchlorobenzene" "halso 99" "1-methyl-2-chlorobenzene" "toluene,2-chloro" );
gibbsFormation
{
    dHf_298   21510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98910.0
    phase     gas;
}
