/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-fluorophenyl)cyclohexanecarboxylic acid  (C13H15FO2, CAS 214263-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14FluorophenylCyclohexanecarboxylicAcid;
formula     C13H15FO2;
CAS         214263-00-0;
InChIKey    XQKPSVJXJIFYAU-UHFFFAOYSA-N;
MW          222.259;      // g/mol [origin=calculated method=formula-sum]
Tc          936.54;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       0.8047;      // -   [origin=predictive method=lee-kesler]
Tb          693.27;      // K   [origin=predictive method=joback]
HvapTb      63095.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.44 1.577 -0.00135016 4.853e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group COOH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-fluorophenyl)cyclohexane-1-carboxylic acid" "1-(4-fluorophenyl)cyclohexanecarboxylicacid" "cyclohexanecarboxylicacid, 1-(4-fluorophenyl)-" );
gibbsFormation
{
    dHf_298   -563410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     673.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-358400.0
    phase     gas;
}
