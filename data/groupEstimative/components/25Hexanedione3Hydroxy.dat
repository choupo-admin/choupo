/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-hexanedione, 3-hydroxy-  (C6H10O3, CAS 61892-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Hexanedione3Hydroxy;
formula     C6H10O3;
CAS         61892-85-1;
InChIKey    MXGSILCFPNVDMX-UHFFFAOYSA-N;
MW          130.143;      // g/mol [origin=calculated method=formula-sum]
Tc          720.43;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       1.0393;      // -   [origin=predictive method=lee-kesler]
Tb          536.36;      // K   [origin=predictive method=joback]
HvapTb      58733.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.761 0.55774 -0.0002988 5.142e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanylhexane-2,5-dione" );
standardThermochemistry
{
    dHf_298   -549840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-397460.0
}
