/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-tert-butyl-2-methylidenecyclohexan-1-ol  (C11H20O, CAS 19245-70-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5TertButyl2Methylidenecyclohexan1Ol;
formula     C11H20O;
CAS         19245-70-6;
InChIKey    MKWJZCGGUSWUQL-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          750.29;      // K   [origin=predictive method=joback]
Pc          25.715;      // bar [origin=predictive method=joback]
omega       0.7234;      // -   [origin=predictive method=lee-kesler]
Tb          554.27;      // K   [origin=predictive method=joback]
HvapTb      55742.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.67 1.18676 -0.00071 1.537e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-tert-butyl-2-methylidene-cyclohexan-1-ol" "cyclohexanol, 5-(1,1-dimethylethyl)-2-methylene-, cis-" "2-methylidene-5-tert-butyl-cyclohexan-1-ol" "cyclohexanol,5-(1,1-dimethylethyl)-2-methylene-cis-" "cyclohexanol,5-(1,1-dimethylethyl)-2-methylene-trans-" "cyclohexanol, 5-(1,1-dimethylethyl)-2-methylene-, trans-" );
gibbsFormation
{
    dHf_298   -313130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-22420.0
    phase     gas;
}
