/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-aminopropiophenone  (C9H11NO, CAS 70-69-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Aminopropiophenone;
formula     C9H11NO;
CAS         70-69-9;
InChIKey    FSWXOANXOQPCFF-UHFFFAOYSA-N;
MW          149.193;      // g/mol [origin=calculated method=formula-sum]
Tc          793.04;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.6493;      // -   [origin=predictive method=lee-kesler]
Tb          563.58;      // K   [origin=predictive method=joback]
HvapTb      55953.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.049 0.75432 -0.00045466 9.846e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-aminophenyl)propan-1-one" "p-aminopropiophenone" "propiophenone, 4'-amino-" "1-propanone, 1-(4-aminophenyl)-" "1-(4-aminophenyl)-1-propanone" "4-aminopropiophenone" "paraminopropiophenone" "propiophenone, 4-amino-" "ethyl p-aminophenyl ketone" "6170-25-8 (hydrochloride)" "1-propanone,1-(4-aminophenyl)-" );
standardThermochemistry
{
    dHf_298   -82820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65210.0
}
