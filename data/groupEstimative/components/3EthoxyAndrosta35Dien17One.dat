/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethoxy-androsta-3,5-dien-17-one  (C21H30O2, CAS 972-46-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3EthoxyAndrosta35Dien17One;
formula     C21H30O2;
CAS         972-46-3;
InChIKey    PAOWPNQOTVTCAF-OEUJLIAZSA-N;
MW          314.469;      // g/mol [origin=calculated method=formula-sum]
Tc          1068.32;      // K   [origin=predictive method=joback]
Pc          16.365;      // bar [origin=predictive method=joback]
omega       0.7720;      // -   [origin=predictive method=lee-kesler]
Tb          822.72;      // K   [origin=predictive method=joback]
HvapTb      68806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-230.729 2.64926 -0.00226268 8.45e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 3; } { group C; count 2; } { group CH=C; count 2; } { group CH2CO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s)-3-ethoxy-10,13-dimethyl-1,2,7,8,9,11,12,14,15,16-decahydrocyclopenta[a]phenanthren-17-one" "3-ethoxyandrosta-3,5-dien-17-one" "androst-4-ene-3,17-dione 3-ethyl enol ether" );
gibbsFormation
{
    dHf_298   -383530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     654.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102820.0
    phase     gas;
}
