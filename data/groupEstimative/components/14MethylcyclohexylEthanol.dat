/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-methylcyclohexyl)ethanol  (C9H18O, CAS 34884-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14MethylcyclohexylEthanol;
formula     C9H18O;
CAS         34884-20-3;
InChIKey    KAUADGCMTGZSPE-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          704.30;      // K   [origin=predictive method=joback]
Pc          30.524;      // bar [origin=predictive method=joback]
omega       0.7044;      // -   [origin=predictive method=lee-kesler]
Tb          512.14;      // K   [origin=predictive method=joback]
HvapTb      52039.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.35 0.99434 -0.000525 8.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexanemethanol, alpha,4-dimethyl-, cis-" "cis-alpha,4-dimethylcyclohexanemethanol" "trans-alpha,4-dimethylcyclohexane-1-methanol" "cyclohexanemethanol, alpha,4-dimethyl-, trans-" );
gibbsFormation
{
    dHf_298   -352620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-97620.0
    phase     gas;
}
