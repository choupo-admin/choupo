/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxydiethylene bis(2-ethylhexanoate)  (C20H38O5, CAS 72269-52-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxydiethyleneBis2Ethylhexanoate;
formula     C20H38O5;
CAS         72269-52-4;
InChIKey    GWQRPOCMBMQBTK-UHFFFAOYSA-N;
MW          358.519;      // g/mol [origin=calculated method=formula-sum]
Tc          976.95;      // K   [origin=predictive method=joback]
Pc          10.214;      // bar [origin=predictive method=joback]
omega       0.9471;      // -   [origin=predictive method=lee-kesler]
Tb          795.18;      // K   [origin=predictive method=joback]
HvapTb      76562.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.662 1.74288 -0.0007704 5.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 11; } { group CH; count 2; } { group CH2O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-ethylhexanoyloxy)ethoxy]ethyl 2-ethylhexanoate" "hexanoic acid, 2-ethyl-, oxydi-2,1-ethanediyl ester" "hexanoic acid, 2-ethyl-, 1,1'-(oxydi-2,1-ethanediyl) ester" "peg-2 dioctanoate" "diethylene glycol dioctanoate" "hexanoic acid,2-ethyl-, 1,1'-(oxydi-2,1-ethanediyl) ester" );
standardThermochemistry
{
    dHf_298   -1233470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1029.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-613100.0
}
