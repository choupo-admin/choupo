/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-divinylcyclobutene  (C8H10, CAS 42206-11-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Divinylcyclobutene;
formula     C8H10;
CAS         42206-11-1;
InChIKey    JFGIMFIUFRAQNR-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          599.82;      // K   [origin=predictive method=joback]
Pc          34.279;      // bar [origin=predictive method=joback]
omega       0.3119;      // -   [origin=predictive method=lee-kesler]
Tb          400.80;      // K   [origin=predictive method=joback]
HvapTb      34072.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.29 0.7166 -0.0005396 1.708e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(ethenyl)cyclobutene" "1,2-diethenylcyclobutene" "cyclobutene, 1,2-diethenyl-" );
gibbsFormation
{
    dHf_298   164230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=259220.0
    phase     gas;
}
