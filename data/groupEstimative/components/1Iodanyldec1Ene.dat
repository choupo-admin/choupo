/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodanyldec-1-ene  (C10H19I, CAS 66291-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodanyldec1Ene;
formula     C10H19I;
CAS         66291-51-8;
InChIKey    DLUIIUGXYKFZRE-UHFFFAOYSA-N;
MW          266.162;      // g/mol [origin=calculated method=formula-sum]
Tc          725.41;      // K   [origin=predictive method=joback]
Pc          21.674;      // bar [origin=predictive method=joback]
omega       0.5100;      // -   [origin=predictive method=lee-kesler]
Tb          525.70;      // K   [origin=predictive method=joback]
HvapTb      47185.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.693 1.01282 -0.0006854 1.951e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH=CH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-decene, 1-iodo-, (z)-" );
standardThermochemistry
{
    dHf_298   -55640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=171660.0
}
