/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetramethoxymethane  (C5H12O4, CAS 1850-14-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetramethoxymethane;
formula     C5H12O4;
CAS         1850-14-2;
InChIKey    AHJWSRRHTXRLAQ-UHFFFAOYSA-N;
MW          136.147;      // g/mol [origin=calculated method=formula-sum]
Tc          578.05;      // K   [origin=predictive method=joback]
Pc          32.765;      // bar [origin=predictive method=joback]
omega       0.4562;      // -   [origin=predictive method=lee-kesler]
Tb          400.45;      // K   [origin=predictive method=joback]
HvapTb      35068.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (75.87 0.35188 2.4e-05 -9.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group CH3O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetramethyl orthocarbonate" "methane, tetramethoxy-" );
gibbsFormation
{
    dHf_298   -684160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-425940.0
    phase     gas;
}
