/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3,3-dimethyl-4-pentenoate  (C9H16O2, CAS 7796-72-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl33Dimethyl4Pentenoate;
formula     C9H16O2;
CAS         7796-72-7;
InChIKey    ZLDOMUPTDYCDBS-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          641.92;      // K   [origin=predictive method=joback]
Pc          24.605;      // bar [origin=predictive method=joback]
omega       0.4738;      // -   [origin=predictive method=lee-kesler]
Tb          457.19;      // K   [origin=predictive method=joback]
HvapTb      41069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.348 0.90986 -0.0005659 1.281e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3,3-dimethylpent-4-enoate" "ethyl 3,3-dimethylpent-4-en-1-oate" "4-pentenoic acid, 3,3-dimethyl-, ethyl ester" "3,3-dimethyl-4-pentenoic acid, ethyl ester" "s848" );
gibbsFormation
{
    dHf_298   -429690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-194790.0
    phase     gas;
}
