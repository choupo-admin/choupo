/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1′-Sulfonylbis[butane]  (C8H18O2S, CAS 598-04-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H18O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        11SulfonylbisButane;
formula     C8H18O2S;
CAS         598-04-9;
InChIKey    AIDFJGKWTOULTC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          178.29;      // g/mol [origin=calculated method=formula-sum]
Tc          502.78;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       0.5969;      // -   [origin=predictive method=lee-kesler]
Tb          361.64;      // K   [origin=predictive method=joback]
HvapTb      45220.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.256 0.80304 -0.000386 4.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butylsulfonylbutane" "1-butylsulfonyl-butane" "butane, 1,1′-sulfonylbis-" "butyl sulfone" "di-n-butyl sulfone" "dibutyl sulfone" "n-butyl sulfone" "butane, 1,1'-sulfonylbis-" "dibutyl sulphone" "di-n-butylsulfone" "1-(Butylsulfonyl)butane" "dibutylsulfone" );
gibbsFormation
{
    dHf_298   -703670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     726.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-485180.0
    phase     gas;
}
