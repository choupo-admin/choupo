/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-trimethylsilyl-1-hexyne  (C9H18Si, CAS 3844-94-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H18Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Trimethylsilyl1Hexyne;
formula     C9H18Si;
CAS         3844-94-8;
InChIKey    SFCRJYVNDZSYCT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          154.328;      // g/mol [origin=calculated method=formula-sum]
Tc          608.70;      // K   [origin=predictive method=joback]
Pc          23.982;      // bar [origin=predictive method=joback]
omega       0.2674;      // -   [origin=predictive method=lee-kesler]
Tb          415.92;      // K   [origin=predictive method=joback]
HvapTb      38074.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.083 0.50288 4.114e-05 -1.4232e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-1-ynyl(trimethyl)silane" "butyl(trimethylsilyl)acetylene" "silane, 1-hexynyltrimethyl-" "hex-1-yn-1-yltrimethylsilane" "silane,1-hexynyltrimethyl- (6ci,7ci,8ci,9ci);1-(trimethylsilyl)-2-butylacetylene;1-butyl-2-trimethylsilylacetylene;1-hexynyltrimethylsilane;butyl(trimethylsilyl)acetylene;" );
standardThermochemistry
{
    dHf_298   -68410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     604.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122940.0
}
