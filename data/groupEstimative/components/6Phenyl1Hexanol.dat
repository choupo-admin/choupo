/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-phenyl-1-hexanol  (C12H18O, CAS 2430-16-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Phenyl1Hexanol;
formula     C12H18O;
CAS         2430-16-2;
InChIKey    FDXBUMXUJRZANT-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          780.96;      // K   [origin=predictive method=joback]
Pc          26.380;      // bar [origin=predictive method=joback]
omega       0.9568;      // -   [origin=predictive method=lee-kesler]
Tb          593.02;      // K   [origin=predictive method=joback]
HvapTb      61261.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.634 1.0989 -0.0006906 1.669e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-phenylhexan-1-ol" "benzenehexanol" "6-phenyl-n-hexanol" "6-phenylhexanol" );
gibbsFormation
{
    dHf_298   -206710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25750.0
    phase     gas;
}
