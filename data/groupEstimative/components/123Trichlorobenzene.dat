/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-trichlorobenzene  (C6H3Cl3, CAS 87-61-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Trichlorobenzene;
formula     C6H3Cl3;
CAS         87-61-6;
InChIKey    RELMFMZEBKVZJC-UHFFFAOYSA-N;
MW          181.44;      // g/mol [origin=calculated method=formula-sum]
Tc          725.38;      // K   [origin=predictive method=joback]
Pc          38.868;      // bar [origin=predictive method=joback]
omega       0.3672;      // -   [origin=predictive method=lee-kesler]
Tb          485.81;      // K   [origin=predictive method=joback]
HvapTb      45705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.8 0.3963 -0.00026092 6.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-tris(chloranyl)benzene" "vic-trichlorobenzene" "benzene, 1,2,3-trichloro-" "trichlorobenzene" "1,2,6-trichlorobenzene" "benzene, trichloro-" "1,2,3-trichlorbenzene" "1,2,3-tcb" "trichlorbenzene" "*chlorobenzens" "trichlorobenzenes" "invalon tc" );
gibbsFormation
{
    dHf_298   -800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     371.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57000.0
    phase     gas;
}
