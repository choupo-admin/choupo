/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diphenylpropene  (C15H14, CAS 5209-18-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diphenylpropene;
formula     C15H14;
CAS         5209-18-7;
InChIKey    AIMDYNJRXHEXEL-KPKJPENVSA-N;
MW          194.277;      // g/mol [origin=calculated method=formula-sum]
Tc          845.82;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.4886;      // -   [origin=predictive method=lee-kesler]
Tb          600.32;      // K   [origin=predictive method=joback]
HvapTb      53494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.739 1.291 -0.0009384 2.657e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-3-phenylprop-1-enyl]benzene" "1,1'-prop-1-ene-1,3-diyldibenzene" "benzene, 1,1'-(1-propene-1,3-diyl)bis-" "propene,3-diphenyl-" "[(e)-3-phenyl-prop-1-enyl]-benzene" "benzene,1'-(1-propene-1,3-diyl)bis-" "benzene, 1,1'-(1-propene-1,3-diyl)bis-, (e)-" );
gibbsFormation
{
    dHf_298   237350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=380460.0
    phase     gas;
}
