/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dibromoethanol  (C2H4Br2O, CAS 83206-47-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dibromoethanol;
formula     C2H4Br2O;
CAS         83206-47-7;
InChIKey    OGZJULUCZAZKHP-UHFFFAOYSA-N;
MW          203.861;      // g/mol [origin=calculated method=formula-sum]
Tc          673.73;      // K   [origin=predictive method=joback]
Pc          72.802;      // bar [origin=predictive method=joback]
omega       0.8256;      // -   [origin=predictive method=lee-kesler]
Tb          469.42;      // K   [origin=predictive method=joback]
HvapTb      49207.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.061 0.3101 -0.0002614 9.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group Br; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(bromanyl)ethanol" "ethanol, 2,2-dibromo-" );
gibbsFormation
{
    dHf_298   -189460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144660.0
    phase     gas;
}
