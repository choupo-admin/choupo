/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-bis(trifluoromethyl)benzyl alcohol  (C9H6F6O, CAS 32707-89-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35BisTrifluoromethylBenzylAlcohol;
formula     C9H6F6O;
CAS         32707-89-4;
InChIKey    BJTWPJOGDWRYDD-UHFFFAOYSA-N;
MW          244.134;      // g/mol [origin=calculated method=formula-sum]
Tc          690.41;      // K   [origin=predictive method=joback]
Pc          27.099;      // bar [origin=predictive method=joback]
omega       0.9605;      // -   [origin=predictive method=lee-kesler]
Tb          523.50;      // K   [origin=predictive method=joback]
HvapTb      48413.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.709 1.0173 -0.00083532 2.588e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 6; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3,5-bis(trifluoromethyl)phenyl]methanol" "fxffr c1q exfff" "3,5-ditrifluoromethylbenzyl alcohol" "(3,5-bis(trifluoromethyl)phenyl)methanol" "3,5-di(trifluoromethyl)benzyl alcohol" "[3,5-di(trifluoromethyl)phenyl]methanol" "3, 5-bis(trifluoromethyl)benzyl alcohol" "(3,5-bis-trifluoromethyl-phenyl)-methanol" "[3,5-bis(trifluoromethyl)phenyl]methan-1-ol" "mbt-byl" "bjtwpjogdwrydd-uhfffaoysa-" "3,5-ditrifluoromethylbenzylalcohol" );
gibbsFormation
{
    dHf_298   -1361890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1181950.0
    phase     gas;
}
