/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,3-dihydroxypropyl)bis(2-cyanethyl)amine  (C9H15N3O2, CAS 4220-30-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DihydroxypropylBis2CyanethylAmine;
formula     C9H15N3O2;
CAS         4220-30-8;
InChIKey    GAPDHXRQKMUCKH-UHFFFAOYSA-N;
MW          197.238;      // g/mol [origin=calculated method=formula-sum]
Tc          996.35;      // K   [origin=predictive method=joback]
Pc          26.516;      // bar [origin=predictive method=joback]
omega       1.7011;      // -   [origin=predictive method=lee-kesler]
Tb          806.04;      // K   [origin=predictive method=joback]
HvapTb      91597.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.916 0.9262 -0.0005804 1.398e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group OH; count 2; } { group CH2N; count 1; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH; count 1; } { group OH; count 2; } { group N; count 1; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2,3-bis(oxidanyl)propyl-(2-cyanoethyl)amino]propanenitrile" "3,3'-((2,3-dihydroxypropyl)imino)bispropiononitrile" "3,3'-[(2,3-dihydroxypropyl)imino]bispropiononitrile" "propanenitrile, 3,3'-((2,3-dihydroxypropyl)imino)bis-" "propanenitrile, 3,3'-[(2,3-dihydroxypropyl)imino]bis-" "2,3-dihydroxypropylbis(2'-cyanoethyl)amine" "3-[2-cyanoethyl(2,3-dihydroxypropyl)amino]propanenitrile" );
gibbsFormation
{
    dHf_298   -141540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125960.0
    phase     gas;
}
