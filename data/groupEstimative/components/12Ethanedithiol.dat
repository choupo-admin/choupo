/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-ethanedithiol  (C2H6S2, CAS 540-63-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Ethanedithiol;
formula     C2H6S2;
CAS         540-63-6;
InChIKey    VYMPLPIFKRHAAC-UHFFFAOYSA-N;
MW          94.19;      // g/mol [origin=calculated method=formula-sum]
Tc          594.18;      // K   [origin=predictive method=joback]
Pc          60.845;      // bar [origin=predictive method=joback]
omega       0.2507;      // -   [origin=predictive method=lee-kesler]
Tb          371.08;      // K   [origin=predictive method=joback]
HvapTb      33520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.852 0.2484 -0.0001298 2.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2SH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group SH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-dithiol" "dithioglycol" "1,2-dimercaptoethane" "ethylene mercaptan" "s-ethylene dimercaptan" "ethylenedithiol" "ethylenedimercaptan" "1,2-ethanethiol" "dithioethyleneglycol" "ethylene dithioglycol" "ethylene glycol, dithio-" "ethylene dimercaptan" );
standardThermochemistry
{
    dHf_298   -7650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24740.0
}
