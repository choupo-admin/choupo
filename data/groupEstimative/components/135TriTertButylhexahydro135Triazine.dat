/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-tri-tert-butylhexahydro-1,3,5-triazine  (C15H33N3, CAS 10560-39-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135TriTertButylhexahydro135Triazine;
formula     C15H33N3;
CAS         10560-39-1;
InChIKey    XNJJKNFDJBAYSE-UHFFFAOYSA-N;
MW          255.45;      // g/mol [origin=calculated method=formula-sum]
Tc          773.84;      // K   [origin=predictive method=joback]
Pc          16.742;      // bar [origin=predictive method=joback]
omega       0.6039;      // -   [origin=predictive method=lee-kesler]
Tb          581.84;      // K   [origin=predictive method=joback]
HvapTb      51447.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-172.42 2.35548 -0.001921 6.227e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 9; } { group C; count 3; } { group CH2N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group C; count 3; } { group CH2_ring; count 3; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-tritert-butyl-1,3,5-triazinane" "1,3,5-triazine, 1,3,5-tris(1,1-dimethylethyl)hexahydro-" "1,3,5-triazine,1,3,5-tris(1,1-dimethylethyl)hexahydro-" "s-triazine,1,3,5-tri-tert-butylhexahydro- (7ci,8ci);1,3,5-tri-tert-butyl-1,3,5-triazacyclohexane; 1,3,5-tri-tert-butylhexahydro-1,3,5-triazine;1,3,5-tri-tert-butylhexahydro-s-triazine;1,3,5-tris(tert-butyl)-1,3,5-triazacyclohexane;n,n',n''-tri-tert-butyl-1,3,5-triazacyclohexane" );
gibbsFormation
{
    dHf_298   -83450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=484740.0
    phase     gas;
}
