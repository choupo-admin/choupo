/*--------------------------------*- Choupo -*-----------------------*\
  Component: iodinated glycerol  (C6H11IO3, CAS 5634-39-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iodinatedGlycerol;
formula     C6H11IO3;
CAS         5634-39-9;
InChIKey    LTINPJMVDKPJJI-UHFFFAOYSA-N;
MW          258.051;      // g/mol [origin=calculated method=formula-sum]
Tc          805.45;      // K   [origin=predictive method=joback]
Pc          39.705;      // bar [origin=predictive method=joback]
omega       0.8455;      // -   [origin=predictive method=lee-kesler]
Tb          586.27;      // K   [origin=predictive method=joback]
HvapTb      63582.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.169 0.75192 -0.0004618 1.033e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group OH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group I; count 1; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(1-iodanylethyl)-1,3-dioxolan-4-yl]methanol" "organidin" "glycerol, iodinated" "iodopropylidene glycerol" "2-(1-iodoethyl)-1,3-dioxolan-4-ylmethanol" "1,3-dioxolane-4-methanol, 2-(1-iodoethyl)-" "[2-(1-iodoethyl)-1,3-dioxolan-4-yl]methanol" "2-(1-iodoethyl)-1,3-dioxolane-4-methanol" "1,3-dioxolane-4-methanol, 2-(iodoethyl)-" "iodoglycerin" "glycerol, iondinated" "iodinated glycerol b" );
gibbsFormation
{
    dHf_298   -471670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     291.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-224900.0
    phase     gas;
}
