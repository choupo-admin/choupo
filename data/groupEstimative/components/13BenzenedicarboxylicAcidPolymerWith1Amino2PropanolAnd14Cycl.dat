/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenedicarboxylic acid, polymer with 1-amino-2-propanol and 1,4-cyclohexanedimethanol  (C19H31NO7, CAS 125304-12-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BenzenedicarboxylicAcidPolymerWith1Amino2PropanolAnd14Cycl;
formula     C19H31NO7;
CAS         125304-12-3;
InChIKey    CTZQPGHHFOTENQ-UHFFFAOYSA-N;
MW          385.457;      // g/mol [origin=calculated method=formula-sum]
Tc          1657.24;      // K   [origin=predictive method=joback]
Pc          20.456;      // bar [origin=predictive method=joback]
omega       1.3050;      // -   [origin=predictive method=lee-kesler]
Tb          1323.31;      // K   [origin=predictive method=joback]
HvapTb      156152.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.863 1.62502 -0.00045296 -1.416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 3; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 3; } { group CH2NH2; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 3; } { group COOH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azanylpropan-2-ol;benzene-1,3-dicarboxylic acid;[4-(hydroxymethyl)cyclohexyl]methanol" );
standardThermochemistry
{
    dHf_298   -1528410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1226.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1015170.0
}
