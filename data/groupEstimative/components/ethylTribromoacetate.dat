/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl tribromoacetate  (C4H5Br3O2, CAS 599-99-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylTribromoacetate;
formula     C4H5Br3O2;
CAS         599-99-5;
InChIKey    ZZUKBDJWZXVOQG-UHFFFAOYSA-N;
MW          324.794;      // g/mol [origin=calculated method=formula-sum]
Tc          788.21;      // K   [origin=predictive method=joback]
Pc          53.202;      // bar [origin=predictive method=joback]
omega       0.6430;      // -   [origin=predictive method=lee-kesler]
Tb          544.59;      // K   [origin=predictive method=joback]
HvapTb      49914.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.761 0.56942 -0.0004852 1.535e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group Br; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group Br; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,2,2-tris(bromanyl)ethanoate" "ethyl 2,2,2-tribromoacetate" );
standardThermochemistry
{
    dHf_298   -372930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-281770.0
}
