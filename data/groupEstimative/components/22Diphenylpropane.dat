/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-diphenylpropane  (C15H16, CAS 778-22-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Diphenylpropane;
formula     C15H16;
CAS         778-22-3;
InChIKey    MILSYCKGLDDVLM-UHFFFAOYSA-N;
MW          196.293;      // g/mol [origin=calculated method=formula-sum]
Tc          843.14;      // K   [origin=predictive method=joback]
Pc          25.585;      // bar [origin=predictive method=joback]
omega       0.4252;      // -   [origin=predictive method=lee-kesler]
Tb          592.93;      // K   [origin=predictive method=joback]
HvapTb      52240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.03 1.39684 -0.0010264 2.902e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylpropan-2-ylbenzene" "propane, 2,2-diphenyl-" "benzene, 1,1'-(1-methylethylidene)bis-" "dimethyldiphenylmethane" "(2-phenylpropan-2-yl)benzene" "(1-methyl-1-phenylethyl)benzene" "(1-methyl-1-phenyl-ethyl)-benzene" );
gibbsFormation
{
    dHf_298   111380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=303080.0
    phase     gas;
}
