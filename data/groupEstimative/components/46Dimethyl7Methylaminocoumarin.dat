/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,6-dimethyl-7-methylaminocoumarin  (C12H13NO2, CAS 26078-24-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        46Dimethyl7Methylaminocoumarin;
formula     C12H13NO2;
CAS         26078-24-0;
InChIKey    RIZOSFDXIXBLIP-UHFFFAOYSA-N;
MW          203.241;      // g/mol [origin=calculated method=formula-sum]
Tc          852.06;      // K   [origin=predictive method=joback]
Pc          27.498;      // bar [origin=predictive method=joback]
omega       0.8315;      // -   [origin=predictive method=lee-kesler]
Tb          635.45;      // K   [origin=predictive method=joback]
HvapTb      61415.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.81 0.97936 -0.00065532 1.725e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH3; count 1; } { group CH3NH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,6-dimethyl-7-(methylamino)chromen-2-one" "4,6-dimethyl-7-(methylamino)-2-benzopyrone" "coumarin, 4,6-dimethyl-7-methylamino-" "coumarin,6-dimethyl-7-methylamino-" "coumarin, 4,6-dimethyl-7-(methylamino)-" "4,6-dimethyl-7-(methylamino)-2h-chromen-2-one" "2h-1-benzopyran-2-one,6-dimethyl-7-(methylamino)-" "2h-1-benzopyran-2-one, 4,6-dimethyl-7-(methylamino)-" "2h-1-benzopyran-2-one,4,6-dimethyl-7-(methylamino)-" "2h-1-benzopyran-2-one, 4,6-dimethyl-7-(methylamino)- (9ci)" );
gibbsFormation
{
    dHf_298   -207090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13590.0
    phase     gas;
}
