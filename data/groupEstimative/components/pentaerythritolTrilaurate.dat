/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentaerythritol trilaurate  (C41H78O7, CAS 67874-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentaerythritolTrilaurate;
formula     C41H78O7;
CAS         67874-04-8;
InChIKey    CYCUQBHCRPDWQM-UHFFFAOYSA-N;
MW          683.068;      // g/mol [origin=calculated method=formula-sum]
Tc          2210.06;      // K   [origin=predictive method=joback]
Pc          3.956;      // bar [origin=predictive method=joback]
omega       -0.5199;      // -   [origin=predictive method=lee-kesler]
Tb          1401.29;      // K   [origin=predictive method=joback]
HvapTb      144464.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.664 3.89426 -0.002125 3.871e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 31; } { group C; count 1; } { group OH; count 1; } { group CH2COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 34; } { group C; count 1; } { group OH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2-bis(dodecanoyloxymethyl)-3-oxidanyl-propyl] dodecanoate" "2-(hydroxymethyl)-2-(((1-oxododecyl)oxy)methyl)propane-1,3-diyl dilaurate" "2-(hydroxymethyl)-2-[[(1-oxododecyl)oxy]methyl]propane-1,3-diyl dilaurate" "dodecanoic acid, 1,1'-(2-(hydroxymethyl)-2-(((1-oxododecyl)oxy)methyl)-1,3-propanediyl) ester" "dodecanoic acid, 1,1'-[2-(hydroxymethyl)-2-[[(1-oxododecyl)oxy]methyl]-1,3-propanediyl] ester" "[2,2-bis(dodecanoyloxymethyl)-3-hydroxypropyl] dodecanoate" "dodecanoic acid, 2-(hydroxymethyl)-2-(((1-oxododecyl)oxy)methyl)-1,3-propanediyl ester" );
gibbsFormation
{
    dHf_298   -2002390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1918.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-770750.0
    phase     gas;
}
