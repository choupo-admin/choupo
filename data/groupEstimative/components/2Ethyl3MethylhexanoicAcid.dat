/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-3-methylhexanoic acid  (C9H18O2, CAS 74581-94-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl3MethylhexanoicAcid;
formula     C9H18O2;
CAS         74581-94-5;
InChIKey    KVHVVWNXJWZHGB-UHFFFAOYSA-N;
MW          158.241;      // g/mol [origin=calculated method=formula-sum]
Tc          740.40;      // K   [origin=predictive method=joback]
Pc          25.585;      // bar [origin=predictive method=joback]
omega       0.7628;      // -   [origin=predictive method=lee-kesler]
Tb          550.15;      // K   [origin=predictive method=joback]
HvapTb      52016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.057 0.92146 -0.0005448 1.229e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-3-methyl-hexanoic acid" );
gibbsFormation
{
    dHf_298   -589920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-323890.0
    phase     gas;
}
