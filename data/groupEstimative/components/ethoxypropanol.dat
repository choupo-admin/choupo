/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethoxypropanol  (C5H12O2, CAS 116164-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethoxypropanol;
formula     C5H12O2;
CAS         116164-74-0;
InChIKey    JLBXCKSMESLGTJ-UHFFFAOYSA-N;
MW          104.149;      // g/mol [origin=calculated method=formula-sum]
Tc          593.68;      // K   [origin=predictive method=joback]
Pc          38.340;      // bar [origin=predictive method=joback]
omega       0.7626;      // -   [origin=predictive method=lee-kesler]
Tb          428.16;      // K   [origin=predictive method=joback]
HvapTb      45425.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.452 0.45554 -0.0001708 2.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxypropan-1-ol" "propanol, 1(or 2)-ethoxy-" "1-propanol, ethoxy-" "1(or 2)-ethoxypropanol" "ethyl ether of propylene glycol" "1,2-propanediol, monoethyl ether" "propanol, ethoxy-" "ethoxy propanol" "propanol, ethoxy- (9ci)" );
standardThermochemistry
{
    dHf_298   -436260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-253040.0
}
