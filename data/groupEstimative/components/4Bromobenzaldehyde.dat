/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromobenzaldehyde  (C7H5BrO, CAS 1122-91-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H5BrO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Bromobenzaldehyde;
formula     C7H5BrO;
CAS         1122-91-4;
InChIKey    ZRYZBQLXDKPBDU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          185.02;      // g/mol [origin=calculated method=formula-sum]
Tc          667.17;      // K   [origin=predictive method=joback]
Pc          46.849;      // bar [origin=predictive method=joback]
omega       0.3147;      // -   [origin=predictive method=lee-kesler]
Tb          434.00;      // K   [origin=predictive method=joback]
HvapTb      38176.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.39 0.5767 -0.00054556 2.035e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanylbenzaldehyde" "p-bromobenzaldehyde" "benzaldehyde, 4-bromo-" "4-bromobenzylaldehyde" "benzaldehyde, p-bromo-" "p-bromo benzaldehyde" "4-bromo benzaldehyde" "4-bromo-benzaldehyde" "4-brombenzaldehyde" "agn-pc-0cq3uo" "4-bba" "benzaldehyde,4-bromo" );
gibbsFormation
{
    dHf_298   140030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=169120.0
    phase     gas;
}
