/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-[4-(benzyloxy)phenyl]propanoate  (C17H18O3, CAS 24807-40-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl34BenzyloxyPhenylPropanoate;
formula     C17H18O3;
CAS         24807-40-7;
InChIKey    XAAMAAXKDLWBKO-UHFFFAOYSA-N;
MW          270.328;      // g/mol [origin=calculated method=formula-sum]
Tc          952.45;      // K   [origin=predictive method=joback]
Pc          20.382;      // bar [origin=predictive method=joback]
omega       0.8461;      // -   [origin=predictive method=lee-kesler]
Tb          727.54;      // K   [origin=predictive method=joback]
HvapTb      68467.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.167 1.28352 -0.00069076 1.053e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-(4-phenylmethoxyphenyl)propanoate" "methyl 3-(4-(benzyloxy)phenyl)propanoate" "propanoic acid, 3-(4-benzyloxyphenyl)-, methyl ester" "benzenepropanoic acid, 4-(phenylmethoxy)-, methyl ester" );
standardThermochemistry
{
    dHf_298   -382120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     661.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-107920.0
}
