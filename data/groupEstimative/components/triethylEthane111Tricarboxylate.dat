/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethyl ethane-1,1,1-tricarboxylate  (C11H18O6, CAS 16515-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triethylEthane111Tricarboxylate;
formula     C11H18O6;
CAS         16515-90-5;
InChIKey    CTFRGNLAGFUMHR-UHFFFAOYSA-N;
MW          246.259;      // g/mol [origin=calculated method=formula-sum]
Tc          809.65;      // K   [origin=predictive method=joback]
Pc          19.930;      // bar [origin=predictive method=joback]
omega       0.8910;      // -   [origin=predictive method=lee-kesler]
Tb          622.71;      // K   [origin=predictive method=joback]
HvapTb      61005.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.643 1.01028 -0.0004626 2.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -1230960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     699.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-886530.0
    phase     gas;
}
