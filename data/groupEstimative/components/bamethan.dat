/*--------------------------------*- Choupo -*-----------------------*\
  Component: bamethan  (C12H19NO2, CAS 3703-79-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bamethan;
formula     C12H19NO2;
CAS         3703-79-5;
InChIKey    RDUHXGIIUDVSHR-UHFFFAOYSA-N;
MW          209.289;      // g/mol [origin=calculated method=formula-sum]
Tc          925.40;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       1.3765;      // -   [origin=predictive method=lee-kesler]
Tb          723.37;      // K   [origin=predictive method=joback]
HvapTb      80323.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.446 1.33562 -0.00099876 3.1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(butylamino)-1-oxidanyl-ethyl]phenol" "butylsympathol" "bamethane" "butedrine" "butyl-nor-sympatol" "n-dutylnorsympathol" "n-butylnorsynephrine" "bamethan [inn:ban]" "bamethanum [inn-latin]" "2-butylamino-1-p-hydroxyphenylethanol" "1-(p-hydroxyphenyl)-2-butylaminoethanol" "4-[2-(butylamino)-1-hydroxyethyl]phenol" );
gibbsFormation
{
    dHf_298   -335830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41920.0
    phase     gas;
}
