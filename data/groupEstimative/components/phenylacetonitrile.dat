/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylacetonitrile  (C8H7N, CAS 140-29-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylacetonitrile;
formula     C8H7N;
CAS         140-29-4;
InChIKey    SUSQOBVLVYHIEX-UHFFFAOYSA-N;
MW          117.151;      // g/mol [origin=calculated method=formula-sum]
Tc          743.16;      // K   [origin=predictive method=joback]
Pc          35.431;      // bar [origin=predictive method=joback]
omega       0.4554;      // -   [origin=predictive method=lee-kesler]
Tb          511.40;      // K   [origin=predictive method=joback]
HvapTb      46156.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.289 0.6197 -0.0004116 1.032e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylethanenitrile" "benzyl cyanide" "benzeneacetonitrile" "2-phenylacetonitrile" "benzyl nitrile" "alpha-tolunitrile" "alpha-cyanotoluene" "(cyanomethyl)benzene" "phenyl acetyl nitrile" "acetonitrile, phenyl-" "benzylnitrile" "usaf kf-21" );
gibbsFormation
{
    dHf_298   192960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     367.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=262070.0
    phase     gas;
}
