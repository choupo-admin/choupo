/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2,6-dimethylphenyl)azetidine  (C11H15N, CAS 19199-06-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n26DimethylphenylAzetidine;
formula     C11H15N;
CAS         19199-06-5;
InChIKey    MHXYJRDWCLHKMY-UHFFFAOYSA-N;
MW          161.248;      // g/mol [origin=calculated method=formula-sum]
Tc          729.77;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.4875;      // -   [origin=predictive method=lee-kesler]
Tb          511.77;      // K   [origin=predictive method=joback]
HvapTb      45945.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.29 1.15224 -0.00085992 2.603e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,6-dimethylphenyl)azetidine" "azetidine,1-(2,6-dimethylphenyl)-" "azetidine,1-(2,6-xylyl)- (8ci);n-(2,6-dimethylphenyl)azetidine;" );
gibbsFormation
{
    dHf_298   103890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=314130.0
    phase     gas;
}
