/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanoic acid, 3-(2-butoxyethoxy)-  (C9H18O4, CAS 7420-07-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanoicAcid32Butoxyethoxy;
formula     C9H18O4;
CAS         7420-07-7;
InChIKey    YOFIXNJYRMEPFD-UHFFFAOYSA-N;
MW          190.239;      // g/mol [origin=calculated method=formula-sum]
Tc          776.99;      // K   [origin=predictive method=joback]
Pc          24.338;      // bar [origin=predictive method=joback]
omega       0.9956;      // -   [origin=predictive method=lee-kesler]
Tb          595.87;      // K   [origin=predictive method=joback]
HvapTb      57612.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.307 0.78322 -0.0003164 1.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH2O; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group O; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-butoxyethoxy)propanoic acid" "3-(2-butoxyethoxy)propionic acid" "propanoic acid,3-(2-butoxyethoxy)-" "propionicacid, 3-(2-butoxyethoxy)- (7ci,8ci); 3-(2-butoxyethoxy)propionic acid" );
standardThermochemistry
{
    dHf_298   -843800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-529010.0
}
