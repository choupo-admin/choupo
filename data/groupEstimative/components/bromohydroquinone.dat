/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromohydroquinone  (C6H5BrO2, CAS 583-69-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromohydroquinone;
formula     C6H5BrO2;
CAS         583-69-7;
InChIKey    REFDOIWRJDGBHY-UHFFFAOYSA-N;
MW          189.008;      // g/mol [origin=calculated method=formula-sum]
Tc          854.36;      // K   [origin=predictive method=joback]
Pc          83.249;      // bar [origin=predictive method=joback]
omega       0.8349;      // -   [origin=predictive method=lee-kesler]
Tb          590.96;      // K   [origin=predictive method=joback]
HvapTb      63689.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.12 0.8423 -0.00091792 3.86e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylbenzene-1,4-diol" "2-bromohydroquinone" "1,4-benzenediol, 2-bromo-" "2-bromobenzene-1,4-diol" "2-bromoquinol" "2-bromo-1,4-benzenediol" "hydroquinone, bromo-" "bromoquinol" );
standardThermochemistry
{
    dHf_298   -258930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-182870.0
}
