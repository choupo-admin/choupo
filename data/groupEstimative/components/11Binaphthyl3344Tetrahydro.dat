/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-binaphthyl, 3,3',4,4'-tetrahydro-  (C20H18, CAS 5405-96-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Binaphthyl3344Tetrahydro;
formula     C20H18;
CAS         5405-96-9;
InChIKey    QZIBLSYKUOHZFG-UHFFFAOYSA-N;
MW          258.364;      // g/mol [origin=calculated method=formula-sum]
Tc          1025.38;      // K   [origin=predictive method=joback]
Pc          22.937;      // bar [origin=predictive method=joback]
omega       0.6854;      // -   [origin=predictive method=lee-kesler]
Tb          760.16;      // K   [origin=predictive method=joback]
HvapTb      68686.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.95 1.7316 -0.0012914 3.818e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=C; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3,4-dihydronaphthalen-1-yl)-1,2-dihydronaphthalene" "1,1'-binaphthalene, 3,3',4,4'-tetrahydro-" "1, 3,3',4,4'-tetrahydro-" "1,1',2,2'-tetrahydro-4,4'-binaphthalene" "3,3',4,4'-tetrahydro-1,1'-binaphthalene" "1,1'-binaphthalene,3,3',4,4'-tetrahydro-" );
standardThermochemistry
{
    dHf_298   260570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=476460.0
}
