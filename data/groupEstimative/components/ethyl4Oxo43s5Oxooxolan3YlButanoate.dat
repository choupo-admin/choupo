/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 4-oxo-4-[(3s)-5-oxooxolan-3-yl]butanoate  (C10H14O5, CAS 72252-46-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl4Oxo43s5Oxooxolan3YlButanoate;
formula     C10H14O5;
CAS         72252-46-1;
InChIKey    JSSPTTVDXUEFBG-ZETCQYMHSA-N;
MW          214.217;      // g/mol [origin=calculated method=formula-sum]
Tc          800.19;      // K   [origin=predictive method=joback]
Pc          25.637;      // bar [origin=predictive method=joback]
omega       0.9081;      // -   [origin=predictive method=lee-kesler]
Tb          605.45;      // K   [origin=predictive method=joback]
HvapTb      59327.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.733 0.96712 -0.0005325 8.386e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2CO; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group CdO; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 4-oxidanylidene-4-[(3s)-5-oxidanylideneoxolan-3-yl]butanoate" );
gibbsFormation
{
    dHf_298   -924070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-655590.0
    phase     gas;
}
