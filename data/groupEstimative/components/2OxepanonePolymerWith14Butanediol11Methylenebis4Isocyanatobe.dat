  Component: 2-oxepanone, polymer with 1,4-butanediol, 1,1'-methylenebis(4-isocyanatobenzene) and 2,2'-oxybis(ethanol)  (C29H40N2O9, CAS 56990-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OxepanonePolymerWith14Butanediol11Methylenebis4Isocyanatobe;
formula     C29H40N2O9;
CAS         56990-15-9;
InChIKey    HWVZBCRVHCPVTE-UHFFFAOYSA-N;
MW          560.644;      // g/mol [origin=calculated method=formula-sum]
Tc          2121.13;      // K   [origin=predictive method=joback]
Pc          11.752;      // bar [origin=predictive method=joback]
omega       0.1918;      // -   [origin=predictive method=lee-kesler]
Tb          1533.29;      // K   [origin=predictive method=joback]
HvapTb      183069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 10; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 3; } { group CH2COO; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 9; } { group dCd; count 2; } { group CH2_ring; count 5; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 4; } { group O; count 1; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,4-diol;2-(2-hydroxyethyloxy)ethanol;1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene;oxepan-2-one" "butane-1,4-diol; 2-(2-hydroxyethoxy)ethanol; 1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene; oxepan-2-one" "2-oxepanone, polymer with 1,4-butanediol, 1,1-methylenebis-[4-isocyanatobenzene] and 2,2'-oxybis[ethanol];2-oxepanone,polymer with 1,4-butanediol,1,1-methylenebis-[4-isocyanatobenzene] and 2,2'-oxybis[ethanol]" );
