/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylheneicosane  (C22H46, CAS 6418-47-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylheneicosane;
formula     C22H46;
CAS         6418-47-9;
InChIKey    OSJUENOXPFOHLF-UHFFFAOYSA-N;
MW          310.61;      // g/mol [origin=calculated method=formula-sum]
Tc          867.50;      // K   [origin=predictive method=joback]
Pc          9.062;      // bar [origin=predictive method=joback]
omega       0.7873;      // -   [origin=predictive method=lee-kesler]
Tb          702.52;      // K   [origin=predictive method=joback]
HvapTb      64178.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.792 2.09976 -0.0011762 2.501e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 18; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 18; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylhenicosane" "heneicosane, 3-methyl-" );
gibbsFormation
{
    dHf_298   -502690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1003.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=131920.0
    phase     gas;
}
