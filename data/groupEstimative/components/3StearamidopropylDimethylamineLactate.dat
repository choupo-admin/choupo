/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-stearamidopropyl)dimethylamine, lactate  (C26H54N2O4, CAS 55819-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3StearamidopropylDimethylamineLactate;
formula     C26H54N2O4;
CAS         55819-53-9;
InChIKey    NTLIJZACUWTZFB-UHFFFAOYSA-N;
MW          458.728;      // g/mol [origin=calculated method=formula-sum]
Tc          1470.40;      // K   [origin=predictive method=joback]
Pc          7.984;      // bar [origin=predictive method=joback]
omega       0.3932;      // -   [origin=predictive method=lee-kesler]
Tb          1149.61;      // K   [origin=predictive method=joback]
HvapTb      122444.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.739 2.53048 -0.0012245 1.5716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 18; } { group CH; count 1; } { group OH; count 1; } { group CH3N; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 19; } { group CH; count 1; } { group OH; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[3-(dimethylamino)propyl]octadecanamide;2-oxidanylpropanoic acid" "(3-stearylamidopropyl)dimethylammonium lactate" "propanoic acid, 2-hydroxy-, compd. with n-(3-(dimethylamino)propyl)octadecanamide (1:1)" "dimethyl((3-stearoylamino)propyl)ammonium lactate" "n,n-dimethyl-n-(3-stearamidopropyl)amine, lactate" "n,n-dimethyl-n-(3-stearamidopropyl)amine, (+-)-lactic acid salt" "n-[3-(dimethylamino)propyl]octadecanamide; 2-hydroxypropanoic acid" "2-hydroxypropanoic acid - n-[3-(dimethylamino)propyl]octadecanamide (1:1)" "(1)-lactic acid, compound with n-(3-(dimethylamino)propyl)octadecanamide (1:1)" );
standardThermochemistry
{
    dHf_298   -1190950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1454.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-348640.0
}
