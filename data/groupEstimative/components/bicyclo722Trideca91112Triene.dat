/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo(7.2.2)trideca-9,11,12-triene  (C13H18, CAS 3761-63-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo722Trideca91112Triene;
formula     C13H18;
CAS         3761-63-5;
InChIKey    MGCLXVBQCDCWPA-UHFFFAOYSA-N;
MW          174.287;      // g/mol [origin=calculated method=formula-sum]
Tc          803.41;      // K   [origin=predictive method=joback]
Pc          28.084;      // bar [origin=predictive method=joback]
omega       0.3973;      // -   [origin=predictive method=lee-kesler]
Tb          557.19;      // K   [origin=predictive method=joback]
HvapTb      48380.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.2 1.2394 -0.00073756 1.52e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[7.2.2]trideca-1(11),9,12-triene" "bicyclo[7.2.2]trideca-9,11,12-triene" );
standardThermochemistry
{
    dHf_298   -18090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     581.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=181420.0
}
