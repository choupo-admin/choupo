/*--------------------------------*- Choupo -*-----------------------*\
  Component: coumarin, 3-methyl-  (C10H8O2, CAS 2445-82-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coumarin3Methyl;
formula     C10H8O2;
CAS         2445-82-1;
InChIKey    VIIIJFZJKFXOGG-UHFFFAOYSA-N;
MW          160.172;      // g/mol [origin=calculated method=formula-sum]
Tc          752.60;      // K   [origin=predictive method=joback]
Pc          34.684;      // bar [origin=predictive method=joback]
omega       0.5630;      // -   [origin=predictive method=lee-kesler]
Tb          529.56;      // K   [origin=predictive method=joback]
HvapTb      49203.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.38 0.83212 -0.000632 1.88e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylchromen-2-one" "3-methylcoumarin" "2h-1-benzopyran-2-one, 3-methyl-" "3-methyl-2h-1-benzopyran-2-one" "methyl-2-benzopyrone" "3-methyl-chromen-2-one" "2h-1-benzopyran-2-one,3-methyl-" "2h-1-benzopyran-2-one, 3-methyl- (9ci)" );
standardThermochemistry
{
    dHf_298   -196340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-73380.0
}
