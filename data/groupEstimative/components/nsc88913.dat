/*--------------------------------*- Choupo -*-----------------------*\
  Component: nsc 88913  (C24H26O4, CAS 21327-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nsc88913;
formula     C24H26O4;
CAS         21327-74-2;
InChIKey    HCDCCKDQHKYDSN-UHFFFAOYSA-N;
MW          378.468;      // g/mol [origin=calculated method=formula-sum]
Tc          1198.65;      // K   [origin=predictive method=joback]
Pc          14.337;      // bar [origin=predictive method=joback]
omega       0.9918;      // -   [origin=predictive method=lee-kesler]
Tb          954.55;      // K   [origin=predictive method=joback]
HvapTb      91004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.52 1.94196 -0.00107272 1.737e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3COO; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 5; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[(4-acetyloxyphenyl)-(2-methylcyclohexylidene)methyl]phenyl] ethanoate" "4-((4-(acetyloxy)phenyl)(2-methylcyclohexylidene)methyl)phenol acetate" "4-((4-(acetyloxy)phenyl)(2-methylcyclohexylidene)methyl)phenol, diacetate" "alpha-(p-hydroxyphenyl)-alpha-(2-methylcyclohexylidene)-p-cresol diacetate" "phenol, 4-((4-(acetyloxy)phenyl)(2-methylcyclohexylidene)methyl)-, acetate" "p-cresol, alpha-(p-hydroxyphenyl)-alpha-(2-methylcyclohexylidene)-, diacetate" "[4-[(4-acetyloxyphenyl)-(2-methylcyclohexylidene)methyl]phenyl] acetate" );
standardThermochemistry
{
    dHf_298   -602570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     905.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-202620.0
}
