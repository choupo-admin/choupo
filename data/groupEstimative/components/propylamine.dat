/*--------------------------------*- Choupo -*-----------------------*\
  Component: propylamine  (C3H9N, CAS 107-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propylamine;
formula     C3H9N;
CAS         107-10-8;
InChIKey    WGYKZJWCGVVSQN-UHFFFAOYSA-N;
MW          59.112;      // g/mol [origin=calculated method=formula-sum]
Tc          522.87;      // K   [origin=predictive method=joback]
Pc          47.628;      // bar [origin=predictive method=joback]
omega       0.3273;      // -   [origin=predictive method=lee-kesler]
Tb          340.77;      // K   [origin=predictive method=joback]
HvapTb      32913.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.652 0.35072 -0.0001828 3.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-1-amine" "1-propanamine" "1-aminopropane" "n-propylamine" "monopropylamine" "propanamine" "mono-n-propylamine" "1-propylamine" "propyl amine" "propyl amines" "n-propyl amine" "3-aminopropyl" );
gibbsFormation
{
    dHf_298   -71460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     324.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40830.0
    phase     gas;
}
