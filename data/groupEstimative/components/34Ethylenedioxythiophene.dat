/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-ethylenedioxythiophene  (C6H6O2S, CAS 126213-50-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Ethylenedioxythiophene;
formula     C6H6O2S;
CAS         126213-50-1;
InChIKey    GKWLILHTTGWKLQ-UHFFFAOYSA-N;
MW          142.172;      // g/mol [origin=calculated method=formula-sum]
Tc          731.10;      // K   [origin=predictive method=joback]
Pc          52.893;      // bar [origin=predictive method=joback]
omega       0.4143;      // -   [origin=predictive method=lee-kesler]
Tb          482.52;      // K   [origin=predictive method=joback]
HvapTb      46650.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.67 0.67721 -0.00054598 1.755e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group FCH2O; count 2; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group O_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydrothieno[3,4-b][1,4]dioxine" "edot" "3,4-ethylenedioxy thiophene" "thieno[3,4-b]-1,4-dioxin, 2,3-dihydro-" "2h,3h-thiopheno[3,4-e]1,4-dioxane" "2,3-dihydrothieno(3,4-b)-1,4-dioxin" "2,3-dihydrothieno[3,4-b]-1,4-dioxin" "thieno(3,4-b)-1,4-dioxin, 2,3-dihydro-" "3,4-ethylendioxythiophen" "3,4-ethyl enedioxythiophene" "am711" "2,3-dihydrothieno[3,4-b][1,4]dioxin" );
standardThermochemistry
{
    dHf_298   -125490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     214.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8540.0
}
