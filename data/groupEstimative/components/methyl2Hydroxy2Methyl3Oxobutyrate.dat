/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-hydroxy-2-methyl-3-oxobutyrate  (C6H10O4, CAS 72450-34-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Hydroxy2Methyl3Oxobutyrate;
formula     C6H10O4;
CAS         72450-34-1;
InChIKey    LNOXHAVSBXMUOI-UHFFFAOYSA-N;
MW          146.142;      // g/mol [origin=calculated method=formula-sum]
Tc          724.85;      // K   [origin=predictive method=joback]
Pc          38.340;      // bar [origin=predictive method=joback]
omega       0.9787;      // -   [origin=predictive method=lee-kesler]
Tb          537.92;      // K   [origin=predictive method=joback]
HvapTb      58486.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.02 0.65086 -0.0003915 7.576e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group OH; count 1; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group OH; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-methyl-2-oxidanyl-3-oxidanylidene-butanoate" "methyl a-acetolactate" "methyl 2-hydroxy-2-methyl-3-oxobutanoate" "butanoic acid,2-hydroxy-2-methyl-3-oxo-, methyl ester" );
gibbsFormation
{
    dHf_298   -758010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-573630.0
    phase     gas;
}
