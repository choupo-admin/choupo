/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-amino-4-methylbenzamide  (C8H10N2O, CAS 19406-86-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Amino4Methylbenzamide;
formula     C8H10N2O;
CAS         19406-86-1;
InChIKey    VYBKAZXQKUFAHG-UHFFFAOYSA-N;
MW          150.181;      // g/mol [origin=calculated method=formula-sum]
Tc          860.99;      // K   [origin=predictive method=joback]
Pc          43.974;      // bar [origin=predictive method=joback]
omega       0.7989;      // -   [origin=predictive method=lee-kesler]
Tb          618.21;      // K   [origin=predictive method=joback]
HvapTb      65030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.65 0.66172 -0.00037662 7.266e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACNH2; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group CdO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azanyl-4-methyl-benzamide" "3-amino-p-toluamide" "benzamide, 3-amino-4-methyl-" "benzamide,3-amino-4-methyl-" "o052" "p-toluamide,3-amino- (8ci);benzamide, 3-amino-4-methyl-;3-amino-p-toluamide;" );
gibbsFormation
{
    dHf_298   -39860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113610.0
    phase     gas;
}
