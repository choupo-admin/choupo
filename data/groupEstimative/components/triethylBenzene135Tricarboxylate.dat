/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethyl benzene-1,3,5-tricarboxylate  (C15H18O6, CAS 4105-92-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triethylBenzene135Tricarboxylate;
formula     C15H18O6;
CAS         4105-92-4;
InChIKey    KXGOWZRHSOJOLF-UHFFFAOYSA-N;
MW          294.303;      // g/mol [origin=calculated method=formula-sum]
Tc          957.80;      // K   [origin=predictive method=joback]
Pc          18.232;      // bar [origin=predictive method=joback]
omega       1.0551;      // -   [origin=predictive method=lee-kesler]
Tb          754.10;      // K   [origin=predictive method=joback]
HvapTb      74805.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.173 1.06656 -0.00040552 -2.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group ACH; count 3; } { group AC; count 3; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethyl trimesate" "triethyl 1,3,5-benzenetricarboxylate" "1,3,5-benzenetricarboxylic acid, triethyl ester" "ethyl 3,5-bis(ethoxycarbonyl)benzoate" "trimesic acid triethyl ester" "triethyl 1,5-benzenetricarboxylate" "1,5-benzenetricarboxylic acid, triethyl ester" "benzene-1,3,5-tricarboxylic acid triethyl ester" "1,3,5-benzenetricarboxylicacid, 1,3,5-triethyl ester" );
gibbsFormation
{
    dHf_298   -1091180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     775.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-762540.0
    phase     gas;
}
