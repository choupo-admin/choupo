/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorotetradecane  (C14H29Cl, CAS 34942-43-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorotetradecane;
formula     C14H29Cl;
CAS         34942-43-3;
InChIKey    BDOUIUPFTBUPNU-UHFFFAOYSA-N;
MW          232.836;      // g/mol [origin=calculated method=formula-sum]
Tc          724.55;      // K   [origin=predictive method=joback]
Pc          14.896;      // bar [origin=predictive method=joback]
omega       0.6943;      // -   [origin=predictive method=lee-kesler]
Tb          556.91;      // K   [origin=predictive method=joback]
HvapTb      50755.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.371 1.34654 -0.0007614 1.639e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyltetradecane" "tetradecane, 2-chloro-" );
gibbsFormation
{
    dHf_298   -353310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     725.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=52630.0
    phase     gas;
}
