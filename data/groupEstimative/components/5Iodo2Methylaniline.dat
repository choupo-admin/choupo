/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-iodo-2-methylaniline  (C7H8IN, CAS 83863-33-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Iodo2Methylaniline;
formula     C7H8IN;
CAS         83863-33-6;
InChIKey    IOEHXNCBPIBDBZ-UHFFFAOYSA-N;
MW          233.048;      // g/mol [origin=calculated method=formula-sum]
Tc          826.51;      // K   [origin=predictive method=joback]
Pc          41.409;      // bar [origin=predictive method=joback]
omega       0.4601;      // -   [origin=predictive method=lee-kesler]
Tb          562.07;      // K   [origin=predictive method=joback]
HvapTb      54790.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.4 0.57182 -0.00037892 9.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACNH2; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group I; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-iodanyl-2-methyl-aniline" "2-amino-4-iodotoluene" "5-iodo-2-methyl-phenylamine" "5-iodo-o-toluidine" "benzenamine, 5-iodo-2-methyl-" "5-iodo-2-methylphenylamine" "5-iodo-2-methylbenzenamine" "tpc-i125" "2-amino-4-iodotoluene; 5-iodo-o-toluidine" "3-iodo-6-methylaniline;5-iodo-2-methyl-phenylamine;5-iodo-2-methylbenzenamine;" );
gibbsFormation
{
    dHf_298   136440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225780.0
    phase     gas;
}
