/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, diethynyldimethyl-  (C6H8Si, CAS 1675-60-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H8Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneDiethynyldimethyl;
formula     C6H8Si;
CAS         1675-60-1;
InChIKey    PEMATDLNMXTNGL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          108.215;      // g/mol [origin=calculated method=formula-sum]
Tc          514.68;      // K   [origin=predictive method=joback]
Pc          38.198;      // bar [origin=predictive method=joback]
omega       0.0925;      // -   [origin=predictive method=lee-kesler]
Tb          318.52;      // K   [origin=predictive method=joback]
HvapTb      28960.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (65.81 0.17984 0.00012034 -1.2022e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH_C; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group tCH; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethynyl(dimethyl)silane" "pematdlnmxtngl-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   305010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=341020.0
}
