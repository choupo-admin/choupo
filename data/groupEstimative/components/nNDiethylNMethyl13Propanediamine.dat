/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethyl-n'-methyl-1,3-propanediamine  (C8H20N2, CAS 5459-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethylNMethyl13Propanediamine;
formula     C8H20N2;
CAS         5459-95-0;
InChIKey    SMJVVYQWUFKTKZ-UHFFFAOYSA-N;
MW          144.262;      // g/mol [origin=calculated method=formula-sum]
Tc          612.26;      // K   [origin=predictive method=joback]
Pc          25.637;      // bar [origin=predictive method=joback]
omega       0.6161;      // -   [origin=predictive method=lee-kesler]
Tb          445.25;      // K   [origin=predictive method=joback]
HvapTb      41881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.285 0.96396 -0.0005726 1.319e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH3NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n',n'-diethyl-n-methyl-propane-1,3-diamine" "1,3-propanediamine, n,n-diethyl-n'-methyl-" "[3-(diethylamino)propyl](methyl)amine" "n1,n1-diethyl-n3-methyl-1,3-propanediamine" "1,3-propanediamine, n1,n1-diethyl-n3-methyl-" "1, n,n-diethyl-n'-methyl-" "diethyl-(3-methylamino-propyl)-amine" "n,n-diethyl-n'-methylpropane-1,3-diamine" "n',n'-diethyl-n-methylpropane-1,3-diamine" );
standardThermochemistry
{
    dHf_298   -87450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=216650.0
}
