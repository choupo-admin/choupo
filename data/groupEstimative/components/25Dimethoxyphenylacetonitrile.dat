/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethoxyphenylacetonitrile  (C10H11NO2, CAS 18086-24-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethoxyphenylacetonitrile;
formula     C10H11NO2;
CAS         18086-24-3;
InChIKey    DBKDGRJAFWDOOJ-UHFFFAOYSA-N;
MW          177.203;      // g/mol [origin=calculated method=formula-sum]
Tc          831.75;      // K   [origin=predictive method=joback]
Pc          26.680;      // bar [origin=predictive method=joback]
omega       0.7147;      // -   [origin=predictive method=lee-kesler]
Tb          611.96;      // K   [origin=predictive method=joback]
HvapTb      56752.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.491 0.56434 -0.00016432 -3.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 2; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,5-dimethoxyphenyl)ethanenitrile" "2-(2,5-dimethoxyphenyl)acetonitrile" "benzeneacetonitrile,2,5-dimethoxy-" );
standardThermochemistry
{
    dHf_298   -135700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49650.0
}
