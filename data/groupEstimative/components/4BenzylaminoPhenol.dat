/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(benzylamino)phenol  (C13H13NO, CAS 103-14-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BenzylaminoPhenol;
formula     C13H13NO;
CAS         103-14-0;
InChIKey    SRYYOKKLTBRLHT-UHFFFAOYSA-N;
MW          199.253;      // g/mol [origin=calculated method=formula-sum]
Tc          932.21;      // K   [origin=predictive method=joback]
Pc          37.090;      // bar [origin=predictive method=joback]
omega       0.8391;      // -   [origin=predictive method=lee-kesler]
Tb          681.19;      // K   [origin=predictive method=joback]
HvapTb      68534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.869 1.3118 -0.00105076 3.381e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACOH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(phenylmethyl)amino]phenol" "phenol, p-(benzylamino)-" "4-benzylaminophenol" "4-n-benzylaminophenol" "phenol, 4-[(phenylmethyl)amino]-" "n-(4-hydroxyphenyl)benzylamine" "phenol, 4-((phenylmethyl)amino)-" "4-[benzylamino]phenol" "4-(benzylamino)-phenol" "sryyokkltbrlht-uhfffaoysa-" "phenol,4-[(phenylmethyl)amino]-" "phenol,p-(benzylamino)- (6ci,7ci,8ci); 4-(benzylamino)phenol; 4-n-benzylaminophenol;4-[(phenylmethyl)amino]phenol; n-(4-hydroxyphenyl)benzylamine;n-benzyl-4-aminophenol; n-benzyl-4-hydroxyaniline; n-benzyl-p-aminophenol;p-(benzylamino)phenol; p-(n-benzylamino)phenol" );
standardThermochemistry
{
    dHf_298   37570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=218170.0
}
