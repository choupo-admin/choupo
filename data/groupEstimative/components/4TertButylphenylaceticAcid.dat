/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butylphenylacetic acid  (C12H16O2, CAS 32857-63-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylphenylaceticAcid;
formula     C12H16O2;
CAS         32857-63-9;
InChIKey    RUAYXHSDAMWEDR-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          873.83;      // K   [origin=predictive method=joback]
Pc          26.407;      // bar [origin=predictive method=joback]
omega       0.7668;      // -   [origin=predictive method=lee-kesler]
Tb          648.10;      // K   [origin=predictive method=joback]
HvapTb      61112.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.499 1.18206 -0.00083756 2.321e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-tert-butylphenyl)ethanoic acid" "(4-tert-butylphenyl)acetic acid" "2-(4-tert-butylphenyl)acetic acid" "4-t-butylphenylacetic acid" "benzeneacetic acid, 4-(1,1-dimethylethyl)-" "tb2" "4-(tert-butyl)phenylacetic acid" "(4-tert-butyl-phenyl)-acetic acid" "acetic acid, (p-tert-butylphenyl)-" "2-(4-(tert-butyl)phenyl)acetic acid" );
standardThermochemistry
{
    dHf_298   -424970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-188130.0
}
