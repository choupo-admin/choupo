/*--------------------------------*- Choupo -*-----------------------*\
  Component: octyl lactate  (C11H22O3, CAS 5464-71-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octylLactate;
formula     C11H22O3;
CAS         5464-71-1;
InChIKey    SFBIZPBTKROSDE-UHFFFAOYSA-N;
MW          202.294;      // g/mol [origin=calculated method=formula-sum]
Tc          767.70;      // K   [origin=predictive method=joback]
Pc          21.256;      // bar [origin=predictive method=joback]
omega       1.1115;      // -   [origin=predictive method=lee-kesler]
Tb          601.24;      // K   [origin=predictive method=joback]
HvapTb      63778.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.907 1.03394 -0.0005136 7.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octyl 2-oxidanylpropanoate" "octyl 2-hydroxypropanoate" "propanoic acid, 2-hydroxy-, octyl ester" "octyl (2s)-2-hydroxypropanoate" "propanoic acid, 2-hydroxy-, octyl ester, (s)-" "propanoic acid,2-hydroxy-, octyl ester, (2s)-" "propanoicacid, 2-hydroxy-, octyl ester, (s)-; octyl (-)-lactate" );
gibbsFormation
{
    dHf_298   -745160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     677.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-407890.0
    phase     gas;
}
