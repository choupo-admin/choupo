/*--------------------------------*- Choupo -*-----------------------*\
  Component: adipic acid, trimethylolpropane monoallyl ether polymer  (C15H28O7, CAS 61680-38-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        adipicAcidTrimethylolpropaneMonoallylEtherPolymer;
formula     C15H28O7;
CAS         61680-38-4;
InChIKey    WGIUMUPNZRABPX-UHFFFAOYSA-N;
MW          320.382;      // g/mol [origin=calculated method=formula-sum]
Tc          1272.53;      // K   [origin=predictive method=joback]
Pc          18.263;      // bar [origin=predictive method=joback]
omega       1.4608;      // -   [origin=predictive method=lee-kesler]
Tb          1035.45;      // K   [origin=predictive method=joback]
HvapTb      117408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.889 1.43482 -0.0006671 6.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group C; count 1; } { group CH2=CH; count 1; } { group OH; count 2; } { group CH2O; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 2; } { group O; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-2-(prop-2-enoxymethyl)propane-1,3-diol;hexanedioic acid" "2-ethyl-2-(prop-2-enoxymethyl)propane-1,3-diol; hexanedioic acid" "hexanedioic acid, polymer with 2-ethyl-2-((2-propen-1-yloxy)methyl)-1,3-propanediol" "hexanedioic acid, polymer with 2-ethyl-2-((2-propenyloxy)methyl)-1,3-propanediol" );
standardThermochemistry
{
    dHf_298   -1485090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1023.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1005120.0
}
