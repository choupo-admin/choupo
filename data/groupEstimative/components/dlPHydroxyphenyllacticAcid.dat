/*--------------------------------*- Choupo -*-----------------------*\
  Component: dl-p-hydroxyphenyllactic acid  (C9H10O4, CAS 306-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dlPHydroxyphenyllacticAcid;
formula     C9H10O4;
CAS         306-23-0;
InChIKey    JVGVDSSUAVXRDY-UHFFFAOYSA-N;
MW          182.175;      // g/mol [origin=calculated method=formula-sum]
Tc          969.97;      // K   [origin=predictive method=joback]
Pc          50.086;      // bar [origin=predictive method=joback]
omega       1.5639;      // -   [origin=predictive method=lee-kesler]
Tb          750.07;      // K   [origin=predictive method=joback]
HvapTb      84373.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.909 1.0252 -0.00085956 2.918e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-hydroxyphenyl)-2-oxidanyl-propanoic acid" "2-hydroxy-3-(4-hydroxyphenyl)propanoic acid" "hpla" "3-(4-hydroxyphenyl)lactic acid" "beta-(p-hydroxyphenyl)lactic acid" "4-hydroxyphenyllactic acid" "beta-(4-hydroxyphenyl)lactic acid" "p-hydroxyphenyl lactic acid" "2-hydroxy-3-(p-hydroxyphenyl)propionic acid" "lactic acid, 3-(p-hydroxyphenyl)-" "b-(4-hydroxyphenyl)lactic acid" "lactic acid, (p-hydroxyphenyl)-" );
gibbsFormation
{
    dHf_298   -677650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-500480.0
    phase     gas;
}
