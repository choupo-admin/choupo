/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-0365cb  (C11H18, CAS 106562-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc0365cb;
formula     C11H18;
CAS         106562-31-6;
InChIKey    MWCYZAVQYCJVIJ-UHFFFAOYSA-N;
MW          150.265;      // g/mol [origin=calculated method=formula-sum]
Tc          676.48;      // K   [origin=predictive method=joback]
Pc          26.218;      // bar [origin=predictive method=joback]
omega       0.3507;      // -   [origin=predictive method=lee-kesler]
Tb          467.35;      // K   [origin=predictive method=joback]
HvapTb      39845.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.8 1.25484 -0.00085728 2.34e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 4; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-propan-2-ylbicyclo[2.2.2]oct-2-ene" "(1s,4s,5s)-5-propan-2-ylbicyclo[2.2.2]oct-2-ene" "bicyclo(2.2.2)oct-2-ene, 5-(1-methylethyl)-, (1alpha,4alpha,5alpha)-" "bicyclo[2.2.2]oct-2-ene, 5-(1-methylethyl)-, (1.alpha.,4.alpha.,5.beta.)-" "bicyclo[2.2.2]oct-2-ene,5-(1-methylethyl)-,(1.alpha.,4.alpha.,5.alpha.)-" );
standardThermochemistry
{
    dHf_298   -104930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     354.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158850.0
}
