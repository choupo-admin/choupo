/*--------------------------------*- Choupo -*-----------------------*\
  Component: echimidine  (C20H31NO7, CAS 520-68-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        echimidine;
formula     C20H31NO7;
CAS         520-68-3;
InChIKey    HRSGCYGUWHGOPY-LYHHMGRNSA-N;
MW          397.468;      // g/mol [origin=calculated method=formula-sum]
Tc          1333.08;      // K   [origin=predictive method=joback]
Pc          16.728;      // bar [origin=predictive method=joback]
omega       1.3440;      // -   [origin=predictive method=lee-kesler]
Tb          1081.65;      // K   [origin=predictive method=joback]
HvapTb      125018.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.319 2.4743 -0.00182594 5.199e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 3; } { group C; count 2; } { group CH=C; count 2; } { group OH; count 3; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group C; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 3; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(7r,8r)-7-[(z)-2-methylbut-2-enoyl]oxy-5,6,7,8-tetrahydro-3h-pyrrolizin-1-yl]methyl (2r)-3-methyl-2,3-bis(oxidanyl)-2-[(1s)-1-oxidanylethyl]butanoate" "7-angelyl-9-echimidinylretronecine" "[(7r,8r)-7-[(z)-2-methylbut-2-enoyl]oxy-5,6,7,8-tetrahydro-3h-pyrrolizin-1-yl]methyl (2r)-2,3-dihydroxy-2-[(1s)-1-hydroxyethyl]-3-methylbutanoate" "2-butenoic acid, 2-methyl-, 7-((2,3-dihydroxy-2-(1-hydroxyethyl)-3-methyl-1-oxobutoxy)methyl)-2,3,5,7a-tetrahydro-1h-pyrrolizin-1-yl ester, (1r-(1alpha(z),7(2r*,3s*),7abeta))-" );
gibbsFormation
{
    dHf_298   -1209450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     904.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-598260.0
    phase     gas;
}
