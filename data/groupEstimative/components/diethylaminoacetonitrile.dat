/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylaminoacetonitrile  (C6H12N2, CAS 3010-02-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylaminoacetonitrile;
formula     C6H12N2;
CAS         3010-02-4;
InChIKey    LVPZSMIBSMMLPI-UHFFFAOYSA-N;
MW          112.176;      // g/mol [origin=calculated method=formula-sum]
Tc          638.31;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       0.5283;      // -   [origin=predictive method=lee-kesler]
Tb          451.40;      // K   [origin=predictive method=joback]
HvapTb      41471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.743 0.63254 -0.0003842 9.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethanenitrile" "2-(diethylamino)acetonitrile" "acetonitrile, (diethylamino)-" "(diethylamino)acetonitrile" "n,n-diethylaminoacetonitrile" "nitril kiseliny diethylaminooctove" "glycinonitrile, n,n-diethyl-" "acetonitrile, 2-(diethylamino)-" "n,n-diethylglycinonitrile" "glycinonitrile,n-diethyl-" "2-diethylamino-acetonitrile" "acetonitrile,2-(diethylamino)-" );
gibbsFormation
{
    dHf_298   65240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243600.0
    phase     gas;
}
