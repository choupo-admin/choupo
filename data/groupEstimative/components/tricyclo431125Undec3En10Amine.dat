/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(4.3.1.12,5)undec-3-en-10-amine  (C11H17N, CAS 85229-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo431125Undec3En10Amine;
formula     C11H17N;
CAS         85229-65-8;
InChIKey    FHLZIYNVLQXIAD-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          774.11;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.4853;      // -   [origin=predictive method=lee-kesler]
Tb          542.39;      // K   [origin=predictive method=joback]
HvapTb      50478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.93 1.4352 -0.00106228 3.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 4; } { group CH=CH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 5; } { group dCH_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[4.3.1.12,5]undec-3-en-10-amine" );
standardThermochemistry
{
    dHf_298   -13400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     283.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=280780.0
}
