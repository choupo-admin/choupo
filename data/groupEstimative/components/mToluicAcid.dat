/*--------------------------------*- Choupo -*-----------------------*\
  Component: m-toluic acid  (C8H8O2, CAS 99-04-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mToluicAcid;
formula     C8H8O2;
CAS         99-04-7;
InChIKey    GPSDUZXPYCFOSQ-UHFFFAOYSA-N;
MW          136.15;      // g/mol [origin=calculated method=formula-sum]
Tc          789.26;      // K   [origin=predictive method=joback]
Pc          40.007;      // bar [origin=predictive method=joback]
omega       0.6745;      // -   [origin=predictive method=lee-kesler]
Tb          559.81;      // K   [origin=predictive method=joback]
HvapTb      53504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.39 0.67622 -0.00044816 1.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbenzoic acid" "benzoic acid, 3-methyl-" "m-toluylic acid" "3-toluic acid" "m-methylbenzoic acid" "meta-toluic acid" "beta-methylbenzoic acid" "beta-bethylbenzoic acid" "3-methyl-benzoic acid" "agn-pc-0d6ulo" "benzoic acid,3-methyl" "68092-46-6 (zinc salt)" );
gibbsFormation
{
    dHf_298   -333660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-224650.0
    phase     gas;
}
