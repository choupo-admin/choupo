/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-bis-(trimethylsiloxy)-1-sila-3-cyclopentene  (C10H24O2Si3, CAS 76795-95-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H24O2Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        11BisTrimethylsiloxy1Sila3Cyclopentene;
formula     C10H24O2Si3;
CAS         76795-95-4;
InChIKey    NSSXJEVMCSWVID-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          260.555;      // g/mol [origin=calculated method=formula-sum]
Tc          694.05;      // K   [origin=predictive method=joback]
Pc          18.139;      // bar [origin=predictive method=joback]
omega       0.3120;      // -   [origin=predictive method=lee-kesler]
Tb          492.28;      // K   [origin=predictive method=joback]
HvapTb      44242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (113.73 0.32072 0.00072972 -5.516e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH=CH; count 1; } { group Si; count 1; } { group SiO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[(1-trimethylsilyloxy-2,5-dihydrosilol-1-yl)oxy]silane" );
gibbsFormation
{
    dHf_298   -704270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     882.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-404640.0
    phase     gas;
}
