/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl 3-hydroxyglutarate  (C9H16O5, CAS 32328-03-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl3Hydroxyglutarate;
formula     C9H16O5;
CAS         32328-03-3;
InChIKey    OLLQYIBTJXUEEX-UHFFFAOYSA-N;
MW          204.222;      // g/mol [origin=calculated method=formula-sum]
Tc          786.85;      // K   [origin=predictive method=joback]
Pc          25.715;      // bar [origin=predictive method=joback]
omega       1.2030;      // -   [origin=predictive method=lee-kesler]
Tb          613.70;      // K   [origin=predictive method=joback]
HvapTb      66733.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.134 0.78914 -0.0003102 -9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 3-oxidanylpentanedioate" "diethyl 3-hydroxypentanedioate" "diethyl3-hydroxyglutarate" "diethyl- .beta.-hydroxyglutarate" "ollqyibtjxueex-uhfffaoysa-" "1,5-diethyl 3-hydroxypentanedioate" "diethyl-beta-hydroxyglutarate" "3-hydroxyglutaric acid diethyl ester" "1,2,3-propanetriol,1,3-dipropanoate" "3-hydroxy-pentanedioic acid diethyl ester" "p821" "propionin,1,3-di- (8ci); 1,3-dipropanoylglycerin; 1,3-dipropanoylglycerol;1,3-dipropionin; glycerol 1,3-dipropionate" );
gibbsFormation
{
    dHf_298   -1021160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-735100.0
    phase     gas;
}
