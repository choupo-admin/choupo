/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-ethyl-9-azabicyclo[3.3.1]nonane  (C10H19N, CAS 64776-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Ethyl9Azabicyclo331Nonane;
formula     C10H19N;
CAS         64776-29-0;
InChIKey    VUNILRQWXQENHQ-UHFFFAOYSA-N;
MW          153.269;      // g/mol [origin=calculated method=formula-sum]
Tc          665.45;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       0.4190;      // -   [origin=predictive method=lee-kesler]
Tb          462.86;      // K   [origin=predictive method=joback]
HvapTb      40067.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.619 1.36032 -0.0009804 2.84e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-azabicyclo[3.3.1]nonane,9-ethyl-" "9-azabicyclo(3.3.1)nonane, 9-ethyl-" );
standardThermochemistry
{
    dHf_298   -48920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=241400.0
}
