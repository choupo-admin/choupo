/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisodecyl phthalate  (C28H46O4, CAS 26761-40-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisodecylPhthalate;
formula     C28H46O4;
CAS         26761-40-0;
InChIKey    ZVFDTKUVRCTHQE-UHFFFAOYSA-N;
MW          446.672;      // g/mol [origin=calculated method=formula-sum]
Tc          1210.17;      // K   [origin=predictive method=joback]
Pc          7.873;      // bar [origin=predictive method=joback]
omega       0.7401;      // -   [origin=predictive method=lee-kesler]
Tb          987.46;      // K   [origin=predictive method=joback]
HvapTb      94898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.284 2.42768 -0.00128076 2.074e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 14; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 14; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(8-methylnonyl) benzene-1,2-dicarboxylate" "phthalic acid, diisodecyl ester" "plasticized ddp" "palatinol z" "vestinol dz" "didp (plasticizer)" "bis(isodecyl)phthalate" "di(i-decyl) phthalate" "bis(isodecyl) phthalate" "1,2-benzenedicarboxylic acid, diisodecyl ester" "di-''isodecyl'' phthalate" "bis(8-methylnonyl) phthalate" );
gibbsFormation
{
    dHf_298   -1041310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1217.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-337960.0
    phase     gas;
}
