/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl-2-norbornanol, acetate  (C15H18O2, CAS 71173-15-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyl2NorbornanolAcetate;
formula     C15H18O2;
CAS         71173-15-4;
InChIKey    RSPCTHIVCKFIDB-UHFFFAOYSA-N;
MW          230.307;      // g/mol [origin=calculated method=formula-sum]
Tc          879.37;      // K   [origin=predictive method=joback]
Pc          24.387;      // bar [origin=predictive method=joback]
omega       0.6056;      // -   [origin=predictive method=lee-kesler]
Tb          641.02;      // K   [origin=predictive method=joback]
HvapTb      57205.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-168.9 1.85272 -0.0016 5.742e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-phenyl-3-bicyclo[2.2.1]heptanyl) ethanoate" "agn-pc-03e9hu" "2-norbornanol, 1-phenyl-, acetate" "(4-phenyl-3-bicyclo[2.2.1]heptanyl) acetate" "[(1s,3r,4r)-4-phenyl-3-bicyclo[2.2.1]heptanyl] acetate" );
gibbsFormation
{
    dHf_298   -299340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26340.0
    phase     gas;
}
