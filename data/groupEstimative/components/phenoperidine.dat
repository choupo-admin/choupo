/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenoperidine  (C23H29NO3, CAS 562-26-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenoperidine;
formula     C23H29NO3;
CAS         562-26-5;
InChIKey    IPOPQVVNCFQFRK-UHFFFAOYSA-N;
MW          367.489;      // g/mol [origin=calculated method=formula-sum]
Tc          1186.72;      // K   [origin=predictive method=joback]
Pc          16.852;      // bar [origin=predictive method=joback]
omega       1.2715;      // -   [origin=predictive method=lee-kesler]
Tb          957.12;      // K   [origin=predictive method=joback]
HvapTb      96191.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-177.977 2.56362 -0.0020014 6.406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group C; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 1-(3-oxidanyl-3-phenyl-propyl)-4-phenyl-piperidine-4-carboxylate" "lealgin" "phenoperidinum [inn-latin]" "4-piperidinecarboxylic acid, 1-(3-hydroxy-3-phenylpropyl)-4-phenyl-, ethyl ester" "phenoperidine [inn:ban:dcf]" "fenoperidine" "ethyl 1-(3-hydroxy-3-phenylpropyl)-4-phenylpiperidine-4-carboxylate" "1-(3-hydroxy-3-phenylpropyl)-4-phenylpiperidine-4-carboxylic acid ethyl ester" "fenoperidina" "phenoperidin" "phenoperidinum" "phenoperidine (inn)" );
gibbsFormation
{
    dHf_298   -376530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     966.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=59810.0
    phase     gas;
}
