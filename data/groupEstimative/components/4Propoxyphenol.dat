/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-propoxyphenol  (C9H12O2, CAS 18979-50-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Propoxyphenol;
formula     C9H12O2;
CAS         18979-50-5;
InChIKey    KIIIPQXXLVCCQP-UHFFFAOYSA-N;
MW          152.193;      // g/mol [origin=calculated method=formula-sum]
Tc          754.97;      // K   [origin=predictive method=joback]
Pc          38.151;      // bar [origin=predictive method=joback]
omega       0.6499;      // -   [origin=predictive method=lee-kesler]
Tb          535.24;      // K   [origin=predictive method=joback]
HvapTb      53328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.618 0.87132 -0.00064236 1.997e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 4-propoxy-" "phenol, p-propoxy-" "p-propoxyphenol" "hydroquinone monopropyl ether" "p-propoxy phenol" "4-propyloxyphenol" "4-n-propoxyphenol" "phenol, p-propoxy- (8ci)" );
standardThermochemistry
{
    dHf_298   -302090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122310.0
}
