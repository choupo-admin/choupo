/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxysilatrane  (C7H15NO4Si, CAS 4025-80-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H15NO4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Methoxysilatrane;
formula     C7H15NO4Si;
CAS         4025-80-3;
InChIKey    JHUCBAOHJYDAIC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          205.285;      // g/mol [origin=calculated method=formula-sum]
Tc          734.69;      // K   [origin=predictive method=joback]
Pc          36.509;      // bar [origin=predictive method=joback]
omega       0.5378;      // -   [origin=predictive method=lee-kesler]
Tb          512.50;      // K   [origin=predictive method=joback]
HvapTb      50413.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.61 0.84032 -0.0003141 -2.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3O; count 1; } { group CH2O; count 3; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group O; count 1; } { group O_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methoxy-4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecane" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane, 1-methoxy-" "1-methoxy-2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane" "1-methoxy-2,8,9-trioxa-5-aza-1-sila-bicyclo[3.3.3]undecane" "silicic acid (h2sio4), methyl ester, cyclic ester with 2,2',2''-nitrilotriethanol" "silicic acid (h2sio4), methyl ester, cyclic ester with 2,2',2''-nitrilotriethanol (8ci)" );
standardThermochemistry
{
    dHf_298   -592320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-248660.0
}
