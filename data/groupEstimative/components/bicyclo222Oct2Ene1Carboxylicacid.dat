/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.2]oct-2-ene-1-carboxylicacid  (C9H12O2, CAS 2534-80-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo222Oct2Ene1Carboxylicacid;
formula     C9H12O2;
CAS         2534-80-7;
InChIKey    CKHVIPJAGMCQPO-UHFFFAOYSA-N;
MW          152.193;      // g/mol [origin=calculated method=formula-sum]
Tc          809.11;      // K   [origin=predictive method=joback]
Pc          38.965;      // bar [origin=predictive method=joback]
omega       0.6471;      // -   [origin=predictive method=lee-kesler]
Tb          572.45;      // K   [origin=predictive method=joback]
HvapTb      52103.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-153.63 1.4281 -0.00140588 5.649e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.2]oct-2-ene-4-carboxylic acid" "bicyclo[2.2.2]oct-2-ene-1-carboxylic acid" "bicyclo(2.2.2)oct-2-ene-1-carboxylic acid" );
gibbsFormation
{
    dHf_298   -373060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197240.0
    phase     gas;
}
