/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxybenzyl mercaptan  (C8H10OS, CAS 6258-60-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethoxybenzylMercaptan;
formula     C8H10OS;
CAS         6258-60-2;
InChIKey    PTDVPWWJRCOIIO-UHFFFAOYSA-N;
MW          154.227;      // g/mol [origin=calculated method=formula-sum]
Tc          733.34;      // K   [origin=predictive method=joback]
Pc          37.963;      // bar [origin=predictive method=joback]
omega       0.4345;      // -   [origin=predictive method=lee-kesler]
Tb          499.58;      // K   [origin=predictive method=joback]
HvapTb      45487.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.401 0.58952 -0.00028696 3.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methoxyphenyl)methanethiol" "4-methoxy-alpha-toluenethiol" "4-methoxybenzylmercaptan" "4-methoxy benzyl mercaptan" "4-methoxy benzylmercaptan" "4-methoxybenzenemethanethiol" "p-methoxy-.alpha.-toluenethiol" "4-methoxy-.alpha.-toluenethiol" "p-methoxybenzylthiol" "p-methoxybenzylmercaptan" "p-methoxybenzyl mercaptan" "p-methoxy-" "a-toluenethiol" );
gibbsFormation
{
    dHf_298   -77130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=43650.0
    phase     gas;
}
