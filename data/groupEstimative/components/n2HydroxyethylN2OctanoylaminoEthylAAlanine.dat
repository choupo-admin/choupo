/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-hydroxyethyl)-n-[2-(octanoylamino)ethyl]-|a-alanine  (C15H30N2O4, CAS 64265-45-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2HydroxyethylN2OctanoylaminoEthylAAlanine;
formula     C15H30N2O4;
CAS         64265-45-8;
InChIKey    OKFFNIVTSMRGQI-UHFFFAOYSA-N;
MW          302.415;      // g/mol [origin=calculated method=formula-sum]
Tc          1098.16;      // K   [origin=predictive method=joback]
Pc          17.318;      // bar [origin=predictive method=joback]
omega       1.4680;      // -   [origin=predictive method=lee-kesler]
Tb          896.97;      // K   [origin=predictive method=joback]
HvapTb      98052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.398 1.68572 -0.0010377 2.4396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group OH; count 1; } { group CH2N; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group OH; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-hydroxyethyl-[2-(octanoylamino)ethyl]amino]propanoic acid" "n-(2-hydroxyethyl)-n-(2-((1-oxooctyl)amino)ethyl)-beta-alanine" "n-(2-hydroxyethyl)-n-[2-[(1-oxooctyl)amino]ethyl]-beta-alanine" "n-(2-hydroxyethyl)-n-[2-(octanoylamino)ethyl]-beta-alanine" "b-alanine,n-(2-hydroxyethyl)-n-[2-[(1-oxooctyl)amino]ethyl]-" "beta-alanine, n-(2-hydroxyethyl)-n-(2-((1-oxooctyl)amino)ethyl)-" ".beta.-alanine, n-(2-hydroxyethyl)-n-[2-[(1-oxooctyl)amino]ethyl]-" );
gibbsFormation
{
    dHf_298   -847010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     927.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-334060.0
    phase     gas;
}
