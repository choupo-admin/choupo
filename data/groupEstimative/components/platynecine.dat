/*--------------------------------*- Choupo -*-----------------------*\
  Component: platynecine  (C8H15NO2, CAS 520-62-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        platynecine;
formula     C8H15NO2;
CAS         520-62-7;
InChIKey    QWOXSTGOGUNUGF-BWZBUEFSSA-N;
MW          157.213;      // g/mol [origin=calculated method=formula-sum]
Tc          771.95;      // K   [origin=predictive method=joback]
Pc          41.516;      // bar [origin=predictive method=joback]
omega       1.3520;      // -   [origin=predictive method=lee-kesler]
Tb          592.52;      // K   [origin=predictive method=joback]
HvapTb      68492.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.159 1.2214 -0.0009234 2.815e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,7s,8r)-7-(hydroxymethyl)-2,3,5,6,7,8-hexahydro-1h-pyrrolizin-1-ol" "mikanecine" "platynecin" "mikanecin" "platynecine (8ci)" "1h-pyrrolizine-1-methanol, hexahydro-7-hydroxy-, (1s-(1alpha,7alpha,7abeta))- (9ci)" );
gibbsFormation
{
    dHf_298   -326280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-44690.0
    phase     gas;
}
