/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-oxo-3-phenoxy-2-phenylpropanoic acid  (C15H12O4, CAS 21601-78-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Oxo3Phenoxy2PhenylpropanoicAcid;
formula     C15H12O4;
CAS         21601-78-5;
InChIKey    IDJNJFYWPMDFNB-UHFFFAOYSA-N;
MW          256.257;      // g/mol [origin=calculated method=formula-sum]
Tc          1045.46;      // K   [origin=predictive method=joback]
Pc          27.877;      // bar [origin=predictive method=joback]
omega       1.0558;      // -   [origin=predictive method=lee-kesler]
Tb          799.45;      // K   [origin=predictive method=joback]
HvapTb      77719.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.23 1.2729 -0.0008358 1.887e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanylidene-3-phenoxy-2-phenyl-propanoic acid" "propanedioic acid, phenyl-, monophenyl ester" "propanedioic acid, 2-phenyl-, 1-phenyl ester" "phenylmalonic acid monophenyl ester" "phenyl hydrogen phenylmalonate" "propanedioic acid,2-phenyl-, 1-phenyl ester" "malonicacid, phenyl-, monophenyl ester (8ci); propanedioic acid, phenyl-, monophenylester (9ci); monophenyl phenylmalonate" );
gibbsFormation
{
    dHf_298   -552700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-356480.0
    phase     gas;
}
