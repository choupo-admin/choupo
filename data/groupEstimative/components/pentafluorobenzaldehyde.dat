/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentafluorobenzaldehyde  (C7HF5O, CAS 653-37-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7HF5O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pentafluorobenzaldehyde;
formula     C7HF5O;
CAS         653-37-2;
InChIKey    QJXCFMJTJYCLFG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          196.074;      // g/mol [origin=calculated method=formula-sum]
Tc          548.42;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.4794;      // -   [origin=predictive method=lee-kesler]
Tb          384.11;      // K   [origin=predictive method=joback]
HvapTb      30304.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.07 0.3595 -0.000288 9.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group CHO; count 1; } { group ACF; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group F; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5,6-pentakis(fluoranyl)benzaldehyde" "2,3,4,5,6-pentafluorobenzaldehyde" "benzaldehyde, pentafluoro-" "benzaldehyde, 2,3,4,5,6-pentafluoro-" "perfluorobenzaldehyde" "pentafluor-benzaldehyd" "agn-pc-0d2vjq" "qjxcfmjtjyclfg-uhfffaoysa-" "2,4,5,6-pentafluorobenzaldehyde" "benzaldehyde, pentafluoro- (8ci)" "benzaldehyde,3,4,5,6-pentafluoro-" "benzaldehyde, pentafluoro- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -912730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-857770.0
}
