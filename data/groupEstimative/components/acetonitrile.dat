/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetonitrile  (C2H3N, CAS 75-05-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetonitrile;
formula     C2H3N;
CAS         75-05-8;
InChIKey    WEVYAHXRMPXWCK-UHFFFAOYSA-N;
MW          41.053;      // g/mol [origin=calculated method=formula-sum]
Tc          541.68;      // K   [origin=predictive method=joback]
Pc          48.562;      // bar [origin=predictive method=joback]
omega       0.2744;      // -   [origin=predictive method=lee-kesler]
Tb          347.44;      // K   [origin=predictive method=joback]
HvapTb      30524.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.07 0.12862 -5.4e-05 6.3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanenitrile" "methyl cyanide" "ethyl nitrile" "methanecarbonitrile" "methane, cyano-" "acetonitril" "cyanure de methyl" "methylkyanid" "cyanure de methyl [french]" "acetonitril [german, dutch]" "acetnitrile" "mecn" );
gibbsFormation
{
    dHf_298   80270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     240.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99140.0
    phase     gas;
}
