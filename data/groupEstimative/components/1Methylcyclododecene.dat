/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylcyclododecene  (C13H24, CAS 23070-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylcyclododecene;
formula     C13H24;
CAS         23070-53-3;
InChIKey    YWYIHWJAVXCTFB-UHFFFAOYSA-N;
MW          180.335;      // g/mol [origin=calculated method=formula-sum]
Tc          790.38;      // K   [origin=predictive method=joback]
Pc          23.634;      // bar [origin=predictive method=joback]
omega       0.3488;      // -   [origin=predictive method=lee-kesler]
Tb          551.02;      // K   [origin=predictive method=joback]
HvapTb      47256.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.12 1.21432 -0.00046164 -1.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 10; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -227640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     750.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38470.0
    phase     gas;
}
