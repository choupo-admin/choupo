/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyl methyl-d3-ether  (C4H7D3O, CAS 29366-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H7D3O (delta D+3H-3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        isopropylMethylD3Ether;
formula     C4H7D3O;
CAS         29366-06-1;
InChIKey    RMGHERXMTMUMMV-HPRDVNIFSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          77.141;      // g/mol [origin=calculated method=formula-sum]
Tc          480.84;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       0.2539;      // -   [origin=predictive method=lee-kesler]
Tb          313.10;      // K   [origin=predictive method=joback]
HvapTb      26520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.07 0.32656 -8.6e-05 -1.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(trideuteriomethoxy)propane" "(2h3)methyl propan-2-yl ether" );
standardThermochemistry
{
    dHf_298   -263390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     313.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124640.0
}
