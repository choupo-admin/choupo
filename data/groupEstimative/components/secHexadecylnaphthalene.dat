/*--------------------------------*- Choupo -*-----------------------*\
  Component: sec-hexadecylnaphthalene  (C26H40, CAS 94247-63-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        secHexadecylnaphthalene;
formula     C26H40;
CAS         94247-63-9;
InChIKey    YRKSLYAWOBZISP-UHFFFAOYSA-N;
MW          352.606;      // g/mol [origin=calculated method=formula-sum]
Tc          1044.93;      // K   [origin=predictive method=joback]
Pc          10.110;      // bar [origin=predictive method=joback]
omega       0.8630;      // -   [origin=predictive method=lee-kesler]
Tb          844.68;      // K   [origin=predictive method=joback]
HvapTb      77660.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.477 2.33764 -0.00149468 3.794e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group ACH; count 7; } { group AC; count 2; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-hexadecan-2-ylnaphthalene" "1-(hexadecan-2-yl)naphthalene" "1-sec-hexadecylnaphthalene" "naphthalene, sec-hexadecyl-" "naphthalene, 1-(1-methylpentadecyl)-" );
gibbsFormation
{
    dHf_298   -169120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     937.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=375030.0
    phase     gas;
}
