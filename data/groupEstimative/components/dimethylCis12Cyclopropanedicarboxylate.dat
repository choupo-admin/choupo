/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl cis-1,2-cyclopropanedicarboxylate  (C7H10O4, CAS 826-34-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylCis12Cyclopropanedicarboxylate;
formula     C7H10O4;
CAS         826-34-6;
InChIKey    JBVOSZYUSFDYIN-SYDPRGILSA-N;
MW          158.153;      // g/mol [origin=calculated method=formula-sum]
Tc          671.70;      // K   [origin=predictive method=joback]
Pc          31.456;      // bar [origin=predictive method=joback]
omega       0.5867;      // -   [origin=predictive method=lee-kesler]
Tb          478.27;      // K   [origin=predictive method=joback]
HvapTb      45594.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.04 0.68364 -0.0003326 2.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl (1s,2r)-cyclopropane-1,2-dicarboxylate" "dimethyl (1r,2s)-cyclopropane-1,2-dicarboxylate" "cyclopropane-1,2-dicarboxylic acid dimethyl ester, z" "cis-dimethyl cyclopropane-1,2-dicarboxylate" "(1r,2s)-dimethyl cyclopropane-1,2-dicarboxylate" "1,2-cyclopropanedicarboxylic acid, dimethyl ester, (1r,2s)-" "1,2-cyclopropanedicarboxylicacid, 1,2-dimethyl ester, (1r,2s)-rel-" "1,2-cyclopropanedicarboxylicacid, dimethyl ester, (1r,2s)-rel- (9ci);1,2-cyclopropanedicarboxylic acid,dimethyl ester, cis- (8ci);(cis)-1,2-bis(methoxycarbonyl)cyclopropane;dimethyl cis-1,2-cyclopropanedicarboxylate;dimethylcis-1,2-cyclopropanedicarboxylate;" );
standardThermochemistry
{
    dHf_298   -769910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-559640.0
}
