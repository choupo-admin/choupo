/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, bis(1,1-dimethylethyl)dimethoxy-  (C10H24O2Si, CAS 79866-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H24O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneBis11DimethylethylDimethoxy;
formula     C10H24O2Si;
CAS         79866-98-1;
InChIKey    OANIYCQMEVXZCJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          204.385;      // g/mol [origin=calculated method=formula-sum]
Tc          656.94;      // K   [origin=predictive method=joback]
Pc          19.003;      // bar [origin=predictive method=joback]
omega       0.3565;      // -   [origin=predictive method=lee-kesler]
Tb          468.18;      // K   [origin=predictive method=joback]
HvapTb      40376.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.67 0.87296 -0.000227 -7.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group CH3O; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group C; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ditert-butyl(dimethoxy)silane" );
gibbsFormation
{
    dHf_298   -643290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     616.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-275760.0
    phase     gas;
}
