/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexyl(dimethoxy)methylsilane  (C9H20O2Si, CAS 17865-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H20O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        cyclohexylDimethoxyMethylsilane;
formula     C9H20O2Si;
CAS         17865-32-6;
InChIKey    SJJCABYOVIHNPZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          188.342;      // g/mol [origin=calculated method=formula-sum]
Tc          675.04;      // K   [origin=predictive method=joback]
Pc          24.243;      // bar [origin=predictive method=joback]
omega       0.3666;      // -   [origin=predictive method=lee-kesler]
Tb          471.31;      // K   [origin=predictive method=joback]
HvapTb      41171.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.92 0.64836 9e-05 -2.213e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH3O; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexyl-dimethoxy-methyl-silane" "cyclohexyldimethoxy(methyl)silane" "cyclohexyl-dimethoxy-methylsilane" "silane, cyclohexyldimethoxymethyl-" "sjjcabyovihnpz-uhfffaoysa-" "cyclohexane, (dimethoxymethylsilyl)-" "methyl cyclohexyl dimethoxy silane" );
standardThermochemistry
{
    dHf_298   -550830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-265410.0
}
