/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(trifluoroacetoxy)pyridine  (C7H4F3NO2, CAS 96254-05-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TrifluoroacetoxyPyridine;
formula     C7H4F3NO2;
CAS         96254-05-6;
InChIKey    BJCXMOBNIFBHBJ-UHFFFAOYSA-N;
MW          191.108;      // g/mol [origin=calculated method=formula-sum]
Tc          702.17;      // K   [origin=predictive method=joback]
Pc          35.899;      // bar [origin=predictive method=joback]
omega       0.5653;      // -   [origin=predictive method=lee-kesler]
Tb          492.94;      // K   [origin=predictive method=joback]
HvapTb      43322.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.11 0.73006 -0.00052386 1.31e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C5H4N; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group F; count 3; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyridin-2-yl 2,2,2-tris(fluoranyl)ethanoate" "2-pyridyl trifluoroacetate" "pyridin-2-yl 2,2,2-trifluoroacetate" );
gibbsFormation
{
    dHf_298   -832850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-694440.0
    phase     gas;
}
