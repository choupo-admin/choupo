/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylpent-2-en-3-amine  (C7H15N, CAS 32317-47-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylpent2En3Amine;
formula     C7H15N;
CAS         32317-47-8;
InChIKey    UCCDUMHVMOCMTB-UHFFFAOYSA-N;
MW          113.204;      // g/mol [origin=calculated method=formula-sum]
Tc          550.81;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.3504;      // -   [origin=predictive method=lee-kesler]
Tb          376.24;      // K   [origin=predictive method=joback]
HvapTb      33257.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.039 0.81268 -0.0005557 1.587e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH=C; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -12850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=190510.0
}
