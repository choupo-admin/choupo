/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,6-paracyclophane  (C24H32, CAS 4384-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        66Paracyclophane;
formula     C24H32;
CAS         4384-23-0;
InChIKey    KZCIQXIXTWAXSA-UHFFFAOYSA-N;
MW          320.52;      // g/mol [origin=calculated method=formula-sum]
Tc          1135.02;      // K   [origin=predictive method=joback]
Pc          15.974;      // bar [origin=predictive method=joback]
omega       0.6462;      // -   [origin=predictive method=lee-kesler]
Tb          861.88;      // K   [origin=predictive method=joback]
HvapTb      76664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-160.41 2.098 -0.00106812 1.34e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group ACH; count 8; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 12; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -50870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     997.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=316320.0
}
