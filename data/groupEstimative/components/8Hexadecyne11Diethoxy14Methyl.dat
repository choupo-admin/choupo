/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-hexadecyne, 1,1-diethoxy-14-methyl-  (C21H40O2, CAS 71566-67-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Hexadecyne11Diethoxy14Methyl;
formula     C21H40O2;
CAS         71566-67-1;
InChIKey    UOOXKQISRGHOFK-HXUWFJFHSA-N;
MW          324.549;      // g/mol [origin=calculated method=formula-sum]
Tc          910.94;      // K   [origin=predictive method=joback]
Pc          10.460;      // bar [origin=predictive method=joback]
omega       0.8447;      // -   [origin=predictive method=lee-kesler]
Tb          733.04;      // K   [origin=predictive method=joback]
HvapTb      68536.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.993 1.73448 -0.00081086 1.0708e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 11; } { group CH; count 2; } { group CH2O; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 13; } { group CH; count 2; } { group tC; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(14r)-1,1-diethoxy-14-methyl-hexadec-8-yne" "14-methyl-8-hexadecynal diethyl acetal" "(14r)-1,1-diethoxy-14-methylhexadec-8-yne" );
gibbsFormation
{
    dHf_298   -479470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     949.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113860.0
    phase     gas;
}
