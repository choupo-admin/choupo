/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-amino-3,3-diethoxypropane  (C7H17NO2, CAS 41365-75-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Amino33Diethoxypropane;
formula     C7H17NO2;
CAS         41365-75-7;
InChIKey    PXXMSHBZYAOHBD-UHFFFAOYSA-N;
MW          147.218;      // g/mol [origin=calculated method=formula-sum]
Tc          658.28;      // K   [origin=predictive method=joback]
Pc          28.936;      // bar [origin=predictive method=joback]
omega       0.6501;      // -   [origin=predictive method=lee-kesler]
Tb          476.69;      // K   [origin=predictive method=joback]
HvapTb      46249.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.334 0.61024 -0.0001816 -2.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2O; count 2; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group O; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-diethoxypropan-1-amine" "3,3-diethoxypropylamine" "3-aminopropionaldehyde diethylacetal" "3-aminopropionaldehyde diethyl acetal" "propionaldehyde, 3-amino-, diethyl acetal" "pxxmshbzyaohbd-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -423740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-137930.0
    phase     gas;
}
