/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-quinolinol, 7-(4-ethyl-1-methyl-1-octenyl)-  (C20H27NO, CAS 64744-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Quinolinol74Ethyl1Methyl1Octenyl;
formula     C20H27NO;
CAS         64744-01-0;
InChIKey    JSCYXWISFCQGAL-UHFFFAOYSA-N;
MW          297.442;      // g/mol [origin=calculated method=formula-sum]
Tc          1075.31;      // K   [origin=predictive method=joback]
Pc          17.924;      // bar [origin=predictive method=joback]
omega       1.0319;      // -   [origin=predictive method=lee-kesler]
Tb          845.76;      // K   [origin=predictive method=joback]
HvapTb      83566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.755 1.97592 -0.00152 4.921e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CH=C; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(5-ethylnon-2-en-2-yl)quinolin-8-ol" "8-quinolinol, 7-(4-ethyl-1-methyl-1-octen-1-yl)-" );
standardThermochemistry
{
    dHf_298   -82370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     732.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=318610.0
}
