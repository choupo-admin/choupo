/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,7-tribromo-2-fluorenamine  (C13H8Br3N, CAS 724-31-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        137Tribromo2Fluorenamine;
formula     C13H8Br3N;
CAS         724-31-2;
InChIKey    DESWTTXWHWPCJD-UHFFFAOYSA-N;
MW          417.926;      // g/mol [origin=calculated method=formula-sum]
Tc          1140.96;      // K   [origin=predictive method=joback]
Pc          43.454;      // bar [origin=predictive method=joback]
omega       1.1269;      // -   [origin=predictive method=lee-kesler]
Tb          854.16;      // K   [origin=predictive method=joback]
HvapTb      82880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.82 1.0971 -0.00096956 3.457e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 6; } { group ACCH2; count 1; } { group ACNH2; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group Br; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,7-tris(bromanyl)-9h-fluoren-2-amine" "fluoren-2-amine, 1,3,7-tribromo-" "1,7-tribromo-2-fluorenamine" "1,7-tribromofluoren-2-amine" "1,3,7-tribromofluoren-2-amine" "fluoren-2-amine,3,7-tribromo-" "9h-fluoren-2-amine,3,7-tribromo-" "1,3,7-tribromo-9h-fluoren-2-amine" "9h-fluoren-2-amine, 1,3,7-tribromo-" "9h-fluoren-2-amine, 1,3,7-tribromo- (9ci)" "1,3,7-tribromo-9h-fluoren-2-amine; 1,3,7-tribromo-9h-fluoren-2-ylamine; 9h-fluoren-2-amine, 1,3,7-tribromo-; fluoren-2-amine, 1,3,7-tribromo-" );
standardThermochemistry
{
    dHf_298   310830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=427690.0
}
