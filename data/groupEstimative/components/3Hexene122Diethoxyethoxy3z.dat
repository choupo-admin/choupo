/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexene, 1-(2,2-diethoxyethoxy)-, (3z)-  (C12H24O3, CAS 50876-88-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexene122Diethoxyethoxy3z;
formula     C12H24O3;
CAS         50876-88-5;
InChIKey    SXFMZKKBIUYSHF-UHFFFAOYSA-N;
MW          216.321;      // g/mol [origin=calculated method=formula-sum]
Tc          715.45;      // K   [origin=predictive method=joback]
Pc          17.939;      // bar [origin=predictive method=joback]
omega       0.7448;      // -   [origin=predictive method=lee-kesler]
Tb          545.14;      // K   [origin=predictive method=joback]
HvapTb      49106.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.616 0.98016 -0.000383 1.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group dCH; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,2-diethoxyethoxy)hex-3-ene" );
gibbsFormation
{
    dHf_298   -575730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-187060.0
    phase     gas;
}
