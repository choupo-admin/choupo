/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanone, cyclic propylene acetal  (C9H16O2, CAS 4722-68-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanoneCyclicPropyleneAcetal;
formula     C9H16O2;
CAS         4722-68-3;
InChIKey    LKGNKCNAPNUZCM-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          722.91;      // K   [origin=predictive method=joback]
Pc          34.807;      // bar [origin=predictive method=joback]
omega       0.3800;      // -   [origin=predictive method=lee-kesler]
Tb          490.22;      // K   [origin=predictive method=joback]
HvapTb      44011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.61 1.40812 -0.0012254 4.555e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-1,4-dioxaspiro[4.5]decane" "2-methyl-1,4-dioxaspiro[4.5]decane" "2-methyl-1,4-dioxaspiro(4.5)decane" "1,4-dioxaspiro(4.5)decane, 2-methyl-" "1,4-dioxaspiro[4.5]decane, 2-methyl-" "4-methyl-2,2-pentamethylene-1,3-dioxolane" );
standardThermochemistry
{
    dHf_298   -356890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-79730.0
}
