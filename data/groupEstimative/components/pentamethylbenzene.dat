/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentamethylbenzene  (C11H16, CAS 700-12-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentamethylbenzene;
formula     C11H16;
CAS         700-12-9;
InChIKey    BEZDDPMMPIDMGJ-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          704.83;      // K   [origin=predictive method=joback]
Pc          24.925;      // bar [origin=predictive method=joback]
omega       0.4363;      // -   [origin=predictive method=lee-kesler]
Tb          497.88;      // K   [origin=predictive method=joback]
HvapTb      45004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.18 0.732 -0.00033764 4.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group ACCH3; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH_ring; count 1; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentamethylbenzene" "benzene, pentamethyl-" "benzene, 1,2,3,4,5-pentamethyl-" "pentamethylbenzol" "agn-pc-00mbh7" "agn-pc-0d5xo8" "1,3,4,5-pentamethylbenzene" "1,2,3,4,5-pentamethyl-benzene" "1,2,3,4,5-pentamethylcyclohexa-1,3,5-triene" );
gibbsFormation
{
    dHf_298   -79720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=115630.0
    phase     gas;
}
