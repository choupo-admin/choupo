/*--------------------------------*- Choupo -*-----------------------*\
  Component: baclofen  (C10H12ClNO2, CAS 1134-47-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        baclofen;
formula     C10H12ClNO2;
CAS         1134-47-0;
InChIKey    KPYSYYIEGFHWSV-UHFFFAOYSA-N;
MW          213.661;      // g/mol [origin=calculated method=formula-sum]
Tc          949.91;      // K   [origin=predictive method=joback]
Pc          32.840;      // bar [origin=predictive method=joback]
omega       1.0129;      // -   [origin=predictive method=lee-kesler]
Tb          715.09;      // K   [origin=predictive method=joback]
HvapTb      72594.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.508 0.9408 -0.00062396 1.559e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanyl-3-(4-chlorophenyl)butanoic acid" "lioresal" "baclon" "kemstro" "4-amino-3-(4-chlorophenyl)butanoic acid" "lioresal intrathecal" "pms-baclofen" "dl-baclofen" "atrofen" "baclofene" "baclofeno" "baclofenum" );
gibbsFormation
{
    dHf_298   -362170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-155730.0
    phase     gas;
}
