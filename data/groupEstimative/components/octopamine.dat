/*--------------------------------*- Choupo -*-----------------------*\
  Component: octopamine  (C8H11NO2, CAS 2039-62-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octopamine;
formula     C8H11NO2;
CAS         2039-62-5;
InChIKey    QHGUCRYDKWKLMG-UHFFFAOYSA-N;
MW          153.181;      // g/mol [origin=calculated method=formula-sum]
Tc          875.28;      // K   [origin=predictive method=joback]
Pc          54.951;      // bar [origin=predictive method=joback]
omega       1.2470;      // -   [origin=predictive method=lee-kesler]
Tb          654.21;      // K   [origin=predictive method=joback]
HvapTb      75624.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.109 0.9413 -0.00077596 2.629e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-azanyl-1-oxidanyl-ethyl)phenol" "norsynephrine" "4-(2-amino-1-hydroxyethyl)phenol" "octopaminum" "octapamine" "norfen" "p-norsynephrin" "norsympatol" "octopamine [inn]" "octopaminum [latin]" "paraoxyphenyl aminoethanol" "1-(p-hydroxyphenyl)-2-aminoethanol" );
standardThermochemistry
{
    dHf_298   -272950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98540.0
}
