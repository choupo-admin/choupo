/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentamethylbenzoic acid  (C12H16O2, CAS 2243-32-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentamethylbenzoicAcid;
formula     C12H16O2;
CAS         2243-32-5;
InChIKey    MNLKGWIYXCKWBU-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          888.19;      // K   [origin=predictive method=joback]
Pc          24.387;      // bar [origin=predictive method=joback]
omega       0.8679;      // -   [origin=predictive method=lee-kesler]
Tb          671.25;      // K   [origin=predictive method=joback]
HvapTb      65056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.17 0.8183 -0.0003976 6.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group ACCH3; count 5; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dC_ring; count 6; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5,6-pentamethylbenzoic acid" "benzoic acid, pentamethyl-" "pentamethyl-benzoic acid" "benzoic acid,2,3,4,5,6-pentamethyl-" );
gibbsFormation
{
    dHf_298   -462100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-229490.0
    phase     gas;
}
