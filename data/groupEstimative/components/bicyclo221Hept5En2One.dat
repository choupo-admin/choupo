/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.1]hept-5-en-2-one  (C7H8O, CAS 694-98-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Hept5En2One;
formula     C7H8O;
CAS         694-98-4;
InChIKey    HUQXEIFQYCVOPD-UHFFFAOYSA-N;
MW          108.14;      // g/mol [origin=calculated method=formula-sum]
Tc          671.31;      // K   [origin=predictive method=joback]
Pc          42.496;      // bar [origin=predictive method=joback]
omega       0.3514;      // -   [origin=predictive method=lee-kesler]
Tb          444.49;      // K   [origin=predictive method=joback]
HvapTb      35713.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.87 0.7367 -0.00049428 1.32e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.1]hept-2-en-5-one" "bicyclo(2.2.1)hept-5-en-2-one" "bicyclo(2.2.1)hept-2-en-5-one" "dehydronorcamphor" "2-norbornenone" "2-norbornen-5-one" "5-norbornen-2-one" "norcamphor, dehydro-" "rd-10" "bicyclo[2.2.1]hept-2-en-6-one" );
standardThermochemistry
{
    dHf_298   -128290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     151.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24830.0
}
