/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-4-(4-methyl-1,3-dioxan-2-yl)phenol  (C12H16O4, CAS 6329-01-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy44Methyl13Dioxan2YlPhenol;
formula     C12H16O4;
CAS         6329-01-7;
InChIKey    ZVJUAEJHNVXHHC-UHFFFAOYSA-N;
MW          224.256;      // g/mol [origin=calculated method=formula-sum]
Tc          919.11;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.8275;      // -   [origin=predictive method=lee-kesler]
Tb          677.64;      // K   [origin=predictive method=joback]
HvapTb      69808.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.07 1.18644 -0.00073632 1.745e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "vanillin 1,3-butylene glycol acetal" "phenol, 2-methoxy-4-(4-methyl-1,3-dioxan-2-yl)-" "phenol,3-dioxan-2-yl)-" "phenol, 2-methoxy-4-(4-methyl-m-dioxan-2-yl)-" "phenol, 2-methoxy-4-(4-methyl-m-dioxan-2-yl)- (8ci)" );
gibbsFormation
{
    dHf_298   -605500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-262180.0
    phase     gas;
}
