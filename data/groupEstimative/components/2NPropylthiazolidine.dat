/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-n-propylthiazolidine  (C6H13NS, CAS 24050-10-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2NPropylthiazolidine;
formula     C6H13NS;
CAS         24050-10-0;
InChIKey    UDJJSTNTIKWCCW-UHFFFAOYSA-N;
MW          131.237;      // g/mol [origin=calculated method=formula-sum]
Tc          669.73;      // K   [origin=predictive method=joback]
Pc          39.308;      // bar [origin=predictive method=joback]
omega       0.3713;      // -   [origin=predictive method=lee-kesler]
Tb          448.54;      // K   [origin=predictive method=joback]
HvapTb      41777.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.308 0.70653 -0.0003881 7.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2NH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group NH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propyl-1,3-thiazolidine" "thiazolidine, 2-propyl-" "2-propylthiazolidine" );
standardThermochemistry
{
    dHf_298   -23620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=163760.0
}
