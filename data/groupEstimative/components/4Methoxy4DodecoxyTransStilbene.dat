/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxy-4'-dodecoxy-trans-stilbene  (C27H38O2, CAS 35135-49-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxy4DodecoxyTransStilbene;
formula     C27H38O2;
CAS         35135-49-0;
InChIKey    ZTKXXACFPFBWBM-UHFFFAOYSA-N;
MW          394.599;      // g/mol [origin=calculated method=formula-sum]
Tc          1143.96;      // K   [origin=predictive method=joback]
Pc          10.014;      // bar [origin=predictive method=joback]
omega       0.9123;      // -   [origin=predictive method=lee-kesler]
Tb          929.68;      // K   [origin=predictive method=joback]
HvapTb      86350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.049 2.18564 -0.00123512 2.491e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-dodecoxy-4-[2-(4-methoxyphenyl)ethenyl]benzene" );
gibbsFormation
{
    dHf_298   -297710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     998.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252240.0
    phase     gas;
}
