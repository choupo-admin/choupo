/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexyl-1-propyl acetate  (C11H20O2, CAS 2114-32-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexyl1PropylAcetate;
formula     C11H20O2;
CAS         2114-32-1;
InChIKey    NGDJXKQCYPJVCL-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          732.64;      // K   [origin=predictive method=joback]
Pc          23.657;      // bar [origin=predictive method=joback]
omega       0.5278;      // -   [origin=predictive method=lee-kesler]
Tb          528.61;      // K   [origin=predictive method=joback]
HvapTb      47528.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.989 1.12204 -0.0005642 7.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexylpropyl ethanoate" "1-cyclohexylpropyl acetate" "[(1s)-1-cyclohexylpropyl] acetate" "cyclohexanemethanol, alpha-ethyl-, acetate" "cyclohexanemethanol, .alpha.-ethyl-, acetate" "cyclohexanemethanol, alpha-ethyl-, 1-acetate" "cyclohexanemethanol, .alpha.-ethyl-, 1-acetate" );
gibbsFormation
{
    dHf_298   -538610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246620.0
    phase     gas;
}
