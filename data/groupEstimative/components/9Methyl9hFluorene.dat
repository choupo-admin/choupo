/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-methyl-9h-fluorene  (C14H12, CAS 2523-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Methyl9hFluorene;
formula     C14H12;
CAS         2523-37-7;
InChIKey    ZVEJRZRAUYJYCO-UHFFFAOYSA-N;
MW          180.25;      // g/mol [origin=calculated method=formula-sum]
Tc          823.98;      // K   [origin=predictive method=joback]
Pc          29.218;      // bar [origin=predictive method=joback]
omega       0.5023;      // -   [origin=predictive method=lee-kesler]
Tb          581.44;      // K   [origin=predictive method=joback]
HvapTb      52203.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.05 1.22712 -0.00097912 3.157e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-methylfluorene" "9h-fluorene, 9-methyl-" "fluorene, 9-methyl-" "agn-pc-0dbdwm" "9h-fluorene, 9-methyl- (9ci)" );
standardThermochemistry
{
    dHf_298   202950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=357510.0
}
