/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-4-methoxyacetophenone  (C9H9ClO2, CAS 37612-52-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro4Methoxyacetophenone;
formula     C9H9ClO2;
CAS         37612-52-5;
InChIKey    QILWOKAXHOAFOF-UHFFFAOYSA-N;
MW          184.619;      // g/mol [origin=calculated method=formula-sum]
Tc          779.15;      // K   [origin=predictive method=joback]
Pc          31.847;      // bar [origin=predictive method=joback]
omega       0.6043;      // -   [origin=predictive method=lee-kesler]
Tb          555.88;      // K   [origin=predictive method=joback]
HvapTb      52769.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.15 0.57654 -0.00025362 1.676e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3CO; count 1; } { group CH3O; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-chloranyl-4-methoxy-phenyl)ethanone" "1-(3-chloro-4-methoxyphenyl)ethanone" "3'-chloro-4'-methoxyacetophenone" "1-(3-chloro-4-methoxyphenyl)ethan-1-one" "ethanone, 1-(3-chloro-4-methoxyphenyl)-" );
standardThermochemistry
{
    dHf_298   -276040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-127800.0
}
