/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-allylcyclohexanol  (C9H16O, CAS 1123-34-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Allylcyclohexanol;
formula     C9H16O;
CAS         1123-34-8;
InChIKey    ZSLKGUQYEQVKQE-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          714.10;      // K   [origin=predictive method=joback]
Pc          34.684;      // bar [origin=predictive method=joback]
omega       0.7025;      // -   [origin=predictive method=lee-kesler]
Tb          514.17;      // K   [origin=predictive method=joback]
HvapTb      50915.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-118.589 1.2868 -0.0011327 4.307e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-prop-2-enylcyclohexan-1-ol" "1-allyl-1-cyclohexanol" "cyclohexanol, 1-allyl-" "cyclohexanol, 1-(2-propenyl)-" "1-allyl-cyclohexan-1-ol" "1-prop-2-enyl-1-cyclohexanol" "cyclohexanol,1-(2-propen-1-yl)-" "cyclohexanol,1-(2-propenyl)- (9ci);cyclohexanol, 1-allyl- (6ci,7ci,8ci);1-(1-hydroxycyclohexyl)-2-propene;1-allyl-1-cyclohexanol;1-allylcyclohexanol;" );
gibbsFormation
{
    dHf_298   -186330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5120.0
    phase     gas;
}
