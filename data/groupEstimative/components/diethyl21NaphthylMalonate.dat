/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl 2-(1-naphthyl)malonate  (C17H18O4, CAS 6341-60-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl21NaphthylMalonate;
formula     C17H18O4;
CAS         6341-60-2;
InChIKey    BWBVCAXBRMQDJU-UHFFFAOYSA-N;
MW          286.327;      // g/mol [origin=calculated method=formula-sum]
Tc          974.01;      // K   [origin=predictive method=joback]
Pc          19.389;      // bar [origin=predictive method=joback]
omega       0.9466;      // -   [origin=predictive method=lee-kesler]
Tb          755.20;      // K   [origin=predictive method=joback]
HvapTb      72440.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.478 1.37304 -0.00081588 1.581e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 7; } { group AC; count 2; } { group ACCH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-naphthalen-1-ylpropanedioate" "diethyl naphthalen-1-ylpropanedioate" "diethyl 2-(naphthalen-1-yl)malonate" "2-naphthalen-1-yl-malonic acid diethyl ester" );
gibbsFormation
{
    dHf_298   -617920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-321490.0
    phase     gas;
}
