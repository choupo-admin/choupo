/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1263287  (C17H23F3N2O, CAS 73747-54-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1263287;
formula     C17H23F3N2O;
CAS         73747-54-3;
InChIKey    UVWOBICVJRBABL-UHFFFAOYSA-N;
MW          328.378;      // g/mol [origin=calculated method=formula-sum]
Tc          956.45;      // K   [origin=predictive method=joback]
Pc          18.031;      // bar [origin=predictive method=joback]
omega       1.0160;      // -   [origin=predictive method=lee-kesler]
Tb          750.79;      // K   [origin=predictive method=joback]
HvapTb      68030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.018 1.97782 -0.00141466 3.8646e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2NH; count 1; } { group CF3; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-piperidin-1-yl-2-[1-[3-(trifluoromethyl)phenyl]propan-2-ylamino]ethanone" "ketone, (alpha-methyl-m-trifluoromethylphenethylaminomethyl) piperidino" "1-(piperidin-1-yl)-2-({1-[3-(trifluoromethyl)phenyl]propan-2-yl}amino)ethanone" );
gibbsFormation
{
    dHf_298   -682270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     827.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-273480.0
    phase     gas;
}
