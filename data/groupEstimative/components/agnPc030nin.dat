/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-030nin  (C18H28O2, CAS 27530-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc030nin;
formula     C18H28O2;
CAS         27530-63-8;
InChIKey    GKYMEBBVOZBYSE-UHFFFAOYSA-N;
MW          276.42;      // g/mol [origin=calculated method=formula-sum]
Tc          915.23;      // K   [origin=predictive method=joback]
Pc          16.687;      // bar [origin=predictive method=joback]
omega       0.6865;      // -   [origin=predictive method=lee-kesler]
Tb          696.20;      // K   [origin=predictive method=joback]
HvapTb      61019.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-226.039 2.54588 -0.0023515 9.245e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 3; } { group C; count 2; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanol, 2-[(1s,3ar,4s,8ar)-decahydro-4,8,8-trimethyl-1,4-methanoazulen-9-ylidene]-, 1-acetate" "ethanol, 2-[(1s,3ar,4s,8ar)-decahydro-4,8,8-trimethyl-1,4-methanoazulen-9-ylidene]-, acetate" );
gibbsFormation
{
    dHf_298   -460220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     703.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32580.0
    phase     gas;
}
