/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl methyl ether  (C4H8O, CAS 627-40-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylMethylEther;
formula     C4H8O;
CAS         627-40-7;
InChIKey    FASUFOTUSHAIHG-UHFFFAOYSA-N;
MW          72.107;      // g/mol [origin=calculated method=formula-sum]
Tc          477.31;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.2612;      // -   [origin=predictive method=lee-kesler]
Tb          310.22;      // K   [origin=predictive method=joback]
HvapTb      26238.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.761 0.30062 -0.0001057 -1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxyprop-1-ene" "3-methoxy-1-propene" "1-propene, 3-methoxy-" "ether, allyl methyl" "3-methoxypropene" "methylallyl ether" "methyl 2-propenyl ether;" "methyl 1-allyl ether" );
standardThermochemistry
{
    dHf_298   -132680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     318.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34360.0
}
