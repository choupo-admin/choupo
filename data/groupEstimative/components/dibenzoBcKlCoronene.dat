/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzo[bc,kl]coronene  (C30H14, CAS 190-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzoBcKlCoronene;
formula     C30H14;
CAS         190-55-6;
InChIKey    HIPGYGZSSWEWRX-UHFFFAOYSA-N;
MW          374.442;      // g/mol [origin=calculated method=formula-sum]
Tc          1339.89;      // K   [origin=predictive method=joback]
Pc          19.648;      // bar [origin=predictive method=joback]
omega       1.2577;      // -   [origin=predictive method=lee-kesler]
Tb          1068.58;      // K   [origin=predictive method=joback]
HvapTb      99860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-199.89 2.6296 -0.00268596 1.0682e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 16; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 14; } { group dC_ring; count 16; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibenzo(bc,kl)coronene" "dibenz[bc,kl]coronene" );
standardThermochemistry
{
    dHf_298   840430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     293.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1076880.0
}
