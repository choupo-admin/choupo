/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorobenzoic acid, isopropyl ester  (C10H11ClO2, CAS 22913-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorobenzoicAcidIsopropylEster;
formula     C10H11ClO2;
CAS         22913-11-7;
InChIKey    VOLPFZRDHTWKTD-UHFFFAOYSA-N;
MW          198.646;      // g/mol [origin=calculated method=formula-sum]
Tc          775.79;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       0.5644;      // -   [origin=predictive method=lee-kesler]
Tb          555.27;      // K   [origin=predictive method=joback]
HvapTb      52196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.81 0.77334 -0.00041336 5.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl 4-chloranylbenzoate" "propan-2-yl 4-chlorobenzoate" "benzoic acid, 4-chloro-, 1-methylethyl ester" "4-chlorobenzoic acid isopropyl ester" );
gibbsFormation
{
    dHf_298   -362970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-188640.0
    phase     gas;
}
