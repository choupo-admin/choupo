/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylsilyl octanoate  (C11H24O2Si, CAS 55494-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H24O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethylsilylOctanoate;
formula     C11H24O2Si;
CAS         55494-06-9;
InChIKey    GRHSLTISTCPPAT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          216.396;      // g/mol [origin=calculated method=formula-sum]
Tc          684.13;      // K   [origin=predictive method=joback]
Pc          17.521;      // bar [origin=predictive method=joback]
omega       0.5840;      // -   [origin=predictive method=lee-kesler]
Tb          510.90;      // K   [origin=predictive method=joback]
HvapTb      47781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.116 0.78788 -6.52e-05 -1.546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH2COO; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octanoic acid, trimethylsilyl ester" "octanoic acid trimethylsilyl ester" );
standardThermochemistry
{
    dHf_298   -699270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     762.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-373390.0
}
