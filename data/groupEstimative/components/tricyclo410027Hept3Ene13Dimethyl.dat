/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(4.1.0.02,7)hept-3-ene, 1,3-dimethyl-  (C9H12, CAS 66036-92-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo410027Hept3Ene13Dimethyl;
formula     C9H12;
CAS         66036-92-8;
InChIKey    DGNRZXTWHUOJMB-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          620.73;      // K   [origin=predictive method=joback]
Pc          34.239;      // bar [origin=predictive method=joback]
omega       0.3326;      // -   [origin=predictive method=lee-kesler]
Tb          416.91;      // K   [origin=predictive method=joback]
HvapTb      34517.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-167.75 1.48064 -0.00161664 7.027e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 3; } { group C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-0cu105" "tricyclo[4.1.0.02,7]hept-3-ene,1,3-dimethyl-" );
gibbsFormation
{
    dHf_298   42840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     179.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=238480.0
    phase     gas;
}
