/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzo[b]thiophene, 2,3,3a,4,7,7a-hexahydro-1,1-dioxide  (C8H12O2S, CAS 92688-79-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H12O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzoBThiophene233a477aHexahydro11Dioxide;
formula     C8H12O2S;
CAS         92688-79-4;
InChIKey    VSEMXKYLUQVDRJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          172.242;      // g/mol [origin=calculated method=formula-sum]
Tc          564.96;      // K   [origin=predictive method=joback]
Pc          42.496;      // bar [origin=predictive method=joback]
omega       0.4530;      // -   [origin=predictive method=lee-kesler]
Tb          382.82;      // K   [origin=predictive method=joback]
HvapTb      45682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.69 1.0296 -0.00072088 1.914e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,3a,4,7,7a-hexahydro-2-benzothiophene 2,2-dioxide" "benzo(b)thiophene, 2,3,3a,4,7,7a-hexahydro-1,1-dioxide" "agn-pc-04h81k" "8-thiabicyclo[4.3.0]non-3-ene 8,8-dioxide" );
standardThermochemistry
{
    dHf_298   -512610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-357920.0
}
