/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexyl-1-pentanol  (C11H22O, CAS 7338-43-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexyl1Pentanol;
formula     C11H22O;
CAS         7338-43-4;
InChIKey    PKXSPCMDZCKLCI-UHFFFAOYSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          750.37;      // K   [origin=predictive method=joback]
Pc          25.793;      // bar [origin=predictive method=joback]
omega       0.8362;      // -   [origin=predictive method=lee-kesler]
Tb          562.57;      // K   [origin=predictive method=joback]
HvapTb      56800.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.107 1.21082 -0.0006892 1.386e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexylpentan-1-ol" "1-cyclohexyl-pentan-1-ol" "n-butyl cyclohexyl carbinol" "agn-pc-00fsa1" "(1-hydroxypentyl)cyclohexane" "(1r)-1-cyclohexylpentan-1-ol" "1-cyclohexyl pentanol-1" "pkxspcmdzcklci-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -373560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-73070.0
}
