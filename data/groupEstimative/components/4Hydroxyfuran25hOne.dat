/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxyfuran-2(5h)-one  (C4H4O3, CAS 541-57-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxyfuran25hOne;
formula     C4H4O3;
CAS         541-57-1;
InChIKey    JZQBAGOECGRTSA-UHFFFAOYSA-N;
MW          100.073;      // g/mol [origin=calculated method=formula-sum]
Tc          644.35;      // K   [origin=predictive method=joback]
Pc          57.305;      // bar [origin=predictive method=joback]
omega       0.8398;      // -   [origin=predictive method=lee-kesler]
Tb          457.07;      // K   [origin=predictive method=joback]
HvapTb      49760.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.15 0.4249 -0.00032544 9.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanyl-2h-furan-5-one" "4-hydroxy-2,5-dihydrofuran-2-one" "5-hydroxyfuran-3(2h)-one" "4-hydroxy-2(5h)-furanone" "5-hydroxyfuran-3-one" "4-hydroxy-5h-furan-2-one" "2(5h)-furanone,4-hydroxy-" "jzqbagoecgrtsa-uhfffaoysa-" "bh764" "2,5-dihydro-4-hydroxyfuran-2-one" "4-hydroxy-2(5h)-furanone;4-hydroxy-5h-furan-2-one;b-tetronic acid;" );
gibbsFormation
{
    dHf_298   -455950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     322.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-375600.0
    phase     gas;
}
