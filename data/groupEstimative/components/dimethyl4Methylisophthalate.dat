/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 4-methylisophthalate  (C11H12O4, CAS 23038-61-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl4Methylisophthalate;
formula     C11H12O4;
CAS         23038-61-1;
InChIKey    MTDRWWFCMSDTBL-UHFFFAOYSA-N;
MW          208.213;      // g/mol [origin=calculated method=formula-sum]
Tc          816.31;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       0.7441;      // -   [origin=predictive method=lee-kesler]
Tb          604.36;      // K   [origin=predictive method=joback]
HvapTb      58494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.4 0.74136 -0.00028252 -1.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 4-methylbenzene-1,3-dicarboxylate" "dimethyl 4-methyl-1,3-benzenedicarboxylate" "1,3-benzenedicarboxylic acid, 4-methyl-, dimethyl ester" "1,3-benzenedicarboxylic acid, 4-methyl-, 1,3-dimethyl ester" "4-methyl-dimethyl isophthalate" );
gibbsFormation
{
    dHf_298   -691340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-485850.0
    phase     gas;
}
