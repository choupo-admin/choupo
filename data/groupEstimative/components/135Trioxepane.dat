/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-trioxepane  (C4H8O3, CAS 5981-06-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Trioxepane;
formula     C4H8O3;
CAS         5981-06-6;
InChIKey    ULAGGPJVDRGWTI-UHFFFAOYSA-N;
MW          104.105;      // g/mol [origin=calculated method=formula-sum]
Tc          619.76;      // K   [origin=predictive method=joback]
Pc          53.592;      // bar [origin=predictive method=joback]
omega       0.3328;      // -   [origin=predictive method=lee-kesler]
Tb          400.46;      // K   [origin=predictive method=joback]
HvapTb      38938.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.45 0.5138 -0.0002421 1.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group FCH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group O_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-trioxepane" "1,5-trioxacycloheptane" );
standardThermochemistry
{
    dHf_298   -453390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     189.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255500.0
}
