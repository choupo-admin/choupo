/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 2-cyclohexyl-4-(1,1-dimethylpropyl)-  (C17H26O, CAS 71889-14-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol2Cyclohexyl411Dimethylpropyl;
formula     C17H26O;
CAS         71889-14-0;
InChIKey    ULWIPPTYIDIZOB-UHFFFAOYSA-N;
MW          246.394;      // g/mol [origin=calculated method=formula-sum]
Tc          957.83;      // K   [origin=predictive method=joback]
Pc          21.414;      // bar [origin=predictive method=joback]
omega       0.7179;      // -   [origin=predictive method=lee-kesler]
Tb          717.16;      // K   [origin=predictive method=joback]
HvapTb      68521.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.169 1.88296 -0.00137432 4.063e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyclohexyl-4-(2-methylbutan-2-yl)phenol" "2-cyclohexyl-4-tert-amylphenol" );
standardThermochemistry
{
    dHf_298   -300890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     662.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=67710.0
}
