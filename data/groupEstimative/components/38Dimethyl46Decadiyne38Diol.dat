/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,8-dimethyl-4,6-decadiyne-3,8-diol  (C12H18O2, CAS 6626-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        38Dimethyl46Decadiyne38Diol;
formula     C12H18O2;
CAS         6626-33-1;
InChIKey    GLWDRGVPXZBLDS-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          871.37;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       1.1571;      // -   [origin=predictive method=lee-kesler]
Tb          670.06;      // K   [origin=predictive method=joback]
HvapTb      77376.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.268 1.16388 -0.00084912 2.5296e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 2; } { group OH; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 2; } { group tC; count 4; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,8-dimethyldeca-4,6-diyne-3,8-diol" "4,6-decadiyne-3,8-diol, 3,8-dimethyl-" "4,6-decadiyne-3,8-diol,3,8-dimethyl-" "3,8-dimethyl-4,6-decadiyn-3,8-diol" );
standardThermochemistry
{
    dHf_298   -68370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=187800.0
}
