/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-decalinyl acetate  (C12H20O2, CAS 10519-11-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DecalinylAcetate;
formula     C12H20O2;
CAS         10519-11-6;
InChIKey    XKCLIPLFEJSOAT-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          777.10;      // K   [origin=predictive method=joback]
Pc          24.076;      // bar [origin=predictive method=joback]
omega       0.5115;      // -   [origin=predictive method=lee-kesler]
Tb          558.27;      // K   [origin=predictive method=joback]
HvapTb      49918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.64 1.32592 -0.0007338 1.253e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 3; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,4a,5,6,7,8,8a-decahydronaphthalen-2-yl ethanoate" "decahydronaphthol acetate" "2-naphthalenol, decahydro-, acetate" "decahydro-2-naphthyl acetate" "decahydro-beta-naphthyl acetate" "decahydro-2-naphthalenol acetate" "2-naphthalenol, decahydro-, 2-acetate" "2-naphthol, decahydro-, acetate" "agn-pc-00m066" "decahydronaphthalen-2-yl acetate" "decahydro-.beta.-naphthyl acetate" "1,2,3,4,4a,5,6,7,8,8a-decahydronaphthalen-2-yl acetate" );
standardThermochemistry
{
    dHf_298   -507670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-194820.0
}
