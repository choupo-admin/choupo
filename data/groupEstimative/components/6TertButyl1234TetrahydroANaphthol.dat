/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-tert-butyl-1,2,3,4-tetrahydro-|a-naphthol  (C14H20O, CAS 68797-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6TertButyl1234TetrahydroANaphthol;
formula     C14H20O;
CAS         68797-71-7;
InChIKey    LLLRKSFANNQEDZ-UHFFFAOYSA-N;
MW          204.313;      // g/mol [origin=calculated method=formula-sum]
Tc          870.19;      // K   [origin=predictive method=joback]
Pc          25.125;      // bar [origin=predictive method=joback]
omega       0.8718;      // -   [origin=predictive method=lee-kesler]
Tb          656.52;      // K   [origin=predictive method=joback]
HvapTb      65826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.69 1.43706 -0.00101092 2.822e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-tert-butyl-1,2,3,4-tetrahydronaphthalen-2-ol" "6-(1,1-dimethylethyl)-1,2,3,4-tetrahydro-2-naphthol" "2-naphthalenol, 6-(1,1-dimethylethyl)-1,2,3,4-tetrahydro-" "6-tert-butyl-1,2,3,4-tetrahydro-beta-naphthol" );
gibbsFormation
{
    dHf_298   -213040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74820.0
    phase     gas;
}
