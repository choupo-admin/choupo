/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxy-4-isopropenyltoluene (dehydrocarvacrol)  (C10H12O, CAS 56423-47-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxy4IsopropenyltolueneDehydrocarvacrol;
formula     C10H12O;
CAS         56423-47-3;
InChIKey    HHTWOMMSBMNRKP-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          766.02;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       0.5615;      // -   [origin=predictive method=lee-kesler]
Tb          537.24;      // K   [origin=predictive method=joback]
HvapTb      53216.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.41 0.94994 -0.00076592 2.607e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-5-prop-1-en-2-yl-phenol" "2-methyl-5-(prop-1-en-2-yl)phenol" "0wv" "2-methyl-5-prop-1-en-2-ylphenol" "phenol, 2-methyl-5-(1-methylethenyl)-" );
gibbsFormation
{
    dHf_298   -86340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60770.0
    phase     gas;
}
