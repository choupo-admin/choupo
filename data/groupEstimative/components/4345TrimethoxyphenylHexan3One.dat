/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(3,4,5-trimethoxyphenyl)hexan-3-one  (C15H22O4, CAS 6955-40-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4345TrimethoxyphenylHexan3One;
formula     C15H22O4;
CAS         6955-40-4;
InChIKey    QBXJTIJLGPTTHB-UHFFFAOYSA-N;
MW          266.337;      // g/mol [origin=calculated method=formula-sum]
Tc          905.77;      // K   [origin=predictive method=joback]
Pc          18.077;      // bar [origin=predictive method=joback]
omega       0.9359;      // -   [origin=predictive method=lee-kesler]
Tb          705.11;      // K   [origin=predictive method=joback]
HvapTb      66834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (80.422 0.9598 -0.00027378 -5.584e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH; count 1; } { group CH2CO; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-hexanone, 4-(3,4,5-trimethoxyphenyl)-" "3-hexanone, 4-(3,4,5-trimethoxyphenyl)-," );
standardThermochemistry
{
    dHf_298   -665330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     666.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-287420.0
}
