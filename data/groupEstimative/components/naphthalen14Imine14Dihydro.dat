/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalen-1,4-imine,1,4-dihydro-  (C10H9N, CAS 5176-20-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphthalen14Imine14Dihydro;
formula     C10H9N;
CAS         5176-20-5;
InChIKey    QMWUOWKZUWTUFQ-UHFFFAOYSA-N;
MW          143.189;      // g/mol [origin=calculated method=formula-sum]
Tc          758.15;      // K   [origin=predictive method=joback]
Pc          40.777;      // bar [origin=predictive method=joback]
omega       0.4671;      // -   [origin=predictive method=lee-kesler]
Tb          516.98;      // K   [origin=predictive method=joback]
HvapTb      47496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.47 1.0574 -0.00089784 3.082e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalen-1,4-imine, 1,4-dihydro-" "11-aza-tricyclo[6.2.1.0(2,7)]undec-2,4,6,9-tetraene" );
gibbsFormation
{
    dHf_298   222680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     188.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=387370.0
    phase     gas;
}
