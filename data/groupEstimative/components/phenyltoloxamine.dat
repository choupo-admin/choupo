/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyltoloxamine  (C17H21NO, CAS 92-12-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenyltoloxamine;
formula     C17H21NO;
CAS         92-12-6;
InChIKey    IZRPKIZLIFYYKR-UHFFFAOYSA-N;
MW          255.361;      // g/mol [origin=calculated method=formula-sum]
Tc          902.16;      // K   [origin=predictive method=joback]
Pc          20.254;      // bar [origin=predictive method=joback]
omega       0.7550;      // -   [origin=predictive method=lee-kesler]
Tb          681.76;      // K   [origin=predictive method=joback]
HvapTb      63103.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.267 1.46224 -0.00089796 1.998e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-2-[2-(phenylmethyl)phenoxy]ethanamine" "phenoxadrin" "phenoxadrine" "phentoloxamine" "bistrimin" "bristamin" "histionex" "antin" "feniltolossamina [dcit]" "phenyltoloxaminum [inn-latin]" "ethanamine, n,n-dimethyl-2-[2-(phenylmethyl)phenoxy]-" "n,n-dimethyl-2-(2-(phenylmethyl)phenoxy)ethanamine" );
standardThermochemistry
{
    dHf_298   2690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     626.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=313230.0
}
