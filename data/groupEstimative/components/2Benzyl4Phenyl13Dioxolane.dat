/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-benzyl-4-phenyl-1,3-dioxolane  (C16H16O2, CAS 4362-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Benzyl4Phenyl13Dioxolane;
formula     C16H16O2;
CAS         4362-20-3;
InChIKey    WIAZXGHBTOASSQ-UHFFFAOYSA-N;
MW          240.302;      // g/mol [origin=calculated method=formula-sum]
Tc          939.71;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       0.6239;      // -   [origin=predictive method=lee-kesler]
Tb          683.55;      // K   [origin=predictive method=joback]
HvapTb      64730.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.369 1.4652 -0.0009532 2.241e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenyl-2-(phenylmethyl)-1,3-dioxolane" "1,3-dioxolane, 4-phenyl-2-(phenylmethyl)-" "phenylacetaldehyde phenylethylene glycol acetal" "1, 2-benzyl-4-phenyl-" "1,3-dioxolane, 2-benzyl-4-phenyl- (8ci)" );
gibbsFormation
{
    dHf_298   -124370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     371.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=165260.0
    phase     gas;
}
