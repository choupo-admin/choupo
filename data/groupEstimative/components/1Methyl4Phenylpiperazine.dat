/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-4-phenylpiperazine  (C11H16N2, CAS 3074-43-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl4Phenylpiperazine;
formula     C11H16N2;
CAS         3074-43-9;
InChIKey    WQDDXVGJRSTLED-UHFFFAOYSA-N;
MW          176.263;      // g/mol [origin=calculated method=formula-sum]
Tc          738.97;      // K   [origin=predictive method=joback]
Pc          32.320;      // bar [origin=predictive method=joback]
omega       0.5166;      // -   [origin=predictive method=lee-kesler]
Tb          518.52;      // K   [origin=predictive method=joback]
HvapTb      46836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.7 1.38552 -0.0010602 3.176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-phenyl-piperazine" "piperazine, 1-methyl-4-phenyl-" "1-methyl-4-phenylpyrazine" "piperazine,1-methyl-4-phenyl-" "q583" );
standardThermochemistry
{
    dHf_298   188200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=432070.0
}
