/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecylcyclohexane  (C24H48, CAS 4445-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecylcyclohexane;
formula     C24H48;
CAS         4445-06-1;
InChIKey    MWWVNZNVTGBKQO-UHFFFAOYSA-N;
MW          336.648;      // g/mol [origin=calculated method=formula-sum]
Tc          948.95;      // K   [origin=predictive method=joback]
Pc          9.089;      // bar [origin=predictive method=joback]
omega       0.7872;      // -   [origin=predictive method=lee-kesler]
Tb          768.27;      // K   [origin=predictive method=joback]
HvapTb      69447.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.533 2.40592 -0.0013628 2.84e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 22; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane, octadecyl-" "1-cyclohexyloctadecane" "stearylcyclohexane" );
standardThermochemistry
{
    dHf_298   -484370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1060.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175650.0
}
