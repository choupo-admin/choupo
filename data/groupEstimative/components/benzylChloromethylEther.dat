/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl chloromethyl ether  (C8H9ClO, CAS 3587-60-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylChloromethylEther;
formula     C8H9ClO;
CAS         3587-60-8;
InChIKey    LADPCMZCENPFGV-UHFFFAOYSA-N;
MW          156.609;      // g/mol [origin=calculated method=formula-sum]
Tc          684.23;      // K   [origin=predictive method=joback]
Pc          34.239;      // bar [origin=predictive method=joback]
omega       0.4244;      // -   [origin=predictive method=lee-kesler]
Tb          469.17;      // K   [origin=predictive method=joback]
HvapTb      42473.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.102 0.6285 -0.000352 6.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyloxymethylbenzene" "(chloromethoxymethyl)benzene" "benzyloxymethyl chloride" "chloromethoxymethyl-benzene" "((chloromethoxy)methyl)benzene" "[(chloromethoxy)methyl]benzene" "benzene, [(chloromethoxy)methyl]-" "1-[(chloromethoxy)methyl]benzene" "1-((chloromethoxy)methyl)benzene" "chloromethoxymethylbenzene" "benzyl-chloromethyl ether" "chloro(phenylmethoxy)methane" );
gibbsFormation
{
    dHf_298   -119880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11960.0
    phase     gas;
}
