/*--------------------------------*- Choupo -*-----------------------*\
  Component: xenysalate  (C19H23NO3, CAS 3572-52-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        xenysalate;
formula     C19H23NO3;
CAS         3572-52-9;
InChIKey    HLDCSYXMVXILQC-UHFFFAOYSA-N;
MW          313.397;      // g/mol [origin=calculated method=formula-sum]
Tc          1069.70;      // K   [origin=predictive method=joback]
Pc          19.877;      // bar [origin=predictive method=joback]
omega       1.1417;      // -   [origin=predictive method=lee-kesler]
Tb          843.94;      // K   [origin=predictive method=joback]
HvapTb      85566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.096 1.81524 -0.00127952 3.544e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 8; } { group AC; count 3; } { group ACOH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethyl 2-oxidanyl-3-phenyl-benzoate" "xenisalato" "biphenamine" "xenysalatum" "alvinine" "(1,1'-biphenyl)-3-carboxylic acid, 2-hydroxy-, 2-(diethylamino)ethyl ester" "[1,1'-biphenyl]-3-carboxylic acid, 2-hydroxy-, 2-(diethylamino)ethyl ester" "xenysalate [inn:ban]" "xenysalatum [inn-latin]" "2-diethylaminoethyl 3-phenylsalicylat" "2-(diethylamino)ethyl 3-phenylsalicylate" "2-diethylaminoethyl 2-hydroxy-3-phenylbenzoate" );
gibbsFormation
{
    dHf_298   -400960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     770.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29920.0
    phase     gas;
}
