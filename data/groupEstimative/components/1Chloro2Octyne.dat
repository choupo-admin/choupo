/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-2-octyne  (C8H13Cl, CAS 51575-83-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro2Octyne;
formula     C8H13Cl;
CAS         51575-83-8;
InChIKey    OUMUOQQKEAGFCJ-UHFFFAOYSA-N;
MW          144.642;      // g/mol [origin=calculated method=formula-sum]
Tc          623.98;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       0.3681;      // -   [origin=predictive method=lee-kesler]
Tb          429.07;      // K   [origin=predictive method=joback]
HvapTb      39939.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.065 0.62082 -0.00033966 7.198e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2Cl; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group tC; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyloct-2-yne" "1-chlorooct-2-yne" "oumuoqqkeagfcj-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   48110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=207350.0
}
