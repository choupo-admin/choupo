/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dichlorohexane  (C6H12Cl2, CAS 2162-92-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dichlorohexane;
formula     C6H12Cl2;
CAS         2162-92-7;
InChIKey    ZHFXSKJYCSWRJA-UHFFFAOYSA-N;
MW          155.062;      // g/mol [origin=calculated method=formula-sum]
Tc          595.66;      // K   [origin=predictive method=joback]
Pc          28.905;      // bar [origin=predictive method=joback]
omega       0.3885;      // -   [origin=predictive method=lee-kesler]
Tb          411.30;      // K   [origin=predictive method=joback]
HvapTb      37332.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.534 0.59332 -0.0003466 7.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)hexane" "hexane, 1,2-dichloro-" "1,2-dichloro-hexane" );
gibbsFormation
{
    dHf_298   -203930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26660.0
    phase     gas;
}
