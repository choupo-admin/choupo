/*--------------------------------*- Choupo -*-----------------------*\
  Component: 14-nonacosyne  (C29H56, CAS 68516-35-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Nonacosyne;
formula     C29H56;
CAS         68516-35-8;
InChIKey    JYLPUGDQADDKAY-UHFFFAOYSA-N;
MW          404.767;      // g/mol [origin=calculated method=formula-sum]
Tc          1068.36;      // K   [origin=predictive method=joback]
Pc          6.775;      // bar [origin=predictive method=joback]
omega       0.6082;      // -   [origin=predictive method=lee-kesler]
Tb          872.12;      // K   [origin=predictive method=joback]
HvapTb      82300.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.915 2.60904 -0.00146166 3.1288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 25; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 25; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonacos-14-yne" );
gibbsFormation
{
    dHf_298   -369590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1257.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=396100.0
    phase     gas;
}
