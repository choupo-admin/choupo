/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dichloro-2,3-dimethylcyclopropane  (C5H8Cl2, CAS 53143-77-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichloro23Dimethylcyclopropane;
formula     C5H8Cl2;
CAS         53143-77-4;
InChIKey    KOBPHDGNTMLQKI-UHFFFAOYSA-N;
MW          139.019;      // g/mol [origin=calculated method=formula-sum]
Tc          591.86;      // K   [origin=predictive method=joback]
Pc          36.159;      // bar [origin=predictive method=joback]
omega       0.2431;      // -   [origin=predictive method=lee-kesler]
Tb          386.50;      // K   [origin=predictive method=joback]
HvapTb      33638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.23 0.88224 -0.000931 4.072e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)-2,3-dimethyl-cyclopropane" "cis-1,2-dimethyl-3,3-dichlorocyclopropane" "agn-pc-00oga9" "1,1-dichloro-2,3-dimethyl cyclopropane" "cis-1,1-dichloro-2,3-dimethylcyclopropane" "trans-1,1-dichloro-2,3-dimethylcyclopropane" "trans-1,2-dimethyl-3,3-dichlorocyclopropane" );
standardThermochemistry
{
    dHf_298   -130650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     312.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=7200.0
}
