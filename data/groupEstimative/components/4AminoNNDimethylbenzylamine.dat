/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-amino-n,n-dimethylbenzylamine  (C9H14N2, CAS 6406-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4AminoNNDimethylbenzylamine;
formula     C9H14N2;
CAS         6406-74-2;
InChIKey    NNCCQALFJIMRKB-UHFFFAOYSA-N;
MW          150.225;      // g/mol [origin=calculated method=formula-sum]
Tc          739.54;      // K   [origin=predictive method=joback]
Pc          34.159;      // bar [origin=predictive method=joback]
omega       0.5756;      // -   [origin=predictive method=lee-kesler]
Tb          522.15;      // K   [origin=predictive method=joback]
HvapTb      51250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.099 0.90624 -0.00058596 1.449e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group CH3N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(dimethylamino)methyl]aniline" "n-(4-aminobenzyl)-n,n-dimethylamine" "4-dimethylaminomethyl-phenylamine" "4-(dimethylaminomethyl)aniline" "4-dimethylaminomethylphenylamine" "[(4-aminophenyl)methyl]dimethylamine" "n,n-dimethyl-4-aminobenzylamine" "4-amino-n,n-dimethyl-benzenemethanamine" "1-amino-3/4-dimethylamino-methylbenzene" "toluene-a,4-diamine, na,na-dimethyl- (6ci,8ci);4-(dimethylaminomethyl)aniline;4-(dimethylaminomethyl)phenylamine;4-amino-n,n-dimethylbenzenemethanamine;4-[(n,n-dimethylamino)methyl]aniline;n-(p-aminobenzyl)dimethylamine;benzenemethanamine,4-amino-n,n-dimethyl-;" );
standardThermochemistry
{
    dHf_298   97290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=304910.0
}
