/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, polymer with 2,4,4-trimethyl-1-pentene  (C14H22O, CAS 68016-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenolPolymerWith244Trimethyl1Pentene;
formula     C14H22O;
CAS         68016-20-6;
InChIKey    OZINQSQBCYTPHZ-UHFFFAOYSA-N;
MW          206.329;      // g/mol [origin=calculated method=formula-sum]
Tc          847.62;      // K   [origin=predictive method=joback]
Pc          22.915;      // bar [origin=predictive method=joback]
omega       0.5645;      // -   [origin=predictive method=lee-kesler]
Tb          616.97;      // K   [origin=predictive method=joback]
HvapTb      59794.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.299 1.36858 -0.0008746 2.128e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol;2,4,4-trimethylpent-1-ene" "diisobutylene, phenol polymer" "phenol; 2,4,4-trimethylpent-1-ene" "1-protene, 2,4,4-trimethyl-, polymer with phenol" );
standardThermochemistry
{
    dHf_298   -266330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     687.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11790.0
}
