/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 2,5-dibromohexanedioate  (C8H12Br2O4, CAS 868-72-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl25Dibromohexanedioate;
formula     C8H12Br2O4;
CAS         868-72-4;
InChIKey    HVICCJCVLLCDFQ-UHFFFAOYSA-N;
MW          331.988;      // g/mol [origin=calculated method=formula-sum]
Tc          842.11;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       0.9158;      // -   [origin=predictive method=lee-kesler]
Tb          630.52;      // K   [origin=predictive method=joback]
HvapTb      60310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.452 0.74244 -0.0003714 3.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group Br; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group Br; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2,5-bis(bromanyl)hexanedioate" "dimethyl 2,2'-dibromoadipate" "dimethyl 2,5-dibromohexane-1,6-dioate" );
gibbsFormation
{
    dHf_298   -800910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     653.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-580500.0
    phase     gas;
}
