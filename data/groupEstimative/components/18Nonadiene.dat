/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-nonadiene  (C9H16, CAS 4900-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Nonadiene;
formula     C9H16;
CAS         4900-30-5;
InChIKey    VJHGSLHHMIELQD-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          568.63;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.4034;      // -   [origin=predictive method=lee-kesler]
Tb          398.88;      // K   [origin=predictive method=joback]
HvapTb      34288.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.275 0.8188 -0.0005116 1.307e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nona-1,8-diene" );
standardThermochemistry
{
    dHf_298   21770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=200580.0
}
