/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-isocyanato-1,2,3-trimethoxybenzene  (C10H11NO4, CAS 1016-19-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Isocyanato123Trimethoxybenzene;
formula     C10H11NO4;
CAS         1016-19-9;
InChIKey    MJJXWPHZDBIHIM-UHFFFAOYSA-N;
MW          209.201;      // g/mol [origin=calculated method=formula-sum]
Tc          814.12;      // K   [origin=predictive method=joback]
Pc          28.627;      // bar [origin=predictive method=joback]
omega       0.8133;      // -   [origin=predictive method=lee-kesler]
Tb          603.95;      // K   [origin=predictive method=joback]
HvapTb      58878.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 3; } { group dCd; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-isocyanato-1,2,3-trimethoxy-benzene" "3,4,5-trimethoxyphenyl isocyanate" "3,4,5-trimethoxyphenyl cyanate" "3,4,5-trimethoxybenzenisocyanate" "benzene, 5-isocyanato-1,2,3-trimethoxy-" "isocyanicacid, 3,4,5-trimethoxyphenyl ester (7ci,8ci);3,4,5-trimethoxyphenylisocyanate;5-isocyanato-1,2,3-trimethoxybenzene;" );
