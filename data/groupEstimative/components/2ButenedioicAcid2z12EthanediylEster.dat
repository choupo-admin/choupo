/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenedioic acid (2z)-, 1,2-ethanediyl ester  (C10H10O8, CAS 15498-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenedioicAcid2z12EthanediylEster;
formula     C10H10O8;
CAS         15498-42-7;
InChIKey    SORHAFXJCOXOIC-UHFFFAOYSA-N;
MW          258.182;      // g/mol [origin=calculated method=formula-sum]
Tc          1058.44;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       1.5433;      // -   [origin=predictive method=lee-kesler]
Tb          844.18;      // K   [origin=predictive method=joback]
HvapTb      86912.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.452 0.9858 -0.0006438 1.444e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 2; } { group COOH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH; count 4; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylidene-4-[2-(4-oxidanyl-4-oxidanylidene-but-2-enoyl)oxyethoxy]but-2-enoic acid" "2-butenedioic acid (2z)-, 1,1'-(1,2-ethanediyl) ester" );
gibbsFormation
{
    dHf_298   -1350390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     741.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1114800.0
    phase     gas;
}
