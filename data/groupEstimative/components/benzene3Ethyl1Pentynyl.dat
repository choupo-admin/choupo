/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, (3-ethyl-1-pentynyl)-  (C13H16, CAS 73829-94-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene3Ethyl1Pentynyl;
formula     C13H16;
CAS         73829-94-4;
InChIKey    WJQBALSWJCYVQH-UHFFFAOYSA-N;
MW          172.271;      // g/mol [origin=calculated method=formula-sum]
Tc          759.68;      // K   [origin=predictive method=joback]
Pc          25.846;      // bar [origin=predictive method=joback]
omega       0.4113;      // -   [origin=predictive method=lee-kesler]
Tb          532.28;      // K   [origin=predictive method=joback]
HvapTb      48572.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.958 1.01604 -0.00062566 1.4748e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethylpent-1-ynylbenzene" "3-(phenylethynyl)pentane" );
gibbsFormation
{
    dHf_298   191900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=371350.0
    phase     gas;
}
