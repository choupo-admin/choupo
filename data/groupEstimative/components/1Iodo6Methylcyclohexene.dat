/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodo-6-methylcyclohexene  (C7H11I, CAS 40648-10-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodo6Methylcyclohexene;
formula     C7H11I;
CAS         40648-10-0;
InChIKey    ZDARRRISQKLIIU-UHFFFAOYSA-N;
MW          222.065;      // g/mol [origin=calculated method=formula-sum]
Tc          722.90;      // K   [origin=predictive method=joback]
Pc          35.179;      // bar [origin=predictive method=joback]
omega       0.2687;      // -   [origin=predictive method=lee-kesler]
Tb          476.59;      // K   [origin=predictive method=joback]
HvapTb      41932.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.31 0.71442 -0.00043964 1.009e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH=C; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyl-6-methyl-cyclohexene" "cyclohexene, 1-iodo-6-methyl-" "1-iodo-6-methyl-1-cyclohexene" );
gibbsFormation
{
    dHf_298   -10310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110960.0
    phase     gas;
}
