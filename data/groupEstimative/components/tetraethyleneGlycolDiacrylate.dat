/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraethylene glycol diacrylate  (C14H22O7, CAS 17831-71-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraethyleneGlycolDiacrylate;
formula     C14H22O7;
CAS         17831-71-9;
InChIKey    HCLJOFJIQIJXHS-UHFFFAOYSA-N;
MW          302.323;      // g/mol [origin=calculated method=formula-sum]
Tc          873.16;      // K   [origin=predictive method=joback]
Pc          15.760;      // bar [origin=predictive method=joback]
omega       1.0925;      // -   [origin=predictive method=lee-kesler]
Tb          696.98;      // K   [origin=predictive method=joback]
HvapTb      67462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (111.498 0.9946 -0.0002614 -8.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2=CH; count 2; } { group CH2O; count 3; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group dCH2; count 2; } { group dCH; count 2; } { group O; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-(2-prop-2-enoyloxyethoxy)ethoxy]ethoxy]ethyl prop-2-enoate" "ttegda" "tetraethyleneglycol diacrylate" "acrylic acid, diester with tetraethylene glycol" "tetra(ethylene glycol) diacrylate" "2-propenoic acid, oxybis(2,1-ethanediyloxy-2,1-ethanediyl) ester" "acrylic acid, oxybis(ethyleneoxyethylene) ester" "oxybis(2,1-ethanediyloxy-2,1-ethanediyl)diacrylate" "2-propenoic acid, oxybis(2,1-ethanediyloxy-2,1-ethanediyl)ester" "13-oxo-3,6,9,12-tetraoxapentadec-14-en-1-yl acrylate" "2-propenoic acid, 1,1'-(oxybis(2,1-ethanediyloxy-2,1-ethanediyl)) ester" "2-propenoic acid, 1,1'-[oxybis(2,1-ethanediyloxy-2,1-ethanediyl)] ester" );
standardThermochemistry
{
    dHf_298   -1112650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     828.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-693060.0
}
