/*--------------------------------*- Choupo -*-----------------------*\
  Component: benproperine  (C21H27NO, CAS 2156-27-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benproperine;
formula     C21H27NO;
CAS         2156-27-6;
InChIKey    JTUQXGZRVLWBCR-UHFFFAOYSA-N;
MW          309.453;      // g/mol [origin=calculated method=formula-sum]
Tc          1028.13;      // K   [origin=predictive method=joback]
Pc          17.580;      // bar [origin=predictive method=joback]
omega       0.8306;      // -   [origin=predictive method=lee-kesler]
Tb          792.79;      // K   [origin=predictive method=joback]
HvapTb      72185.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.008 2.00632 -0.00130156 3.146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[1-[2-(phenylmethyl)phenoxy]propan-2-yl]piperidine" "pirexyl" "benproperinum [inn-latin]" "benproperine (inn)" "benproperine [inn]" "1-[1-(2-benzylphenoxy)propan-2-yl]piperidine" "1-(2-(2-benzylphenoxy)-1-methylethyl)piperidine" "1-(1-methyl-2-((alpha-phenyl-o-tolyl)oxy)ethyl)piperidine" "piperidine, 1-(1-methyl-2-((alpha-phenyl-o-tolyl)oxy)ethyl)-" "bemproperina" "benproperinum" "piperidine, 1-(1-methyl-2-(2-(phenylmethyl)phenoxy)ethyl)-" );
standardThermochemistry
{
    dHf_298   -4330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     764.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=388730.0
}
