/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 5540  (C16H16, CAS 96563-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris5540;
formula     C16H16;
CAS         96563-06-3;
InChIKey    ZMIPDNFQNDHTBC-UHFFFAOYSA-N;
MW          208.304;      // g/mol [origin=calculated method=formula-sum]
Tc          871.68;      // K   [origin=predictive method=joback]
Pc          23.293;      // bar [origin=predictive method=joback]
omega       0.5993;      // -   [origin=predictive method=lee-kesler]
Tb          637.16;      // K   [origin=predictive method=joback]
HvapTb      57979.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.27 1.29816 -0.00095384 2.897e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 6; } { group AC; count 3; } { group ACCH3; count 2; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,9-trimethyl-9h-fluorene" "9h-fluorene, 2,3,9-trimethyl-" );
standardThermochemistry
{
    dHf_298   138730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=355090.0
}
