/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxycholest-5-ene  (C28H48O, CAS 1174-92-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxycholest5Ene;
formula     C28H48O;
CAS         1174-92-1;
InChIKey    RCXPTZJNVLDKKV-UHFFFAOYSA-N;
MW          400.691;      // g/mol [origin=calculated method=formula-sum]
Tc          1122.40;      // K   [origin=predictive method=joback]
Pc          9.467;      // bar [origin=predictive method=joback]
omega       0.7348;      // -   [origin=predictive method=lee-kesler]
Tb          900.70;      // K   [origin=predictive method=joback]
HvapTb      77793.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-287.087 3.55692 -0.00286284 1.0046e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 11; } { group CH; count 7; } { group C; count 2; } { group CH=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxy-10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthrene" "cholest-5-ene, 3.beta.-methoxy-" "cholesterol methyl ether" "cholesteryl methyl ether" "cholest-5-ene, 3-methoxy-, (3.beta.)-" "cholesterin methyl ether" "3beta-methoxycholest-5-ene" "3-o-methylcholesterol" "isocholesteryl methyl ether" "3.alpha.-cholesterol methyl ether" "cholest-5-ene, 3beta-methoxy- (8ci)" "cholest-5-ene, 3-methoxy-, (3beta)- (9ci)" );
gibbsFormation
{
    dHf_298   -487860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     945.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243720.0
    phase     gas;
}
