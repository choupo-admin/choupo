/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dioxaspiro(4.5)decane, 7,7,9-trimethyl-  (C11H20O2, CAS 99743-21-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dioxaspiro45Decane779Trimethyl;
formula     C11H20O2;
CAS         99743-21-2;
InChIKey    ZTUOQBOZIFOYMP-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          765.58;      // K   [origin=predictive method=joback]
Pc          28.444;      // bar [origin=predictive method=joback]
omega       0.4079;      // -   [origin=predictive method=lee-kesler]
Tb          531.55;      // K   [origin=predictive method=joback]
HvapTb      47003.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-187.48 1.86356 -0.0018114 7.491e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,7,9-trimethyl-1,4-dioxaspiro[4.5]decane" "1,4-dioxaspiro[4.5]decane, 7,7,9-trimethyl-" "7,9,9-trimethyl-1,4-dioxaspiro[4.5]decane" );
gibbsFormation
{
    dHf_298   -403270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76090.0
    phase     gas;
}
