/*--------------------------------*- Choupo -*-----------------------*\
  Component: tribromoethylene  (C2HBr3, CAS 598-16-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tribromoethylene;
formula     C2HBr3;
CAS         598-16-3;
InChIKey    OZVJKTHTULCNHB-UHFFFAOYSA-N;
MW          264.742;      // g/mol [origin=calculated method=formula-sum]
Tc          697.54;      // K   [origin=predictive method=joback]
Pc          76.143;      // bar [origin=predictive method=joback]
omega       0.4195;      // -   [origin=predictive method=lee-kesler]
Tb          447.88;      // K   [origin=predictive method=joback]
HvapTb      39389.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.77 0.3283 -0.0003853 1.641e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group dC; count 1; } { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2-tris(bromanyl)ethene" "ethene, tribromo-" "ethylene, tribromo-" "ethylene tribromide" "ethene, 1,1,2-tribromo-" "tribromoethene" "1,1,2-tribromoethene" "1,1,2-tribromoethylene" "1,2-tribromoethylene" "ethylene, tribromo- (van)" "ethylene, tribromo- (van) (8ci)" );
standardThermochemistry
{
    dHf_298   101810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80590.0
}
