/*--------------------------------*- Choupo -*-----------------------*\
  Component: pantothenic acid  (C9H17NO5, CAS 79-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pantothenicAcid;
formula     C9H17NO5;
CAS         79-83-4;
InChIKey    GHOKWGTUZJEAQD-ZETCQYMHSA-N;
MW          219.237;      // g/mol [origin=calculated method=formula-sum]
Tc          1031.22;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       1.9545;      // -   [origin=predictive method=lee-kesler]
Tb          835.76;      // K   [origin=predictive method=joback]
HvapTb      97648.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.117 1.15754 -0.0008041 2.1636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[[(2r)-3,3-dimethyl-2,4-bis(oxidanyl)butanoyl]amino]propanoic acid" "vitamin b5" "d-pantothenic acid" "pantothenate" "chick antidermatitis factor" "(r)-pantothenate" "pantothenoic acid" "pantothenic acid [ban]" "beta-alanine, n-(2,4-dihydroxy-3,3-dimethyl-1-oxobutyl)-, (r)-" "(d)-(+)-pantothenic acid" "d(+)-n-(2,4-dihydroxy-3,3-dimethylbutyryl)-beta-alanine" "(d,+)-n(alpha-gamma-dihydroxy-beta,beta-dimethylbutyryl)-beta-alanine" );
standardThermochemistry
{
    dHf_298   -956960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     680.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-631780.0
}
