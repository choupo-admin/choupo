/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-cycloheptadienone, 2-methyl-  (C8H10O, CAS 42104-03-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Cycloheptadienone2Methyl;
formula     C8H10O;
CAS         42104-03-0;
InChIKey    ZVBMJGIUGHSZKQ-UHFFFAOYSA-N;
MW          122.167;      // g/mol [origin=calculated method=formula-sum]
Tc          706.87;      // K   [origin=predictive method=joback]
Pc          36.776;      // bar [origin=predictive method=joback]
omega       0.3398;      // -   [origin=predictive method=lee-kesler]
Tb          472.60;      // K   [origin=predictive method=joback]
HvapTb      38834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.12 0.59602 -0.00017656 -4.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH=CH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylcyclohepta-3,5-dien-1-one" "2-methyl-cyclohepta-3,5-dien-1-one" );
standardThermochemistry
{
    dHf_298   -182430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     303.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-33840.0
}
