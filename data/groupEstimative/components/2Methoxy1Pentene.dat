/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-1-pentene  (C6H12O, CAS 53119-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy1Pentene;
formula     C6H12O;
CAS         53119-70-3;
InChIKey    HOBMRFOADKWGMD-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          527.28;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       0.3291;      // -   [origin=predictive method=lee-kesler]
Tb          355.86;      // K   [origin=predictive method=joback]
HvapTb      30770.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.252 0.49054 -0.0002168 2.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxypent-1-ene" "1-pentene, 2-methoxy-" );
standardThermochemistry
{
    dHf_298   -183750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26070.0
}
