/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-2-carbomethoxycyclopentanone  (C8H12O3, CAS 30680-84-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl2Carbomethoxycyclopentanone;
formula     C8H12O3;
CAS         30680-84-3;
InChIKey    TZHZMYGNHVTEFA-UHFFFAOYSA-N;
MW          156.181;      // g/mol [origin=calculated method=formula-sum]
Tc          750.20;      // K   [origin=predictive method=joback]
Pc          33.763;      // bar [origin=predictive method=joback]
omega       0.5132;      // -   [origin=predictive method=lee-kesler]
Tb          524.20;      // K   [origin=predictive method=joback]
HvapTb      44162.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.02 0.96434 -0.0007328 2.514e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 1-methyl-2-oxidanylidene-cyclopentane-1-carboxylate" "methyl 1-methyl-2-oxocyclopentanecarboxylate" "cyclopentanecarboxylic acid, 1-methyl-2-oxo-, methyl ester" "(r)-methyl 1-methyl-2-oxocyclopentanecarboxylate" "cyclopentanecarboxylic acid, 1-methyl-2-oxo-, methyl ester, (1s)-" "methyl 1-methyl-2-oxo-1-cyclopentanecarboxylate" "methyl 1-methyl-2-oxocyclopentane-1-carboxylate" "cyclopentanecarboxylicacid, 1-methyl-2-oxo-, methyl ester" "2-methyl-2-carbomethoxycyclopentanone;methyl 1-methyl-2-oxo-1-cyclopentanecarboxylate; methyl 1-methyl-2-oxocyclopentanecarboxylate" );
standardThermochemistry
{
    dHf_298   -587710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-385420.0
}
