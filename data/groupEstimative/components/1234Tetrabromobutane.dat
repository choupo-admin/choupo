/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-tetrabromobutane  (C4H6Br4, CAS 1529-68-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234Tetrabromobutane;
formula     C4H6Br4;
CAS         1529-68-6;
InChIKey    HGRZLIGHKHRTRE-UHFFFAOYSA-N;
MW          373.708;      // g/mol [origin=calculated method=formula-sum]
Tc          806.35;      // K   [origin=predictive method=joback]
Pc          58.272;      // bar [origin=predictive method=joback]
omega       0.6573;      // -   [origin=predictive method=lee-kesler]
Tb          554.88;      // K   [origin=predictive method=joback]
HvapTb      49462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.652 0.5484 -0.0004858 1.718e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group Br; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 2; } { group Br; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetrakis(bromanyl)butane" "tetrabromobutane" "butane, 1,2,3,4-tetrabromo-" "meso-1,2,3,4-tetrabromobutane" "1,3,4-tetrabromobutane" "butane,2,3,4-tetrabromo-" "butane,1,2,3,4-tetrabromo-" "agn-pc-03v735" );
gibbsFormation
{
    dHf_298   -31130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35200.0
    phase     gas;
}
