name        2HydroxyethylProp2Enoate1Isocyanato44IsocyanatocyclohexylMet;
formula     C26H40N2O7;
CAS         52404-33-8;
InChIKey    FHEPAJYPVFUTEE-UHFFFAOYSA-N;
MW          492.613;      // g/mol [origin=calculated method=formula-sum]
Tc          1453.40;      // K   [origin=predictive method=joback]
Pc          10.814;      // bar [origin=predictive method=joback]
omega       1.0242;      // -   [origin=predictive method=lee-kesler]
Tb          1185.63;      // K   [origin=predictive method=joback]
HvapTb      124751.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 15; } { group CH; count 4; } { group CH2=CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group dCd; count 2; } { group CH2_ring; count 13; } { group CH_ring; count 4; } { group OH; count 1; } { group COO; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hydroxyethyl prop-2-enoate; 1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane; oxepan-2-one" "2-propenoic acid, 2-hydroxyethyl ester, polymer with 1,1'-methylenebis(4-isocyanatocyclohexane) and 2-oxepanone" "beta-hydroxyethyl acrylate, epsilon-caprolactone copolymer, bis(4,4'-isocyanatocyclohexyl)methane adduct" );
