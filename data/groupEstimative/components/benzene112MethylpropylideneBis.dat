/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,1'-(2-methylpropylidene)bis-  (C16H18, CAS 1634-11-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene112MethylpropylideneBis;
formula     C16H18;
CAS         1634-11-3;
InChIKey    WYYWMBKUPQWNRU-UHFFFAOYSA-N;
MW          210.32;      // g/mol [origin=calculated method=formula-sum]
Tc          858.38;      // K   [origin=predictive method=joback]
Pc          23.203;      // bar [origin=predictive method=joback]
omega       0.5074;      // -   [origin=predictive method=lee-kesler]
Tb          618.16;      // K   [origin=predictive method=joback]
HvapTb      54986.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.83 1.37784 -0.0009154 2.292e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-1-phenyl-propyl)benzene" "benzene,1'-(2-methylpropylidene)bis-" "benzene,1,1'-(2-methylpropylidene)bis-" "1,1'-(2-methylpropane-1,1-diyl)dibenzene" );
gibbsFormation
{
    dHf_298   88930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=303780.0
    phase     gas;
}
