/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl carbobutoxymethyl phthalate  (C18H24O6, CAS 85-70-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylCarbobutoxymethylPhthalate;
formula     C18H24O6;
CAS         85-70-1;
InChIKey    GOJCZVPJCKEBQV-UHFFFAOYSA-N;
MW          336.384;      // g/mol [origin=calculated method=formula-sum]
Tc          1018.03;      // K   [origin=predictive method=joback]
Pc          14.624;      // bar [origin=predictive method=joback]
omega       1.1038;      // -   [origin=predictive method=lee-kesler]
Tb          817.76;      // K   [origin=predictive method=joback]
HvapTb      80821.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.147 1.41104 -0.00063576 3.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group ACH; count 4; } { group AC; count 2; } { group CH2COO; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o2-(2-butoxy-2-oxidanylidene-ethyl) o1-butyl benzene-1,2-dicarboxylate" "butyl phthalyl butyl glycolate" "butoxycarbonylmethyl butyl phthalate" "reomol 4pg" "santicizer b-16" "2-butoxy-2-oxoethyl butyl phthalate" "phthalic acid, butyl ester, ester with butyl glycolate" "butyl glycolyl butyl phthalate" "butyl phthalate butyl glycolate" "butylcarbobutoxymethyl phthalate" "dibutyl o-carboxybenzoyloxyacetate" "butylphthalyl butylglycolate(bpbg)" );
standardThermochemistry
{
    dHf_298   -1141630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     898.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-727650.0
}
