/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-68309  (C5H5F3O2, CAS 69056-67-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG68309;
formula     C5H5F3O2;
CAS         69056-67-3;
InChIKey    QRRCTLYMABZQCS-UHFFFAOYSA-N;
MW          154.087;      // g/mol [origin=calculated method=formula-sum]
Tc          644.01;      // K   [origin=predictive method=joback]
Pc          35.942;      // bar [origin=predictive method=joback]
omega       0.6432;      // -   [origin=predictive method=lee-kesler]
Tb          458.13;      // K   [origin=predictive method=joback]
HvapTb      40179.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.13 0.71072 -0.0006279 2.142e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group COOH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } { group F; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4,4-tris(fluoranyl)-3-methyl-but-2-enoic acid" "?trifluoromethylcrotonic acid" "3-(trifluoromethyl)crotonic acid 95%" "2-butenoic acid,4,4,4-trifluoro-3-methyl-" "crotonicacid, 4,4,4-trifluoro-3-methyl- (6ci); 4,4,4-trifluoro-3-methyl-2-butenoicacid; b-(trifluoromethyl)crotonic acid" );
gibbsFormation
{
    dHf_298   -986450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-862610.0
    phase     gas;
}
