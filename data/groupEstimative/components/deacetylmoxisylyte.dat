/*--------------------------------*- Choupo -*-----------------------*\
  Component: deacetylmoxisylyte  (C14H23NO2, CAS 35231-36-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        deacetylmoxisylyte;
formula     C14H23NO2;
CAS         35231-36-8;
InChIKey    HJGRPZCEBPNMDU-UHFFFAOYSA-N;
MW          237.343;      // g/mol [origin=calculated method=formula-sum]
Tc          877.33;      // K   [origin=predictive method=joback]
Pc          22.187;      // bar [origin=predictive method=joback]
omega       0.9191;      // -   [origin=predictive method=lee-kesler]
Tb          671.60;      // K   [origin=predictive method=joback]
HvapTb      67437.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.938 1.3572 -0.00089608 2.463e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(dimethylamino)ethoxy]-2-methyl-5-propan-2-yl-phenol" "deacetylthymoxamine" "desacetylthymoxamine" "carvacrol, 5-(2-(dimethylamino)ethoxy)-" "phenol, 4-(2-(dimethylamino)ethoxy)-5-isopropyl-2-methyl-" "(2-(4-hydroxy-2-isopropyl-5-methylphenoxy)ethyl)dimethylamine" "phenol, 4-(2-(dimethylamino)ethoxy)-2-methyl-5-(1-methylethyl)-" "16809-53-3 (hydrochloride)" "4-(2-dimethylaminoethyloxy)-2-methyl-5-propan-2-ylphenol" );
gibbsFormation
{
    dHf_298   -365980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     626.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8870.0
    phase     gas;
}
