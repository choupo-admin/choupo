/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis,cis-cyclonona-1,5-diene  (C9H14, CAS 14255-64-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cisCisCyclonona15Diene;
formula     C9H14;
CAS         14255-64-2;
InChIKey    UWMOLRCQDVCRLG-NQOXHWNZSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          670.99;      // K   [origin=predictive method=joback]
Pc          34.725;      // bar [origin=predictive method=joback]
omega       0.2517;      // -   [origin=predictive method=lee-kesler]
Tb          440.87;      // K   [origin=predictive method=joback]
HvapTb      37466.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.64 0.8666 -0.00043756 5.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1z,5z)-cyclonona-1,5-diene" "cis,trans-cyclonona-1,5-diene" );
standardThermochemistry
{
    dHf_298   -57350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80680.0
}
