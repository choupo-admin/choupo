/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluoro-6-(trifluoromethyl)benzyl alcohol  (C8H6F4O, CAS 152211-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Fluoro6TrifluoromethylBenzylAlcohol;
formula     C8H6F4O;
CAS         152211-15-9;
InChIKey    TZUCYZIRXZYZOP-UHFFFAOYSA-N;
MW          194.127;      // g/mol [origin=calculated method=formula-sum]
Tc          679.71;      // K   [origin=predictive method=joback]
Pc          32.504;      // bar [origin=predictive method=joback]
omega       0.9009;      // -   [origin=predictive method=lee-kesler]
Tb          505.31;      // K   [origin=predictive method=joback]
HvapTb      49117.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.509 0.7729 -0.00057632 1.638e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group ACF; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-fluoranyl-6-(trifluoromethyl)phenyl]methanol" "[2-fluoro-6-(trifluoromethyl)phenyl]methanol" "(2-fluoro-6-(trifluoromethyl)phenyl)methanol" "[6-fluoro-2-(trifluoromethyl)phenyl]methan-1-ol" "otf-byl-6f" "2-fluoro-6-(trifluoromethyl)benzylalcohol" "benzenemethanol,2-fluoro-6-(trifluoromethyl)-" "2-fluoro-6-(trifluoromethyl)benzenemethanol;2-fluoro-6-(trifluoromethyl)benzyl alcohol;" );
gibbsFormation
{
    dHf_298   -940280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-803590.0
    phase     gas;
}
