/*--------------------------------*- Choupo -*-----------------------*\
  Component: fisioquens  (C41H54O3, CAS 8064-76-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fisioquens;
formula     C41H54O3;
CAS         8064-76-4;
InChIKey    RPGGYYVWJTWVMS-ZPSVQYCPSA-N;
MW          594.88;      // g/mol [origin=calculated method=formula-sum]
Tc          1824.32;      // K   [origin=predictive method=joback]
Pc          10.419;      // bar [origin=predictive method=joback]
omega       0.9254;      // -   [origin=predictive method=lee-kesler]
Tb          1479.69;      // K   [origin=predictive method=joback]
HvapTb      150738.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-575.61 5.81616 -0.00564322 2.29188e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 14; } { group CH; count 5; } { group C; count 5; } { group CH=C; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 2; } { group ACOH; count 1; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group tCH; count 2; } { group tC; count 2; } { group CH2_ring; count 15; } { group CH_ring; count 6; } { group C_ring; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s,17r)-17-ethynyl-10,13-dimethyl-1,2,3,6,7,8,9,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-17-ol;(8r,9s,13s,14s,17r)-17-ethynyl-13-methyl-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthrene-3,17-diol" "ministat" "ovostat" "fysioquens" "minilyn" "yermonil" "ovostat e" "ethinyloestradiol mixt. with lynoestrenol" "lynoestrenol mixt. with ethinyloestradiol" "lynestrenol mixture with ethinyl estradiol" "ethynylestradiol-lynestrenol mixt" "ethynylestradiol-lynestrenol mixt." );
gibbsFormation
{
    dHf_298   -166470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1457.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=612830.0
    phase     gas;
}
