/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dichloro-5-pentyldihydrofuran-2(3h)-one  (C9H14Cl2O2, CAS 68039-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dichloro5Pentyldihydrofuran23hOne;
formula     C9H14Cl2O2;
CAS         68039-30-5;
InChIKey    CWLQYNYPWWUCTQ-UHFFFAOYSA-N;
MW          225.109;      // g/mol [origin=calculated method=formula-sum]
Tc          742.58;      // K   [origin=predictive method=joback]
Pc          24.777;      // bar [origin=predictive method=joback]
omega       0.6091;      // -   [origin=predictive method=lee-kesler]
Tb          540.91;      // K   [origin=predictive method=joback]
HvapTb      50258.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.396 1.23392 -0.0011094 4.259e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CCl2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(chloranyl)-5-pentyl-oxolan-2-one" "2(3h)-furanone, 3,3-dichlorodihydro-5-pentyl-" "2,2-dichloro-gamma-nonalactone" "3,3-dichloro-5-pentyloxolan-2-one" "3,3-dichlorodihydro-5-pentylfuran-2(3h)-one" );
gibbsFormation
{
    dHf_298   -510150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-261780.0
    phase     gas;
}
