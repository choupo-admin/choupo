/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,4-trimethylpiperidine  (C8H17N, CAS 1003-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        144Trimethylpiperidine;
formula     C8H17N;
CAS         1003-84-5;
InChIKey    CWHCTKAJYQOXMG-UHFFFAOYSA-N;
MW          127.231;      // g/mol [origin=calculated method=formula-sum]
Tc          610.02;      // K   [origin=predictive method=joback]
Pc          32.173;      // bar [origin=predictive method=joback]
omega       0.3184;      // -   [origin=predictive method=lee-kesler]
Tb          410.60;      // K   [origin=predictive method=joback]
HvapTb      34551.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-125.55 1.31136 -0.001184 4.589e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -65200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158320.0
}
