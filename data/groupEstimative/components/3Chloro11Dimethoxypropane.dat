/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-1,1-dimethoxypropane  (C5H11ClO2, CAS 35502-06-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro11Dimethoxypropane;
formula     C5H11ClO2;
CAS         35502-06-8;
InChIKey    DXWRNRRBDAQWDB-UHFFFAOYSA-N;
MW          138.591;      // g/mol [origin=calculated method=formula-sum]
Tc          573.61;      // K   [origin=predictive method=joback]
Pc          32.246;      // bar [origin=predictive method=joback]
omega       0.4305;      // -   [origin=predictive method=lee-kesler]
Tb          395.83;      // K   [origin=predictive method=joback]
HvapTb      35541.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.552 0.36514 -4.98e-05 -5.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH3O; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-1,1-dimethoxy-propane" "propane, 3-chloro-1,1-dimethoxy-" "3-chloropropionaldehyde dimethyl acetal" "1-chloro-3,3-dimethoxypropane" "propane,3-chloro-1,1-dimethoxy-" "3-chloro-1,1-dimethoxy-propane;1-chloro-3,3-dimethoxypropane;propane, 3-chloro-1,1-dimethoxy-;" );
gibbsFormation
{
    dHf_298   -431990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-233150.0
    phase     gas;
}
