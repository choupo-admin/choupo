/*--------------------------------*- Choupo -*-----------------------*\
  Component: isoborneol, formate  (C11H18O2, CAS 1200-67-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H18O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        isoborneolFormate;
formula     C11H18O2;
CAS         1200-67-5;
InChIKey    RDWUNORUTVEHJF-YUCVTWSNSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          647.40;      // K   [origin=predictive method=joback]
Pc          26.218;      // bar [origin=predictive method=joback]
omega       0.2494;      // -   [origin=predictive method=lee-kesler]
Tb          436.59;      // K   [origin=predictive method=joback]
HvapTb      34785.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-220.32 1.87996 -0.002076 9.247e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 2; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s)-4,7,7-trimethyl-3-bicyclo[2.2.1]heptanyl] methanoate" "isobornyl methanoate" "isobornyl formate" "2-bornyl formate, exo-" "2-camphanyl formate, exo-" "exo-1,7,7-trimethylbicyclo(2.2.1)hept-2-yl formate" "1,7,7-trimethylbicyclo(2.2.1)heptan-2-yl formate, exo-" "bicyclo(2.2.1)heptan-2-ol, 1,7,7-trimethyl-, formate, (1r,2r,4r)-rel-" "bicyclo[2.2.1]heptan-2-ol, 1,7,7-trimethyl-, formate, exo-" "bicyclo(2.2.1)heptan-2-ol, 1,7,7-trimethyl-, 2-formate, (1r,2r,4r)-rel-" "[(3s)-4,7,7-trimethyl-3-bicyclo[2.2.1]heptanyl] formate" );
gibbsFormation
{
    dHf_298   -64680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     661.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=168700.0
    phase     gas;
}
