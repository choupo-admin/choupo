/*--------------------------------*- Choupo -*-----------------------*\
  Component: procyclidine  (C19H29NO, CAS 77-37-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        procyclidine;
formula     C19H29NO;
CAS         77-37-2;
InChIKey    WYDUSKDSKCASEF-UHFFFAOYSA-N;
MW          287.447;      // g/mol [origin=calculated method=formula-sum]
Tc          1021.42;      // K   [origin=predictive method=joback]
Pc          20.493;      // bar [origin=predictive method=joback]
omega       1.0551;      // -   [origin=predictive method=lee-kesler]
Tb          797.62;      // K   [origin=predictive method=joback]
HvapTb      78413.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-205.068 2.3035 -0.001666 4.667e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexyl-1-phenyl-3-pyrrolidin-1-yl-propan-1-ol" "arpicolin" "osnervan" "tricyclamol" "spamol" "procyklidin" "triciclidina" "elorine" "kemadrine" "lergine" "metanin" "tricoloid" );
gibbsFormation
{
    dHf_298   -151110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     759.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=279120.0
    phase     gas;
}
