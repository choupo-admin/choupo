/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-azabicyclo[3.3.1]nonane,9-propyl-  (C11H21N, CAS 73320-99-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Azabicyclo331Nonane9Propyl;
formula     C11H21N;
CAS         73320-99-7;
InChIKey    LYUBMQXAKJPYPE-UHFFFAOYSA-N;
MW          167.296;      // g/mol [origin=calculated method=formula-sum]
Tc          685.72;      // K   [origin=predictive method=joback]
Pc          25.872;      // bar [origin=predictive method=joback]
omega       0.4678;      // -   [origin=predictive method=lee-kesler]
Tb          485.74;      // K   [origin=predictive method=joback]
HvapTb      42293.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.528 1.45532 -0.0010348 2.959e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-propyl-9-azabicyclo[3.3.1]nonane" "9-azabicyclo(3.3.1)nonane, 9-propyl-" );
gibbsFormation
{
    dHf_298   -69560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=249820.0
    phase     gas;
}
