/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl pentafluorobenzoate  (C9H5F5O2, CAS 4522-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylPentafluorobenzoate;
formula     C9H5F5O2;
CAS         4522-93-4;
InChIKey    DFUDMSIRGGTHGI-UHFFFAOYSA-N;
MW          240.127;      // g/mol [origin=calculated method=formula-sum]
Tc          683.00;      // K   [origin=predictive method=joback]
Pc          23.888;      // bar [origin=predictive method=joback]
omega       0.7856;      // -   [origin=predictive method=lee-kesler]
Tb          511.67;      // K   [origin=predictive method=joback]
HvapTb      44536.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (88.161 0.48662 -0.0001492 -3.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group AC; count 1; } { group ACF; count 5; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dC_ring; count 6; } { group F; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,3,4,5,6-pentakis(fluoranyl)benzoate" "ethyl 2,3,4,5,6-pentafluorobenzoate" "ethyl perfluorobenzoate" "pentafluorobenzoic acid ethyl ester" "benzoic acid, pentafluoro-, ethyl ester" "ethyl pentafluorobenzoate 98%" "perfluorobenzoic acid ethyl ester" "m419" "2,3,4,5,6-pentafluoro-benzoic acid ethyl ester" "benzoic acid,2,3,4,5,6-pentafluoro-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -1347740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1195260.0
}
