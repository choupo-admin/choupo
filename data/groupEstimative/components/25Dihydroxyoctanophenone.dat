/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2',5'-dihydroxyoctanophenone  (C14H20O3, CAS 4693-19-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dihydroxyoctanophenone;
formula     C14H20O3;
CAS         4693-19-0;
InChIKey    UVAFQENBAUNGJG-UHFFFAOYSA-N;
MW          236.311;      // g/mol [origin=calculated method=formula-sum]
Tc          981.33;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       1.2249;      // -   [origin=predictive method=lee-kesler]
Tb          761.71;      // K   [origin=predictive method=joback]
HvapTb      81808.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.224 1.53612 -0.00126302 4.3806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,5-bis(oxidanyl)phenyl]octan-1-one" "1-(2,5-dihydroxyphenyl)octan-1-one" "1-octanone, 1-(2,5-dihydroxyphenyl)-" );
standardThermochemistry
{
    dHf_298   -562960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     674.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-258750.0
}
