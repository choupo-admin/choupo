/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethyl-2-butene  (C6H12, CAS 563-79-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethyl2Butene;
formula     C6H12;
CAS         563-79-1;
InChIKey    WGLLSSPDPJPLOR-UHFFFAOYSA-N;
MW          84.162;      // g/mol [origin=calculated method=formula-sum]
Tc          520.59;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.2246;      // -   [origin=predictive method=lee-kesler]
Tb          340.80;      // K   [origin=predictive method=joback]
HvapTb      29068.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.13 0.59368 -0.000391 1.112e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethylbut-2-ene" "tetramethylethylene" "2-butene, 2,3-dimethyl-" "1,1,2,2-tetramethylethylene" "2,3-dimethylbutene-2" "2-butene,3-dimethyl-" "1,2,2-tetramethylethylene" "2,3-dimethyl-2-butene solution" );
gibbsFormation
{
    dHf_298   -69530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62760.0
    phase     gas;
}
