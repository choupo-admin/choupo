/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-menthyl phenylacetate  (C18H26O2, CAS 1154-92-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1MenthylPhenylacetate;
formula     C18H26O2;
CAS         1154-92-3;
InChIKey    GIFKSWTZIAVRIG-UHFFFAOYSA-N;
MW          274.404;      // g/mol [origin=calculated method=formula-sum]
Tc          927.11;      // K   [origin=predictive method=joback]
Pc          16.484;      // bar [origin=predictive method=joback]
omega       0.6883;      // -   [origin=predictive method=lee-kesler]
Tb          706.11;      // K   [origin=predictive method=joback]
HvapTb      64768.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.379 1.65516 -0.0008654 1.241e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 4; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5-methyl-2-propan-2-yl-cyclohexyl) 2-phenylethanoate" "l-menthyl phenylacetate" "(-)-menthyl phenylacetate" "2-isopropyl-5-methylcyclohexyl phenylacetate" "phenylacetic acid,(-)-menthyl ester" "menthol phenylacetate, (1r,3r,4s)-(-)-" "(1r-(1alpha,2beta,5alpha))-p-menthyl phenylacetate" "benzeneacetic acid, (1r,2s,5r)-5-methyl-2-(1-methylethyl)cyclohexyl ester" "benzeneacetic acid, 5-methyl-2-(1-methylethyl)cyclohexyl ester, (1r-(1-alpha,2-beta,5-alpha))-" "benzeneacetic acid, 5-methyl-2-(1-methylethyl)cyclohexyl ester, (1theta-(1alpha,2beta,5alpha))-" "(5-methyl-2-propan-2-ylcyclohexyl) 2-phenylacetate" "phenylacetic acid, (-)-menthyl ester" );
gibbsFormation
{
    dHf_298   -487240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     677.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90690.0
    phase     gas;
}
