/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxy-4'-butoxy-trans-stilbene  (C19H22O2, CAS 35135-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxy4ButoxyTransStilbene;
formula     C19H22O2;
CAS         35135-42-3;
InChIKey    RKTLNHBAULXRBR-UHFFFAOYSA-N;
MW          282.383;      // g/mol [origin=calculated method=formula-sum]
Tc          969.15;      // K   [origin=predictive method=joback]
Pc          17.477;      // bar [origin=predictive method=joback]
omega       0.8190;      // -   [origin=predictive method=lee-kesler]
Tb          746.64;      // K   [origin=predictive method=joback]
HvapTb      68542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.777 1.42564 -0.00079992 1.539e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butoxy-4-[2-(4-methoxyphenyl)ethenyl]benzene" );
standardThermochemistry
{
    dHf_298   -132590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     686.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184880.0
}
