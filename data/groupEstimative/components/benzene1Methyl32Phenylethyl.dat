/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene,1-methyl-3-(2-phenylethyl)-  (C15H16, CAS 34403-06-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1Methyl32Phenylethyl;
formula     C15H16;
CAS         34403-06-0;
InChIKey    ZWRSMFOUGMXCNP-UHFFFAOYSA-N;
MW          196.293;      // g/mol [origin=calculated method=formula-sum]
Tc          836.92;      // K   [origin=predictive method=joback]
Pc          24.727;      // bar [origin=predictive method=joback]
omega       0.5234;      // -   [origin=predictive method=lee-kesler]
Tb          601.14;      // K   [origin=predictive method=joback]
HvapTb      54198.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.258 1.21152 -0.00078756 1.934e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group ACCH3; count 1; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3-(2-phenylethyl)benzene" "1-methyl-3-phenethylbenzene" "benzene, 1-methyl-3-(2-phenylethyl)-" );
gibbsFormation
{
    dHf_298   108660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=290610.0
    phase     gas;
}
