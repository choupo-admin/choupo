/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-diisopropylaniline  (C12H19N, CAS 24544-04-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Diisopropylaniline;
formula     C12H19N;
CAS         24544-04-5;
InChIKey    WKBALTUBRZPIPZ-UHFFFAOYSA-N;
MW          177.291;      // g/mol [origin=calculated method=formula-sum]
Tc          802.38;      // K   [origin=predictive method=joback]
Pc          25.100;      // bar [origin=predictive method=joback]
omega       0.5940;      // -   [origin=predictive method=lee-kesler]
Tb          582.45;      // K   [origin=predictive method=joback]
HvapTb      55771.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.2 1.01968 -0.00057592 1.173e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 3; } { group ACCH; count 2; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-di(propan-2-yl)aniline" "aniline, 2,6-diisopropyl-" "benzenamine, 2,6-bis(1-methylethyl)-" "2,6-diisopropyl aniline" "2,6-dilsopropylaniline" "2,6-diisopropylphenylamine" "2,6-bis(1-methylethyl)aniline" "2,6-bis(methylethyl)phenylamine" "aniline,2,6-diisopropyl- (6ci,8ci);2,6-bis(1-methylethyl)aniline;2,6-bis(1-methylethyl)benzenamine;2,6-diisopropylphenylamine;n-(2,6-diisopropylphenyl)amine;" );
standardThermochemistry
{
    dHf_298   -54190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=204880.0
}
