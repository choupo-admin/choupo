/*--------------------------------*- Choupo -*-----------------------*\
  Component: coumarin 338  (C20H23NO4, CAS 62669-75-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coumarin338;
formula     C20H23NO4;
CAS         62669-75-4;
InChIKey    XSHJSSYQUYNTBG-UHFFFAOYSA-N;
MW          341.407;      // g/mol [origin=calculated method=formula-sum]
Tc          1090.65;      // K   [origin=predictive method=joback]
Pc          18.031;      // bar [origin=predictive method=joback]
omega       1.1074;      // -   [origin=predictive method=lee-kesler]
Tb          863.55;      // K   [origin=predictive method=joback]
HvapTb      82047.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.69 2.15336 -0.00171588 5.395e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 1; } { group AC; count 3; } { group ACCH2; count 2; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 6; } { group dCH_ring; count 2; } { group dC_ring; count 6; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h,5h,11h-(1)benzopyrano(6,7,8-ij)quinolizine-10-carboxylicacid, 2,3,6,7-tetrahydro-11-oxo-, 1,1-dimethylethyl ester" "1h,5h,11h-(1)benzopyrano(6,7,8-ij)quinolizine-10-carboxylic acid, 2,3,6,7-tetrahydro-11-oxo-, 1,1-dimethylethyl ester" "1h,5h,11h-[1]benzopyrano[6,7,8-ij]quinolizine-10-carboxylic acid, 2,3,6,7-tetrahydro-11-oxo-, 1,1-dimethylethyl ester" "coumarin338;tert-butyl 11-oxo-2,3,6,7-tetrahydro-1h,5h,11h-pyrano[2,3-f]pyrido[3,2,1-ij]quinoline-10-carboxylate;1h,5h,11h-(1)benzopyrano(6,7,8-ij)quinolizine-10-carboxylic acid, 2,3,6,7-tetrahydro-11-oxo-, 1,1-dimethylethyl ester;" "tert-butyl 11-oxo-2,3,6,7-tetrahydro-1h,5h,11h-pyrano[2,3-f]pyrido[3,2,1-ij]quinoline-10-carboxylate" "tert-butyl 2,3,6,7-tetrahydro-11-oxo-7h,5h,11h-(1)benzopyrano(6,7,8-ij)quinolizine-10-carboxylate" "tert-butyl 4-oxo-3-oxa-13-azatetracyclo[7.7.1.0^{2,7}.0^{13,17}]heptadeca-1,5,7,9(17)-tetraene-5-carboxylate" );
standardThermochemistry
{
    dHf_298   -509370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     676.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77900.0
}
