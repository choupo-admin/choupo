/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-propanediol, polymer with 1,3-diisocyanatomethylbenzene and 1,1'-methylenebis(isocyanatobenzene)  (C27H28N4O6, CAS 153965-58-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12PropanediolPolymerWith13DiisocyanatomethylbenzeneAnd11Meth;
formula     C27H28N4O6;
CAS         153965-58-3;
InChIKey    SFLOTUHSTCCKGZ-UHFFFAOYSA-N;
MW          504.543;      // g/mol [origin=calculated method=formula-sum]
Tc          1657.70;      // K   [origin=predictive method=joback]
Pc          15.343;      // bar [origin=predictive method=joback]
omega       1.2546;      // -   [origin=predictive method=lee-kesler]
Tb          1343.62;      // K   [origin=predictive method=joback]
HvapTb      150706.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group C; count 2; } { group CH=CH; count 4; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:4
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCd; count 4; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 11; } { group dC_ring; count 3; } { group OH; count 2; } { group dO_oth; count 4; } { group Nd; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diisocyanato-2-methyl-benzene;5-isocyanato-5-[(1-isocyanatocyclohexa-2,4-dien-1-yl)methyl]cyclohexa-1,3-diene;propane-1,2-diol" );
