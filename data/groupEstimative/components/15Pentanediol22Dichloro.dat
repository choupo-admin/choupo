/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-pentanediol,2,2-dichloro-  (C5H10Cl2O2, CAS 141942-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Pentanediol22Dichloro;
formula     C5H10Cl2O2;
CAS         141942-66-7;
InChIKey    AAQBILGCTDLJJQ-UHFFFAOYSA-N;
MW          173.033;      // g/mol [origin=calculated method=formula-sum]
Tc          746.60;      // K   [origin=predictive method=joback]
Pc          40.621;      // bar [origin=predictive method=joback]
omega       1.2797;      // -   [origin=predictive method=lee-kesler]
Tb          569.99;      // K   [origin=predictive method=joback]
HvapTb      67556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.234 0.6862 -0.0005216 1.578e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 2; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group C; count 1; } { group Cl; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)pentane-1,5-diol" "2,2-dichloro-1,5-pentanediol" "2,2-dichloropentane-1,5-diol" );
gibbsFormation
{
    dHf_298   -491220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-303440.0
    phase     gas;
}
