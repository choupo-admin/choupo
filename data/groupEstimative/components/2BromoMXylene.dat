/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-m-xylene  (C8H9Br, CAS 576-22-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromoMXylene;
formula     C8H9Br;
CAS         576-22-7;
InChIKey    MYMYVYZLMUEVED-UHFFFAOYSA-N;
MW          185.064;      // g/mol [origin=calculated method=formula-sum]
Tc          716.72;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.4111;      // -   [origin=predictive method=lee-kesler]
Tb          485.44;      // K   [origin=predictive method=joback]
HvapTb      43437.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.5 0.60414 -0.00037992 9.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-1,3-dimethyl-benzene" "2,6-dimethylbromobenzene" "2-bromo-1,3-dimethylbenzene" "1-bromo-2,6-dimethylbenzene" "2,6-dimethyl bromobenzene" "benzene, 2-bromo-1,3-dimethyl-" "m-xylene, 2-bromo-" "2,6-dimethylphenyl bromide" "benzene, bromo-1,3-dimethyl-" "tpc-i104" "576-22-7 2,6-dimethylbromobenzene" "2007-6-22 2,6-dimethylbromobenzene" );
gibbsFormation
{
    dHf_298   31470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=123950.0
    phase     gas;
}
