/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-benz(f)indene  (C13H10, CAS 268-40-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1hBenzFIndene;
formula     C13H10;
CAS         268-40-6;
InChIKey    LJVOKUMRGBIJGP-UHFFFAOYSA-N;
MW          166.223;      // g/mol [origin=calculated method=formula-sum]
Tc          810.97;      // K   [origin=predictive method=joback]
Pc          33.763;      // bar [origin=predictive method=joback]
omega       0.4815;      // -   [origin=predictive method=lee-kesler]
Tb          563.23;      // K   [origin=predictive method=joback]
HvapTb      50286.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.08 1.1586 -0.00098012 3.32e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h-cyclopenta[b]naphthalene" "1h-benz[f]indene" "1-beta-naphthindene" );
standardThermochemistry
{
    dHf_298   243930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=356800.0
}
