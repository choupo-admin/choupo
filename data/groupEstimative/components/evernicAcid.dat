/*--------------------------------*- Choupo -*-----------------------*\
  Component: evernic acid  (C17H16O7, CAS 537-09-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        evernicAcid;
formula     C17H16O7;
CAS         537-09-7;
InChIKey    GODLCSLPZIBRMG-UHFFFAOYSA-N;
MW          332.308;      // g/mol [origin=calculated method=formula-sum]
Tc          1300.80;      // K   [origin=predictive method=joback]
Pc          28.505;      // bar [origin=predictive method=joback]
omega       1.7176;      // -   [origin=predictive method=lee-kesler]
Tb          1049.23;      // K   [origin=predictive method=joback]
HvapTb      113645.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.49 1.46506 -0.00107496 3.248e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 4; } { group ACCH3; count 2; } { group ACOH; count 2; } { group CH3O; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } { group O; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-methoxy-2-methyl-6-oxidanyl-phenyl)carbonyloxy-2-methyl-6-oxidanyl-benzoic acid" "lecanoric acid methyl ether" "4-((4-methoxy-6-methylsalicyloyl)oxy)-6-methylsalicylic acid" "2,6-cresotic acid, 4-methoxy-, 4-ester with 6-methyl-beta-resorcylate" "2-hydroxy-4-[2-hydroxy-4-methoxy-6-methylbenzoyloxy]-6-methylbenzoic acid" "evernic acid, pruiss" "2-hydroxy-4-(2-hydroxy-4-methoxy-6-methylbenzoyloxy)-6-methylbenzoic acid" "benzoic acid, 2-hydroxy-4-((2-hydroxy-4-methoxy-6-methylbenzoyl)oxy)-6-methyl-" "benzoic acid, 2-hydroxy-4-[(2-hydroxy-4-methoxy-6-methylbenzoyl)oxy]-6-methyl-" "2, 4-methoxy-, 4-ester with 6-methyl-.beta.-resorcylate" "2,6-cresotic acid, 4-methoxy-, 4-ester with 6-methyl-beta-resorcylic acid" "2-hydroxy-4-(2-hydroxy-4-methoxy-6-methylbenzoyl)oxy-6-methylbenzoic acid" );
gibbsFormation
{
    dHf_298   -1121420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     749.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-789960.0
    phase     gas;
}
