/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1,2,2-pentafluoropropane  (C3H3F5, CAS 1814-88-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11122Pentafluoropropane;
formula     C3H3F5;
CAS         1814-88-6;
InChIKey    FDOPVENYMZRARC-UHFFFAOYSA-N;
MW          134.047;      // g/mol [origin=calculated method=formula-sum]
Tc          392.77;      // K   [origin=predictive method=joback]
Pc          34.889;      // bar [origin=predictive method=joback]
omega       0.2542;      // -   [origin=predictive method=lee-kesler]
Tb          258.13;      // K   [origin=predictive method=joback]
HvapTb      15595.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.33 0.59942 -0.000565 1.963e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CF3; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 2; } { group F; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,2,2-pentakis(fluoranyl)propane" "propane, pentafluoro-" "propane, 1,1,1,2,2-pentafluoro-" );
gibbsFormation
{
    dHf_298   -1103300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     353.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-993990.0
    phase     gas;
}
