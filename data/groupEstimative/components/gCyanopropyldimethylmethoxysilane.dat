/*--------------------------------*- Choupo -*-----------------------*\
  Component: g-cyanopropyldimethylmethoxysilane  (C7H15NOSi, CAS 143203-47-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H15NOSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        gCyanopropyldimethylmethoxysilane;
formula     C7H15NOSi;
CAS         143203-47-8;
InChIKey    XMFCIYUZZWZEHI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          157.288;      // g/mol [origin=calculated method=formula-sum]
Tc          678.06;      // K   [origin=predictive method=joback]
Pc          23.749;      // bar [origin=predictive method=joback]
omega       0.4881;      // -   [origin=predictive method=lee-kesler]
Tb          485.66;      // K   [origin=predictive method=joback]
HvapTb      44358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (79.843 0.33426 0.0001998 -2.062e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH3O; count 1; } { group CH2CN; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[methoxy(dimethyl)silyl]butanenitrile" "butanenitrile,4-(methoxydimethylsilyl)-" "(3-cyanopropyl)dimethylmethoxysilane" "4-(methoxydimethylsilyl)butanenitrile" "4-[methoxy(dimethyl)silyl]butanenitrile;(3-cyanopropyl)dimethylmethoxyilane;" );
standardThermochemistry
{
    dHf_298   -266770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68520.0
}
