/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-butoxy-2,6-dimethyloct-2-ene  (C14H28O, CAS 71077-30-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Butoxy26Dimethyloct2Ene;
formula     C14H28O;
CAS         71077-30-0;
InChIKey    ZEBHRRNMSFKVIM-UHFFFAOYSA-N;
MW          212.377;      // g/mol [origin=calculated method=formula-sum]
Tc          717.29;      // K   [origin=predictive method=joback]
Pc          15.822;      // bar [origin=predictive method=joback]
omega       0.6574;      // -   [origin=predictive method=lee-kesler]
Tb          545.94;      // K   [origin=predictive method=joback]
HvapTb      48818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.107 1.29648 -0.0007161 1.493e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 1; } { group CH=C; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-butoxy-2,6-dimethyl-oct-2-ene" "2-octene, 8-butoxy-2,6-dimethyl-" "citronellyl butyl ether" "2-octene,8-butoxy-2,6-dimethyl-" "3,7-dimethyl-6-octenylbutyl ether" );
gibbsFormation
{
    dHf_298   -362360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     692.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31230.0
    phase     gas;
}
