/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexadecaoctaene  (C16H16, CAS 3332-38-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexadecaoctaene;
formula     C16H16;
CAS         3332-38-5;
InChIKey    RDEIDWDSOWVJQA-BHRJBCITSA-N;
MW          208.304;      // g/mol [origin=calculated method=formula-sum]
Tc          902.63;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       0.3569;      // -   [origin=predictive method=lee-kesler]
Tb          625.88;      // K   [origin=predictive method=joback]
HvapTb      56004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.17 1.1284 -0.00041724 -4.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 16; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[16]annulene" "(16)annulene" "1,3,5,7,9,11,13,15-cyclohexadecaoctaene" );
gibbsFormation
{
    dHf_298   101730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     691.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=234680.0
    phase     gas;
}
