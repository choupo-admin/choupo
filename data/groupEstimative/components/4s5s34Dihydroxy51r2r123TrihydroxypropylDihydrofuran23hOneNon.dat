/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4s,5s)-3,4-dihydroxy-5-[(1r,2r)-1,2,3-trihydroxypropyl]dihydrofuran-2(3h)-one(non-preferred name)  (C7H12O7, CAS 60046-25-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4s5s34Dihydroxy51r2r123TrihydroxypropylDihydrofuran23hOneNon;
formula     C7H12O7;
CAS         60046-25-5;
InChIKey    VIVCRCODGMFTFY-JPRIQSOUSA-N;
MW          208.166;      // g/mol [origin=calculated method=formula-sum]
Tc          1072.52;      // K   [origin=predictive method=joback]
Pc          55.278;      // bar [origin=predictive method=joback]
omega       2.5096;      // -   [origin=predictive method=lee-kesler]
Tb          875.40;      // K   [origin=predictive method=joback]
HvapTb      120497.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.661 0.8937 -0.0005302 1.059e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 5; } { group OH; count 5; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 2; } { group CH_ring; count 3; } { group OH; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4s,5s)-3,4-bis(oxidanyl)-5-[(1r,2r)-1,2,3-tris(oxidanyl)propyl]oxolan-2-one" "(2.xi)-d-gluco-heptono-gamma-lactone" "(4s,5s)-3,4-dihydroxy-5-[(1r,2r)-1,2,3-trihydroxypropyl]oxolan-2-one" );
gibbsFormation
{
    dHf_298   -1244680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-945960.0
    phase     gas;
}
