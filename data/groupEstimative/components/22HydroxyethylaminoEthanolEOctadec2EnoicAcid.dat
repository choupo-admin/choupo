/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-hydroxyethylamino)ethanol;(e)-octadec-2-enoic acid  (C22H45NO4, CAS 68444-28-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22HydroxyethylaminoEthanolEOctadec2EnoicAcid;
formula     C22H45NO4;
CAS         68444-28-0;
InChIKey    KGVPAGDDAAYBGA-CMBBICFISA-N;
MW          387.605;      // g/mol [origin=calculated method=formula-sum]
Tc          1372.77;      // K   [origin=predictive method=joback]
Pc          10.541;      // bar [origin=predictive method=joback]
omega       0.7104;      // -   [origin=predictive method=lee-kesler]
Tb          1088.56;      // K   [origin=predictive method=joback]
HvapTb      121776.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.498 2.10262 -0.001024 1.389e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CH=CH; count 1; } { group OH; count 2; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group dCH; count 2; } { group OH; count 2; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecenoic acid compd. with 2,2'-iminobis[ethanol] (1:1)" "octadecenoic acid, compound with 2,2'-iminodiethanol (1:1)" "2-(2-hydroxyethylamino)ethanol; (e)-octadec-2-enoic acid" "octadecenoic acid, compd. with 2,2'-iminobis(ethanol) (1:1)" );
gibbsFormation
{
    dHf_298   -1093070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1309.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-418340.0
    phase     gas;
}
