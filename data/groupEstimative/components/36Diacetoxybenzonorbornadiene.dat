/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3',6'-diacetoxybenzonorbornadiene  (C15H14O4, CAS 7213-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Diacetoxybenzonorbornadiene;
formula     C15H14O4;
CAS         7213-65-2;
InChIKey    GHNDBDFQIQQOER-UHFFFAOYSA-N;
MW          258.273;      // g/mol [origin=calculated method=formula-sum]
Tc          930.52;      // K   [origin=predictive method=joback]
Pc          22.871;      // bar [origin=predictive method=joback]
omega       0.9004;      // -   [origin=predictive method=lee-kesler]
Tb          709.23;      // K   [origin=predictive method=joback]
HvapTb      68006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.52 1.31724 -0.00090716 2.366e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH; count 2; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-acetyloxytricyclo[6.2.1.0<2,7>]undeca-2(7),3,5,9-tetraen-3-yl acetate" );
standardThermochemistry
{
    dHf_298   -575830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-298240.0
}
