/*--------------------------------*- Choupo -*-----------------------*\
  Component: triallyl(methyl)silane  (C10H18Si, CAS 1112-91-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H18Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        triallylMethylSilane;
formula     C10H18Si;
CAS         1112-91-0;
InChIKey    JFCCVNTYPIUJDJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          166.339;      // g/mol [origin=calculated method=formula-sum]
Tc          598.22;      // K   [origin=predictive method=joback]
Pc          21.197;      // bar [origin=predictive method=joback]
omega       0.3325;      // -   [origin=predictive method=lee-kesler]
Tb          419.84;      // K   [origin=predictive method=joback]
HvapTb      36138.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.643 0.68762 -0.0001741 -5.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 3; } { group dCH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl-tris(prop-2-enyl)silane" "triallylmethylsilane" "methyltriallylsilane" "silane,methyltri-2-propen-1-yl-" "silane,methyltri-2-propenyl- (9ci); silane, triallylmethyl- (6ci,7ci,8ci);triallylmethylsilane" );
gibbsFormation
{
    dHf_298   14940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     658.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192080.0
    phase     gas;
}
