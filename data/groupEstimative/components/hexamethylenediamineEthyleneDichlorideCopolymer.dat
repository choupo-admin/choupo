/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexamethylenediamine, ethylene dichloride copolymer  (C8H20Cl2N2, CAS 56927-54-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexamethylenediamineEthyleneDichlorideCopolymer;
formula     C8H20Cl2N2;
CAS         56927-54-9;
InChIKey    PLMCTRXWPXUOBK-UHFFFAOYSA-N;
MW          215.162;      // g/mol [origin=calculated method=formula-sum]
Tc          807.09;      // K   [origin=predictive method=joback]
Pc          24.171;      // bar [origin=predictive method=joback]
omega       0.7838;      // -   [origin=predictive method=lee-kesler]
Tb          603.96;      // K   [origin=predictive method=joback]
HvapTb      63748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (75.198 0.695 -0.0001242 -9.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2NH2; count 2; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group Cl; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)ethane;hexane-1,6-diamine" "1,6-hexanediamine, polymer with 1,2-dichloroethane" "1,2-dichloroethane; hexane-1,6-diamine" );
gibbsFormation
{
    dHf_298   -283970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     745.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20760.0
    phase     gas;
}
