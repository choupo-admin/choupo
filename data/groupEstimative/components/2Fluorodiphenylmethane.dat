/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluorodiphenylmethane  (C13H11F, CAS 3794-15-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Fluorodiphenylmethane;
formula     C13H11F;
CAS         3794-15-8;
InChIKey    YWWVDXKZLGXVHT-UHFFFAOYSA-N;
MW          186.229;      // g/mol [origin=calculated method=formula-sum]
Tc          787.81;      // K   [origin=predictive method=joback]
Pc          28.781;      // bar [origin=predictive method=joback]
omega       0.4833;      // -   [origin=predictive method=lee-kesler]
Tb          554.65;      // K   [origin=predictive method=joback]
HvapTb      48929.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.349 1.0333 -0.00069516 1.752e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-2-(phenylmethyl)benzene" "1-benzyl-2-fluorobenzene" "2-fluoro-1-benzylbenzene" "agn-pc-0dbf7w" "1-fluoro-2-(phenylmethyl)benzene" "1-(cyclohexatrienylmethyl)-2-fluorobenzene" );
gibbsFormation
{
    dHf_298   -46170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78960.0
    phase     gas;
}
