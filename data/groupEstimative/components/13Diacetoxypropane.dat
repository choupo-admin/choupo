/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diacetoxypropane  (C7H12O4, CAS 628-66-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diacetoxypropane;
formula     C7H12O4;
CAS         628-66-0;
InChIKey    DSVGICPKBRQDDX-UHFFFAOYSA-N;
MW          160.169;      // g/mol [origin=calculated method=formula-sum]
Tc          655.96;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       0.6550;      // -   [origin=predictive method=lee-kesler]
Tb          476.20;      // K   [origin=predictive method=joback]
HvapTb      45990.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.343 0.55924 -0.0001678 -4.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-acetyloxypropyl ethanoate" "trimethylene acetate" "1,3-propanediol, diacetate" "3-acetyloxypropyl acetate" "1,3-propylene diacetate" "1,3-propylene glycol diacetate" "1,3-propanediol,1,3-diacetate" );
standardThermochemistry
{
    dHf_298   -822370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-612680.0
}
