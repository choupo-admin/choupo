/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-trimethylenebis(1-methylpiperidine)  (C15H30N2, CAS 64168-11-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Trimethylenebis1Methylpiperidine;
formula     C15H30N2;
CAS         64168-11-2;
InChIKey    JWOTWWORMYMZCR-UHFFFAOYSA-N;
MW          238.419;      // g/mol [origin=calculated method=formula-sum]
Tc          798.17;      // K   [origin=predictive method=joback]
Pc          18.871;      // bar [origin=predictive method=joback]
omega       0.6520;      // -   [origin=predictive method=lee-kesler]
Tb          598.24;      // K   [origin=predictive method=joback]
HvapTb      53584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-153.097 1.94004 -0.0012722 3.211e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 2; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-[3-(1-methylpiperidin-4-yl)propyl]piperidine" "piperidine, 4,4'-(1,3-propanediyl)bis[1-methyl-" "4,4'-propane-1,3-diylbis(1-methylpiperidine)" "piperidine, 4,4'-(1,3-propanediyl)bis(1-methyl-" "jwotwwormymzcr-uhfffaoysa-" "t778" "4,4'-(propane-1,3-diyl)bis(1-methylpiperidine)" "piperidine,4,4'-(1,3-propanediyl)bis[1-methyl-" "4,4''4,4''4,4''4,4''-trimethylenebis(1-methylpiperidine)" "4,4 inverted exclamation marka-trimethylenebis(1-methylpiperidine)" "4,4 inverted exclamation marka-(1,3-propanediyl)bis[1-methyl-piperidine]" );
standardThermochemistry
{
    dHf_298   -96910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     671.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=370080.0
}
