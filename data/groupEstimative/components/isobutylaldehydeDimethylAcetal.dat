/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutylaldehyde dimethyl acetal  (C6H14O2, CAS 41632-89-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutylaldehydeDimethylAcetal;
formula     C6H14O2;
CAS         41632-89-7;
InChIKey    YINGOXPFQFTXIX-UHFFFAOYSA-N;
MW          118.176;      // g/mol [origin=calculated method=formula-sum]
Tc          554.01;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.3891;      // -   [origin=predictive method=lee-kesler]
Tb          380.84;      // K   [origin=predictive method=joback]
HvapTb      32994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.07 0.45928 -8.7e-05 -5.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethoxy-2-methyl-propane" "propane, 1,1-dimethoxy-2-methyl-" "1,1-dimethoxy-2-methylpropane" );
gibbsFormation
{
    dHf_298   -442170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-215240.0
    phase     gas;
}
