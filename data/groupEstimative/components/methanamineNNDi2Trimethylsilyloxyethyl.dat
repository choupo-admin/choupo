/*--------------------------------*- Choupo -*-----------------------*\
  Component: methanamine, n,n-di(2-trimethylsilyloxyethyl)-  (C11H29NO2Si2, CAS 76710-52-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H29NO2Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methanamineNNDi2Trimethylsilyloxyethyl;
formula     C11H29NO2Si2;
CAS         76710-52-6;
InChIKey    FAJPYHFAPOGNPE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          263.528;      // g/mol [origin=calculated method=formula-sum]
Tc          681.45;      // K   [origin=predictive method=joback]
Pc          15.379;      // bar [origin=predictive method=joback]
omega       0.5405;      // -   [origin=predictive method=lee-kesler]
Tb          511.36;      // K   [origin=predictive method=joback]
HvapTb      47531.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (114.834 0.63404 0.0003644 -3.869e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH2O; count 2; } { group CH3N; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 4; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-2-trimethylsilyloxy-n-(2-trimethylsilyloxyethyl)ethanamine" "methanamine, n,n-bis-[2-(trimethylsiloxy)ethyl]-" );
gibbsFormation
{
    dHf_298   -690520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     876.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-267000.0
    phase     gas;
}
