/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl butyl phthalate  (C19H20O4, CAS 85-68-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylButylPhthalate;
formula     C19H20O4;
CAS         85-68-7;
InChIKey    IRIAEXORFWYRCZ-UHFFFAOYSA-N;
MW          312.365;      // g/mol [origin=calculated method=formula-sum]
Tc          1031.43;      // K   [origin=predictive method=joback]
Pc          17.580;      // bar [origin=predictive method=joback]
omega       0.9907;      // -   [origin=predictive method=lee-kesler]
Tb          809.10;      // K   [origin=predictive method=joback]
HvapTb      77916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.076 1.48192 -0.00081596 1.268e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-butyl o2-(phenylmethyl) benzene-1,2-dicarboxylate" "butyl benzyl phthalate" "sicol" "palatinol bb" "unimoll bb" "butylbenzyl phthalate" "n-butyl benzyl phthalate" "benzyl n-butyl phthalate" "1,2-benzenedicarboxylic acid, butyl phenylmethyl ester" "butylbenzylphthalate" "benzyl butylphthalate" "phthalic acid benzyl butyl ester" );
standardThermochemistry
{
    dHf_298   -608460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     779.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-296450.0
}
