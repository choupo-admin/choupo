/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethoxydimethylsilane  (C4H12O2Si, CAS 1112-39-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H12O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dimethoxydimethylsilane;
formula     C4H12O2Si;
CAS         1112-39-6;
InChIKey    JJQZDUKDJDQPMQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          120.223;      // g/mol [origin=calculated method=formula-sum]
Tc          509.03;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.2601;      // -   [origin=predictive method=lee-kesler]
Tb          337.36;      // K   [origin=predictive method=joback]
HvapTb      29612.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (91.07 0.05128 0.000443 -2.904e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH3O; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethoxy(dimethyl)silane" "dimethyldimethoxysilane" "silane, dimethoxydimethyl-" "kbm 22" "dimethoxy-dimethylsilane" "dimethyl dimethoxysilane" "jjqzdukdjdqpmq-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -501950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-331960.0
    phase     gas;
}
