/*--------------------------------*- Choupo -*-----------------------*\
  Component: 13,14-dihydroxydocosanoic acid  (C22H44O4, CAS 616-01-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1314DihydroxydocosanoicAcid;
formula     C22H44O4;
CAS         616-01-3;
InChIKey    KXWWULNBUIUDOT-UHFFFAOYSA-N;
MW          372.59;      // g/mol [origin=calculated method=formula-sum]
Tc          1290.89;      // K   [origin=predictive method=joback]
Pc          10.814;      // bar [origin=predictive method=joback]
omega       0.8060;      // -   [origin=predictive method=lee-kesler]
Tb          1031.95;      // K   [origin=predictive method=joback]
HvapTb      114312.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.292 2.22442 -0.0013128 2.972e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CH; count 2; } { group OH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group CH; count 2; } { group OH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "13,14-bis(oxidanyl)docosanoic acid" "docosanoic acid, 13,14-dihydroxy-" "13,14-dihydroxy-docosanoic acid" );
standardThermochemistry
{
    dHf_298   -1162700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1148.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-488070.0
}
