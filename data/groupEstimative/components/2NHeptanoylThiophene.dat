/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(n-heptanoyl)thiophene  (C11H16OS, CAS 30711-40-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2NHeptanoylThiophene;
formula     C11H16OS;
CAS         30711-40-1;
InChIKey    BDNFJEMAAFFMFH-UHFFFAOYSA-N;
MW          196.308;      // g/mol [origin=calculated method=formula-sum]
Tc          789.66;      // K   [origin=predictive method=joback]
Pc          26.380;      // bar [origin=predictive method=joback]
omega       0.6529;      // -   [origin=predictive method=lee-kesler]
Tb          576.23;      // K   [origin=predictive method=joback]
HvapTb      54450.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.495 1.02193 -0.00066492 1.7066e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2CO; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group CdO; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-thiophen-2-ylheptan-1-one" "1-(2-thienyl)-1-heptanone" "1-heptanone, 1-(2-thienyl)-" "2-heptanoylthiophene" "1-(2-thienyl)heptan-1-one" "1-thiophen-2-yl-1-heptanone" "1-heptanone,1-(2-thienyl)-" );
standardThermochemistry
{
    dHf_298   -152780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47230.0
}
