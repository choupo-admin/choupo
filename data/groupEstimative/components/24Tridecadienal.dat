/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-tridecadienal  (C13H22O, CAS 60998-24-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Tridecadienal;
formula     C13H22O;
CAS         60998-24-5;
InChIKey    CMKUXOGSJXLFFZ-UHFFFAOYSA-N;
MW          194.318;      // g/mol [origin=calculated method=formula-sum]
Tc          732.84;      // K   [origin=predictive method=joback]
Pc          19.102;      // bar [origin=predictive method=joback]
omega       0.7226;      // -   [origin=predictive method=lee-kesler]
Tb          554.02;      // K   [origin=predictive method=joback]
HvapTb      51168.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.893 1.25332 -0.000844 2.362e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH=CH; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH; count 4; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trideca-2,4-dienal" "2,4-tridecadien-1-al" "2,4-tridecadienal, (2e,4z)-" "trideca-2,4-dienal;2,4-tridecadienal" );
standardThermochemistry
{
    dHf_298   -162790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     667.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=119500.0
}
