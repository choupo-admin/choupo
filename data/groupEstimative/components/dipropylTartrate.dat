/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipropyl tartrate  (C10H18O6, CAS 2217-14-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipropylTartrate;
formula     C10H18O6;
CAS         2217-14-3;
InChIKey    WCHBXSPACACNBJ-UHFFFAOYSA-N;
MW          234.248;      // g/mol [origin=calculated method=formula-sum]
Tc          903.06;      // K   [origin=predictive method=joback]
Pc          25.820;      // bar [origin=predictive method=joback]
omega       1.6320;      // -   [origin=predictive method=lee-kesler]
Tb          728.32;      // K   [origin=predictive method=joback]
HvapTb      85250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.834 0.92404 -0.0003982 1.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipropyl 2,3-bis(oxidanyl)butanedioate" "dipropyl 2,3-dihydroxybutanedioate" "dipropyl 2,3-dihydroxybutanedioate (r-(r*,r*))-" "butanedioic acid, 2,3-dihydroxy-, dipropyl ester, (r-(r*,r*))-" );
gibbsFormation
{
    dHf_298   -1199310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     730.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-865940.0
    phase     gas;
}
