/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-00holg  (C8H12N2O, CAS 105786-40-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc00holg;
formula     C8H12N2O;
CAS         105786-40-1;
InChIKey    SCQSHSJVMGGQKR-UHFFFAOYSA-N;
MW          152.197;      // g/mol [origin=calculated method=formula-sum]
Tc          825.17;      // K   [origin=predictive method=joback]
Pc          41.409;      // bar [origin=predictive method=joback]
omega       0.7322;      // -   [origin=predictive method=lee-kesler]
Tb          589.14;      // K   [origin=predictive method=joback]
HvapTb      61102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.99 1.0428 -0.00074998 2.1346e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 3; } { group CH=CH; count 1; } { group CHNH2; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group CdO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azanylbicyclo[2.2.1]hept-5-ene-2-carboxamide" "(1s,2r,3s,4r)-3-aminobicyclo[2.2.1]hept-5-ene-2-carboxamide" );
standardThermochemistry
{
    dHf_298   -96910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     314.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=144400.0
}
