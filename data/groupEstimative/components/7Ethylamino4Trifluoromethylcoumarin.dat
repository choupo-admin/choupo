/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-ethylamino-4-trifluoromethylcoumarin  (C12H10F3NO2, CAS 52840-38-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Ethylamino4Trifluoromethylcoumarin;
formula     C12H10F3NO2;
CAS         52840-38-7;
InChIKey    GZTMNDOZYLMFQE-UHFFFAOYSA-N;
MW          257.211;      // g/mol [origin=calculated method=formula-sum]
Tc          824.29;      // K   [origin=predictive method=joback]
Pc          24.801;      // bar [origin=predictive method=joback]
omega       0.9066;      // -   [origin=predictive method=lee-kesler]
Tb          625.05;      // K   [origin=predictive method=joback]
HvapTb      57006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.309 1.20002 -0.00094336 2.861e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH2NH; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group F; count 3; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(ethylamino)-4-(trifluoromethyl)chromen-2-one" "7-(ethylamino)-4-trifluoromethylcoumarin" "7-(ethylamino)-4-(trifluoromethyl)-2h-1-benzopyran-2-one" "2h-1-benzopyran-2-one, 7-(ethylamino)-4-(trifluoromethyl)-" "7-(ethylamino)-4-(trifluoromethyl)-2-benzopyrone" "7-(ethylamino)-4-(trifluoromethyl)-2h-chromen-2-one" "7-(ethylamino)-4-(trifluoromethyl)-1-benzopyran-2-one" "2h-1-benzopyran-2-one,7-(ethylamino)-4-(trifluoromethyl)-" );
standardThermochemistry
{
    dHf_298   -792700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-558370.0
}
