/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 2-hydroxyethyl maleate  (C10H16O5, CAS 26469-34-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl2HydroxyethylMaleate;
formula     C10H16O5;
CAS         26469-34-1;
InChIKey    PUDIPIBJWKQFNR-UHFFFAOYSA-N;
MW          216.233;      // g/mol [origin=calculated method=formula-sum]
Tc          816.59;      // K   [origin=predictive method=joback]
Pc          24.411;      // bar [origin=predictive method=joback]
omega       1.2404;      // -   [origin=predictive method=lee-kesler]
Tb          641.18;      // K   [origin=predictive method=joback]
HvapTb      69305.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.725 0.89822 -0.0004452 5.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=CH; count 1; } { group OH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH; count 2; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-butyl o4-(2-hydroxyethyl) but-2-enedioate" "2-butenedioic acid (2e)-, butyl 2-hydroxyethyl ester" "2-butenedioic acid (2e)-, 1-butyl 4-(2-hydroxyethyl) ester" "2-butenedioic acid(2z)-, butyl 2-hydroxyethyl ester (9ci)" "2-butenedioicacid (z)-, butyl 2-hydroxyethyl ester; maleic acid, butyl 2-hydroxyethyl ester(8ci); butyl hydroxyethyl maleate" );
gibbsFormation
{
    dHf_298   -919300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     692.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-644020.0
    phase     gas;
}
