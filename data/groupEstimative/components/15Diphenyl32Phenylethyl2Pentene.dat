/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-diphenyl-3-(2-phenylethyl)-2-pentene  (C25H26, CAS 55334-57-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Diphenyl32Phenylethyl2Pentene;
formula     C25H26;
CAS         55334-57-1;
InChIKey    LEPFYNPJKPSWHQ-UHFFFAOYSA-N;
MW          326.483;      // g/mol [origin=calculated method=formula-sum]
Tc          1100.13;      // K   [origin=predictive method=joback]
Pc          15.164;      // bar [origin=predictive method=joback]
omega       0.8054;      // -   [origin=predictive method=lee-kesler]
Tb          855.68;      // K   [origin=predictive method=joback]
HvapTb      78110.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.425 2.162 -0.0015159 4.12e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=C; count 1; } { group ACH; count 15; } { group ACCH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[5-phenyl-3-(2-phenylethyl)pent-2-enyl]benzene" "benzene, 1,1'-[3-(2-phenylethylidene)-1,5-pentanediyl]bis-" "(3-phenethyl-5-phenylpent-2-enyl)benzene" "[5-phenyl-3-(2-phenylethyl)pent-2-en-1-yl]benzene" "benzene,1'-[3-(2-phenylethylidene)-1,5-pentanediyl]bis-" );
standardThermochemistry
{
    dHf_298   257690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     799.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=568520.0
}
