/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylhexadecane  (C17H36, CAS 6418-43-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylhexadecane;
formula     C17H36;
CAS         6418-43-5;
InChIKey    WWPCLIMUTNKTDY-UHFFFAOYSA-N;
MW          240.475;      // g/mol [origin=calculated method=formula-sum]
Tc          749.11;      // K   [origin=predictive method=joback]
Pc          12.381;      // bar [origin=predictive method=joback]
omega       0.7427;      // -   [origin=predictive method=lee-kesler]
Tb          588.12;      // K   [origin=predictive method=joback]
HvapTb      53048.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.247 1.62476 -0.0009042 1.906e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 13; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 13; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecane, 3-methyl-" "14-methylhexadecane;3-methylhexadecane; anteisoheptadecane" );
gibbsFormation
{
    dHf_298   -399490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     808.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89820.0
    phase     gas;
}
