/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-heptylcyclopentane  (C12H24, CAS 5617-42-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nHeptylcyclopentane;
formula     C12H24;
CAS         5617-42-5;
InChIKey    BOFNAOHMSHEKQL-UHFFFAOYSA-N;
MW          168.324;      // g/mol [origin=calculated method=formula-sum]
Tc          674.98;      // K   [origin=predictive method=joback]
Pc          20.850;      // bar [origin=predictive method=joback]
omega       0.4940;      // -   [origin=predictive method=lee-kesler]
Tb          489.44;      // K   [origin=predictive method=joback]
HvapTb      42563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.504 1.27552 -0.0007564 1.711e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH2_ring; count 4; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptylcyclopentane" "cyclopentane, heptyl-" );
gibbsFormation
{
    dHf_298   -230530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86710.0
    phase     gas;
}
