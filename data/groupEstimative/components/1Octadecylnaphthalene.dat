/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octadecylnaphthalene  (C28H44, CAS 56388-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octadecylnaphthalene;
formula     C28H44;
CAS         56388-48-8;
InChIKey    DKTSRTYLZGWAIT-UHFFFAOYSA-N;
MW          380.66;      // g/mol [origin=calculated method=formula-sum]
Tc          1093.62;      // K   [origin=predictive method=joback]
Pc          8.937;      // bar [origin=predictive method=joback]
omega       0.8369;      // -   [origin=predictive method=lee-kesler]
Tb          890.88;      // K   [origin=predictive method=joback]
HvapTb      82500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.613 2.52172 -0.00160028 4.037e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene, octadecyl-" "1-octadecyl-naphthalene" "naphthalene, 1-octadecyl-" "octadecane, 1-(1-naphthyl)-" "octadecane,1-(naphthyl)- (6ci); octadecylnaphthalene" );
gibbsFormation
{
    dHf_298   -205120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1025.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=394310.0
    phase     gas;
}
