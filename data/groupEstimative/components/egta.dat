/*--------------------------------*- Choupo -*-----------------------*\
  Component: egta  (C14H24N2O10, CAS 67-42-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        egta;
formula     C14H24N2O10;
CAS         67-42-5;
InChIKey    DEFVIWRASFVYLL-UHFFFAOYSA-N;
MW          380.35;      // g/mol [origin=calculated method=formula-sum]
Tc          1448.93;      // K   [origin=predictive method=joback]
Pc          19.859;      // bar [origin=predictive method=joback]
omega       1.4465;      // -   [origin=predictive method=lee-kesler]
Tb          1171.68;      // K   [origin=predictive method=joback]
HvapTb      124320.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.18 1.6584 -0.0010314 2.326e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2O; count 2; } { group CH2N; count 2; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group O; count 2; } { group COOH; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-[bis(2-hydroxy-2-oxoethyl)amino]ethoxy]ethoxy]ethyl-(2-hydroxy-2-oxoethyl)amino]ethanoic acid" "egtazic acid" "gedta" "ethylenebis(oxyethylenenitrilo)tetraacetic acid" "ebonta" "ethylene glycol tetraacetic acid" "6,9-dioxa-3,12-diazatetradecanedioic acid, 3,12-bis(carboxymethyl)-" "ethylene glycol bis(2-aminoethyl ether)tetraacetic acid" "ethylene glycol bis(2-aminoethyl ether)-n,n,n',n'-tetraacetic acid" "acide egtazique [inn-french]" "acidum egtazicum [inn-latin]" "glycoletherdiaminetetraacetic acid" );
standardThermochemistry
{
    dHf_298   -1862750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     968.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1297080.0
}
