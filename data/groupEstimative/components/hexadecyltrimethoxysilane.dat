/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexadecyltrimethoxysilane  (C19H42O3Si, CAS 16415-12-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C19H42O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        hexadecyltrimethoxysilane;
formula     C19H42O3Si;
CAS         16415-12-6;
InChIKey    RSKGMYDENCAJEN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          346.627;      // g/mol [origin=calculated method=formula-sum]
Tc          869.70;      // K   [origin=predictive method=joback]
Pc          9.687;      // bar [origin=predictive method=joback]
omega       0.8256;      // -   [origin=predictive method=lee-kesler]
Tb          702.98;      // K   [origin=predictive method=joback]
HvapTb      65412.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (102.935 1.41308 -0.000262 -1.667e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH3O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 15; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecyl(trimethoxy)silane" "trimethoxyhexadecylsilane" "silane, hexadecyltrimethoxy-" );
standardThermochemistry
{
    dHf_298   -943770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1056.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-310660.0
}
