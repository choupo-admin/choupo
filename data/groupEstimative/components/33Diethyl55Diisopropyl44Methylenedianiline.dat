/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3'-diethyl-5,5'-diisopropyl-4,4'-methylenedianiline  (C23H34N2, CAS 75790-86-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Diethyl55Diisopropyl44Methylenedianiline;
formula     C23H34N2;
CAS         75790-86-2;
InChIKey    DDTOOQIKICNNHB-UHFFFAOYSA-N;
MW          338.539;      // g/mol [origin=calculated method=formula-sum]
Tc          1185.46;      // K   [origin=predictive method=joback]
Pc          13.477;      // bar [origin=predictive method=joback]
omega       1.0482;      // -   [origin=predictive method=lee-kesler]
Tb          953.26;      // K   [origin=predictive method=joback]
HvapTb      95822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.583 1.80972 -0.00098076 1.851e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 3; } { group ACCH; count 2; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(4-azanyl-2-ethyl-6-propan-2-yl-phenyl)methyl]-3-ethyl-5-propan-2-yl-aniline" "benzenamine, 4,4'-methylenebis(3-ethyl-5-(1-methylethyl)-" "benzenamine, 4,4'-methylenebis[3-ethyl-5-(1-methylethyl)-" "4-[(4-amino-2-ethyl-6-propan-2-ylphenyl)methyl]-3-ethyl-5-propan-2-ylaniline" );
standardThermochemistry
{
    dHf_298   -56790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     886.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=437840.0
}
