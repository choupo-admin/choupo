/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-2-amino-1-benzyloxybutane  (C11H17NO, CAS 142559-11-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r2Amino1Benzyloxybutane;
formula     C11H17NO;
CAS         142559-11-3;
InChIKey    DFQWOAPAERBEID-LLVKDONJSA-N;
MW          179.263;      // g/mol [origin=calculated method=formula-sum]
Tc          786.94;      // K   [origin=predictive method=joback]
Pc          27.847;      // bar [origin=predictive method=joback]
omega       0.6604;      // -   [origin=predictive method=lee-kesler]
Tb          572.47;      // K   [origin=predictive method=joback]
HvapTb      55019.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.707 0.97452 -0.0005414 1.009e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-1-phenylmethoxybutan-2-amine" "(2r)-1-(phenylmethoxy)but-2-ylamine" "2-butanamine,1-(phenylmethoxy)-, (2r)-" "(r)-1-(benzyloxy)butan-2-amine" "(2r)-1-(benzyl-oxy)butan-2-amine" "2-butanamine,1-(phenylmethoxy)-, (r)-;((r)-1-((phenylmethoxy)methyl)propyl)amine;(r)-o-benzyl-2-amino-1-butanol;" );
gibbsFormation
{
    dHf_298   -137550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113160.0
    phase     gas;
}
