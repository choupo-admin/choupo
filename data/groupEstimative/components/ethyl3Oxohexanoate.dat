/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-oxohexanoate  (C8H14O3, CAS 3249-68-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Oxohexanoate;
formula     C8H14O3;
CAS         3249-68-1;
InChIKey    KQWWVLVLVYYYDT-UHFFFAOYSA-N;
MW          158.197;      // g/mol [origin=calculated method=formula-sum]
Tc          676.61;      // K   [origin=predictive method=joback]
Pc          27.183;      // bar [origin=predictive method=joback]
omega       0.6819;      // -   [origin=predictive method=lee-kesler]
Tb          494.73;      // K   [origin=predictive method=joback]
HvapTb      47555.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.384 0.68104 -0.0002981 1.786e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-oxidanylidenehexanoate" "ethyl butyrylacetate" "ethyl butyroacetate" "hexanoic acid, 3-oxo-, ethyl ester" "ethyl .alpha.-butyrylacetate" "ethyl beta-ketohexanoate" "ethyl alpha-butyrylacetate" "ethyl-3-oxohexanoate" "erhyl butyrylacetate" "ethyl 3-oxocaproate" "ethyl butanoylacetate" "ethyl 3-ketohexanoate" );
gibbsFormation
{
    dHf_298   -638310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-422810.0
    phase     gas;
}
