/*--------------------------------*- Choupo -*-----------------------*\
  Component: brodifacoum  (C31H23BrO3, CAS 56073-10-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brodifacoum;
formula     C31H23BrO3;
CAS         56073-10-0;
InChIKey    VEUZZDOCACZPRY-UHFFFAOYSA-N;
MW          523.426;      // g/mol [origin=calculated method=formula-sum]
Tc          1552.03;      // K   [origin=predictive method=joback]
Pc          16.991;      // bar [origin=predictive method=joback]
omega       1.3452;      // -   [origin=predictive method=lee-kesler]
Tb          1258.14;      // K   [origin=predictive method=joback]
HvapTb      123988.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-157.44 2.7195 -0.00211304 6.481e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 16; } { group AC; count 5; } { group ACCH2; count 1; } { group ACCH; count 2; } { group OH; count 1; } { group Br; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 16; } { group dC_ring; count 10; } { group Br; count 1; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[3-[4-(4-bromophenyl)phenyl]-1,2,3,4-tetrahydronaphthalen-1-yl]-4-oxidanyl-chromen-2-one" "bromfenacoum" "klerat" "talon" "volid" "super warfarin" "talon rodenticide" "brodifacoum [ansi:bsi:iso]" "coumarin, 3-(3-(4'-bromo-1,1'-biphenyl-4-yl)-1,2,3,4-tetrahydro-1-naphthyl)-4-hydroxy-" "bfc" "3-(3-(4'-bromo-(1,1'-biphenyl)-4-yl)-1,2,3,4-tetrahydro-1-napthalenyl)-4-hydroxycoumarin" "3-(3-(4'-bromo-1,1'-biphenyl-4-yl)-1,2,3,4-tetrahydro-1-naphthyl)-4-hydroxycoumarin" );
gibbsFormation
{
    dHf_298   -59280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     817.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=312420.0
    phase     gas;
}
