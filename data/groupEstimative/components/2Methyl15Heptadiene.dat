/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1,5-heptadiene  (C8H14, CAS 41044-63-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl15Heptadiene;
formula     C8H14;
CAS         41044-63-7;
InChIKey    LXKRFDPUBWVICN-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          562.44;      // K   [origin=predictive method=joback]
Pc          28.084;      // bar [origin=predictive method=joback]
omega       0.3191;      // -   [origin=predictive method=lee-kesler]
Tb          383.36;      // K   [origin=predictive method=joback]
HvapTb      32770.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.248 0.76374 -0.0005204 1.506e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylhepta-1,5-diene" "1,5-heptadiene, 2-methyl-, (z)-" "(5e)-2-methylhepta-1,5-diene" "1,5-heptadiene, 2-methyl-" );
standardThermochemistry
{
    dHf_298   24410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175990.0
}
