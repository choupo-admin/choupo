/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisphenol a dimethacrylate  (C23H24O4, CAS 3253-39-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisphenolADimethacrylate;
formula     C23H24O4;
CAS         3253-39-2;
InChIKey    QUZSUMLPWDHKCJ-UHFFFAOYSA-N;
MW          364.441;      // g/mol [origin=calculated method=formula-sum]
Tc          1129.29;      // K   [origin=predictive method=joback]
Pc          14.017;      // bar [origin=predictive method=joback]
omega       0.9300;      // -   [origin=predictive method=lee-kesler]
Tb          895.49;      // K   [origin=predictive method=joback]
HvapTb      85006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.25 1.88808 -0.00118872 2.598e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CH2=C; count 2; } { group ACH; count 8; } { group AC; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH2; count 2; } { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[2-[4-(2-methylprop-2-enoyloxy)phenyl]propan-2-yl]phenyl] 2-methylprop-2-enoate" "2,2-di(4-methacryloxyphenyl)propane" "4,4'-isopropylidenediphenol dimethacrylate" "4,4'-isopropylidenediphenyl dimethacrylate" "2-propenoic acid, 2-methyl-, (1-methylethylidene)di-4,1-phenylene ester" "2,2-propanediyldi-4,1-phenylene bis(2-methylacrylate)" "bis-dma" "2-propenoic acid, 2-methyl-, 1,1'-((1-methylethylidene)di-4,1-phenylene) ester" "2-propenoic acid, 2-methyl-, 1,1'-[(1-methylethylidene)di-4,1-phenylene] ester" "4-{1-methyl-1-[4-(2-methylprop-2-enoyloxy)phenyl]ethyl}phenyl 2-methylprop-2-e noate" "bisphenol-a-dimethacrylate (bisdma)" "2-propenoic acid,2-methyl-, 1,1'-[(1-methylethylidene)di-4,1-phenylene] ester" );
standardThermochemistry
{
    dHf_298   -479960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     872.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-110980.0
}
