/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-tert-butyl-3-isopropylphenol  (C13H20O, CAS 4151-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6TertButyl3Isopropylphenol;
formula     C13H20O;
CAS         4151-60-4;
InChIKey    DBULNVCXEGKRIX-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          831.53;      // K   [origin=predictive method=joback]
Pc          25.663;      // bar [origin=predictive method=joback]
omega       0.6266;      // -   [origin=predictive method=lee-kesler]
Tb          605.65;      // K   [origin=predictive method=joback]
HvapTb      58800.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.61 1.3868 -0.00107892 3.486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tert-butyl-5-propan-2-yl-phenol" "phenol, 2-(1,1-dimethylethyl)-5-(1-methylethyl)-" "2-tert-butyl-5-propan-2-ylphenol" "2-tert-butyl-5-isopropylphenol" "2-tert-butyl-5-(propan-2-yl)phenol" );
gibbsFormation
{
    dHf_298   -277930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=7140.0
    phase     gas;
}
