/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 5-methylsalicylate  (C9H10O3, CAS 22717-57-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl5Methylsalicylate;
formula     C9H10O3;
CAS         22717-57-3;
InChIKey    JQYUQKRFSSSGJM-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          802.51;      // K   [origin=predictive method=joback]
Pc          38.483;      // bar [origin=predictive method=joback]
omega       0.7323;      // -   [origin=predictive method=lee-kesler]
Tb          576.02;      // K   [origin=predictive method=joback]
HvapTb      58987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.41 0.82024 -0.00059172 1.725e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 5-methyl-2-oxidanyl-benzoate" "methyl 2-hydroxy-5-methylbenzoate" "benzoic acid, 2-hydroxy-5-methyl-, methyl ester" "2,5-cresotic acid, methyl ester" "p-cresotic acid methyl ester" "2-hydroxy-5-methylbenzoic acid methyl ester" "5-methylsalicylic acid methyl ester" "6-hydroxy-m-toluic acid methyl ester" "methyl-5-methylsalicylate" "methyl 5-methyl salicylate" "methyl-5-methyl salicylate" "methyl 6-hydroxy-m-toluate" );
gibbsFormation
{
    dHf_298   -498620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-337310.0
    phase     gas;
}
