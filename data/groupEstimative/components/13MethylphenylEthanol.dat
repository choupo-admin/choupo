/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(3-methylphenyl)ethanol  (C9H12O, CAS 25675-28-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13MethylphenylEthanol;
formula     C9H12O;
CAS         25675-28-9;
InChIKey    SPNHUMWMKXWVIU-UHFFFAOYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          729.18;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       0.7713;      // -   [origin=predictive method=lee-kesler]
Tb          528.92;      // K   [origin=predictive method=joback]
HvapTb      54857.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.29 0.76034 -0.00046356 1.058e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "m-tolyl methylcarbinol" "1-(3-methylphenyl)ethan-1-ol" "m-tolylmethylcarbinol" "alpha-3-dimethylbenzyl alcohol" "ambap25675-28-9" );
standardThermochemistry
{
    dHf_298   -161540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11580.0
}
