/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl bicyclo(2.2.1)-2,5-heptadiene-2,3-dicarboxylate  (C11H12O4, CAS 947-57-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylBicyclo22125Heptadiene23Dicarboxylate;
formula     C11H12O4;
CAS         947-57-9;
InChIKey    WFKWXJMEUOLYOS-UHFFFAOYSA-N;
MW          208.213;      // g/mol [origin=calculated method=formula-sum]
Tc          803.31;      // K   [origin=predictive method=joback]
Pc          26.653;      // bar [origin=predictive method=joback]
omega       0.7468;      // -   [origin=predictive method=lee-kesler]
Tb          593.75;      // K   [origin=predictive method=joback]
HvapTb      56800.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.74 1.00044 -0.00061988 1.328e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group CH=CH; count 1; } { group C=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl bicyclo[2.2.1]hepta-2,5-diene-2,3-dicarboxylate" "dimethyl bicyclo[2.2.1]-2,5-heptadiene-2,3-dicarboxylate" "bicyclo[2.2.1]hepta-2,5-diene-2,3-dicarboxylic acid, dimethyl ester" "2,3-dimethyl bicyclo[2.2.1]hepta-2,5-diene-2,3-dicarboxylate" "bicyclo[2.2.1]hepta-2,5-diene-5,6-dicarboxylic acid dimethyl ester" "bicyclo[2.2.1]hepta-2,5-diene-2,3-dicarboxylic acid dimethyl ester" );
standardThermochemistry
{
    dHf_298   -672870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-428940.0
}
