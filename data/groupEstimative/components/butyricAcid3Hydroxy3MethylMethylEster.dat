/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyric acid, 3-hydroxy-3-methyl-, methyl ester  (C6H12O3, CAS 6149-45-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyricAcid3Hydroxy3MethylMethylEster;
formula     C6H12O3;
CAS         6149-45-7;
InChIKey    JNURPEZKOSMRMZ-UHFFFAOYSA-N;
MW          132.159;      // g/mol [origin=calculated method=formula-sum]
Tc          661.90;      // K   [origin=predictive method=joback]
Pc          35.515;      // bar [origin=predictive method=joback]
omega       0.8224;      // -   [origin=predictive method=lee-kesler]
Tb          484.05;      // K   [origin=predictive method=joback]
HvapTb      51740.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.661 0.67886 -0.0004102 8.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-methyl-3-oxidanyl-butanoate" "butanoic acid, 3-hydroxy-3-methyl-, methyl ester" "methyl 3-hydroxy-3-methylbutanoate" "3-hydroxy-3-methylbutanoic acid methyl ester" "3-hydroxy-3-methyl-butyric acid methyl ester" );
gibbsFormation
{
    dHf_298   -645430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-444710.0
    phase     gas;
}
