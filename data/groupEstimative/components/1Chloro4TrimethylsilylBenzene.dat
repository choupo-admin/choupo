/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-4-(trimethylsilyl)benzene  (C9H13ClSi, CAS 10557-71-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H13ClSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Chloro4TrimethylsilylBenzene;
formula     C9H13ClSi;
CAS         10557-71-8;
InChIKey    LCQUSGXMZKOTPG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          184.738;      // g/mol [origin=calculated method=formula-sum]
Tc          698.82;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       0.3016;      // -   [origin=predictive method=lee-kesler]
Tb          476.01;      // K   [origin=predictive method=joback]
HvapTb      43245.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.81 0.52106 -3.556e-05 -1.117e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-chlorophenyl)-trimethyl-silane" "silane, (4-chlorophenyl)trimethyl-" "benzene, 1-chloro-4-(trimethylsilyl)-" "p-chlorophenyltrimethylsilane" "4-chlorophenyltrimethylsilane" "(p-chlorophenyl)trmethylsilane" "(4-chlorophenyl)-trimethylsilane" "(4-chlorophenyl)(trimethyl)silane" "silane,(4-chlorophenyl)trimethyl- (9ci);silane, (p-chlorophenyl)trimethyl-(6ci,7ci,8ci);(4-chlorophenyl)trimethylsilane;(p-chlorophenyl)trimethylsilane;trimethyl-p-chlorophenylsilane;p-(trimethylsilyl)chlorobenzene;" );
gibbsFormation
{
    dHf_298   -131390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10990.0
    phase     gas;
}
