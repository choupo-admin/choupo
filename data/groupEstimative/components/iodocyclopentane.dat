/*--------------------------------*- Choupo -*-----------------------*\
  Component: iodocyclopentane  (C5H9I, CAS 1556-18-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iodocyclopentane;
formula     C5H9I;
CAS         1556-18-9;
InChIKey    PCEBAZIVZVIQEO-UHFFFAOYSA-N;
MW          196.027;      // g/mol [origin=calculated method=formula-sum]
Tc          662.67;      // K   [origin=predictive method=joback]
Pc          42.166;      // bar [origin=predictive method=joback]
omega       0.2095;      // -   [origin=predictive method=lee-kesler]
Tb          422.42;      // K   [origin=predictive method=joback]
HvapTb      36354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.45 0.6495 -0.000457 1.277e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "iodanylcyclopentane" "cyclopentyl iodide" "cyclopentane, iodo-" );
gibbsFormation
{
    dHf_298   -9180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85890.0
    phase     gas;
}
