/*--------------------------------*- Choupo -*-----------------------*\
  Component: tripentyl orthoformate  (C16H34O3, CAS 637-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tripentylOrthoformate;
formula     C16H34O3;
CAS         637-42-3;
InChIKey    NRRGKWUTVHJHCS-UHFFFAOYSA-N;
MW          274.445;      // g/mol [origin=calculated method=formula-sum]
Tc          795.28;      // K   [origin=predictive method=joback]
Pc          12.782;      // bar [origin=predictive method=joback]
omega       0.8881;      // -   [origin=predictive method=lee-kesler]
Tb          632.50;      // K   [origin=predictive method=joback]
HvapTb      58052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.162 1.34016 -0.0005168 1.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(dipentoxymethoxy)pentane" "pentane, 1,1',1''-(methylidynetris(oxy))tris-" "pentane, 1,1',1''-[methylidynetris(oxy)]tris-" "tri-n-amyl orthoformate" "pentane,1,1',1''-[methylidynetris(oxy)]tris-" "orthoformicacid, tripentyl ester (8ci); triamyl orthoformate; tripentyl orthoformate;tris(pentyloxy)methane" );
standardThermochemistry
{
    dHf_298   -775510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     803.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-233600.0
}
