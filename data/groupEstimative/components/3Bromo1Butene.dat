/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-1-butene  (C4H7Br, CAS 22037-73-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo1Butene;
formula     C4H7Br;
CAS         22037-73-6;
InChIKey    XOTGLEGIDHZTIM-UHFFFAOYSA-N;
MW          135.004;      // g/mol [origin=calculated method=formula-sum]
Tc          548.10;      // K   [origin=predictive method=joback]
Pc          45.469;      // bar [origin=predictive method=joback]
omega       0.2735;      // -   [origin=predictive method=lee-kesler]
Tb          353.52;      // K   [origin=predictive method=joback]
HvapTb      29875.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.77 0.40792 -0.0002913 8.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylbut-1-ene" "3-bromobut-1-ene" "1-butene, 3-bromo-" "1-butene, 3-bromo-(6ci,7ci,8ci,9ci)" "1-methallylbromide; 1-methylallyl bromide; 3-bromo-1-butene; a-methallyl bromide" );
standardThermochemistry
{
    dHf_298   20590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82520.0
}
