/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1',1''-methanetriyltricyclopentane  (C16H28, CAS 3752-92-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Methanetriyltricyclopentane;
formula     C16H28;
CAS         3752-92-9;
InChIKey    NOTANCVPTDLROZ-UHFFFAOYSA-N;
MW          220.4;      // g/mol [origin=calculated method=formula-sum]
Tc          847.53;      // K   [origin=predictive method=joback]
Pc          20.549;      // bar [origin=predictive method=joback]
omega       0.4547;      // -   [origin=predictive method=lee-kesler]
Tb          611.08;      // K   [origin=predictive method=joback]
HvapTb      51593.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-194.79 1.9248 -0.001232 2.972e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group CH2_ring; count 12; } { group CH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dicyclopentylmethylcyclopentane" );
gibbsFormation
{
    dHf_298   -197410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     618.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191050.0
    phase     gas;
}
