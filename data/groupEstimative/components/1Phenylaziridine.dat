/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylaziridine  (C8H9N, CAS 696-18-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenylaziridine;
formula     C8H9N;
CAS         696-18-4;
InChIKey    YKNKBBMRKMLLJS-UHFFFAOYSA-N;
MW          119.167;      // g/mol [origin=calculated method=formula-sum]
Tc          645.47;      // K   [origin=predictive method=joback]
Pc          43.340;      // bar [origin=predictive method=joback]
omega       0.3731;      // -   [origin=predictive method=lee-kesler]
Tb          428.90;      // K   [origin=predictive method=joback]
HvapTb      37771.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.04 0.9958 -0.0008772 3.043e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-phenylaziridine" "aziridine, 1-phenyl-" "n-phenylethylenimine" "aziridine, 1-phenyl- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   194910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     309.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=320230.0
}
