/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylcyclohexylamine  (C7H15N, CAS 2523-55-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylcyclohexylamine;
formula     C7H15N;
CAS         2523-55-9;
InChIKey    KSMVBYPXNKCPAJ-UHFFFAOYSA-N;
MW          113.204;      // g/mol [origin=calculated method=formula-sum]
Tc          664.80;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.3599;      // -   [origin=predictive method=lee-kesler]
Tb          447.17;      // K   [origin=predictive method=joback]
HvapTb      41937.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.65 0.82632 -0.000426 6.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylcyclohexan-1-amine" "trans-4-methylcyclohexylamine" "4-methylcyclohexanamine" "cyclohexanamine, 4-methyl-" "trans-4-methyl-cyclohexylamine" "4-methylcyclohexyl amine" "cis-4-methylcyclohexylamine" "4-methylcyclohexanamin" "p-methylcyclohexylamine" "4-methyl-cyclohexylamine" "cyclohexylamine, 4-methyl-" "trans-4-methylcyclohexyl amine" );
standardThermochemistry
{
    dHf_298   -120040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91250.0
}
