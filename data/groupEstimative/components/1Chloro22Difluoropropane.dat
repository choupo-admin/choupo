/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-2,2-difluoropropane  (C3H5ClF2, CAS 420-99-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro22Difluoropropane;
formula     C3H5ClF2;
CAS         420-99-5;
InChIKey    OOXYGJSMTMPTFW-UHFFFAOYSA-N;
MW          114.519;      // g/mol [origin=calculated method=formula-sum]
Tc          464.03;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.2388;      // -   [origin=predictive method=lee-kesler]
Tb          300.98;      // K   [origin=predictive method=joback]
HvapTb      23727.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.761 0.44502 -0.0003644 1.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2Cl; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group F; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2,2-bis(fluoranyl)propane" "2,2-difluoropropyl chloride" "propane, 1-chloro-2,2-difluoro-" "(chloromethyl)(difluoromethyl)methane" );
gibbsFormation
{
    dHf_298   -521960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-424330.0
    phase     gas;
}
