/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl-2-(trimethylsilyl)acetylene  (C11H14Si, CAS 2170-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H14Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Phenyl2TrimethylsilylAcetylene;
formula     C11H14Si;
CAS         2170-06-1;
InChIKey    UZIXCCMXZQWTPB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          174.318;      // g/mol [origin=calculated method=formula-sum]
Tc          727.03;      // K   [origin=predictive method=joback]
Pc          27.614;      // bar [origin=predictive method=joback]
omega       0.2534;      // -   [origin=predictive method=lee-kesler]
Tb          488.36;      // K   [origin=predictive method=joback]
HvapTb      44802.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.36 0.61396 -9.886e-05 -9.302e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 5; } { group AC; count 1; } { group C_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(2-phenylethynyl)silane" "trimethyl(phenylethynyl)silane" "(trimethylsilyl)phenylacetylene" "silane, trimethyl(phenylethynyl)-" "1-phenyl-2-trimethylsilylacetylene" "phenylethynyl-trimethylsilane" "1-(trimethylsilyl)-2-phenylacetylene" "(phenylethynyl)trimethylsilane" "trimethyl-(2-phenylethynyl)silane" );
gibbsFormation
{
    dHf_298   126840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252190.0
    phase     gas;
}
