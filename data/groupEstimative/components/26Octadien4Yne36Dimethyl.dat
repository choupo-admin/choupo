/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-octadien-4-yne, 3,6-dimethyl-  (C10H14, CAS 3725-07-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Octadien4Yne36Dimethyl;
formula     C10H14;
CAS         3725-07-3;
InChIKey    XNXUVIQXKVKKGS-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          657.29;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       0.2886;      // -   [origin=predictive method=lee-kesler]
Tb          445.48;      // K   [origin=predictive method=joback]
HvapTb      40082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.39 0.84388 -0.00060026 1.8518e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH=C; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 2; } { group dC; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-dimethylocta-2,6-dien-4-yne" "agn-pc-00mhf8" );
gibbsFormation
{
    dHf_298   237430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=379460.0
    phase     gas;
}
