/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-mentha-1,5-dien-8-ol  (C10H16O, CAS 1686-20-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pMentha15Dien8Ol;
formula     C10H16O;
CAS         1686-20-0;
InChIKey    FQEXRDMYDXBXEO-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          742.21;      // K   [origin=predictive method=joback]
Pc          30.693;      // bar [origin=predictive method=joback]
omega       0.7133;      // -   [origin=predictive method=lee-kesler]
Tb          540.20;      // K   [origin=predictive method=joback]
HvapTb      54912.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.13 1.06426 -0.00071092 1.826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methylcyclohexa-2,4-dien-1-yl)propan-2-ol" "2,4-cyclohexadiene-1-methanol, .alpha.,.alpha.,4-trimethyl-" "2-(4-methyl-2,4-cyclohexadienyl)-2-propanol" );
gibbsFormation
{
    dHf_298   -252300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-25920.0
    phase     gas;
}
