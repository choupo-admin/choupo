/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentylcyclohexane  (C11H22, CAS 4292-92-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentylcyclohexane;
formula     C11H22;
CAS         4292-92-6;
InChIKey    HLTMUYBTNSVOFY-UHFFFAOYSA-N;
MW          154.297;      // g/mol [origin=calculated method=formula-sum]
Tc          665.47;      // K   [origin=predictive method=joback]
Pc          23.360;      // bar [origin=predictive method=joback]
omega       0.4151;      // -   [origin=predictive method=lee-kesler]
Tb          470.83;      // K   [origin=predictive method=joback]
HvapTb      40509.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.716 1.17092 -0.0006556 1.293e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane, pentyl-" "n-amylcyclohexane" "1-cyclohexylpentane" "cyclohexane, n-pentyl-" "amylcyclohexane" "n-pentylcyclohexane" "agn-pc-0d63tq" );
standardThermochemistry
{
    dHf_298   -216050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66190.0
}
