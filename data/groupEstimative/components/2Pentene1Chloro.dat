/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pentene, 1-chloro-  (C5H9Cl, CAS 10071-60-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Pentene1Chloro;
formula     C5H9Cl;
CAS         10071-60-0;
InChIKey    UPJCRKZUCADENN-UHFFFAOYSA-N;
MW          104.577;      // g/mol [origin=calculated method=formula-sum]
Tc          537.69;      // K   [origin=predictive method=joback]
Pc          35.305;      // bar [origin=predictive method=joback]
omega       0.2818;      // -   [origin=predictive method=lee-kesler]
Tb          355.59;      // K   [origin=predictive method=joback]
HvapTb      31067.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.948 0.50562 -0.0003524 1.047e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylpent-2-ene" "2-pentene, 1-chloro-, (z)-" );
standardThermochemistry
{
    dHf_298   -45050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=59510.0
}
