/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenedioic acid (2z)-, monomethyl ester, polymer with ethenyl acetate and methyl 2-propenoate  (C13H18O8, CAS 50886-03-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenedioicAcid2zMonomethylEsterPolymerWithEthenylAcetateAn;
formula     C13H18O8;
CAS         50886-03-8;
InChIKey    QULGSJUQFAQKHJ-BGQPXYRPSA-N;
MW          302.279;      // g/mol [origin=calculated method=formula-sum]
Tc          1026.44;      // K   [origin=predictive method=joback]
Pc          17.332;      // bar [origin=predictive method=joback]
omega       1.1430;      // -   [origin=predictive method=lee-kesler]
Tb          817.53;      // K   [origin=predictive method=joback]
HvapTb      83123.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (133.37 0.69286 0.0002278 -3.52e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 2; } { group CH=CH; count 1; } { group CH3COO; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 2; } { group dCH; count 4; } { group COOH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl ethanoate;(z)-4-methoxy-4-oxidanylidene-but-2-enoic acid;methyl prop-2-enoate" "2-butenedioic acid (2z)-, 1-methyl ester, polymer with ethenyl acetate and methyl 2-propenoate" "methyl acrylate, vinyl acetate, monomethyl maleate polymer" "ethenyl acetate; (z)-4-methoxy-4-oxobut-2-enoic acid; methyl prop-2-enoate" );
gibbsFormation
{
    dHf_298   -1468920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1068.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1170060.0
    phase     gas;
}
