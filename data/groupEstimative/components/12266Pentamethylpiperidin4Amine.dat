/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,2,6,6-pentamethylpiperidin-4-amine  (C10H22N2, CAS 40327-96-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12266Pentamethylpiperidin4Amine;
formula     C10H22N2;
CAS         40327-96-6;
InChIKey    CGXOAAMIQPDTPE-UHFFFAOYSA-N;
MW          170.3;      // g/mol [origin=calculated method=formula-sum]
Tc          734.40;      // K   [origin=predictive method=joback]
Pc          27.155;      // bar [origin=predictive method=joback]
omega       0.4854;      // -   [origin=predictive method=lee-kesler]
Tb          519.79;      // K   [origin=predictive method=joback]
HvapTb      47875.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-158.99 1.8022 -0.001758 7.353e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 2; } { group CHNH2; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-amino-1,2,2,6,6-pentamethylpiperidine" "1,2,2,6,6-pentamethyl-4-piperidylamine" "4-piperidinamine,1,2,2,6,6-pentamethyl-" "piperidine,4-amino-1,2,2,6,6-pentamethyl- (7ci);(1,2,2,6,6-pentamethylpiperidin-4-yl)amine;1,2,2,6,6-pentamethyl-4-aminopiperidine;1,2,2,6,6-pentamethyl-4-piperidinamine;4-amino-1,2,2,6,6-pentamethylpiperidine;" );
gibbsFormation
{
    dHf_298   -98130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     617.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=220700.0
    phase     gas;
}
