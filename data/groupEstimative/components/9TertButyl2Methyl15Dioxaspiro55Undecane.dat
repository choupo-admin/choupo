/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-tert-butyl-2-methyl-1,5-dioxaspiro[5.5]undecane  (C14H26O2, CAS 63449-90-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9TertButyl2Methyl15Dioxaspiro55Undecane;
formula     C14H26O2;
CAS         63449-90-1;
InChIKey    YXVMHTMPUCZZEW-UHFFFAOYSA-N;
MW          226.36;      // g/mol [origin=calculated method=formula-sum]
Tc          834.75;      // K   [origin=predictive method=joback]
Pc          21.354;      // bar [origin=predictive method=joback]
omega       0.4654;      // -   [origin=predictive method=lee-kesler]
Tb          600.99;      // K   [origin=predictive method=joback]
HvapTb      53708.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-169.81 1.97288 -0.0015674 5.288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group C; count 2; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-tert-butyl-4-methyl-1,5-dioxaspiro[5.5]undecane" "1,5-dioxaspiro(5.5)undecane, 9-(1,1-dimethylethyl)-2-methyl-" "1,5-dioxaspiro[5.5]undecane, 9-(1,1-dimethylethyl)-2-methyl-" "3-tert-butyl-10-methyl-7,11-dioxaspiro[5.5]undecane" "9-(1,1-dimethylethyl)-2-methyl-1,5-dioxaspiro(5.5)undecane" );
standardThermochemistry
{
    dHf_298   -495340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-54600.0
}
