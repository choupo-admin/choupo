/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenylpropionaldehyde  (C9H10O, CAS 93-53-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenylpropionaldehyde;
formula     C9H10O;
CAS         93-53-8;
InChIKey    IQVAERDLDAZARL-UHFFFAOYSA-N;
MW          134.178;      // g/mol [origin=calculated method=formula-sum]
Tc          698.22;      // K   [origin=predictive method=joback]
Pc          35.899;      // bar [origin=predictive method=joback]
omega       0.4602;      // -   [origin=predictive method=lee-kesler]
Tb          480.42;      // K   [origin=predictive method=joback]
HvapTb      44236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.48 0.76032 -0.0004932 1.188e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylpropanal" "hydratropaldehyde" "hydratropic aldehyde" "hyacinthal" "cumene aldehyde" "hydratropa aldehyde" "hydrotropic aldehyde" "propionaldehyde, 2-phenyl-" "benzeneacetaldehyde, .alpha.-methyl-" "alpha-phenylpropanal" "2-phenyl-1-propanal" "alpha-formylethylbenzene" );
standardThermochemistry
{
    dHf_298   -83420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35350.0
}
