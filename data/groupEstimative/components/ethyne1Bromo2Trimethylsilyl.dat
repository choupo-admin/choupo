/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyne, 1-bromo-2-trimethylsilyl-  (C5H9BrSi, CAS 18243-59-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H9BrSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethyne1Bromo2Trimethylsilyl;
formula     C5H9BrSi;
CAS         18243-59-9;
InChIKey    YRBAQEQNCDDFKM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          177.116;      // g/mol [origin=calculated method=formula-sum]
Tc          612.20;      // K   [origin=predictive method=joback]
Pc          39.605;      // bar [origin=predictive method=joback]
omega       0.1928;      // -   [origin=predictive method=lee-kesler]
Tb          390.56;      // K   [origin=predictive method=joback]
HvapTb      35605.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.91 0.16106 0.00018734 -1.5582e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group Br; count 1; } { group C_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group tC; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylethynyl(trimethyl)silane" "(bromoethynyl)(trimethyl)silane" "2-bromoethynyl(trimethyl)silane" );
standardThermochemistry
{
    dHf_298   40480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103580.0
}
