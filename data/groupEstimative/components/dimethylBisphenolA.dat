/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl-bisphenol a  (C17H20O2, CAS 1568-83-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylBisphenolA;
formula     C17H20O2;
CAS         1568-83-8;
InChIKey    OJYIBEYSBXIQOP-UHFFFAOYSA-N;
MW          256.345;      // g/mol [origin=calculated method=formula-sum]
Tc          927.58;      // K   [origin=predictive method=joback]
Pc          20.055;      // bar [origin=predictive method=joback]
omega       0.6694;      // -   [origin=predictive method=lee-kesler]
Tb          693.49;      // K   [origin=predictive method=joback]
HvapTb      62836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.25 1.34148 -0.00077912 1.546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-4-[2-(4-methoxyphenyl)propan-2-yl]benzene" "2,2-bis(4'-methoxyphenyl)propane" "4-methoxy-1-[1-(4-methoxyphenyl)-isopropyl]benzene" "benzene, 1,1'-(1-methylethylidene)bis[4-methoxy-" "propane,2,2-bis(p-methoxyphenyl)- (6ci,7ci,8ci); 2,2-bis(4-methoxyphenyl)propane;bisphenol a dimethyl ether" );
standardThermochemistry
{
    dHf_298   -217280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90660.0
}
