/*--------------------------------*- Choupo -*-----------------------*\
  Component: glucono-delta-lactone  (C6H10O6, CAS 54910-68-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gluconoDeltaLactone;
formula     C6H10O6;
CAS         54910-68-8;
InChIKey    PHOQVHQSTUBQQK-UHFFFAOYSA-N;
MW          178.14;      // g/mol [origin=calculated method=formula-sum]
Tc          937.13;      // K   [origin=predictive method=joback]
Pc          53.670;      // bar [origin=predictive method=joback]
omega       2.3760;      // -   [origin=predictive method=lee-kesler]
Tb          760.82;      // K   [origin=predictive method=joback]
HvapTb      102231.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.461 0.7168 -0.0003372 2.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group OH; count 4; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH_ring; count 4; } { group OH; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-(hydroxymethyl)-3,4,5-tris(oxidanyl)oxan-2-one" "d-gluconic acid, .delta.-lactone" "gluconic acid, .delta.-lactone, d-" "3,4,5-trihydroxy-6-(hydroxymethyl)tetrahydro-2h-pyran-2-on" "d-glucono-delta-lactone" ".delta.-gluconolactone" "d-talonic acid lactone" "an aldono-1,5-lactone" "galactonic acid, 8ci," "agn-pc-00yhty" "gluconic acid-1,5-lactone" "d -gluconic acid-d -lactone" );
gibbsFormation
{
    dHf_298   -1087750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-832490.0
    phase     gas;
}
