/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-di-tert-pentylbenzene  (C16H26, CAS 3373-10-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14DiTertPentylbenzene;
formula     C16H26;
CAS         3373-10-2;
InChIKey    KNLFZJBLNQRLEL-UHFFFAOYSA-N;
MW          218.384;      // g/mol [origin=calculated method=formula-sum]
Tc          803.47;      // K   [origin=predictive method=joback]
Pc          17.361;      // bar [origin=predictive method=joback]
omega       0.4817;      // -   [origin=predictive method=lee-kesler]
Tb          590.88;      // K   [origin=predictive method=joback]
HvapTb      51556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.208 1.63712 -0.00115436 3.236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(2-methylbutan-2-yl)benzene" "benzene, p-di-tert-pentyl-" "p-di-tert-amylbenzene" "benzene, 1,4-bis(1,1-dimethylpropyl)-" "p-di-tert-pentylbenzene" "benzene,1,4-bis(1,1-dimethylpropyl)-" "benzene,p-di-tert-pentyl- (7ci,8ci); 1,4-di-tert-pentylbenzene" );
gibbsFormation
{
    dHf_298   -166010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192300.0
    phase     gas;
}
