/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis[2-(dimethylamino)ethyl] succinate  (C12H24N2O4, CAS 19249-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2DimethylaminoEthylSuccinate;
formula     C12H24N2O4;
CAS         19249-04-8;
InChIKey    JSINVKLVDNFTSU-UHFFFAOYSA-N;
MW          260.334;      // g/mol [origin=calculated method=formula-sum]
Tc          785.63;      // K   [origin=predictive method=joback]
Pc          17.894;      // bar [origin=predictive method=joback]
omega       0.9905;      // -   [origin=predictive method=lee-kesler]
Tb          615.48;      // K   [origin=predictive method=joback]
HvapTb      61206.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.416 1.28208 -0.000665 9.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2COO; count 2; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group COO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[2-(dimethylamino)ethyl] butanedioate" "bis(2-(dimethylamino)ethyl) succinate" "bis-(beta-dimethylaminoethyl)succinate" "bis(2-dimethylaminoethyl) butanedioate" "butanedioic acid,1,4-bis[2-(dimethylamino)ethyl] ester" "butanedioicacid, bis[2-(dimethylamino)ethyl] ester (9ci); succinic acid,bis[2-(dimethylamino)ethyl] ester (6ci,8ci)" );
gibbsFormation
{
    dHf_298   -790510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     758.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-349020.0
    phase     gas;
}
