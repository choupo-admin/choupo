/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclovirobuxin d  (C26H46N2O, CAS 860-79-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclovirobuxinD;
formula     C26H46N2O;
CAS         860-79-7;
InChIKey    GMNAPBAUIVITMI-BDKDDEIASA-N;
MW          402.667;      // g/mol [origin=calculated method=formula-sum]
Tc          1245.62;      // K   [origin=predictive method=joback]
Pc          12.728;      // bar [origin=predictive method=joback]
omega       1.1075;      // -   [origin=predictive method=lee-kesler]
Tb          1010.92;      // K   [origin=predictive method=joback]
HvapTb      95414.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-506.39 4.71894 -0.0048692 2.0843e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 8; } { group CH; count 6; } { group C; count 5; } { group OH; count 1; } { group CH3NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 5; } { group OH; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bebuxine" "cyclovirobuxine d" "cyclovirobuxine" "cvb-d" "9,19-cyclopregnan-16-ol, 4,4,14-trimethyl-3,20-bis(methylamino)-, (3beta,5alpha,16alpha,20s)-" "9,19-cyclo-5-alpha,9-beta-pregnan-16-alpha-ol, 4,4,14-trimethyl-3-beta,20-alpha-bis(methylamino)-" );
gibbsFormation
{
    dHf_298   -310520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1035.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=409010.0
    phase     gas;
}
