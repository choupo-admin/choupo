/*--------------------------------*- Choupo -*-----------------------*\
  Component: cembrene a  (C20H32, CAS 31570-39-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cembreneA;
formula     C20H32;
CAS         31570-39-5;
InChIKey    VWSPQDDPRITBAM-KPGNMOGWSA-N;
MW          272.476;      // g/mol [origin=calculated method=formula-sum]
Tc          956.54;      // K   [origin=predictive method=joback]
Pc          14.535;      // bar [origin=predictive method=joback]
omega       0.5265;      // -   [origin=predictive method=lee-kesler]
Tb          719.89;      // K   [origin=predictive method=joback]
HvapTb      64191.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.31 1.58258 -0.00055992 -4.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1e,5e,9e,12r)-1,5,9-trimethyl-12-prop-1-en-2-yl-cyclotetradeca-1,5,9-triene" "neocembrene" "neocembrene-a" "1,5,9-trimethyl-12-(1-methylethenyl)-1,5,9-cyclotetradecatriene" "(1e,5e,9e,12r)-1,5,9-trimethyl-12-prop-1-en-2-ylcyclotetradeca-1,5,9-triene" "1,5,9-cyclotetradecatriene, 1,5,9-trimethyl-12-(1-methylethenyl)-, (r-(e,e,e))-" );
gibbsFormation
{
    dHf_298   -196520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     924.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185450.0
    phase     gas;
}
