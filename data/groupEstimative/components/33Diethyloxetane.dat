/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-diethyloxetane  (C7H14O, CAS 10196-39-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Diethyloxetane;
formula     C7H14O;
CAS         10196-39-1;
InChIKey    VFYHHERJNPKXIX-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          593.53;      // K   [origin=predictive method=joback]
Pc          34.643;      // bar [origin=predictive method=joback]
omega       0.3298;      // -   [origin=predictive method=lee-kesler]
Tb          397.96;      // K   [origin=predictive method=joback]
HvapTb      34620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.508 1.09904 -0.0010495 4.308e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxetane, 3,3-diethyl-" "oxetane, 3,3-diethyl" "3,3-diethyl-oxetane" "agn-pc-0cmok3" );
gibbsFormation
{
    dHf_298   -237930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34900.0
    phase     gas;
}
