/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-1-(2,4,6-trimethoxy-3,5-dimethylphenyl)butan-1-one  (C16H24O4, CAS 3567-96-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl1246Trimethoxy35DimethylphenylButan1One;
formula     C16H24O4;
CAS         3567-96-2;
InChIKey    PYUCCSKQLHUKCA-UHFFFAOYSA-N;
MW          280.364;      // g/mol [origin=calculated method=formula-sum]
Tc          938.36;      // K   [origin=predictive method=joback]
Pc          16.285;      // bar [origin=predictive method=joback]
omega       0.9599;      // -   [origin=predictive method=lee-kesler]
Tb          737.95;      // K   [origin=predictive method=joback]
HvapTb      70384.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (108.111 0.93584 -0.0001941 -9.374e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group AC; count 4; } { group ACCH3; count 2; } { group CH2CO; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 1; } { group CH; count 1; } { group dC_ring; count 6; } { group O; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-1-(2,4,6-trimethoxy-3,5-dimethyl-phenyl)butan-1-one" "torquatone" );
standardThermochemistry
{
    dHf_298   -708910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     692.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-298260.0
}
