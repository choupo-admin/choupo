/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethoxy-5-prop-1-enylphenol  (C11H14O2, CAS 94-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethoxy5Prop1Enylphenol;
formula     C11H14O2;
CAS         94-86-0;
InChIKey    RADIRXJQODWKGQ-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          812.84;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.7142;      // -   [origin=predictive method=lee-kesler]
Tb          590.14;      // K   [origin=predictive method=joback]
HvapTb      58400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.319 1.02184 -0.00076792 2.46e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxy-5-prop-1-enyl-phenol" "trans-2-ethoxy-5-(1-propenyl)phenol" "phenol, 2-ethoxy-5-(1-propen-1-yl)-" );
gibbsFormation
{
    dHf_298   -237620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34880.0
    phase     gas;
}
