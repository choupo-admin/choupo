/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(diisopropylamino)ethyl methacrylate  (C12H23NO2, CAS 16715-83-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DiisopropylaminoEthylMethacrylate;
formula     C12H23NO2;
CAS         16715-83-6;
InChIKey    SVYHMICYJHWXIN-UHFFFAOYSA-N;
MW          213.321;      // g/mol [origin=calculated method=formula-sum]
Tc          718.18;      // K   [origin=predictive method=joback]
Pc          18.838;      // bar [origin=predictive method=joback]
omega       0.6805;      // -   [origin=predictive method=lee-kesler]
Tb          540.50;      // K   [origin=predictive method=joback]
HvapTb      50390.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.652 1.2047 -0.0006786 1.301e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 2; } { group CH2=C; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[di(propan-2-yl)amino]ethyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 2-(bis(1-methylethyl)amino)ethyl ester" "2-propenoic acid, 2-methyl-, 2-[bis(1-methylethyl)amino]ethyl ester" "dpaema" "diisopropylaminoethyl methacrylate" "2-diisopropylaminoethyl methacrylate" "n,n-diisopropylaminoethyl methacrylate" "methacrylic acid, 2-(diisopropylamino)ethyl ester" "2-propenoic acid,2-methyl-, 2-[bis(1-methylethyl)amino]ethyl ester" "methacrylicacid, 2-(diisopropylamino)ethyl ester (8ci); ethanol, 2-(diisopropylamino)-,methacrylate (ester) (8ci); 2-(diisopropylamino)ethyl methacrylate;diisopropylaminoethyl methacrylate; n,n-diisopropylaminoethyl methacrylate" );
gibbsFormation
{
    dHf_298   -435680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     662.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75020.0
    phase     gas;
}
