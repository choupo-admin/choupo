/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-o-cresoxyethanol  (C9H12O2, CAS 6161-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OCresoxyethanol;
formula     C9H12O2;
CAS         6161-86-0;
InChIKey    KWYCFJCICXFNEK-UHFFFAOYSA-N;
MW          152.193;      // g/mol [origin=calculated method=formula-sum]
Tc          746.30;      // K   [origin=predictive method=joback]
Pc          34.971;      // bar [origin=predictive method=joback]
omega       0.8977;      // -   [origin=predictive method=lee-kesler]
Tb          551.78;      // K   [origin=predictive method=joback]
HvapTb      57655.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.892 0.69122 -0.00034936 5.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methylphenoxy)ethanol" "2-(o-tolyloxy)ethanol" "phenoxyethanol, o-methyl-" "ether, 2-(hydroxyethyl) o-tolyl" "ethyl alcohol, 2-(o-tolyloxy)-" "beta-hydroxyethyl ether of o-cresol" "ethanol, 2-(2-methylphenoxy)-" "ethanol, 2-(o-tolyloxy)-" ".beta.-hydroxyethyl ether of o-cresol" "ethanol, 2-(2-methylphenoxy)- (9ci)" );
standardThermochemistry
{
    dHf_298   -288480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114140.0
}
