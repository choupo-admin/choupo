/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-2-pentylcyclopentan-1-ol  (C11H22O, CAS 76649-20-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl2Pentylcyclopentan1Ol;
formula     C11H22O;
CAS         76649-20-2;
InChIKey    AASLUBJZRBOXBK-UHFFFAOYSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          727.39;      // K   [origin=predictive method=joback]
Pc          23.383;      // bar [origin=predictive method=joback]
omega       0.8377;      // -   [origin=predictive method=lee-kesler]
Tb          549.40;      // K   [origin=predictive method=joback]
HvapTb      56398.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.426 1.16154 -0.0006216 1.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-2-pentyl-cyclopentan-1-ol" "cyclopentanol, 3-methyl-2-pentyl-" "cyclopentanol,3-methyl-2-pentyl-" "3-methyl-2-pentylcyclopentan-1-ol;2-hexenylcyclopentanol" );
standardThermochemistry
{
    dHf_298   -402800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-73950.0
}
