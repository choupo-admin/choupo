/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-bis(2-hydroxyethylthio)butane  (C8H18O2S2, CAS 7425-93-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Bis2HydroxyethylthioButane;
formula     C8H18O2S2;
CAS         7425-93-6;
InChIKey    FORJWQPDKXQQOG-UHFFFAOYSA-N;
MW          210.35;      // g/mol [origin=calculated method=formula-sum]
Tc          890.24;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       1.5397;      // -   [origin=predictive method=lee-kesler]
Tb          704.56;      // K   [origin=predictive method=joback]
HvapTb      80394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.398 0.82058 -0.0003918 4.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group OH; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group OH; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(2-hydroxyethylsulfanyl)butylsulfanyl]ethanol" "ethanol, 2,2'-[1,4-butanediylbis(thio)]bis-" "2-[4-(2-hydroxyethylthio)butylthio]ethan-1-ol" "1,4-bis(2-hydroxyethyl thio)butane" "2,2'-(butane-1,4-diylbis(thio))bisethanol" "2,2'-(butane-1,4-diyldisulfanediyl)diethanol" "ethanol,2,2'-[1,4-butanediylbis(thio)]bis-" "2,2'-(tetramethylenedithio)diethanol;ethanol,2,2'-(tetramethylenedithio)di- (6ci,7ci,8ci);1,4-bis(2-hydroxyethylthio)butane;" );
standardThermochemistry
{
    dHf_298   -429170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     692.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-190920.0
}
