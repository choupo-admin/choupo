/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl prop-2-enoate;2-hydroxyethyl prop-2-enoate;methyl 2-methylprop-2-enoate;6-oxidanylhexanoic acid  (C23H40O10, CAS 118276-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylProp2Enoate2HydroxyethylProp2EnoateMethyl2Methylprop2En;
formula     C23H40O10;
CAS         118276-84-9;
InChIKey    SCBRARXITABCLP-UHFFFAOYSA-N;
MW          476.563;      // g/mol [origin=calculated method=formula-sum]
Tc          1569.82;      // K   [origin=predictive method=joback]
Pc          9.346;      // bar [origin=predictive method=joback]
omega       0.4887;      // -   [origin=predictive method=lee-kesler]
Tb          1224.49;      // K   [origin=predictive method=joback]
HvapTb      138487.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (187.18 1.46456 9.64e-05 -4.588e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 10; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group OH; count 2; } { group COOH; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group OH; count 2; } { group COOH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, methyl ester, polymer with butyl 2-propenoate and 2-hydroxyethyl 2-propenoate, 6-hydroxyhexanoate" );
standardThermochemistry
{
    dHf_298   -2092980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1665.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1465190.0
}
