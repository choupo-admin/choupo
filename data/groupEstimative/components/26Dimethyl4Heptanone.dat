/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethyl-4-heptanone  (C9H18O, CAS 108-83-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethyl4Heptanone;
formula     C9H18O;
CAS         108-83-8;
InChIKey    PTTPXKJBFFKCEK-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          640.38;      // K   [origin=predictive method=joback]
Pc          24.925;      // bar [origin=predictive method=joback]
omega       0.5091;      // -   [origin=predictive method=lee-kesler]
Tb          458.51;      // K   [origin=predictive method=joback]
HvapTb      41598.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.298 0.84268 -0.0004535 8.586e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethylheptan-4-one" "diisobutyl ketone" "isovalerone" "isobutyl ketone" "s-diisopropylacetone" "diisobutylketone" "4-heptanone, 2,6-dimethyl-" "diisobutilchetone" "di-isobutylcetone" "dibk" "2,6-dimetil-eptan-4-one" "2,6-dimethyl-heptan-4-on" );
gibbsFormation
{
    dHf_298   -352230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-108900.0
    phase     gas;
}
