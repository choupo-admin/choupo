/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-acetylpent-4-enoate  (C9H14O3, CAS 610-89-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Acetylpent4Enoate;
formula     C9H14O3;
CAS         610-89-9;
InChIKey    IXKFNTFJUHTDNE-UHFFFAOYSA-N;
MW          170.208;      // g/mol [origin=calculated method=formula-sum]
Tc          701.19;      // K   [origin=predictive method=joback]
Pc          25.925;      // bar [origin=predictive method=joback]
omega       0.6721;      // -   [origin=predictive method=lee-kesler]
Tb          513.85;      // K   [origin=predictive method=joback]
HvapTb      48723.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.802 0.76194 -0.0003786 4.666e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-ethanoylpent-4-enoate" "ethyl 2-allylacetoacetate" "4-pentenoic acid, 2-acetyl-, ethyl ester" "ethyl .alpha.-allylacetoacetate" "2-acetyl-pent-4-enoic acid ethyl ester" "ethyl alpha-allylacetoacetate" );
gibbsFormation
{
    dHf_298   -538800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-328990.0
    phase     gas;
}
