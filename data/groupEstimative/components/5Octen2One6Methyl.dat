/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-octen-2-one, 6-methyl-  (C9H16O, CAS 24199-46-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Octen2One6Methyl;
formula     C9H16O;
CAS         24199-46-0;
InChIKey    SAXWRVSDVXCTEL-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          649.22;      // K   [origin=predictive method=joback]
Pc          25.978;      // bar [origin=predictive method=joback]
omega       0.5116;      // -   [origin=predictive method=lee-kesler]
Tb          463.43;      // K   [origin=predictive method=joback]
HvapTb      42412.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.807 0.85076 -0.0005332 1.3606e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH; count 1; } { group dC; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyloct-5-en-2-one" "ethylheptenone" "agn-pc-00odwu" "5-octen-2-one,6-methyl-" "5-octen-2-one, 6-methyl-, (z)-" "3-methyl-3-octen-7-one;6-methyl-5-octen-2-one" );
standardThermochemistry
{
    dHf_298   -234240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32350.0
}
