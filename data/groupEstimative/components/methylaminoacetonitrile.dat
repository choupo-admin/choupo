/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylaminoacetonitrile  (C3H6N2, CAS 5616-32-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylaminoacetonitrile;
formula     C3H6N2;
CAS         5616-32-0;
InChIKey    PVVRRUUMHFWFQV-UHFFFAOYSA-N;
MW          70.095;      // g/mol [origin=calculated method=formula-sum]
Tc          618.72;      // K   [origin=predictive method=joback]
Pc          43.397;      // bar [origin=predictive method=joback]
omega       0.4751;      // -   [origin=predictive method=lee-kesler]
Tb          420.49;      // K   [origin=predictive method=joback]
HvapTb      39186.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.951 0.29982 -0.000157 2.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3NH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(methylamino)ethanenitrile" "sarcosinonitrile" "(methylamino)acetonitrile" "2-(methylamino)acetonitrile" "acetonitrile, (methylamino)-" "n-methylaminoacetonitrile" "glycinonitrile, n-methyl-" "acetonitrile, 2-(methylamino)-" "n-methylglycinonitrile sulfate" );
standardThermochemistry
{
    dHf_298   113100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     319.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196950.0
}
