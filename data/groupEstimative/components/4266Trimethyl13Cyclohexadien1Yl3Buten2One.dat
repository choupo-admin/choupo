/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2,6,6-trimethyl-1,3-cyclohexadien-1-yl)-3-buten-2-one  (C13H18O, CAS 1203-08-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4266Trimethyl13Cyclohexadien1Yl3Buten2One;
formula     C13H18O;
CAS         1203-08-3;
InChIKey    UWWCASOGCPOGJP-UHFFFAOYSA-N;
MW          190.286;      // g/mol [origin=calculated method=formula-sum]
Tc          804.40;      // K   [origin=predictive method=joback]
Pc          23.588;      // bar [origin=predictive method=joback]
omega       0.5545;      // -   [origin=predictive method=lee-kesler]
Tb          583.14;      // K   [origin=predictive method=joback]
HvapTb      52422.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.19 1.41388 -0.00120258 4.4806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH=CH; count 2; } { group CH3CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 2; } { group CH2_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2,6,6-trimethylcyclohexa-1,3-dien-1-yl)but-3-en-2-one" "agn-pc-03d2q9" "3-buten-2-one,4-(2,6,6-trimethyl-1,3-cyclohexadien-1-yl)-" "3-buten-2-one, 4-(2,6,6-trimethyl-1,3-cyclohexadien-1-yl)-" "3-buten-2-one, 4-(2,6,6-trimethyl-1,3-cyclohexadien-1-yl)-, (e)-" "3-buten-2-one, 4-(2,6,6-trimethyl-1,3-cyclohexadien-1-yl)-, (z)-" "3,4-dehydro-b-ionone;4-(2,6,6-trimethyl-1,3-cyclohexadienyl)but-3-en-2-one; dehydro-b-ionone; b-ionone, dehydro-" );
gibbsFormation
{
    dHf_298   -144830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     634.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69500.0
    phase     gas;
}
