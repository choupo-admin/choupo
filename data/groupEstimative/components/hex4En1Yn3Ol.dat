/*--------------------------------*- Choupo -*-----------------------*\
  Component: hex-4-en-1-yn-3-ol  (C6H8O, CAS 10138-60-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hex4En1Yn3Ol;
formula     C6H8O;
CAS         10138-60-0;
InChIKey    SRSOGIWDNSFTEG-UHFFFAOYSA-N;
MW          96.129;      // g/mol [origin=calculated method=formula-sum]
Tc          607.51;      // K   [origin=predictive method=joback]
Pc          44.802;      // bar [origin=predictive method=joback]
omega       0.6136;      // -   [origin=predictive method=lee-kesler]
Tb          422.90;      // K   [origin=predictive method=joback]
HvapTb      45057.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.64 0.53982 -0.00041593 1.3529e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH; count 2; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-hexen-1-yn-3-ol, (4e)-" );
gibbsFormation
{
    dHf_298   84440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=163670.0
    phase     gas;
}
