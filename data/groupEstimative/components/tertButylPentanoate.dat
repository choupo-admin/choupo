/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl pentanoate  (C9H18O2, CAS 23361-78-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertButylPentanoate;
formula     C9H18O2;
CAS         23361-78-6;
InChIKey    SCSLUABEVMLYEA-UHFFFAOYSA-N;
MW          158.241;      // g/mol [origin=calculated method=formula-sum]
Tc          641.53;      // K   [origin=predictive method=joback]
Pc          23.611;      // bar [origin=predictive method=joback]
omega       0.4976;      // -   [origin=predictive method=lee-kesler]
Tb          460.51;      // K   [origin=predictive method=joback]
HvapTb      41739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.357 0.92988 -0.000543 1.107e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentanoic acid, 1,1-dimethylethyl ester" );
standardThermochemistry
{
    dHf_298   -555120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-282630.0
}
