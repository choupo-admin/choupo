/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-methylenebis(2-isopropyl-6-methylaniline)  (C21H30N2, CAS 16298-38-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Methylenebis2Isopropyl6Methylaniline;
formula     C21H30N2;
CAS         16298-38-7;
InChIKey    FLNVGZMDLLIECD-UHFFFAOYSA-N;
MW          310.485;      // g/mol [origin=calculated method=formula-sum]
Tc          1142.68;      // K   [origin=predictive method=joback]
Pc          15.598;      // bar [origin=predictive method=joback]
omega       1.0286;      // -   [origin=predictive method=lee-kesler]
Tb          907.50;      // K   [origin=predictive method=joback]
HvapTb      91370.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.401 1.61972 -0.00087196 1.613e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group ACCH; count 2; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(4-azanyl-3-methyl-5-propan-2-yl-phenyl)methyl]-2-methyl-6-propan-2-yl-aniline" "4,4'-methylenebis(2-methyl-6-isopropylaniline)" "benzenamine, 4,4'-methylenebis(2-methyl-6-(1-methylethyl)-" "benzenamine, 4,4'-methylenebis[2-methyl-6-(1-methylethyl)-" "4-{[4-amino-5-methyl-3-(methylethyl)phenyl]methyl}-6-methyl-2-(methylethyl)phe nylamine" "benzenamine,4,4'-methylenebis[2-methyl-6-(1-methylethyl)-" "4-[(4-amino-3-methyl-5-propan-2-ylphenyl)methyl]-2-methyl-6-propan-2-ylaniline" "m-cymen-2-amine,5,5'-methylenedi- (8ci); 4,4'-methylenebis[2-methyl-6-isopropylaniline];bis(4-amino-3-methyl-5-isopropylphenyl) methane; lonzacure m-mipa" );
standardThermochemistry
{
    dHf_298   -15510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     808.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=421000.0
}
