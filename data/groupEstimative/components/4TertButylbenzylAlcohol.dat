/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butylbenzyl alcohol  (C11H16O, CAS 877-65-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylbenzylAlcohol;
formula     C11H16O;
CAS         877-65-6;
InChIKey    FVEINXLJOJPHLH-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          773.96;      // K   [origin=predictive method=joback]
Pc          29.313;      // bar [origin=predictive method=joback]
omega       0.7965;      // -   [origin=predictive method=lee-kesler]
Tb          571.89;      // K   [origin=predictive method=joback]
HvapTb      58401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.899 1.07026 -0.00074096 2.02e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-tert-butylphenyl)methanol" "4-t-butylbenzyl alcohol" "p-tert-butylbenzyl alcohol" "4-t-butylbenzylalcohol" "benzenemethanol, 4-(1,1-dimethylethyl)-" "(4-(tert-butyl)phenyl)methanol" "4-(1,1-dimethylethyl)benzenemethanol" "[4-(tert-butyl)phenyl]methan-1-ol" );
gibbsFormation
{
    dHf_298   -206290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10540.0
    phase     gas;
}
