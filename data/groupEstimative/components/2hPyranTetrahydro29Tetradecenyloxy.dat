/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-pyran, tetrahydro-2-(9-tetradecenyloxy)-  (C19H36O2, CAS 51812-91-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hPyranTetrahydro29Tetradecenyloxy;
formula     C19H36O2;
CAS         51812-91-0;
InChIKey    FUYLUCBYVQPAQH-UHFFFAOYSA-N;
MW          296.495;      // g/mol [origin=calculated method=formula-sum]
Tc          892.62;      // K   [origin=predictive method=joback]
Pc          12.655;      // bar [origin=predictive method=joback]
omega       0.8456;      // -   [origin=predictive method=lee-kesler]
Tb          707.40;      // K   [origin=predictive method=joback]
HvapTb      65195.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.349 1.88472 -0.0010497 2.084e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tetradec-9-enoxyoxane" "2h-pyran, tetrahydro-2-(9-tetradecen-1-yloxy)-" "2-[(e)-tetradec-9-enoxy]oxane" "2h-pyran, tetrahydro-2-[(9e)-9-tetradecenyloxy]-" "2h-pyran, tetrahydro-2-[(9e)-9-tetradecen-1-yloxy]-" "tetrahydro-2-(9-tetradecenyloxy)-2h-pyran" "tetrahydro-2-[(e)-9-tetradecenyloxy]-2h-pyran" );
standardThermochemistry
{
    dHf_298   -528170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     818.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22650.0
}
