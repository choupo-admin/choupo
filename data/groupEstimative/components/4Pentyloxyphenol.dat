/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pentyloxyphenol  (C11H16O2, CAS 18979-53-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pentyloxyphenol;
formula     C11H16O2;
CAS         18979-53-8;
InChIKey    JCLFHZLOKITRCE-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          793.33;      // K   [origin=predictive method=joback]
Pc          30.490;      // bar [origin=predictive method=joback]
omega       0.7529;      // -   [origin=predictive method=lee-kesler]
Tb          581.00;      // K   [origin=predictive method=joback]
HvapTb      57780.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.436 1.06132 -0.00075116 2.235e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-pentoxyphenol" "phenol, 4-(pentyloxy)-" "4-amyloxyphenol" "phenol, p-(pentyloxy)-" "4-(pentyloxy)phenol" "p-n-pentyloxyphenol" "p-pentyl-oxyphenol" "4-n-pentyloxyphenol" "p-(pentyloxy)phenol" "hydroquinone monoamyl ether" "hydroquinone monopentyl ether" "phenol,p-(pentyloxy)- (7ci,8ci);4-(pentyloxy)phenol;p-(pentyloxy)phenol;p-(n-pentyloxy)phenol;p-pentoxyphenol;" );
gibbsFormation
{
    dHf_298   -343370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105470.0
    phase     gas;
}
