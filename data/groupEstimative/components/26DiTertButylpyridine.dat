/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-di-tert-butylpyridine  (C13H21N, CAS 585-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DiTertButylpyridine;
formula     C13H21N;
CAS         585-48-8;
InChIKey    UWKQJZCTQGMHKD-UHFFFAOYSA-N;
MW          191.318;      // g/mol [origin=calculated method=formula-sum]
Tc          808.22;      // K   [origin=predictive method=joback]
Pc          22.440;      // bar [origin=predictive method=joback]
omega       0.4337;      // -   [origin=predictive method=lee-kesler]
Tb          575.94;      // K   [origin=predictive method=joback]
HvapTb      51088.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.42 1.38588 -0.00100042 2.897e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-ditert-butylpyridine" "2,6-di(tert-butyl)pyridine" "2,6-bis(tert-butyl)pyridine" "dibutylpyridine" "2,6-di-t-butylpyridine" "pyridine,6-di-tert-butyl-" "uwkqjzctqgmhkd-uhfffaoysa-" "2,6-di-t-butyl pyridine" "pyridine,6-bis(1,1-dimethylethyl)-" "pyridine, 2,6-bis(1,1-dimethylethyl)-" );
gibbsFormation
{
    dHf_298   -71300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=244090.0
    phase     gas;
}
