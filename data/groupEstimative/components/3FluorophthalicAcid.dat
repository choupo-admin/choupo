/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-fluorophthalic acid  (C8H5FO4, CAS 1583-67-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3FluorophthalicAcid;
formula     C8H5FO4;
CAS         1583-67-1;
InChIKey    BBCQSMSCEJBIRD-UHFFFAOYSA-N;
MW          184.122;      // g/mol [origin=calculated method=formula-sum]
Tc          938.04;      // K   [origin=predictive method=joback]
Pc          41.516;      // bar [origin=predictive method=joback]
omega       1.1990;      // -   [origin=predictive method=lee-kesler]
Tb          709.57;      // K   [origin=predictive method=joback]
HvapTb      70513.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.6 0.6793 -0.00047012 1.213e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group COOH; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-fluoranylphthalic acid" "3-fluoro-1,2-benzenedicarboxylic acid" "3-fluorobenzene-1,2-dicarboxylic acid" "3-fluorophthalate" "1,2-benzenedicarboxylic acid, 3-fluoro-" "1583-67-1 3-fluorophthalic acid" "bbcqsmscejbird-uhfffaoysa-" "wt491" "1,2-benzenedicarboxylicacid, 3-fluoro-" "q554" );
standardThermochemistry
{
    dHf_298   -891510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-773000.0
}
