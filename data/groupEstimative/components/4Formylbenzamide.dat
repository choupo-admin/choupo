/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-formylbenzamide  (C8H7NO2, CAS 6051-41-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H7NO2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Formylbenzamide;
formula     C8H7NO2;
CAS         6051-41-8;
InChIKey    QWDCXCRLPNMJIH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          149.149;      // g/mol [origin=calculated method=formula-sum]
Tc          751.55;      // K   [origin=predictive method=joback]
Pc          44.091;      // bar [origin=predictive method=joback]
omega       0.5436;      // -   [origin=predictive method=lee-kesler]
Tb          517.12;      // K   [origin=predictive method=joback]
HvapTb      51354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.64 0.6674 -0.00055326 1.8326e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methanoylbenzamide" "benzamide, 4-formyl-" "4-formyl-benzamide" "benzamide,4-formyl-" "agn-pc-00faet" "terephthalaldehydamide(8ci); 4-aminocarbonylbenzaldehyde; 4-carbamoylbenzaldehyde; 4-formylbenzamide" );
gibbsFormation
{
    dHf_298   14270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100750.0
    phase     gas;
}
