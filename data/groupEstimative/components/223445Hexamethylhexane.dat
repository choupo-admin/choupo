/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,3,4,4,5-hexamethylhexane  (C12H26, CAS 62185-13-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        223445Hexamethylhexane;
formula     C12H26;
CAS         62185-13-1;
InChIKey    QJVUKMHIEDVCDT-UHFFFAOYSA-N;
MW          170.34;      // g/mol [origin=calculated method=formula-sum]
Tc          655.50;      // K   [origin=predictive method=joback]
Pc          18.643;      // bar [origin=predictive method=joback]
omega       0.3440;      // -   [origin=predictive method=lee-kesler]
Tb          466.82;      // K   [origin=predictive method=joback]
HvapTb      38938.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.33 1.40736 -0.000979 2.744e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH; count 2; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH; count 2; } { group C; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-02x4d3" );
gibbsFormation
{
    dHf_298   -319070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50960.0
    phase     gas;
}
