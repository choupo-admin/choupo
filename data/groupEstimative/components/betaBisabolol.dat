/*--------------------------------*- Choupo -*-----------------------*\
  Component: .beta.-bisabolol  (C15H26O, CAS 15352-77-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaBisabolol;
formula     C15H26O;
CAS         15352-77-9;
InChIKey    WTVHAMTYZJGJLJ-UHFFFAOYSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          860.48;      // K   [origin=predictive method=joback]
Pc          20.109;      // bar [origin=predictive method=joback]
omega       0.9066;      // -   [origin=predictive method=lee-kesler]
Tb          662.51;      // K   [origin=predictive method=joback]
HvapTb      65545.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.528 1.78718 -0.00144574 5.127e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-1-(6-methylhept-5-en-2-yl)cyclohex-3-en-1-ol" "3-cyclohexen-1-ol, 1-(1,5-dimethyl-4-hexenyl)-4-methyl-" "beta-bisabolol" "3-cyclohexen-1-ol, 1-(1,5-dimethyl-4-hexenyl)-4-methyl-, (s-(r*,r*))-" );
standardThermochemistry
{
    dHf_298   -287140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     766.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47120.0
}
