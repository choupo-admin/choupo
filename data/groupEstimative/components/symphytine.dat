/*--------------------------------*- Choupo -*-----------------------*\
  Component: symphytine  (C20H31NO6, CAS 22571-95-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        symphytine;
formula     C20H31NO6;
CAS         22571-95-5;
InChIKey    MVWPTZQHBOWRTF-SMLWLWDZSA-N;
MW          381.469;      // g/mol [origin=calculated method=formula-sum]
Tc          1214.93;      // K   [origin=predictive method=joback]
Pc          15.403;      // bar [origin=predictive method=joback]
omega       1.3601;      // -   [origin=predictive method=lee-kesler]
Tb          992.26;      // K   [origin=predictive method=joback]
HvapTb      109247.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.819 2.3204 -0.00162694 4.377e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 4; } { group C; count 1; } { group CH=C; count 2; } { group OH; count 2; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 2; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(7r,8r)-7-[(e)-2-methylbut-2-enoyl]oxy-5,6,7,8-tetrahydro-3h-pyrrolizin-1-yl]methyl (2s)-3-methyl-2-oxidanyl-2-[(1s)-1-oxidanylethyl]butanoate" "7-tiglyl-9-(-)-viridiflorylretronecine" "(1r,7ar)-7-({[(2s,3s)-2,3-dihydroxy-2-isopropylbutanoyl]oxy}methyl)-2,3,5,7a-tetrahydro-1h-pyrrolizin-1-yl (2e)-2-methylbut-2-enoate" "[(7r,8r)-7-[(e)-2-methylbut-2-enoyl]oxy-5,6,7,8-tetrahydro-3h-pyrrolizin-1-yl]methyl (2s)-2-hydroxy-2-[(1s)-1-hydroxyethyl]-3-methylbutanoate" );
gibbsFormation
{
    dHf_298   -1053750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     882.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-466720.0
    phase     gas;
}
