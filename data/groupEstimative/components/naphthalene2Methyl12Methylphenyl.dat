/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalene, 2-methyl-1-(2-methylphenyl)-  (C18H16, CAS 93870-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphthalene2Methyl12Methylphenyl;
formula     C18H16;
CAS         93870-58-7;
InChIKey    HCMRLMHAGTYPID-UHFFFAOYSA-N;
MW          232.326;      // g/mol [origin=calculated method=formula-sum]
Tc          951.00;      // K   [origin=predictive method=joback]
Pc          23.025;      // bar [origin=predictive method=joback]
omega       0.6265;      // -   [origin=predictive method=lee-kesler]
Tb          698.72;      // K   [origin=predictive method=joback]
HvapTb      63840.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.83 1.37384 -0.0009534 2.604e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 4; } { group ACCH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-1-(2-methylphenyl)naphthalene" );
standardThermochemistry
{
    dHf_298   214870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=403260.0
}
