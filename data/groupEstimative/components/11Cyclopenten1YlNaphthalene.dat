/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(1-cyclopenten-1-yl)naphthalene  (C15H14, CAS 58195-37-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Cyclopenten1YlNaphthalene;
formula     C15H14;
CAS         58195-37-2;
InChIKey    IQHWZOGRTZTFDB-UHFFFAOYSA-N;
MW          194.277;      // g/mol [origin=calculated method=formula-sum]
Tc          872.09;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       0.5148;      // -   [origin=predictive method=lee-kesler]
Tb          617.53;      // K   [origin=predictive method=joback]
HvapTb      55082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.14 1.3294 -0.00099612 2.96e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=C; count 1; } { group ACH; count 7; } { group AC; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(cyclopenten-1-yl)naphthalene" "naphthalene, 1-(1-cyclopenten-1-yl)-" "1-(1-cyclopentenyl)-naphthalene" );
standardThermochemistry
{
    dHf_298   190330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=349440.0
}
