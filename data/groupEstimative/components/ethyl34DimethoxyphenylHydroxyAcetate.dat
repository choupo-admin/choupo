/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl(3,4-dimethoxyphenyl)(hydroxy)acetate  (C12H16O5, CAS 32407-67-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl34DimethoxyphenylHydroxyAcetate;
formula     C12H16O5;
CAS         32407-67-3;
InChIKey    TXKORQPSJUQGFY-UHFFFAOYSA-N;
MW          240.255;      // g/mol [origin=calculated method=formula-sum]
Tc          900.20;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       1.2395;      // -   [origin=predictive method=lee-kesler]
Tb          705.60;      // K   [origin=predictive method=joback]
HvapTb      74424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (66.691 0.80466 -0.00024312 -5.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH; count 1; } { group OH; count 1; } { group CH3O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-(3,4-dimethoxyphenyl)-2-oxidanyl-ethanoate" "ethyl 3,4-dimethoxymandelate" "ethyl (3,4-dimethoxyphenyl)(hydroxy)acetate" "ethyl 3,4-dimethoxy-alpha-hydroxyphenylacetate" "ethyl 2-(3,4-dimethoxyphenyl)-2-hydroxyacetate" "methyl dl-3,4-dimethoxy-alpha-hydroxyphenylacetate" "benzeneacetic acid, alpha-hydroxy-3,4-dimethoxy-, ethyl ester" "benzeneacetic acid, .alpha.-hydroxy-3,4-dimethoxy-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -816650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-516320.0
}
