/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-aminosulfolane  (C4H9NO2S, CAS 6338-70-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H9NO2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Aminosulfolane;
formula     C4H9NO2S;
CAS         6338-70-1;
InChIKey    OVKIDXBGVUQFFC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          135.181;      // g/mol [origin=calculated method=formula-sum]
Tc          530.44;      // K   [origin=predictive method=joback]
Pc          60.655;      // bar [origin=predictive method=joback]
omega       0.5085;      // -   [origin=predictive method=lee-kesler]
Tb          353.66;      // K   [origin=predictive method=joback]
HvapTb      47042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.98 0.6262 -0.0003856 8.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CHNH2; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dO_oth; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(oxidanylidene)thiolan-3-amine" "3-sulfolanylamine" "1,1-dioxidotetrahydrothien-3-ylamine" "n-3-sulfolanylamine" "tetrahydro-3-thiophenamine 1,1-dioxide" "tetrahydrothiophen-3-amine 1,1-dioxide" "3-thiophenamine, tetrahydro-, 1,1-dioxide" "3-aminotetrahydrothiophene 1,1-dioxide" "(1,1-dioxidotetrahydro-3-thienyl)amine" "3-aminothiolane-1,1-dione" "1,1-dioxothiolan-3-amine" "3-amino-1" "e6-thiolane-1,1-dione" );
standardThermochemistry
{
    dHf_298   -520680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-403760.0
}
