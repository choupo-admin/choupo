/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,2-diethoxyethyl)piperidine  (C11H23NO2, CAS 3616-58-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        122DiethoxyethylPiperidine;
formula     C11H23NO2;
CAS         3616-58-8;
InChIKey    VSHHRRNJQBETGT-UHFFFAOYSA-N;
MW          201.31;      // g/mol [origin=calculated method=formula-sum]
Tc          715.53;      // K   [origin=predictive method=joback]
Pc          22.915;      // bar [origin=predictive method=joback]
omega       0.6538;      // -   [origin=predictive method=lee-kesler]
Tb          528.07;      // K   [origin=predictive method=joback]
HvapTb      47121.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.907 1.21044 -0.0006512 1.147e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2O; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 5; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperidinoacetal" "n-(2,2-diethoxyethyl)piperidine" "1-piperidineacetaldehyde diethyl acetal" "1-piperidineacetaldehyde, diethyl acetal" "1,1-diethoxy-2-piperidylethane" "piperidine,1-(2,2-diethoxyethyl)-" "piperidine, 1-(2,2-diethoxyethyl)-" "piperidine, 1-(2,2-diethoxyethyl)- (9ci)" );
gibbsFormation
{
    dHf_298   -391740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15660.0
    phase     gas;
}
