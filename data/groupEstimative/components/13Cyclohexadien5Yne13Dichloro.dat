/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-cyclohexadien-5-yne,1,3-dichloro-  (C6H2Cl2, CAS 24634-94-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H2Cl2 (delta C+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13Cyclohexadien5Yne13Dichloro;
formula     C6H2Cl2;
CAS         24634-94-4;
InChIKey    XVYJGUQDTIRIEP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          144.982;      // g/mol [origin=calculated method=formula-sum]
Tc          606.12;      // K   [origin=predictive method=joback]
Pc          43.858;      // bar [origin=predictive method=joback]
omega       0.2529;      // -   [origin=predictive method=lee-kesler]
Tb          389.94;      // K   [origin=predictive method=joback]
HvapTb      35570.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.89 0.3342 -0.00030428 1.106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)cyclohexa-1,3-dien-5-yne" "1,3-dichlorocyclohexa-1,3-dien-5-yne" "1,3-cyclohexadien-5-yne, 1,3-dichloro-" );
gibbsFormation
{
    dHf_298   22230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     275.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55960.0
    phase     gas;
}
