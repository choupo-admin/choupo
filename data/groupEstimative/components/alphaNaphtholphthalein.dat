/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-naphtholphthalein  (C28H18O4, CAS 596-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaNaphtholphthalein;
formula     C28H18O4;
CAS         596-01-0;
InChIKey    HQHBAGKIEAOSNM-UHFFFAOYSA-N;
MW          418.448;      // g/mol [origin=calculated method=formula-sum]
Tc          1479.34;      // K   [origin=predictive method=joback]
Pc          24.029;      // bar [origin=predictive method=joback]
omega       1.5470;      // -   [origin=predictive method=lee-kesler]
Tb          1191.08;      // K   [origin=predictive method=joback]
HvapTb      121869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-226.69 2.9576 -0.00292904 1.1522e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 16; } { group AC; count 8; } { group ACOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dCH_ring; count 16; } { group dC_ring; count 10; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(4-oxidanylnaphthalen-1-yl)-2-benzofuran-1-one" "a-naphtholphthalein" "1-naphtholphthalein" "naphtholphthalein" "naphtholphthalein blue" ".alpha. naphtholphthalein" ".alpha.-naphtholphthaleine" "3,3-bis(4-hydroxy-1-naphthyl)phthalide" "3,3-bis(4-hydroxynaphthalen-1-yl)-2-benzofuran-1-one" "3,3-bis(4-hydroxynaphthyl)-3-hydroisobenzofuran-1-one" );
standardThermochemistry
{
    dHf_298   -135470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     734.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=166370.0
}
