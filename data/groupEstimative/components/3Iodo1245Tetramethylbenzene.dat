/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-iodo-1,2,4,5-tetramethylbenzene  (C10H13I, CAS 2100-25-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Iodo1245Tetramethylbenzene;
formula     C10H13I;
CAS         2100-25-6;
InChIKey    MCRSYYLHVQGFNR-UHFFFAOYSA-N;
MW          260.114;      // g/mol [origin=calculated method=formula-sum]
Tc          809.92;      // K   [origin=predictive method=joback]
Pc          26.874;      // bar [origin=predictive method=joback]
omega       0.4342;      // -   [origin=predictive method=lee-kesler]
Tb          568.14;      // K   [origin=predictive method=joback]
HvapTb      52151.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.78 0.67598 -0.00036464 7.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 1; } { group ACCH3; count 4; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-iodanyl-1,2,4,5-tetramethyl-benzene" "iododurene" "3-iododurene" "2,3,5,6-tetramethyliodobenzene" "benzene, 3-iodo-1,2,4,5-tetramethyl-" "3-iodo-1,4,5-tetramethylbenzene" "1-iodo-2,3,5,6-tetramethylbenzene" "3-iodo-1,2,4,5-tetramethyl-benzene" );
standardThermochemistry
{
    dHf_298   17790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=165330.0
}
