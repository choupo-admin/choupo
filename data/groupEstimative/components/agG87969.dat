/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-87969  (C23H48N2O4, CAS 72968-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG87969;
formula     C23H48N2O4;
CAS         72968-70-8;
InChIKey    YXVDTEGYUWOITN-UHFFFAOYSA-N;
MW          416.647;      // g/mol [origin=calculated method=formula-sum]
Tc          1450.31;      // K   [origin=predictive method=joback]
Pc          9.633;      // bar [origin=predictive method=joback]
omega       0.7447;      // -   [origin=predictive method=lee-kesler]
Tb          1163.32;      // K   [origin=predictive method=joback]
HvapTb      122696.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.981 2.208 -0.0010446 1.233e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 19; } { group CH2NH2; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 21; } { group COOH; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecanedioic acid;undecane-1,11-diamine" "dodecanedioic acid, polymer with 1,11-undecanediamine" "dodecanedioic acid, compd. with 1,11-undecanediamine (1:1)" "dodecanedioic acid, 1,11-undecanediamine polymer" );
gibbsFormation
{
    dHf_298   -1262630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1369.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-516900.0
    phase     gas;
}
