/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropenylaniline  (C9H11N, CAS 52562-19-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropenylaniline;
formula     C9H11N;
CAS         52562-19-3;
InChIKey    HEDYZFYQYPWWCC-UHFFFAOYSA-N;
MW          133.194;      // g/mol [origin=calculated method=formula-sum]
Tc          736.48;      // K   [origin=predictive method=joback]
Pc          36.202;      // bar [origin=predictive method=joback]
omega       0.4590;      // -   [origin=predictive method=lee-kesler]
Tb          506.27;      // K   [origin=predictive method=joback]
HvapTb      48617.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.09 0.76222 -0.00049856 1.267e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-prop-1-en-2-ylaniline" "o-isopropenylaniline" "benzenamine, 2-(1-methylethenyl)-" "2-(prop-1-en-2-yl)aniline" );
standardThermochemistry
{
    dHf_298   145400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=273420.0
}
