/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl butyl sulfide  (C7H14S, CAS 5399-19-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylButylSulfide;
formula     C7H14S;
CAS         5399-19-9;
InChIKey    HXMYUSWENPCWFT-UHFFFAOYSA-N;
MW          130.249;      // g/mol [origin=calculated method=formula-sum]
Tc          616.64;      // K   [origin=predictive method=joback]
Pc          29.828;      // bar [origin=predictive method=joback]
omega       0.3952;      // -   [origin=predictive method=lee-kesler]
Tb          425.22;      // K   [origin=predictive method=joback]
HvapTb      37323.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.134 0.64321 -0.0003397 6.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-prop-2-enylsulfanylbutane" "4-thia-1-octene" "1-butylthioprop-2-ene" "n-c4h9sch2ch=ch2" );
gibbsFormation
{
    dHf_298   -20510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=129020.0
    phase     gas;
}
