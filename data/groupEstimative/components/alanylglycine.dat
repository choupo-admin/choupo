/*--------------------------------*- Choupo -*-----------------------*\
  Component: alanylglycine  (C5H10N2O3, CAS 1188-01-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alanylglycine;
formula     C5H10N2O3;
CAS         1188-01-8;
InChIKey    CXISPYVYMQWFLE-UHFFFAOYSA-N;
MW          146.146;      // g/mol [origin=calculated method=formula-sum]
Tc          849.72;      // K   [origin=predictive method=joback]
Pc          46.403;      // bar [origin=predictive method=joback]
omega       1.1577;      // -   [origin=predictive method=lee-kesler]
Tb          635.64;      // K   [origin=predictive method=joback]
HvapTb      67323.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.901 0.64562 -0.0003973 8.826e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-azanylpropanoylamino)ethanoic acid" "dl-alanylglycine" "l-alanylglycine" "n-l-alanylglycine" "n-dl-alanylglycine" "ala-gly" "glycine, n-l-alanyl-" "dl-ala-gly" "glycine, n-dl-alanyl-" "2-[(2-aminopropanoyl)amino]acetic acid" "2-(2-aminopropanoylamino)acetic acid" "d-alanylglycine" );
standardThermochemistry
{
    dHf_298   -527400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-328210.0
}
