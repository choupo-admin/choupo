/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 1-methyl-6-oxo-6h-benzo[c]chromene-4-carboxylate  (C16H12O4, CAS 67801-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl1Methyl6Oxo6hBenzoCChromene4Carboxylate;
formula     C16H12O4;
CAS         67801-58-5;
InChIKey    KMKSTIMFSHHDHY-UHFFFAOYSA-N;
MW          268.268;      // g/mol [origin=calculated method=formula-sum]
Tc          983.01;      // K   [origin=predictive method=joback]
Pc          23.703;      // bar [origin=predictive method=joback]
omega       0.9800;      // -   [origin=predictive method=lee-kesler]
Tb          754.00;      // K   [origin=predictive method=joback]
HvapTb      72930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.27 1.22464 -0.00086644 2.336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 6; } { group AC; count 5; } { group ACCH3; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 1-methyl-6-oxidanylidene-benzo[c]chromene-4-carboxylate" "6h-dibenzo(b,d)pyran-4-carboxylic acid, 1-methyl-6-oxo-, methyl ester" "6h-dibenzo[b,d]pyran-4-carboxylic acid, 1-methyl-6-oxo-, methyl ester" "methyl 1-methyl-6-oxo-6h-dibenzopyran-4-carboxylate" "methyl 1-methyl-6-oxobenzo[c]chromene-4-carboxylate" "methyl 1-methyl-6-oxo-6h-dibenzo(b,d)pyran-4-carboxylate" );
gibbsFormation
{
    dHf_298   -469330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-245840.0
    phase     gas;
}
