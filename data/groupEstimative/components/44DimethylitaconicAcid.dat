/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-dimethylitaconic acid  (C7H10O4, CAS 584-27-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44DimethylitaconicAcid;
formula     C7H10O4;
CAS         584-27-0;
InChIKey    GYXGAEAOIFNGAE-UHFFFAOYSA-N;
MW          158.153;      // g/mol [origin=calculated method=formula-sum]
Tc          870.16;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       1.0745;      // -   [origin=predictive method=lee-kesler]
Tb          654.70;      // K   [origin=predictive method=joback]
HvapTb      65622.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.839 0.79024 -0.0005906 1.791e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group COOH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dC; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-ylidenebutanedioic acid" "isopropylidene-succinic acid" "2-isopropylidenebutanedioic acid" "4,4-dimethyl itaconic acid" );
gibbsFormation
{
    dHf_298   -790710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-616640.0
    phase     gas;
}
