/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentanemethanol  (C6H12O, CAS 3637-61-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentanemethanol;
formula     C6H12O;
CAS         3637-61-4;
InChIKey    ISQVBYGGNVVVHB-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          632.03;      // K   [origin=predictive method=joback]
Pc          43.169;      // bar [origin=predictive method=joback]
omega       0.6549;      // -   [origin=predictive method=lee-kesler]
Tb          444.34;      // K   [origin=predictive method=joback]
HvapTb      45886.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.759 0.7395 -0.0004604 1.095e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentylmethanol" "cyclopentyl-methanol" "cyclopentylcarbinol" "cyclopentyl carbinol" "cyclopentylmethan-1-ol" "(hydroxymethyl)cyclopentane" "(hydroxymethyl)cyclopentane; cyclopentyl carbinol" );
gibbsFormation
{
    dHf_298   -258920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-100630.0
    phase     gas;
}
