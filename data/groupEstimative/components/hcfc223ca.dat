/*--------------------------------*- Choupo -*-----------------------*\
  Component: hcfc-223ca  (C3HCl4F3, CAS 422-52-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hcfc223ca;
formula     C3HCl4F3;
CAS         422-52-6;
InChIKey    VSPRXIMPHWEJMN-UHFFFAOYSA-N;
MW          235.835;      // g/mol [origin=calculated method=formula-sum]
Tc          606.29;      // K   [origin=predictive method=joback]
Pc          32.916;      // bar [origin=predictive method=joback]
omega       0.3349;      // -   [origin=predictive method=lee-kesler]
Tb          408.87;      // K   [origin=predictive method=joback]
HvapTb      34381.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.37 0.6089 -0.000617 2.206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl2; count 1; } { group CF2; count 1; } { group CCl2F; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 2; } { group F; count 3; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,3,3-tetrakis(chloranyl)-1,2,2-tris(fluoranyl)propane" "propane, 1,1,3,3-tetrachloro-1,2,2-trifluoro-" "1,1,3,3-tetrachloro-2,2,3-trifluoropropane" "propane,1,1,3,3-tetrachloro-1,2,2-trifluoro-" );
gibbsFormation
{
    dHf_298   -779320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-654530.0
    phase     gas;
}
