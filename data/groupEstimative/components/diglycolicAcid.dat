/*--------------------------------*- Choupo -*-----------------------*\
  Component: diglycolic acid  (C4H6O5, CAS 110-99-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diglycolicAcid;
formula     C4H6O5;
CAS         110-99-6;
InChIKey    QEVGZEDELICMKH-UHFFFAOYSA-N;
MW          134.087;      // g/mol [origin=calculated method=formula-sum]
Tc          812.51;      // K   [origin=predictive method=joback]
Pc          48.158;      // bar [origin=predictive method=joback]
omega       1.1294;      // -   [origin=predictive method=lee-kesler]
Tb          604.56;      // K   [origin=predictive method=joback]
HvapTb      61236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.952 0.4222 -0.000228 3.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2O; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group O; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxy-2-oxoethyloxy)ethanoic acid" "oxydiacetic acid" "2,2'-oxydiacetic acid" "acetic acid, 2,2'-oxybis-" "oxybisacetic acid" "oxydiethanolic acid" "acetic acid, oxydi-" "diglycolicacid" "bis(carboxymethyl) ether" "oxodiacetic acid" "oxydi(acetic acid)" "3-oxapentanedioic acid" );
standardThermochemistry
{
    dHf_298   -958650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-810020.0
}
