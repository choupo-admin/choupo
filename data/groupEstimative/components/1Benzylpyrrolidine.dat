/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-benzylpyrrolidine  (C11H15N, CAS 29897-82-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Benzylpyrrolidine;
formula     C11H15N;
CAS         29897-82-3;
InChIKey    CWEGCQIIDCZZED-UHFFFAOYSA-N;
MW          161.248;      // g/mol [origin=calculated method=formula-sum]
Tc          729.93;      // K   [origin=predictive method=joback]
Pc          32.393;      // bar [origin=predictive method=joback]
omega       0.4555;      // -   [origin=predictive method=lee-kesler]
Tb          506.08;      // K   [origin=predictive method=joback]
HvapTb      44793.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.009 1.2616 -0.0009476 2.802e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(phenylmethyl)pyrrolidine" "n-benzylpyrrolidine" "1-benzyl-pyrrolidine" "benzylpyrrolidine" "1-(benzyl)pyrrolidine" "pyrrolidine, 1-benzyl-" "pyrrolidine,1-(phenylmethyl)-" "pyrrolidine, 1-(phenylmethyl)-" "pyrrolidine,1-benzyl- (6ci,8ci); 1-benzylpyrrolidine; n-benzylpyrrolidine;n-benzyltetrahydropyrrole" );
gibbsFormation
{
    dHf_298   120670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=321290.0
    phase     gas;
}
