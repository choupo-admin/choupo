/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl vinyl ketone  (C5H8O, CAS 1629-58-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylVinylKetone;
formula     C5H8O;
CAS         1629-58-9;
InChIKey    JLIDVCMBCGBIEY-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          546.71;      // K   [origin=predictive method=joback]
Pc          39.407;      // bar [origin=predictive method=joback]
omega       0.3537;      // -   [origin=predictive method=lee-kesler]
Tb          364.55;      // K   [origin=predictive method=joback]
HvapTb      32800.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.711 0.43082 -0.0002524 5.666e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-1-en-3-one" "1-penten-3-one" "1-pentene-3-one" "ethylvinyl ketone" "ketone, ethyl vinyl" "4-penten-3-one" "u117" );
gibbsFormation
{
    dHf_298   -133680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49860.0
    phase     gas;
}
