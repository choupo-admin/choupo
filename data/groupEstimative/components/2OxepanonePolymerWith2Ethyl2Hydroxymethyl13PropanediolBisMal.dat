/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxepanone, polymer with 2-ethyl-2-(hydroxymethyl)-1,3-propanediol, bis(maleate) ester  (C20H28O11, CAS 71662-45-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OxepanonePolymerWith2Ethyl2Hydroxymethyl13PropanediolBisMal;
formula     C20H28O11;
CAS         71662-45-8;
InChIKey    GMMCXFRWQJUXEN-VIOUERSGSA-N;
MW          444.433;      // g/mol [origin=calculated method=formula-sum]
Tc          1535.89;      // K   [origin=predictive method=joback]
Pc          14.736;      // bar [origin=predictive method=joback]
omega       1.1853;      // -   [origin=predictive method=lee-kesler]
Tb          1241.50;      // K   [origin=predictive method=joback]
HvapTb      132822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.016 1.99282 -0.0010634 1.385e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group C; count 1; } { group CH=CH; count 2; } { group OH; count 1; } { group CH2COO; count 1; } { group COOH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group dCH; count 4; } { group CH2_ring; count 5; } { group OH; count 1; } { group COOH; count 2; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-4-[2-(hydroxymethyl)-2-[[(z)-4-oxidanyl-4-oxidanylidene-but-2-enoyl]oxymethyl]butoxy]-4-oxidanylidene-but-2-enoic acid;oxepan-2-one" "2-oxepanone, polymer with 2-ethyl-2-(hydroxymethyl)-1,3-propanediol, bis(hydrogen (2z)-2-butenedioate)" );
gibbsFormation
{
    dHf_298   -2065850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1293.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1535450.0
    phase     gas;
}
