/*--------------------------------*- Choupo -*-----------------------*\
  Component: ricinoleic acid diethanolamide  (C22H43NO4, CAS 40716-42-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ricinoleicAcidDiethanolamide;
formula     C22H43NO4;
CAS         40716-42-5;
InChIKey    PDVQCPFKYPYROG-ZDKIGPTLSA-N;
MW          385.589;      // g/mol [origin=calculated method=formula-sum]
Tc          1333.38;      // K   [origin=predictive method=joback]
Pc          11.625;      // bar [origin=predictive method=joback]
omega       0.7189;      // -   [origin=predictive method=lee-kesler]
Tb          1049.53;      // K   [origin=predictive method=joback]
HvapTb      122962.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.433 2.31762 -0.0014451 3.5526e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 3; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group CH; count 1; } { group dCH; count 2; } { group OH; count 3; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z,12r)-n,n-bis(2-hydroxyethyl)-12-oxidanyl-octadec-9-enamide" "ricinoleamide dea" "ricinoleoyl diethanolamide" "9-octadecenamide, 12-hydroxy-n,n-bis(2-hydroxyethyl)-, (9z,12r)-" "diethanolamine ricinoleic acid amide" "n,n-bis(2-hydroxyethyl)ricinoleamide" "12-hydroxy-n,n-bis(2-hydroxyethyl)-9-octadecenamide" "9-octadecenamide, 12-hydroxy-n,n-bis(2-hydroxyethyl)-," "(r-(z))-12-hydroxy-n,n-bis(2-hydroxyethyl)-9-octadecenamide" "(z,12r)-12-hydroxy-n,n-bis(2-hydroxyethyl)octadec-9-enamide" "9-octadecenamide, 12-hydroxy-n,n-bis(2-hydroxyethyl)-, (r-(z))-" );
standardThermochemistry
{
    dHf_298   -887210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1192.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-216460.0
}
