/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9h-fluorene, 9-phenyl-  (C19H14, CAS 789-24-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9hFluorene9Phenyl;
formula     C19H14;
CAS         789-24-2;
InChIKey    ZJQCOVBALALRCC-UHFFFAOYSA-N;
MW          242.321;      // g/mol [origin=calculated method=formula-sum]
Tc          987.82;      // K   [origin=predictive method=joback]
Pc          25.025;      // bar [origin=predictive method=joback]
omega       0.6409;      // -   [origin=predictive method=lee-kesler]
Tb          722.52;      // K   [origin=predictive method=joback]
HvapTb      65609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.5 1.6232 -0.00128232 4.007e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 13; } { group AC; count 4; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group dCH_ring; count 13; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-phenyl-9h-fluorene" "9-phenylfluorene" "fluorene, 9-phenyl-" "9-phenyl-9h-fluoren" );
standardThermochemistry
{
    dHf_298   336280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=512020.0
}
