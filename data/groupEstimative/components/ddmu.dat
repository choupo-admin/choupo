/*--------------------------------*- Choupo -*-----------------------*\
  Component: ddmu  (C14H9Cl3, CAS 1022-22-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ddmu;
formula     C14H9Cl3;
CAS         1022-22-6;
InChIKey    LNKQQZFLNUVWQQ-UHFFFAOYSA-N;
MW          283.576;      // g/mol [origin=calculated method=formula-sum]
Tc          965.41;      // K   [origin=predictive method=joback]
Pc          25.405;      // bar [origin=predictive method=joback]
omega       0.5892;      // -   [origin=predictive method=lee-kesler]
Tb          699.57;      // K   [origin=predictive method=joback]
HvapTb      65827.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.25 1.0973 -0.00081342 2.328e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCl; count 2; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-[2-chloranyl-1-(4-chlorophenyl)ethenyl]benzene" "p,p'-ddd olefin" "p,p'-tde olefin" "tdee" "p,p'-ddmu" "p,p'-tdee" "p,p'-ddm" "p,p'-dme" "1,1-bis(p-chlorophenyl)-2-chloroethene" "1,1-bis(p-chlorophenyl)-2-chloroethylene" "1-chloro-2,2-bis(p-chlorophenyl)ethylene" "2,2-bis(4-chlorophenyl)-1-chloroethylene" );
gibbsFormation
{
    dHf_298   178040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=308440.0
    phase     gas;
}
