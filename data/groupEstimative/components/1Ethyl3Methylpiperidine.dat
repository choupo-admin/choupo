/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethyl-3-methylpiperidine  (C8H17N, CAS 2162-86-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethyl3Methylpiperidine;
formula     C8H17N;
CAS         2162-86-9;
InChIKey    YSPBEFPTFBRJBH-UHFFFAOYSA-N;
MW          127.231;      // g/mol [origin=calculated method=formula-sum]
Tc          601.15;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.3592;      // -   [origin=predictive method=lee-kesler]
Tb          410.36;      // K   [origin=predictive method=joback]
HvapTb      35702.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.559 1.01944 -0.0006514 1.609e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-3-methyl-piperidine" );
standardThermochemistry
{
    dHf_298   -80440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=163810.0
}
