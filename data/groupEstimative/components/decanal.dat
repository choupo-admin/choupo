/*--------------------------------*- Choupo -*-----------------------*\
  Component: decanal  (C10H20O, CAS 112-31-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decanal;
formula     C10H20O;
CAS         112-31-2;
InChIKey    KSMVZQYAVGTKIV-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          645.72;      // K   [origin=predictive method=joback]
Pc          22.590;      // bar [origin=predictive method=joback]
omega       0.6532;      // -   [origin=predictive method=lee-kesler]
Tb          477.06;      // K   [origin=predictive method=joback]
HvapTb      44574.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.198 0.92832 -0.0005132 1.057e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decyl aldehyde" "capraldehyde" "caprinaldehyde" "decanaldehyde" "n-decyl aldehyde" "capric aldehyde" "n-decaldehyde" "1-decanal" "n-decanal" "1-decyl aldehyde" "decylic aldehyde" "caprinic aldehyde" );
standardThermochemistry
{
    dHf_298   -335310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-66200.0
}
