/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chlorocholestene  (C27H45Cl, CAS 910-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chlorocholestene;
formula     C27H45Cl;
CAS         910-31-6;
InChIKey    OTVRYZXVVMZHHW-DPAQBDIFSA-N;
MW          405.107;      // g/mol [origin=calculated method=formula-sum]
Tc          1119.99;      // K   [origin=predictive method=joback]
Pc          9.926;      // bar [origin=predictive method=joback]
omega       0.7113;      // -   [origin=predictive method=lee-kesler]
Tb          892.83;      // K   [origin=predictive method=joback]
HvapTb      77542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-298.787 3.5319 -0.00293984 1.0565e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 11; } { group CH; count 6; } { group C; count 2; } { group CH=C; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,8s,9s,10r,13r,14s,17r)-3-chloranyl-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthrene" "cholesteryl chloride" "cholesterol chloride" "(3b)-3-chlorocholest-5-ene" "3-chlorocholest-5-ene" "3beta-chloro-5-cholestene" "3" "a-chloro-5-cholestene" "3beta-chlorocholest-5-ene" "5-cholesten-3beta-chloride" "3-beta-chlorocholest-5-ene" "3.beta.-chlorocholest-5-ene" "cholest-5-ene, 3beta-chloro- (8ci)" );
standardThermochemistry
{
    dHf_298   -350740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     929.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=328370.0
}
