/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethaen  (C12H23NO13, CAS 63980-59-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethaen;
formula     C12H23NO13;
CAS         63980-59-6;
InChIKey    DUUCJSJYISFGCI-WBPXWQEISA-N;
MW          389.31;      // g/mol [origin=calculated method=formula-sum]
Tc          2210.97;      // K   [origin=predictive method=joback]
Pc          34.602;      // bar [origin=predictive method=joback]
omega       0.4754;      // -   [origin=predictive method=lee-kesler]
Tb          1530.58;      // K   [origin=predictive method=joback]
HvapTb      195436.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (101.052 1.25214 -0.0003672 -1.064e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 4; } { group OH; count 5; } { group CH3N; count 1; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 4; } { group OH; count 5; } { group COOH; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3r)-2,3-bis(oxidanyl)butanedioic acid;2-(dimethylamino)ethanol" "recrein" "2-(dimethylamino)ethanol bitartrate" "ethanol, 2-(dimethylamino)-, bitartrate" "(2r,3r)-2,3-dihydroxybutanedioic acid; 2-(dimethylamino)ethanol" );
gibbsFormation
{
    dHf_298   -2630070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1283.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2118080.0
    phase     gas;
}
