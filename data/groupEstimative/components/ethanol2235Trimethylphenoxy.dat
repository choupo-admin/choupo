/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanol, 2-(2,3,5-trimethylphenoxy)-  (C11H16O2, CAS 56949-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanol2235Trimethylphenoxy;
formula     C11H16O2;
CAS         56949-56-5;
InChIKey    MBBSUPCYATWRHO-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          799.12;      // K   [origin=predictive method=joback]
Pc          27.326;      // bar [origin=predictive method=joback]
omega       0.9888;      // -   [origin=predictive method=lee-kesler]
Tb          607.50;      // K   [origin=predictive method=joback]
HvapTb      63431.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.672 0.76226 -0.00032408 2.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 3; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,3,5-trimethylphenoxy)ethanol" "ethanol, 2-(2,3,5-trimethylphenoxy)-," );
gibbsFormation
{
    dHf_298   -352700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116560.0
    phase     gas;
}
