/*--------------------------------*- Choupo -*-----------------------*\
  Component: (5e)-2-methylhepta-2,5-dien-4-ol  (C8H14O, CAS 926-98-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5e2Methylhepta25Dien4Ol;
formula     C8H14O;
CAS         926-98-7;
InChIKey    PKBWVARBUGUSTC-SNAWJCMRSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          663.59;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       0.7237;      // -   [origin=predictive method=lee-kesler]
Tb          482.58;      // K   [origin=predictive method=joback]
HvapTb      49689.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.83 0.84366 -0.0006149 1.899e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH; count 3; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -141310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29110.0
    phase     gas;
}
