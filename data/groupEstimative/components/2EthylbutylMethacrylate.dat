/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylbutyl methacrylate  (C10H18O2, CAS 5138-86-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylbutylMethacrylate;
formula     C10H18O2;
CAS         5138-86-3;
InChIKey    CHNGPLVDGWOPMD-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          662.02;      // K   [origin=predictive method=joback]
Pc          22.292;      // bar [origin=predictive method=joback]
omega       0.5614;      // -   [origin=predictive method=lee-kesler]
Tb          482.74;      // K   [origin=predictive method=joback]
HvapTb      44283.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.843 0.88486 -0.000454 6.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylbutyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 2-ethylbutyl ester" "methacrylic acid, 2-ethylbutyl ester" "methacrylic acid, 2-ethylbutyl ester (8ci)" "2-propenoic acid,2-methyl-, 2-ethylbutyl ester" );
gibbsFormation
{
    dHf_298   -456650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200200.0
    phase     gas;
}
