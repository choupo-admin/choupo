/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4,5-triethoxybenzoic acid  (C13H18O5, CAS 6970-19-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        345TriethoxybenzoicAcid;
formula     C13H18O5;
CAS         6970-19-0;
InChIKey    YCENSLDYFDZUMO-UHFFFAOYSA-N;
MW          254.282;      // g/mol [origin=calculated method=formula-sum]
Tc          958.14;      // K   [origin=predictive method=joback]
Pc          21.795;      // bar [origin=predictive method=joback]
omega       1.1446;      // -   [origin=predictive method=lee-kesler]
Tb          751.43;      // K   [origin=predictive method=joback]
HvapTb      73188.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (81.163 0.84266 -0.00025308 -4.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 2; } { group AC; count 4; } { group CH2O; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, 3,4,5-triethoxy-" "benzoic acid,3,4,5-triethoxy-" "upcmld0enat5883878:001" );
gibbsFormation
{
    dHf_298   -856460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-516810.0
    phase     gas;
}
