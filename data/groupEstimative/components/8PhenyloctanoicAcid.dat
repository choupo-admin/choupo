/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-phenyloctanoic acid  (C14H20O2, CAS 26547-51-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8PhenyloctanoicAcid;
formula     C14H20O2;
CAS         26547-51-3;
InChIKey    VZECIAZMSHBQOC-UHFFFAOYSA-N;
MW          220.312;      // g/mol [origin=calculated method=formula-sum]
Tc          898.57;      // K   [origin=predictive method=joback]
Pc          21.795;      // bar [origin=predictive method=joback]
omega       0.9635;      // -   [origin=predictive method=lee-kesler]
Tb          692.11;      // K   [origin=predictive method=joback]
HvapTb      66198.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.143 1.3057 -0.0008416 2.089e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group ACH; count 5; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenylcaprylicacid" "benzeneoctanoic acid" "omega-phenyl octanoic acid" "w-phenyloctanoic acid;8-phenyloctanoic acid;8-phenylcaprylic acid;octanoicacid, 8-phenyl- (6ci,8ci);" );
gibbsFormation
{
    dHf_298   -446030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-164500.0
    phase     gas;
}
