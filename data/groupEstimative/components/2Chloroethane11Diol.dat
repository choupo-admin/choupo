/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloroethane-1,1-diol  (C2H5ClO2, CAS 15873-56-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloroethane11Diol;
formula     C2H5ClO2;
CAS         15873-56-0;
InChIKey    QXCPBNVAQSUDRV-UHFFFAOYSA-N;
MW          96.51;      // g/mol [origin=calculated method=formula-sum]
Tc          636.21;      // K   [origin=predictive method=joback]
Pc          63.491;      // bar [origin=predictive method=joback]
omega       1.1526;      // -   [origin=predictive method=lee-kesler]
Tb          466.71;      // K   [origin=predictive method=joback]
HvapTb      57401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.861 0.2745 -0.0001694 4.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group OH; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group Cl; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylethane-1,1-diol" "chloroacetaldehyde hydrate" "2-chloro-1,1-ethanediol" "1,1-ethanediol, 2-chloro-" "2-chloro-1,1-dihydroxyethane" "sjphlqdikup@" "acetaldehyde, chloro-, hydrate (6ci)" "1,1-ethanediol,2-chloro- (8ci,9ci)" "acetaldehyde,chloro-, hydrate (6ci); 2-chloro-1,1-ethanediol; chloroacetaldehyde hydrate" );
gibbsFormation
{
    dHf_298   -410090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     359.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-322050.0
    phase     gas;
}
