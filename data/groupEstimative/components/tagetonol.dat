/*--------------------------------*- Choupo -*-----------------------*\
  Component: tagetonol  (C10H18O2, CAS 71547-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tagetonol;
formula     C10H18O2;
CAS         71547-63-2;
InChIKey    HPKAJXIDKBSLHJ-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          748.87;      // K   [origin=predictive method=joback]
Pc          26.191;      // bar [origin=predictive method=joback]
omega       0.9340;      // -   [origin=predictive method=lee-kesler]
Tb          567.46;      // K   [origin=predictive method=joback]
HvapTb      58925.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.698 1.07156 -0.0007298 1.9736e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethyl-6-oxidanyl-oct-7-en-4-one" "6-hydroxy-2,6-dimethyloct-7-en-4-one" "7-octen-4-one, 6-hydroxy-2,6-dimethyl-" );
standardThermochemistry
{
    dHf_298   -403140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144180.0
}
