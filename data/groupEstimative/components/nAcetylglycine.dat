/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-acetylglycine  (C4H7NO3, CAS 543-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nAcetylglycine;
formula     C4H7NO3;
CAS         543-24-8;
InChIKey    OKJIRPAQVSHGFK-UHFFFAOYSA-N;
MW          117.104;      // g/mol [origin=calculated method=formula-sum]
Tc          745.69;      // K   [origin=predictive method=joback]
Pc          48.427;      // bar [origin=predictive method=joback]
omega       0.9170;      // -   [origin=predictive method=lee-kesler]
Tb          540.67;      // K   [origin=predictive method=joback]
HvapTb      54844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.001 0.48282 -0.0002963 6.586e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-acetamidoethanoic acid" "acetamidoacetic acid" "aceturic acid" "glycine, n-acetyl-" "acetylglycine" "acetylaminoacetic acid" "acetylglycocoll" "ethanoylaminoethanoic acid" "ac-gly-oh" "2-acetamidoacetic acid" "(acetylamino)acetic acid" "acetyl-glycine" );
gibbsFormation
{
    dHf_298   -535270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-400640.0
    phase     gas;
}
