/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,10-decanediol dimethacrylate  (C18H30O4, CAS 119546-31-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        110DecanediolDimethacrylate;
formula     C18H30O4;
CAS         119546-31-5;
InChIKey    LRZPQLZONWIQOJ-UHFFFAOYSA-N;
MW          310.434;      // g/mol [origin=calculated method=formula-sum]
Tc          899.39;      // K   [origin=predictive method=joback]
Pc          12.381;      // bar [origin=predictive method=joback]
omega       0.9444;      // -   [origin=predictive method=lee-kesler]
Tb          721.00;      // K   [origin=predictive method=joback]
HvapTb      69296.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.98 1.56404 -0.0008166 1.272e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH2=C; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group dCH2; count 2; } { group dC; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-(2-methylprop-2-enoyloxy)decyl 2-methylprop-2-enoate" "decane-1,10-diyl bis(2-methylacrylate)" "1,10-decamethylene glycol dimethacrylate" "2-propenoic acid, 2-methyl-, 1,1'-(1,10-decanediyl) ester" "1,10-decanediyl bismethacrylate" "decane-1,10-diyl bis(2-methylprop-2-enoate)" "2-propenoic acid, 2-methyl-, 1,10-decanediyl ester" );
standardThermochemistry
{
    dHf_298   -818130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     942.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-361480.0
}
