name        brn2716449;
formula     C11H19NSi;
CAS         10433-33-7;
InChIKey    IJDNGNISLLHUCN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          193.365;      // g/mol [origin=calculated method=formula-sum]
Tc          739.63;      // K   [origin=predictive method=joback]
Pc          23.795;      // bar [origin=predictive method=joback]
omega       0.4865;      // -   [origin=predictive method=lee-kesler]
Tb          529.53;      // K   [origin=predictive method=joback]
HvapTb      49086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.408 0.83996 -0.0002396 -6.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2NH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenyl-n-trimethylsilyl-ethanamine" "n-(2-phenylethyl)-1,1,1-trimethylsilanamine" "silanamine, 1,1,1-trimethyl-n-(2-phenylethyl)-" "silanamine, n-(2-phenylethyl)-1,1,1-trimethyl-" "2-phenyl-n-trimethylsilylethanamine" "1,1,1-trimethyl-n-(2-phenylethyl)silanamine" );
gibbsFormation
{
    dHf_298   -91990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     645.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=138780.0
    phase     gas;
}
