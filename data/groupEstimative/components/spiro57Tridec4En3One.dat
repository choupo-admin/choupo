/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[5.7]tridec-4-en-3-one  (C13H20O, CAS 60033-39-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro57Tridec4En3One;
formula     C13H20O;
CAS         60033-39-8;
InChIKey    NPVAAOCDILSFAY-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          876.20;      // K   [origin=predictive method=joback]
Pc          28.233;      // bar [origin=predictive method=joback]
omega       0.4365;      // -   [origin=predictive method=lee-kesler]
Tb          612.30;      // K   [origin=predictive method=joback]
HvapTb      49259.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-156.98 1.5675 -0.00113028 3.502e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group C; count 1; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro[5.7]tridec-1-en-3-one" "spiro[5.7]tridec-1-ene-3-one" "spiro(5.7)tridec-1-ene-3-one" "3-spiro[5.7]tridec-4-enone" "spiro[5,7]trideca-1,4-dien-3-one" );
standardThermochemistry
{
    dHf_298   -253510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     617.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4970.0
}
