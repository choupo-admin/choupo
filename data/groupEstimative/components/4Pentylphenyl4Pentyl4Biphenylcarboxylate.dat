/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pentylphenyl 4-pentyl-4'-biphenylcarboxylate  (C29H34O2, CAS 61436-49-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pentylphenyl4Pentyl4Biphenylcarboxylate;
formula     C29H34O2;
CAS         61436-49-5;
InChIKey    HYRFINJDWFLMME-UHFFFAOYSA-N;
MW          414.589;      // g/mol [origin=calculated method=formula-sum]
Tc          1251.94;      // K   [origin=predictive method=joback]
Pc          10.757;      // bar [origin=predictive method=joback]
omega       0.9630;      // -   [origin=predictive method=lee-kesler]
Tb          1016.32;      // K   [origin=predictive method=joback]
HvapTb      96369.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.882 2.28884 -0.00135168 2.786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group ACH; count 12; } { group AC; count 4; } { group ACCH2; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-pentylphenyl) 4-(4-pentylphenyl)benzoate" "(1,1'-biphenyl)-4-carboxylic acid, 4'-pentyl-, 4-pentylphenyl ester" "[1,1'-biphenyl]-4-carboxylic acid, 4'-pentyl-, 4-pentylphenyl ester" "4-pentylphenyl 4'-pentyl(1,1'-biphenyl)-4-carboxylate" );
standardThermochemistry
{
    dHf_298   -283990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     999.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191270.0
}
