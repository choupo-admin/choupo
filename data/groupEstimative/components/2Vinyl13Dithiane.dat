/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-vinyl-1,3-dithiane  (C6H10S2, CAS 61685-40-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Vinyl13Dithiane;
formula     C6H10S2;
CAS         61685-40-3;
InChIKey    SIZZLUKBSIWVMD-UHFFFAOYSA-N;
MW          146.266;      // g/mol [origin=calculated method=formula-sum]
Tc          693.82;      // K   [origin=predictive method=joback]
Pc          41.144;      // bar [origin=predictive method=joback]
omega       0.2515;      // -   [origin=predictive method=lee-kesler]
Tb          448.77;      // K   [origin=predictive method=joback]
HvapTb      40333.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.52 0.70472 -0.0004439 1.048e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethenyl-1,3-dithiane" "1,3-dithiane, 2-ethenyl" "1,3-dithiane, 2-ethenyl-" );
gibbsFormation
{
    dHf_298   103100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191650.0
    phase     gas;
}
