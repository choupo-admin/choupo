/*--------------------------------*- Choupo -*-----------------------*\
  Component: alcohols, c18-32, propoxylated  (C21H44O, CAS 79771-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alcoholsC1832Propoxylated;
formula     C21H44O;
CAS         79771-03-2;
InChIKey    XIHDFPHFJXUOQA-UHFFFAOYSA-N;
MW          312.582;      // g/mol [origin=calculated method=formula-sum]
Tc          866.58;      // K   [origin=predictive method=joback]
Pc          9.462;      // bar [origin=predictive method=joback]
omega       0.8356;      // -   [origin=predictive method=lee-kesler]
Tb          702.50;      // K   [origin=predictive method=joback]
HvapTb      64750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.299 1.93564 -0.0010076 1.839e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 18; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 19; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propoxyoctadecane" );
gibbsFormation
{
    dHf_298   -608990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     985.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20940.0
    phase     gas;
}
