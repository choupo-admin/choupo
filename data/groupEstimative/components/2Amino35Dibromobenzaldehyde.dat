/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-3,5-dibromobenzaldehyde  (C7H5Br2NO, CAS 50910-55-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H5Br2NO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Amino35Dibromobenzaldehyde;
formula     C7H5Br2NO;
CAS         50910-55-9;
InChIKey    RCPAZWISSAVDEA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          278.931;      // g/mol [origin=calculated method=formula-sum]
Tc          846.09;      // K   [origin=predictive method=joback]
Pc          53.670;      // bar [origin=predictive method=joback]
omega       0.6280;      // -   [origin=predictive method=lee-kesler]
Tb          582.65;      // K   [origin=predictive method=joback]
HvapTb      56576.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.89 0.5578 -0.00052628 1.988e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group CHO; count 1; } { group ACNH2; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-3,5-bis(bromanyl)benzaldehyde" "3,5-dibromo-2-aminobenzaldehyde" "3,5-dibromoanthranilaldehyde" "2-amino-3,5-dibromo-benzaldehyde" "benzaldehyde, 2-amino-3,5-dibromo-;2-amino-3,5-dibromo benzaldehyde (adba);3,5-dibromo-2-aminobenzaldehyde;" );
gibbsFormation
{
    dHf_298   177210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=230630.0
    phase     gas;
}
