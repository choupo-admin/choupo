/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(3-chloro-4-(methylthio)phenyl)ethanone  (C9H9ClOS, CAS 32467-66-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Chloro4MethylthioPhenylEthanone;
formula     C9H9ClOS;
CAS         32467-66-6;
InChIKey    IYWCQEVVYVUWFY-UHFFFAOYSA-N;
MW          200.68;      // g/mol [origin=calculated method=formula-sum]
Tc          847.90;      // K   [origin=predictive method=joback]
Pc          33.106;      // bar [origin=predictive method=joback]
omega       0.5958;      // -   [origin=predictive method=lee-kesler]
Tb          602.24;      // K   [origin=predictive method=joback]
HvapTb      57176.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.25 0.63413 -0.00032442 4.396e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3CO; count 1; } { group ACCl; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group CdO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-chloranyl-4-methylsulfanyl-phenyl)ethanone" "3-cl-4-ch3s-c6h3-coch3" "1-(3-chloro-4-methylsulfanylphenyl)ethanone" "ethanone, 1-[3-chloro-4-(methylthio)phenyl]-" );
gibbsFormation
{
    dHf_298   -101950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10320.0
    phase     gas;
}
