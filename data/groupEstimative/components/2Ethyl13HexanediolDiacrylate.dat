/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-1,3-hexanediol diacrylate  (C14H22O4, CAS 67905-08-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl13HexanediolDiacrylate;
formula     C14H22O4;
CAS         67905-08-2;
InChIKey    IWUXTVVCZZSKON-UHFFFAOYSA-N;
MW          254.326;      // g/mol [origin=calculated method=formula-sum]
Tc          810.06;      // K   [origin=predictive method=joback]
Pc          16.633;      // bar [origin=predictive method=joback]
omega       0.8521;      // -   [origin=predictive method=lee-kesler]
Tb          628.84;      // K   [origin=predictive method=joback]
HvapTb      59456.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.634 1.19604 -0.0006008 7.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group CH2=CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-ethyl-3-prop-2-enoyloxy-hexyl) prop-2-enoate" "2-ethyl-1-propyl-1,3-propanediyl diacrylate" "2-propenoic acid, 1,1'-(2-ethyl-1-propyl-1,3-propanediyl) ester" "2-propenoic acid, 2-ethyl-1-propyl-1,3-propanediyl ester" "3-(acryloyloxy)-2-ethylhexyl prop-2-enoate" "(2-ethyl-3-prop-2-enoyloxyhexyl) prop-2-enoate" );
standardThermochemistry
{
    dHf_298   -726550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     775.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-382940.0
}
