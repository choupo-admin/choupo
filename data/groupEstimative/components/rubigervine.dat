/*--------------------------------*- Choupo -*-----------------------*\
  Component: rubigervine  (C27H43NO2, CAS 79-58-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        rubigervine;
formula     C27H43NO2;
CAS         79-58-3;
InChIKey    AANKDJLVHZQCFG-LJTVCTDBSA-N;
MW          413.646;      // g/mol [origin=calculated method=formula-sum]
Tc          1289.13;      // K   [origin=predictive method=joback]
Pc          12.664;      // bar [origin=predictive method=joback]
omega       1.1782;      // -   [origin=predictive method=lee-kesler]
Tb          1052.55;      // K   [origin=predictive method=joback]
HvapTb      108233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-391.09 3.92748 -0.00336064 1.2195e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 10; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 9; } { group CH_ring; count 10; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "rubijervin" "rubijervine" "solanid-5-en-3beta,12alpha-diol" "solanid-5-ene-3-beta,12-alpha-diol" "(3" "a,12" "a,14xi)-solanid-5-en-3,12-diol" "delta(sup 5)-3-beta,12-alpha-dihydroxysolanidene" "solanid-5-ene-3,12-diol, (3-beta,12-alpha)-" "solanid-5-ene-3beta,12alpha-diol" "solanid-5-ene-3beta,12alpha-diol (8ci)" );
standardThermochemistry
{
    dHf_298   -476790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     724.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=280690.0
}
