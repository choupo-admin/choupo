/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(4-chloro-2,5-dimethylphenyl)sulfanyl]acetic acid  (C10H11ClO2S, CAS 93-77-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro25DimethylphenylSulfanylAceticAcid;
formula     C10H11ClO2S;
CAS         93-77-6;
InChIKey    OEEPIGFTISQIKQ-UHFFFAOYSA-N;
MW          230.706;      // g/mol [origin=calculated method=formula-sum]
Tc          963.54;      // K   [origin=predictive method=joback]
Pc          30.090;      // bar [origin=predictive method=joback]
omega       0.9186;      // -   [origin=predictive method=lee-kesler]
Tb          721.74;      // K   [origin=predictive method=joback]
HvapTb      70482.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.881 0.74843 -0.00040308 6.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 2; } { group COOH; count 1; } { group ACCl; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chloranyl-2,5-dimethyl-phenyl)sulfanylethanoic acid" "acetic acid, ((4-chloro-2,5-dimethylphenyl)thio)-" "acetic acid, [(4-chloro-2,5-dimethylphenyl)thio]-" "acetic acid, 2-((4-chloro-2,5-dimethylphenyl)thio)-" "acetic acid, 2-[(4-chloro-2,5-dimethylphenyl)thio]-" "((4-chloro-2,5-dimethylphenyl)thio)acetic acid" "2-((4-chloro-2,5-dimethylphenyl)thio)acetic acid" "2-(4-chloro-2,5-dimethylphenyl)sulfanylacetic acid" "2-[(4-chloro-2,5-dimethylphenyl)sulfanyl]acetic acid" "2-(4-chloro-2,5-dimethylphenylthio)acetic acid" );
gibbsFormation
{
    dHf_298   -371750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-205880.0
    phase     gas;
}
