/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,6-dibromodecane  (C10H20Br2, CAS 77928-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        56Dibromodecane;
formula     C10H20Br2;
CAS         77928-86-0;
InChIKey    GRHWTEWNWUYZGF-UHFFFAOYSA-N;
MW          300.078;      // g/mol [origin=calculated method=formula-sum]
Tc          759.04;      // K   [origin=predictive method=joback]
Pc          24.411;      // bar [origin=predictive method=joback]
omega       0.6839;      // -   [origin=predictive method=lee-kesler]
Tb          559.84;      // K   [origin=predictive method=joback]
HvapTb      49948.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.816 1.04204 -0.0006694 1.75e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,6-bis(bromanyl)decane" "decane, 5,6-dibromo-" "agn-pc-00k4ji" );
standardThermochemistry
{
    dHf_298   -207630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     628.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57080.0
}
