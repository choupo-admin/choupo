/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-trimethylcyclopentene  (C8H14, CAS 473-91-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Trimethylcyclopentene;
formula     C8H14;
CAS         473-91-6;
InChIKey    YNEQKUWRFVQFPF-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          604.94;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.3015;      // -   [origin=predictive method=lee-kesler]
Tb          407.04;      // K   [origin=predictive method=joback]
HvapTb      35275.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.49 0.72056 -0.000392 7.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentene, 1,2,3-trimethyl-" "cyclopentene,1,2,3-trimethyl-" "1,2,3-trimethylcyclopentene;laurolen; laurolene" );
standardThermochemistry
{
    dHf_298   -113130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     367.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63730.0
}
