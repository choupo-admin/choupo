/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1,2-Tetrachloro-2,2-difluoroethane  (C2Cl4F2, CAS 76-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1112Tetrachloro22Difluoroethane;
formula     C2Cl4F2;
CAS         76-11-9;
InChIKey    SLGOCMATMKJJCE-UHFFFAOYSA-N;
MW          203.818;      // g/mol [origin=calculated method=formula-sum]
Tc          593.02;      // K   [origin=predictive method=joback]
Pc          38.579;      // bar [origin=predictive method=joback]
omega       0.2638;      // -   [origin=predictive method=lee-kesler]
Tb          387.16;      // K   [origin=predictive method=joback]
HvapTb      33360.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.87 0.4962 -0.000543 2.036e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl3; count 1; } { group CClF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group F; count 2; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-difluoro-1,2,2,2-tetrachloroethane" "1,1-difluoroperchloroethane" "1,2,2,2-tetrachloro-1,1-difluoroethane" "2,2-difluoro-1,1,1,2-tetrachloroethane" "CFC 112a" "ethane, 1,1,1,2-tetrachloro-2,2-difluoro-" "f 112a" "R 112a" "1,1-difluorotetrachloroethane" "halocarbon 112a" "refrigerant 112a" "fluorocarbon 112a" );
gibbsFormation
{
    dHf_298   -557290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     353.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-465700.0
    phase     gas;
}
