/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo(2.2.1)heptane-2-pentanol, beta,2-dimethyl-3-methylene-  (C15H26O, CAS 34289-89-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Heptane2PentanolBeta2Dimethyl3Methylene;
formula     C15H26O;
CAS         34289-89-9;
InChIKey    XIWCAVKLPUJHOO-UHFFFAOYSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          834.66;      // K   [origin=predictive method=joback]
Pc          19.894;      // bar [origin=predictive method=joback]
omega       0.9622;      // -   [origin=predictive method=lee-kesler]
Tb          647.02;      // K   [origin=predictive method=joback]
HvapTb      63972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-134.506 1.90884 -0.0016046 5.86e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group dCH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-5-(3-methyl-2-methylidene-3-bicyclo[2.2.1]heptanyl)pentan-1-ol" "bicyclo(2.2.1)heptane-2-pentanol, " "a,2-dimethyl-3-methylene-" "bicyclo[2.2.1]heptane-2-pentanol, .beta.,2-dimethyl-3-methylene-" "2-(4-hydroxymethylpentyl)-2-methyl-3-methylenebicyclo(2.2.1)heptane" );
gibbsFormation
{
    dHf_298   -291860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85440.0
    phase     gas;
}
