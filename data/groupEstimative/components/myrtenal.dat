/*--------------------------------*- Choupo -*-----------------------*\
  Component: myrtenal  (C10H14O, CAS 564-94-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        myrtenal;
formula     C10H14O;
CAS         564-94-3;
InChIKey    KMRMUZKLFIEVAO-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          708.91;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.4725;      // -   [origin=predictive method=lee-kesler]
Tb          494.52;      // K   [origin=predictive method=joback]
HvapTb      44066.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.38 1.37044 -0.00130464 5.235e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,6-dimethylbicyclo[3.1.1]hept-3-ene-4-carbaldehyde" "(1r)-(-)-myrtenal" "benihinal" "d-myrtenal" "pin-2-ene-1-carbaldehyde" "2-norpinene-2-carboxaldehyde, 6,6-dimethyl-" "(+)-myrtenal" "(1s)-myrtenal" "bicyclo[3.1.1]hept-2-ene-2-carboxaldehyde, 6,6-dimethyl-" "6,6-dimethyl-2-norpinene-2-carboxaldehyde" "2-formyl-6,6-dimethylbicyclo(3.1.1)hept-2-ene" "6,6-dimethylbicyclo(3.1.1)hept-2-ene-2-carboxaldehyde" );
standardThermochemistry
{
    dHf_298   -154660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50330.0
}
