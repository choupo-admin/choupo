/*--------------------------------*- Choupo -*-----------------------*\
  Component: indan  (C9H10, CAS 496-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        indan;
formula     C9H10;
CAS         496-11-7;
InChIKey    PQNFLJBBNBOBRQ-UHFFFAOYSA-N;
MW          118.179;      // g/mol [origin=calculated method=formula-sum]
Tc          675.74;      // K   [origin=predictive method=joback]
Pc          38.916;      // bar [origin=predictive method=joback]
omega       0.3310;      // -   [origin=predictive method=lee-kesler]
Tb          448.59;      // K   [origin=predictive method=joback]
HvapTb      38788.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.08 0.8978 -0.00070556 2.24e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydro-1h-indene" "indane" "hydrindene" "1h-indene, 2,3-dihydro-" "2,3-dihydroindene" "benzocyclopentane" "1,2-hydrindene" "hydrindonaphthene" "indane (van)" "indene, 2,3-dihydro-" "indane (alkane)" "indan odor standard" );
gibbsFormation
{
    dHf_298   89110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196140.0
    phase     gas;
}
