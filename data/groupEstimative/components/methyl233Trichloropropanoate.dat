/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2,3,3-trichloropropanoate  (C4H5Cl3O2, CAS 20618-07-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl233Trichloropropanoate;
formula     C4H5Cl3O2;
CAS         20618-07-9;
InChIKey    VCJSVVVJNDJVPM-UHFFFAOYSA-N;
MW          191.432;      // g/mol [origin=calculated method=formula-sum]
Tc          667.69;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.4634;      // -   [origin=predictive method=lee-kesler]
Tb          460.75;      // K   [origin=predictive method=joback]
HvapTb      44284.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.97 0.36122 -0.0001668 5.3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CHCl; count 1; } { group CHCl2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 2; } { group Cl; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,3,3-tris(chloranyl)propanoate" "propanoic acid, 2,3,3-trichloro-, methyl ester" );
gibbsFormation
{
    dHf_298   -500950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-368240.0
    phase     gas;
}
