/*--------------------------------*- Choupo -*-----------------------*\
  Component: iophenoxic acid  (C11H11I3O3, CAS 96-84-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iophenoxicAcid;
formula     C11H11I3O3;
CAS         96-84-4;
InChIKey    GOIQOQCNFWYSTQ-UHFFFAOYSA-N;
MW          571.906;      // g/mol [origin=calculated method=formula-sum]
Tc          1292.28;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       1.2164;      // -   [origin=predictive method=lee-kesler]
Tb          998.01;      // K   [origin=predictive method=joback]
HvapTb      102251.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.952 1.11972 -0.00098104 3.508e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 1; } { group AC; count 3; } { group ACCH2; count 1; } { group ACOH; count 1; } { group COOH; count 1; } { group I; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group I; count 3; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[2,4,6-tris(iodanyl)-3-oxidanyl-phenyl]methyl]butanoic acid" "teridax" "acido iofenoico" "triiodoethionic acid" "acide iophenoique [inn-french]" "acidum iophenoicum [inn-latin]" "alpha-ethyl-3-hydroxy-2,4,6-triiodohydrocinnamic acid" "alpha-(2,4,6-triiodo-3-hydroxybenzyl)butyric acid" "alpha-ethyl-3-hydroxy-2,4,6-triiodobenzenepropanoic acid" "alpha-ethyl-beta-(3-hydroxy-2,4,6-triiodophenyl)propionic acid" "hydrocinnamic acid, alpha-ethyl-3-hydroxy-2,4,6-triiodo-" "acide iophenoique" );
standardThermochemistry
{
    dHf_298   -370500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     696.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-201350.0
}
