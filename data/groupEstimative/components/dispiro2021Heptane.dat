/*--------------------------------*- Choupo -*-----------------------*\
  Component: dispiro(2.0.2.1)heptane  (C7H10, CAS 33475-22-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dispiro2021Heptane;
formula     C7H10;
CAS         33475-22-8;
InChIKey    KGSOURBADOHWIS-UHFFFAOYSA-N;
MW          94.157;      // g/mol [origin=calculated method=formula-sum]
Tc          591.24;      // K   [origin=predictive method=joback]
Pc          49.108;      // bar [origin=predictive method=joback]
omega       0.2534;      // -   [origin=predictive method=lee-kesler]
Tb          376.59;      // K   [origin=predictive method=joback]
HvapTb      28578.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-249.88 1.751 -0.002231 1.054e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dispiro[2.0.2^{4}.1^{3}]heptane" "dispiro[2.0.2.1]heptane" );
gibbsFormation
{
    dHf_298   93730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     299.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=211240.0
    phase     gas;
}
