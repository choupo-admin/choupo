/*--------------------------------*- Choupo -*-----------------------*\
  Component: ketotifen  (C19H19NOS, CAS 34580-13-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ketotifen;
formula     C19H19NOS;
CAS         34580-13-7;
InChIKey    ZCVMWBYGMWKGHF-UHFFFAOYSA-N;
MW          309.427;      // g/mol [origin=calculated method=formula-sum]
Tc          1133.72;      // K   [origin=predictive method=joback]
Pc          23.519;      // bar [origin=predictive method=joback]
omega       0.9045;      // -   [origin=predictive method=lee-kesler]
Tb          862.78;      // K   [origin=predictive method=joback]
HvapTb      77806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.92 1.72823 -0.00119614 3.246e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH2CO; count 1; } { group CH3N; count 1; } { group C=C; count 1; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group CdO_ring; count 1; } { group N; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-(1-methylpiperidin-4-ylidene)-5h-benzo[1,2]cyclohepta[3,4-b]thiophen-4-one" "ketotifene" "ketotifenum" "ketotiphene" "ketotifeno" "ketotiphen" "ketotifene [inn-french]" "ketotifenum [inn-latin]" "zaditen" "zaditor" "ketotifin" "ketotifene fumarate" );
gibbsFormation
{
    dHf_298   146900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=448270.0
    phase     gas;
}
