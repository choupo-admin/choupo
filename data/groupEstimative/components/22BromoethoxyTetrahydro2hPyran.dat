/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-bromoethoxy)tetrahydro-2h-pyran  (C7H13BrO2, CAS 17739-45-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BromoethoxyTetrahydro2hPyran;
formula     C7H13BrO2;
CAS         17739-45-6;
InChIKey    GCUOLJOTJRUDIZ-UHFFFAOYSA-N;
MW          209.083;      // g/mol [origin=calculated method=formula-sum]
Tc          714.59;      // K   [origin=predictive method=joback]
Pc          37.090;      // bar [origin=predictive method=joback]
omega       0.5058;      // -   [origin=predictive method=lee-kesler]
Tb          494.84;      // K   [origin=predictive method=joback]
HvapTb      44960.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.068 0.7629 -0.0003845 5.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Br; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-bromoethyloxy)oxane" "2h-pyran, 2-(2-bromoethoxy)tetrahydro-" "2-(2-bromoethoxy) tetrahydro-2h-pyran" "2-(2-bromoethoxy)oxane" "2-((2-bromoethyl)oxy)tetrahaydro-2h-pyran" "2-[(2-bromoethyl)oxy]tetrahaydro-2h-pyran" "2(2-bromoethoxy)tetrahydro-2h-pyran" "2-(2-bromo-ethoxy)-tetrahydro-pyran" "1-(2h-3,4,5,6-tetrahydropyran-2-yloxy)-2-bromoethane" "1-(tetrahydropyran-2-yloxy)-2-bromoethane;1-bromo-2-(2-tetrahydropyranyloxy)ethane;1-bromo-2-(tetrahydropyranyloxy)ethane;2-(2-bromoethoxy)tetrahydro-1h-pyran;2-(2-bromoethoxy)tetrahydropyran;2-bromo-1-(tetrahydropyran-2-yloxy)ethane;2-bromoethanol tetrahydropyranylether;2-bromoethyl 2-tetrahydropyranyl ether;2-tetrahydropyranyl 2-bromoethylether;2-[(2-bromoethyl)oxy]tetrahydro-2h-pyran;2-[(tetrahydropyran-2-yl)oxy]ethyl bromide;" );
gibbsFormation
{
    dHf_298   -371380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144290.0
    phase     gas;
}
