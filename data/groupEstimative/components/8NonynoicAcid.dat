/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-nonynoic acid  (C9H14O2, CAS 30964-01-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8NonynoicAcid;
formula     C9H14O2;
CAS         30964-01-3;
InChIKey    NLRIJHGYFNZMGB-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          735.85;      // K   [origin=predictive method=joback]
Pc          29.377;      // bar [origin=predictive method=joback]
omega       0.7629;      // -   [origin=predictive method=lee-kesler]
Tb          541.15;      // K   [origin=predictive method=joback]
HvapTb      52650.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.086 0.8157 -0.00053433 1.4229e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group COOH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group tCH; count 1; } { group tC; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "non-8-ynoic acid" );
gibbsFormation
{
    dHf_298   -287460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-95940.0
    phase     gas;
}
