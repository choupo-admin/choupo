/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-1,2-divinylcyclobutane  (C8H12, CAS 2422-85-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis12Divinylcyclobutane;
formula     C8H12;
CAS         2422-85-7;
InChIKey    UHHCYAAVGADGGP-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          575.00;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.2630;      // -   [origin=predictive method=lee-kesler]
Tb          382.34;      // K   [origin=predictive method=joback]
HvapTb      31838.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.79 0.8386 -0.0005756 1.6e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(ethenyl)cyclobutane" "cyclobutane, 1,2-divinyl-, trans-" "cyclobutane, 1,2-diethenyl-" "cis-1,2-diethenyl-cyclobutane" "cyclobutane, 1,2-diethenyl-, trans-" "trans-1,2-divinylcyclobutane" "agn-pc-03cz4k" "cyclobutane, 1,2-divinyl-" "cyclobutane,1,2-diethenyl-" "1,2-divinylcyclobutane" "1,2-diethenylcyclobutane" "cyclobutane,1,2-divinyl- (6ci,7ci,8ci); 1,2-divinylcyclobutane" );
gibbsFormation
{
    dHf_298   88710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     345.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233100.0
    phase     gas;
}
