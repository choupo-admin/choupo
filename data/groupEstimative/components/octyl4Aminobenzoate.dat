/*--------------------------------*- Choupo -*-----------------------*\
  Component: octyl 4-aminobenzoate  (C15H23NO2, CAS 14309-41-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octyl4Aminobenzoate;
formula     C15H23NO2;
CAS         14309-41-2;
InChIKey    XOEUGELJHSUYGP-UHFFFAOYSA-N;
MW          249.354;      // g/mol [origin=calculated method=formula-sum]
Tc          908.92;      // K   [origin=predictive method=joback]
Pc          19.237;      // bar [origin=predictive method=joback]
omega       0.9476;      // -   [origin=predictive method=lee-kesler]
Tb          705.21;      // K   [origin=predictive method=joback]
HvapTb      69970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.547 1.29752 -0.00070516 1.218e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octyl 4-azanylbenzoate" "benzoic acid, 4-amino-, octyl ester" );
standardThermochemistry
{
    dHf_298   -411360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     730.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-65720.0
}
