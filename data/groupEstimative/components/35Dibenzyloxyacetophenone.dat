/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dibenzyloxyacetophenone  (C22H20O3, CAS 28924-21-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dibenzyloxyacetophenone;
formula     C22H20O3;
CAS         28924-21-2;
InChIKey    KOJXGMJOTRYLBD-UHFFFAOYSA-N;
MW          332.399;      // g/mol [origin=calculated method=formula-sum]
Tc          1137.22;      // K   [origin=predictive method=joback]
Pc          18.294;      // bar [origin=predictive method=joback]
omega       1.0149;      // -   [origin=predictive method=lee-kesler]
Tb          891.67;      // K   [origin=predictive method=joback]
HvapTb      84284.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.868 1.58372 -0.00089182 1.5866e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 13; } { group AC; count 5; } { group CH3CO; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group O; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[3,5-bis(phenylmethoxy)phenyl]ethanone" "3',5'-dibenzyloxyacetophenone" "1-[3,5-bis(benzyloxy)phenyl]ethanon" "ethanone, 1-[3,5-bis(phenylmethoxy)phenyl]-" "1-(3,5-bis(benzyloxy)phenyl)ethanone" "1-[3,5-bis(benzyloxy)phenyl]ethanone" "1-acetyl-3,5-bis(phenylmethoxy)benzene" "1-(3,5-bis(phenylmethoxy)phenyl)ethanone" "ethanone, 1-(3,5-bis(phenylmethoxy)phenyl)-" "3,5-bis(benzyloxy)acetophenone" "kojxgmjotrylbd-uhfffaoysa-" "3',5'-bis(benzyloxy)acetophenone" );
gibbsFormation
{
    dHf_298   -187780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     730.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113410.0
    phase     gas;
}
