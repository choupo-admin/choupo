/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenyl-4-propylpyridine  (C14H15N, CAS 53911-35-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenyl4Propylpyridine;
formula     C14H15N;
CAS         53911-35-6;
InChIKey    MDEOSZGDWLTQLL-UHFFFAOYSA-N;
MW          197.281;      // g/mol [origin=calculated method=formula-sum]
Tc          879.60;      // K   [origin=predictive method=joback]
Pc          27.297;      // bar [origin=predictive method=joback]
omega       0.5727;      // -   [origin=predictive method=lee-kesler]
Tb          631.96;      // K   [origin=predictive method=joback]
HvapTb      58182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.288 1.15028 -0.00074242 1.833e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenyl-4-propyl-pyridine" "pyridine,3-phenyl-4-propyl-" );
gibbsFormation
{
    dHf_298   162090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=359240.0
    phase     gas;
}
