/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(perfluoro-7-methyloctyl)-2-hydroxypropyl methacrylate  (C16H11F19O3, CAS 88752-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Perfluoro7Methyloctyl2HydroxypropylMethacrylate;
formula     C16H11F19O3;
CAS         88752-37-8;
InChIKey    WNVNMSONKCMAPU-UHFFFAOYSA-N;
MW          612.223;      // g/mol [origin=calculated method=formula-sum]
Tc          819.37;      // K   [origin=predictive method=joback]
Pc          9.261;      // bar [origin=predictive method=joback]
omega       0.8984;      // -   [origin=predictive method=lee-kesler]
Tb          669.26;      // K   [origin=predictive method=joback]
HvapTb      47131.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.848 2.84522 -0.0026686 9.041e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } { group CF3; count 2; } { group CF2; count 6; } { group CF; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group C; count 9; } { group dCH2; count 1; } { group dC; count 1; } { group F; count 19; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4,4,5,5,6,6,7,7,8,8,9,9,10,11,11,11-hexadecakis(fluoranyl)-2-oxidanyl-10-(trifluoromethyl)undecyl] 2-methylprop-2-enoate" "2-propenoic acid,2-methyl-,4,4,5,5,6,6,7,7,8,8,9,9,10,11,11,11-hexadecafluoro-2-hydroxy-10-(trifluoromethyl)undecylester" "[4,4,5,5,6,6,7,7,8,8,9,9,10,11,11,11-hexadecafluoro-2-hydroxy-10-(trifluoromethyl)undecyl] 2-methylprop-2-enoate" "2-methyl-2-propenoic acid [4,4,5,5,6,6,7,7,8,8,9,9,10,11,11,11-hexadecafluoro-2-hydroxy-10-(trifluoromethyl)undecyl] ester" "4,4,5,5,6,6,7,7,8,8,9,9,10,11,11,11-hexadecafluoro-2-hydroxy-10-(trifluoromethyl)undecyl 2-methylprop-2-enoate" "4,4,5,5,6,6,7,7,8,8,9,9,10,11,11,11-hexadecafluoro-2-hydroxy-10-(trifluoromethyl)undecyl methacrylate" );
gibbsFormation
{
    dHf_298   -4537560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1115.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3962330.0
    phase     gas;
}
