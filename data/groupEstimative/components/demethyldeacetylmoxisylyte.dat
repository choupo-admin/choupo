/*--------------------------------*- Choupo -*-----------------------*\
  Component: demethyldeacetylmoxisylyte  (C13H21NO2, CAS 72732-50-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        demethyldeacetylmoxisylyte;
formula     C13H21NO2;
CAS         72732-50-4;
InChIKey    GOHVWKGLNUZCRK-UHFFFAOYSA-N;
MW          223.316;      // g/mol [origin=calculated method=formula-sum]
Tc          897.53;      // K   [origin=predictive method=joback]
Pc          24.703;      // bar [origin=predictive method=joback]
omega       0.9801;      // -   [origin=predictive method=lee-kesler]
Tb          686.45;      // K   [origin=predictive method=joback]
HvapTb      69604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.548 1.21448 -0.00077768 2.075e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH2O; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-4-[2-(methylamino)ethoxy]-5-propan-2-yl-phenol" "deacetyldemethylthymoxamine" "carvacrol, 5-(2-(methylamino)ethoxy)-" "phenol, 2-methyl-4-(2-(methylamino)ethoxy)-5-isopropyl-" "(2-(4-hydroxy-2-isopropyl-5-methylphenoxy)ethyl)methylamine" "phenol, 2-methyl-4-(2-(methylamino)ethoxy)-5-(1-methylethyl)-" "phenol, 2-methyl-4-(2-(methylamino)ethoxy)-5-(1-methylethyl)-, 9-cis-" "2-methyl-4-[2-(methylamino)ethoxy]-5-(propan-2-yl)phenol" "2-methyl-4-[2-(methylamino)ethoxy]-5-propan-2-ylphenol" );
standardThermochemistry
{
    dHf_298   -359400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-20940.0
}
