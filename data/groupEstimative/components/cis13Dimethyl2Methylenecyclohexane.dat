/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-1,3-dimethyl-2-methylenecyclohexane  (C9H16, CAS 95177-47-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis13Dimethyl2Methylenecyclohexane;
formula     C9H16;
CAS         95177-47-2;
InChIKey    UTQSTOKTRPNZHE-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          620.00;      // K   [origin=predictive method=joback]
Pc          27.965;      // bar [origin=predictive method=joback]
omega       0.2875;      // -   [origin=predictive method=lee-kesler]
Tb          419.56;      // K   [origin=predictive method=joback]
HvapTb      35907.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.67 0.83694 -0.000399 4.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dimethyl-2-methylidene-cyclohexane" "trans-1,3-dimethyl-2-methylenecyclohexane" "cyclohexane, 1,3-dimethyl-2-methylene-" "cyclohexane, 1,3-dimethyl-2-methylene-, cis-" "cyclohexane, 1,3-dimethyl-2-methylene-, trans-" "1,3-dimethyl-2-methylidenecyclohexane" );
standardThermochemistry
{
    dHf_298   -110870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94720.0
}
