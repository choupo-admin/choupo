/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethynyl-1h-indene  (C11H8, CAS 74010-34-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethynyl1hIndene;
formula     C11H8;
CAS         74010-34-7;
InChIKey    ZQOOYBLMYCOHSK-UHFFFAOYSA-N;
MW          140.185;      // g/mol [origin=calculated method=formula-sum]
Tc          729.89;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.3553;      // -   [origin=predictive method=lee-kesler]
Tb          488.61;      // K   [origin=predictive method=joback]
HvapTb      44052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.04 0.8784 -0.00073053 2.4549e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h-indene, 2-ethynyl-" "1h-indene, 2-ethynyl- (9ci)" );
gibbsFormation
{
    dHf_298   386040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=456380.0
    phase     gas;
}
