/*--------------------------------*- Choupo -*-----------------------*\
  Component: thenalidine  (C17H22N2S, CAS 86-12-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thenalidine;
formula     C17H22N2S;
CAS         86-12-4;
InChIKey    KLOHYVOVXOUKQI-UHFFFAOYSA-N;
MW          286.437;      // g/mol [origin=calculated method=formula-sum]
Tc          974.74;      // K   [origin=predictive method=joback]
Pc          23.136;      // bar [origin=predictive method=joback]
omega       0.7285;      // -   [origin=predictive method=lee-kesler]
Tb          726.48;      // K   [origin=predictive method=joback]
HvapTb      67679.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.079 1.92053 -0.00139382 3.909e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 2; } { group N; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-n-phenyl-n-(thiophen-2-ylmethyl)piperidin-4-amine" "sanbosten" "thenaldine" "thenophenopiperidine" "tenalidina" "thenalidinum" "thenalidinum [inn-latin]" "1-methyl-4-n-2-thenylanilinopiperidine" "1-methyl-4-amino-n-phenyl-n-(2-thenyl)piperidine" "4-piperidinamine, 1-methyl-n-phenyl-n-(2-thienylmethyl)-" "piperidine, 1-methyl-4-(n-2-thenylanilino)-" "sandostene" );
standardThermochemistry
{
    dHf_298   268030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     654.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=597190.0
}
