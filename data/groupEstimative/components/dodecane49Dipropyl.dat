/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecane, 4,9-dipropyl-  (C18H38, CAS 3054-63-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecane49Dipropyl;
formula     C18H38;
CAS         3054-63-5;
InChIKey    SUVYZSWABJDNFR-UHFFFAOYSA-N;
MW          254.502;      // g/mol [origin=calculated method=formula-sum]
Tc          773.76;      // K   [origin=predictive method=joback]
Pc          11.648;      // bar [origin=predictive method=joback]
omega       0.7425;      // -   [origin=predictive method=lee-kesler]
Tb          610.56;      // K   [origin=predictive method=joback]
HvapTb      54886.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.838 1.72568 -0.0009618 2.02e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,9-dipropyldodecane" "4,9-di-n-propyldodecane" "dodecane,9-dipropyl-" );
standardThermochemistry
{
    dHf_298   -425410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     838.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95800.0
}
