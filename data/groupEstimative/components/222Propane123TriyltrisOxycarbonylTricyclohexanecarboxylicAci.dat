/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2',2''-[propane-1,2,3-triyltris(oxycarbonyl)]tricyclohexanecarboxylic acid  (C27H38O12, CAS 68901-23-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222Propane123TriyltrisOxycarbonylTricyclohexanecarboxylicAci;
formula     C27H38O12;
CAS         68901-23-5;
InChIKey    IZWUWCWNWYLTHQ-UHFFFAOYSA-N;
MW          554.589;      // g/mol [origin=calculated method=formula-sum]
Tc          1851.71;      // K   [origin=predictive method=joback]
Pc          11.082;      // bar [origin=predictive method=joback]
omega       0.7767;      // -   [origin=predictive method=lee-kesler]
Tb          1472.75;      // K   [origin=predictive method=joback]
HvapTb      149381.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.308 2.8495 -0.001459 1.665e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 14; } { group CH; count 7; } { group COOH; count 3; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 12; } { group CH_ring; count 6; } { group COOH; count 3; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,3-bis[(2-carboxycyclohexyl)carbonyloxy]propoxycarbonyl]cyclohexane-1-carboxylic acid" "1,2-cyclohexanedicarboxylic acid, 1,2,3-propanetriyl ester" "1,2-cyclohexanedicarboxylic acid, 1,1',1''-(1,2,3-propanetriyl) ester" "glycerol tri(hexahydrophthalate)" "propane-1,2,3-triyl tris(cyclohexane-1,2-dicarboxylate)" "2-[2,3-bis[(2-carboxycyclohexanecarbonyl)oxy]propoxycarbonyl]cyclohexane-1-carboxylic acid" );
standardThermochemistry
{
    dHf_298   -2506600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1292.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1738600.0
}
