/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hexadecanol  (C16H34O, CAS 36653-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hexadecanol;
formula     C16H34O;
CAS         36653-82-4;
InChIKey    BXWNKGSJHAJOGX-UHFFFAOYSA-N;
MW          242.447;      // g/mol [origin=calculated method=formula-sum]
Tc          817.70;      // K   [origin=predictive method=joback]
Pc          14.112;      // bar [origin=predictive method=joback]
omega       1.0923;      // -   [origin=predictive method=lee-kesler]
Tb          657.86;      // K   [origin=predictive method=joback]
HvapTb      67889.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.365 1.55782 -0.000877 1.89e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecan-1-ol" "cetyl alcohol" "cetanol" "hexadecanol" "palmityl alcohol" "n-cetyl alcohol" "hexadecyl alcohol" "ethal" "ethol" "n-1-hexadecanol" "cetaffine" "cetylol" );
standardThermochemistry
{
    dHf_298   -525800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     830.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-52980.0
}
