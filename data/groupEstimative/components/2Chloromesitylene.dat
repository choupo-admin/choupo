/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloromesitylene  (C9H11Cl, CAS 1667-04-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloromesitylene;
formula     C9H11Cl;
CAS         1667-04-5;
InChIKey    WDZACGWEPQLKOM-UHFFFAOYSA-N;
MW          154.637;      // g/mol [origin=calculated method=formula-sum]
Tc          702.28;      // K   [origin=predictive method=joback]
Pc          29.763;      // bar [origin=predictive method=joback]
omega       0.3972;      // -   [origin=predictive method=lee-kesler]
Tb          484.57;      // K   [origin=predictive method=joback]
HvapTb      44275.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.59 0.60826 -0.00031628 5.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 3; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-1,3,5-trimethyl-benzene" "2-chloro-1,3,5-trimethylbenzene" "chloromesitylene" "mesityl chloride" "mesitylene, 2-chloro-" "benzene, 2-chloro-1,3,5-trimethyl-" "2-chloro-1,3,5-trimethyl-benzene" "2,6-trimethylchlorobenzene" "2,6-trimethylmonochlorobenzene" "1-chloro-2,6-trimethylbenzene" "2-chloro-1,5-trimethylbenzene" "1-chloro-2,4,6-trimethylbenzene" );
standardThermochemistry
{
    dHf_298   -42710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=96490.0
}
