/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-dichlorohexane  (C6H12Cl2, CAS 2163-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Dichlorohexane;
formula     C6H12Cl2;
CAS         2163-00-0;
InChIKey    OVISMSJCKCDOPU-UHFFFAOYSA-N;
MW          155.062;      // g/mol [origin=calculated method=formula-sum]
Tc          591.89;      // K   [origin=predictive method=joback]
Pc          28.658;      // bar [origin=predictive method=joback]
omega       0.4204;      // -   [origin=predictive method=lee-kesler]
Tb          411.74;      // K   [origin=predictive method=joback]
HvapTb      37720.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.216 0.5874 -0.0003434 7.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6-bis(chloranyl)hexane" "hexane, 1,6-dichloro-" "hexamethylene dichloride" "hexane,6-dichloro-" "hexamethylene chloride" "ovismsjckcdopu-uhfffaoysa-" "k903" );
standardThermochemistry
{
    dHf_298   -198650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-24220.0
}
