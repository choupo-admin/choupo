/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-diisocyanatonaphthalene  (C12H6N2O2, CAS 3173-72-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Diisocyanatonaphthalene;
formula     C12H6N2O2;
CAS         3173-72-6;
InChIKey    SBJCUZQNHOLYMD-UHFFFAOYSA-N;
MW          210.192;      // g/mol [origin=calculated method=formula-sum]
Tc          905.96;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.8301;      // -   [origin=predictive method=lee-kesler]
Tb          663.12;      // K   [origin=predictive method=joback]
HvapTb      66610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group dCd; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-naphthalene diisocyanate" "1,5-naphthylene diisocyanate" "naphthalene, 1,5-diisocyanato-" "1,5-naphthylene di-isocyanate" "1,5-naphthyl diisocyanate" "1,5-naphthalene diisocyanate [diisocyanates]" "isocyanic acid, 1,5-naphthylene ester" "naphthalene,5-diisocyanato-" "naphthalene 1,5-diisocyanate" "isocyanic acid,5-naphthylene ester" "h176" );
