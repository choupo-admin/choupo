/*--------------------------------*- Choupo -*-----------------------*\
  Component: napropamide  (C17H21NO2, CAS 15299-99-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        napropamide;
formula     C17H21NO2;
CAS         15299-99-7;
InChIKey    WXZVAROIGSFCFJ-UHFFFAOYSA-N;
MW          271.36;      // g/mol [origin=calculated method=formula-sum]
Tc          943.55;      // K   [origin=predictive method=joback]
Pc          19.983;      // bar [origin=predictive method=joback]
omega       0.9150;      // -   [origin=predictive method=lee-kesler]
Tb          727.49;      // K   [origin=predictive method=joback]
HvapTb      68825.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.128 1.51536 -0.00098798 2.4586e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 7; } { group AC; count 3; } { group CH-O; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group O; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-2-naphthalen-1-yloxy-propanamide" "napropamid" "devrinol" "waylay" "racemic devrinol" "n,n-diethyl-2-(1-naphthyloxy)propanamide" "propanamide, n,n-diethyl-2-(1-naphthalenyloxy)-" "propionamide, n,n-diethyl-2-(1-naphthyloxy)-" "napropamide [iso:prop]" "n,n-diethyl-2-(1-naphthyloxy)propionamide" "n,n-diethyl-2-(naphthalen-1-yloxy)propanamide" "n,n-diethyl-2-(1-naphthalenyloxy)propanamide" );
standardThermochemistry
{
    dHf_298   -160630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176110.0
}
