/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl isopropyl sulfide  (C7H16S, CAS 44657-76-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertButylIsopropylSulfide;
formula     C7H16S;
CAS         44657-76-3;
InChIKey    OBGJHUWOEJFPJS-UHFFFAOYSA-N;
MW          132.265;      // g/mol [origin=calculated method=formula-sum]
Tc          629.74;      // K   [origin=predictive method=joback]
Pc          29.345;      // bar [origin=predictive method=joback]
omega       0.2935;      // -   [origin=predictive method=lee-kesler]
Tb          424.87;      // K   [origin=predictive method=joback]
HvapTb      36309.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.03 0.79499 -0.0004918 1.159e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group C; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group C; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-2-propan-2-ylsulfanyl-propane" "propane, 2-methyl-2-[(1-methylethyl)thio]-" "2-methyl-2-propan-2-ylsulfanylpropane" );
gibbsFormation
{
    dHf_298   -159970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41580.0
    phase     gas;
}
