/*--------------------------------*- Choupo -*-----------------------*\
  Component: fluorogesarol  (C14H9Cl3F2, CAS 475-26-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fluorogesarol;
formula     C14H9Cl3F2;
CAS         475-26-3;
InChIKey    CLSXNIPAOWPLFR-UHFFFAOYSA-N;
MW          321.572;      // g/mol [origin=calculated method=formula-sum]
Tc          937.06;      // K   [origin=predictive method=joback]
Pc          22.590;      // bar [origin=predictive method=joback]
omega       0.6348;      // -   [origin=predictive method=lee-kesler]
Tb          690.40;      // K   [origin=predictive method=joback]
HvapTb      62471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.35 1.2327 -0.00093512 2.662e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 1; } { group CCl3; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 2; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-4-[2,2,2-tris(chloranyl)-1-(4-fluorophenyl)ethyl]benzene" "dfdt" "fluoro-ddt" "p,p'-fluoro-ddt" "p,p'-difluorodiphenyltrichloroethane" "1,1-bis(p-fluorophenyl)2,2,2-trichloroethane" "difluorodiphenyltrichloroethane" "ho-2,474" "difluoro diphenyl trichloroethane" "ethane, 1,1,1-trichloro-2,2-bis(p-fluorophenyl)-" "1,1,1-trichloro-2,2-bis(p-fluorophenyl)ethane" "1,1-bis(p-fluorophenyl) 2,2,2-trichloroethane" );
standardThermochemistry
{
    dHf_298   -335640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-152450.0
}
