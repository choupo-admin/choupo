/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5,8,11,14,17,20-heptaoxatetracosan-22-ol, 4,7,10,13,16,19-hexamethyl-  (C23H48O8, CAS 72187-28-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25811141720Heptaoxatetracosan22Ol4710131619Hexamethyl;
formula     C23H48O8;
CAS         72187-28-1;
InChIKey    YELAUJGAFYBBGT-UHFFFAOYSA-N;
MW          452.629;      // g/mol [origin=calculated method=formula-sum]
Tc          1201.24;      // K   [origin=predictive method=joback]
Pc          8.666;      // bar [origin=predictive method=joback]
omega       0.7394;      // -   [origin=predictive method=lee-kesler]
Tb          971.88;      // K   [origin=predictive method=joback]
HvapTb      97625.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (153.998 1.82186 -0.0005032 -1.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 2; } { group CH; count 6; } { group CH3O; count 1; } { group CH2O; count 5; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 8; } { group CH; count 7; } { group OH; count 1; } { group O; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[1-[1-[1-[1-[1-(1-methoxypropan-2-yloxy)propan-2-yloxy]propan-2-yloxy]propan-2-yloxy]propan-2-yloxy]propan-2-yloxy]butan-2-ol" "5,8,11,14,17,20,23-heptaoxatetracosan-3-ol, 6,9,12,15,18,21-hexamethyl-" );
gibbsFormation
{
    dHf_298   -1632780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1115.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-746120.0
    phase     gas;
}
