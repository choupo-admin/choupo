/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dihydro-2-methylbenzofuran  (C9H10O, CAS 1746-11-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dihydro2Methylbenzofuran;
formula     C9H10O;
CAS         1746-11-8;
InChIKey    BWCJVGMZEQDOMY-UHFFFAOYSA-N;
MW          134.178;      // g/mol [origin=calculated method=formula-sum]
Tc          696.37;      // K   [origin=predictive method=joback]
Pc          36.955;      // bar [origin=predictive method=joback]
omega       0.3901;      // -   [origin=predictive method=lee-kesler]
Tb          470.87;      // K   [origin=predictive method=joback]
HvapTb      42989.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.82 0.86832 -0.00063626 1.871e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-2,3-dihydro-1-benzofuran" "2-methyl-2,3-dihydrobenzofuran" "benzofuran, 2,3-dihydro-2-methyl-" "2-methylcoumaran" "benzofuran, 2,3-dihydromethyl-" "benzofuran,3-dihydro-2-methyl-" "2-methyl-2,3-dihydro-benzofuran" "2-methyl-2,3-dihydrobenzo[b]furan" );
standardThermochemistry
{
    dHf_298   -63230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     252.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102310.0
}
