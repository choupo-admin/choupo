/*--------------------------------*- Choupo -*-----------------------*\
  Component: styrene-butadiene copolymer  (C12H14, CAS 9003-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        styreneButadieneCopolymer;
formula     C12H14;
CAS         9003-55-8;
InChIKey    MTAZNLWOLGHBHU-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          712.35;      // K   [origin=predictive method=joback]
Pc          24.975;      // bar [origin=predictive method=joback]
omega       0.3321;      // -   [origin=predictive method=lee-kesler]
Tb          492.28;      // K   [origin=predictive method=joback]
HvapTb      42866.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.08 0.7987 -0.0003141 -7.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 3; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 3; } { group dCH; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "buta-1,3-diene;ethenylbenzene" "poly(styrene-co-butadiene)" "polystyrene-block-polybutadiene-block-polystyrene" "styrene 1,3-butadiene polymer" "buta-1,3-diene; styrene" "kopolymer butadien styrenovy" "buta-1,3-diene; ethenylbenzene" "benzene, ethenyl-, polymer with 1,3-butadiene, chlorinated" "benzene, ethenyl-, polymer with 1,3-butadiene, ethoxylated" "benzene, ethenyl-, polymer with 1,3-butadiene, hydrogenated" "benzene, ethenyl-, polymer with 1,3-butadiene, carboxy-terminated" "hydrogenated styrene-butadiene polymer" );
gibbsFormation
{
    dHf_298   210190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     610.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=321330.0
    phase     gas;
}
