/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-hydroxy-2-(4-hydroxyphenyl)acetate  (C10H12O4, CAS 68758-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Hydroxy24HydroxyphenylAcetate;
formula     C10H12O4;
CAS         68758-68-9;
InChIKey    VLOUFSKXRCPIQR-UHFFFAOYSA-N;
MW          196.202;      // g/mol [origin=calculated method=formula-sum]
Tc          895.17;      // K   [origin=predictive method=joback]
Pc          39.407;      // bar [origin=predictive method=joback]
omega       1.2952;      // -   [origin=predictive method=lee-kesler]
Tb          685.66;      // K   [origin=predictive method=joback]
HvapTb      76842.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.009 1.01462 -0.00074676 2.186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-(4-hydroxyphenyl)-2-oxidanyl-ethanoate" "ethyl 4-hydroxymandelate" "ethyl 4-hydroxy-dl-mandelate" "ethyl alpha,4-dihydroxyphenylacetate" "ethyl hydroxy(4-hydroxyphenyl)acetate" "4-(2-ethoxy-1-hydroxy-2-oxoethyl)phenol" "benzeneacetic acid, alpha,4-dihydroxy-, ethyl ester" "2-hydroxy-2-(4-hydroxyphenyl)acetic acid ethyl ester" "benzeneacetic acid, .alpha.,4-dihydroxy-, ethyl ester" );
gibbsFormation
{
    dHf_298   -665300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-458520.0
    phase     gas;
}
