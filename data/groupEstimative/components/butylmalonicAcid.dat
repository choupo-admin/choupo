/*--------------------------------*- Choupo -*-----------------------*\
  Component: butylmalonic acid  (C7H12O4, CAS 534-59-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylmalonicAcid;
formula     C7H12O4;
CAS         534-59-8;
InChIKey    MCRZWYDXIGCFKO-UHFFFAOYSA-N;
MW          160.169;      // g/mol [origin=calculated method=formula-sum]
Tc          855.05;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       1.1377;      // -   [origin=predictive method=lee-kesler]
Tb          650.34;      // K   [origin=predictive method=joback]
HvapTb      65116.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.043 0.77632 -0.0005054 1.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butylpropanedioic acid" "2-butylmalonic acid" "butylmalonate" "2-butylmalonate" "propanedioic acid, butyl-" "n-butylmalonic acid" "2-n-butylmalonic acid" "1,1-pentanedicarboxylic acid" "butyl malonate" "n-butyl malonate" "2-n-butylmalonate" "malonic acid, butyl-" );
gibbsFormation
{
    dHf_298   -893630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-682200.0
    phase     gas;
}
