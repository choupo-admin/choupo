/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentanone, 2-(1-hydroxypentyl)-  (C10H18O2, CAS 42558-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentanone21Hydroxypentyl;
formula     C10H18O2;
CAS         42558-01-0;
InChIKey    DYVAUIYAEICDNS-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          800.05;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       0.9488;      // -   [origin=predictive method=lee-kesler]
Tb          603.24;      // K   [origin=predictive method=joback]
HvapTb      58649.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.647 0.95712 -0.0004372 4.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 2; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1-oxidanylpentyl)cyclopentan-1-one" "2-(1-hydroxypentyl)cyclopentan-1-one" "2-(1-hydroxypentyl)cyclopentanone" "cyclopentanone,2-(1-hydroxypentyl)-" "2-(1-hydroxypentyl)cyclopentan-1-one;2-(1-hydroxypentyl)cyclopentanone" );
standardThermochemistry
{
    dHf_298   -484460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-191980.0
}
