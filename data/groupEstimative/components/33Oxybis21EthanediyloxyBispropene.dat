/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3'-(oxybis(2,1-ethanediyloxy))bispropene  (C10H18O3, CAS 57947-82-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Oxybis21EthanediyloxyBispropene;
formula     C10H18O3;
CAS         57947-82-7;
InChIKey    XSSOJMFOKGTAFU-UHFFFAOYSA-N;
MW          186.251;      // g/mol [origin=calculated method=formula-sum]
Tc          657.51;      // K   [origin=predictive method=joback]
Pc          21.734;      // bar [origin=predictive method=joback]
omega       0.6781;      // -   [origin=predictive method=lee-kesler]
Tb          489.02;      // K   [origin=predictive method=joback]
HvapTb      43744.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.316 0.7242 -0.000233 -2.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 2; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH2; count 2; } { group dCH; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-(2-prop-2-enoxyethoxy)ethoxy]prop-1-ene" "1-propene, 3,3'-(oxybis(2,1-ethanediyloxy))bis-" "1-propene, 3,3'-[oxybis(2,1-ethanediyloxy)]bis-" "diethyleneglycol diallyl ether" );
standardThermochemistry
{
    dHf_298   -395530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-106000.0
}
