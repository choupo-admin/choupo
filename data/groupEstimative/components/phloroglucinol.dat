/*--------------------------------*- Choupo -*-----------------------*\
  Component: phloroglucinol  (C6H6O3, CAS 108-73-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phloroglucinol;
formula     C6H6O3;
CAS         108-73-6;
InChIKey    QCDYQQDYXPDABM-UHFFFAOYSA-N;
MW          126.111;      // g/mol [origin=calculated method=formula-sum]
Tc          858.81;      // K   [origin=predictive method=joback]
Pc          99.800;      // bar [origin=predictive method=joback]
omega       0.9847;      // -   [origin=predictive method=lee-kesler]
Tb          600.44;      // K   [origin=predictive method=joback]
HvapTb      69606.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.53 1.0182 -0.00116992 5.099e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3,5-triol" "1,3,5-benzenetriol" "1,3,5-trihydroxybenzene" "phloroglucin" "phloroglucine" "spasfon-lyoc" "benzene-s-triol" "s-trihydroxybenzene" "5-hydroxyresorcinol" "benzene, trihydroxy" "sym-trihydroxybenzene" "3,5-dihydroxyphenol" );
standardThermochemistry
{
    dHf_298   -451100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-342180.0
}
