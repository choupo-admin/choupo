/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-hydroxyphenoxy)propanoic acid  (C9H10O4, CAS 67648-61-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24HydroxyphenoxyPropanoicAcid;
formula     C9H10O4;
CAS         67648-61-7;
InChIKey    AQIHDXGKQHFBNW-UHFFFAOYSA-N;
MW          182.175;      // g/mol [origin=calculated method=formula-sum]
Tc          914.98;      // K   [origin=predictive method=joback]
Pc          43.169;      // bar [origin=predictive method=joback]
omega       1.0614;      // -   [origin=predictive method=lee-kesler]
Tb          680.31;      // K   [origin=predictive method=joback]
HvapTb      70104.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.7 0.92802 -0.00071816 2.272e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH-O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-oxidanylphenoxy)propanoic acid" "2-(4-hydroxyphenoxy)propionic acid" "2-(4-hydroxyphenoxy)propanoicacid" "(r)-2-(4-hydrophenoxy)propionicacid" "(2r)-2-(4-hydroxyphenoxy)propanoic acid" "propanoic acid, 2-(4-hydroxyphenoxy)-, (2s)-" "2-(4-hydroxy-phenoxy)-propanoic acid" "propanoic acid,2-(4-hydroxyphenoxy)-" "propanoic acid, 2-(4-hydroxyphenoxy)-" );
gibbsFormation
{
    dHf_298   -657640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-468660.0
    phase     gas;
}
