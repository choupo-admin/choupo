/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(dimethylamino)diphenylsilane  (C16H22N2Si, CAS 1027-62-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H22N2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bisDimethylaminoDiphenylsilane;
formula     C16H22N2Si;
CAS         1027-62-9;
InChIKey    FTURFVPIEOKJBC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          270.451;      // g/mol [origin=calculated method=formula-sum]
Tc          875.07;      // K   [origin=predictive method=joback]
Pc          20.364;      // bar [origin=predictive method=joback]
omega       0.5848;      // -   [origin=predictive method=lee-kesler]
Tb          645.32;      // K   [origin=predictive method=joback]
HvapTb      60142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.03 1.40768 -0.0007194 8.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 10; } { group AC; count 2; } { group CH3N; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[dimethylamino(diphenyl)silyl]-n-methyl-methanamine" "silanediamine, n,n,n',n'-tetramethyl-1,1-diphenyl-" "n,n,n',n'-tetramethyl-1,1-diphenylsilanediamine" "silanediamine,n,n',n'-tetramethyl-1,1-diphenyl-" "n-[dimethylamino(diphenyl)silyl]-n-methylmethanamine" );
standardThermochemistry
{
    dHf_298   122930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     725.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=425460.0
}
