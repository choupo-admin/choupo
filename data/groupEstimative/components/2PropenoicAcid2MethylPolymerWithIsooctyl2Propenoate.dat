/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, polymer with isooctyl 2-propenoate  (C15H26O4, CAS 66251-42-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2MethylPolymerWithIsooctyl2Propenoate;
formula     C15H26O4;
CAS         66251-42-1;
InChIKey    VVUXLKACYYLEIW-UHFFFAOYSA-N;
MW          270.369;      // g/mol [origin=calculated method=formula-sum]
Tc          934.31;      // K   [origin=predictive method=joback]
Pc          15.319;      // bar [origin=predictive method=joback]
omega       0.9963;      // -   [origin=predictive method=lee-kesler]
Tb          740.73;      // K   [origin=predictive method=joback]
HvapTb      72201.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.725 1.18446 -0.0004067 -4.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylheptyl prop-2-enoate;2-methylprop-2-enoic acid" "6-methylheptyl prop-2-enoate; 2-methylprop-2-enoic acid" );
gibbsFormation
{
    dHf_298   -896310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     929.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-518930.0
    phase     gas;
}
