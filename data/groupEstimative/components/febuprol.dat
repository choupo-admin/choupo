/*--------------------------------*- Choupo -*-----------------------*\
  Component: febuprol  (C13H20O3, CAS 3102-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        febuprol;
formula     C13H20O3;
CAS         3102-00-9;
InChIKey    WBLXZPHICYCDGN-UHFFFAOYSA-N;
MW          224.3;      // g/mol [origin=calculated method=formula-sum]
Tc          847.65;      // K   [origin=predictive method=joback]
Pc          23.360;      // bar [origin=predictive method=joback]
omega       1.1221;      // -   [origin=predictive method=lee-kesler]
Tb          660.30;      // K   [origin=predictive method=joback]
HvapTb      67919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.775 1.07342 -0.0005262 6.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butoxy-3-phenoxy-propan-2-ol" "valbil" "1-butoxy-3-phenoxy-2-propanol" "2-propanol, 1-butoxy-3-phenoxy-" "febuprolum [inn-latin]" "1-n-butyl-3-phenyl diether glycerol" "2-propanol, 1-n-butoxy-3-phenoxy-" "1-butoxy-3-phenoxypropan-2-ol" "3-n-butoxy-1-phenoxy-2-propanol" "3-butoxy-1-phenoxy-propanol-(2)" "febuprol (inn)" "febuprol [inn]" );
gibbsFormation
{
    dHf_298   -497070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-178270.0
    phase     gas;
}
