/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethane, 2-(p-bromophenyl)-1,1,1-trichloro-2-phenyl-,  (C14H10BrCl3, CAS 39211-93-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethane2PBromophenyl111Trichloro2Phenyl;
formula     C14H10BrCl3;
CAS         39211-93-3;
InChIKey    NBTGDHBAHMODDU-UHFFFAOYSA-N;
MW          364.488;      // g/mol [origin=calculated method=formula-sum]
Tc          1034.31;      // K   [origin=predictive method=joback]
Pc          26.846;      // bar [origin=predictive method=joback]
omega       0.6471;      // -   [origin=predictive method=lee-kesler]
Tb          753.04;      // K   [origin=predictive method=joback]
HvapTb      69878.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.64 1.3068 -0.00104076 3.14e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH; count 1; } { group CCl3; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-[2,2,2-tris(chloranyl)-1-phenyl-ethyl]benzene" "1-bromo-4-(2,2,2-trichloro-1-phenylethyl)benzene" "nbtgdhbahmoddu-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   94380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=261120.0
    phase     gas;
}
