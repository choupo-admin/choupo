/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 4-isocyanatobenzoate  (C10H9NO3, CAS 30806-83-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl4Isocyanatobenzoate;
formula     C10H9NO3;
CAS         30806-83-8;
InChIKey    CFEPCPHKICBCJV-UHFFFAOYSA-N;
MW          191.186;      // g/mol [origin=calculated method=formula-sum]
Tc          803.24;      // K   [origin=predictive method=joback]
Pc          31.456;      // bar [origin=predictive method=joback]
omega       0.7298;      // -   [origin=predictive method=lee-kesler]
Tb          584.95;      // K   [origin=predictive method=joback]
HvapTb      57731.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(ethoxycarbonyl)phenyl isocyanate" "ethyl para-isocyanatobenzoate" "4-carboethoxyphenyl isocyanate" "4-isocyanato-benzoic acid ethyl ester" "benzoicacid, p-isocyanato-, ethyl ester (6ci,8ci); (p-ethoxycarbonyl)phenylisocyanate; 4-(ethoxycarbonyl)phenyl isocyanate; 4-isocyanatobenzoic acid ethylester; ethyl 4-isocyanatobenzoate; ethyl p-isocyanatobenzoate" );
