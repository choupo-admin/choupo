/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-oxathiane, 4,6-dimethyl-, cis-  (C6H12OS, CAS 22452-25-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Oxathiane46DimethylCis;
formula     C6H12OS;
CAS         22452-25-1;
InChIKey    TWCXFZMBALMLNT-UHFFFAOYSA-N;
MW          132.221;      // g/mol [origin=calculated method=formula-sum]
Tc          648.00;      // K   [origin=predictive method=joback]
Pc          37.317;      // bar [origin=predictive method=joback]
omega       0.2831;      // -   [origin=predictive method=lee-kesler]
Tb          426.54;      // K   [origin=predictive method=joback]
HvapTb      39392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.09 0.68085 -0.000333 4.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group FCH2O; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,6-dimethyl-1,3-oxathiane" "1,3-oxathiane, 4,6-dimethyl-, trans-" "cis-4,6-dimethyl-1,3-oxathiane" "trans-4,6-dimethyl-1,3-oxathiane" "(4r,6s)-4,6-dimethyl-1,3-oxathiane" );
standardThermochemistry
{
    dHf_298   -219930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     315.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29880.0
}
