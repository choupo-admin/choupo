/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiophene-3-carboxylic acid  (C5H4O2S, CAS 88-13-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiophene3CarboxylicAcid;
formula     C5H4O2S;
CAS         88-13-1;
InChIKey    YNVOMSDITJMNET-UHFFFAOYSA-N;
MW          128.145;      // g/mol [origin=calculated method=formula-sum]
Tc          774.21;      // K   [origin=predictive method=joback]
Pc          55.278;      // bar [origin=predictive method=joback]
omega       0.6133;      // -   [origin=predictive method=lee-kesler]
Tb          530.59;      // K   [origin=predictive method=joback]
HvapTb      51512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.8 0.53071 -0.00042982 1.363e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 1; } { group COOH; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-thiophenecarboxylic acid" "3-thenoic acid" "3-thiophenezoic acid" "beta-thiophenic acid" "3-carboxythiophene" "3-thiophenic acid" "3-thiophenoic acid" "3-thienylcarboxylic acid" "thiophene-3-carboxylicacid" "beta-thiophenecarboxylic acid" ".beta.-thiophenecarboxylic acid" "3-thiophene carboxylic acid" );
gibbsFormation
{
    dHf_298   -266630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     365.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-218280.0
    phase     gas;
}
