/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-iodohexane  (C6H13I, CAS 31294-91-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Iodohexane;
formula     C6H13I;
CAS         31294-91-4;
InChIKey    QQKICFXKOIDMSQ-UHFFFAOYSA-N;
MW          212.07;      // g/mol [origin=calculated method=formula-sum]
Tc          634.88;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.3212;      // -   [origin=predictive method=lee-kesler]
Tb          429.58;      // K   [origin=predictive method=joback]
HvapTb      37935.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.443 0.61874 -0.0003872 9.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-iodanylhexane" "hexane, 3-iodo-" "3-didohexane" "3-iodohexane;" );
gibbsFormation
{
    dHf_298   -95580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55320.0
    phase     gas;
}
