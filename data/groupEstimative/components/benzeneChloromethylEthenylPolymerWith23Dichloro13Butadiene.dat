/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, (chloromethyl)ethenyl-, polymer with 2,3-dichloro-1,3-butadiene  (C13H13Cl3, CAS 72319-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneChloromethylEthenylPolymerWith23Dichloro13Butadiene;
formula     C13H13Cl3;
CAS         72319-12-1;
InChIKey    DZKFEDAVOIXTRH-UHFFFAOYSA-N;
MW          275.597;      // g/mol [origin=calculated method=formula-sum]
Tc          870.18;      // K   [origin=predictive method=joback]
Pc          20.419;      // bar [origin=predictive method=joback]
omega       0.4945;      // -   [origin=predictive method=lee-kesler]
Tb          632.19;      // K   [origin=predictive method=joback]
HvapTb      59069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.601 0.8544 -0.00036726 9.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH2=C; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2Cl; count 1; } { group Cl_C=C_; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(chloranyl)buta-1,3-diene;1-(chloromethyl)-2-ethenyl-benzene" "2,3-dichloro-1,3-butadiene, (chloromethyl)ethenylbenzene polymer" );
gibbsFormation
{
    dHf_298   111280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     735.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=267230.0
    phase     gas;
}
