/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-2-pentyl-1,3-dioxolane  (C9H18O2, CAS 1599-49-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl2Pentyl13Dioxolane;
formula     C9H18O2;
CAS         1599-49-1;
InChIKey    GWMSIWCZZKMUQM-UHFFFAOYSA-N;
MW          158.241;      // g/mol [origin=calculated method=formula-sum]
Tc          660.73;      // K   [origin=predictive method=joback]
Pc          26.218;      // bar [origin=predictive method=joback]
omega       0.4968;      // -   [origin=predictive method=lee-kesler]
Tb          470.03;      // K   [origin=predictive method=joback]
HvapTb      44596.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.196 0.95804 -0.00051 8.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 4-methyl-2-pentyl-" "4-methyl-2-pentyl-dioxolane" "2-amyl-4-methyl-1,3-dioxolane" "4-methyl-2-pentyl-1,3-dioxolan" "hexaldehyde propylene glycol acetal" "hexanal propylene glycol acetal" "hexaldehyde propyleneglycol acetal" );
standardThermochemistry
{
    dHf_298   -452950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     311.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-118500.0
}
