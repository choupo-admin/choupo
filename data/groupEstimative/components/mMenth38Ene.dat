/*--------------------------------*- Choupo -*-----------------------*\
  Component: m-menth-3(8)-ene  (C10H18, CAS 13828-34-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mMenth38Ene;
formula     C10H18;
CAS         13828-34-7;
InChIKey    NBSQIOVLBNJEFJ-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          662.72;      // K   [origin=predictive method=joback]
Pc          26.598;      // bar [origin=predictive method=joback]
omega       0.3238;      // -   [origin=predictive method=lee-kesler]
Tb          454.47;      // K   [origin=predictive method=joback]
HvapTb      39150.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.4 0.99836 -0.000572 1.201e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3-propan-2-ylidene-cyclohexane" "cyclohexane, 1-methyl-3-(1-methylethylidene)-" "1-methyl-3-propan-2-ylidenecyclohexane" );
standardThermochemistry
{
    dHf_298   -129170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94680.0
}
