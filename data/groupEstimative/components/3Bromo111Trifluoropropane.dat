/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-1,1,1-trifluoropropane  (C3H4BrF3, CAS 460-32-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo111Trifluoropropane;
formula     C3H4BrF3;
CAS         460-32-2;
InChIKey    SAUGMJLWYLQPEM-UHFFFAOYSA-N;
MW          176.963;      // g/mol [origin=calculated method=formula-sum]
Tc          495.74;      // K   [origin=predictive method=joback]
Pc          41.463;      // bar [origin=predictive method=joback]
omega       0.3520;      // -   [origin=predictive method=lee-kesler]
Tb          328.98;      // K   [origin=predictive method=joback]
HvapTb      24960.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.152 0.4882 -0.0004318 1.473e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group Br; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group F; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-1,1,1-tris(fluoranyl)propane" "propane,3-bromo-1,1,1-trifluoro-" "1-bromo-3,3,3-trifluoropropane;3,3,3-trifluoropropyl bromide;" );
gibbsFormation
{
    dHf_298   -676000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-592890.0
    phase     gas;
}
