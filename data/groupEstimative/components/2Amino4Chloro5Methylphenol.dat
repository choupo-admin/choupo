/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-4-chloro-5-methylphenol  (C7H8ClNO, CAS 53524-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino4Chloro5Methylphenol;
formula     C7H8ClNO;
CAS         53524-27-9;
InChIKey    QDGJHZNOQSIFAT-UHFFFAOYSA-N;
MW          157.597;      // g/mol [origin=calculated method=formula-sum]
Tc          833.88;      // K   [origin=predictive method=joback]
Pc          49.593;      // bar [origin=predictive method=joback]
omega       0.7240;      // -   [origin=predictive method=lee-kesler]
Tb          586.98;      // K   [origin=predictive method=joback]
HvapTb      62816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.68 0.69422 -0.00057428 2.009e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 1; } { group ACOH; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group OH_phenol; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-4-chloranyl-5-methyl-phenol" "phenol, 2-amino-4-chloro-5-methyl-" );
standardThermochemistry
{
    dHf_298   -133480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1110.0
}
