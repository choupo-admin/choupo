/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-butyl-4-ethyloxolan-2-one  (C10H18O2, CAS 72230-89-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Butyl4Ethyloxolan2One;
formula     C10H18O2;
CAS         72230-89-8;
InChIKey    XNKPSAQZOXYRRQ-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          682.78;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.5678;      // -   [origin=predictive method=lee-kesler]
Tb          493.60;      // K   [origin=predictive method=joback]
HvapTb      44023.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.026 1.34184 -0.0011784 4.48e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-butyl-4-ethyl-oxolan-2-one" "2(3h)-furanone, 4-butyl-4-ethyldihydro-" "4,5-dihydro-4-butyl-4-ethyl-2(3h)-furanone" );
standardThermochemistry
{
    dHf_298   -478970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-221790.0
}
