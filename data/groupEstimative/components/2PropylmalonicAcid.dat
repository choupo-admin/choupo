/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propylmalonic acid  (C6H10O4, CAS 616-62-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropylmalonicAcid;
formula     C6H10O4;
CAS         616-62-6;
InChIKey    VQDJODAWOFNASI-UHFFFAOYSA-N;
MW          146.142;      // g/mol [origin=calculated method=formula-sum]
Tc          835.20;      // K   [origin=predictive method=joback]
Pc          38.675;      // bar [origin=predictive method=joback]
omega       1.0913;      // -   [origin=predictive method=lee-kesler]
Tb          627.46;      // K   [origin=predictive method=joback]
HvapTb      62890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.952 0.68132 -0.000451 1.157e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propylpropanedioic acid" "propylmalonic acid" "butanedicarboxylic acid" "propanedioic acid, propyl-" "n-propylmalonic acid" "propylpropanedioic acid" "i564" );
standardThermochemistry
{
    dHf_298   -872990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-690620.0
}
