/*--------------------------------*- Choupo -*-----------------------*\
  Component: mesitylacetic acid  (C11H14O2, CAS 4408-60-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mesitylaceticAcid;
formula     C11H14O2;
CAS         4408-60-0;
InChIKey    CQWMQAKKAHTCSC-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          857.32;      // K   [origin=predictive method=joback]
Pc          27.730;      // bar [origin=predictive method=joback]
omega       0.8246;      // -   [origin=predictive method=lee-kesler]
Tb          638.41;      // K   [origin=predictive method=joback]
HvapTb      61506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.481 0.84226 -0.00047728 9.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 3; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,4,6-trimethylphenyl)ethanoic acid" "2,4,6-trimethylphenylacetic acid" "2-mesitylacetic acid" "mesityleneacetic acid" "2,4,6-trimethylbenzeneacetic acid" "2-(2,4,6-trimethylphenyl)acetic acid" "2-mesityleneacetic acid" "(2,4,6-trimethylphenyl)acetic acid" "mesityl-acetic acid" "2,4,6-tmpac" "(2,4,6-trimethyl-phenyl)-acetic acid" "2,4,6-trimethylbenzeneacetyl chloride" );
gibbsFormation
{
    dHf_298   -418520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-218650.0
    phase     gas;
}
