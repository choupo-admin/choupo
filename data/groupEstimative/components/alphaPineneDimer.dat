/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-pinene dimer  (C20H32, CAS 6993-66-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaPineneDimer;
formula     C20H32;
CAS         6993-66-4;
InChIKey    BMUDNYIETWSZJW-UHFFFAOYSA-N;
MW          272.476;      // g/mol [origin=calculated method=formula-sum]
Tc          922.94;      // K   [origin=predictive method=joback]
Pc          14.907;      // bar [origin=predictive method=joback]
omega       0.5312;      // -   [origin=predictive method=lee-kesler]
Tb          693.52;      // K   [origin=predictive method=joback]
HvapTb      59392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-229.63 2.58192 -0.00223228 8.452e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2_ring; count 4; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,6,6-trimethylbicyclo[3.1.1]hept-3-ene" "bicyclo(3.1.1)hept-2-ene, 2,6,6-trimethyl-, dimer" );
standardThermochemistry
{
    dHf_298   -206450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     688.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=245820.0
}
