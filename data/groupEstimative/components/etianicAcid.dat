/*--------------------------------*- Choupo -*-----------------------*\
  Component: etianic acid  (C20H32O2, CAS 438-08-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        etianicAcid;
formula     C20H32O2;
CAS         438-08-4;
InChIKey    PBXJGQQGODZSQR-WQBJWTDHSA-N;
MW          304.474;      // g/mol [origin=calculated method=formula-sum]
Tc          1081.40;      // K   [origin=predictive method=joback]
Pc          17.175;      // bar [origin=predictive method=joback]
omega       0.8530;      // -   [origin=predictive method=lee-kesler]
Tb          837.49;      // K   [origin=predictive method=joback]
HvapTb      74561.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-319.43 3.01454 -0.0026846 1.0139e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 5; } { group C; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 10; } { group CH_ring; count 5; } { group C_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5s,8r,9s,10s,13s,14s,17s)-10,13-dimethyl-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthrene-17-carboxylic acid" "etiocholanic acid" "androstane carboxylic acid" "androstane-17-carboxylic acid, (5beta,17beta)-" );
standardThermochemistry
{
    dHf_298   -576540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     738.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-78000.0
}
