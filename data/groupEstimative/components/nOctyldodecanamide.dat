/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-octyldodecanamide  (C20H41NO, CAS 69943-69-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nOctyldodecanamide;
formula     C20H41NO;
CAS         69943-69-7;
InChIKey    NBEJBMSIQHPHDT-UHFFFAOYSA-N;
MW          311.554;      // g/mol [origin=calculated method=formula-sum]
Tc          936.89;      // K   [origin=predictive method=joback]
Pc          10.666;      // bar [origin=predictive method=joback]
omega       0.9656;      // -   [origin=predictive method=lee-kesler]
Tb          761.24;      // K   [origin=predictive method=joback]
HvapTb      73296.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.143 1.95204 -0.0010941 2.2826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecanamide, n-octyl-" );
gibbsFormation
{
    dHf_298   -515240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1002.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77990.0
    phase     gas;
}
