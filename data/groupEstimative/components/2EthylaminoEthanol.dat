/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(ethylamino)ethanol  (C4H11NO, CAS 110-73-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylaminoEthanol;
formula     C4H11NO;
CAS         110-73-6;
InChIKey    MIJDSYMOBYNHOT-UHFFFAOYSA-N;
MW          89.138;      // g/mol [origin=calculated method=formula-sum]
Tc          600.47;      // K   [origin=predictive method=joback]
Pc          44.623;      // bar [origin=predictive method=joback]
omega       0.8438;      // -   [origin=predictive method=lee-kesler]
Tb          433.47;      // K   [origin=predictive method=joback]
HvapTb      47613.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.333 0.49402 -0.0002728 5.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanol, 2-(ethylamino)-" "ethyl ethanolamine" "2-ethylaminoethanol" "(2-hydroxyethyl)ethylamine" "n-ethylaminoethanol" "n-ethylethanolamine" "n-ethyl ethanolamine" "n-ethylmonoethanolamine" "2-n-monoethylaminoethanol" "2-ethylamino ethanol" "ethanol,2-(ethylamino)-" "agn-pc-0dajr5" );
standardThermochemistry
{
    dHf_298   -224650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64630.0
}
