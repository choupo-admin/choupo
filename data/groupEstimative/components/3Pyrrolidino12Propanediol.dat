/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pyrrolidino-1,2-propanediol  (C7H15NO2, CAS 85391-19-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Pyrrolidino12Propanediol;
formula     C7H15NO2;
CAS         85391-19-1;
InChIKey    MFPZRSWYUKWRIQ-UHFFFAOYSA-N;
MW          145.202;      // g/mol [origin=calculated method=formula-sum]
Tc          745.51;      // K   [origin=predictive method=joback]
Pc          43.742;      // bar [origin=predictive method=joback]
omega       1.3776;      // -   [origin=predictive method=lee-kesler]
Tb          571.80;      // K   [origin=predictive method=joback]
HvapTb      66583.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.568 1.0344 -0.0007628 2.262e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-pyrrolidin-1-ylpropane-1,2-diol" "3-(pyrrolidin-1-yl)propane-1,2-diol" "1,2-propanediol, 3-(1-pyrrolidinyl)-" "3-pyrrolidinylpropane-1,2-diol" "3-(1-pyrrolidinyl)propane-1,2-diol" "3-pyrrolidin-1-yl-propane-1,2-diol" "3-pyrrolidin-1-yl-1,2-propanediol" );
gibbsFormation
{
    dHf_298   -343040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-100880.0
    phase     gas;
}
