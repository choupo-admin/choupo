/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5,9-trimethyldecane  (C13H28, CAS 62108-22-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        259Trimethyldecane;
formula     C13H28;
CAS         62108-22-9;
InChIKey    YKAQOUURBLPHIN-UHFFFAOYSA-N;
MW          184.367;      // g/mol [origin=calculated method=formula-sum]
Tc          665.56;      // K   [origin=predictive method=joback]
Pc          16.769;      // bar [origin=predictive method=joback]
omega       0.5416;      // -   [origin=predictive method=lee-kesler]
Tb          495.72;      // K   [origin=predictive method=joback]
HvapTb      43368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.975 1.2566 -0.000693 1.42e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decane, 2,5,9-trimethyl-" );
gibbsFormation
{
    dHf_298   -327490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=51260.0
    phase     gas;
}
