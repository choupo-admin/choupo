/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cyclohexene-1-methanol, 6-methyl-  (C8H14O, CAS 5259-31-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Cyclohexene1Methanol6Methyl;
formula     C8H14O;
CAS         5259-31-4;
InChIKey    FNCRYRFSEYFWQZ-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          681.02;      // K   [origin=predictive method=joback]
Pc          35.179;      // bar [origin=predictive method=joback]
omega       0.6896;      // -   [origin=predictive method=lee-kesler]
Tb          488.86;      // K   [origin=predictive method=joback]
HvapTb      50493.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.979 0.83742 -0.00045468 7.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 2; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6-methylcyclohex-3-en-1-yl)methanol" "6-methyl-3-cyclohexene-1-methanol" "6-methyl-3-cyclohexene-1-methanol, mixture of cis and trans" "agn-pc-00maue" "6-methylcyclohex-3-ene-1-methanol" "3-cyclohexene-1-methanol,6-methyl-" "(6-methyl-1-cyclohex-3-enyl)methanol" "(6-methyl-3-cyclohexen-1-yl)methanol" "(6-methylcyclohex-3-enyl)methan-1-ol" "6-methyl-3-cyclohexene-1-methanol;6-methylcyclohex-3-enylmethanol;" );
standardThermochemistry
{
    dHf_298   -268920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-73640.0
}
