/*--------------------------------*- Choupo -*-----------------------*\
  Component: decyl trichloroacetate  (C12H21Cl3O2, CAS 65611-33-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decylTrichloroacetate;
formula     C12H21Cl3O2;
CAS         65611-33-8;
InChIKey    JVOWHDCGJSEUMO-UHFFFAOYSA-N;
MW          303.648;      // g/mol [origin=calculated method=formula-sum]
Tc          831.03;      // K   [origin=predictive method=joback]
Pc          16.565;      // bar [origin=predictive method=joback]
omega       0.7993;      // -   [origin=predictive method=lee-kesler]
Tb          641.44;      // K   [origin=predictive method=joback]
HvapTb      61572.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.589 1.23522 -0.0007674 1.734e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CCl3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group C; count 1; } { group Cl; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decyl 2,2,2-tris(chloranyl)ethanoate" "trichloroacetic acid, decyl ester" "decyl 2,2,2-trichloroacetate" "acetic acid, trichloro-, decyl ester" );
standardThermochemistry
{
    dHf_298   -664260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     736.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-293160.0
}
