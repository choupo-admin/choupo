/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl cinnamic acid  (C10H10O2, CAS 3029-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethylCinnamicAcid;
formula     C10H10O2;
CAS         3029-79-6;
InChIKey    JZINNAKNHHQBOS-UHFFFAOYSA-N;
MW          162.188;      // g/mol [origin=calculated method=formula-sum]
Tc          840.38;      // K   [origin=predictive method=joback]
Pc          33.763;      // bar [origin=predictive method=joback]
omega       0.7403;      // -   [origin=predictive method=lee-kesler]
Tb          609.73;      // K   [origin=predictive method=joback]
HvapTb      57914.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.39 0.88622 -0.00064076 1.838e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3-methylphenyl)prop-2-enoic acid" "2-propenoic acid,3-(3-methylphenyl)-, (2e)-" "2-propenoicacid, 3-(3-methylphenyl)-, (e)-; cinnamic acid, m-methyl-, (e)- (8ci);(e)-3-(3-tolyl)acrylic acid; (e)-3-(m-tolyl)-2-propenoic acid;3-methyl-trans-cinnamic acid; trans-3-(3-methylphenyl)-2-propenoic acid;trans-m-methylcinnamic acid" );
standardThermochemistry
{
    dHf_298   -257720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-127590.0
}
