/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dibromo-3-chloro-4-methylaniline  (C7H6Br2ClN, CAS 84483-22-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dibromo3Chloro4Methylaniline;
formula     C7H6Br2ClN;
CAS         84483-22-7;
InChIKey    XBSGYHXODZBFBM-UHFFFAOYSA-N;
MW          299.39;      // g/mol [origin=calculated method=formula-sum]
Tc          913.99;      // K   [origin=predictive method=joback]
Pc          46.849;      // bar [origin=predictive method=joback]
omega       0.7504;      // -   [origin=predictive method=lee-kesler]
Tb          648.64;      // K   [origin=predictive method=joback]
HvapTb      63996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.58 0.49702 -0.00032664 8.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 2; } { group ACCH3; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Cl; count 1; } { group Br; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis(bromanyl)-3-chloranyl-4-methyl-aniline" "3-chloro-2,6-dibromo-4-methylaniline" "3-chloro-2,6-dibromo-p-toluidine" "2,6-dibromo-3-chloro-4-methylphenylamine" "benzenamine,2,6-dibromo-3-chloro-4-methyl-" );
standardThermochemistry
{
    dHf_298   73550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=165110.0
}
