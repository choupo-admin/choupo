/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha2,alpha2'-(oxybis(ethylenethio))bis(6-nonyl-2,4-xylenol)  (C38H62O3S2, CAS 4142-74-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alpha2Alpha2OxybisEthylenethioBis6Nonyl24Xylenol;
formula     C38H62O3S2;
CAS         4142-74-9;
InChIKey    ZHEOXZXROVDONK-UHFFFAOYSA-N;
MW          631.031;      // g/mol [origin=calculated method=formula-sum]
Tc          1910.74;      // K   [origin=predictive method=joback]
Pc          6.412;      // bar [origin=predictive method=joback]
omega       0.1231;      // -   [origin=predictive method=lee-kesler]
Tb          1463.54;      // K   [origin=predictive method=joback]
HvapTb      149454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.592 3.45286 -0.00215896 5.486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 2; } { group ACCH2; count 3; } { group ACOH; count 2; } { group CH2O; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 22; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } { group O; count 1; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-[2-[2-[(5-methyl-3-nonyl-2-oxidanyl-phenyl)methylsulfanyl]ethoxy]ethylsulfanylmethyl]-6-nonyl-phenol" "phenol, 2,2'-(oxybis(2,1-ethanediylthiomethylene))bis(4-methyl-6-nonyl-" "phenol, 2,2'-[oxybis(2,1-ethanediylthiomethylene)]bis[4-methyl-6-nonyl-" "2,4-xylenol, alpha2,alpha2'-(oxybis(ethylenethio))bis(6-nonyl-" "2-[2-[2-[(2-hydroxy-5-methyl-3-nonylphenyl)methylsulfanyl]ethoxy]ethylsulfanylmethyl]-4-methyl-6-nonylphenol" );
gibbsFormation
{
    dHf_298   -803570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1585.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107380.0
    phase     gas;
}
