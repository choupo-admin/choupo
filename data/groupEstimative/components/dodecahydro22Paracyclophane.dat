/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecahydro[2.2]paracyclophane  (C16H28, CAS 283-68-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecahydro22Paracyclophane;
formula     C16H28;
CAS         283-68-1;
InChIKey    NJKSNKVRWTTWPA-UHFFFAOYSA-N;
MW          220.4;      // g/mol [origin=calculated method=formula-sum]
Tc          850.67;      // K   [origin=predictive method=joback]
Pc          20.254;      // bar [origin=predictive method=joback]
omega       0.4279;      // -   [origin=predictive method=lee-kesler]
Tb          611.12;      // K   [origin=predictive method=joback]
HvapTb      51844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-192.29 1.8828 -0.001127 2.396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 12; } { group CH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[8.2.2.24,7]hexadecane" "tricyclo(8.2.2.24,7)-hexadecane" "tricyclo[8.2.2.24,7]-hexadecane" );
gibbsFormation
{
    dHf_298   -218630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173680.0
    phase     gas;
}
