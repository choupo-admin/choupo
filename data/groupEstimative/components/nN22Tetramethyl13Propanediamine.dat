/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,2,2-tetramethyl-1,3-propanediamine  (C7H18N2, CAS 53369-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nN22Tetramethyl13Propanediamine;
formula     C7H18N2;
CAS         53369-71-4;
InChIKey    ULDIVZQLPBUHAG-UHFFFAOYSA-N;
MW          130.235;      // g/mol [origin=calculated method=formula-sum]
Tc          629.87;      // K   [origin=predictive method=joback]
Pc          30.323;      // bar [origin=predictive method=joback]
omega       0.4830;      // -   [origin=predictive method=lee-kesler]
Tb          441.50;      // K   [origin=predictive method=joback]
HvapTb      42564.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.148 0.98048 -0.0006848 1.924e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH2NH2; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n',n',2,2-tetramethylpropane-1,3-diamine" "n,n-dimethylneopentanediamine" "n,n,2,2-tetramethylpropane-1,3-diamine" "1,3-propanediamine, n,n,2,2-tetramethyl-" "1,3-propanediamine, n1,n1,2,2-tetramethyl-" "uldivzqlpbuhag-uhfffaoysa-" "(3-amino-2,2-dimethylpropyl)dimethylamine" );
standardThermochemistry
{
    dHf_298   -95240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=188130.0
}
