/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzyl suberate  (C22H26O4, CAS 42413-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzylSuberate;
formula     C22H26O4;
CAS         42413-23-0;
InChIKey    KWYCNDSIQMBOIS-UHFFFAOYSA-N;
MW          354.446;      // g/mol [origin=calculated method=formula-sum]
Tc          1089.17;      // K   [origin=predictive method=joback]
Pc          14.154;      // bar [origin=predictive method=joback]
omega       1.0490;      // -   [origin=predictive method=lee-kesler]
Tb          872.76;      // K   [origin=predictive method=joback]
HvapTb      83932.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.102 1.8264 -0.0010462 1.874e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 10; } { group ACCH2; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(phenylmethyl) octanedioate" "octanedioic acid, bis(phenylmethyl) ester" "octanedioic acid, 1,8-bis(phenylmethyl) ester" "dibenzyl octanedioate" "octanedioic acid bisbenzyl ester" );
standardThermochemistry
{
    dHf_298   -658910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     902.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-261560.0
}
