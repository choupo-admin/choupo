/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimefadane  (C17H19N, CAS 5581-40-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimefadane;
formula     C17H19N;
CAS         5581-40-8;
InChIKey    GAVBHVRHVQMWEI-UHFFFAOYSA-N;
MW          237.346;      // g/mol [origin=calculated method=formula-sum]
Tc          900.08;      // K   [origin=predictive method=joback]
Pc          22.504;      // bar [origin=predictive method=joback]
omega       0.6153;      // -   [origin=predictive method=lee-kesler]
Tb          661.41;      // K   [origin=predictive method=joback]
HvapTb      60297.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.07 1.64984 -0.00117376 3.257e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 9; } { group AC; count 1; } { group ACCH; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-3-phenyl-2,3-dihydro-1h-inden-1-amine" "dimethyl fandane" "dimefadane [usan:inn]" "dimefadanum [inn-latin]" "n,n-dimethyl-3-phenyl-1-indanamine" "1h-inden-1-amine, 2,3-dihydro-n,n-dimethyl-3-phenyl-" "1-indanamine, n,n-dimethyl-3-phenyl-" "dimefadano" "dimefadanum" "dimefadane (usan/inn)" "agn-pc-00mzr3" "n,n-dimethyl-3-phenyl-1-indanylamin" );
standardThermochemistry
{
    dHf_298   187370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=471270.0
}
