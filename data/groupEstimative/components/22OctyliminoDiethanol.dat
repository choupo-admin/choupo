/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-(octylimino)diethanol  (C12H27NO2, CAS 15520-05-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22OctyliminoDiethanol;
formula     C12H27NO2;
CAS         15520-05-5;
InChIKey    QZQNMMLYACBCMJ-UHFFFAOYSA-N;
MW          217.353;      // g/mol [origin=calculated method=formula-sum]
Tc          830.70;      // K   [origin=predictive method=joback]
Pc          20.888;      // bar [origin=predictive method=joback]
omega       1.4734;      // -   [origin=predictive method=lee-kesler]
Tb          670.96;      // K   [origin=predictive method=joback]
HvapTb      77707.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.129 1.33572 -0.0008024 1.886e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-hydroxyethyl(octyl)amino]ethanol" "2,2'-(octylimino)bisethanol" "ethanol, 2,2'-(octylimino)bis-" "2-[(2-hydroxyethyl)octylamino]ethan-1-ol" );
gibbsFormation
{
    dHf_298   -527940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     741.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-112700.0
    phase     gas;
}
