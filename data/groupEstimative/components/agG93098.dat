/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-93098  (C15H15NO, CAS 73928-02-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG93098;
formula     C15H15NO;
CAS         73928-02-6;
InChIKey    BZUYFADJDPOAKR-UHFFFAOYSA-N;
MW          225.291;      // g/mol [origin=calculated method=formula-sum]
Tc          954.13;      // K   [origin=predictive method=joback]
Pc          26.735;      // bar [origin=predictive method=joback]
omega       0.7485;      // -   [origin=predictive method=lee-kesler]
Tb          705.23;      // K   [origin=predictive method=joback]
HvapTb      67869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.15 1.17072 -0.00073672 1.721e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 3; } { group CH3O; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-4-(2-phenylethenyl)aniline" );
standardThermochemistry
{
    dHf_298   115980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=322650.0
}
