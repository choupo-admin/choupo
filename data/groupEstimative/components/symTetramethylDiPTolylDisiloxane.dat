/*--------------------------------*- Choupo -*-----------------------*\
  Component: sym-tetramethyl-di-(p-tolyl)disiloxane  (C18H26OSi2, CAS 18055-70-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C18H26OSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        symTetramethylDiPTolylDisiloxane;
formula     C18H26OSi2;
CAS         18055-70-4;
InChIKey    MEQYEVSZYLVDNX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          314.575;      // g/mol [origin=calculated method=formula-sum]
Tc          933.20;      // K   [origin=predictive method=joback]
Pc          15.129;      // bar [origin=predictive method=joback]
omega       0.5282;      // -   [origin=predictive method=lee-kesler]
Tb          699.98;      // K   [origin=predictive method=joback]
HvapTb      64536.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.45 0.96152 5.688e-05 -2.85e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 2; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[dimethyl-(4-methylphenyl)silyl]oxy-dimethyl-(4-methylphenyl)silane" "1,3-di(p-tolyl)-1,1,3,3-tetramethyldisiloxane" "disiloxane, 1,1,3,3-tetramethyl-1,3-bis(4-methylphenyl)-" "1,3-bis(4-methylphenyl)-1,1,3,3-tetramethyldisiloxane" "1,3-di(4-methylphenyl)-1,1,3,3-tetramethyldisiloxane" "disiloxane,1,1,3,3-tetramethyl-1,3-di-p-tolyl- (8ci);1,1,3,3-tetramethyl-1,3-di-p-tolyldisiloxane; 1,3-bis(4-methylphenyl)-1,1,3,3-tetramethyldisiloxane;1,3-bis(p-tolyl)-1,1,3,3-tetramethyldisiloxane;1,3-bis(p-tolyl)tetramethyldisiloxane" );
standardThermochemistry
{
    dHf_298   -320190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     896.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-8280.0
}
