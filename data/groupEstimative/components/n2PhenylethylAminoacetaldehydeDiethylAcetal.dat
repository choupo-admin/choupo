/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-phenylethyl)aminoacetaldehyde diethyl acetal  (C14H23NO2, CAS 94508-09-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2PhenylethylAminoacetaldehydeDiethylAcetal;
formula     C14H23NO2;
CAS         94508-09-5;
InChIKey    IZISGBNIQIHBHI-UHFFFAOYSA-N;
MW          237.343;      // g/mol [origin=calculated method=formula-sum]
Tc          836.84;      // K   [origin=predictive method=joback]
Pc          19.859;      // bar [origin=predictive method=joback]
omega       0.8554;      // -   [origin=predictive method=lee-kesler]
Tb          641.17;      // K   [origin=predictive method=joback]
HvapTb      59902.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.365 1.21064 -0.0005988 8.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-diethoxy-n-(2-phenylethyl)ethanamine" "2,2-diethoxy-n-phenethylethanamine" "n-(2-phenylethyl)amino acetaldehyde diethyl acetal" );
gibbsFormation
{
    dHf_298   -312010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56360.0
    phase     gas;
}
