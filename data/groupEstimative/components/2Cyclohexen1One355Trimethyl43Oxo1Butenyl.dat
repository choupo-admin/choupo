/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexen-1-one, 3,5,5-trimethyl-4-(3-oxo-1-butenyl)-  (C13H18O2, CAS 20194-68-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexen1One355Trimethyl43Oxo1Butenyl;
formula     C13H18O2;
CAS         20194-68-7;
InChIKey    MLYOGKJJENFVJN-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          872.98;      // K   [origin=predictive method=joback]
Pc          23.158;      // bar [origin=predictive method=joback]
omega       0.6373;      // -   [origin=predictive method=lee-kesler]
Tb          642.15;      // K   [origin=predictive method=joback]
HvapTb      55406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.9 1.33458 -0.00098294 3.2756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5,5-trimethyl-4-(3-oxidanylidenebut-1-enyl)cyclohex-2-en-1-one" "agn-pc-00l4y9" "3,5,5-trimethyl-4-(3-oxo-1-butenyl)-2-cyclohexen-1-one" "2-cyclohexen-1-one, 3,5,5-trimethyl-4-[(1e)-3-oxo-1-butenyl]-" );
gibbsFormation
{
    dHf_298   -349180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-81130.0
    phase     gas;
}
