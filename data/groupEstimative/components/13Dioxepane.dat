/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxepane  (C5H10O2, CAS 505-65-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxepane;
formula     C5H10O2;
CAS         505-65-7;
InChIKey    CZLMRJZAHXYRIX-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          613.30;      // K   [origin=predictive method=joback]
Pc          47.366;      // bar [origin=predictive method=joback]
omega       0.2941;      // -   [origin=predictive method=lee-kesler]
Tb          396.39;      // K   [origin=predictive method=joback]
HvapTb      36654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.68 0.6118 -0.0003104 3.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxepan" "tetramethylene formal" "1,3-dioxacycloheptane" "1,4-butanediol formal" "formaldehyde, cyclic tetramethylene acetal" "tetramethyl ene formal" "1,3-dioxepin, tetrahydro-" );
gibbsFormation
{
    dHf_298   -342030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     279.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-160960.0
    phase     gas;
}
