/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxy-n-(2-hydroxyethyl)butanamide  (C6H13NO3, CAS 66857-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HydroxyN2HydroxyethylButanamide;
formula     C6H13NO3;
CAS         66857-17-8;
InChIKey    MFHPPMMWHSHDSI-UHFFFAOYSA-N;
MW          147.174;      // g/mol [origin=calculated method=formula-sum]
Tc          794.39;      // K   [origin=predictive method=joback]
Pc          42.496;      // bar [origin=predictive method=joback]
omega       1.6792;      // -   [origin=predictive method=lee-kesler]
Tb          625.28;      // K   [origin=predictive method=joback]
HvapTb      75490.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.165 0.69 -0.0003933 8.126e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 2; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group OH; count 2; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-hydroxyethyl)-4-oxidanyl-butanamide" "butanamide, 4-hydroxy-n-(2-hydroxyethyl)-" "etoxybamide" "etoxybamide [inn]" "butyramide, 4-hydroxy-n-(2-hydroxyethyl)-" "4-hydroxy-n-(2-hydroxyethyl)butyramide" "n-(2-hydroxyethyl)-4-hydroxybutyramide" );
standardThermochemistry
{
    dHf_298   -530740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-313530.0
}
