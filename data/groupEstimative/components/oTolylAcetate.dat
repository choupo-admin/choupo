/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-tolyl acetate  (C9H10O2, CAS 533-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oTolylAcetate;
formula     C9H10O2;
CAS         533-18-6;
InChIKey    AMZORBZSQRUXNC-UHFFFAOYSA-N;
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          709.82;      // K   [origin=predictive method=joback]
Pc          32.246;      // bar [origin=predictive method=joback]
omega       0.4872;      // -   [origin=predictive method=lee-kesler]
Tb          495.40;      // K   [origin=predictive method=joback]
HvapTb      45973.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.51 0.66564 -0.00033536 3.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methylphenyl) ethanoate" "o-cresyl acetate" "acetic acid, o-tolyl ester" "2-methylphenyl acetate" "acetyl-o-cresol" "o-cresol acetate" "o-acetoxytoluene" "o-cresylic acetate" "o-cresolacetate" "o-methylphenyl acetate" "tolyl acetate" "2-acetoxytoluene" );
standardThermochemistry
{
    dHf_298   -321310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-182690.0
}
