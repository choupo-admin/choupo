/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorofluorene  (C13H9Cl, CAS 2523-44-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorofluorene;
formula     C13H9Cl;
CAS         2523-44-6;
InChIKey    FCPAQNZCCWBDSY-UHFFFAOYSA-N;
MW          200.665;      // g/mol [origin=calculated method=formula-sum]
Tc          858.03;      // K   [origin=predictive method=joback]
Pc          31.811;      // bar [origin=predictive method=joback]
omega       0.5420;      // -   [origin=predictive method=lee-kesler]
Tb          605.64;      // K   [origin=predictive method=joback]
HvapTb      55333.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.89 1.1059 -0.00093348 3.161e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group ACCH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-9h-fluorene" "fluorene, 2-chloro-" "2-chloro-9h-fluorene" "9h-fluorene, 2-chloro-" "fluorene, 2-chloro- (8ci)" "9h-fluorene, 2-chloro- (9ci)" "r490" );
gibbsFormation
{
    dHf_298   216720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=335240.0
    phase     gas;
}
