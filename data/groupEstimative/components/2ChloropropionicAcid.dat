/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloropropionic acid  (C3H5ClO2, CAS 598-78-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloropropionicAcid;
formula     C3H5ClO2;
CAS         598-78-7;
InChIKey    GAWAYYRQGQZKCR-UHFFFAOYSA-N;
MW          108.521;      // g/mol [origin=calculated method=formula-sum]
Tc          657.56;      // K   [origin=predictive method=joback]
Pc          47.826;      // bar [origin=predictive method=joback]
omega       0.5566;      // -   [origin=predictive method=lee-kesler]
Tb          450.74;      // K   [origin=predictive method=joback]
HvapTb      43433.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.97 0.35232 -0.0002356 6.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group COOH; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylpropanoic acid" "2-chloropropanoic acid" "propanoic acid, 2-chloro-" "propionic acid, 2-chloro-" "alpha-chloropropionic acid" "d-2-chloropropionic acid" "alpha-monochloropropionic acid" "propionic acid, alpha-chloro-" "(r)-(+)-2-chloropropionicacid" "propanoic acid, chloro-" "(+/-)-2-chloropropionic acid" "2-chloropropionate" );
standardThermochemistry
{
    dHf_298   -476540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-383900.0
}
