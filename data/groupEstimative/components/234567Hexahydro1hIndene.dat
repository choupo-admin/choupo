/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,5,6,7-hexahydro-1h-indene  (C9H14, CAS 695-90-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        234567Hexahydro1hIndene;
formula     C9H14;
CAS         695-90-9;
InChIKey    CVKGBEGKZIIWRA-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          672.62;      // K   [origin=predictive method=joback]
Pc          35.643;      // bar [origin=predictive method=joback]
omega       0.3336;      // -   [origin=predictive method=lee-kesler]
Tb          450.27;      // K   [origin=predictive method=joback]
HvapTb      38204.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.64 1.0098 -0.000731 2.156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h-indene, 2,3,4,5,6,7-hexahydro-" "bicyclo[4.3.0]nonyl" "4,5,6,7-tetrahydroindan" "2,3,4,7-tetrahydro-5h-indene" );
standardThermochemistry
{
    dHf_298   -26450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136220.0
}
