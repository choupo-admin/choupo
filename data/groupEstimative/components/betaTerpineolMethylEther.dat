/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-terpineol, methyl ether  (C11H20O, CAS 26946-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaTerpineolMethylEther;
formula     C11H20O;
CAS         26946-68-9;
InChIKey    OLQOOKYEEAQGPU-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          694.92;      // K   [origin=predictive method=joback]
Pc          24.338;      // bar [origin=predictive method=joback]
omega       0.3702;      // -   [origin=predictive method=lee-kesler]
Tb          485.38;      // K   [origin=predictive method=joback]
HvapTb      40869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.95 1.35306 -0.001047 3.635e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH2=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-1-methyl-4-prop-1-en-2-yl-cyclohexane" "1-methoxy-1-methyl-4-prop-1-en-2-ylcyclohexane" "1-methoxy-1-methyl-4-(prop-1-en-2-yl)cyclohexane" "cyclohexane, 1-methoxy-1-methyl-4-(1-methylethenyl)-" "ether,p-menth-8-en-1-yl methyl (8ci)" "4-isopropenyl-1-methoxy-1-methylcyclohexane" "1-methoxy-1-methyl-4-(1-methylvinyl)cyclohexane" "cyclohexane,1-methoxy-1-methyl-4-(1-methylethenyl)-" );
gibbsFormation
{
    dHf_298   -237730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=27280.0
    phase     gas;
}
