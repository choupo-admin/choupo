/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dihydroxanthotoxol  (C11H8O4, CAS 68123-30-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dihydroxanthotoxol;
formula     C11H8O4;
CAS         68123-30-8;
InChIKey    GWDMSCZQYHAETO-UHFFFAOYSA-N;
MW          204.181;      // g/mol [origin=calculated method=formula-sum]
Tc          919.19;      // K   [origin=predictive method=joback]
Pc          44.091;      // bar [origin=predictive method=joback]
omega       0.9851;      // -   [origin=predictive method=lee-kesler]
Tb          676.40;      // K   [origin=predictive method=joback]
HvapTb      69837.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.77 1.1966 -0.00113742 4.269e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 1; } { group AC; count 3; } { group ACCH2; count 1; } { group ACOH; count 1; } { group FCH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-oxidanyl-2,3-dihydrofuro[3,2-g]chromen-7-one" "2,3-dihydro-9-hydroxy-7h-furo[3,2-g][1]benzopyran-7-one" "9-hydroxy-2,3-dihydro-7h-furo[3,2-g]chromen-7-one" "7h-furo(3,2-g)(1)benzopyran-7-one, 2,3-dihydro-9-hydroxy-" "2,3-dihydro-9-hydroxy-7h-furo(3,2-g)(1)benzopyran-7-one" "7h-furo[3,2-g][1]benzopyran-7-one, 2,3-dihydro-9-hydroxy-" "9-hydroxy-2h-furo[3,2-g]chromen-7(3h)-one" "9-hydroxy-2,3-dihydrofuro[3,2-g]chromen-7-one" "9-hydroxy-2,3-dihydrofuro[3,2-g][1]benzopyran-7-one" "9-hydroxy-2,3-dihydro-7h-furo[3,2-g]chromen-7-one;2,3-dihydroxanthotoxol;2,3-dihydro-9-hydroxy-7h-furo(3,2-g)(1)benzopyran-7-one;2,3-dihydro-9-hydroxyfuro[3,2-g]chromen-7-one;" );
standardThermochemistry
{
    dHf_298   -444620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     332.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246870.0
}
