/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2,3-dihydro-1h-inden-2-yl)acetic acid  (C11H12O2, CAS 37868-26-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        223Dihydro1hInden2YlAceticAcid;
formula     C11H12O2;
CAS         37868-26-1;
InChIKey    TULDPXYHBFBRGW-UHFFFAOYSA-N;
MW          176.215;      // g/mol [origin=calculated method=formula-sum]
Tc          867.53;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.7938;      // -   [origin=predictive method=lee-kesler]
Tb          635.19;      // K   [origin=predictive method=joback]
HvapTb      60095.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.359 1.1121 -0.00083156 2.476e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,3-dihydro-1h-inden-2-yl)ethanoic acid" "2,3-dihydro-1h-inden-2-ylacetic acid" "indan-2-ylacetic acid" "2-indan-2-ylacetic acid" "indan-2-yl-acetic acid" "1h-indene-2-aceticacid, 2,3-dihydro-" "2,3-dihydro-1h-indene-2-acetic acid" "1h-indene-2-acetic acid, 2,3-dihydro-" );
gibbsFormation
{
    dHf_298   -322780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-138640.0
    phase     gas;
}
