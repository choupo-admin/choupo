/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,13-di-tert-butyl-6,7,9,10,17,18,20,21-octahydrodibenzo[b,k][1,4,7,10,13,16]hexaoxacyclooctadecine  (C28H40O6, CAS 29471-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        213DiTertButyl6791017182021OctahydrodibenzoBK147101316Hexaox;
formula     C28H40O6;
CAS         29471-17-8;
InChIKey    ODEWVZWKIFSVMI-UHFFFAOYSA-N;
MW          472.622;      // g/mol [origin=calculated method=formula-sum]
Tc          1400.95;      // K   [origin=predictive method=joback]
Pc          12.040;      // bar [origin=predictive method=joback]
omega       0.9601;      // -   [origin=predictive method=lee-kesler]
Tb          1127.14;      // K   [origin=predictive method=joback]
HvapTb      111704.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.71 2.57352 -0.00131904 1.636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 6; } { group AC; count 6; } { group FCH2O; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group CH2_ring; count 8; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibenzo(b,k)(1,4,7,10,13,16)hexaoxacyclooctadecin, 2,13(or 2,14)-bis(1,1-dimethylethyl)-6,7,9,10,17,18,20,21-octahydro-" "dibenzo(b,k)(1,4,7,10,13,16)hexaoxacyclooctadecin, 6,7,9,10,17,18,20,21-octahydro-2,13(or 2,14)-bis(1,1-dimethylethyl)-" "dibenzo[b,k][1,4,7,10,13,16]hexaoxacyclooctadecin, 2,13(or 2,14)-bis(1,1-dimethylethyl)-6,7,9,10,17,18,20,21-octahydro-" );
standardThermochemistry
{
    dHf_298   -978190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     794.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-204500.0
}
