/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dibutoxy-4-morpholinoaniline  (C18H30N2O3, CAS 67828-46-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dibutoxy4Morpholinoaniline;
formula     C18H30N2O3;
CAS         67828-46-0;
InChIKey    YOVXTCPXRNWWRF-UHFFFAOYSA-N;
MW          322.449;      // g/mol [origin=calculated method=formula-sum]
Tc          1041.84;      // K   [origin=predictive method=joback]
Pc          16.866;      // bar [origin=predictive method=joback]
omega       1.1210;      // -   [origin=predictive method=lee-kesler]
Tb          829.77;      // K   [origin=predictive method=joback]
HvapTb      82504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.784 1.67104 -0.00088838 1.516e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group ACH; count 2; } { group AC; count 3; } { group CH2O; count 2; } { group FCH2O; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } { group O_ring; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dibutoxy-4-morpholin-4-yl-aniline" "2,5-dibutoxy-4-(morpholin-4-yl)aniline" "n-(4-amino-2,5-dibutoxyphenyl)morpholine" "benzenamine, 2,5-dibutoxy-4-(4-morpholinyl)-" "2,5-dibutoxy-4-morpholin-4-ylaniline" );
standardThermochemistry
{
    dHf_298   -427030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     763.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109570.0
}
