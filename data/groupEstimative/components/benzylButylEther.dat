/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl butyl ether  (C11H16O, CAS 588-67-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylButylEther;
formula     C11H16O;
CAS         588-67-0;
InChIKey    MAYUYFCAPVDYBQ-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          700.85;      // K   [origin=predictive method=joback]
Pc          26.031;      // bar [origin=predictive method=joback]
omega       0.5136;      // -   [origin=predictive method=lee-kesler]
Tb          500.38;      // K   [origin=predictive method=joback]
HvapTb      44766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.516 0.90672 -0.0004948 9.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butoxymethylbenzene" "ether, benzyl butyl" "benzene, (butoxymethyl)-" "butoxyphenylmethane" "butyl benzyl ether" "(butoxymethyl)benzene" "n-butyl benzyl ether" "benzene, butoxymethyl-" );
gibbsFormation
{
    dHf_298   -166060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49150.0
    phase     gas;
}
