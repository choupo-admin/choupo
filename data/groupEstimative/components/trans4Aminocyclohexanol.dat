/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-4-aminocyclohexanol  (C6H13NO, CAS 27489-62-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans4Aminocyclohexanol;
formula     C6H13NO;
CAS         27489-62-9;
InChIKey    IMLXLGZJLAOKJN-UHFFFAOYSA-N;
MW          115.176;      // g/mol [origin=calculated method=formula-sum]
Tc          722.74;      // K   [origin=predictive method=joback]
Pc          46.089;      // bar [origin=predictive method=joback]
omega       0.7887;      // -   [origin=predictive method=lee-kesler]
Tb          516.47;      // K   [origin=predictive method=joback]
HvapTb      56390.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.45 0.7653 -0.000402 6.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanylcyclohexan-1-ol" "4-aminocyclohexan-1-ol" "4-aminocyclohexanol" "cis-4-aminocyclohexanol" "cyclohexanol, 4-amino-, trans-" "aminocyclohexanol(trans-4)" "trans-4-amino-cyclohexanol" "trans-4-hydroxycyclohexylamine" "(1r,4r)-4-aminocyclohexan-1-ol" "trans-4-amino-1-hydroxycyclohexane" "4-amino-1-cyclohexanol" "cyclohexanol, 4-amino-" );
standardThermochemistry
{
    dHf_298   -251630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-53990.0
}
