/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl acrylate, methacrylic acid, allyl methacrylate polymer  (C16H24O6, CAS 55088-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylAcrylateMethacrylicAcidAllylMethacrylatePolymer;
formula     C16H24O6;
CAS         55088-65-8;
InChIKey    VRYCDGAYXVYMPJ-UHFFFAOYSA-N;
MW          312.362;      // g/mol [origin=calculated method=formula-sum]
Tc          1022.16;      // K   [origin=predictive method=joback]
Pc          14.208;      // bar [origin=predictive method=joback]
omega       1.0229;      // -   [origin=predictive method=lee-kesler]
Tb          816.91;      // K   [origin=predictive method=joback]
HvapTb      81256.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (114.052 0.97246 3.4e-06 -2.682e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH2=CH; count 2; } { group CH2=C; count 2; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH2; count 4; } { group dCH; count 2; } { group dC; count 2; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl prop-2-enoate;2-methylprop-2-enoic acid;prop-2-enyl 2-methylprop-2-enoate" "ethyl prop-2-enoate; 2-methylprop-2-enoic acid; prop-2-enyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, polymer with ethyl 2-propenoate and 2-propen-1-yl 2-methyl-2-propenoate" "2-propenoic acid, 2-methyl-, polymer with ethyl 2-propenoate and 2-propenyl 2-methyl-2-propenoate" );
standardThermochemistry
{
    dHf_298   -1099500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1123.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-756070.0
}
