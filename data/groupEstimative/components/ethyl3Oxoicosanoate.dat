/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-oxoicosanoate  (C22H42O3, CAS 7146-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Oxoicosanoate;
formula     C22H42O3;
CAS         7146-82-9;
InChIKey    ZSZUZHXUJXYSMM-UHFFFAOYSA-N;
MW          354.575;      // g/mol [origin=calculated method=formula-sum]
Tc          998.81;      // K   [origin=predictive method=joback]
Pc          9.398;      // bar [origin=predictive method=joback]
omega       0.9010;      // -   [origin=predictive method=lee-kesler]
Tb          815.05;      // K   [origin=predictive method=joback]
HvapTb      78719.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.658 2.01104 -0.0010597 1.8446e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-oxidanylideneicosanoate" "ethyl stearoylacetate" "eicosanoic acid, 3-oxo-, ethyl ester" "eicosanoic acid,3-oxo-, ethyl ester" );
gibbsFormation
{
    dHf_298   -927270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1090.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-304930.0
    phase     gas;
}
