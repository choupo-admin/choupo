/*--------------------------------*- Choupo -*-----------------------*\
  Component: (10-phenyldecyl)benzene  (C22H30, CAS 35511-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10PhenyldecylBenzene;
formula     C22H30;
CAS         35511-93-4;
InChIKey    SSSBYZTYRWXPNJ-UHFFFAOYSA-N;
MW          294.482;      // g/mol [origin=calculated method=formula-sum]
Tc          965.49;      // K   [origin=predictive method=joback]
Pc          14.048;      // bar [origin=predictive method=joback]
omega       0.8148;      // -   [origin=predictive method=lee-kesler]
Tb          756.32;      // K   [origin=predictive method=joback]
HvapTb      69118.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.92 1.936 -0.0012354 3.016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group ACH; count 10; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-phenyldecylbenzene" "decane, 1,10-diphenyl-" );
standardThermochemistry
{
    dHf_298   -24350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     800.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=359180.0
}
