/*--------------------------------*- Choupo -*-----------------------*\
  Component: propyl formate  (C4H8O2, CAS 110-74-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H8O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        propylFormate;
formula     C4H8O2;
CAS         110-74-7;
InChIKey    KFNNIILCVOLYIR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          88.106;      // g/mol [origin=calculated method=formula-sum]
Tc          423.73;      // K   [origin=predictive method=joback]
Pc          39.555;      // bar [origin=predictive method=joback]
omega       0.1600;      // -   [origin=predictive method=lee-kesler]
Tb          267.54;      // K   [origin=predictive method=joback]
HvapTb      22125.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.248 0.39192 -0.0003468 1.331e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propyl methanoate" "formic acid, propyl ester" "n-propyl formate" "formiate de propyle [french]" "n-propyl methanoate" "propyl formates" "formiate de propyle" "formic acid propyl ester" "agn-pc-0d2fbq" "propylester kyseliny mravenci" );
standardThermochemistry
{
    dHf_298   -49440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=26760.0
}
