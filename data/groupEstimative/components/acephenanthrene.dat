/*--------------------------------*- Choupo -*-----------------------*\
  Component: acephenanthrene  (C16H12, CAS 6232-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acephenanthrene;
formula     C16H12;
CAS         6232-48-0;
InChIKey    ZBWXZZIIMVVCNZ-UHFFFAOYSA-N;
MW          204.272;      // g/mol [origin=calculated method=formula-sum]
Tc          906.08;      // K   [origin=predictive method=joback]
Pc          29.537;      // bar [origin=predictive method=joback]
omega       0.6242;      // -   [origin=predictive method=lee-kesler]
Tb          652.40;      // K   [origin=predictive method=joback]
HvapTb      58802.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.61 1.446 -0.00127212 4.496e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,5-dihydroacephenanthrylene" "acephenanthrylene, 4,5-dihydro-" );
gibbsFormation
{
    dHf_298   309990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=461220.0
    phase     gas;
}
