/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4s,5s)-4,5-di(aminomethyl)-2,2-dimethyldioxolane  (C7H16N2O2, CAS 119322-88-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4s5s45DiAminomethyl22Dimethyldioxolane;
formula     C7H16N2O2;
CAS         119322-88-2;
InChIKey    KQGQLRAYJUXGOW-WDSKDSINSA-N;
MW          160.217;      // g/mol [origin=calculated method=formula-sum]
Tc          790.51;      // K   [origin=predictive method=joback]
Pc          37.408;      // bar [origin=predictive method=joback]
omega       0.6900;      // -   [origin=predictive method=lee-kesler]
Tb          564.90;      // K   [origin=predictive method=joback]
HvapTb      59966.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.448 1.15724 -0.0009652 3.578e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH-O; count 2; } { group CH2NH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group O_ring; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(4s,5s)-5-(aminomethyl)-2,2-dimethyl-1,3-dioxolan-4-yl]methanamine" "[(4s,5s)-5-(aminomethyl)-2,2-dimethyl-1,3-dioxolan-4-yl]methylamine" );
standardThermochemistry
{
    dHf_298   -349190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15640.0
}
