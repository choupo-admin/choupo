/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(diethylamino)acetamide  (C6H14N2O, CAS 7409-48-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DiethylaminoAcetamide;
formula     C6H14N2O;
CAS         7409-48-5;
InChIKey    PPQDYOBQQWPTIS-UHFFFAOYSA-N;
MW          130.191;      // g/mol [origin=calculated method=formula-sum]
Tc          664.94;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.6739;      // -   [origin=predictive method=lee-kesler]
Tb          475.72;      // K   [origin=predictive method=joback]
HvapTb      48380.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.593 0.73164 -0.0004399 9.956e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2N; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CdO; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethanamide" );
standardThermochemistry
{
    dHf_298   -178430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47950.0
}
