/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trichloroaniline  (C6H4Cl3N, CAS 634-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trichloroaniline;
formula     C6H4Cl3N;
CAS         634-93-5;
InChIKey    NATVSFWWYVJTAZ-UHFFFAOYSA-N;
MW          196.455;      // g/mol [origin=calculated method=formula-sum]
Tc          813.90;      // K   [origin=predictive method=joback]
Pc          40.986;      // bar [origin=predictive method=joback]
omega       0.5446;      // -   [origin=predictive method=lee-kesler]
Tb          563.32;      // K   [origin=predictive method=joback]
HvapTb      57008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.59 0.3987 -0.00023728 4.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACNH2; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-tris(chloranyl)aniline" "s-trichloroaniline" "benzenamine, 2,4,6-trichloro-" "aniline, 2,4,6-trichloro-" "2,4,6-trichlorobenzenamine" "2,4,6-trichlorophenylamine" "sym-trichloroaniline" "1-amino-2,4,6-trichlorobenzene" "2,4,6-tca" "2,6-trichloroaniline" "2,6-trichlorophenylamine" "aniline,4,6-trichloro-" );
standardThermochemistry
{
    dHf_298   21520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113820.0
}
