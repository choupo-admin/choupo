/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-norbornadienyl acetate  (C9H10O2, CAS 13426-49-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7NorbornadienylAcetate;
formula     C9H10O2;
CAS         13426-49-8;
InChIKey    FLHISVDCSFSARC-UHFFFAOYSA-N;
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          684.96;      // K   [origin=predictive method=joback]
Pc          32.541;      // bar [origin=predictive method=joback]
omega       0.4599;      // -   [origin=predictive method=lee-kesler]
Tb          475.14;      // K   [origin=predictive method=joback]
HvapTb      43308.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.99 0.95772 -0.00068436 1.877e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 3; } { group CH=CH; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH_ring; count 3; } { group dCH_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-bicyclo[2.2.1]hepta-2,5-dienyl ethanoate" "7-acetoxybicyclo(2.2.1)-2,5-heptadiene" "7-acetoxybicyclo[2.2.1]-2,5-heptadiene" "7-bicyclo[2.2.1]hepta-2,5-dienyl acetate" );
gibbsFormation
{
    dHf_298   -311710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     280.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-123860.0
    phase     gas;
}
