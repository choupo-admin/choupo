/*--------------------------------*- Choupo -*-----------------------*\
  Component: nortricyclyl formate  (C8H10O2, CAS 21892-95-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H10O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nortricyclylFormate;
formula     C8H10O2;
CAS         21892-95-5;
InChIKey    ZYRFBCPCNSLRCD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          138.166;      // g/mol [origin=calculated method=formula-sum]
Tc          551.25;      // K   [origin=predictive method=joback]
Pc          34.602;      // bar [origin=predictive method=joback]
omega       0.2425;      // -   [origin=predictive method=lee-kesler]
Tb          361.40;      // K   [origin=predictive method=joback]
HvapTb      29806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-152.49 1.1908 -0.001207 4.82e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 5; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5,6,7-hexahydro-1h-tricyclo[2.2.1.0^{2,6}]heptan-3-yl methanoate" "nortricyclan-3-ol, formate" "tricyclo[2.2.1.02,6]hept-3-yl formate" );
gibbsFormation
{
    dHf_298   58040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     255.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=251470.0
    phase     gas;
}
