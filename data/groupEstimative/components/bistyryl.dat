/*--------------------------------*- Choupo -*-----------------------*\
  Component: bistyryl  (C16H14, CAS 538-81-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bistyryl;
formula     C16H14;
CAS         538-81-8;
InChIKey    JFLKFZNIIQFQBS-FNCQTZNRSA-N;
MW          206.288;      // g/mol [origin=calculated method=formula-sum]
Tc          878.39;      // K   [origin=predictive method=joback]
Pc          25.303;      // bar [origin=predictive method=joback]
omega       0.5023;      // -   [origin=predictive method=lee-kesler]
Tb          627.36;      // K   [origin=predictive method=joback]
HvapTb      55678.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.83 1.406 -0.0010766 3.25e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1e,3e)-4-phenylbuta-1,3-dienyl]benzene" "1,4-diphenyl-1,3-butadiene" "trans,trans-1,4-diphenyl-1,3-butadiene" "1,4-diphenylbutadiene" "1,4-diphenylerythrene" "distyryl" "1,1'-(1e,3e)-buta-1,3-diene-1,4-diyldibenzene" "1,4-diphenylbuta-1,3-diene" "beta,beta'-bistyryl" "1,3-butadiene, 1,4-diphenyl-, (e,e)-" "benzene, 1,1'-(1,3-butadiene-1,4-diyl)bis-" "((1e,3e)-4-phenylbuta-1,3-dienyl)benzene" );
gibbsFormation
{
    dHf_298   333930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=469100.0
    phase     gas;
}
