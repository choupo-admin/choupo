/*--------------------------------*- Choupo -*-----------------------*\
  Component: morpholine, 4-(1-hydroxy-2-naphthoyl)-  (C15H15NO3, CAS 33079-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        morpholine41Hydroxy2Naphthoyl;
formula     C15H15NO3;
CAS         33079-11-7;
InChIKey    WUJQEUMREGBPIV-UHFFFAOYSA-N;
MW          257.289;      // g/mol [origin=calculated method=formula-sum]
Tc          1041.91;      // K   [origin=predictive method=joback]
Pc          35.305;      // bar [origin=predictive method=joback]
omega       1.0901;      // -   [origin=predictive method=lee-kesler]
Tb          787.27;      // K   [origin=predictive method=joback]
HvapTb      80441.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.15 1.6924 -0.00141224 4.6946e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 6; } { group AC; count 3; } { group ACOH; count 1; } { group FCH2O; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O_ring; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "morpholin-4-yl-(1-oxidanylnaphthalen-2-yl)methanone" "methanone, (1-hydroxy-2-naphthalenyl)-4-morpholinyl-" "morpholine, 4-((1-hydroxy-2-naphthalenyl)carbonyl)-" "morpholine, 4-[(1-hydroxy-2-naphthalenyl)carbonyl]-" "1-hydroxy-2-naphthoic acid morpholide" "4-(1-hydroxy-2-naphthoyl)morpholine" "(1-hydroxynaphthalen-2-yl)-morpholin-4-ylmethanone" );
standardThermochemistry
{
    dHf_298   -210340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70230.0
}
