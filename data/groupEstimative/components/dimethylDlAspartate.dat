/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl dl-aspartate  (C6H11NO4, CAS 40149-67-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylDlAspartate;
formula     C6H11NO4;
CAS         40149-67-5;
InChIKey    BYHXBBOSJKPUJL-UHFFFAOYSA-N;
MW          161.157;      // g/mol [origin=calculated method=formula-sum]
Tc          722.01;      // K   [origin=predictive method=joback]
Pc          33.841;      // bar [origin=predictive method=joback]
omega       0.7621;      // -   [origin=predictive method=lee-kesler]
Tb          525.41;      // K   [origin=predictive method=joback]
HvapTb      54017.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.061 0.53204 -0.00016 -4.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2COO; count 1; } { group CHNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group COO; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-azanylbutanedioate" "aspartic acid, dimethyl ester" "dimethyl 2-aminosuccinate" "dimethyl 2-aminobutanedioate" "l-aspartic acid, dimethyl ester" "asparticacid, 1,4-dimethyl ester" "asparticacid, dimethyl ester (9ci); dl-aspartic acid, dimethyl ester; o,o-dimethyl-dl-asparticacid" );
gibbsFormation
{
    dHf_298   -773220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-557090.0
    phase     gas;
}
