/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(benzylthio)ethanamine  (C9H13NS, CAS 1007-54-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BenzylthioEthanamine;
formula     C9H13NS;
CAS         1007-54-1;
InChIKey    PNCWHIAZZSDHPU-UHFFFAOYSA-N;
MW          167.27;      // g/mol [origin=calculated method=formula-sum]
Tc          813.43;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.5855;      // -   [origin=predictive method=lee-kesler]
Tb          573.51;      // K   [origin=predictive method=joback]
HvapTb      55362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.107 0.83619 -0.0005002 1.048e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(phenylmethylsulfanyl)ethanamine" "2-(benzylsulfanyl)ethanamine" "2-benzylsulfanylethanamine" "2-(benzylsulfanyl)ethan-1-amine" );
gibbsFormation
{
    dHf_298   83100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=236880.0
    phase     gas;
}
