/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-4-iodoaniline  (C6H5ClIN, CAS 42016-93-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro4Iodoaniline;
formula     C6H5ClIN;
CAS         42016-93-3;
InChIKey    MYDAOWXYGPEPJT-UHFFFAOYSA-N;
MW          253.463;      // g/mol [origin=calculated method=formula-sum]
Tc          851.25;      // K   [origin=predictive method=joback]
Pc          44.742;      // bar [origin=predictive method=joback]
omega       0.4711;      // -   [origin=predictive method=lee-kesler]
Tb          576.62;      // K   [origin=predictive method=joback]
HvapTb      56949.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.2 0.4836 -0.00034492 9.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group I; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-4-iodanyl-aniline" "2-chloro-4-iodo-phenylamine" "benzenamine, 2-chloro-4-iodo-" "2-chloro-4-iodoanilline" "2-chloro-4-iodophenylamine" "4-iodo-2-chloroaniline" "2-chloro-4-iodo-benzenamine" );
gibbsFormation
{
    dHf_298   141340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=205430.0
    phase     gas;
}
