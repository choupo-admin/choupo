/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[4.2.2.01,5]dec-3-en-8-yl propionate  (C13H18O2, CAS 67990-29-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo422015Dec3En8YlPropionate;
formula     C13H18O2;
CAS         67990-29-8;
InChIKey    GNSJBXUKHHNIFD-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          793.19;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.5791;      // -   [origin=predictive method=lee-kesler]
Tb          574.48;      // K   [origin=predictive method=joback]
HvapTb      50682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-175.639 1.83652 -0.00166748 6.284e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h-1,3a-ethanopentalen-3-ol, 2,3,4,6a-tetrahydro-, propanoate" "1h-1,3a-ethanopentalen-3-ol, 2,3,4,6a-tetrahydro-, 3-propanoate" "2,3,4,6a-tetrahydro-1h-1,3a-ethanopentalen-3-yl propionate" );
gibbsFormation
{
    dHf_298   -364010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64880.0
    phase     gas;
}
