/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl trans-4-bromocinnamate  (C11H11BrO2, CAS 24393-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylTrans4Bromocinnamate;
formula     C11H11BrO2;
CAS         24393-53-1;
InChIKey    YOOKYIPLSLPRTC-VMPITWQZSA-N;
MW          255.111;      // g/mol [origin=calculated method=formula-sum]
Tc          841.95;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       0.6839;      // -   [origin=predictive method=lee-kesler]
Tb          611.48;      // K   [origin=predictive method=joback]
HvapTb      56818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.299 0.91382 -0.00059936 1.447e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (e)-3-(4-bromophenyl)prop-2-enoate" "(e)-ethyl 3-(4-bromophenyl)acrylate" "2-propenoic acid, 3-(4-bromophenyl)-, ethyl ester" "4-bromzimtsaeureethylester" "trans-4-bromocinnamic acid ethyl ester" "ethyl (2e)-3-(4-bromophenyl)-2-propenoate" "ethyl (2e)-3-(4-bromophenyl)prop-2-enoate" );
standardThermochemistry
{
    dHf_298   -219040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-71310.0
}
