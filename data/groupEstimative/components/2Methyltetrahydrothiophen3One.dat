/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyltetrahydrothiophen-3-one  (C5H8OS, CAS 13679-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyltetrahydrothiophen3One;
formula     C5H8OS;
CAS         13679-85-1;
InChIKey    YMZZPMVKABUEBL-UHFFFAOYSA-N;
MW          116.178;      // g/mol [origin=calculated method=formula-sum]
Tc          682.35;      // K   [origin=predictive method=joback]
Pc          45.104;      // bar [origin=predictive method=joback]
omega       0.3112;      // -   [origin=predictive method=lee-kesler]
Tb          444.93;      // K   [origin=predictive method=joback]
HvapTb      37040.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.89 0.45663 -0.0001503 -1.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2CO; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group CdO_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylthiolan-3-one" "dihydro-2-methyl-3(2h)-thiophenone" "3(2h)-thiophenone, dihydro-2-methyl-" "2-methyl-3-tetrahydrothiophenone" "2-methyl-3-oxotetrahydrothiophene" "dihydro-2-methyl-3-thiophenone" "2-methyl tetrahydrothiophen-3-one" "2-methyldihydrothiophen-3(2h)-one" "dihydro-2-methylthiophen-3(2h)-one" "2-methyl-4,5-dihydro-3(2h)-thiophenone" "2-methyl-3-oxotetrahydrothiophene;2-methyl-4,5-dihydro-3(2h)-thiophenone;2-methylthiolan-3-one;2-methylthiophan-3-one;dihydro-2-methyl-3(2h)-thiophenone;dihydro-2-methyl-3-thiophenone;" );
gibbsFormation
{
    dHf_298   -178490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     271.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-54960.0
    phase     gas;
}
