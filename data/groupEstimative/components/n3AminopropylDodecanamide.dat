/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(3-aminopropyl)dodecanamide  (C15H32N2O, CAS 10375-08-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3AminopropylDodecanamide;
formula     C15H32N2O;
CAS         10375-08-3;
InChIKey    FTRKNUBBAPIZMS-UHFFFAOYSA-N;
MW          256.434;      // g/mol [origin=calculated method=formula-sum]
Tc          899.58;      // K   [origin=predictive method=joback]
Pc          15.685;      // bar [origin=predictive method=joback]
omega       1.1092;      // -   [origin=predictive method=lee-kesler]
Tb          719.37;      // K   [origin=predictive method=joback]
HvapTb      72807.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.893 1.53892 -0.0008655 1.7976e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH2NH2; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(3-azanylpropyl)dodecanamide" "dodecanamide, n-(3-aminopropyl)-" "dodecanoic acid, 1,3-propylenediamine monoamide" );
gibbsFormation
{
    dHf_298   -378250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     859.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102340.0
    phase     gas;
}
