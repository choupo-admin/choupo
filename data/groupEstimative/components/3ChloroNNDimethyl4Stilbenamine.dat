/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3'-chloro-n,n-dimethyl-4-stilbenamine  (C16H16ClN, CAS 63040-27-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ChloroNNDimethyl4Stilbenamine;
formula     C16H16ClN;
CAS         63040-27-7;
InChIKey    YEVLKSJVFNBMDH-UHFFFAOYSA-N;
MW          257.761;      // g/mol [origin=calculated method=formula-sum]
Tc          923.82;      // K   [origin=predictive method=joback]
Pc          22.483;      // bar [origin=predictive method=joback]
omega       0.6558;      // -   [origin=predictive method=lee-kesler]
Tb          683.03;      // K   [origin=predictive method=joback]
HvapTb      63472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.85 1.39774 -0.00099172 2.742e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 3; } { group CH3N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(3-chlorophenyl)ethenyl]-n,n-dimethyl-aniline" "3'-chloro-4-dimethylaminostilbene" "3'-chloro-4-stilbenyl-n,n-dimethylamine" "4-stilbenamine, 3'-chloro-n,n-dimethyl-" "3'-chloro-n,n-dimethylaminostiben [german]" "3'-chloro-n,n-dimethylaminostiben" "4-[2-(3-chlorophenyl)ethenyl]-n,n-dimethylaniline" );
standardThermochemistry
{
    dHf_298   245560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=468470.0
}
