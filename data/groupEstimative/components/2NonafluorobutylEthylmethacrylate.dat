/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(nonafluorobutyl)ethylmethacrylate  (C10H9F9O2, CAS 1799-84-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2NonafluorobutylEthylmethacrylate;
formula     C10H9F9O2;
CAS         1799-84-4;
InChIKey    TYNRPOFACABVSI-UHFFFAOYSA-N;
MW          332.162;      // g/mol [origin=calculated method=formula-sum]
Tc          608.03;      // K   [origin=predictive method=joback]
Pc          16.592;      // bar [origin=predictive method=joback]
omega       0.7023;      // -   [origin=predictive method=lee-kesler]
Tb          463.69;      // K   [origin=predictive method=joback]
HvapTb      32134.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.548 1.48832 -0.0012856 4.079e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group CF3; count 1; } { group CF2; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group F; count 9; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,5,5,6,6,6-nonakis(fluoranyl)hexyl 2-methylprop-2-enoate" "3,3,4,4,5,5,6,6,6-nonafluorohexyl methacrylate" "2-(nonafluorobutyl)ethyl methacrylate" "2-(perfluorobutyl)ethyl methacrylate" "1h,1h,2h,2h-perfluorohexyl methacrylate" "3,3,4,4,5,5,6,6,6-nonafluorohexyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 3,3,4,4,5,5,6,6,6-nonafluorohexyl ester" "methacrylic acid, 3,3,4,4,5,5,6,6,6-nonafluorohexyl ester" "2-propenoic acid,2-methyl-, 3,3,4,4,5,5,6,6,6-nonafluorohexyl ester" );
gibbsFormation
{
    dHf_298   -2251360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     717.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1939690.0
    phase     gas;
}
