/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-isopropylcyclopentene  (C8H14, CAS 4276-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Isopropylcyclopentene;
formula     C8H14;
CAS         4276-45-3;
InChIKey    WGGDPEMWUJIPOF-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          596.23;      // K   [origin=predictive method=joback]
Pc          32.210;      // bar [origin=predictive method=joback]
omega       0.2721;      // -   [origin=predictive method=lee-kesler]
Tb          396.64;      // K   [origin=predictive method=joback]
HvapTb      33563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.77 0.84544 -0.00052928 1.272e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-propan-2-ylcyclopentene" "cyclopentene,3-(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -95470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     370.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80550.0
    phase     gas;
}
