/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethenylaziridine  (C4H7N, CAS 5628-99-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethenylaziridine;
formula     C4H7N;
CAS         5628-99-9;
InChIKey    VZNJDNKFUXILTJ-UHFFFAOYSA-N;
MW          69.107;      // g/mol [origin=calculated method=formula-sum]
Tc          480.86;      // K   [origin=predictive method=joback]
Pc          49.315;      // bar [origin=predictive method=joback]
omega       0.2671;      // -   [origin=predictive method=lee-kesler]
Tb          307.38;      // K   [origin=predictive method=joback]
HvapTb      25921.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.49 0.6747 -0.0006513 2.486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-vinylaziridine" "aziridine, 1-ethenyl-" "n-vinylethyleneimine" "aziridine, 1-vinyl-" "1-vinyl aziridine" "1-vinylaziridine" "n-vinylethylenimine" "aziridine, 1-ethenyl- (9ci)" "aziridine,1-vinyl- (7ci,8ci); 1-vinylaziridine; n-vinylethylenimine" );
standardThermochemistry
{
    dHf_298   166370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     255.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=261980.0
}
