/*--------------------------------*- Choupo -*-----------------------*\
  Component: isononyl 6-aminohexanoate  (C15H31NO2, CAS 72066-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isononyl6Aminohexanoate;
formula     C15H31NO2;
CAS         72066-93-4;
InChIKey    YTBVJJCLLLCHCU-UHFFFAOYSA-N;
MW          257.418;      // g/mol [origin=calculated method=formula-sum]
Tc          849.92;      // K   [origin=predictive method=joback]
Pc          14.930;      // bar [origin=predictive method=joback]
omega       0.9656;      // -   [origin=predictive method=lee-kesler]
Tb          673.11;      // K   [origin=predictive method=joback]
HvapTb      66644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.471 1.44184 -0.0007442 1.207e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group CH2COO; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methyloctyl 6-azanylhexanoate" "hexanoic acid, 6-amino-, isononyl ester" "7-methyloctyl 6-aminohexanoate" );
standardThermochemistry
{
    dHf_298   -641700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     833.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-170940.0
}
