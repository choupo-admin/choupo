/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexyl-1,1,1,3,5,5,5-heptamethyltrisiloxane  (C13H34O2Si3, CAS 190-90-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H34O2Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Hexyl1113555Heptamethyltrisiloxane;
formula     C13H34O2Si3;
CAS         190-90-9;
InChIKey    PNJMJEXVQAFSBS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          306.668;      // g/mol [origin=calculated method=formula-sum]
Tc          720.01;      // K   [origin=predictive method=joback]
Pc          12.226;      // bar [origin=predictive method=joback]
omega       0.4727;      // -   [origin=predictive method=lee-kesler]
Tb          546.08;      // K   [origin=predictive method=joback]
HvapTb      50234.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (164.525 0.49396 0.000783 -6.177e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 5; } { group Si; count 1; } { group SiO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 5; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexyl-methyl-bis(trimethylsilyloxy)silane" "1-hexyl-1,3,3,3-tetramethyl-1-((trimethylsilyl)oxy)disiloxane" "disiloxane, 1-hexyl-1,3,3,3-tetramethyl-1-((trimethylsilyl)oxy)-" "trisiloxane, 3-hexyl-1,1,1,3,5,5,5-heptamethyl-" );
standardThermochemistry
{
    dHf_298   -910950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1064.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-465700.0
}
