/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethene-1,2-diol  (C2H4O2, CAS 1571-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethene12Diol;
formula     C2H4O2;
CAS         1571-60-4;
InChIKey    JMCRDEBJJPRTPV-UHFFFAOYSA-N;
MW          60.052;      // g/mol [origin=calculated method=formula-sum]
Tc          601.25;      // K   [origin=predictive method=joback]
Pc          72.554;      // bar [origin=predictive method=joback]
omega       1.0808;      // -   [origin=predictive method=lee-kesler]
Tb          433.88;      // K   [origin=predictive method=joback]
HvapTb      53362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.53 0.2818 -0.0002296 7.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-ethene-1,2-diol" "1,2-ethenediol, (1e)-" "1,2-ethenediol(7ci,8ci,9ci)" "1,2-ethenediol, (1z)-(9ci)" "1,2-dihydroxyethene;1,2-dihydroxyethylene" "1,2-ethenediol,(z)-; (z)-1,2-dihydroxyethene; cis-1,2-dihydroxyethylene; cis-1,2-ethenediol" );
gibbsFormation
{
    dHf_298   -271850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     329.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-227460.0
    phase     gas;
}
