/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl orsellinate  (C9H10O4, CAS 3187-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylOrsellinate;
formula     C9H10O4;
CAS         3187-58-4;
InChIKey    NCCWCZLEACWJIN-UHFFFAOYSA-N;
MW          182.175;      // g/mol [origin=calculated method=formula-sum]
Tc          892.41;      // K   [origin=predictive method=joback]
Pc          46.721;      // bar [origin=predictive method=joback]
omega       1.0155;      // -   [origin=predictive method=lee-kesler]
Tb          656.64;      // K   [origin=predictive method=joback]
HvapTb      72001.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.33 0.97484 -0.00084808 3.056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-methyl-4,6-bis(oxidanyl)benzoate" "methyl 2,4-dihydroxy-6-methylbenzoate" "methyl 4,6-dihydroxy-2-methylbenzoate" "benzoic acid, 2,4-dihydroxy-6-methyl-, methyl ester" "methyl 2,4-dihydroxy-6-methyl benzoate" ".beta.-resorcylic acid, 6-methyl-, methyl ester" "benzoic acid,2,4-dihydroxy-6-methyl-, methyl ester" "b-resorcylic acid, 6-methyl-,methyl ester (6ci,7ci,8ci); 2,4-dihydroxy-6-methylbenzoic acid methyl ester;methyl 2,4-dihydroxy-6-methylbenzoate; methyl 2,4-hydroxy-6-methylbenzoate;methyl 6-methyl-b-resorcylate;methyl o-orsellinate; methyl orsellinate; orsellinic acid methyl ester;orsellinic acid monomethyl ester" );
standardThermochemistry
{
    dHf_298   -675930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-491930.0
}
