/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxepanone, trimethyl-  (C9H16O2, CAS 64047-30-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OxepanoneTrimethyl;
formula     C9H16O2;
CAS         64047-30-9;
InChIKey    XXCRXPYEAMCJKH-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          680.61;      // K   [origin=predictive method=joback]
Pc          28.143;      // bar [origin=predictive method=joback]
omega       0.4244;      // -   [origin=predictive method=lee-kesler]
Tb          474.59;      // K   [origin=predictive method=joback]
HvapTb      41832.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.42 1.20116 -0.0009758 3.481e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4-trimethyloxepan-2-one" "agn-pc-03dgfs" "hexanoicacid, 6-hydroxytrimethyl-, e-lactone (7ci)" );
gibbsFormation
{
    dHf_298   -490990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-262120.0
    phase     gas;
}
