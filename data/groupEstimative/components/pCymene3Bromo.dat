/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-cymene, 3-bromo-  (C10H13Br, CAS 4478-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pCymene3Bromo;
formula     C10H13Br;
CAS         4478-10-8;
InChIKey    XMIWWDSQSRUTKQ-UHFFFAOYSA-N;
MW          213.118;      // g/mol [origin=calculated method=formula-sum]
Tc          759.14;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.4775;      // -   [origin=predictive method=lee-kesler]
Tb          530.76;      // K   [origin=predictive method=joback]
HvapTb      47501.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.0 0.80006 -0.00049192 1.171e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-4-methyl-1-propan-2-yl-benzene" "benzene, 2-bromo-4-methyl-1-(1-methylethyl)-" "2 - bromo - p - cymene" "2-bromo-4-methyl-1-propan-2-ylbenzene" "2-bromo-4-methyl-1-isopropylbenzene" );
standardThermochemistry
{
    dHf_298   -15090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=138350.0
}
