/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropa[b]naphthalene, 1,1-difluoro-  (C11H6F2, CAS 76266-17-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropaBNaphthalene11Difluoro;
formula     C11H6F2;
CAS         76266-17-6;
InChIKey    IODQPPRCWKIQOR-UHFFFAOYSA-N;
MW          176.165;      // g/mol [origin=calculated method=formula-sum]
Tc          725.51;      // K   [origin=predictive method=joback]
Pc          34.889;      // bar [origin=predictive method=joback]
omega       0.4954;      // -   [origin=predictive method=lee-kesler]
Tb          503.88;      // K   [origin=predictive method=joback]
HvapTb      42104.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.67 1.3328 -0.00148684 6.448e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(fluoranyl)cyclopropa[b]naphthalene" "cyclopropa(b)naphthalene, 1,1-difluoro-" "1,1-difluorocyclopropa[b]naphthalene" "1,1-difluoro-1h-cyclopropa[b]naphthalene" );
gibbsFormation
{
    dHf_298   -157570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     359.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68620.0
    phase     gas;
}
