/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutyraldehyde  (C4H8O, CAS 78-84-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutyraldehyde;
formula     C4H8O;
CAS         78-84-2;
InChIKey    AMIMRNSIRUDHCM-UHFFFAOYSA-N;
MW          72.107;      // g/mol [origin=calculated method=formula-sum]
Tc          516.65;      // K   [origin=predictive method=joback]
Pc          43.283;      // bar [origin=predictive method=joback]
omega       0.3254;      // -   [origin=predictive method=lee-kesler]
Tb          339.34;      // K   [origin=predictive method=joback]
HvapTb      30830.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.97 0.36424 -0.00019 3.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropanal" "isobutylaldehyde" "propanal, 2-methyl-" "isobutanal" "2-methylpropionaldehyde" "isobutyric aldehyde" "methylpropanal" "valine aldehyde" "isopropylaldehyde" "isopropylformaldehyde" "2-methyl-1-propanal" "isobutaldehyde" );
standardThermochemistry
{
    dHf_298   -216750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     320.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-119160.0
}
