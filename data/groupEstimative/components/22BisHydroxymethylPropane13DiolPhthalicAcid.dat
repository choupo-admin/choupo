/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(hydroxymethyl)propane-1,3-diol;phthalic acid  (C13H18O8, CAS 15015-84-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BisHydroxymethylPropane13DiolPhthalicAcid;
formula     C13H18O8;
CAS         15015-84-6;
InChIKey    BFRLRGJQKQUFHK-UHFFFAOYSA-N;
MW          302.279;      // g/mol [origin=calculated method=formula-sum]
Tc          1476.99;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       1.8448;      // -   [origin=predictive method=lee-kesler]
Tb          1186.61;      // K   [origin=predictive method=joback]
HvapTb      147512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.174 1.2576 -0.00067136 9.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)propane-1,3-diol; phthalic acid" "benzene-1,2-dicarboxylic acid- 2,2-bis(hydroxymethyl)propane-1,3-diol(1:1)" "benzene-1,2-dicarboxylic acid - 2,2-bis(hydroxymethyl)propane-1,3-diol (1:1)" );
standardThermochemistry
{
    dHf_298   -1516420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     928.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1175660.0
}
