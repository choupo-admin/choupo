/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-chlorophenyl)ethanol  (C8H9ClO, CAS 5182-44-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23ChlorophenylEthanol;
formula     C8H9ClO;
CAS         5182-44-5;
InChIKey    NDWAVJKRSASRPH-UHFFFAOYSA-N;
MW          156.609;      // g/mol [origin=calculated method=formula-sum]
Tc          747.56;      // K   [origin=predictive method=joback]
Pc          38.340;      // bar [origin=predictive method=joback]
omega       0.8246;      // -   [origin=predictive method=lee-kesler]
Tb          543.91;      // K   [origin=predictive method=joback]
HvapTb      57404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.808 0.6662 -0.00042636 1.034e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group OH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzeneethanol, 3-chloro-" "3-chlorophenethyl alcohol" "3-chlorophenethylalcohol" "2-(3-chlorophenyl)ethan-1-ol" "phenethyl alcohol, m-chloro-" "m-chlorophenethyl alcohol" "m-chlorophenethylic alcohol" "3-chloro-benzeneethanol" "3-chloro-beta-phenethyl alcohol" "2-(3-chlorophenyl)ethanol;2-(3-chlorophenyl)ethyl alcohol;3-chlorophenethyl alcohol;phenethylalcohol, m-chloro- (6ci,7ci,8ci);ac1l2w3v;" );
gibbsFormation
{
    dHf_298   -151360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29490.0
    phase     gas;
}
