/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hentriacontene  (C31H62, CAS 18435-54-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hentriacontene;
formula     C31H62;
CAS         18435-54-6;
InChIKey    YITPJHKSILJOFQ-UHFFFAOYSA-N;
MW          434.837;      // g/mol [origin=calculated method=formula-sum]
Tc          1118.55;      // K   [origin=predictive method=joback]
Pc          5.801;      // bar [origin=predictive method=joback]
omega       0.3988;      // -   [origin=predictive method=lee-kesler]
Tb          905.56;      // K   [origin=predictive method=joback]
HvapTb      83930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.282 2.92882 -0.0016855 3.751e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 28; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 28; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hentriacont-1-ene" "hentriacontene" "1-untriacontene" );
standardThermochemistry
{
    dHf_298   -557740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1358.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=297980.0
}
