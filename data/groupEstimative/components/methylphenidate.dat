/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylphenidate  (C14H19NO2, CAS 113-45-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylphenidate;
formula     C14H19NO2;
CAS         113-45-1;
InChIKey    DUGOZIWVEXMGBE-UHFFFAOYSA-N;
MW          233.311;      // g/mol [origin=calculated method=formula-sum]
Tc          913.09;      // K   [origin=predictive method=joback]
Pc          25.303;      // bar [origin=predictive method=joback]
omega       0.6932;      // -   [origin=predictive method=lee-kesler]
Tb          672.48;      // K   [origin=predictive method=joback]
HvapTb      63240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.7 1.31472 -0.000698 1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2NH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-phenyl-2-piperidin-2-yl-ethanoate" "daytrana" "methylphenidan" "phenidylate" "methylin" "metilfenidato" "calocain" "plimasine" "concerta" "meridil" "ritalin" "methylphenidatum" );
standardThermochemistry
{
    dHf_298   -326190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-21240.0
}
