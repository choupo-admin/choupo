/*--------------------------------*- Choupo -*-----------------------*\
  Component: di(neopentylglycol) hydroxypivalate  (C15H30O5, CAS 112484-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diNeopentylglycolHydroxypivalate;
formula     C15H30O5;
CAS         112484-43-2;
InChIKey    NTHVXGUXZILPFV-UHFFFAOYSA-N;
MW          290.4;      // g/mol [origin=calculated method=formula-sum]
Tc          983.81;      // K   [origin=predictive method=joback]
Pc          17.061;      // bar [origin=predictive method=joback]
omega       1.3514;      // -   [origin=predictive method=lee-kesler]
Tb          797.67;      // K   [origin=predictive method=joback]
HvapTb      87883.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.357 1.76224 -0.001166 2.902e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 2; } { group CH; count 1; } { group C; count 3; } { group OH; count 2; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 3; } { group CH; count 1; } { group C; count 3; } { group OH; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpropyl 3-(2,2-dimethyl-3-oxidanyl-propoxy)-2,2-dimethyl-3-oxidanyl-propanoate" "2,2-dimethylpropyl 3-hydroxy-3-(3-hydroxy-2,2-dimethylpropoxy)-2,2-dimethylpropanoate" "propanoic acid, 3-hydroxy-2,2-dimethyl-, 3-(3-hydroxy-2,2-dimethylpropoxy)-2,2-dimethylpropyl ester" "hydroxypivalic acid, di(neopentylglycol) ester" );
standardThermochemistry
{
    dHf_298   -1138420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     778.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-607510.0
}
