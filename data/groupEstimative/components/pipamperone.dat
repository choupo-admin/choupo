/*--------------------------------*- Choupo -*-----------------------*\
  Component: pipamperone  (C21H30FN3O2, CAS 1893-33-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pipamperone;
formula     C21H30FN3O2;
CAS         1893-33-0;
InChIKey    AXKPFOAXAHJUAG-UHFFFAOYSA-N;
MW          375.488;      // g/mol [origin=calculated method=formula-sum]
Tc          1187.78;      // K   [origin=predictive method=joback]
Pc          18.170;      // bar [origin=predictive method=joback]
omega       1.2508;      // -   [origin=predictive method=lee-kesler]
Tb          951.63;      // K   [origin=predictive method=joback]
HvapTb      92352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-206.787 2.7077 -0.00217316 7.1782e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 1; } { group CH2N; count 2; } { group ACF; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 9; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group CdO; count 2; } { group NH2; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-(4-fluorophenyl)-4-oxidanylidene-butyl]-4-piperidin-1-yl-piperidine-4-carboxamide" "floropipamide" "dipiperon" "dipiperone" "piperonil" "piperonyl" "dipiperal" "pipamperonum [inn-latin]" "pipamperone dihydrochloride" "pipaneperone" "(1,4'-bipiperidine)-4'-carboxamide, 1'-(3-(p-fluorobenzoyl)propyl)-" "pipamperone hcl" );
gibbsFormation
{
    dHf_298   -347590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1041.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=139400.0
    phase     gas;
}
