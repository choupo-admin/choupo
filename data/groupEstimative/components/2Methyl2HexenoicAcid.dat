/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-2-hexenoic acid  (C7H12O2, CAS 28897-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl2HexenoicAcid;
formula     C7H12O2;
CAS         28897-58-7;
InChIKey    AKOVMBAFZSPEQU-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          708.40;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.6670;      // -   [origin=predictive method=lee-kesler]
Tb          509.31;      // K   [origin=predictive method=joback]
HvapTb      48378.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.748 0.73954 -0.0005157 1.493e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylhex-2-enoic acid" "2-hexenoic acid, 2-methyl-, (2e)-" "2-methyl-2-hexenoicacid" "2-hexenoic acid,2-methyl-" );
gibbsFormation
{
    dHf_298   -430650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-264180.0
    phase     gas;
}
