/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4′-Bisphenol A  (C15H16O2, CAS 837-08-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24BisphenolA;
formula     C15H16O2;
CAS         837-08-1;
InChIKey    MLCQXUZZAXKTSG-UHFFFAOYSA-N;
MW          228.291;      // g/mol [origin=calculated method=formula-sum]
Tc          1018.89;      // K   [origin=predictive method=joback]
Pc          35.473;      // bar [origin=predictive method=joback]
omega       0.9144;      // -   [origin=predictive method=lee-kesler]
Tb          754.17;      // K   [origin=predictive method=joback]
HvapTb      78268.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.87 1.70604 -0.00153912 5.564e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(4-hydroxyphenyl)propan-2-yl]phenol" "2,4′-dihydroxydiphenyldimethylmethane" "2,4′-isopropylidenebisphenol" "2,4′-isopropylidenediphenol" "2-(2-hydroxyphenyl)-2-(4-hydroxyphenyl)propane" "2-[1-(4-hydroxyphenyl)-1-methylethyl]phenol" "4-[2-(2-Hydroxyphenyl)-2-propyl]phenol" "phenol, 2,4′-isopropylidenedi-" "Phenol, 2-[1-(4-hydroxyphenyl)-1-methylethyl]-" "o,p-diphenylolpropane" "o,p′-bisphenol a" "o,p′-dian" );
gibbsFormation
{
    dHf_298   -243240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6160.0
    phase     gas;
}
