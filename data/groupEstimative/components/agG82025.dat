/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-82025  (C11H19NO, CAS 7182-08-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG82025;
formula     C11H19NO;
CAS         7182-08-3;
InChIKey    HLVQJUUPEMTTIS-UHFFFAOYSA-N;
MW          181.279;      // g/mol [origin=calculated method=formula-sum]
Tc          777.24;      // K   [origin=predictive method=joback]
Pc          31.280;      // bar [origin=predictive method=joback]
omega       0.4818;      // -   [origin=predictive method=lee-kesler]
Tb          543.25;      // K   [origin=predictive method=joback]
HvapTb      49063.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.49 1.3514 -0.00086634 2.033e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH=C; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(cyclohepten-1-yl)morpholine" "morpholine, 4-(1-cyclohepten-1-yl)-" "4-cyclohept-1-en-1-ylmorpholine" "4-(1-cyclohepten-1-yl)morpholine" "morpholine,4-(1-cyclohepten-1-yl)-" );
gibbsFormation
{
    dHf_298   -139210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=151050.0
    phase     gas;
}
