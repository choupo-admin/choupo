/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-trimethyl-4-(isopropenyl)-1-cyclohexene  (C12H20, CAS 68443-73-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Trimethyl4Isopropenyl1Cyclohexene;
formula     C12H20;
CAS         68443-73-2;
InChIKey    JARFYGJEQCRGOP-UHFFFAOYSA-N;
MW          164.292;      // g/mol [origin=calculated method=formula-sum]
Tc          687.80;      // K   [origin=predictive method=joback]
Pc          21.374;      // bar [origin=predictive method=joback]
omega       0.3593;      // -   [origin=predictive method=lee-kesler]
Tb          485.07;      // K   [origin=predictive method=joback]
HvapTb      42481.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.35 1.07738 -0.00054464 8.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 3; } { group CH2=C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-trimethyl-4-prop-1-en-2-yl-cyclohexene" "1,3,5-trimethyl-4-(1-methylvinyl)cyclohexene" "cyclohexene, 1,3,5-trimethyl-4-(1-methylethenyl)-" "agn-pc-00givo" "1,3,5-trimethyl-4-prop-1-en-2-ylcyclohexene" );
standardThermochemistry
{
    dHf_298   -115420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158810.0
}
