/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dichloro-1,1,2,2,3,3-hexafluoropropane  (C3Cl2F6, CAS 662-01-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dichloro112233Hexafluoropropane;
formula     C3Cl2F6;
CAS         662-01-1;
InChIKey    JETINLPZEWINFD-UHFFFAOYSA-N;
MW          220.921;      // g/mol [origin=calculated method=formula-sum]
Tc          486.49;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.3257;      // -   [origin=predictive method=lee-kesler]
Tb          329.03;      // K   [origin=predictive method=joback]
HvapTb      22252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.93 0.7506 -0.000794 2.918e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CF2; count 1; } { group CClF2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group F; count 6; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)-1,1,2,2,3,3-hexakis(fluoranyl)propane" "1,3-dichlorohexafluoropropane" "1,3-dichloro-1,1,2,2,3,3-hexafluoro-propane" "propane,1,3-dichloro-1,1,2,2,3,3-hexafluoro-" "1,1,2,2,3,3-hexafluoro-1,3-dichloropropane" "propane,1,3-dichlorohexafluoro- (6ci,7ci,8ci);1,3-dichloro-1,1,2,2,3,3-hexafluoropropane; 1,3-dichlorohexafluoropropane; hcfc216ca" );
gibbsFormation
{
    dHf_298   -1339640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1209820.0
    phase     gas;
}
