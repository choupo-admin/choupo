/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutyl bromoacetate  (C6H11BrO2, CAS 59956-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutylBromoacetate;
formula     C6H11BrO2;
CAS         59956-48-8;
InChIKey    UOUQDZFAJUNYQQ-UHFFFAOYSA-N;
MW          195.056;      // g/mol [origin=calculated method=formula-sum]
Tc          656.36;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.5435;      // -   [origin=predictive method=lee-kesler]
Tb          460.82;      // K   [origin=predictive method=joback]
HvapTb      42404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.352 0.56314 -0.0002826 3.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2COO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropyl 2-bromanylethanoate" "bromoacetic acid, 2-methylpropyl ester" "2-methylpropyl 2-bromoacetate" "acetic acid, bromo-, 2-methylpropyl ester" );
gibbsFormation
{
    dHf_298   -463400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-298850.0
    phase     gas;
}
