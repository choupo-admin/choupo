/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexamethylbenzene  (C12H18, CAS 87-85-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexamethylbenzene;
formula     C12H18;
CAS         87-85-4;
InChIKey    YUWFEBAXEOLKSG-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          730.80;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.4839;      // -   [origin=predictive method=lee-kesler]
Tb          525.74;      // K   [origin=predictive method=joback]
HvapTb      47892.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.57 0.76752 -0.000325 3.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACCH3; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5,6-hexamethylbenzene" "mellitene" "benzene, hexamethyl-" "1,2,3,4,5,6-hexamethyl-benzene" "benzene, 1,2,3,4,5,6-hexamethyl-" "hexamethylbenzol" "benzene,hexamethyl" "agn-pc-0cozl2" "1,2,3,4,5,6-hexamethylcyclohexane-1,2,3,4,5,6-hexaide" );
gibbsFormation
{
    dHf_298   -111830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114420.0
    phase     gas;
}
