/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-(octahydro-4,7-methano-1h-indenediyl)bis(6-tert-butyl-p-cresol)  (C32H44O2, CAS 41699-00-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Octahydro47Methano1hIndenediylBis6TertButylPCresol;
formula     C32H44O2;
CAS         41699-00-7;
InChIKey    UIPRADCHGCDTNY-UHFFFAOYSA-N;
MW          460.702;      // g/mol [origin=calculated method=formula-sum]
Tc          1436.81;      // K   [origin=predictive method=joback]
Pc          10.849;      // bar [origin=predictive method=joback]
omega       1.0091;      // -   [origin=predictive method=lee-kesler]
Tb          1170.30;      // K   [origin=predictive method=joback]
HvapTb      116446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-241.63 3.57256 -0.00281556 9.144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 4; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } { group ACCH3; count 2; } { group ACCH; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group C; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2'-octahydro-1h-4,7-methanoindene-1,5-diylbis(6-tert-butyl-4-methylphenol)" "phenol, 2,2'-(octahydro-4,7-methano-1h-indenediyl)bis(6-(1,1-dimethylethyl)-4-methyl-" );
standardThermochemistry
{
    dHf_298   -497530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     762.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=248320.0
}
