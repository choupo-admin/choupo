/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutyric acid  (C4H8O2, CAS 79-31-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutyricAcid;
formula     C4H8O2;
CAS         79-31-2;
InChIKey    KQNPFQTWMSNSAP-UHFFFAOYSA-N;
MW          88.106;      // g/mol [origin=calculated method=formula-sum]
Tc          633.93;      // K   [origin=predictive method=joback]
Pc          44.150;      // bar [origin=predictive method=joback]
omega       0.5441;      // -   [origin=predictive method=lee-kesler]
Tb          436.19;      // K   [origin=predictive method=joback]
HvapTb      41274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.17 0.44054 -0.0002696 6.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropanoic acid" "isobutanoic acid" "propanoic acid, 2-methyl-" "2-methylpropionic acid" "dimethylacetic acid" "isobutyrate" "isopropylformic acid" "iso-butyric acid" "alpha-methylpropanoic acid" "alpha-methylpropionic acid" "cenex rp b2" "isobutanoate" );
standardThermochemistry
{
    dHf_298   -481440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-363550.0
}
