/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, 2-methylpropyl ester, polymer with 2-ethylhexyl 2-propenoate and 2-hydroxyethyl 2-propenoate  (C24H42O7, CAS 71839-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2Methyl2MethylpropylEsterPolymerWith2Ethylhexy;
formula     C24H42O7;
CAS         71839-66-2;
InChIKey    XTPJCXNCHNJLSQ-UHFFFAOYSA-N;
MW          442.593;      // g/mol [origin=calculated method=formula-sum]
Tc          1239.13;      // K   [origin=predictive method=joback]
Pc          8.431;      // bar [origin=predictive method=joback]
omega       0.7640;      // -   [origin=predictive method=lee-kesler]
Tb          1007.40;      // K   [origin=predictive method=joback]
HvapTb      105800.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (132.198 1.6928 -0.0002762 -2.685e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 8; } { group CH; count 2; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group OH; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 8; } { group CH; count 2; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group OH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylhexyl prop-2-enoate;2-hydroxyethyl prop-2-enoate;2-methylpropyl 2-methylprop-2-enoate" "isobutyl methacrylate, 2-ethylhexyl acrylate, beta-hydroxyethyl acrylate polymer" );
gibbsFormation
{
    dHf_298   -1510060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1473.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-876160.0
    phase     gas;
}
