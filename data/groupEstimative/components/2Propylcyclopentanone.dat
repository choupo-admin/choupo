/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propylcyclopentanone  (C8H14O, CAS 1193-70-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propylcyclopentanone;
formula     C8H14O;
CAS         1193-70-0;
InChIKey    PFUCFFRQJFQQHE-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          677.73;      // K   [origin=predictive method=joback]
Pc          31.883;      // bar [origin=predictive method=joback]
omega       0.4062;      // -   [origin=predictive method=lee-kesler]
Tb          465.74;      // K   [origin=predictive method=joback]
HvapTb      37906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.438 0.72722 -0.0002948 1.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propylcyclopentan-1-one" "cyclopentanone, 2-propyl-" );
standardThermochemistry
{
    dHf_298   -285670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     338.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-69560.0
}
