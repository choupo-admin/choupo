/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-2-(dimethylaminomethyl)phenol  (C9H12ClNO, CAS 54828-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro2DimethylaminomethylPhenol;
formula     C9H12ClNO;
CAS         54828-00-1;
InChIKey    WPEGHIRPYPPYDO-UHFFFAOYSA-N;
MW          185.651;      // g/mol [origin=calculated method=formula-sum]
Tc          792.13;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.6961;      // -   [origin=predictive method=lee-kesler]
Tb          567.67;      // K   [origin=predictive method=joback]
HvapTb      58008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.619 1.00574 -0.00081932 2.76e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-2-[(dimethylamino)methyl]phenol" "4-chloro-a-(dimethylamino)-o-cresol" "4-chloro-2-[(dimethylamino)methyl]phenol" );
standardThermochemistry
{
    dHf_298   -129550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71910.0
}
