/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,5,9,10-tetrahydropyrene  (C16H14, CAS 781-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        45910Tetrahydropyrene;
formula     C16H14;
CAS         781-17-9;
InChIKey    XDFUNRTWHPWCKO-UHFFFAOYSA-N;
MW          206.288;      // g/mol [origin=calculated method=formula-sum]
Tc          904.45;      // K   [origin=predictive method=joback]
Pc          28.414;      // bar [origin=predictive method=joback]
omega       0.6244;      // -   [origin=predictive method=lee-kesler]
Tb          653.24;      // K   [origin=predictive method=joback]
HvapTb      58510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-124.39 1.502 -0.00128484 4.454e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyrene, 4,5,9,10-tetrahydro-" );
standardThermochemistry
{
    dHf_298   252210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=431260.0
}
