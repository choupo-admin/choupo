/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-azanylethanol;6-(2-ethylhexanoylamino)hexanoic acid  (C16H34N2O4, CAS 75113-48-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Azanylethanol62EthylhexanoylaminoHexanoicAcid;
formula     C16H34N2O4;
CAS         75113-48-3;
InChIKey    XAVBWLUBRPYLNE-UHFFFAOYSA-N;
MW          318.458;      // g/mol [origin=calculated method=formula-sum]
Tc          1201.23;      // K   [origin=predictive method=joback]
Pc          15.747;      // bar [origin=predictive method=joback]
omega       1.3778;      // -   [origin=predictive method=lee-kesler]
Tb          980.90;      // K   [origin=predictive method=joback]
HvapTb      108782.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.011 1.51844 -0.0006113 1.176e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group OH; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 1; } { group OH; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanoic acid, 6-((2-ethyl-1-oxohexyl)amino)-, compd. with 2-aminoethanol (1:1)" "hexanoic acid, 6-((2-ethylhexanoyl)amino)-, compd. with 2-aminoethanol (1:1)" );
gibbsFormation
{
    dHf_298   -1018290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1100.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-477170.0
    phase     gas;
}
