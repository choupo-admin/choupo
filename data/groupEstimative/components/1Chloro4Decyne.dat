/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-4-decyne  (C10H17Cl, CAS 26817-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro4Decyne;
formula     C10H17Cl;
CAS         26817-65-2;
InChIKey    WQROTKWHQIGFTO-UHFFFAOYSA-N;
MW          172.696;      // g/mol [origin=calculated method=formula-sum]
Tc          665.61;      // K   [origin=predictive method=joback]
Pc          23.680;      // bar [origin=predictive method=joback]
omega       0.4647;      // -   [origin=predictive method=lee-kesler]
Tb          474.83;      // K   [origin=predictive method=joback]
HvapTb      44391.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.247 0.81082 -0.00044846 9.578e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH2Cl; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group tC; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyldec-4-yne" "1-chlorodec-4-yne" "4-decyne, 1-chloro-" );
gibbsFormation
{
    dHf_298   6830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=224190.0
    phase     gas;
}
