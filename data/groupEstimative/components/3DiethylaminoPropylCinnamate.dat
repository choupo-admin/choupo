/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(diethylamino)propyl cinnamate  (C16H23NO2, CAS 4361-80-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3DiethylaminoPropylCinnamate;
formula     C16H23NO2;
CAS         4361-80-2;
InChIKey    CHLMFHKZCVSJIJ-UHFFFAOYSA-N;
MW          261.365;      // g/mol [origin=calculated method=formula-sum]
Tc          865.19;      // K   [origin=predictive method=joback]
Pc          17.834;      // bar [origin=predictive method=joback]
omega       0.8406;      // -   [origin=predictive method=lee-kesler]
Tb          667.18;      // K   [origin=predictive method=joback]
HvapTb      62894.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.025 1.53404 -0.0009796 2.324e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(diethylamino)propyl 3-phenylprop-2-enoate" "2-propenoic acid,3-phenyl-, 3-(diethylamino)propyl ester" "cinnamicacid, 3-(diethylamino)propyl ester (8ci); 1-propanol, 3-(diethylamino)-,cinnamate (ester); apothesine" );
standardThermochemistry
{
    dHf_298   -269570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     733.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76880.0
}
