/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxy-4-(1-phenylethyl)benzene  (C15H16O, CAS 2605-18-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxy41PhenylethylBenzene;
formula     C15H16O;
CAS         2605-18-7;
InChIKey    JMOKUPRAECXBIE-UHFFFAOYSA-N;
MW          212.292;      // g/mol [origin=calculated method=formula-sum]
Tc          860.49;      // K   [origin=predictive method=joback]
Pc          24.507;      // bar [origin=predictive method=joback]
omega       0.5671;      // -   [origin=predictive method=lee-kesler]
Tb          623.12;      // K   [origin=predictive method=joback]
HvapTb      56220.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.44 1.15424 -0.00067976 1.381e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACCH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-4-(1-phenyl-ethyl)benzene" "benzene,1-methoxy-4-(1-phenylethyl)-" "benzene, 1-methoxy-4-(1-phenylethyl)-" "1-methoxy-4-(1-phenyl-ethyl)-benzene" );
gibbsFormation
{
    dHf_298   -28840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=183170.0
    phase     gas;
}
