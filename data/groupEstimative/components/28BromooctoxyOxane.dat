/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(8-bromooctoxy)oxane  (C13H25BrO2, CAS 50816-20-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        28BromooctoxyOxane;
formula     C13H25BrO2;
CAS         50816-20-1;
InChIKey    JCRBYQZIJFWGOO-UHFFFAOYSA-N;
MW          293.245;      // g/mol [origin=calculated method=formula-sum]
Tc          832.19;      // K   [origin=predictive method=joback]
Pc          20.327;      // bar [origin=predictive method=joback]
omega       0.7980;      // -   [origin=predictive method=lee-kesler]
Tb          632.12;      // K   [origin=predictive method=joback]
HvapTb      58316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.522 1.3329 -0.0007109 1.237e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Br; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(8-bromanyloctoxy)oxane" "2h-pyran, 2-[(8-bromooctyl)oxy]tetrahydro-" "1-bromo-8-tetrahydropyranyloxyoctane" "2h-pyran, 2-((8-bromooctyl)oxy)tetrahydro-" "8-bromooctyl tetrahydropyranyl ether" "1-(2-tetrahydropyranyloxy)-8-bromooctane" "2-(8-bromooctyloxy)tetrahydropyran" "2-((8-bromooctyl)oxy)tetrahydro-2h-pyran" "2h-pyran,2-[(8-bromooctyl)oxy]tetrahydro-" "1-bromo-8-(tetrahydropyranyloxy)octane" "1-(2h-3,4,5,6-tetrahydropyran-2-yloxy)-8-bromooctane" "1-(2-tetrahydropyranyloxy)-8-bromooctane;1-bromo-8-(tetrahydro-2-pyranyloxy)octane; 2-[(8-bromooctyl)oxy]tetrahydro-2h-pyran;2-[(8-bromooctyl)oxy]tetrahydropyran; 8-(tetrahydropyranyloxy)octyl bromide;8-bromo-1-[(tetrahydropyran-2-yl)oxy]octane; 8-bromo-1-octanoltetrahydropyranyl ether" );
standardThermochemistry
{
    dHf_298   -495220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     642.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-93770.0
}
