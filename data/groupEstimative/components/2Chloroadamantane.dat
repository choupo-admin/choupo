/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloroadamantane  (C10H15Cl, CAS 7346-41-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloroadamantane;
formula     C10H15Cl;
CAS         7346-41-0;
InChIKey    DPCLLPAHJSYBTE-UHFFFAOYSA-N;
MW          170.68;      // g/mol [origin=calculated method=formula-sum]
Tc          700.64;      // K   [origin=predictive method=joback]
Pc          28.719;      // bar [origin=predictive method=joback]
omega       0.3592;      // -   [origin=predictive method=lee-kesler]
Tb          480.98;      // K   [origin=predictive method=joback]
HvapTb      41532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-137.28 1.3507 -0.001044 3.284e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 4; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 5; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyladamantane" "adamantane, 2-chloro" "ambap7346-41-0" "2-chlorotricyclo(3.3.1.13,7)decane" "adamantane,2-chloro- (6ci,7ci,8ci);2-adamantyl chloride;2-chloradamantane;tricyclo[3.3.1.13,7]decane,2-chloro-;" );
gibbsFormation
{
    dHf_298   -93910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     243.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176120.0
    phase     gas;
}
