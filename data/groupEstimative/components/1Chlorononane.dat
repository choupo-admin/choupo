/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chlorononane  (C9H19Cl, CAS 2473-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chlorononane;
formula     C9H19Cl;
CAS         2473-01-0;
InChIKey    RKAMCQVGHFRILV-UHFFFAOYSA-N;
MW          162.701;      // g/mol [origin=calculated method=formula-sum]
Tc          612.87;      // K   [origin=predictive method=joback]
Pc          22.271;      // bar [origin=predictive method=joback]
omega       0.5079;      // -   [origin=predictive method=lee-kesler]
Tb          442.95;      // K   [origin=predictive method=joback]
HvapTb      40013.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.598 0.86562 -0.0004862 1.049e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylnonane" "nonyl chloride" "nonane, 1-chloro-" "1-propene, tetramer, chlorinated" "nonane,1-chloro-" "tetrapropenyl chloride" "1-chlorononane;nonyl chloride; n-nonyl chloride" );
gibbsFormation
{
    dHf_298   -244830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12970.0
    phase     gas;
}
