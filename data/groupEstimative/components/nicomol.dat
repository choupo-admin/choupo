/*--------------------------------*- Choupo -*-----------------------*\
  Component: nicomol  (C34H32N4O9, CAS 27959-26-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nicomol;
formula     C34H32N4O9;
CAS         27959-26-8;
InChIKey    VRAHPESAMYMDQI-UHFFFAOYSA-N;
MW          640.649;      // g/mol [origin=calculated method=formula-sum]
Tc          2045.47;      // K   [origin=predictive method=joback]
Pc          12.637;      // bar [origin=predictive method=joback]
omega       0.9291;      // -   [origin=predictive method=lee-kesler]
Tb          1634.79;      // K   [origin=predictive method=joback]
HvapTb      169038.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-170.176 3.52094 -0.00267504 8.332e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group C; count 2; } { group OH; count 1; } { group C5H4N; count 4; } { group COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 16; } { group dC_ring; count 4; } { group OH; count 1; } { group COO; count 4; } { group Nd_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-oxidanyl-1,3,3-tris(pyridin-3-ylcarbonyloxymethyl)cyclohexyl]methyl pyridine-3-carboxylate" "cholexamine" "cholexamin" "k 31 (pharmaceutical)" "k 31" "nicomolum [inn-latin]" "nicomolol" "2,2,6,6-tetrakis(nicotinoyloxymethyl)cyclohexanol" "tetranicotinic acid 2-hydroxycyclohexa-1,1,3,3-tetramethyl ester" "2-hydroxycyclohexane-1,1,3,3-tetramethanol tetraester with nicotinic acid" "3-pyridinecarboxylic acid, (2-hydroxy-1,3-cyclohexanediylidene)tetrakis(methylene) ester" "nicotinic acid, 1,1,3,3-tetraester with 2-hydroxy-1,1,3,3-cyclohexanetetramethanol" );
gibbsFormation
{
    dHf_298   -1045040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1385.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-387010.0
    phase     gas;
}
