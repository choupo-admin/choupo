/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropane,tris(1-methylethylidene)-  (C12H18, CAS 2799-44-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropaneTris1Methylethylidene;
formula     C12H18;
CAS         2799-44-2;
InChIKey    LCGAWMBXFZIHQA-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          707.00;      // K   [origin=predictive method=joback]
Pc          22.568;      // bar [origin=predictive method=joback]
omega       0.4502;      // -   [origin=predictive method=lee-kesler]
Tb          505.13;      // K   [origin=predictive method=joback]
HvapTb      45129.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.98 1.08852 -0.000817 2.672e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C=C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dC; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-tri(propan-2-ylidene)cyclopropane" "cyclopropane, tris(1-methylethylidene)-" );
gibbsFormation
{
    dHf_298   850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=229350.0
    phase     gas;
}
