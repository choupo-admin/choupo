/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2',4',6'-triisopropylacetophenone  (C17H26O, CAS 2234-14-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Triisopropylacetophenone;
formula     C17H26O;
CAS         2234-14-2;
InChIKey    SGRDDUKVLKWIBZ-UHFFFAOYSA-N;
MW          246.394;      // g/mol [origin=calculated method=formula-sum]
Tc          890.04;      // K   [origin=predictive method=joback]
Pc          16.299;      // bar [origin=predictive method=joback]
omega       0.7370;      // -   [origin=predictive method=lee-kesler]
Tb          682.73;      // K   [origin=predictive method=joback]
HvapTb      63280.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.26 1.35124 -0.00072198 1.3136e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group ACH; count 2; } { group AC; count 1; } { group ACCH; count 3; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,4,6-tri(propan-2-yl)phenyl]ethanone" "2,4,6-tri-isopropylacetophenone" "1-acetyl-2,4,6-tris(methylethyl)benzene" "2',6'-triisopropylacetophenone" "acetophenone,4',6'-triisopropyl-" "1-(2,4,6-triisopropylphenyl)ethanone" "ethanone,4,6-tris(1-methylethyl)phenyl]-" "1-(2,4,6-tris(1-methylethyl)phenyl)ethan-1-one" );
gibbsFormation
{
    dHf_298   -320510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     691.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39540.0
    phase     gas;
}
