/*--------------------------------*- Choupo -*-----------------------*\
  Component: dehydroepiandrosterone acetate  (C21H30O3, CAS 853-23-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dehydroepiandrosteroneAcetate;
formula     C21H30O3;
CAS         853-23-6;
InChIKey    NCMZQTLCXHGLOK-ZKHIMWLXSA-N;
MW          330.468;      // g/mol [origin=calculated method=formula-sum]
Tc          1096.13;      // K   [origin=predictive method=joback]
Pc          15.949;      // bar [origin=predictive method=joback]
omega       0.8108;      // -   [origin=predictive method=lee-kesler]
Tb          849.71;      // K   [origin=predictive method=joback]
HvapTb      72540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-246.96 2.74666 -0.00230344 8.352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,8r,9s,10r,13s,14s)-10,13-dimethyl-17-oxidanylidene-1,2,3,4,7,8,9,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-3-yl] ethanoate" "dehydroisoandrosterone acetate" "androstenolone acetate" "dehydroisoandrosterone 3-acetate" "trans-dehydroandrosterone acetate" "prasterone acetate" "dehydroisoandosterone 3-acetate" "dehydroepiandrosterone 3-acetate" "3-beta-acetoxydehydroepiandrosterone" "3beta-acetoxy-5-androstene-17-one" "5-androsten-3beta-ol-7-one acetate" "17-oxoandrost-5-en-3beta-yl acetate" );
gibbsFormation
{
    dHf_298   -635240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     695.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130590.0
    phase     gas;
}
