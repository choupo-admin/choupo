/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(dimethylamino)cyclohexanone  (C8H15NO, CAS 6970-60-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DimethylaminoCyclohexanone;
formula     C8H15NO;
CAS         6970-60-1;
InChIKey    JOZKRRZOWRUDEK-UHFFFAOYSA-N;
MW          141.214;      // g/mol [origin=calculated method=formula-sum]
Tc          699.71;      // K   [origin=predictive method=joback]
Pc          32.728;      // bar [origin=predictive method=joback]
omega       0.4326;      // -   [origin=predictive method=lee-kesler]
Tb          482.45;      // K   [origin=predictive method=joback]
HvapTb      40121.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.25 0.84154 -0.000361 1.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2CO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)cyclohexan-1-one" "cyclohexanone, 2-(dimethylamino)-" "2-(n,n-dimethylamino)cyclohexanone" );
gibbsFormation
{
    dHf_298   -224300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29120.0
    phase     gas;
}
