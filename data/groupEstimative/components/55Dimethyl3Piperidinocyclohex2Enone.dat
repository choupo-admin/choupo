/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-3-piperidinocyclohex-2-enone  (C13H21NO, CAS 13358-76-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl3Piperidinocyclohex2Enone;
formula     C13H21NO;
CAS         13358-76-4;
InChIKey    ZPOZHYJJQWTDJR-UHFFFAOYSA-N;
MW          207.317;      // g/mol [origin=calculated method=formula-sum]
Tc          863.62;      // K   [origin=predictive method=joback]
Pc          26.325;      // bar [origin=predictive method=joback]
omega       0.5618;      // -   [origin=predictive method=lee-kesler]
Tb          621.18;      // K   [origin=predictive method=joback]
HvapTb      51620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.13 1.65114 -0.00126864 4.225e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 7; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethyl-3-piperidin-1-yl-cyclohex-2-en-1-one" "5,5-dimethyl-3-(piperidin-1-yl)cyclohex-2-en-1-one" "5,5-dimethyl-3-piperidylcyclohex-2-en-1-one" "5,5-dimethyl-3-piperidin-1-yl-cyclohex-2-enone" "5,5-dimethyl-3-piperidin-1-ylcyclohex-2-en-1-one" );
gibbsFormation
{
    dHf_298   -185130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130320.0
    phase     gas;
}
