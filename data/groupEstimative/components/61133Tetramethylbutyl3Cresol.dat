/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-(1,1,3,3-tetramethylbutyl)-3-cresol  (C15H24O, CAS 3287-10-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        61133Tetramethylbutyl3Cresol;
formula     C15H24O;
CAS         3287-10-3;
InChIKey    JIFAIMFIZHUBEK-UHFFFAOYSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          874.53;      // K   [origin=predictive method=joback]
Pc          21.533;      // bar [origin=predictive method=joback]
omega       0.6535;      // -   [origin=predictive method=lee-kesler]
Tb          648.62;      // K   [origin=predictive method=joback]
HvapTb      62344.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.219 1.69672 -0.00135632 4.448e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-2-(2,4,4-trimethylpentan-2-yl)phenol" "6-(1,1,3,3-tetramethylbutyl)-m-cresol" "phenol, 5-methyl-2-(1,1,3,3-tetramethylbutyl)-" );
gibbsFormation
{
    dHf_298   -322680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29260.0
    phase     gas;
}
