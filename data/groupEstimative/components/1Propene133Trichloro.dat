/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propene, 1,3,3-trichloro-  (C3H3Cl3, CAS 26556-03-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propene133Trichloro;
formula     C3H3Cl3;
CAS         26556-03-6;
InChIKey    KHMZDLNSWZGRDB-UHFFFAOYSA-N;
MW          145.407;      // g/mol [origin=calculated method=formula-sum]
Tc          591.44;      // K   [origin=predictive method=joback]
Pc          41.250;      // bar [origin=predictive method=joback]
omega       0.2682;      // -   [origin=predictive method=lee-kesler]
Tb          384.25;      // K   [origin=predictive method=joback]
HvapTb      34997.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.97 0.3351 -0.0002876 9.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CHCl2; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH; count 2; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,3-tris(chloranyl)prop-1-ene" "1-propene, 1,3,3-trichloro-, (z)-" );
gibbsFormation
{
    dHf_298   -40530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=16370.0
    phase     gas;
}
