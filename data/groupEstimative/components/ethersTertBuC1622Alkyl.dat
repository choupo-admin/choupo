/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethers, tert-bu c16-22-alkyl  (C19H40O, CAS 104133-72-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethersTertBuC1622Alkyl;
formula     C19H40O;
CAS         104133-72-4;
InChIKey    FWMZORPEMVYZPK-UHFFFAOYSA-N;
MW          284.528;      // g/mol [origin=calculated method=formula-sum]
Tc          819.18;      // K   [origin=predictive method=joback]
Pc          10.821;      // bar [origin=predictive method=joback]
omega       0.7866;      // -   [origin=predictive method=lee-kesler]
Tb          653.51;      // K   [origin=predictive method=joback]
HvapTb      59002.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.356 1.87148 -0.0010706 2.32e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 13; } { group C; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 14; } { group C; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(2-methylpropan-2-yl)oxy]pentadecane" );
standardThermochemistry
{
    dHf_298   -576460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     868.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6940.0
}
