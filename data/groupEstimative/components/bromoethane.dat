/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromoethane  (C2H5Br, CAS 74-96-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromoethane;
formula     C2H5Br;
CAS         74-96-4;
InChIKey    RDHPKYGYEGBMSE-UHFFFAOYSA-N;
MW          108.966;      // g/mol [origin=calculated method=formula-sum]
Tc          497.21;      // K   [origin=predictive method=joback]
Pc          55.609;      // bar [origin=predictive method=joback]
omega       0.2353;      // -   [origin=predictive method=lee-kesler]
Tb          311.52;      // K   [origin=predictive method=joback]
HvapTb      26481.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.261 0.23202 -0.0001564 4.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromanylethane" "ethyl bromide" "ethane, bromo-" "1-bromoethane" "monobromoethane" "bromic ether" "bromure d'ethyle" "hydrobromic ether" "ethylbromide" "bromo-ethane" "etylu bromek" "bromoethane (ethyl bromide)" );
standardThermochemistry
{
    dHf_298   -58280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     284.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19720.0
}
