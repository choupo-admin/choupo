/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-((trimethoxysilyl)methyl)butane-1,4-diamine  (C8H22N2O3Si, CAS 6037-49-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H22N2O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2TrimethoxysilylMethylButane14Diamine;
formula     C8H22N2O3Si;
CAS         6037-49-6;
InChIKey    HEXHLHNCJVXPNU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          222.36;      // g/mol [origin=calculated method=formula-sum]
Tc          789.61;      // K   [origin=predictive method=joback]
Pc          24.147;      // bar [origin=predictive method=joback]
omega       0.8506;      // -   [origin=predictive method=lee-kesler]
Tb          595.92;      // K   [origin=predictive method=joback]
HvapTb      61820.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (124.234 0.49776 0.0002464 -2.761e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH3O; count 3; } { group CH2NH2; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group O; count 3; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(trimethoxysilylmethyl)butane-1,4-diamine" "1,4-butanediamine, 2-[(trimethoxysilyl)methyl]-" "1,4-butanediamine, 2-((trimethoxysilyl)methyl)-" "2-[(trimethoxysilyl)methyl]butane-1,4-diamine" "agn-pc-03qzwc" ".beta.-(aminoethyl)-.gamma.-aminopropyltrimethoxysilane" "2-aminoethyl-3-aminopropyltrimethoxysilane" "1,4-butanediamine,2-[(trimethoxysilyl)methyl]-" );
standardThermochemistry
{
    dHf_298   -654430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-272820.0
}
