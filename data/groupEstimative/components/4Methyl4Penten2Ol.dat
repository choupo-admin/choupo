/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-4-penten-2-ol  (C6H12O, CAS 2004-67-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl4Penten2Ol;
formula     C6H12O;
CAS         2004-67-3;
InChIKey    KPHPTSMXBAVNPX-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          596.17;      // K   [origin=predictive method=joback]
Pc          36.865;      // bar [origin=predictive method=joback]
omega       0.6707;      // -   [origin=predictive method=lee-kesler]
Tb          425.18;      // K   [origin=predictive method=joback]
HvapTb      44651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.639 0.59364 -0.0003614 8.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylpent-4-en-2-ol" "4-penten-2-ol, 4-methyl-" "4-penten-2-ol, 4-methyl-, (s)-" "4-penten-2-ol,4-methyl-" "1,3-dimethyl-3-buten-1-ol;2-methyl-1-penten-4-ol; 4-methyl-4-penten-2-ol" );
gibbsFormation
{
    dHf_298   -209040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60330.0
    phase     gas;
}
