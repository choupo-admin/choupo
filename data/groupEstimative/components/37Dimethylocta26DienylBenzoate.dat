/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethylocta-2,6-dienyl benzoate  (C17H22O2, CAS 94-48-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethylocta26DienylBenzoate;
formula     C17H22O2;
CAS         94-48-4;
InChIKey    YDVXYTIIPGKIJP-UHFFFAOYSA-N;
MW          258.361;      // g/mol [origin=calculated method=formula-sum]
Tc          892.66;      // K   [origin=predictive method=joback]
Pc          17.361;      // bar [origin=predictive method=joback]
omega       0.7401;      // -   [origin=predictive method=lee-kesler]
Tb          681.54;      // K   [origin=predictive method=joback]
HvapTb      63195.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.807 1.52496 -0.0010098 2.579e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH=C; count 2; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH; count 2; } { group dC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-octadien-1-ol, 3,7-dimethyl-, 1-benzoate, (2e)-" "[(2z)-3,7-dimethylocta-2,6-dienyl] benzoate" );
gibbsFormation
{
    dHf_298   -260100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     741.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37640.0
    phase     gas;
}
