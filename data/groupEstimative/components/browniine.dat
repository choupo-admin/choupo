/*--------------------------------*- Choupo -*-----------------------*\
  Component: browniine  (C25H41NO7, CAS 5140-42-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        browniine;
formula     C25H41NO7;
CAS         5140-42-1;
InChIKey    MODXUQZMEBLSJD-UHFFFAOYSA-N;
MW          467.603;      // g/mol [origin=calculated method=formula-sum]
Tc          1439.77;      // K   [origin=predictive method=joback]
Pc          13.892;      // bar [origin=predictive method=joback]
omega       1.0855;      // -   [origin=predictive method=lee-kesler]
Tb          1158.97;      // K   [origin=predictive method=joback]
HvapTb      125675.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-372.498 4.2395 -0.0041598 1.7243e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 9; } { group C; count 4; } { group OH; count 3; } { group CH3O; count 4; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 9; } { group C_ring; count 4; } { group OH; count 3; } { group O; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "20-ethyl-1,6,16-trimethoxy-4-(methoxymethyl)aconitane-7,8,14-triol" "aconitane-7,8,14-triol, 20-ethyl-4-(methoxymethyl)-1,6,16-trimethoxy-, (1-alpha,6-beta,14-alpha,16-beta)-" "browniine (7ci)" );
standardThermochemistry
{
    dHf_298   -1121990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     783.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-271490.0
}
