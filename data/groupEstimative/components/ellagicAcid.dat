/*--------------------------------*- Choupo -*-----------------------*\
  Component: ellagic acid  (C14H6O8, CAS 476-66-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ellagicAcid;
formula     C14H6O8;
CAS         476-66-4;
InChIKey    AFSDNFLWKVMVRB-UHFFFAOYSA-N;
MW          302.194;      // g/mol [origin=calculated method=formula-sum]
Tc          1287.18;      // K   [origin=predictive method=joback]
Pc          72.063;      // bar [origin=predictive method=joback]
omega       2.3390;      // -   [origin=predictive method=lee-kesler]
Tb          1029.32;      // K   [origin=predictive method=joback]
HvapTb      120240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.95 1.8592 -0.00219788 9.594e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 6; } { group ACOH; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 10; } { group OH_phenol; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoaric acid" "lagistase" "eleagic acid" "alizarine yellow" "elagostasine" "ellagic acid dihydrate" "llagic acid" "acide ellagique" "acido elagico" "acidum ellagicum" "gallogen (van)" "2,3,7,8-tetrahydroxychromeno[5,4,3-cde]chromene-5,10-dione" );
gibbsFormation
{
    dHf_298   -1025670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-776400.0
    phase     gas;
}
