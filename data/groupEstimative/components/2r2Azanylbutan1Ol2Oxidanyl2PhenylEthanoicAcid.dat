/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2r)-2-azanylbutan-1-ol;2-oxidanyl-2-phenyl-ethanoic acid  (C12H19NO4, CAS 71550-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2r2Azanylbutan1Ol2Oxidanyl2PhenylEthanoicAcid;
formula     C12H19NO4;
CAS         71550-49-7;
InChIKey    UPWLDSYIAGBPIF-FZSMXKCYSA-N;
MW          241.287;      // g/mol [origin=calculated method=formula-sum]
Tc          1117.76;      // K   [origin=predictive method=joback]
Pc          31.526;      // bar [origin=predictive method=joback]
omega       1.8411;      // -   [origin=predictive method=lee-kesler]
Tb          903.76;      // K   [origin=predictive method=joback]
HvapTb      105263.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.202 1.05122 -0.0004286 -2.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 2; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzeneacetic acid, alpha-hydroxy-, (alphas)-, compd. with (2r)-2-amino-1-butanol (1:1)" "benzeneacetic acid, alpha-hydroxy-, (s)-(+)-, salt with (r)-2-amino-1-butanol" );
gibbsFormation
{
    dHf_298   -797600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     812.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-498170.0
    phase     gas;
}
