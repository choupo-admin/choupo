/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hexene, 5-bromo-5-methyl-  (C7H13Br, CAS 90601-72-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hexene5Bromo5Methyl;
formula     C7H13Br;
CAS         90601-72-2;
InChIKey    URGZHESHYWFVJL-UHFFFAOYSA-N;
MW          177.085;      // g/mol [origin=calculated method=formula-sum]
Tc          618.36;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       0.3516;      // -   [origin=predictive method=lee-kesler]
Tb          419.37;      // K   [origin=predictive method=joback]
HvapTb      35645.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.748 0.81284 -0.0006231 1.955e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bromanyl-5-methyl-hex-1-ene" );
standardThermochemistry
{
    dHf_298   -44800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113060.0
}
