name        ac1l3htk;
formula     C10H15;
CAS         21517-94-2;
InChIKey    YXXKMTIGKAVJTA-UHFFFAOYSA-N;
role        radical;
MW          135.23;      // g/mol [origin=calculated method=formula-sum]
Tc          662.62;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       0.3288;      // -   [origin=predictive method=lee-kesler]
Tb          447.80;      // K   [origin=predictive method=joback]
HvapTb      37602.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-152.22 1.3424 -0.00107264 3.497e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 4; } { group dCH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -28940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     233.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=210740.0
}
