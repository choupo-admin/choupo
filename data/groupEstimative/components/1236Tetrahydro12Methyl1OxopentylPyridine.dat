/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,6-tetrahydro-1-(2-methyl-1-oxopentyl)pyridine  (C11H19NO, CAS 77251-49-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1236Tetrahydro12Methyl1OxopentylPyridine;
formula     C11H19NO;
CAS         77251-49-1;
InChIKey    BIBAJQQJVJRDND-UHFFFAOYSA-N;
MW          181.279;      // g/mol [origin=calculated method=formula-sum]
Tc          737.10;      // K   [origin=predictive method=joback]
Pc          26.137;      // bar [origin=predictive method=joback]
omega       0.6286;      // -   [origin=predictive method=lee-kesler]
Tb          536.26;      // K   [origin=predictive method=joback]
HvapTb      49339.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.768 1.25284 -0.00084178 2.1946e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH=CH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3,6-dihydro-2h-pyridin-1-yl)-2-methyl-pentan-1-one" "pyridine, 1,2,3,6-tetrahydro-1-(2-methyl-1-oxopentyl)-" "1-(3,6-dihydro-2h-pyridin-1-yl)-2-methylpentan-1-one" "pyridine, 1,2,3,6-tetrahydro-1-(2-methyl-1-oxopentyl)- (9ci)" );
gibbsFormation
{
    dHf_298   -182100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95380.0
    phase     gas;
}
