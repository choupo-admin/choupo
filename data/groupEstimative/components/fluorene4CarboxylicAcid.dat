/*--------------------------------*- Choupo -*-----------------------*\
  Component: fluorene-4-carboxylic acid  (C14H10O2, CAS 6954-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fluorene4CarboxylicAcid;
formula     C14H10O2;
CAS         6954-55-8;
InChIKey    WJNBLUOXTBTGMB-UHFFFAOYSA-N;
MW          210.232;      // g/mol [origin=calculated method=formula-sum]
Tc          986.28;      // K   [origin=predictive method=joback]
Pc          32.916;      // bar [origin=predictive method=joback]
omega       0.9458;      // -   [origin=predictive method=lee-kesler]
Tb          736.60;      // K   [origin=predictive method=joback]
HvapTb      70338.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.09 1.2449 -0.00104008 3.47e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 4; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9h-fluorene-4-carboxylic acid" "4-fluorenecarboxylic acid" "9h-fluorene-4-carboxylicacid" );
gibbsFormation
{
    dHf_298   -138450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11680.0
    phase     gas;
}
