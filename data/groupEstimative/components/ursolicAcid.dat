/*--------------------------------*- Choupo -*-----------------------*\
  Component: ursolic acid  (C30H48O3, CAS 77-52-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ursolicAcid;
formula     C30H48O3;
CAS         77-52-1;
InChIKey    WCGUUGGRBIKTOS-GPOJBZKASA-N;
MW          456.711;      // g/mol [origin=calculated method=formula-sum]
Tc          1426.79;      // K   [origin=predictive method=joback]
Pc          10.792;      // bar [origin=predictive method=joback]
omega       1.0294;      // -   [origin=predictive method=lee-kesler]
Tb          1164.60;      // K   [origin=predictive method=joback]
HvapTb      110331.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-493.79 4.81104 -0.00473824 1.9709e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 9; } { group CH; count 6; } { group C; count 5; } { group CH=C; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2_ring; count 9; } { group CH_ring; count 6; } { group C_ring; count 5; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,2r,4as,6ar,6as,6br,8ar,10s,12ar,14bs)-1,2,6a,6b,9,9,12a-heptamethyl-10-oxidanyl-2,3,4,5,6,6a,7,8,8a,10,11,12,13,14b-tetradecahydro-1h-picene-4a-carboxylic acid" "malol" "prunol" "urson" "3beta-hydroxyurs-12-en-28-oic acid" "(3beta)-3-hydroxyurs-12-en-28-oic acid" ".beta.-ursolic acid" "3beta-hydroxy-12-ursen-28-ic acid" "merotaine" "hnmr" "urs-12-en-28-oic acid, 3-hydroxy-, (3beta)-" "bungeolic acid" );
standardThermochemistry
{
    dHf_298   -843680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1166.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113340.0
}
