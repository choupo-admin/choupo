/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethyl-o-toluidine  (C11H17N, CAS 606-46-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethylOToluidine;
formula     C11H17N;
CAS         606-46-2;
InChIKey    YQYUUNRAPYPAPC-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          695.99;      // K   [origin=predictive method=joback]
Pc          26.031;      // bar [origin=predictive method=joback]
omega       0.4965;      // -   [origin=predictive method=lee-kesler]
Tb          495.38;      // K   [origin=predictive method=joback]
HvapTb      45061.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.408 1.03436 -0.00065136 1.577e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-2-methyl-aniline" "n,n-diethyl-2-methylaniline" "o-toluidine, n,n-diethyl-" "benzenamine, n,n-diethyl-2-methyl-" "2-(dimethylamino)toluene" "n,n-diethyl-o-toluidinium ion" "2-diethylaminotoluene" "o-toluidine,n-diethyl-" "benzenamine,n-diethyl-2-methyl-" "u383" );
standardThermochemistry
{
    dHf_298   22220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=255300.0
}
