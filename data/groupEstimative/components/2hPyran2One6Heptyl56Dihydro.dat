/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-pyran-2-one, 6-heptyl-5,6-dihydro-  (C12H20O2, CAS 16400-72-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hPyran2One6Heptyl56Dihydro;
formula     C12H20O2;
CAS         16400-72-9;
InChIKey    XPTXKXKPWKNYKB-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          728.43;      // K   [origin=predictive method=joback]
Pc          21.158;      // bar [origin=predictive method=joback]
omega       0.6732;      // -   [origin=predictive method=lee-kesler]
Tb          542.55;      // K   [origin=predictive method=joback]
HvapTb      50090.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.194 1.17432 -0.00069548 1.481e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-heptyl-2,3-dihydropyran-6-one" "5-hydroxy-2-dodecenoic acid lactone" "delta-2-dodecenolactone" "2h-pyran-2-one, 6-heptyl-5,6-dihydro-, (6r)-" "5-heptyl-2-pentene-5-olide" "6-heptyl-5,6-dihydro-2-pyrone" "6-heptyl-5,6-dihydropyran-2-one" "6-heptyl-5,6-dihydro-2h-pyran-2-one" "5-hydroxy-2-dodecenoic acid delta-lactone" );
standardThermochemistry
{
    dHf_298   -483870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-181600.0
}
