/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethoxyethyl dodecanoate  (C16H32O3, CAS 106-13-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthoxyethylDodecanoate;
formula     C16H32O3;
CAS         106-13-8;
InChIKey    ZZEVAQRDBLJTKL-UHFFFAOYSA-N;
MW          272.429;      // g/mol [origin=calculated method=formula-sum]
Tc          811.80;      // K   [origin=predictive method=joback]
Pc          13.071;      // bar [origin=predictive method=joback]
omega       0.9163;      // -   [origin=predictive method=lee-kesler]
Tb          646.32;      // K   [origin=predictive method=joback]
HvapTb      61027.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.253 1.40584 -0.000641 6.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH2COO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecanoic acid, 2-ethoxyethyl ester" "lauric acid, 2-ethoxyethyl ester" "2-ethoxyethyl laurate" "dodecanoic acid,2-ethoxyethyl ester" "lauric acid, 2-ethoxyethyl ester (8ci)" "dodecanoic acid 2-ethoxyethyl ester" );
standardThermochemistry
{
    dHf_298   -823070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     841.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-331530.0
}
