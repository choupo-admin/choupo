/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid;1-[4-[2-[4-(2-oxidanylpropoxy)phenyl]propan-2-yl]phenoxy]propan-2-ol;propane-1,2-diol  (C30H46O10, CAS 72017-98-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcid14242OxidanylpropoxyPhenylPropan2YlPhenoxyPro;
formula     C30H46O10;
CAS         72017-98-2;
InChIKey    RDDLRILMPQTEAS-UHFFFAOYSA-N;
MW          566.688;      // g/mol [origin=calculated method=formula-sum]
Tc          2477.42;      // K   [origin=predictive method=joback]
Pc          10.494;      // bar [origin=predictive method=joback]
omega       -0.1225;      // -   [origin=predictive method=lee-kesler]
Tb          1652.15;      // K   [origin=predictive method=joback]
HvapTb      192242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.887 2.4194 -0.00093312 -3.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group OH; count 2; } { group COOH; count 2; } { group C2H4O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 7; } { group CH; count 3; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 4; } { group O; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanedioic acid, polymer with 1,1'-((1-methylethylidene)bis(4,1-phenyleneoxy))bis(2-propanol) and 1,2-propanediol" );
standardThermochemistry
{
    dHf_298   -2034140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1579.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1251820.0
}
