/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyl methacrylate  (C7H12O2, CAS 4655-34-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylMethacrylate;
formula     C7H12O2;
CAS         4655-34-9;
InChIKey    BOQSSGDQNWEFSX-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          598.06;      // K   [origin=predictive method=joback]
Pc          29.861;      // bar [origin=predictive method=joback]
omega       0.4151;      // -   [origin=predictive method=lee-kesler]
Tb          414.10;      // K   [origin=predictive method=joback]
HvapTb      37605.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.57 0.59986 -0.0002908 3.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl 2-methylprop-2-enoate" "methacrylic acid, isopropyl ester" "2-propenoic acid, 2-methyl-, 1-methylethyl ester" "isopropyl 2-methyl-2-propenoate" "1-methylethyl 2-methyl-2-propenoate" "acrylic acid, 2-methyl-, isopropyl ester" "isopropyl 2-methylacrylate" "methacrylic acid isopropyl ester" "2-propenoic acid,2-methyl-, 1-methylethyl ester" );
standardThermochemistry
{
    dHf_298   -394730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-225460.0
}
