/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-thiophenemethanol  (C5H6OS, CAS 636-72-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Thiophenemethanol;
formula     C5H6OS;
CAS         636-72-6;
InChIKey    ZPHGMBGIFODUMF-UHFFFAOYSA-N;
MW          114.162;      // g/mol [origin=calculated method=formula-sum]
Tc          686.49;      // K   [origin=predictive method=joback]
Pc          55.526;      // bar [origin=predictive method=joback]
omega       0.6969;      // -   [origin=predictive method=lee-kesler]
Tb          477.26;      // K   [origin=predictive method=joback]
HvapTb      51027.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.109 0.51391 -0.00038762 1.181e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group OH; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thiophen-2-ylmethanol" "2-hydroxymethylthiophene" "thenyl alcohol" "2-thenyl alcohol" "2-(hydroxymethyl)thiophene" "thiophene-2-methanol" "2-thienylmethanol" "2-thienyl carbinol" "(thien-2-yl)methanol" "2-thienylmethan-1-ol" "2-thiophenecarbinol" "thiophen-2-yl-methanol" );
gibbsFormation
{
    dHf_298   -68590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11190.0
    phase     gas;
}
