/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl chloromalonate  (C5H7ClO4, CAS 28868-76-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylChloromalonate;
formula     C5H7ClO4;
CAS         28868-76-0;
InChIKey    LNBQBURECUEBKZ-UHFFFAOYSA-N;
MW          166.557;      // g/mol [origin=calculated method=formula-sum]
Tc          661.04;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.5810;      // -   [origin=predictive method=lee-kesler]
Tb          467.43;      // K   [origin=predictive method=joback]
HvapTb      45535.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.37 0.38194 -8.26e-05 -5.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CHCl; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group Cl; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-chloranylpropanedioate" "dimethyl 2-chloromalonate" "dimethyl chloropropanedioate" "dimethyl 2-chloropropanedioate" "1,3-dimethyl 2-chloropropanedioate" "dimethyl 2-chloropropane-1,3-dioate" "2-chloropropanedioic acid dimethyl ester" "propanedioic acid,2-chloro-, 1,3-dimethyl ester" "malonicacid, chloro-, dimethyl ester (8ci);propanedioic acid, chloro-, dimethyl ester(9ci);chloropropanedioic acid dimethyl ester;dimethyl a-chloromalonate;" );
gibbsFormation
{
    dHf_298   -802110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-643890.0
    phase     gas;
}
