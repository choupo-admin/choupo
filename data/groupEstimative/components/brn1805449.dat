/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1805449  (C20H38O6, CAS 25724-60-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1805449;
formula     C20H38O6;
CAS         25724-60-1;
InChIKey    XKBUCJYNRHGGOM-UHFFFAOYSA-N;
MW          374.518;      // g/mol [origin=calculated method=formula-sum]
Tc          1002.63;      // K   [origin=predictive method=joback]
Pc          10.104;      // bar [origin=predictive method=joback]
omega       0.9586;      // -   [origin=predictive method=lee-kesler]
Tb          817.60;      // K   [origin=predictive method=joback]
HvapTb      78972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (83.162 1.67968 -0.0006594 2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 2; } { group CH2COO; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[2-(2-ethylbutoxy)ethyl] butanedioate" "succinic acid, bis(2-(2-ethoxybutoxy)ethyl) ester" );
gibbsFormation
{
    dHf_298   -1365690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1041.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-718100.0
    phase     gas;
}
