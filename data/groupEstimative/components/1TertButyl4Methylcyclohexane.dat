/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tert-butyl-4-methylcyclohexane  (C11H22, CAS 75736-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButyl4Methylcyclohexane;
formula     C11H22;
CAS         75736-66-2;
InChIKey    YCLKWKCHQLIGTA-UHFFFAOYSA-N;
MW          154.297;      // g/mol [origin=calculated method=formula-sum]
Tc          670.15;      // K   [origin=predictive method=joback]
Pc          23.047;      // bar [origin=predictive method=joback]
omega       0.2971;      // -   [origin=predictive method=lee-kesler]
Tb          462.93;      // K   [origin=predictive method=joback]
HvapTb      38904.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.25 1.27028 -0.000772 1.73e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-4-methyl-cyclohexane" "cyclohexane, 1-(1,1-dimethylethyl)-4-methyl-" "cyclohexane, 1-(1,1-dimethylethyl)-4-methyl-, cis" "cyclohexane, 1-(1,1-dimethylethyl)-4-methyl-, trans" );
standardThermochemistry
{
    dHf_298   -245140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61320.0
}
