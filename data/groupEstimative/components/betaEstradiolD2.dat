/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-estradiol-d2  (C18H22D2O2, CAS 53866-33-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C18H22D2O2 (delta D+2H-2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        betaEstradiolD2;
formula     C18H22D2O2;
CAS         53866-33-4;
InChIKey    VOXZDWNPVJITMN-JXCLBMSPSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          274.4;      // g/mol [origin=calculated method=formula-sum]
Tc          1070.16;      // K   [origin=predictive method=joback]
Pc          25.767;      // bar [origin=predictive method=joback]
omega       1.2163;      // -   [origin=predictive method=lee-kesler]
Tb          835.56;      // K   [origin=predictive method=joback]
HvapTb      86607.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-235.79 2.43642 -0.00219592 8.262e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,13s,14s,17s)-2,4-dideuterio-13-methyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthrene-3,17-diol" "a-estradiol-d2" "1,3,5(10)-estratriene-2,4-d2-3,17beta-diol" );
gibbsFormation
{
    dHf_298   -338690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49160.0
    phase     gas;
}
