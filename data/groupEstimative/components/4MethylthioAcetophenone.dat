/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-(methylthio)acetophenone  (C9H10OS, CAS 1778-09-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethylthioAcetophenone;
formula     C9H10OS;
CAS         1778-09-2;
InChIKey    JECUZQLBQKNEMW-UHFFFAOYSA-N;
MW          166.238;      // g/mol [origin=calculated method=formula-sum]
Tc          800.72;      // K   [origin=predictive method=joback]
Pc          35.179;      // bar [origin=predictive method=joback]
omega       0.5341;      // -   [origin=predictive method=lee-kesler]
Tb          559.83;      // K   [origin=predictive method=joback]
HvapTb      52129.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.06 0.68683 -0.00037106 5.986e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methylsulfanylphenyl)ethanone" "4'-methylthioacetophenone" "4-(methylthio)acetophenone" "4-(acetyl)thioanisole" "1-[4-(methylsulfanyl)phenyl]ethanone" "1-(4-(methylthio)phenyl)ethan-1-one" "4'-(methylmercapto)acetophenone" "ethanone, 1-[4-(methylthio)phenyl]-" "1-[4-(methylthio)phenyl]ethanone" "1-[4-(methylthio)phenyl]ethan-1-one" "1-acetyl-4-methylthiobenzene" "ethanone, 1-(4-(methylthio)phenyl)-" );
standardThermochemistry
{
    dHf_298   -74740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31880.0
}
