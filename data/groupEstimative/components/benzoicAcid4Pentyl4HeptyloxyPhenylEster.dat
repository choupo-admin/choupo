/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 4-pentyl-, 4-(heptyloxy)phenyl ester  (C25H34O3, CAS 50802-53-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid4Pentyl4HeptyloxyPhenylEster;
formula     C25H34O3;
CAS         50802-53-4;
InChIKey    WZNRFIHLJAONQM-UHFFFAOYSA-N;
MW          382.544;      // g/mol [origin=calculated method=formula-sum]
Tc          1129.23;      // K   [origin=predictive method=joback]
Pc          11.126;      // bar [origin=predictive method=joback]
omega       0.9785;      // -   [origin=predictive method=lee-kesler]
Tb          915.56;      // K   [origin=predictive method=joback]
HvapTb      86937.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.14 1.98404 -0.00105892 1.756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-heptoxyphenyl) 4-pentylbenzoate" "4-n-heptyloxyphenol 4-n-pentylbenzoate" );
standardThermochemistry
{
    dHf_298   -558710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     967.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-50190.0
}
