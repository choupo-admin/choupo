/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl isobutylmalonate  (C11H20O4, CAS 10203-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylIsobutylmalonate;
formula     C11H20O4;
CAS         10203-58-4;
InChIKey    OFRFGNSZCYDFOH-UHFFFAOYSA-N;
MW          216.277;      // g/mol [origin=calculated method=formula-sum]
Tc          746.81;      // K   [origin=predictive method=joback]
Pc          19.788;      // bar [origin=predictive method=joback]
omega       0.7752;      // -   [origin=predictive method=lee-kesler]
Tb          566.84;      // K   [origin=predictive method=joback]
HvapTb      54118.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.343 0.95108 -0.0003918 4.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-(2-methylpropyl)propanedioate" "isobutylmalonic acid diethyl ester" "propanedioic acid, (2-methylpropyl)-, diethyl ester" "ethyl 2-carbethoxy-4-methyl pentanoate" "malonic acid, isobutyl-, diethyl ester" "propanedioic acid, 2-(2-methylpropyl)-, 1,3-diethyl ester" "diethyl 2-isobutylmalonate" "ofrfgnszcydfoh-uhfffaoysa-" "o269" "2-(2-methylpropyl)propanedioic acid diethyl ester" );
standardThermochemistry
{
    dHf_298   -915490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     667.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-583880.0
}
