/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-pyran-2-one  (C5H4O2, CAS 504-31-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hPyran2One;
formula     C5H4O2;
CAS         504-31-4;
InChIKey    ZPSJGADGUYYRKE-UHFFFAOYSA-N;
MW          96.085;      // g/mol [origin=calculated method=formula-sum]
Tc          589.18;      // K   [origin=predictive method=joback]
Pc          48.698;      // bar [origin=predictive method=joback]
omega       0.3577;      // -   [origin=predictive method=lee-kesler]
Tb          386.22;      // K   [origin=predictive method=joback]
HvapTb      35109.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.99 0.4798 -0.00035736 9.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyran-2-one" "2-pyranone" "2-pyrone" "alpha-pyrone" ".alpha.-pyrone" "pyrone" "coumalin" "a-pyrone" "2-oxo-2h-pyran" "2h-pyrane-2-one" "1,2-pyrone" "t338" );
gibbsFormation
{
    dHf_298   -261270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     299.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-202870.0
    phase     gas;
}
