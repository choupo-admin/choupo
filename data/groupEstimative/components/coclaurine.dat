/*--------------------------------*- Choupo -*-----------------------*\
  Component: coclaurine  (C17H19NO3, CAS 486-39-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coclaurine;
formula     C17H19NO3;
CAS         486-39-5;
InChIKey    LVVKXRQZSRUVPY-HNNXBMFYSA-N;
MW          285.343;      // g/mol [origin=calculated method=formula-sum]
Tc          1154.99;      // K   [origin=predictive method=joback]
Pc          32.393;      // bar [origin=predictive method=joback]
omega       1.2932;      // -   [origin=predictive method=lee-kesler]
Tb          895.10;      // K   [origin=predictive method=joback]
HvapTb      94593.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.559 1.71592 -0.00134424 4.402e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 1; } { group ACCH2; count 2; } { group ACCH; count 1; } { group ACOH; count 2; } { group CH3O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } { group O; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s)-1-[(4-hydroxyphenyl)methyl]-6-methoxy-1,2,3,4-tetrahydroisoquinolin-7-ol" "(s)-coclaurine" "(1s)-1-(4-hydroxybenzyl)-6-methoxy-1,2,3,4-tetrahydroisoquinolin-7-ol" "1,2,3,4-tetrahydro-1-(p-hydroxybenzyl)-6-methoxy-7-isoquinolinol" "1-(p-hydroxybenzyl)-6-methoxy-7-hydroxy-1,2,3,4-tetrahydroisoquinoline" "(s)-1,2,3,4-tetrahydro-1-[(4-hydroxyphenyl)methyl]-6-methoxy-7-isoquinolinol" "7-isoquinolinol,1,2,3,4-tetrahydro-1-[(4-hydroxyphenyl)methyl]-6-methoxy-, (1s)-" "7-isoquinolinol,1,2,3,4-tetrahydro-1-[(4-hydroxyphenyl)methyl]-6-methoxy-, (s)-; coclaurine(6ci,7ci,8ci); (-)-coclaurine;(s)-1,2,3,4-tetrahydro-1-(p-hydroxybenzyl)-6-methoxy-7-isoquinolinol;(s)-1-(p-hydroxybenzyl)-6-methoxy-7-hydroxy-1,2,3,4-tetrahydroisoquinoline;(s)-coclaurine; coclaurin; machiline" );
gibbsFormation
{
    dHf_298   -326480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=19940.0
    phase     gas;
}
