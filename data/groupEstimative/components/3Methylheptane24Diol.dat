/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylheptane-2,4-diol  (C8H18O2, CAS 6964-04-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylheptane24Diol;
formula     C8H18O2;
CAS         6964-04-1;
InChIKey    ZMWAURRHTDCQCX-UHFFFAOYSA-N;
MW          146.23;      // g/mol [origin=calculated method=formula-sum]
Tc          730.12;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       1.2740;      // -   [origin=predictive method=lee-kesler]
Tb          565.68;      // K   [origin=predictive method=joback]
HvapTb      65596.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.152 0.84956 -0.0004818 1.021e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -528750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-264480.0
    phase     gas;
}
