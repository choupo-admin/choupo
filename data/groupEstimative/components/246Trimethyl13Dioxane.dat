/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trimethyl-1,3-dioxane  (C7H14O2, CAS 19145-91-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trimethyl13Dioxane;
formula     C7H14O2;
CAS         19145-91-6;
InChIKey    OQGOSNRNRKMTEX-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          626.16;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.3397;      // -   [origin=predictive method=lee-kesler]
Tb          423.87;      // K   [origin=predictive method=joback]
HvapTb      40007.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.56 0.73196 -0.0002994 7.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH-O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "m-dioxane, 2,4,6-trimethyl-, cis-2,4,cis-2,6-" "1,3-dioxane, 2,4,6-trimethyl-, (2.alpha.,4.alpha.,6.alpha.)-" "agn-pc-03f25q" "1,3-dioxane, 2,4,6-trimethyl-, (2alpha,4alpha,6alpha)-" "1,3-dioxane, 2,4,6-trimethyl-" "1,3-dioxane,2,4,6-trimethyl-, (4r,6s)-rel-" "1,3-dioxane,2,4,6-trimethyl-, (2alpha,4alpha,6beta)-" "1,3-dioxane,2,4,6-trimethyl-,(2.alpha.,4.alpha.,6.beta.)-" "1,3-dioxane,2,4,6-trimethyl-, (2a,4a,6a)- (9ci); m-dioxane, 2,4,6-trimethyl-,cis-2,4,cis-2,6- (8ci); cis-2,4,6-trimethyl-1,3-dioxane;cis-2,4-trans-6-trimethyl-1,3-dioxane" );
standardThermochemistry
{
    dHf_298   -438170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     210.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-155150.0
}
