/*--------------------------------*- Choupo -*-----------------------*\
  Component: isojasmone  (C11H16O, CAS 11050-62-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isojasmone;
formula     C11H16O;
CAS         11050-62-7;
InChIKey    GVONPEQEUQYVNH-SNAWJCMRSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          768.84;      // K   [origin=predictive method=joback]
Pc          25.820;      // bar [origin=predictive method=joback]
omega       0.5453;      // -   [origin=predictive method=lee-kesler]
Tb          552.33;      // K   [origin=predictive method=joback]
HvapTb      46467.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.908 0.88374 -0.0004504 7.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH=CH; count 1; } { group CH2CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 2; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-3-[(e)-pent-2-enyl]cyclopent-2-en-1-one" "isojasmone (natural)" "2-cyclopenten-1-one, 2-methyl-3-(2-pentenyl)-" "2-methyl-3-pent-2-enylcyclopent-2-enone" "2-methyl-3-(2-pentenyl)-2-cyclopenten-1-one" "2-cyclopenten-1-one, 2-methyl-3-(2-penten-1-yl)-" );
standardThermochemistry
{
    dHf_298   -175190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54330.0
}
