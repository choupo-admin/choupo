/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butanol, 3-chloro-  (C4H9ClO, CAS 563-84-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butanol3Chloro;
formula     C4H9ClO;
CAS         563-84-8;
InChIKey    XKEHIUIIEXXHJX-UHFFFAOYSA-N;
MW          108.565;      // g/mol [origin=calculated method=formula-sum]
Tc          596.97;      // K   [origin=predictive method=joback]
Pc          42.663;      // bar [origin=predictive method=joback]
omega       0.6520;      // -   [origin=predictive method=lee-kesler]
Tb          419.85;      // K   [origin=predictive method=joback]
HvapTb      44786.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.07 0.43644 -0.000251 5.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group OH; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylbutan-2-ol" "3-chlorobutan-2-ol" "3-chloro-2-butanol" ".beta.-butylene chlorohydrin" "2-butanol, 3-chloro-, threo-" "2-butanol, 3-chloro-, erythro-" "2-butanol, 3-chloro-, (r*,r*)-" "2-butanol, 3-chloro-, (r*,s*)-" );
standardThermochemistry
{
    dHf_298   -304420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-170830.0
}
