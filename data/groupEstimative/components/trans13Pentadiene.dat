/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-1,3-Pentadiene  (C5H8, CAS 2004-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans13Pentadiene;
formula     C5H8;
CAS         2004-70-8;
InChIKey    PMJHHCWVYXUKFD-SNAWJCMRSA-N;
MW          68.119;      // g/mol [origin=calculated method=formula-sum]
Tc          490.60;      // K   [origin=predictive method=joback]
Pc          38.868;      // bar [origin=predictive method=joback]
omega       0.2064;      // -   [origin=predictive method=lee-kesler]
Tb          314.84;      // K   [origin=predictive method=joback]
HvapTb      26012.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.83 0.47882 -0.0003549 1.131e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3E)-penta-1,3-diene" "(3E)-1,3-Pentadiene" "(E)-1,3-Pentadiene" "(e)-piperylene" "1,3-Pentadiene, (3E)-" "1,3-Pentadiene, (E)-" "1,3-Pentadiene, (E)- (8CI)" "1,3-trans-pentadiene" "piperylene, trans-" "Piperylene, trans- (6CI)" "trans-1-methyl-1,3-butadiene" "trans-1-methylbutadiene" );
standardThermochemistry
{
    dHf_298   96120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     339.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=159280.0
}
