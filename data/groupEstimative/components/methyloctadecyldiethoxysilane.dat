/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyloctadecyldiethoxysilane  (C23H50O2Si, CAS 67859-75-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C23H50O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methyloctadecyldiethoxysilane;
formula     C23H50O2Si;
CAS         67859-75-0;
InChIKey    DJVQMRRXRRBRIH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          386.736;      // g/mol [origin=calculated method=formula-sum]
Tc          946.54;      // K   [origin=predictive method=joback]
Pc          7.803;      // bar [origin=predictive method=joback]
omega       0.7285;      // -   [origin=predictive method=lee-kesler]
Tb          772.08;      // K   [origin=predictive method=joback]
HvapTb      71906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.799 1.85628 -0.0005906 -6.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 17; } { group CH2O; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 19; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethoxy-methyl-octadecyl-silane" "diethoxymethyloctadecylsilane" "silane, diethoxymethyloctadecyl-" "diethoxy-methyl-octadecylsilane" );
standardThermochemistry
{
    dHf_298   -894110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1200.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-171980.0
}
