/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diphenyl-1-heptene  (C19H22, CAS 1530-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diphenyl1Heptene;
formula     C19H22;
CAS         1530-20-7;
InChIKey    SRMGQBFDRIIXAH-UHFFFAOYSA-N;
MW          250.385;      // g/mol [origin=calculated method=formula-sum]
Tc          921.74;      // K   [origin=predictive method=joback]
Pc          18.531;      // bar [origin=predictive method=joback]
omega       0.6502;      // -   [origin=predictive method=lee-kesler]
Tb          691.72;      // K   [origin=predictive method=joback]
HvapTb      62478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.066 1.67092 -0.0011583 3.151e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=C; count 1; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylhept-1-enylbenzene" "1-heptene, 1,1-diphenyl-" "benzene,1'-(1-heptenylidene)bis-" "benzene, 1,1'-(1-heptenylidene)bis-" );
standardThermochemistry
{
    dHf_298   145000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     672.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=405590.0
}
