/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(triethoxysilyl)butan-1-amine  (C10H25NO3Si, CAS 3069-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H25NO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4TriethoxysilylButan1Amine;
formula     C10H25NO3Si;
CAS         3069-30-5;
InChIKey    SWDDLRSGGCWDPH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          235.399;      // g/mol [origin=calculated method=formula-sum]
Tc          747.08;      // K   [origin=predictive method=joback]
Pc          19.036;      // bar [origin=predictive method=joback]
omega       0.7872;      // -   [origin=predictive method=lee-kesler]
Tb          569.59;      // K   [origin=predictive method=joback]
HvapTb      56019.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (117.607 0.61996 0.0001842 -2.628e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH2O; count 3; } { group CH2NH2; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group O; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-triethoxysilylbutan-1-amine" "4-(triethoxysilyl)butylamine" "(4-aminobutyl)triethoxysilane" "butylamine, 4-(triethoxysilyl)-" "silane, (4-aminobutyl)triethoxy-" "4-aminobutyltriethoxysilane" "1-butanamine,4-(triethoxysilyl)-" "butylamine,4-(triethoxysilyl)- (6ci,7ci,8ci); silane, (4-aminobutyl)triethoxy- (8ci);4-(triethoxysilyl)-1-aminobutane; 4-(triethoxysilyl)butylamine;4-aminobutyltriethoxysilane; d-aminobutyltriethoxysilane" );
gibbsFormation
{
    dHf_298   -724220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     757.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-319990.0
    phase     gas;
}
