/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(hexyloxy)tetrahydro-2h-pyran  (C11H22O2, CAS 1927-63-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HexyloxyTetrahydro2hPyran;
formula     C11H22O2;
CAS         1927-63-5;
InChIKey    LMUWFXQGRIPPJK-UHFFFAOYSA-N;
MW          186.295;      // g/mol [origin=calculated method=formula-sum]
Tc          712.87;      // K   [origin=predictive method=joback]
Pc          22.784;      // bar [origin=predictive method=joback]
omega       0.5772;      // -   [origin=predictive method=lee-kesler]
Tb          520.20;      // K   [origin=predictive method=joback]
HvapTb      47429.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.895 1.10472 -0.0005307 6.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexoxyoxane" "2h-pyran, 2-(hexyloxy)tetrahydro-" "tetrahydropyran-2-yl hexyl ether" );
standardThermochemistry
{
    dHf_298   -480270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124930.0
}
