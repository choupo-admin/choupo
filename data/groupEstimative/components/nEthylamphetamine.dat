/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-ethylamphetamine  (C11H17N, CAS 457-87-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nEthylamphetamine;
formula     C11H17N;
CAS         457-87-4;
InChIKey    YAGBSNMZQKEFCO-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          735.57;      // K   [origin=predictive method=joback]
Pc          27.070;      // bar [origin=predictive method=joback]
omega       0.5598;      // -   [origin=predictive method=lee-kesler]
Tb          527.69;      // K   [origin=predictive method=joback]
HvapTb      48404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.908 1.05204 -0.0006576 1.552e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-1-phenyl-propan-2-amine" "etilamfetamine" "apetinil" "ethylamphetamine" "etilamfetamine [inn]" "etilamfetaminum [latin]" "etilamfetaminum [inn-latin]" "1-phenyl-2-ethylaminopropane" "n-ethyl-alpha-methylphenethylamine" "alpha-phenyl-beta-ethylaminopropane" "etilamfetamine (inn)" "1-phenyl-2-aethylamino-propan [german]" );
gibbsFormation
{
    dHf_298   14350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=241100.0
    phase     gas;
}
