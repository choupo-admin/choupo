/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylpent-1-yn-3-one  (C11H10O, CAS 19307-74-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenylpent1Yn3One;
formula     C11H10O;
CAS         19307-74-5;
InChIKey    XAJIQJSLJKBJTP-UHFFFAOYSA-N;
MW          158.2;      // g/mol [origin=calculated method=formula-sum]
Tc          780.69;      // K   [origin=predictive method=joback]
Pc          33.802;      // bar [origin=predictive method=joback]
omega       0.4692;      // -   [origin=predictive method=lee-kesler]
Tb          540.83;      // K   [origin=predictive method=joback]
HvapTb      51254.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.099 0.79212 -0.00049496 1.1514e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pentyn-3-one, 1-phenyl-" "1-phenyl-1-pentyn-3-one" "1-phenylpenta-1-yn-3-one" "1-phenyl-pent-1-yn-3-one" );
standardThermochemistry
{
    dHf_298   125880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=228030.0
}
