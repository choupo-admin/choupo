/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-3-bromocyclohex-2-enone  (C8H11BrO, CAS 13271-49-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl3Bromocyclohex2Enone;
formula     C8H11BrO;
CAS         13271-49-3;
InChIKey    LPZGJNIBSGPOED-UHFFFAOYSA-N;
MW          203.079;      // g/mol [origin=calculated method=formula-sum]
Tc          791.52;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       0.4521;      // -   [origin=predictive method=lee-kesler]
Tb          540.55;      // K   [origin=predictive method=joback]
HvapTb      44316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.28 0.93224 -0.00077264 2.92e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group Br; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-5,5-dimethyl-cyclohex-2-en-1-one" "2-cyclohexenone,3-bromo,5,5-dimethyl-" "2-cyclohexenone, 3-bromo-5,5-dimethyl-" "3-bromo-5,5-dimethylcyclohex-2-en-1-one" "2-cyclohexen-1-one,3-bromo-5,5-dimethyl-" "3-bromo-5,5-dimethyl-2-cyclohexen-1-one;3-bromo-5,5-dimethyl-2-cyclohexenone; 5,5-dimethyl-3-bromocyclohex-2-enone" );
gibbsFormation
{
    dHf_298   -203950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-52500.0
    phase     gas;
}
