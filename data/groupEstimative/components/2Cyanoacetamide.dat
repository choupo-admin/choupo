/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyanoacetamide  (C3H4N2O, CAS 107-91-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyanoacetamide;
formula     C3H4N2O;
CAS         107-91-5;
InChIKey    DGJMPUGMZIKDRO-UHFFFAOYSA-N;
MW          84.078;      // g/mol [origin=calculated method=formula-sum]
Tc          716.65;      // K   [origin=predictive method=joback]
Pc          50.228;      // bar [origin=predictive method=joback]
omega       0.6371;      // -   [origin=predictive method=lee-kesler]
Tb          496.72;      // K   [origin=predictive method=joback]
HvapTb      50137.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.011 0.2575 -0.0001331 2.016e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2CN; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CdO; count 1; } { group NH2; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyanoethanamide" "cyanoacetamide" "cyanacetamide" "acetamide, 2-cyano-" "malonamide nitrile" "malonamonitrile" "nitrilomalonamide" "cyanoiminoacetic acid" "3-nitrilo-propionamide" "propionamide, 3-nitrilo-" "usaf kf-14" "propionamide nitrile" );
standardThermochemistry
{
    dHf_298   -19160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45090.0
}
