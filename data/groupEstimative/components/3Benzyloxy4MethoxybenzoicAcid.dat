/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-benzyloxy-4-methoxybenzoic acid  (C15H14O4, CAS 58452-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Benzyloxy4MethoxybenzoicAcid;
formula     C15H14O4;
CAS         58452-00-9;
InChIKey    YPDXIGBSOBESNI-UHFFFAOYSA-N;
MW          258.273;      // g/mol [origin=calculated method=formula-sum]
Tc          1033.02;      // K   [origin=predictive method=joback]
Pc          25.741;      // bar [origin=predictive method=joback]
omega       1.0838;      // -   [origin=predictive method=lee-kesler]
Tb          796.47;      // K   [origin=predictive method=joback]
HvapTb      76844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.641 1.07642 -0.00057112 8.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group CH3O; count 1; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxy-3-phenylmethoxy-benzoic acid" "benzoic acid, 4-methoxy-3-(phenylmethoxy)-" "3-benzyloxy-p-anisic acid" "4-methoxy-3-phenylmethoxybenzoic acid" "4-methoxy-3-(phenylmethoxy)benzoic acid" "benzoic acid,4-methoxy-3-(phenylmethoxy)-" "3-benzyloxy-4-methoxybenzoic acid, 98%" "benzoicacid, 3-(benzyloxy)-4-methoxy- (6ci); 3-benzyloxy-4-methoxybenzoic acid" );
standardThermochemistry
{
    dHf_298   -517520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-272930.0
}
