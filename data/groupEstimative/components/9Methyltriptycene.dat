/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-methyltriptycene  (C21H16, CAS 793-39-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Methyltriptycene;
formula     C21H16;
CAS         793-39-5;
InChIKey    OFWMYJWQNDGHLY-UHFFFAOYSA-N;
MW          268.359;      // g/mol [origin=calculated method=formula-sum]
Tc          1035.71;      // K   [origin=predictive method=joback]
Pc          23.092;      // bar [origin=predictive method=joback]
omega       0.7253;      // -   [origin=predictive method=lee-kesler]
Tb          771.70;      // K   [origin=predictive method=joback]
HvapTb      69141.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-205.01 2.21572 -0.00216968 8.567e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group ACH; count 12; } { group AC; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-methyl triptycene" "9,10(1',2')-benzenoanthracene, 9,10-dihydro-9-methyl-" );
standardThermochemistry
{
    dHf_298   383890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=598690.0
}
