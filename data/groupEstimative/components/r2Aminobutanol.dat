/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-2-aminobutanol  (C4H11NO, CAS 5856-63-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r2Aminobutanol;
formula     C4H11NO;
CAS         5856-63-3;
InChIKey    JCBPETKZIGVZRE-SCSAIBSYSA-N;
MW          89.138;      // g/mol [origin=calculated method=formula-sum]
Tc          635.06;      // K   [origin=predictive method=joback]
Pc          47.892;      // bar [origin=predictive method=joback]
omega       0.8308;      // -   [origin=predictive method=lee-kesler]
Tb          455.39;      // K   [origin=predictive method=joback]
HvapTb      51430.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.352 0.48562 -0.0002708 5.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group OH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-azanylbutan-1-ol" "(r)-(-)-2-amino-1-butanol" "(2r)-2-aminobutan-1-ol" "(r)-2-aminobutan-1-ol" "l-(-)-2-amino-1-butanol" "l-2-amino-1-butanol" "(r)-(-)-2-aminobutan-1-ol" "(r)(-)-2-aminobutanol" "(r)-(-)-2-aminobutanol" "l(-)-2-amino-1-butanol" "r-(-)-2-amino-1-butanol" "1-butanol,2-amino-, (-)- (7ci);1-butanol, 2-amino-, (r)-;1-butanol, 2-amino-, (r)-(-)-(8ci);1-butanol, 2-amino-, l- (4ci);(-)-2-amino-1-butanol;(2r)-2-amino-1-butanol;(r)-(-)-2-amino-1-butanol;(r)-(-)-2-aminobutan-1-ol;(r)-2-amino-1-butanol;(r)-2-aminobutanol;d-(-)-2-amino-1-butanol;d-2-amino-1-butanol;[(r)-1-(hydroxymethyl)propyl]amine;" );
standardThermochemistry
{
    dHf_298   -249610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90010.0
}
