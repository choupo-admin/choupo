/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5,7,11-tetraoxaspiro[5.5]undecane  (C7H12O4, CAS 24472-02-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15711Tetraoxaspiro55Undecane;
formula     C7H12O4;
CAS         24472-02-4;
InChIKey    PCEBNPHEKQSKKT-UHFFFAOYSA-N;
MW          160.169;      // g/mol [origin=calculated method=formula-sum]
Tc          753.69;      // K   [origin=predictive method=joback]
Pc          46.721;      // bar [origin=predictive method=joback]
omega       0.4575;      // -   [origin=predictive method=lee-kesler]
Tb          507.30;      // K   [origin=predictive method=joback]
HvapTb      49060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.21 1.229 -0.0010978 4.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group FCH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group C_ring; count 1; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5,7,11-tetraoxaspiro(5.5)undecane" "1,7,11-tetraoxaspiro[5.5]undecane" );
gibbsFormation
{
    dHf_298   -565430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     254.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-273200.0
    phase     gas;
}
