/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromotriphenylethylene  (C20H15Br, CAS 1607-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromotriphenylethylene;
formula     C20H15Br;
CAS         1607-57-4;
InChIKey    VUQVJIUBUPPCDB-UHFFFAOYSA-N;
MW          335.244;      // g/mol [origin=calculated method=formula-sum]
Tc          1093.24;      // K   [origin=predictive method=joback]
Pc          24.654;      // bar [origin=predictive method=joback]
omega       0.6978;      // -   [origin=predictive method=lee-kesler]
Tb          807.32;      // K   [origin=predictive method=joback]
HvapTb      73495.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.38 1.7251 -0.0013176 3.884e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 15; } { group AC; count 3; } { group Br; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC; count 2; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-bromanyl-2,2-diphenyl-ethenyl)benzene" "eitriphin" "triphenylethylene bromide" "phenylstilbene bromide" "ethylene, bromotriphenyl-" "2-bromo-1,1,2-triphenylethylene" "(2-bromoethene-1,1,2-triyl)tribenzene" "1,1,2-triphenylvinyl bromide" "stilbene, alpha'-bromo-alpha-phenyl-" "(1-bromo-2,2-diphenylethenyl)benzene" "benzene, 1,1',1''-(1-bromo-1-ethenyl-2-ylidene)tris-" "bromotriphenylethene" );
standardThermochemistry
{
    dHf_298   377430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     651.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=532190.0
}
