/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyldesorphine  (C18H21NO2, CAS 16008-36-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyldesorphine;
formula     C18H21NO2;
CAS         16008-36-9;
InChIKey    CUFWYVOFDYVCPM-GGNLRSJOSA-N;
MW          283.371;      // g/mol [origin=calculated method=formula-sum]
Tc          1038.86;      // K   [origin=predictive method=joback]
Pc          26.407;      // bar [origin=predictive method=joback]
omega       1.0301;      // -   [origin=predictive method=lee-kesler]
Tb          795.16;      // K   [origin=predictive method=joback]
HvapTb      78112.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-244.83 2.58104 -0.00258762 1.0449e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH-O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,4ar,7as,12bs)-3,7-dimethyl-2,4,4a,5,7a,13-hexahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-9-ol" "metildesorfina" "methyldesorphinum" "methyldesorphinum [inn-latin]" "mk-57" "3-hydroxy-6,n-dimethyl-4,5-epoxymorphin-6-en" "4,5alpha-epoxy-6,n-dimethyl-6-morphinen-3-ol" "3-hydroxy-6,''n''-dimethyl- 4,5-epoxymorphin-6-en" );
standardThermochemistry
{
    dHf_298   -84130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=333810.0
}
