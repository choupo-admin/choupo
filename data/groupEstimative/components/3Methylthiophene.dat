/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylthiophene  (C5H6S, CAS 616-44-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylthiophene;
formula     C5H6S;
CAS         616-44-4;
InChIKey    QENGPZGAWFQWCZ-UHFFFAOYSA-N;
MW          98.163;      // g/mol [origin=calculated method=formula-sum]
Tc          607.42;      // K   [origin=predictive method=joback]
Pc          48.630;      // bar [origin=predictive method=joback]
omega       0.2346;      // -   [origin=predictive method=lee-kesler]
Tb          385.08;      // K   [origin=predictive method=joback]
HvapTb      34348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.4 0.47993 -0.00035722 1.083e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thiophene, 3-methyl-" "3-thiotolene" "beta-methylthiophene" "3-methyl thiophene" "3-methyl-thiophene" "poly(3-methylthiophene)" "p3mt" "jirrevdkwwhkmf-uhfffaoysa-" "thiophene, 3-methyl-, homopolymer" );
standardThermochemistry
{
    dHf_298   83640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     311.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125630.0
}
