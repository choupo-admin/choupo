/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-1-piperazinepropanamine  (C8H19N3, CAS 4572-03-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl1Piperazinepropanamine;
formula     C8H19N3;
CAS         4572-03-6;
InChIKey    RGUABPVONIGVAT-UHFFFAOYSA-N;
MW          157.261;      // g/mol [origin=calculated method=formula-sum]
Tc          689.99;      // K   [origin=predictive method=joback]
Pc          32.840;      // bar [origin=predictive method=joback]
omega       0.6620;      // -   [origin=predictive method=lee-kesler]
Tb          495.73;      // K   [origin=predictive method=joback]
HvapTb      48523.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.577 1.24132 -0.0009092 2.674e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2NH2; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group NH2; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-methylpiperazin-1-yl)propan-1-amine" "1-(3-aminopropyl)-4-methylpiperazine" "1-piperazinepropanamine, 4-methyl-" "1-methyl-4-(3'-aminopropyl)piperazine" "3-(4-methyl-1-piperazinyl)propylamine" "3-(4-methyl-piperazin-1-yl)-propylamine" "4-(3-aminopropyl)-1-methylpiperazine" "3-(4-methylpiperazin-1-yl)propylamine" "n-methyl-n'-(3-aminopropyl)piperazine" "piperazine, 1-(3-aminopropyl)-4-methyl-" "3-(4-methylpiperazinyl)propylamine" "3-(4-methylpiperazino)propylamine" );
standardThermochemistry
{
    dHf_298   47380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=360850.0
}
