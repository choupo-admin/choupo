/*--------------------------------*- Choupo -*-----------------------*\
  Component: meperidine  (C15H21NO2, CAS 57-42-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        meperidine;
formula     C15H21NO2;
CAS         57-42-1;
InChIKey    XADCESSVHJOZHK-UHFFFAOYSA-N;
MW          247.338;      // g/mol [origin=calculated method=formula-sum]
Tc          881.95;      // K   [origin=predictive method=joback]
Pc          22.697;      // bar [origin=predictive method=joback]
omega       0.6994;      // -   [origin=predictive method=lee-kesler]
Tb          655.66;      // K   [origin=predictive method=joback]
HvapTb      59816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.409 1.84264 -0.0015014 5.106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 1-methyl-4-phenyl-piperidine-4-carboxylate" "pethidine" "demerol" "isonipecaine" "pethidin" "pethidineter" "meperidol" "pethanol" "phetidine" "pipersal" "dolsin" "lydol" );
gibbsFormation
{
    dHf_298   -290430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     720.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=19300.0
    phase     gas;
}
