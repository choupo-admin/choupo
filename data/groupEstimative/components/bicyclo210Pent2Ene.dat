/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.1.0]pent-2-ene  (C5H6, CAS 5164-35-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo210Pent2Ene;
formula     C5H6;
CAS         5164-35-2;
InChIKey    CGKPQMCLTLUAOW-UHFFFAOYSA-N;
MW          66.103;      // g/mol [origin=calculated method=formula-sum]
Tc          511.34;      // K   [origin=predictive method=joback]
Pc          49.108;      // bar [origin=predictive method=joback]
omega       0.2192;      // -   [origin=predictive method=lee-kesler]
Tb          322.37;      // K   [origin=predictive method=joback]
HvapTb      26670.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.24 0.7342 -0.00072228 2.81e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo(2.1.0)pent-2-ene" "bicyclo[2,1,0]penten-2-ene" );
gibbsFormation
{
    dHf_298   63010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     112.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=154780.0
    phase     gas;
}
