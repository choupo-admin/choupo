/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dimethylpropyl formate  (C6H12O2, CAS 66794-46-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H12O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        12DimethylpropylFormate;
formula     C6H12O2;
CAS         66794-46-5;
InChIKey    XEQSPMCNFJQDHU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          480.03;      // K   [origin=predictive method=joback]
Pc          32.064;      // bar [origin=predictive method=joback]
omega       0.1915;      // -   [origin=predictive method=lee-kesler]
Tb          312.42;      // K   [origin=predictive method=joback]
HvapTb      25801.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.43 0.59376 -0.000462 1.559e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 2; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutan-2-yl methanoate" "3-methylbutan-2-yl formate" "agn-pc-02kf6h" );
standardThermochemistry
{
    dHf_298   -101280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38720.0
}
