/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxyethyl acrylate  (C6H10O3, CAS 3121-61-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethoxyethylAcrylate;
formula     C6H10O3;
CAS         3121-61-7;
InChIKey    HFCUBKYHMMPGBY-UHFFFAOYSA-N;
MW          130.143;      // g/mol [origin=calculated method=formula-sum]
Tc          591.56;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       0.5027;      // -   [origin=predictive method=lee-kesler]
Tb          414.20;      // K   [origin=predictive method=joback]
HvapTb      38097.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.352 0.43582 -0.0001199 -3.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxyethyl prop-2-enoate" "methoxyethyl acrylate" "acrylic acid, 2-methoxyethyl ester" "ethylene glycol methyl ether acrylate" "2-methoxyethoxy acrylate" "2-propenoic acid, 2-methoxyethyl ester" "ethylene glycol monomethyl ether acrylate" "methyl cellosolve acrylate" "sipomer mca" "2-methoxyethanol, acrylate" "glycol monomethyl ether acrylate" "acrylic acid, 2-methoxyethoxy ester" );
gibbsFormation
{
    dHf_298   -491240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-327890.0
    phase     gas;
}
