/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-octanol  (C8H18O, CAS 123-96-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Octanol;
formula     C8H18O;
CAS         123-96-6;
InChIKey    SJWFXCIHNDVPSH-UHFFFAOYSA-N;
MW          130.231;      // g/mol [origin=calculated method=formula-sum]
Tc          637.36;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       0.8284;      // -   [origin=predictive method=lee-kesler]
Tb          474.38;      // K   [origin=predictive method=joback]
HvapTb      49693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.775 0.80374 -0.000445 9.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octan-2-ol" "hexylmethylcarbinol" "sec-caprylic alcohol" "2-hydroxyoctane" "1-methylheptyl alcohol" "2-octyl alcohol" "methylhexylcarbinol" "dl-2-octanol" "n-octan-2-ol" "hexyl methyl carbinol" "1-methyl-1-heptanol" "sec-octyl alcohol" );
standardThermochemistry
{
    dHf_298   -365960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122780.0
}
