/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-butylhexane-1,6-diamine  (C10H24N2, CAS 38615-43-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nButylhexane16Diamine;
formula     C10H24N2;
CAS         38615-43-9;
InChIKey    IQDWESONKRVAER-UHFFFAOYSA-N;
MW          172.316;      // g/mol [origin=calculated method=formula-sum]
Tc          727.98;      // K   [origin=predictive method=joback]
Pc          22.504;      // bar [origin=predictive method=joback]
omega       0.8330;      // -   [origin=predictive method=lee-kesler]
Tb          551.10;      // K   [origin=predictive method=joback]
HvapTb      54931.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.921 1.09192 -0.0006122 1.293e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2NH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-butylhexane-1,6-diamine" "n-butylhexamethylenediamine" "1,6-hexanediamine, n-butyl-" "n-butyl-1,6-hexanediamine" "monobutyl hexamethylenediamine" "1,6-hexanediamine, n1-butyl-" );
standardThermochemistry
{
    dHf_298   -162470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     637.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=189160.0
}
