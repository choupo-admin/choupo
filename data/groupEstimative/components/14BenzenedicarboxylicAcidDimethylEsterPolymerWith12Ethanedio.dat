/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-benzenedicarboxylic acid, dimethyl ester, polymer with 1,2-ethanediol and 2,2'-((octahydro-4,7-methano-5h-inden-5-ylidene)bis(4,1-phenyleneoxy))bis(ethanol)  (C38H48O10, CAS 109721-30-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BenzenedicarboxylicAcidDimethylEsterPolymerWith12Ethanedio;
formula     C38H48O10;
CAS         109721-30-4;
InChIKey    LFPFMTZOJXJFIX-UHFFFAOYSA-N;
MW          664.792;      // g/mol [origin=calculated method=formula-sum]
Tc          2525.20;      // K   [origin=predictive method=joback]
Pc          8.879;      // bar [origin=predictive method=joback]
omega       -0.1443;      // -   [origin=predictive method=lee-kesler]
Tb          1712.21;      // K   [origin=predictive method=joback]
HvapTb      194076.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.814 3.36824 -0.00185268 3.334e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 4; } { group C; count 1; } { group ACH; count 12; } { group AC; count 6; } { group _CH2OH_2; count 1; } { group COO; count 2; } { group C2H5O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH2_ring; count 5; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group OH; count 4; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-benzenedicarboxylic acid, 1,4-dimethyl ester, polymer with 1,2-ethanediol and 2,2'-((octahydro-4,7-methano-5h-inden-5-ylidene)bis(4,1-phenyleneoxy))bis(ethanol)" );
gibbsFormation
{
    dHf_298   -1696830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1576.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-860880.0
    phase     gas;
}
