name        nNBisTriethoxysilylMethylAllylamine;
formula     C17H39NO6Si2;
CAS         26868-19-9;
InChIKey    JKIXQFFUDBSKMM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          409.67;      // g/mol [origin=calculated method=formula-sum]
Tc          908.05;      // K   [origin=predictive method=joback]
Pc          10.065;      // bar [origin=predictive method=joback]
omega       0.8731;      // -   [origin=predictive method=lee-kesler]
Tb          735.00;      // K   [origin=predictive method=joback]
HvapTb      69857.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (208.389 0.93122 0.0004591 -5.173e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2O; count 6; } { group CH2N; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 9; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 6; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(triethoxysilylmethyl)prop-2-en-1-amine" "2-propen-1-amine, n,n-bis((triethoxysilyl)methyl)-" "2-propen-1-amine, n,n-bis[(triethoxysilyl)methyl]-" "n,n-bis[(triethoxysilyl)methyl]prop-2-en-1-amine" );
standardThermochemistry
{
    dHf_298   -1217810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1150.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-548640.0
}
