/*--------------------------------*- Choupo -*-----------------------*\
  Component: lynestrenol  (C20H28O, CAS 52-76-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lynestrenol;
formula     C20H28O;
CAS         52-76-6;
InChIKey    YNVGQYHLRCDXFQ-XGXHKTLJSA-N;
MW          284.443;      // g/mol [origin=calculated method=formula-sum]
Tc          1019.05;      // K   [origin=predictive method=joback]
Pc          20.512;      // bar [origin=predictive method=joback]
omega       0.9023;      // -   [origin=predictive method=lee-kesler]
Tb          783.09;      // K   [origin=predictive method=joback]
HvapTb      75197.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-288.82 2.81482 -0.00261397 1.02159e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s,17r)-17-ethynyl-13-methyl-2,3,6,7,8,9,10,11,12,14,15,16-dodecahydro-1h-cyclopenta[a]phenanthren-17-ol" "linestrenol" "exluton" "ethynylestrenol" "lynoestrenol" "endometril" "exlution" "exlutona" "orgametil" "orgametril" "orgametrol" "3-desoxynorlutin" );
gibbsFormation
{
    dHf_298   -19950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=380200.0
    phase     gas;
}
