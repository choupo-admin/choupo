/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethylsulfolane  (C6H12O2S, CAS 1003-78-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H12O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        24Dimethylsulfolane;
formula     C6H12O2S;
CAS         1003-78-7;
InChIKey    WKFQMDFSDQFAIC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          148.22;      // g/mol [origin=calculated method=formula-sum]
Tc          479.91;      // K   [origin=predictive method=joback]
Pc          40.777;      // bar [origin=predictive method=joback]
omega       0.3957;      // -   [origin=predictive method=lee-kesler]
Tb          322.22;      // K   [origin=predictive method=joback]
HvapTb      40544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.35 0.72784 -0.0003956 6.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2SuCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-dimethylthiolane 1,1-dioxide" "2,4-dimethyl sulfolane" "2,4-dimethyltetrahydrothiophene-1,1-dioxide" "2,4-dimethyltetramethylene sulfone" "2,4-dimethyltetrahydrothiophene dioxide" "2,4-dimethyltetrahydrothiophene 1,1-dioxide" "thiophene, tetrahydro-2,4-dimethyl-, 1,1-dioxide" "2,4-dimethylthiolane-1,1-dione" "dimethylsulfolane" "thiophene,4-dimethyl-, 1,1-dioxide" "thiophene,tetrahydro-2,4-dimethyl-, 1,1-dioxide" "(2s,4r)-2,4-dimethyltetrahydrothiophene 1,1-dioxide" );
standardThermochemistry
{
    dHf_298   -616090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-461080.0
}
