/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-chloroethoxy)-2-ethoxyethane  (C6H13ClO2, CAS 41771-35-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Chloroethoxy2Ethoxyethane;
formula     C6H13ClO2;
CAS         41771-35-1;
InChIKey    NDDRUUNXMMRCIV-UHFFFAOYSA-N;
MW          152.618;      // g/mol [origin=calculated method=formula-sum]
Tc          591.99;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.5134;      // -   [origin=predictive method=lee-kesler]
Tb          419.15;      // K   [origin=predictive method=joback]
HvapTb      38155.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.325 0.45422 -0.000101 -4.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2O; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-chloroethyloxy)-2-ethoxy-ethane" "ethane, 1-(2-chloroethoxy)-2-ethoxy-" "2-chloro-1-(2-ethoxyethoxy)ethane" "1-chloro-2-(2-ethoxyethoxy)ethane" );
standardThermochemistry
{
    dHf_298   -447350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-222290.0
}
