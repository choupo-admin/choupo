/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibenzoylethane  (C16H14O2, CAS 495-71-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibenzoylethane;
formula     C16H14O2;
CAS         495-71-6;
InChIKey    OSWWFLDIIGGSJV-UHFFFAOYSA-N;
MW          238.286;      // g/mol [origin=calculated method=formula-sum]
Tc          968.79;      // K   [origin=predictive method=joback]
Pc          25.872;      // bar [origin=predictive method=joback]
omega       0.8430;      // -   [origin=predictive method=lee-kesler]
Tb          726.78;      // K   [origin=predictive method=joback]
HvapTb      69254.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.748 1.31 -0.0008716 2.1212e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-diphenylbutane-1,4-dione" "1,4-diphenyl-1,4-butanedione" "1,4-butanedione, 1,4-diphenyl-" "biphenacyl" "dibenzoylethane" "2,2''-biacetophenone" "1,4-diphenyl-1,4-butadione" "1,4-dioxo-1,4-diphenylbutane" "1,4-diphenyl-butane-1,4-dione" );
standardThermochemistry
{
    dHf_298   -125670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50820.0
}
