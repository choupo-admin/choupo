/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-decene, 1,1,3-triethoxy-  (C16H32O3, CAS 72152-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Decene113Triethoxy;
formula     C16H32O3;
CAS         72152-75-1;
InChIKey    RCATYCKUCAVYNI-LHNRBYRGSA-N;
MW          272.429;      // g/mol [origin=calculated method=formula-sum]
Tc          806.07;      // K   [origin=predictive method=joback]
Pc          13.349;      // bar [origin=predictive method=joback]
omega       0.8472;      // -   [origin=predictive method=lee-kesler]
Tb          636.22;      // K   [origin=predictive method=joback]
HvapTb      57622.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.298 1.36608 -0.0006038 6.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 2; } { group dCH; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e,3r)-1,1,3-triethoxydec-4-ene" "1,1,3-triethoxy-4-decene" );
gibbsFormation
{
    dHf_298   -663570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     787.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-155820.0
    phase     gas;
}
