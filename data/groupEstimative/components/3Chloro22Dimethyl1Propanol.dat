/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-2,2-dimethyl-1-propanol  (C5H11ClO, CAS 13401-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro22Dimethyl1Propanol;
formula     C5H11ClO;
CAS         13401-56-4;
InChIKey    CAZPRAORHCOIHC-UHFFFAOYSA-N;
MW          122.592;      // g/mol [origin=calculated method=formula-sum]
Tc          619.34;      // K   [origin=predictive method=joback]
Pc          37.916;      // bar [origin=predictive method=joback]
omega       0.6651;      // -   [origin=predictive method=lee-kesler]
Tb          440.38;      // K   [origin=predictive method=joback]
HvapTb      46492.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.948 0.64544 -0.0004708 1.39e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-2,2-dimethyl-propan-1-ol" "3-chloro-2,2-dimethylpropan-1-ol" "1-propanol, 3-chloro-2,2-dimethyl-" "2-chloromethyl-2-methyl-1-propanol" "cazpraorhcoihc-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -323250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154690.0
}
