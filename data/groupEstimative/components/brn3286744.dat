/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3286744  (C14H19NO2, CAS 63887-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3286744;
formula     C14H19NO2;
CAS         63887-51-4;
InChIKey    UACSYZPPUXXDTL-UHFFFAOYSA-N;
MW          233.311;      // g/mol [origin=calculated method=formula-sum]
Tc          839.18;      // K   [origin=predictive method=joback]
Pc          21.433;      // bar [origin=predictive method=joback]
omega       0.8251;      // -   [origin=predictive method=lee-kesler]
Tb          636.99;      // K   [origin=predictive method=joback]
HvapTb      60225.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.267 1.20814 -0.00070776 1.4696e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-2-prop-2-enoxy-benzamide" "benzamide, o-allyloxy-n,n-diethyl-" "n,n-diethyl-2-prop-2-enoxybenzamide" "n,n-diethyl-2-(prop-2-en-1-yloxy)benzamide" );
gibbsFormation
{
    dHf_298   -159070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=134480.0
    phase     gas;
}
