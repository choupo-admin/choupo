/*--------------------------------*- Choupo -*-----------------------*\
  Component: tiletamine  (C12H17NOS, CAS 14176-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tiletamine;
formula     C12H17NOS;
CAS         14176-49-9;
InChIKey    QAXBVGVYDCAVLV-UHFFFAOYSA-N;
MW          223.334;      // g/mol [origin=calculated method=formula-sum]
Tc          944.96;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.6658;      // -   [origin=predictive method=lee-kesler]
Tb          683.02;      // K   [origin=predictive method=joback]
HvapTb      59891.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.139 1.46683 -0.00115622 3.967e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group CH2CO; count 1; } { group CH2NH; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group NH; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(ethylamino)-2-thiophen-2-yl-cyclohexan-1-one" "tiletaminum [inn-latin]" "cyclohexanone, 2-(ethylamino)-2-(2-thienyl)-" "2-(ethylamino)-2-(2-thienyl)cyclohexanone" "tiletamina" "tiletaminum" "tiletamine (inn)" "tiletamine [inn:ban]" "14176-50-2 (hydrochloride)" "2-(ethylamino)-2-(thiophen-2-yl)cyclohexanone" "2-(ethylamino)-2-thiophen-2-yl-1-cyclohexanone" "2-(ethylamino)-2-thiophen-2-ylcyclohexan-1-one" );
standardThermochemistry
{
    dHf_298   -75510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=170330.0
}
