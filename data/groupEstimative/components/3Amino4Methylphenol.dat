/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-amino-4-methylphenol  (C7H9NO, CAS 2836-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Amino4Methylphenol;
formula     C7H9NO;
CAS         2836-00-2;
InChIKey    NUNAWQZKZVVELQ-UHFFFAOYSA-N;
MW          123.155;      // g/mol [origin=calculated method=formula-sum]
Tc          786.41;      // K   [origin=predictive method=joback]
Pc          53.435;      // bar [origin=predictive method=joback]
omega       0.6577;      // -   [origin=predictive method=lee-kesler]
Tb          544.57;      // K   [origin=predictive method=joback]
HvapTb      57769.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.51 0.74692 -0.00062092 2.168e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 1; } { group ACOH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azanyl-4-methyl-phenol" "2-amino-4-hydroxytoluene" "phenol, 3-amino-4-methyl-" "3-amino-p-cresol" "p-cresol, 3-amino-" "3-amino-4-methyl-phenol" "phenol,3-amino-4-methyl-" "wt486" "2836-00-2 3-amino-4-methylphenol" "3-amino-p-cresol; 5-hydroxy-o-toluidine" "p-cresol,3-amino- (6ci,7ci,8ci);3-hydroxy-6-methylaniline;4-methyl-3-aminophenol;3-amino-4-methylphenol;2-amino-4-hydroxytoluene;5-hydroxy-2-methylaniline;5-hydroxy-o-toluidine;" );
gibbsFormation
{
    dHf_298   -106270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22670.0
    phase     gas;
}
