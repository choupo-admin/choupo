/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylethenamine  (C3H7N, CAS 2308-42-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylethenamine;
formula     C3H7N;
CAS         2308-42-1;
InChIKey    HGUZQMQXAHVIQC-UHFFFAOYSA-N;
MW          57.096;      // g/mol [origin=calculated method=formula-sum]
Tc          488.64;      // K   [origin=predictive method=joback]
Pc          47.497;      // bar [origin=predictive method=joback]
omega       0.2865;      // -   [origin=predictive method=lee-kesler]
Tb          315.09;      // K   [origin=predictive method=joback]
HvapTb      28038.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.04 0.34502 -0.0002109 5.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ch3nhch=ch2" "n-ethylidenemethylamine" "n-methyl-n-ethenylamine" );
gibbsFormation
{
    dHf_298   73650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     308.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=151610.0
    phase     gas;
}
