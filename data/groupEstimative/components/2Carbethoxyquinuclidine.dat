/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-carbethoxyquinuclidine  (C10H17NO2, CAS 39926-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Carbethoxyquinuclidine;
formula     C10H17NO2;
CAS         39926-11-9;
InChIKey    KCCLFMFYEDPKEL-UHFFFAOYSA-N;
MW          183.251;      // g/mol [origin=calculated method=formula-sum]
Tc          717.15;      // K   [origin=predictive method=joback]
Pc          27.995;      // bar [origin=predictive method=joback]
omega       0.6033;      // -   [origin=predictive method=lee-kesler]
Tb          516.81;      // K   [origin=predictive method=joback]
HvapTb      47302.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.089 1.31512 -0.0009322 2.568e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 2; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 1-azabicyclo[2.2.2]octane-2-carboxylate" "ethyl 1-aza-bicyclo[2.2.2]octane-2-carboxylate" "1-azabicyclo[2.2.2]octane-2-carboxylicacid, ethyl ester" "2-quinuclidinecarboxylicacid, ethyl ester (7ci); 2-(ethoxycarbonyl)quinuclidine; 2-carbethoxyquinuclidine;ethyl 2-quinuclidinecarboxylate" );
standardThermochemistry
{
    dHf_298   -360040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-56870.0
}
