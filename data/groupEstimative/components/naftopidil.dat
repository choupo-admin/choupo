/*--------------------------------*- Choupo -*-----------------------*\
  Component: naftopidil  (C24H28N2O3, CAS 57149-07-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naftopidil;
formula     C24H28N2O3;
CAS         57149-07-2;
InChIKey    HRRBJVNMSRJFHQ-UHFFFAOYSA-N;
MW          392.499;      // g/mol [origin=calculated method=formula-sum]
Tc          1241.94;      // K   [origin=predictive method=joback]
Pc          17.434;      // bar [origin=predictive method=joback]
omega       1.3865;      // -   [origin=predictive method=lee-kesler]
Tb          1008.16;      // K   [origin=predictive method=joback]
HvapTb      102125.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.658 2.33242 -0.00161284 4.288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 11; } { group AC; count 5; } { group CH3O; count 1; } { group CH2N; count 2; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 11; } { group dC_ring; count 5; } { group OH; count 1; } { group O; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-(2-methoxyphenyl)piperazin-1-yl]-3-naphthalen-1-yloxy-propan-2-ol" "flivas" "avishot" "naftopidilum [latin]" "naftopidil (unspecified)" "(+-)-1-(4-(2-methoxyphenyl)piperazinyl)-3-(1-naphthyloxy)propan-2-ol" "(+-)-4-(o-methoxyphenyl)-alpha-((1-naphthyloxy)methyl)-1-piperazineethanol" "(rs)-1-(4-(2-methoxyphenyl)-1-piperazinyl)-3-(1-naphthyloxy)-2-propanol" "1-pioerazineethanol, 4-(2-methoxyphenyl)-alpha-((1-naphthalenyloxy)methyl)-" "4-(2-methoxyphenyl)-alpha-((1-naphthalenyloxy)methyl)-1-pioerazineethanol" "flivas, naftopidil, flivas, kt-611, bm-15275, avishot" "naftopidilum" );
standardThermochemistry
{
    dHf_298   -97410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     824.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=392070.0
}
