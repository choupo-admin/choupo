/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentacosanenitrile  (C25H49N, CAS 95960-95-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentacosanenitrile;
formula     C25H49N;
CAS         95960-95-5;
InChIKey    YEGZSJUZUMEHPD-UHFFFAOYSA-N;
MW          363.674;      // g/mol [origin=calculated method=formula-sum]
Tc          1069.96;      // K   [origin=predictive method=joback]
Pc          7.535;      // bar [origin=predictive method=joback]
omega       0.7076;      // -   [origin=predictive method=lee-kesler]
Tb          873.68;      // K   [origin=predictive method=joback]
HvapTb      81722.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.837 2.31362 -0.0013052 2.8e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 22; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 23; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -394450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1135.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=292800.0
}
