/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclotriacontane  (C30H60, CAS 297-35-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclotriacontane;
formula     C30H60;
CAS         297-35-8;
InChIKey    RPRAXXJCTCCPOZ-UHFFFAOYSA-N;
MW          420.81;      // g/mol [origin=calculated method=formula-sum]
Tc          1292.53;      // K   [origin=predictive method=joback]
Pc          9.409;      // bar [origin=predictive method=joback]
omega       0.5266;      // -   [origin=predictive method=lee-kesler]
Tb          1012.70;      // K   [origin=predictive method=joback]
HvapTb      87240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-218.83 2.772 -0.000631 -3.34e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 30; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 30; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclotriacotane" );
gibbsFormation
{
    dHf_298   -735710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1814.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-56520.0
    phase     gas;
}
