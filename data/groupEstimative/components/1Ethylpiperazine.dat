/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethylpiperazine  (C6H14N2, CAS 5308-25-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethylpiperazine;
formula     C6H14N2;
CAS         5308-25-8;
InChIKey    WGCYRFWNGRMRJA-UHFFFAOYSA-N;
MW          114.192;      // g/mol [origin=calculated method=formula-sum]
Tc          621.10;      // K   [origin=predictive method=joback]
Pc          41.197;      // bar [origin=predictive method=joback]
omega       0.4080;      // -   [origin=predictive method=lee-kesler]
Tb          417.82;      // K   [origin=predictive method=joback]
HvapTb      38317.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.759 0.84252 -0.0005374 1.324e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperazine, 1-ethyl-" "n-ethylpiperazine" "1-ethylpiperazin" "1-ethyl-piperazine" "ethylpiperazine" "1-ethyl-piperazin" );
gibbsFormation
{
    dHf_298   18990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=242390.0
    phase     gas;
}
