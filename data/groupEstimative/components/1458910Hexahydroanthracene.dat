/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,5,8,9,10-hexahydroanthracene  (C14H16, CAS 5910-28-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1458910Hexahydroanthracene;
formula     C14H16;
CAS         5910-28-1;
InChIKey    LNRAWXJRDXDHJN-UHFFFAOYSA-N;
MW          184.282;      // g/mol [origin=calculated method=formula-sum]
Tc          838.32;      // K   [origin=predictive method=joback]
Pc          28.781;      // bar [origin=predictive method=joback]
omega       0.5001;      // -   [origin=predictive method=lee-kesler]
Tb          592.06;      // K   [origin=predictive method=joback]
HvapTb      52100.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.67 1.356 -0.00101356 3.056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH=CH; count 2; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "anthracene, 1,4,5,8,9,10-hexahydro-" "1,4,5,8,9,10-hexahydro-anthracene" "anthracene, 1,4,5,8,9,10-hexahydro-;" );
standardThermochemistry
{
    dHf_298   101570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=293200.0
}
