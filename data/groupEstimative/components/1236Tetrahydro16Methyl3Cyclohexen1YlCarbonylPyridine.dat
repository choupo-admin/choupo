/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,6-tetrahydro-1-((6-methyl-3-cyclohexen-1-yl)carbonyl)pyridine  (C13H19NO, CAS 69462-56-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1236Tetrahydro16Methyl3Cyclohexen1YlCarbonylPyridine;
formula     C13H19NO;
CAS         69462-56-2;
InChIKey    XOSMTRXKSZLBST-UHFFFAOYSA-N;
MW          205.301;      // g/mol [origin=calculated method=formula-sum]
Tc          825.05;      // K   [origin=predictive method=joback]
Pc          26.353;      // bar [origin=predictive method=joback]
omega       0.5934;      // -   [origin=predictive method=lee-kesler]
Tb          596.50;      // K   [origin=predictive method=joback]
HvapTb      54591.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.79 1.47652 -0.00096026 2.2936e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 2; } { group CH=CH; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-dihydro-2h-pyridin-1-yl-(6-methylcyclohex-3-en-1-yl)methanone" "pyridine, 1,2,3,6-tetrahydro-1-((6-methyl-3-cyclohexen-1-yl)carbonyl)-" );
gibbsFormation
{
    dHf_298   -126340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161360.0
    phase     gas;
}
