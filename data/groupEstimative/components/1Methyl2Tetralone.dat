/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-2-tetralone  (C11H12O, CAS 4024-14-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl2Tetralone;
formula     C11H12O;
CAS         4024-14-0;
InChIKey    VGZQKUJGVYFKBP-UHFFFAOYSA-N;
MW          160.216;      // g/mol [origin=calculated method=formula-sum]
Tc          806.20;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.4756;      // -   [origin=predictive method=lee-kesler]
Tb          561.77;      // K   [origin=predictive method=joback]
HvapTb      47350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.65 0.88342 -0.00046856 7.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3,4-dihydro-1h-naphthalen-2-one" "1-methyl-3,4-dihydronaphthalen-2(1h)-one" "1,2,3,4-tetrahydro-1-methylnaphthalen-2-one" "1-methyl-1,3,4-trihydronaphthalen-2-one" );
gibbsFormation
{
    dHf_298   -116370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     322.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70580.0
    phase     gas;
}
