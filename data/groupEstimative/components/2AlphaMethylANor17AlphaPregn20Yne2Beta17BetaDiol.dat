/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-alpha-methyl-a-nor-17-alpha-pregn-20-yne-2-beta,17-beta-diol  (C21H32O2, CAS 53-38-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AlphaMethylANor17AlphaPregn20Yne2Beta17BetaDiol;
formula     C21H32O2;
CAS         53-38-3;
InChIKey    AVMGEEZXZUABHL-YRWKUUEZSA-N;
MW          316.485;      // g/mol [origin=calculated method=formula-sum]
Tc          1105.62;      // K   [origin=predictive method=joback]
Pc          20.037;      // bar [origin=predictive method=joback]
omega       1.2613;      // -   [origin=predictive method=lee-kesler]
Tb          880.88;      // K   [origin=predictive method=joback]
HvapTb      90056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-389.5 3.59976 -0.00377933 1.63349e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 4; } { group C; count 4; } { group OH; count 2; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 4; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3as,3bs,5as,6r,8as,8br,10as)-6-ethynyl-2,3a,5a-trimethyl-1,3,3b,4,5,7,8,8a,8b,9,10,10a-dodecahydroindeno[5,4-e]indene-2,6-diol" "a-nor-17-alpha-pregn-20-yne-2-beta,17-beta-diol, 2-alpha-methyl-" );
gibbsFormation
{
    dHf_298   -243170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     872.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=217170.0
    phase     gas;
}
