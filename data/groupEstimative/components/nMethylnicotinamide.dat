/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylnicotinamide  (C7H8N2O, CAS 114-33-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylnicotinamide;
formula     C7H8N2O;
CAS         114-33-0;
InChIKey    ZYVXHFWBYUDDBM-UHFFFAOYSA-N;
MW          136.154;      // g/mol [origin=calculated method=formula-sum]
Tc          780.10;      // K   [origin=predictive method=joback]
Pc          45.531;      // bar [origin=predictive method=joback]
omega       0.6324;      // -   [origin=predictive method=lee-kesler]
Tb          544.18;      // K   [origin=predictive method=joback]
HvapTb      52844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.17 0.67188 -0.00042736 1.0086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C5H4N; count 1; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group CdO; count 1; } { group NH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methylpyridine-3-carboxamide" "nicotinic acid methylamide" "n-methyl-3-pyridinecarboxamide" "3-(methylcarbamoyl)pyridine" "3-(n-methylcarbamoyl)pyridine" "nicotinyl methylamide" "n-methyl nicotinamide" "3-pyridinecarboxamide, n-methyl-" "nicotinamide, n-methyl-" "n-methylniacinamide" "n-methyl nicotineamide" "n -methyl nicotineamide" );
gibbsFormation
{
    dHf_298   22400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157990.0
    phase     gas;
}
