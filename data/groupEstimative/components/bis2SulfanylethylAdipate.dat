/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-sulfanylethyl) adipate  (C10H18O4S2, CAS 10194-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2SulfanylethylAdipate;
formula     C10H18O4S2;
CAS         10194-00-0;
InChIKey    SDBQMGGFXXVCCV-UHFFFAOYSA-N;
MW          266.37;      // g/mol [origin=calculated method=formula-sum]
Tc          877.22;      // K   [origin=predictive method=joback]
Pc          24.029;      // bar [origin=predictive method=joback]
omega       0.9575;      // -   [origin=predictive method=lee-kesler]
Tb          670.56;      // K   [origin=predictive method=joback]
HvapTb      66142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.398 0.8988 -0.0003758 4.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2COO; count 2; } { group CH2SH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group COO; count 2; } { group SH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-sulfanylethyl) hexanedioate" "hexanedioic acid, bis(2-mercaptoethyl) ester" "hexanedioic acid, 1,6-bis(2-mercaptoethyl) ester" "bis(2-mercaptoethyl) adipate" "bis(2-mercaptoethyl)hexanedioate" "hexanedioic acid, bis(2-mercaptoethyl)ester)" "hexanedioic acid,1,6-bis(2-mercaptoethyl) ester" "adipicacid, bis(2-mercaptoethyl) ester (8ci); hexanedioic acid, bis(2-mercaptoethyl)ester (9ci); ethanol, 2-mercapto-, o,o'-adipate (8ci); bis(2-mercaptoethyl)adipate; bis(2-mercaptoethyl) hexanedioate" );
standardThermochemistry
{
    dHf_298   -807330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     773.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-528640.0
}
