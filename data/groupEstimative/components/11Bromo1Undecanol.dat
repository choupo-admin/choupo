/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11-bromo-1-undecanol  (C11H23BrO, CAS 1611-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Bromo1Undecanol;
formula     C11H23BrO;
CAS         1611-56-9;
InChIKey    XFGANBYCJWQYBI-UHFFFAOYSA-N;
MW          251.208;      // g/mol [origin=calculated method=formula-sum]
Tc          779.80;      // K   [origin=predictive method=joback]
Pc          22.398;      // bar [origin=predictive method=joback]
omega       1.1300;      // -   [origin=predictive method=lee-kesler]
Tb          609.62;      // K   [origin=predictive method=joback]
HvapTb      63194.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.371 1.121 -0.0006764 1.636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 11; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-bromanylundecan-1-ol" "11-bromoundecan-1-ol" "1-undecanol, 11-bromo-" "undecamethylene bromohydrin" "11-bromoundecanol" "1-bromo-11-hydroxyundecane" "11-bromoundecyl alcohol" "p226" );
standardThermochemistry
{
    dHf_298   -396270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     686.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-80760.0
}
