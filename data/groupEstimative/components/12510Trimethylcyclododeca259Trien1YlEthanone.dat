/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,5,10-trimethylcyclododeca-2,5,9-trien-1-yl)ethanone  (C17H26O, CAS 144020-22-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12510Trimethylcyclododeca259Trien1YlEthanone;
formula     C17H26O;
CAS         144020-22-4;
InChIKey    XVILRJBIOPPCNB-UHFFFAOYSA-N;
MW          246.394;      // g/mol [origin=calculated method=formula-sum]
Tc          933.32;      // K   [origin=predictive method=joback]
Pc          17.818;      // bar [origin=predictive method=joback]
omega       0.6234;      // -   [origin=predictive method=lee-kesler]
Tb          700.02;      // K   [origin=predictive method=joback]
HvapTb      64505.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.3 1.30888 -0.00044562 -4.984e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CH=C; count 3; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "acetic acid, anhydride,reaction products with 1,5,10-trimethyl-1,5,9-cyclododecatriene" "2,5,10-trimethyl-2,5,9-cyclododecatrien-1-yl methyl ketone" "2,5,10-trimethyl-2,5,9-cyclododecatrien-1-yl methyl ketone;trimofix a'a inverted exclamation marka'a a'a inverted exclamation marka'a oa'a inverted exclamation marka'a a'a inverted exclamation marka'a ;aceticacid,anhydride,reactionproductswith1,5,10-trimethyl-1,5,9-cyclodode;catriene;aceticacid,anhydride,reactionproductswith1,5,10-trimethyl-1,5,9-cyclododecatriene" );
standardThermochemistry
{
    dHf_298   -350500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     803.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23820.0
}
