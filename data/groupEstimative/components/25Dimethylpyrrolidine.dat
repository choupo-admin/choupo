/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethylpyrrolidine  (C6H13N, CAS 3378-71-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethylpyrrolidine;
formula     C6H13N;
CAS         3378-71-0;
InChIKey    ZEBFPAXSQXIPNF-UHFFFAOYSA-N;
MW          99.177;      // g/mol [origin=calculated method=formula-sum]
Tc          600.72;      // K   [origin=predictive method=joback]
Pc          38.010;      // bar [origin=predictive method=joback]
omega       0.2955;      // -   [origin=predictive method=lee-kesler]
Tb          396.04;      // K   [origin=predictive method=joback]
HvapTb      35656.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.19 0.66564 -0.000314 3.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-03f3hh" "pyrrolidine, 2,5-dimethyl-" "2,5-dimethylpyrrolidine, mixture of cis and trans" );
gibbsFormation
{
    dHf_298   -89220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     290.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116190.0
    phase     gas;
}
