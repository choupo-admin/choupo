/*--------------------------------*- Choupo -*-----------------------*\
  Component: nandrolone  (C18H26O2, CAS 434-22-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nandrolone;
formula     C18H26O2;
CAS         434-22-0;
InChIKey    NPAGDVCDWIYMMC-IZPLOLCNSA-N;
MW          274.404;      // g/mol [origin=calculated method=formula-sum]
Tc          1047.93;      // K   [origin=predictive method=joback]
Pc          21.158;      // bar [origin=predictive method=joback]
omega       1.0339;      // -   [origin=predictive method=lee-kesler]
Tb          814.79;      // K   [origin=predictive method=joback]
HvapTb      76285.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-214.36 2.25852 -0.00173264 5.684e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 5; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s,17s)-13-methyl-17-oxidanyl-2,6,7,8,9,10,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-one" "19-nortestosterone" "19-norandrostenolone" "norandrostenolone" "menidrabol" "nortestonate" "nortestosterone" "oestrenolon" "nandrolon" "norandrostenolon" "4-estren-17beta-ol-3-one" "nortestosteronum" );
gibbsFormation
{
    dHf_298   -423510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23190.0
    phase     gas;
}
