/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetamide, 2-(dodecylthio)-  (C14H29NOS, CAS 10220-53-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetamide2Dodecylthio;
formula     C14H29NOS;
CAS         10220-53-8;
InChIKey    FZFDAJRZDGMCLE-UHFFFAOYSA-N;
MW          259.452;      // g/mol [origin=calculated method=formula-sum]
Tc          906.59;      // K   [origin=predictive method=joback]
Pc          17.005;      // bar [origin=predictive method=joback]
omega       1.0225;      // -   [origin=predictive method=lee-kesler]
Tb          715.10;      // K   [origin=predictive method=joback]
HvapTb      70962.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.612 1.36211 -0.0007223 1.2976e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CONH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group CdO; count 1; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-dodecylsulfanylethanamide" "2-(dodecylthio)acetamide" "2-dodecylsulfanylacetamide" );
gibbsFormation
{
    dHf_298   -369210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     841.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37650.0
    phase     gas;
}
