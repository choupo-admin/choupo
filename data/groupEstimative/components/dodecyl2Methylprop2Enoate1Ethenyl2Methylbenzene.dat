/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecyl 2-methylprop-2-enoate; 1-ethenyl-2-methylbenzene  (C25H40O2, CAS 67859-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecyl2Methylprop2Enoate1Ethenyl2Methylbenzene;
formula     C25H40O2;
CAS         67859-82-9;
InChIKey    FQBFZMYXLPFPTI-UHFFFAOYSA-N;
MW          372.593;      // g/mol [origin=calculated method=formula-sum]
Tc          1055.52;      // K   [origin=predictive method=joback]
Pc          9.205;      // bar [origin=predictive method=joback]
omega       0.8172;      // -   [origin=predictive method=lee-kesler]
Tb          856.12;      // K   [origin=predictive method=joback]
HvapTb      80623.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.111 1.93936 -0.00083906 4.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 11; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecyl 2-methylprop-2-enoate;1-ethenyl-2-methyl-benzene" "2-propenoic acid, 2-methyl-, dodecyl ester, polymer with ethenylmethylbenzene" );
standardThermochemistry
{
    dHf_298   -522100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1162.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14400.0
}
