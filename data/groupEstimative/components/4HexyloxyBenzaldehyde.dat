/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(hexyloxy)benzaldehyde  (C13H18O2, CAS 5736-94-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H18O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4HexyloxyBenzaldehyde;
formula     C13H18O2;
CAS         5736-94-7;
InChIKey    GWXUVWKBVROFDM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          723.28;      // K   [origin=predictive method=joback]
Pc          22.187;      // bar [origin=predictive method=joback]
omega       0.5605;      // -   [origin=predictive method=lee-kesler]
Tb          527.54;      // K   [origin=predictive method=joback]
HvapTb      47507.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.535 1.04532 -0.00068956 1.86e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-hexoxybenzaldehyde" "4-hexyloxybenzaldehyde" "benzaldehyde, 4-(hexyloxy)-" "4-n-hexyloxybenzaldehyde" "4-hexyloxbenzaldehyde" "p-hexyloxybenzaldehyde" "p-(hexyloxy)benzaldehyde" "benzaldehyde, p-(hexyloxy)-" "p-hexoxybenzaldehyde" "4-n-hexyl-oxybenzaldehyde" );
standardThermochemistry
{
    dHf_298   -142360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100320.0
}
