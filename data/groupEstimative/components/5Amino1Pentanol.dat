/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-amino-1-pentanol  (C5H13NO, CAS 2508-29-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Amino1Pentanol;
formula     C5H13NO;
CAS         2508-29-4;
InChIKey    LQGKDMHENBFVRC-UHFFFAOYSA-N;
MW          103.165;      // g/mol [origin=calculated method=formula-sum]
Tc          653.14;      // K   [origin=predictive method=joback]
Pc          41.677;      // bar [origin=predictive method=joback]
omega       0.9232;      // -   [origin=predictive method=lee-kesler]
Tb          478.71;      // K   [origin=predictive method=joback]
HvapTb      54044.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.125 0.5747 -0.000322 6.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-azanylpentan-1-ol" "5-aminopentan-1-ol" "pentanol, 5-amino-" "5-amino-1-pentanol solution" "5-aminopentanol" "1-pentanol, 5-amino-" "lqgkdmhenbfvrc-uhfffaoysa-" "5-aminopentan-1-ol, 50% aqueous solution" "1-amino-5-hydroxypentane;5-aminopentanol;5-hydroxy-1-pentanamine;5-hydroxypentylamine;pentanolamine;" );
gibbsFormation
{
    dHf_298   -264970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-79150.0
    phase     gas;
}
