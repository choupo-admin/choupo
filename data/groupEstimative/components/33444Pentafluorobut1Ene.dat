/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,4,4,4-pentafluorobut-1-ene  (C4H3F5, CAS 374-27-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33444Pentafluorobut1Ene;
formula     C4H3F5;
CAS         374-27-6;
InChIKey    IZHPSCJEIFFRLN-UHFFFAOYSA-N;
MW          146.058;      // g/mol [origin=calculated method=formula-sum]
Tc          417.47;      // K   [origin=predictive method=joback]
Pc          32.765;      // bar [origin=predictive method=joback]
omega       0.2777;      // -   [origin=predictive method=lee-kesler]
Tb          277.69;      // K   [origin=predictive method=joback]
HvapTb      17151.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.23 0.6744 -0.0006423 2.256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CF3; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,4-pentakis(fluoranyl)but-1-ene" "pentafluorobutene-1" "(perfluoroethyl)ethene" "(perfluoroethyl)ethylene" "3,3,4,4,4-pentafluorobutene-1" );
gibbsFormation
{
    dHf_298   -998510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-897730.0
    phase     gas;
}
