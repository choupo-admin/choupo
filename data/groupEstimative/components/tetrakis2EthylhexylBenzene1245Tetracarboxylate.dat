/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrakis(2-ethylhexyl) benzene-1,2,4,5-tetracarboxylate  (C42H70O8, CAS 3126-80-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrakis2EthylhexylBenzene1245Tetracarboxylate;
formula     C42H70O8;
CAS         3126-80-5;
InChIKey    GNCDUZFXTFAOBE-UHFFFAOYSA-N;
MW          703.014;      // g/mol [origin=calculated method=formula-sum]
Tc          2043.85;      // K   [origin=predictive method=joback]
Pc          4.145;      // bar [origin=predictive method=joback]
omega       -0.3851;      // -   [origin=predictive method=lee-kesler]
Tb          1433.30;      // K   [origin=predictive method=joback]
HvapTb      141424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.61 3.54096 -0.00172548 2.09e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 20; } { group CH; count 4; } { group ACH; count 2; } { group AC; count 4; } { group COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 20; } { group CH; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4,5-benzenetetracarboxylic acid, tetrakis(2-ethylhexyl) ester" "1,2,4,5-benzenetetracarboxylic acid, 1,2,4,5-tetrakis(2-ethylhexyl) ester" "1,2,4,5-benzenetetracarboxylicacid, 1,2,4,5-tetrakis(2-ethylhexyl) ester" );
gibbsFormation
{
    dHf_298   -1998330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1834.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-864960.0
    phase     gas;
}
