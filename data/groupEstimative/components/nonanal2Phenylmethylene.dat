/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonanal, 2-(phenylmethylene)-  (C16H22O, CAS 20175-19-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonanal2Phenylmethylene;
formula     C16H22O;
CAS         20175-19-3;
InChIKey    VXDUTTLHVAAEFQ-UHFFFAOYSA-N;
MW          230.351;      // g/mol [origin=calculated method=formula-sum]
Tc          848.16;      // K   [origin=predictive method=joback]
Pc          19.036;      // bar [origin=predictive method=joback]
omega       0.7672;      // -   [origin=predictive method=lee-kesler]
Tb          645.06;      // K   [origin=predictive method=joback]
HvapTb      60244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.034 1.43932 -0.0009569 2.518e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(phenylmethylidene)nonanal" "2-benzylidenenonanal" "alpha-heptylcinnamaldehyde" "agn-pc-02p2yy" );
gibbsFormation
{
    dHf_298   -115190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     680.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=168400.0
    phase     gas;
}
