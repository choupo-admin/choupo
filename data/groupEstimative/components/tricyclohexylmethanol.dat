/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclohexylmethanol  (C19H34O, CAS 17687-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclohexylmethanol;
formula     C19H34O;
CAS         17687-74-0;
InChIKey    MRGVKQSSSOCONZ-UHFFFAOYSA-N;
MW          278.48;      // g/mol [origin=calculated method=formula-sum]
Tc          1014.77;      // K   [origin=predictive method=joback]
Pc          18.643;      // bar [origin=predictive method=joback]
omega       0.8633;      // -   [origin=predictive method=lee-kesler]
Tb          781.92;      // K   [origin=predictive method=joback]
HvapTb      74558.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-230.38 2.3349 -0.001455 3.254e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 15; } { group CH; count 3; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group CH2_ring; count 15; } { group CH_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexanemethanol, .alpha.,.alpha.-dicyclohexyl-" "tricyclohexyl-methanol" "tricyclohexylmethan-1-ol" "mrgvkqsssoconz-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -433510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     816.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48470.0
}
