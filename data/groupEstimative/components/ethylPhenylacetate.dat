/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl phenylacetate  (C10H12O2, CAS 101-97-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylPhenylacetate;
formula     C10H12O2;
CAS         101-97-3;
InChIKey    DULCUDSUACXJJC-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          723.22;      // K   [origin=predictive method=joback]
Pc          29.473;      // bar [origin=predictive method=joback]
omega       0.5381;      // -   [origin=predictive method=lee-kesler]
Tb          513.30;      // K   [origin=predictive method=joback]
HvapTb      47537.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.698 0.82012 -0.0004568 7.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-phenylacetate" "2-phenylacetic acid ethyl ester" "acetic acid, phenyl-, ethyl ester" "benzeneacetic acid, ethyl ester" "ethyl 2-phenylethanoate" "ethyl benzeneacetate" "ethyl phenacetate" "ethyl α-phenylacetate" "ethyl α-toluate" "phenylacetic acid ethyl ester" "α-toluic acid ethyl ester" "ethyl phenylethanoate" );
standardThermochemistry
{
    dHf_298   -330480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-164640.0
}
