/*--------------------------------*- Choupo -*-----------------------*\
  Component: thujyl alcohol  (C10H18O, CAS 3284-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thujylAlcohol;
formula     C10H18O;
CAS         3284-85-3;
InChIKey    DZVXRFMREAADPP-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          715.25;      // K   [origin=predictive method=joback]
Pc          29.569;      // bar [origin=predictive method=joback]
omega       0.7463;      // -   [origin=predictive method=lee-kesler]
Tb          524.52;      // K   [origin=predictive method=joback]
HvapTb      52202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.19 1.53446 -0.001416 5.573e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 4; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-1-propan-2-yl-bicyclo[3.1.0]hexan-3-ol" ".delta.3-thujanol" "neoisothujyl alcohol" "thujanol" "thujol" "bicyclo[3.1.0]hexan-3-ol, 4-methyl-1-(1-methylethyl)-" "(+)-thujol" "bicyclo[3.1.0]hexan-3-ol, 4-methyl-1-(1-methylethyl)-, (1.alpha.,3.beta.,4.beta.,5.alpha.)-" "bicyclo(3.1.0)hexan-3-ol, 4-methyl-1-(1-methylethyl)-" "isothujol" "bicyclo(3.1.0)hexan-3-ol, 4-methyl-1-(1-methylethyl)-, (1r,3r,4s,5s)-" "bicyclo[3.1.0]hexan-3-ol, 4-methyl-1-(1-methylethyl)-, (1r,3r,4s,5s)-" );
standardThermochemistry
{
    dHf_298   -287080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5350.0
}
