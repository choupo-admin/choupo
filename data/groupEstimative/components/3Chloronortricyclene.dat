/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloronortricyclene  (C7H9Cl, CAS 3509-46-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloronortricyclene;
formula     C7H9Cl;
CAS         3509-46-4;
InChIKey    BUZGNAVALTYIOX-UHFFFAOYSA-N;
MW          128.599;      // g/mol [origin=calculated method=formula-sum]
Tc          601.77;      // K   [origin=predictive method=joback]
Pc          36.598;      // bar [origin=predictive method=joback]
omega       0.3097;      // -   [origin=predictive method=lee-kesler]
Tb          399.53;      // K   [origin=predictive method=joback]
HvapTb      34338.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.19 1.0945 -0.00102 3.824e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 5; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-2,3,4,5,6,7-hexahydro-1h-tricyclo[2.2.1.0^{2,6}]heptane" "3-chlorotricyclo[2.2.1.02,6]heptane" "tricyclo[2.2.1.02,6]heptane, 3-chloro-" );
gibbsFormation
{
    dHf_298   -13510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     66.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=187160.0
    phase     gas;
}
