/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanol, 2-(2-methoxyethoxy)-, 4-aminobenzoate  (C12H17NO4, CAS 49744-35-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanol22Methoxyethoxy4Aminobenzoate;
formula     C12H17NO4;
CAS         49744-35-6;
InChIKey    KRCFNZKIXDOQFX-UHFFFAOYSA-N;
MW          239.271;      // g/mol [origin=calculated method=formula-sum]
Tc          889.57;      // K   [origin=predictive method=joback]
Pc          24.362;      // bar [origin=predictive method=joback]
omega       0.9853;      // -   [origin=predictive method=lee-kesler]
Tb          681.41;      // K   [origin=predictive method=joback]
HvapTb      68112.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.274 0.88612 -0.00031996 -2.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methoxyethoxy)ethyl 4-azanylbenzoate" "ethanol, 2-(2-methoxyethoxy)-, 1-(4-aminobenzoate)" "2-(2-methoxyethoxy)ethyl 4-aminobenzoate" "4-aminobenzoic acid, 2-(2-methoxyethoxy)ethyl ester" );
gibbsFormation
{
    dHf_298   -613880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     636.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-300980.0
    phase     gas;
}
