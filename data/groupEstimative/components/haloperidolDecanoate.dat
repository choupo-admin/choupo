/*--------------------------------*- Choupo -*-----------------------*\
  Component: haloperidol decanoate  (C31H41ClFNO3, CAS 74050-97-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        haloperidolDecanoate;
formula     C31H41ClFNO3;
CAS         74050-97-8;
InChIKey    GUTXTARXLVFHDK-UHFFFAOYSA-N;
MW          530.121;      // g/mol [origin=calculated method=formula-sum]
Tc          1408.30;      // K   [origin=predictive method=joback]
Pc          8.895;      // bar [origin=predictive method=joback]
omega       0.8488;      // -   [origin=predictive method=lee-kesler]
Tb          1148.95;      // K   [origin=predictive method=joback]
HvapTb      109346.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.919 3.15532 -0.00228702 6.8226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group CH2CO; count 1; } { group CH2COO; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 1; } { group Cl; count 1; } { group CdO; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(4-chlorophenyl)-1-[4-(4-fluorophenyl)-4-oxidanylidene-butyl]piperidin-4-yl] decanoate" "haldol decanoate" "haldol decanoas" "kd 16" "4-(4-chlorophenyl)-1-(4-(4-fluorophenyl)-4-oxobutyl)-4-piperidyl decanoate" "decanoic acid, 4-(4-chlorophenyl)-1-(4-(4-fluorophenyl)-4-oxobutyl)-4-piperidinyl ester" "decanoic acid 4-(4-chlorophenyl)-1-[4-(4-fluorophenyl)-4-oxobutyl]-4-piperidinyl ester" "depot haloperidol" "haloperidol depot" "halomonth (tn)" "haloperidol decanoate (jan/usan)" "haloperidol decanoate [usan:ban:jan]" );
standardThermochemistry
{
    dHf_298   -731510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1316.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-88490.0
}
