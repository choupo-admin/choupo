/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3474372  (C36H26, CAS 59766-02-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3474372;
formula     C36H26;
CAS         59766-02-8;
InChIKey    MTAQIUQQZZGSQB-UHFFFAOYSA-N;
MW          458.604;      // g/mol [origin=calculated method=formula-sum]
Tc          1489.88;      // K   [origin=predictive method=joback]
Pc          12.977;      // bar [origin=predictive method=joback]
omega       1.0747;      // -   [origin=predictive method=lee-kesler]
Tb          1204.14;      // K   [origin=predictive method=joback]
HvapTb      112428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-185.828 2.8748 -0.00223988 6.936e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 22; } { group AC; count 10; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 22; } { group dC_ring; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,14-bis(phenylmethyl)naphtho[1,2-b]phenanthrene" "9,10-dibenzyl-1,2,5,6-dibenzanthracene" "dibenz(a,h)anthracene, 7,14-dibenzyl-" "7,14-dibenzylbenzo[k]tetraphene" "7,14-dibenzylnaphtho[1,2-b]phenanthrene" );
gibbsFormation
{
    dHf_298   630150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     772.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=967920.0
    phase     gas;
}
