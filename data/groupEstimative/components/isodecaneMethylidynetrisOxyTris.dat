/*--------------------------------*- Choupo -*-----------------------*\
  Component: isodecane, (methylidynetris(oxy))tris-  (C31H64O3, CAS 27136-79-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isodecaneMethylidynetrisOxyTris;
formula     C31H64O3;
CAS         27136-79-4;
InChIKey    REGOXHBDMWJBSB-UHFFFAOYSA-N;
MW          484.85;      // g/mol [origin=calculated method=formula-sum]
Tc          1212.55;      // K   [origin=predictive method=joback]
Pc          5.634;      // bar [origin=predictive method=joback]
omega       0.3178;      // -   [origin=predictive method=lee-kesler]
Tb          974.38;      // K   [origin=predictive method=joback]
HvapTb      90278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.481 2.78292 -0.0013424 1.913e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 18; } { group CH; count 4; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 21; } { group CH; count 4; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[bis(8-methylnonoxy)methoxy]-8-methyl-nonane" "isodecane, [methylidynetris(oxy)]tris-" "triisodecyl orthoformate" "(methylidynetris(oxy))trisisodecane" "1-[bis(8-methylnonoxy)methoxy]-8-methylnonane" );
standardThermochemistry
{
    dHf_298   -1100950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1359.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114620.0
}
