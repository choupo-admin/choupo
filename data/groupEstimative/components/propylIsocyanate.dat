/*--------------------------------*- Choupo -*-----------------------*\
  Component: propyl isocyanate  (C4H7NO, CAS 110-78-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propylIsocyanate;
formula     C4H7NO;
CAS         110-78-1;
InChIKey    OQURWGJAWSLGQG-UHFFFAOYSA-N;
MW          85.106;      // g/mol [origin=calculated method=formula-sum]
Tc          537.14;      // K   [origin=predictive method=joback]
Pc          42.831;      // bar [origin=predictive method=joback]
omega       0.3793;      // -   [origin=predictive method=lee-kesler]
Tb          357.79;      // K   [origin=predictive method=joback]
HvapTb      34030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCd; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanatopropane" "propane, 1-isocyanato-" "isocyanic acid, propyl ester" "m-propyl isocyanate" "1-propyl isocyanate" "n-propyl isocyanate" "isocyanic acid propyl ester" "propanisocyanate" "1-isocyanato-propane" "oqurwgjawslgqg-uhfffaoysa-" );
