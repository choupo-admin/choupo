/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-7-octadecyne  (C19H36, CAS 35354-38-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl7Octadecyne;
formula     C19H36;
CAS         35354-38-2;
InChIKey    WQMKDHREUPHQQE-UHFFFAOYSA-N;
MW          264.497;      // g/mol [origin=calculated method=formula-sum]
Tc          817.40;      // K   [origin=predictive method=joback]
Pc          12.107;      // bar [origin=predictive method=joback]
omega       0.7420;      // -   [origin=predictive method=lee-kesler]
Tb          642.88;      // K   [origin=predictive method=joback]
HvapTb      59652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.493 1.66496 -0.00092086 1.9338e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 13; } { group CH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 13; } { group CH; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyloctadec-7-yne" "7-octadecyne, 2-methyl-" );
gibbsFormation
{
    dHf_298   -168470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     858.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=309460.0
    phase     gas;
}
