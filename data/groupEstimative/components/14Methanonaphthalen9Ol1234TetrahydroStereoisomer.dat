/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-methanonaphthalen-9-ol, 1,2,3,4-tetrahydro-, stereoisomer  (C11H12O, CAS 1198-20-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Methanonaphthalen9Ol1234TetrahydroStereoisomer;
formula     C11H12O;
CAS         1198-20-5;
InChIKey    HEKIGGFOVMNILV-UHFFFAOYSA-N;
MW          160.216;      // g/mol [origin=calculated method=formula-sum]
Tc          791.37;      // K   [origin=predictive method=joback]
Pc          36.115;      // bar [origin=predictive method=joback]
omega       0.8430;      // -   [origin=predictive method=lee-kesler]
Tb          579.66;      // K   [origin=predictive method=joback]
HvapTb      59042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.85 1.2293 -0.00100056 3.304e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group ACH; count 4; } { group ACCH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-methanonaphthalen-9-ol, 1,2,3,4-tetrahydro-, anti-" "1,2,3,4-tetrahydro-1,4-methanonaphthalen-9-ol" "1,4-methanonaphthalen-9-ol, 1,2,3,4-tetrahydro-" "1,4-methanonaphthalen-9-ol, 1,2,3,4-tetrahydro-, syn-" );
standardThermochemistry
{
    dHf_298   -66120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     279.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133590.0
}
