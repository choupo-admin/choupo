/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-83031  (C15H18O, CAS 72036-52-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG83031;
formula     C15H18O;
CAS         72036-52-3;
InChIKey    VBVILNYBMHFOQS-UHFFFAOYSA-N;
MW          214.308;      // g/mol [origin=calculated method=formula-sum]
Tc          919.45;      // K   [origin=predictive method=joback]
Pc          24.124;      // bar [origin=predictive method=joback]
omega       0.5627;      // -   [origin=predictive method=lee-kesler]
Tb          666.21;      // K   [origin=predictive method=joback]
HvapTb      56401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.44 1.42066 -0.0010462 3.418e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethyl-3-(4-methylphenyl)cyclohex-2-en-1-one" "5,5-dimethyl-3-(4-methylphenyl)cyclohex-2-enone" "5,5-dimethyl-3-p-tolylcyclohex-2-enone" "3-(4-tolyl)-5,5-dimethyl-2-cyclohexenone" "2-cyclohexen-1-one,5,5-dimethyl-3-(4-methylphenyl)-" );
gibbsFormation
{
    dHf_298   -149700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94900.0
    phase     gas;
}
