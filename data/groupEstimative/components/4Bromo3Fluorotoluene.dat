/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-3-fluorotoluene  (C7H6BrF, CAS 452-74-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo3Fluorotoluene;
formula     C7H6BrF;
CAS         452-74-4;
InChIKey    SLFNGVGRINFJLK-UHFFFAOYSA-N;
MW          189.027;      // g/mol [origin=calculated method=formula-sum]
Tc          684.14;      // K   [origin=predictive method=joback]
Pc          40.829;      // bar [origin=predictive method=joback]
omega       0.4203;      // -   [origin=predictive method=lee-kesler]
Tb          461.83;      // K   [origin=predictive method=joback]
HvapTb      40394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.5 0.52092 -0.00034192 8.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group Br; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-fluoranyl-4-methyl-benzene" "1-bromo-2-fluoro-4-methylbenzene" "3-fluoro-4-bromotoluene" "benzene, 1-bromo-2-fluoro-4-methyl-" "3-fluoro-4-bromo-toluene" "4-bromo-3-fluoro-1-methylbenzene" "1-brom-2-fluor-4-methylbenzol" "452-74-4 4-bromo-3-fluorotoluene" "3-fluoro-4-bromo-toluone" "slfngvgrinfjlk-uhfffaoysa-" "wt434" "1-bromo-2-fluoro-4-methyl-benzene" );
gibbsFormation
{
    dHf_298   -144000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-79280.0
    phase     gas;
}
