/*--------------------------------*- Choupo -*-----------------------*\
  Component: racemic-ici 79,939  (C22H29FO6, CAS 40666-04-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        racemicIci79939;
formula     C22H29FO6;
CAS         40666-04-4;
InChIKey    CVJGVCBPOYDYKS-USKRPNENSA-N;
MW          408.466;      // g/mol [origin=calculated method=formula-sum]
Tc          1484.32;      // K   [origin=predictive method=joback]
Pc          15.772;      // bar [origin=predictive method=joback]
omega       1.1189;      // -   [origin=predictive method=lee-kesler]
Tb          1187.51;      // K   [origin=predictive method=joback]
HvapTb      135156.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.365 2.1549 -0.00133836 3.086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 4; } { group CH=CH; count 2; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 2; } { group COOH; count 1; } { group ACF; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group CH; count 1; } { group dCH; count 4; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group OH; count 3; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-7-[(2r)-2-[(e,3r)-4-(4-fluoranylphenoxy)-3-oxidanyl-but-1-enyl]-3,5-bis(oxidanyl)cyclopentyl]hept-5-enoic acid" "ici 79,939" "5-heptenoic acid, 7-(2-(4-(4-fluorophenoxy)-3-hydroxy-1-butenyl)-3,5-dihydroxycyclopentyl)-, (1-alpha-(z),2-beta-(1e,3s*),3-alpha,5-alpha)-" "(z)-7-[(2r)-2-[(e,3r)-4-(4-fluorophenoxy)-3-hydroxybut-1-enyl]-3,5-dihydroxycyclopentyl]hept-5-enoic acid" );
gibbsFormation
{
    dHf_298   -1179020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     948.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-645620.0
    phase     gas;
}
