/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(pentachloroethyl)benzene  (C8H5Cl5, CAS 706-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PentachloroethylBenzene;
formula     C8H5Cl5;
CAS         706-93-4;
InChIKey    AXVLZOYLQOEKAO-UHFFFAOYSA-N;
MW          278.378;      // g/mol [origin=calculated method=formula-sum]
Tc          859.74;      // K   [origin=predictive method=joback]
Pc          30.796;      // bar [origin=predictive method=joback]
omega       0.3859;      // -   [origin=predictive method=lee-kesler]
Tb          590.01;      // K   [origin=predictive method=joback]
HvapTb      55011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.78 0.9705 -0.0008882 2.983e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CCl2; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2,2-pentakis(chloranyl)ethylbenzene" "(1,1,2,2,2-pentachloroethyl)benzene" "1,1,2,2,2-pentachloroethylbenzene" "benzene,1,2,3,4,5-pentachloro-6-ethyl-" );
gibbsFormation
{
    dHf_298   -68120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74920.0
    phase     gas;
}
