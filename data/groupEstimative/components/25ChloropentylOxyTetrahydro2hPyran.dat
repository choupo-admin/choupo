/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[(5-chloropentyl)oxy]tetrahydro-2h-pyran  (C10H19ClO2, CAS 13129-60-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25ChloropentylOxyTetrahydro2hPyran;
formula     C10H19ClO2;
CAS         13129-60-7;
InChIKey    WLHOOFDTKPBKIY-UHFFFAOYSA-N;
MW          206.71;      // g/mol [origin=calculated method=formula-sum]
Tc          734.97;      // K   [origin=predictive method=joback]
Pc          24.124;      // bar [origin=predictive method=joback]
omega       0.5882;      // -   [origin=predictive method=lee-kesler]
Tb          534.75;      // K   [origin=predictive method=joback]
HvapTb      49588.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.095 1.0165 -0.0004967 6.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Cl; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(5-chloranylpentoxy)oxane" "2h-pyran, 2-((5-chloropentyl)oxy)tetrahydro-" "2h-pyran, 2-[(5-chloropentyl)oxy]tetrahydro-" "2-(5-chloropentoxy)oxane" "1-[2-tertahydropyranyloxy]-5-chloropentane" );
gibbsFormation
{
    dHf_298   -475370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-145280.0
    phase     gas;
}
