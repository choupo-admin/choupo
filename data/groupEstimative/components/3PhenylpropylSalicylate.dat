/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylpropyl salicylate  (C16H16O3, CAS 24781-13-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3PhenylpropylSalicylate;
formula     C16H16O3;
CAS         24781-13-3;
InChIKey    GMHNYYKDPGWAJR-UHFFFAOYSA-N;
MW          256.301;      // g/mol [origin=calculated method=formula-sum]
Tc          996.38;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.9777;      // -   [origin=predictive method=lee-kesler]
Tb          757.88;      // K   [origin=predictive method=joback]
HvapTb      76183.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.977 1.4658 -0.00107076 3.062e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylpropyl 2-oxidanylbenzoate" "3-phenylpropylsalicylate" "propanol, 3-phenyl-, salicylate" "benzoic acid, 2-hydroxy-, 3-phenylpropyl ester" "salicylic acid, 3-phenylpropyl ester" "s 22" "3-phenylpropyl 2-hydroxybenzoate" "2-hydroxy-benzoic acid 3-phenylpropyl ester" );
gibbsFormation
{
    dHf_298   -395100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     644.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-156330.0
    phase     gas;
}
