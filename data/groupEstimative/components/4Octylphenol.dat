/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-octylphenol  (C14H22O, CAS 1806-26-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Octylphenol;
formula     C14H22O;
CAS         1806-26-4;
InChIKey    NTDQQZYCCIDJRK-UHFFFAOYSA-N;
MW          206.329;      // g/mol [origin=calculated method=formula-sum]
Tc          831.91;      // K   [origin=predictive method=joback]
Pc          23.070;      // bar [origin=predictive method=joback]
omega       0.8152;      // -   [origin=predictive method=lee-kesler]
Tb          627.22;      // K   [origin=predictive method=joback]
HvapTb      62048.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.663 1.40952 -0.00102536 3.14e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 4-octyl-" "p-octylphenol" "4-n-octylphenol" "phenol, p-octyl-" "para-octylphenol" "1-(p-hydroxyphenyl)octane" "phenol, octenylated" "4-octyl-phenol" "p-(n-octyl)phenol" "58288-41-8 (potassium)" "41157-62-4 (barium)" "78899-79-3 (hydrochloride)" );
gibbsFormation
{
    dHf_298   -273070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     621.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24790.0
    phase     gas;
}
