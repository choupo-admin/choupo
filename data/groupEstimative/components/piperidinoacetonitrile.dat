/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperidinoacetonitrile  (C7H12N2, CAS 3010-03-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperidinoacetonitrile;
formula     C7H12N2;
CAS         3010-03-5;
InChIKey    CLVBVRODHJFTGF-UHFFFAOYSA-N;
MW          124.187;      // g/mol [origin=calculated method=formula-sum]
Tc          709.77;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       0.5034;      // -   [origin=predictive method=lee-kesler]
Tb          494.23;      // K   [origin=predictive method=joback]
HvapTb      44263.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.589 0.8857 -0.0006214 1.709e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 5; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-piperidin-1-ylethanenitrile" "piperidin-1-ylacetonitrile" "1-piperidineacetonitrile" "piperidoacetonitrile" "1-cyanomethylpiperidine" "n-piperidinoacetonitrile" "n-cyanomethylpiperidine" "1-piperidinoacetonitrile" "piperidine-1-acetonitrile" "2-piperidin-1-ylacetonitrile" "2-piperidylethanenitrile" "piperidineacetonitrile" );
gibbsFormation
{
    dHf_298   125420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=296280.0
    phase     gas;
}
