/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dichlorophenetole  (C8H8Cl2O, CAS 5392-86-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dichlorophenetole;
formula     C8H8Cl2O;
CAS         5392-86-9;
InChIKey    AWPAAILWWGKSIF-UHFFFAOYSA-N;
MW          191.051;      // g/mol [origin=calculated method=formula-sum]
Tc          739.70;      // K   [origin=predictive method=joback]
Pc          31.704;      // bar [origin=predictive method=joback]
omega       0.4830;      // -   [origin=predictive method=lee-kesler]
Tb          516.56;      // K   [origin=predictive method=joback]
HvapTb      48182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.591 0.51632 -0.00023832 2.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CH2O; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(chloranyl)-1-ethoxy-benzene" "2,4-dichloro-1-ethoxybenzene" "phenetole,4-dichloro-" "benzene,4-dichloro-1-ethoxy-" "ethyl 2,4-dichlorophenyl ether" "benzene, 2,4-dichloro1-ethoxy" "benzene,2,4-dichloro-1-ethoxy-" "benzene, 2,4-dichloro-1-ethoxy-" );
standardThermochemistry
{
    dHf_298   -158560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19230.0
}
