/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethylene glycol diacrylate  (C12H18O6, CAS 1680-21-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triethyleneGlycolDiacrylate;
formula     C12H18O6;
CAS         1680-21-3;
InChIKey    INQDDHNZXOAFFD-UHFFFAOYSA-N;
MW          258.27;      // g/mol [origin=calculated method=formula-sum]
Tc          805.78;      // K   [origin=predictive method=joback]
Pc          18.740;      // bar [origin=predictive method=joback]
omega       0.9848;      // -   [origin=predictive method=lee-kesler]
Tb          628.80;      // K   [origin=predictive method=joback]
HvapTb      60600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (87.816 0.8678 -0.0002636 -5.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2=CH; count 2; } { group CH2O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH2; count 2; } { group dCH; count 2; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-prop-2-enoyloxyethoxy)ethoxy]ethyl prop-2-enoate" "acrylic acid, diester with triethylene glycol" "1,2-ethanediylbis(oxy-2,1-ethanediyl) diacrylate" "2-propenoic acid, 1,2-ethanediylbis(oxy-2,1-ethanediyl) ester" "2-propenoic acid, 1,1'-(1,2-ethanediylbis(oxy-2,1-ethanediyl)) ester" "2-propenoic acid, 1,1'-[1,2-ethanediylbis(oxy-2,1-ethanediyl)] ester" "triethyleneglycol diacrylate" "ethane-1,2-diylbis(oxyethane-2,1-diyl) bisprop-2-enoate" "2-{2-[2-(prop-2-enoyloxy)ethoxy]ethoxy}ethyl prop-2-enoate" "2-propenoic acid 2-[2-[2-(1-oxoprop-2-enoxy)ethoxy]ethoxy]ethyl ester" );
gibbsFormation
{
    dHf_298   -939150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     739.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-604900.0
    phase     gas;
}
