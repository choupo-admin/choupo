/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclononasiloxane, octadecamethyl-  (C18H54O9Si9, CAS 556-71-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C18H54O9Si9 (delta Si+9; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        cyclononasiloxaneOctadecamethyl;
formula     C18H54O9Si9;
CAS         556-71-8;
InChIKey    ISXOGOLHEGHGQF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          667.386;      // g/mol [origin=calculated method=formula-sum]
Tc          1133.68;      // K   [origin=predictive method=joback]
Pc          6.947;      // bar [origin=predictive method=joback]
omega       0.4273;      // -   [origin=predictive method=lee-kesler]
Tb          903.62;      // K   [origin=predictive method=joback]
HvapTb      100152.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (422.87 -0.04884 0.0029057 -1.882e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 18; } { group SiO; count 9; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 18; } { group O_ring; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4,6,6,8,8,10,10,12,12,14,14,16,16,18,18-octadecamethyl-1,3,5,7,9,11,13,15,17-nonaoxa-2,4,6,8,10,12,14,16,18-nonasilacyclooctadecane" "octadeamethyl-cyclononasiloxane" "octadecamethylcyclononasiloxane" );
standardThermochemistry
{
    dHf_298   -2551250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1605.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1621380.0
}
