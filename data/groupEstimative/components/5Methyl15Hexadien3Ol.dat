/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-1,5-hexadien-3-ol  (C7H12O, CAS 17123-61-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl15Hexadien3Ol;
formula     C7H12O;
CAS         17123-61-4;
InChIKey    AVMGRIXBDWUWFN-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          618.05;      // K   [origin=predictive method=joback]
Pc          34.561;      // bar [origin=predictive method=joback]
omega       0.6969;      // -   [origin=predictive method=lee-kesler]
Tb          444.74;      // K   [origin=predictive method=joback]
HvapTb      46207.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.539 0.66862 -0.0004387 1.18e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylhexa-1,5-dien-3-ol" "1,5-hexadien-3-ol,5-methyl-" );
standardThermochemistry
{
    dHf_298   -104250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35930.0
}
