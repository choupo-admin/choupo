/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanoic acid, 3-(methylthio)-  (C5H10O2S, CAS 16630-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanoicAcid3Methylthio;
formula     C5H10O2S;
CAS         16630-65-2;
InChIKey    QWAKSOMWGWIYQP-UHFFFAOYSA-N;
MW          134.193;      // g/mol [origin=calculated method=formula-sum]
Tc          744.27;      // K   [origin=predictive method=joback]
Pc          39.856;      // bar [origin=predictive method=joback]
omega       0.6722;      // -   [origin=predictive method=lee-kesler]
Tb          527.85;      // K   [origin=predictive method=joback]
HvapTb      50317.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.861 0.52993 -0.0002838 4.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group COOH; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylsulfanylbutanoic acid" "3-(methylsulfanyl)butanoic acid" "3-(methylthio)butyric acid" "agn-pc-00nm3p" );
gibbsFormation
{
    dHf_298   -460210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-322010.0
    phase     gas;
}
