/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl dichloroacetate  (C4H4Cl2O2, CAS 7561-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylDichloroacetate;
formula     C4H4Cl2O2;
CAS         7561-04-8;
InChIKey    ZBCLTORTGNOIGM-UHFFFAOYSA-N;
MW          154.974;      // g/mol [origin=calculated method=formula-sum]
Tc          620.28;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.4123;      // -   [origin=predictive method=lee-kesler]
Tb          420.44;      // K   [origin=predictive method=joback]
HvapTb      39617.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.77 0.3285 -0.0001661 1.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CHCl2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl 2,2-bis(chloranyl)ethanoate" "ethenyl 2,2-dichloroacetate" "vinyl dichloro acetate" "dichloroacetic acid vinyl ester" );
standardThermochemistry
{
    dHf_298   -354500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-266030.0
}
