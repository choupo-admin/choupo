/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethyl-1-phenylsilatrane  (C14H21NO3Si, CAS 2097-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H21NO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        37Dimethyl1Phenylsilatrane;
formula     C14H21NO3Si;
CAS         2097-20-3;
InChIKey    HOBATWHQQHWNCD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          279.411;      // g/mol [origin=calculated method=formula-sum]
Tc          909.89;      // K   [origin=predictive method=joback]
Pc          23.912;      // bar [origin=predictive method=joback]
omega       0.6373;      // -   [origin=predictive method=lee-kesler]
Tb          667.58;      // K   [origin=predictive method=joback]
HvapTb      65243.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.5 1.43664 -0.0007263 8.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group CH-O; count 2; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyl-5-phenyl-4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecane" "1-phenyl,3,10-dimethylsilatrane, a" "1-phenyl,3,10-dimethylsilatrane, b,c" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane, 3,7-dimethyl-1-phenyl-" "2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane, 3,7-dimethyl-1-phenyl-" "3,7-dimethyl-1-phenyl-2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane" "3,7-dimethyl-1-phenyl-2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane" );
gibbsFormation
{
    dHf_298   -408730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12270.0
    phase     gas;
}
