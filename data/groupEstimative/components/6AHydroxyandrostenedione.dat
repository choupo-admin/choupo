/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6|a-hydroxyandrostenedione  (C19H26O3, CAS 63-00-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6AHydroxyandrostenedione;
formula     C19H26O3;
CAS         63-00-3;
InChIKey    WVAMBAWFDOYFOD-DQXCSHPPSA-N;
MW          302.414;      // g/mol [origin=calculated method=formula-sum]
Tc          1151.40;      // K   [origin=predictive method=joback]
Pc          20.850;      // bar [origin=predictive method=joback]
omega       1.1450;      // -   [origin=predictive method=lee-kesler]
Tb          905.73;      // K   [origin=predictive method=joback]
HvapTb      81607.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-228.83 2.47714 -0.00207564 7.653e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6r,8r,9s,10r,13s,14s)-10,13-dimethyl-6-oxidanyl-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthrene-3,17-dione" "6" "a-hydroxy androstenedione" "androst-4-en-6" "a-ol-3,17-dione" "6" "a-hydroxy-4-androstene-3,17-dione" "6" "a-hydroxyandrost-4-ene-3,17-dione" "6-hydroxy-4-androstene-3,17-dione" "(6" "a)-6-hydroxyandrost-4-ene-3,17-dione" "6beta-hydroxy-4-androstene-3,17-dione" "androst-4-ene-3,17-dione, 6-hydroxy-, (6beta)-" "(6r,8r,9s,10r,13s,14s)-6-hydroxy-10,13-dimethyl-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthrene-3,17-dione" );
standardThermochemistry
{
    dHf_298   -566610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96470.0
}
