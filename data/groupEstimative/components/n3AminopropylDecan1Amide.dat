/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(3-aminopropyl)decan-1-amide  (C13H28N2O, CAS 73772-40-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3AminopropylDecan1Amide;
formula     C13H28N2O;
CAS         73772-40-4;
InChIKey    PLJISUVFPNUOBK-UHFFFAOYSA-N;
MW          228.38;      // g/mol [origin=calculated method=formula-sum]
Tc          854.46;      // K   [origin=predictive method=joback]
Pc          18.373;      // bar [origin=predictive method=joback]
omega       1.0745;      // -   [origin=predictive method=lee-kesler]
Tb          673.61;      // K   [origin=predictive method=joback]
HvapTb      68355.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.711 1.34892 -0.0007567 1.5596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH2NH2; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(3-azanylpropyl)decanamide" "decanamide, n-(3-aminopropyl)-" "decanoic acid, 1,3-propanediamine monoamide" "n-(3-aminopropyl)decanamide" "decanamide,n-(3-aminopropyl)-" );
standardThermochemistry
{
    dHf_298   -336970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     781.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85500.0
}
