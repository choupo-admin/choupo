/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-hexanediamine, n,n,n',n'-tetrapropyl-  (C18H40N2, CAS 27090-62-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16HexanediamineNNNNTetrapropyl;
formula     C18H40N2;
CAS         27090-62-6;
InChIKey    OAFOHGONKIXDDE-UHFFFAOYSA-N;
MW          284.532;      // g/mol [origin=calculated method=formula-sum]
Tc          794.90;      // K   [origin=predictive method=joback]
Pc          11.491;      // bar [origin=predictive method=joback]
omega       0.8687;      // -   [origin=predictive method=lee-kesler]
Tb          636.32;      // K   [origin=predictive method=joback]
HvapTb      59748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.856 1.96168 -0.0011806 2.778e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 14; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,n',n'-tetrapropylhexane-1,6-diamine" "1,6-hexanediamine, n1,n1,n6,n6-tetrapropyl-" );
standardThermochemistry
{
    dHf_298   -279790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     889.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=322240.0
}
