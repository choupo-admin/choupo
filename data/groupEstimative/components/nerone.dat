/*--------------------------------*- Choupo -*-----------------------*\
  Component: nerone  (C13H22O, CAS 31375-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nerone;
formula     C13H22O;
CAS         31375-17-4;
InChIKey    DZSVIVLGBJKQAP-UHFFFAOYSA-N;
MW          194.318;      // g/mol [origin=calculated method=formula-sum]
Tc          774.75;      // K   [origin=predictive method=joback]
Pc          20.624;      // bar [origin=predictive method=joback]
omega       0.5708;      // -   [origin=predictive method=lee-kesler]
Tb          569.49;      // K   [origin=predictive method=joback]
HvapTb      51964.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.839 1.19688 -0.00061374 9.466e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 3; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methyl-5-propan-2-yl-cyclohex-2-en-1-yl)propan-1-one" "2-propionyl-6-menthene" "menthenyl ketone" "1-1-p-menthen-6-yl-1-propanone" "1-propanone, 1-p-menth-6-en-2-yl-" "1-(p-menth-1-en-6-yl)propan-1-one" "1-(p-menthen-6-yl)-1-propanone" "1-(p-menthen-6(2)-yl)-1-propanone" "1-propanone, 1-[2-methyl-5-(1-methylethyl)-2-cyclohexen-1-yl]-" "1-(5-isopropyl-2-methylcyclohex-2-en-1-yl)propan-1-one" "1-propanone, 1-(2-methyl-5-(1-methylethyl)-2-cyclohexen-1-yl)-" "1-(5-isopropyl-2-methyl-cyclohex-2-enyl)-propan-1-one" );
gibbsFormation
{
    dHf_298   -349220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-35710.0
    phase     gas;
}
