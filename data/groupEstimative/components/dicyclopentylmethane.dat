/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicyclopentylmethane  (C11H20, CAS 2619-34-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicyclopentylmethane;
formula     C11H20;
CAS         2619-34-3;
InChIKey    LXDNTYWNYRNHSB-UHFFFAOYSA-N;
MW          152.281;      // g/mol [origin=calculated method=formula-sum]
Tc          700.57;      // K   [origin=predictive method=joback]
Pc          27.297;      // bar [origin=predictive method=joback]
omega       0.3472;      // -   [origin=predictive method=lee-kesler]
Tb          481.84;      // K   [origin=predictive method=joback]
HvapTb      40594.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.079 1.3122 -0.0008294 1.987e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentylmethylcyclopentane" "methane, dicyclopentyl-(6ci,7ci,8ci)" );
gibbsFormation
{
    dHf_298   -149410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114840.0
    phase     gas;
}
