/*--------------------------------*- Choupo -*-----------------------*\
  Component: (chloromethyl)dimethylisopropoxysilane  (C6H15ClOSi, CAS 18171-11-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H15ClOSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        chloromethylDimethylisopropoxysilane;
formula     C6H15ClOSi;
CAS         18171-11-4;
InChIKey    KOTFCAKXPLOYLN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          166.72;      // g/mol [origin=calculated method=formula-sum]
Tc          580.85;      // K   [origin=predictive method=joback]
Pc          26.031;      // bar [origin=predictive method=joback]
omega       0.3083;      // -   [origin=predictive method=lee-kesler]
Tb          397.69;      // K   [origin=predictive method=joback]
HvapTb      35651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.961 0.31718 0.0001996 -2.033e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH-O; count 1; } { group CH2Cl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl-dimethyl-propan-2-yloxy-silane" "2-dimethyl(chloromethyl)silyloxypropane" "chloromethyldimethylisopropoxysilane" "(chloromethyl)isopropoxydimethylsilane" "(chloromethyl)-isopropoxy-dimethylsilane" "chloromethyl-dimethyl-propan-2-yloxysilane" );
standardThermochemistry
{
    dHf_298   -432030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-224490.0
}
