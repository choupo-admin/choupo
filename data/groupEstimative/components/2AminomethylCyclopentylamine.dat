/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(aminomethyl)cyclopentylamine  (C6H14N2, CAS 21544-02-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AminomethylCyclopentylamine;
formula     C6H14N2;
CAS         21544-02-5;
InChIKey    SRGQQZYVZFJYHJ-UHFFFAOYSA-N;
MW          114.192;      // g/mol [origin=calculated method=formula-sum]
Tc          717.19;      // K   [origin=predictive method=joback]
Pc          42.552;      // bar [origin=predictive method=joback]
omega       0.5195;      // -   [origin=predictive method=lee-kesler]
Tb          492.55;      // K   [origin=predictive method=joback]
HvapTb      50180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.129 0.8028 -0.0004614 9.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH2NH2; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(aminomethyl)cyclopentan-1-amine" "cyclopentanemethanamine, 2-amino-" "2-aminocyclopentanemethylamine" "cyclopentanemethylamine, 2-amino-" "cyclopentylamine, 2-(aminomethyl)-" "1-(aminomethyl)-2-aminocyclopentane" "1-amino-2-(aminomethyl)cyclopentane" "cyclopentanemethanamine,2-amino-" "cyclopentanemethylamine, 2-amino- (8ci)" );
gibbsFormation
{
    dHf_298   -59450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161380.0
    phase     gas;
}
