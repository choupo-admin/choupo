/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-hexanedithiol  (C6H14S2, CAS 1191-43-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Hexanedithiol;
formula     C6H14S2;
CAS         1191-43-1;
InChIKey    SRZXCOWFGPICGA-UHFFFAOYSA-N;
MW          150.298;      // g/mol [origin=calculated method=formula-sum]
Tc          675.22;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       0.4408;      // -   [origin=predictive method=lee-kesler]
Tb          462.60;      // K   [origin=predictive method=joback]
HvapTb      42424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.216 0.6284 -0.0003474 7.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2SH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group SH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexane-1,6-dithiol" "1,6-dimercaptohexane" "hexamethylene dimercaptan" "usaf uctl-72" "1,6-hexanedimercaptan" "1,6-hexamethylenedithiol" "srzxcowfgpicga-uhfffaoysa-" "k905" );
gibbsFormation
{
    dHf_298   -90210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58420.0
    phase     gas;
}
