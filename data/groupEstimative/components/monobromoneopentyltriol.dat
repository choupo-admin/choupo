/*--------------------------------*- Choupo -*-----------------------*\
  Component: monobromoneopentyltriol  (C5H11BrO3, CAS 19184-65-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        monobromoneopentyltriol;
formula     C5H11BrO3;
CAS         19184-65-7;
InChIKey    MMHHBAUIJVTLFZ-UHFFFAOYSA-N;
MW          199.044;      // g/mol [origin=calculated method=formula-sum]
Tc          827.48;      // K   [origin=predictive method=joback]
Pc          56.194;      // bar [origin=predictive method=joback]
omega       1.9357;      // -   [origin=predictive method=lee-kesler]
Tb          653.47;      // K   [origin=predictive method=joback]
HvapTb      81900.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.066 0.7448 -0.0005826 1.837e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group OH; count 3; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group C; count 1; } { group Br; count 1; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(bromomethyl)-2-(hydroxymethyl)propane-1,3-diol" "tris(hydroxymethyl)(bromomethyl)methane" "1,3-propanediol, 2-(bromomethyl)-2-(hydroxymethyl)-" "2-(bromomethyl)-2-(hydroxymethyl)-1,3-propanediol" "1, 2-(bromomethyl)-2-(hydroxymethyl)-" "2,2-bis(hydroxymethyl)-3-bromopropan-1-ol" "1,3-propanediol,2-(bromomethyl)-2-(hydroxymethyl)-" "2-(bromomethyl)-2-(hydroxymethyl)-propane-1,3-diol" );
gibbsFormation
{
    dHf_298   -585640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-402080.0
    phase     gas;
}
