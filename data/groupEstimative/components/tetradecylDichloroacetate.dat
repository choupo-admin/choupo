/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecyl dichloroacetate  (C16H30Cl2O2, CAS 83005-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecylDichloroacetate;
formula     C16H30Cl2O2;
CAS         83005-02-1;
InChIKey    JFGNOMDHPRPBJP-UHFFFAOYSA-N;
MW          325.314;      // g/mol [origin=calculated method=formula-sum]
Tc          875.11;      // K   [origin=predictive method=joback]
Pc          12.620;      // bar [origin=predictive method=joback]
omega       0.9119;      // -   [origin=predictive method=lee-kesler]
Tb          698.32;      // K   [origin=predictive method=joback]
HvapTb      66999.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.853 1.48852 -0.000796 1.396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CHCl2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecyl 2,2-bis(chloranyl)ethanoate" "dichloroacetic acid, tetradecyl ester" "tetradecyl 2,2-dichloroacetate" "acetic acid, dichloro-, tetradecyl ester" );
gibbsFormation
{
    dHf_298   -727610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     887.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-252830.0
    phase     gas;
}
