/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxamide  (C2H4N2O2, CAS 471-46-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxamide;
formula     C2H4N2O2;
CAS         471-46-5;
InChIKey    YIKSCQDJHCMVMK-UHFFFAOYSA-N;
MW          88.066;      // g/mol [origin=calculated method=formula-sum]
Tc          723.32;      // K   [origin=predictive method=joback]
Pc          73.051;      // bar [origin=predictive method=joback]
omega       0.7541;      // -   [origin=predictive method=lee-kesler]
Tb          498.16;      // K   [origin=predictive method=joback]
HvapTb      54820.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.77 0.2616 -0.0001344 1.652e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CONH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CdO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanediamide" "oxalamide" "oxalic acid diamide" "oxamimidic acid" "diaminoglyoxal" "oxamid" "formimidic acid, 1-carbamoyl-" "amid kyseliny stavelove" "1-carbamoylformimidic acid" "p554" );
gibbsFormation
{
    dHf_298   -242190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-158980.0
    phase     gas;
}
