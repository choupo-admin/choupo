/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(2-isocyanatopropan-2-yl)benzene;2-(2-hydroxyethyloxy)ethanol;oxepan-2-one  (C24H36N2O7, CAS 138519-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Bis2Isocyanatopropan2YlBenzene22HydroxyethyloxyEthanolOxep;
formula     C24H36N2O7;
CAS         138519-56-9;
InChIKey    MFMGUCOAHKUDHI-UHFFFAOYSA-N;
MW          464.559;      // g/mol [origin=calculated method=formula-sum]
Tc          1472.42;      // K   [origin=predictive method=joback]
Pc          12.655;      // bar [origin=predictive method=joback]
omega       1.1027;      // -   [origin=predictive method=lee-kesler]
Tb          1195.01;      // K   [origin=predictive method=joback]
HvapTb      132757.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 1; } { group CH2COO; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 2; } { group dCd; count 2; } { group CH2_ring; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group O; count 1; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxepanone, polymer with 1,3-bis(1-isocyanato-1-methylethyl)benzene and 2,2'-oxybis(ethanol)" );
