/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tetralone  (C10H10O, CAS 530-93-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Tetralone;
formula     C10H10O;
CAS         530-93-8;
InChIKey    KCKZIWSINLBROE-UHFFFAOYSA-N;
MW          146.189;      // g/mol [origin=calculated method=formula-sum]
Tc          793.22;      // K   [origin=predictive method=joback]
Pc          37.226;      // bar [origin=predictive method=joback]
omega       0.4548;      // -   [origin=predictive method=lee-kesler]
Tb          543.56;      // K   [origin=predictive method=joback]
HvapTb      45433.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.68 0.8149 -0.00046956 9.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dihydro-1h-naphthalen-2-one" "beta-tetralone" ".beta.-tetralone" "2(1h)-naphthalenone, 3,4-dihydro-" "b-tetralone" "3,4-dihydro-2(1h)-naphthalenone" "3,4-dihydro-2-oxonaphthalene" "3,4-dihydronaphthalen-2(1h)-one" "1,2,3,4-tetrahydro-2-naphthalenone" "dihydro-naphthalenone, 4e" "3,4-dihydro-2-naphthol" "1,3,4-trihydronaphthalen-2-one" );
gibbsFormation
{
    dHf_298   -75390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     326.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69870.0
    phase     gas;
}
