/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 5336  (C5H4Cl2O3, CAS 125974-08-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris5336;
formula     C5H4Cl2O3;
CAS         125974-08-5;
InChIKey    WDEQLMYIIXBHTJ-UHFFFAOYSA-N;
MW          182.984;      // g/mol [origin=calculated method=formula-sum]
Tc          751.55;      // K   [origin=predictive method=joback]
Pc          42.220;      // bar [origin=predictive method=joback]
omega       0.9926;      // -   [origin=predictive method=lee-kesler]
Tb          555.12;      // K   [origin=predictive method=joback]
HvapTb      61109.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.961 0.4475 -0.0002982 7.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group OH; count 1; } { group CH2Cl; count 1; } { group Cl_C=C_; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH_ring; count 1; } { group dC_ring; count 2; } { group Cl; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-3-(chloromethyl)-2-oxidanyl-2h-furan-5-one" "2(5h)-furanone, 3-chloro-4-(chloromethyl)-5-hydroxy-" "2(5h)-furanone,3-chloro-4-(chloromethyl)-5-hydroxy-" "wdeqlmyiixbhtj-uhfffaoysa-" "4-chloro-3-(chloromethyl)-2-hydroxy-2h-furan-5-one" );
standardThermochemistry
{
    dHf_298   -539880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-408380.0
}
