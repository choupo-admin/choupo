/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(4-pyridyl)ethane  (C12H12N2, CAS 4916-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Bis4PyridylEthane;
formula     C12H12N2;
CAS         4916-57-8;
InChIKey    DQRKTVIJNCVZAX-UHFFFAOYSA-N;
MW          184.242;      // g/mol [origin=calculated method=formula-sum]
Tc          899.85;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       0.5744;      // -   [origin=predictive method=lee-kesler]
Tb          634.92;      // K   [origin=predictive method=joback]
HvapTb      59278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.708 1.05352 -0.00070992 1.862e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C5H4N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 2; } { group Nd_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-pyridin-4-ylethyl)pyridine" "4,4'-ethylenedipyridine" "4,4'-ethane-1,2-diyldipyridine" "1,2-di(4-pyridyl)ethane" "pyridine, 4,4'-(1,2-ethanediyl)bis-" "4-(2-(4-pyridyl)ethyl)pyridine" "1,2-di(pyridin-4-yl)ethane" "4-[2-(pyridin-4-yl)ethyl]pyridine" "pyridine,4'-(1,2-ethanediyl)bis-" );
gibbsFormation
{
    dHf_298   247630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=429080.0
    phase     gas;
}
