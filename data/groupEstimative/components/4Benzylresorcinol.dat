/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-benzylresorcinol  (C13H12O2, CAS 2284-30-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Benzylresorcinol;
formula     C13H12O2;
CAS         2284-30-2;
InChIKey    QVFIWTNWKHFVEH-UHFFFAOYSA-N;
MW          200.237;      // g/mol [origin=calculated method=formula-sum]
Tc          973.42;      // K   [origin=predictive method=joback]
Pc          44.091;      // bar [origin=predictive method=joback]
omega       0.9327;      // -   [origin=predictive method=lee-kesler]
Tb          711.64;      // K   [origin=predictive method=joback]
HvapTb      75112.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.579 1.3902 -0.00125852 4.607e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(phenylmethyl)benzene-1,3-diol" "resorcinol, 4-benzyl-" "1,3-benzenediol, 4-(phenylmethyl)-" "4-benzyl resorcinol" "4-benzylbenzene-1,3-diol" "qvfiwtnwkhfveh-uhfffaoysa-" "1,3-benzenediol,4-(phenylmethyl)-" "cresorcinol,a-phenyl- (5ci); resorcinol,4-benzyl- (6ci,7ci,8ci); 4-benzyl-1,3-benzenediol; 4-benzylresorcinol;p-benzylresorcinol" );
gibbsFormation
{
    dHf_298   -193210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-25840.0
    phase     gas;
}
