/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-nonadienenitrile, 3,7,8-trimethyl-  (C12H19N, CAS 67952-54-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Nonadienenitrile378Trimethyl;
formula     C12H19N;
CAS         67952-54-9;
InChIKey    HBSCQFFTLCILMW-UHFFFAOYSA-N;
MW          177.291;      // g/mol [origin=calculated method=formula-sum]
Tc          786.34;      // K   [origin=predictive method=joback]
Pc          19.304;      // bar [origin=predictive method=joback]
omega       0.6041;      // -   [origin=predictive method=lee-kesler]
Tb          584.20;      // K   [origin=predictive method=joback]
HvapTb      52940.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.457 1.11838 -0.0007725 2.255e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH=C; count 1; } { group CH2CN; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group dCH; count 1; } { group dC; count 3; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7,8-trimethylnona-3,7-dienenitrile" );
standardThermochemistry
{
    dHf_298   78940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=318130.0
}
