/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclamen aldehyde diethyl acetal  (C17H28O2, CAS 7149-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclamenAldehydeDiethylAcetal;
formula     C17H28O2;
CAS         7149-24-8;
InChIKey    YZGBDMRJUNSBTG-UHFFFAOYSA-N;
MW          264.409;      // g/mol [origin=calculated method=formula-sum]
Tc          859.50;      // K   [origin=predictive method=joback]
Pc          15.451;      // bar [origin=predictive method=joback]
omega       0.7568;      // -   [origin=predictive method=lee-kesler]
Tb          663.74;      // K   [origin=predictive method=joback]
HvapTb      60030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.783 1.3718 -0.00065276 8.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH; count 2; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3,3-diethoxy-2-methyl-propyl)-4-propan-2-yl-benzene" "1-(3,3-diethoxy-2-methylpropyl)-4-(isopropyl)benzene" "benzene, 1-(3,3-diethoxy-2-methylpropyl)-4-(1-methylethyl)-" "alpha-methyl-p-isopropyl hydrocinnamic aldehyde diethyl acetal" "hydrocinnamaldehyde, p-isopropyl-alpha-methyl-, diethyl acetal" "1-(3,3-diethoxy-2-methylpropyl)-4-propan-2-ylbenzene" "benzene,3-diethoxy-2-methylpropyl)-4-(1-methylethyl)-" ".alpha.-methyl-p-isopropyl hydrocinnamic aldehyde diethyl acetal" );
standardThermochemistry
{
    dHf_298   -449430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     699.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-22280.0
}
