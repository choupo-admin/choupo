/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-bromo-4-fluorophenyl)-1,3-dioxolane  (C9H8BrFO2, CAS 77771-04-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Bromo4Fluorophenyl13Dioxolane;
formula     C9H8BrFO2;
CAS         77771-04-1;
InChIKey    OATOZCSPTSMOIY-UHFFFAOYSA-N;
MW          247.063;      // g/mol [origin=calculated method=formula-sum]
Tc          821.59;      // K   [origin=predictive method=joback]
Pc          39.308;      // bar [origin=predictive method=joback]
omega       0.6052;      // -   [origin=predictive method=lee-kesler]
Tb          576.77;      // K   [origin=predictive method=joback]
HvapTb      54123.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.16 0.8366 -0.00055032 1.334e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 1; } { group FCH2O; count 2; } { group Br; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Br; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-bromanyl-4-fluoranyl-phenyl)-1,3-dioxolane" "1,3-dioxolane, 2-(3-bromo-4-fluorophenyl)-" );
gibbsFormation
{
    dHf_298   -388800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     317.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-198130.0
    phase     gas;
}
