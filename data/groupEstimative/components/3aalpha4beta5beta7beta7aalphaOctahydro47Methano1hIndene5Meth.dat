/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3aalpha,4beta,5beta,7beta,7aalpha)-octahydro-4,7-methano-1h-indene-5-methanol  (C11H18O, CAS 145374-29-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3aalpha4beta5beta7beta7aalphaOctahydro47Methano1hIndene5Meth;
formula     C11H18O;
CAS         145374-29-4;
InChIKey    HSPRVWPULGKMRC-ORMBPQIASA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          755.65;      // K   [origin=predictive method=joback]
Pc          29.763;      // bar [origin=predictive method=joback]
omega       0.8082;      // -   [origin=predictive method=lee-kesler]
Tb          558.61;      // K   [origin=predictive method=joback]
HvapTb      56052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-145.789 1.4729 -0.0011084 3.411e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 5; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 5; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -251040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     299.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=59650.0
    phase     gas;
}
