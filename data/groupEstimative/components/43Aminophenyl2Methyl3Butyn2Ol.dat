/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(3-aminophenyl)-2-methyl-3-butyn-2-ol  (C11H13NO, CAS 69088-96-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        43Aminophenyl2Methyl3Butyn2Ol;
formula     C11H13NO;
CAS         69088-96-6;
InChIKey    DQPSETABKZMTEZ-UHFFFAOYSA-N;
MW          175.231;      // g/mol [origin=calculated method=formula-sum]
Tc          887.48;      // K   [origin=predictive method=joback]
Pc          37.638;      // bar [origin=predictive method=joback]
omega       0.9045;      // -   [origin=predictive method=lee-kesler]
Tb          653.42;      // K   [origin=predictive method=joback]
HvapTb      71194.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.85 0.98234 -0.00069222 1.9198e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 1; } { group ACNH2; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group tC; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3-aminophenyl)-2-methyl-but-3-yn-2-ol" "1-(3-aminophenyl)-3-methyl-1-butyn-3-ol" "4-(3-aminophenyl)-2-methylbut-3-yn-2-ol" "3-butyn-2-ol, 4-(3-aminophenyl)-2-methyl-" "3-(3-hydroxy-3-methylbutyn-1-yl)aniline" "2-methyl-4-(3-aminophenyl)-3-butyn-2-ol" "3-(3-hydroxy-3-methyl-1-butyn-1-yl)aniline" "1-(3-aminophenyl)-3-methyl-1-butyn-3-ol;4-(3-aminophenyl)-2-methyl-but-3-yn-2-ol;" );
gibbsFormation
{
    dHf_298   99800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=279790.0
    phase     gas;
}
