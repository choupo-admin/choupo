/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid; 1-[3-(2-hydroxypropoxy)-2,2-bis(2-hydroxypropoxymethyl)propoxy]propan-2-ol  (C23H46O12, CAS 68238-96-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcid132Hydroxypropoxy22Bis2HydroxypropoxymethylPr;
formula     C23H46O12;
CAS         68238-96-0;
InChIKey    ABCOYUMTGQOUTD-UHFFFAOYSA-N;
MW          514.609;      // g/mol [origin=calculated method=formula-sum]
Tc          2226.63;      // K   [origin=predictive method=joback]
Pc          11.223;      // bar [origin=predictive method=joback]
omega       -0.1200;      // -   [origin=predictive method=lee-kesler]
Tb          1471.67;      // K   [origin=predictive method=joback]
HvapTb      174922.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (123.962 2.11688 -0.00082 -8.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group C; count 1; } { group COOH; count 2; } { group C2H4O2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 4; } { group C; count 1; } { group OH; count 4; } { group O; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanedioic acid;1-[3-(2-oxidanylpropoxy)-2,2-bis(2-oxidanylpropoxymethyl)propoxy]propan-2-ol" "hexanedioic acid, polymer with 1,1'-((2,2-bis((2-hydroxypropoxy)methyl)-1,3-propanediyl)bis(oxy))bis(2-propanol)" );
standardThermochemistry
{
    dHf_298   -2497880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1437.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1624000.0
}
