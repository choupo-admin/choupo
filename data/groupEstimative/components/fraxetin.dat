/*--------------------------------*- Choupo -*-----------------------*\
  Component: fraxetin  (C10H8O5, CAS 574-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fraxetin;
formula     C10H8O5;
CAS         574-84-5;
InChIKey    HAVWRBANWNTOJX-UHFFFAOYSA-N;
MW          208.169;      // g/mol [origin=calculated method=formula-sum]
Tc          951.57;      // K   [origin=predictive method=joback]
Pc          49.804;      // bar [origin=predictive method=joback]
omega       1.2173;      // -   [origin=predictive method=lee-kesler]
Tb          713.22;      // K   [origin=predictive method=joback]
HvapTb      77641.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.72 1.07812 -0.00103372 3.994e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 1; } { group AC; count 3; } { group ACOH; count 2; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group OH_phenol; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methoxy-7,8-bis(oxidanyl)chromen-2-one" "7,8-dihydroxy-6-methoxycoumarin" "7,8-dihydroxy-6-methoxy-2h-chromen-2-one" "2h-1-benzopyran-2-one, 7,8-dihydroxy-6-methoxy-" "7,8-dihydroxy-6-methoxychromen-2-one" "coumarin, 7,8-dihydroxy-6-methoxy-" "7,8-dihydroxy-6-methoxy-2-benzopyrone" "brd-k76587808-001-03-8" );
gibbsFormation
{
    dHf_298   -683180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-487620.0
    phase     gas;
}
