/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3134754  (C20H14, CAS 63041-88-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3134754;
formula     C20H14;
CAS         63041-88-3;
InChIKey    IJAOHUABITVDOH-UHFFFAOYSA-N;
MW          254.332;      // g/mol [origin=calculated method=formula-sum]
Tc          1022.98;      // K   [origin=predictive method=joback]
Pc          24.171;      // bar [origin=predictive method=joback]
omega       0.8150;      // -   [origin=predictive method=lee-kesler]
Tb          768.59;      // K   [origin=predictive method=joback]
HvapTb      70498.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.97 1.71292 -0.00153876 5.584e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 7; } { group ACCH3; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-methyl-1',9-methylene-1,2-benzanthracene" "6-methyl-11h-cyclopenta[pqr]tetraphene" );
gibbsFormation
{
    dHf_298   401720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=594390.0
    phase     gas;
}
