/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pentanone, 3,3-dichloro-  (C5H8Cl2O, CAS 57856-10-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Pentanone33Dichloro;
formula     C5H8Cl2O;
CAS         57856-10-7;
InChIKey    VKWUGBQFNMLUAO-UHFFFAOYSA-N;
MW          155.018;      // g/mol [origin=calculated method=formula-sum]
Tc          646.20;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       0.3955;      // -   [origin=predictive method=lee-kesler]
Tb          439.50;      // K   [origin=predictive method=joback]
HvapTb      40944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.011 0.59024 -0.0004421 1.2916e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH3CO; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group Cl; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(chloranyl)pentan-2-one" "3,3-dichloropentan-2-one" );
standardThermochemistry
{
    dHf_298   -299340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-158720.0
}
