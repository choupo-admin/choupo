/*--------------------------------*- Choupo -*-----------------------*\
  Component: furan, 2,2,3,3,4,4-hexafluorotetrahydro-5-[2,2,2-trifluoro-1,1-bis(trifluoromethyl)ethyl]-  (C8HF15O, CAS 71302-72-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        furan223344Hexafluorotetrahydro5222Trifluoro11BisTrifluorome;
formula     C8HF15O;
CAS         71302-72-2;
InChIKey    PCNHGPSESDZSRB-UHFFFAOYSA-N;
MW          398.065;      // g/mol [origin=calculated method=formula-sum]
Tc          515.58;      // K   [origin=predictive method=joback]
Pc          17.684;      // bar [origin=predictive method=joback]
omega       0.6372;      // -   [origin=predictive method=lee-kesler]
Tb          387.71;      // K   [origin=predictive method=joback]
HvapTb      16350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-186.23 2.3689 -0.0028897 1.2958e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group CH-O; count 1; } { group CF3; count 3; } { group CF2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 4; } { group CH_ring; count 1; } { group C_ring; count 3; } { group F; count 15; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,3,4,4-hexakis(fluoranyl)-5-[1,1,1,3,3,3-hexakis(fluoranyl)-2-(trifluoromethyl)propan-2-yl]oxolane" "furan, 2,2,3,3,4,4-hexafluorotetrahydro-5-(2,2,2-trifluoro-1,1-bis(trifluoromethyl)ethyl)-" "5-(perfluoro-tert-butyl)-2,2,3,3,4,4-hexafluorotetrahydrofuran" "2,2,3,3,4,4-hexafluoro-5-[1,1,1,3,3,3-hexafluoro-2-(trifluoromethyl)propan-2-yl]oxolane" );
gibbsFormation
{
    dHf_298   -3271920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     767.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2983480.0
    phase     gas;
}
