/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylnaphthalene  (C12H12, CAS 939-27-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethylnaphthalene;
formula     C12H12;
CAS         939-27-5;
InChIKey    RJTJVVYSTUQWNI-UHFFFAOYSA-N;
MW          156.228;      // g/mol [origin=calculated method=formula-sum]
Tc          755.25;      // K   [origin=predictive method=joback]
Pc          30.558;      // bar [origin=predictive method=joback]
omega       0.4421;      // -   [origin=predictive method=lee-kesler]
Tb          524.80;      // K   [origin=predictive method=joback]
HvapTb      46884.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.069 1.00172 -0.00072988 2.133e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene, 2-ethyl-" ".beta.-ethylnaphthalene" "beta-ethylnaphthalene" "2-ethyl-naphthalene" "rjtjvvystuqwni-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   125120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=259590.0
    phase     gas;
}
