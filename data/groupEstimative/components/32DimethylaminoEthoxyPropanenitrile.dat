/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-[2-(dimethylamino)ethoxy]propanenitrile  (C7H14N2O, CAS 22397-29-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32DimethylaminoEthoxyPropanenitrile;
formula     C7H14N2O;
CAS         22397-29-1;
InChIKey    MNAXYNVBGBASIG-UHFFFAOYSA-N;
MW          142.202;      // g/mol [origin=calculated method=formula-sum]
Tc          680.84;      // K   [origin=predictive method=joback]
Pc          26.735;      // bar [origin=predictive method=joback]
omega       0.6582;      // -   [origin=predictive method=lee-kesler]
Tb          496.70;      // K   [origin=predictive method=joback]
HvapTb      46107.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.334 0.66434 -0.0003276 4.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2O; count 1; } { group CH3N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group O; count 1; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propanenitrile, 3-(2-(dimethylamino)ethoxy)-" "propanenitrile, 3-[2-(dimethylamino)ethoxy]-" "dimethylaminoethoxypropionitrile" "3-(2-dimethylaminoethyloxy)propanenitrile" "3-(2-(dimethylamino)ethoxy)propiononitrile" );
standardThermochemistry
{
    dHf_298   -87620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147020.0
}
