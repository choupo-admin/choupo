/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexyl phenylacetate  (C14H20O2, CAS 5421-17-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexylPhenylacetate;
formula     C14H20O2;
CAS         5421-17-0;
InChIKey    MTAHGWGAEGVCLS-UHFFFAOYSA-N;
MW          220.312;      // g/mol [origin=calculated method=formula-sum]
Tc          802.68;      // K   [origin=predictive method=joback]
Pc          20.181;      // bar [origin=predictive method=joback]
omega       0.7305;      // -   [origin=predictive method=lee-kesler]
Tb          604.82;      // K   [origin=predictive method=joback]
HvapTb      56441.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.334 1.20012 -0.0006744 1.238e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexyl 2-phenylethanoate" "benzeneacetic acid, hexyl ester" "n-hexyl phenylacetate" "hexyl 2-phenylacetate" "hexyl alpha-toluate" "hexyl benzeneacetate" "benzeneacetic acid,hexyl ester" "acetic acid, phenyl-, hexyl ester" );
standardThermochemistry
{
    dHf_298   -413040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130960.0
}
