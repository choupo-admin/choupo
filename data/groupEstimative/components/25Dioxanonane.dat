/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dioxanonane  (C7H16O2, CAS 13343-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dioxanonane;
formula     C7H16O2;
CAS         13343-98-1;
InChIKey    XDFQEFFBRPGSMC-UHFFFAOYSA-N;
MW          132.203;      // g/mol [origin=calculated method=formula-sum]
Tc          569.54;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       0.5031;      // -   [origin=predictive method=lee-kesler]
Tb          404.60;      // K   [origin=predictive method=joback]
HvapTb      35996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.525 0.54244 -0.000135 -3.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methoxyethoxy)butane" "butyl 2-methoxyethyl ether" "ethane, 1-butoxy-2-methoxy-" "butane, 1-(2-methoxyethoxy)-" "butane,1-(2-methoxyethoxy)-" "ethane,1-butoxy-2-methoxy- (6ci,7ci,8ci); 1-(2-methoxyethoxy)butane;1-butoxy-2-methoxyethane; 2,5-dioxanonane; 2-butoxyethyl methyl ether; ethyleneglycol methyl butyl ether" );
standardThermochemistry
{
    dHf_298   -452250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-201940.0
}
