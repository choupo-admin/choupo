/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxalic acid dihydrate  (C2H6O6, CAS 6153-56-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C2H6O6 (delta H+4O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        oxalicAcidDihydrate;
formula     C2H6O6;
CAS         6153-56-6;
InChIKey    GEVPUGOOGXGPIO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          126.064;      // g/mol [origin=calculated method=formula-sum]
Tc          753.73;      // K   [origin=predictive method=joback]
Pc          49.315;      // bar [origin=predictive method=joback]
omega       0.7923;      // -   [origin=predictive method=lee-kesler]
Tb          536.38;      // K   [origin=predictive method=joback]
HvapTb      54374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.27 0.2954 -0.0002302 6.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group H2O; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanedioic acid;dihydrate" "ethanedioic acid, dihydrate" "ethanedioic acid dihydrate" "oxalic acid, dihydrate" "oo paragraph signthornea" "oxalic acid, acs" "ambap6153-56-6" "ethanedioicacid, dihydrate (9ci);oxalic acid, dihydrate (8ci);" );
standardThermochemistry
{
    dHf_298   -785150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     806.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-721860.0
}
