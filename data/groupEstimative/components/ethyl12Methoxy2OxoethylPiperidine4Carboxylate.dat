/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 1-(2-methoxy-2-oxoethyl)piperidine-4-carboxylate  (C11H19NO4, CAS 71172-59-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl12Methoxy2OxoethylPiperidine4Carboxylate;
formula     C11H19NO4;
CAS         71172-59-3;
InChIKey    FDOUEVZZUSOBRB-UHFFFAOYSA-N;
MW          229.276;      // g/mol [origin=calculated method=formula-sum]
Tc          790.02;      // K   [origin=predictive method=joback]
Pc          22.981;      // bar [origin=predictive method=joback]
omega       0.8102;      // -   [origin=predictive method=lee-kesler]
Tb          595.44;      // K   [origin=predictive method=joback]
HvapTb      57194.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.468 1.19484 -0.0006254 8.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH2COO; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 1-(2-methoxy-2-oxidanylidene-ethyl)piperidine-4-carboxylate" "4-carboxy-1-piperidineacetic acid, 4-ethyl-1, methyl ester" "ethyl 1-(methoxycarbonylmethyl)piperidine-4-carboxylate" );
standardThermochemistry
{
    dHf_298   -776920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     652.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-431670.0
}
