/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-diacetylbenzene diethyl ketal  (C18H30O4, CAS 47189-08-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pDiacetylbenzeneDiethylKetal;
formula     C18H30O4;
CAS         47189-08-2;
InChIKey    OKYWFWIKJZITQH-UHFFFAOYSA-N;
MW          310.434;      // g/mol [origin=calculated method=formula-sum]
Tc          926.08;      // K   [origin=predictive method=joback]
Pc          14.133;      // bar [origin=predictive method=joback]
omega       0.8301;      // -   [origin=predictive method=lee-kesler]
Tb          726.32;      // K   [origin=predictive method=joback]
HvapTb      65648.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.974 1.57432 -0.00081916 1.282e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(1,1-diethoxyethyl)benzene" );
gibbsFormation
{
    dHf_298   -736170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     711.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-210860.0
    phase     gas;
}
