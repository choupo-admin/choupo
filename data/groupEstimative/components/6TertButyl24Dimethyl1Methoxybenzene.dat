/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-tert-butyl-2,4-dimethyl-1-methoxybenzene  (C13H20O, CAS 67845-33-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6TertButyl24Dimethyl1Methoxybenzene;
formula     C13H20O;
CAS         67845-33-4;
InChIKey    PZISTOMBMFSTQA-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          768.04;      // K   [origin=predictive method=joback]
Pc          21.081;      // bar [origin=predictive method=joback]
omega       0.5092;      // -   [origin=predictive method=lee-kesler]
Tb          557.85;      // K   [origin=predictive method=joback]
HvapTb      49908.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.09 1.04412 -0.00057428 1.114e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-2-methoxy-3,5-dimethyl-benzene" "6-tert-butyl-2,4-dimethylanisole" "benzene, 1-(1,1-dimethylethyl)-2-methoxy-3,5-dimethyl-" "1-tert-butyl-2-methoxy-3,5-dimethylbenzene" );
standardThermochemistry
{
    dHf_298   -250500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39940.0
}
