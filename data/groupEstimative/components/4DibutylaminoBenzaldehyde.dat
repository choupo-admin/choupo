/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(dibutylamino)benzaldehyde  (C15H23NO, CAS 90134-10-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H23NO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4DibutylaminoBenzaldehyde;
formula     C15H23NO;
CAS         90134-10-4;
InChIKey    VNWPLOWYHIDMEB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          233.355;      // g/mol [origin=calculated method=formula-sum]
Tc          753.26;      // K   [origin=predictive method=joback]
Pc          18.904;      // bar [origin=predictive method=joback]
omega       0.6373;      // -   [origin=predictive method=lee-kesler]
Tb          563.32;      // K   [origin=predictive method=joback]
HvapTb      51592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.544 1.42244 -0.00102196 3.02e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   16110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     724.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=332940.0
    phase     gas;
}
