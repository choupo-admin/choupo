/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzyl-n-(4-methylphenyl)amine  (C14H15N, CAS 5405-15-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzylN4MethylphenylAmine;
formula     C14H15N;
CAS         5405-15-2;
InChIKey    KEVOWRWHMCBERP-UHFFFAOYSA-N;
MW          197.281;      // g/mol [origin=calculated method=formula-sum]
Tc          867.02;      // K   [origin=predictive method=joback]
Pc          27.643;      // bar [origin=predictive method=joback]
omega       0.6331;      // -   [origin=predictive method=lee-kesler]
Tb          628.43;      // K   [origin=predictive method=joback]
HvapTb      58408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.559 1.19272 -0.00078176 1.92e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH3; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-n-(phenylmethyl)aniline" "n-benzyl-4-toluidine" "benzenemethanamine, n-(4-methylphenyl)-" "n-benzyl-p-toluidine" "n-benzyl-4-methylaniline" "benzenemethanamine,n-(4-methylphenyl)-" );
standardThermochemistry
{
    dHf_298   182770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=371580.0
}
