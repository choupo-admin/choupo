/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-bromophenylethynyl)trimethylsilane  (C11H13BrSi, CAS 38274-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H13BrSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2BromophenylethynylTrimethylsilane;
formula     C11H13BrSi;
CAS         38274-16-7;
InChIKey    FABNGXSCLHXUOH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          253.214;      // g/mol [origin=calculated method=formula-sum]
Tc          815.45;      // K   [origin=predictive method=joback]
Pc          29.250;      // bar [origin=predictive method=joback]
omega       0.3642;      // -   [origin=predictive method=lee-kesler]
Tb          559.50;      // K   [origin=predictive method=joback]
HvapTb      51899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.85 0.59266 -0.00010322 -8.382e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 4; } { group AC; count 2; } { group Br; count 1; } { group C_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group tC; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-bromophenyl)ethynyl-trimethyl-silane" "((2-bromophenyl)ethynyl)trimethylsilane" "(2-bromo-phenylethynyl)-trimethylsilane" "2-(2-bromophenyl)ethynyl-trimethylsilane" "benzene,1-bromo-2-[2-(trimethylsilyl)ethynyl]-" "silane,[(2-bromophenyl)ethynyl]trimethyl- (9ci);((2-bromophenyl)ethynyl)trimethylsilane; (2-(2-bromophenyl)ethynyl)trimethylsilane;1-bromo-2-[(trimethylsilyl)ethynyl]benzene;1-bromo-2-[2-(trimethylsilyl)ethynyl]benzene;[(o-bromophenyl)ethynyl]trimethylsilane" );
gibbsFormation
{
    dHf_298   141700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     621.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=256880.0
    phase     gas;
}
