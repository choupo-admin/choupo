/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenyl-1-indanone  (C15H12O, CAS 16618-72-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenyl1Indanone;
formula     C15H12O;
CAS         16618-72-7;
InChIKey    SIUOTMYWHGODQX-UHFFFAOYSA-N;
MW          208.26;      // g/mol [origin=calculated method=formula-sum]
Tc          941.80;      // K   [origin=predictive method=joback]
Pc          29.345;      // bar [origin=predictive method=joback]
omega       0.5991;      // -   [origin=predictive method=lee-kesler]
Tb          675.70;      // K   [origin=predictive method=joback]
HvapTb      58358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.07 1.1941 -0.00076376 1.797e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenyl-2,3-dihydroinden-1-one" "3-phenylindan-1-one" "1-indanone, 3-phenyl-" "3-phenylindanone" "3-phenyl-2,3-dihydro-1h-inden-1-one" "3-phenyl-2,3-dihydro-inden-1-one" "1h-inden-1-one,3-dihydro-3-phenyl-" "1h-inden-1-one,2,3-dihydro-3-phenyl-" "1h-inden-1-one, 2,3-dihydro-3-phenyl-" "(3s)-3-phenyl-2,3-dihydro-1h-inden-1-one" "1h-inden-1-one, 2,3-dihydro-3-phenyl- (9ci)" );
gibbsFormation
{
    dHf_298   43760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=228770.0
    phase     gas;
}
