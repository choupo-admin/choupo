/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-dibromo-1,1,2,2-tetrafluorooctane  (C8H12Br2F4, CAS 64382-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Dibromo1122Tetrafluorooctane;
formula     C8H12Br2F4;
CAS         64382-00-9;
InChIKey    HQQKCBTWMGGVPR-UHFFFAOYSA-N;
MW          343.984;      // g/mol [origin=calculated method=formula-sum]
Tc          687.16;      // K   [origin=predictive method=joback]
Pc          25.252;      // bar [origin=predictive method=joback]
omega       0.6852;      // -   [origin=predictive method=lee-kesler]
Tb          505.58;      // K   [origin=predictive method=joback]
HvapTb      40412.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.584 1.139 -0.0009634 3.184e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group Br; count 2; } { group CF2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group C; count 2; } { group F; count 4; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,8-bis(bromanyl)-1,1,2,2-tetrakis(fluoranyl)octane" "octane, 1,8-dibromo-1,1,2,2-tetrafluoro-" );
gibbsFormation
{
    dHf_298   -957730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     618.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-728440.0
    phase     gas;
}
