/*--------------------------------*- Choupo -*-----------------------*\
  Component: styrene-d8  (C8D8, CAS 19361-62-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8D8 (delta D+8H-8; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        styreneD8;
formula     C8D8;
CAS         19361-62-7;
InChIKey    PPBRXRYQALVLMV-GDALLCCDSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          112.2;      // g/mol [origin=calculated method=formula-sum]
Tc          620.42;      // K   [origin=predictive method=joback]
Pc          38.435;      // bar [origin=predictive method=joback]
omega       0.2712;      // -   [origin=predictive method=lee-kesler]
Tb          406.00;      // K   [origin=predictive method=joback]
HvapTb      35008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.28 0.6649 -0.0004655 1.269e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentadeuterio-6-(1,2,2-trideuterioethenyl)benzene" "octadeuterostyrene" "benzene-d5, ethenyl-d3-" "benzene-1,2,3,4,5-d5, 6-(ethenyl-1,2,2-d3)-" "phenethylene-d8" "phenylethene-d8" "vinylbenzene-d8" "vinylbenzol-d8" "cinnamene-d8" "perdeuteriostyrene" "styrolene-d8" "styrole-d8" );
standardThermochemistry
{
    dHf_298   153510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=216730.0
}
