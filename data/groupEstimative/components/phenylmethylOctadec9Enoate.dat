/*--------------------------------*- Choupo -*-----------------------*\
  Component: (phenylmethyl) octadec-9-enoate  (C25H40O2, CAS 55130-16-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylmethylOctadec9Enoate;
formula     C25H40O2;
CAS         55130-16-0;
InChIKey    CGFITOCWTCRCSL-UHFFFAOYSA-N;
MW          372.593;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.71;      // K   [origin=predictive method=joback]
Pc          9.585;      // bar [origin=predictive method=joback]
omega       0.8872;      // -   [origin=predictive method=lee-kesler]
Tb          860.66;      // K   [origin=predictive method=joback]
HvapTb      80885.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.515 2.26512 -0.0013566 3.021e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH=CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-octadecenoic acid(9z)-, phenylmethyl ester" "9-octadecenoicacid (z)-, phenylmethyl ester; oleic acid, benzyl ester (6ci,7ci); benzyloleate" );
standardThermochemistry
{
    dHf_298   -522860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1068.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41880.0
}
