/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,9-dimethylphenanthrene  (C16H14, CAS 17980-09-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        29Dimethylphenanthrene;
formula     C16H14;
CAS         17980-09-5;
InChIKey    UBHFDMXPUHEOGF-UHFFFAOYSA-N;
MW          206.288;      // g/mol [origin=calculated method=formula-sum]
Tc          889.94;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       0.5959;      // -   [origin=predictive method=lee-kesler]
Tb          645.26;      // K   [origin=predictive method=joback]
HvapTb      58752.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.55 1.25904 -0.00095012 2.922e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group ACCH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenanthrene, 2,9-dimethyl-" );
standardThermochemistry
{
    dHf_298   210690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=380660.0
}
