/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(trifluoromethyl)aniline  (C7H6F3N, CAS 98-16-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3TrifluoromethylAniline;
formula     C7H6F3N;
CAS         98-16-8;
InChIKey    VIUDTWATMPPKEL-UHFFFAOYSA-N;
MW          161.126;      // g/mol [origin=calculated method=formula-sum]
Tc          665.02;      // K   [origin=predictive method=joback]
Pc          37.500;      // bar [origin=predictive method=joback]
omega       0.4883;      // -   [origin=predictive method=lee-kesler]
Tb          458.53;      // K   [origin=predictive method=joback]
HvapTb      41008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.79 0.7535 -0.00058556 1.724e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-aminobenzotrifluoride" "m-aminobenzotrifluoride" "3-aminotrifluorotoluene" "benzenamine, 3-(trifluoromethyl)-" "3-trifluoromethylaniline" "m-(trifluoromethyl)aniline" "m-amino trifluorotoluene" "3-(trifluoromethyl)benzenamine" "m-abtf" "alpha,alpha,alpha-trifluoro-m-toluidine" "m-aminotrifluoromethylbenzene" "m-aminobenzal fluoride" );
gibbsFormation
{
    dHf_298   -526040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-404300.0
    phase     gas;
}
