/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4-trimethyl-1,3-dioxane  (C7H14O2, CAS 696-79-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224Trimethyl13Dioxane;
formula     C7H14O2;
CAS         696-79-7;
InChIKey    JINWMPBLUUKRSV-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          640.74;      // K   [origin=predictive method=joback]
Pc          34.971;      // bar [origin=predictive method=joback]
omega       0.3253;      // -   [origin=predictive method=lee-kesler]
Tb          428.78;      // K   [origin=predictive method=joback]
HvapTb      39165.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.49 1.05036 -0.0008874 3.341e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxane, 2,2,4-trimethyl-, (s)-" );
gibbsFormation
{
    dHf_298   -402590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     322.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-152930.0
    phase     gas;
}
