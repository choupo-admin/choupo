/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-isocyanato-3-methylbutanoate  (C7H11NO3, CAS 30293-86-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Isocyanato3Methylbutanoate;
formula     C7H11NO3;
CAS         30293-86-8;
InChIKey    JCVZXXSBCISMLJ-UHFFFAOYSA-N;
MW          157.169;      // g/mol [origin=calculated method=formula-sum]
Tc          675.30;      // K   [origin=predictive method=joback]
Pc          31.036;      // bar [origin=predictive method=joback]
omega       0.6169;      // -   [origin=predictive method=lee-kesler]
Tb          483.77;      // K   [origin=predictive method=joback]
HvapTb      47339.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 3; } { group CH; count 2; } { group dCd; count 1; } { group COO; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-isocyanato-3-methyl-butanoate" "2-isocyanato-3-methyl-butyric acid methyl ester" "(s)-(-)-2-isocyanato-3-methylbutyric acid methyl ester" "methyl n-(oxomethylene)valinate" "methyl n-(oxomethylidene)valinate" );
// formation datum unavailable (element entropy missing): dHf_298=-521060.0 dGf_298=None
