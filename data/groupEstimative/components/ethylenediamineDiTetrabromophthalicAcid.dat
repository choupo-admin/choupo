/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylenediamine di(tetrabromophthalic acid)  (C18H12Br8N2O8, CAS 66046-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylenediamineDiTetrabromophthalicAcid;
formula     C18H12Br8N2O8;
CAS         66046-78-4;
InChIKey    YBHJNOXBYJUFRP-UHFFFAOYSA-N;
MW          1023.532;      // g/mol [origin=calculated method=formula-sum]
Tc          2538.68;      // K   [origin=predictive method=joback]
Pc          39.655;      // bar [origin=predictive method=joback]
omega       1.4701;      // -   [origin=predictive method=lee-kesler]
Tb          1973.78;      // K   [origin=predictive method=joback]
HvapTb      208840.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (240.252 1.1812 -0.0004662 -2.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 12; } { group CH2NH2; count 2; } { group COOH; count 4; } { group Br; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dC_ring; count 12; } { group Br; count 8; } { group COOH; count 4; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-diamine;3,4,5,6-tetrakis(bromanyl)phthalic acid" "3,4,5,6-tetrabromophthalic acid- ethane-1,2-diamine(2:1)" "1,2-benzenedicarboxylic acid, 3,4,5,6-tetrabromo-, compd. with 1,2-ethanediamine (2:1)" "bis(tetrabromophthalic acid)ethylenediamine salt" "ethane-1,2-diamine; 3,4,5,6-tetrabromophthalic acid" "3,4,5,6-tetrabromophthalic acid - ethane-1,2-diamine (2:1)" "3,4,5,6-tetrabromobenzene-1,2-dicarboxylic acid - ethane-1,2-diamine (2:1)" );
standardThermochemistry
{
    dHf_298   -1402590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1521.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1108500.0
}
