/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,8-dimethyl-1,2,3,4-tetrahydroquinoxaline  (C10H14N2, CAS 66102-39-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        58Dimethyl1234Tetrahydroquinoxaline;
formula     C10H14N2;
CAS         66102-39-4;
InChIKey    DJVBBBRKTTVZCV-UHFFFAOYSA-N;
MW          162.236;      // g/mol [origin=calculated method=formula-sum]
Tc          826.92;      // K   [origin=predictive method=joback]
Pc          36.553;      // bar [origin=predictive method=joback]
omega       0.5956;      // -   [origin=predictive method=lee-kesler]
Tb          582.80;      // K   [origin=predictive method=joback]
HvapTb      56026.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.67 0.83744 -0.00045828 9.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group NH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "quinoxaline, 1,2,3,4-tetrahydro-5,8-dimethyl-" );
gibbsFormation
{
    dHf_298   114990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=348620.0
    phase     gas;
}
