/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylene glycol monovinyl ether  (C6H12O3, CAS 929-37-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyleneGlycolMonovinylEther;
formula     C6H12O3;
CAS         929-37-3;
InChIKey    WULAHPYSGCVQHM-UHFFFAOYSA-N;
MW          132.159;      // g/mol [origin=calculated method=formula-sum]
Tc          634.91;      // K   [origin=predictive method=joback]
Pc          34.848;      // bar [origin=predictive method=joback]
omega       0.9154;      // -   [origin=predictive method=lee-kesler]
Tb          470.58;      // K   [origin=predictive method=joback]
HvapTb      49779.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.734 0.4614 -0.0001339 -2.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH2O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-ethenoxyethoxy)ethanol" "di(ethylene glycol) vinyl ether" "degmve [russian]" "ethanol, 2-[2-(vinyloxy)ethoxy]-" "ethanol, 2-(2-(ethenyloxy)ethoxy)-" "ethanol, 2-[2-(ethenyloxy)ethoxy]-" "diethyleneglycol vinyl ether" "diethylen-glycol monovinyl ester" "2-(2-(ethenyloxy)ethoxy)ethanol" "ethanol, 2-(2-(vinyloxy)ethoxy)-" "degmve" "vinyl carbitol" );
standardThermochemistry
{
    dHf_298   -458410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-259340.0
}
