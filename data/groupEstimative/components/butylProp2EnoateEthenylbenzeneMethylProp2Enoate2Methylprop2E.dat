/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl prop-2-enoate;ethenylbenzene;methyl prop-2-enoate;2-methylprop-2-enoic acid  (C23H32O6, CAS 51939-28-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylProp2EnoateEthenylbenzeneMethylProp2Enoate2Methylprop2E;
formula     C23H32O6;
CAS         51939-28-7;
InChIKey    UQBBLQKAZWDLBF-UHFFFAOYSA-N;
MW          404.503;      // g/mol [origin=calculated method=formula-sum]
Tc          1235.70;      // K   [origin=predictive method=joback]
Pc          10.494;      // bar [origin=predictive method=joback]
omega       0.9653;      // -   [origin=predictive method=lee-kesler]
Tb          1005.27;      // K   [origin=predictive method=joback]
HvapTb      99328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (114.293 1.35246 8.5e-06 -3.784e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH2=CH; count 3; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH2; count 4; } { group dCH; count 3; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, polymer with butyl 2-propenoate, ethenylbenzene and methyl 2-propenoate" );
gibbsFormation
{
    dHf_298   -1109280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1401.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-680930.0
    phase     gas;
}
