/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-3-pyrrolidino-cyclohex-2-en-1-one  (C12H19NO, CAS 3357-16-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl3PyrrolidinoCyclohex2En1One;
formula     C12H19NO;
CAS         3357-16-2;
InChIKey    QUHBLBSKTJUBLZ-UHFFFAOYSA-N;
MW          193.29;      // g/mol [origin=calculated method=formula-sum]
Tc          833.22;      // K   [origin=predictive method=joback]
Pc          28.354;      // bar [origin=predictive method=joback]
omega       0.5456;      // -   [origin=predictive method=lee-kesler]
Tb          594.03;      // K   [origin=predictive method=joback]
HvapTb      49222.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-137.1 1.56574 -0.00126064 4.405e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 6; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethyl-3-pyrrolidin-1-yl-cyclohex-2-en-1-one" "5,5-dimethyl-3-pyrrolidin-1-yl-cyclohex-2-enone" "5,5-dimethyl-3-pyrrolidinocyclohex-2-enone" "5,5-dimethyl-3-pyrrolidin-1-ylcyclohex-2-en-1-one" "5,5-dimethyl-3-(1-pyrrolidinyl)-2-cyclohexen-1-one" "5,5-dimethyl-3-(pyrrolidin-1-yl)cyclohex-2-en-1-one" );
gibbsFormation
{
    dHf_298   -158330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=134000.0
    phase     gas;
}
