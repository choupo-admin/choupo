/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(3-aminomethylbenzyl)-3-(z)-9-octadecenylaminopropionamide  (C29H51N3O, CAS 94022-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3Aminomethylbenzyl3Z9Octadecenylaminopropionamide;
formula     C29H51N3O;
CAS         94022-57-8;
InChIKey    KWSZBVNWSUIJKL-UHFFFAOYSA-N;
MW          457.747;      // g/mol [origin=calculated method=formula-sum]
Tc          1394.95;      // K   [origin=predictive method=joback]
Pc          8.220;      // bar [origin=predictive method=joback]
omega       0.6693;      // -   [origin=predictive method=lee-kesler]
Tb          1125.68;      // K   [origin=predictive method=joback]
HvapTb      113303.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.831 2.82672 -0.00172366 4.0486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2NH2; count 1; } { group CH2NH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 19; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[[3-(aminomethyl)phenyl]methyl]-3-(octadec-9-enylamino)propanamide" "propanamide, n-[[3-(aminomethyl)phenyl]methyl]-3-[(9z)-9-octadecen-1-ylamino]-" "propanamide, n-[[3-(aminomethyl)phenyl]methyl]-3-[(9z)-9-octadecenylamino]-" );
gibbsFormation
{
    dHf_298   -271460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1326.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=492610.0
    phase     gas;
}
