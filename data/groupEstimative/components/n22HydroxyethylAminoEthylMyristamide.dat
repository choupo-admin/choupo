/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-((2-hydroxyethyl)amino)ethyl)myristamide  (C18H38N2O2, CAS 53989-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n22HydroxyethylAminoEthylMyristamide;
formula     C18H38N2O2;
CAS         53989-67-6;
InChIKey    GFVTUBMIUWNDMN-UHFFFAOYSA-N;
MW          314.514;      // g/mol [origin=calculated method=formula-sum]
Tc          1050.26;      // K   [origin=predictive method=joback]
Pc          13.080;      // bar [origin=predictive method=joback]
omega       1.2124;      // -   [origin=predictive method=lee-kesler]
Tb          857.83;      // K   [origin=predictive method=joback]
HvapTb      91959.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.244 1.87222 -0.0010643 2.2476e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group OH; count 1; } { group CH2NH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group OH; count 1; } { group CdO; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[2-(2-hydroxyethylamino)ethyl]tetradecanamide" "n-{2-[(2-hydroxyethyl)amino]ethyl}tetradecanamide" "tetradecanamide, n-(2-((2-hydroxyethyl)amino)ethyl)-" "tetradecanamide, n-[2-[(2-hydroxyethyl)amino]ethyl]-" "n-myristoyl-n'-(2-hydroxyethyl)ethylenediamine" "tetradecanamide,n-[2-[(2-hydroxyethyl)amino]ethyl]-" );
gibbsFormation
{
    dHf_298   -572720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1016.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13720.0
    phase     gas;
}
