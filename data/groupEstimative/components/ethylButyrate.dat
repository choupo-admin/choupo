/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl butyrate  (C6H12O2, CAS 105-54-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylButyrate;
formula     C6H12O2;
CAS         105-54-4;
InChIKey    OBNCKNCVKJNDBV-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          568.77;      // K   [origin=predictive method=joback]
Pc          31.245;      // bar [origin=predictive method=joback]
omega       0.4499;      // -   [origin=predictive method=lee-kesler]
Tb          395.10;      // K   [origin=predictive method=joback]
HvapTb      36357.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.843 0.51904 -0.000208 3.1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl butanoate" "butyric acid ethyl ester" "butanoic acid, ethyl ester" "ethyl n-butyrate" "butyric acid, ethyl ester" "butyric ester" "butyric ether" "ethyl n-butanoate" "butanoic acid ethyl ester" "ethyl butyrate (natural)" "butyric ethee" "butyric acid ethyl estee" );
standardThermochemistry
{
    dHf_298   -484450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-310730.0
}
