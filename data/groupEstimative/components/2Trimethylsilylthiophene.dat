/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-trimethylsilylthiophene  (C7H12SSi, CAS 18245-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H12SSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Trimethylsilylthiophene;
formula     C7H12SSi;
CAS         18245-28-8;
InChIKey    OANGLGSZPSFVDY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          156.318;      // g/mol [origin=calculated method=formula-sum]
Tc          657.61;      // K   [origin=predictive method=joback]
Pc          32.803;      // bar [origin=predictive method=joback]
omega       0.2336;      // -   [origin=predictive method=lee-kesler]
Tb          432.24;      // K   [origin=predictive method=joback]
HvapTb      39094.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.6 0.46377 -5.122e-05 -8.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group Si; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(thiophen-2-yl)silane" "2-thienyltrimethylsilane" "trimethyl-2-thienylsilane" "silane, trimethyl-2-thienyl-" "trimethyl(2-thienyl)silane" "thien-2-yl-trimethyl-silane" "thiophene,2-(trimethylsilyl)-" "2-(1,1-dimethyl-1-silaethyl)thiophene" "silane,trimethyl-2-thienyl- (6ci,7ci,8ci,9ci);2-(trimethylsilyl)thiophene;2-thienyltrimethylsilane;trimethyl-2-thienylsilane;" );
standardThermochemistry
{
    dHf_298   -69260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37710.0
}
