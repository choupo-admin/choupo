/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dichlorooxolan-2-yl formate  (C5H6Cl2O3, CAS 141942-51-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H6Cl2O3 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        33Dichlorooxolan2YlFormate;
formula     C5H6Cl2O3;
CAS         141942-51-0;
InChIKey    ILRYJOJVKDLSBM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          185.0;      // g/mol [origin=calculated method=formula-sum]
Tc          625.58;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.2307;      // -   [origin=predictive method=lee-kesler]
Tb          403.08;      // K   [origin=predictive method=joback]
HvapTb      36428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.59 0.8946 -0.0010327 4.636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group HCOO; count 1; } { group FCH2O; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group Cl; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3,3-bis(chloranyl)oxolan-2-yl] methanoate" "(3,3-dichlorooxolan-2-yl) formate" "3,3-dichloro-2-formoxytetrahydrofuran" "2-furanol,3,3-dichlorotetrahydro-, formate (9ci);3,3-dichloro-2-(formyloxy)tetrahydrofuran" );
gibbsFormation
{
    dHf_298   -178180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51450.0
    phase     gas;
}
