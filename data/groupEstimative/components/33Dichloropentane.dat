/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dichloropentane  (C5H10Cl2, CAS 21571-91-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dichloropentane;
formula     C5H10Cl2;
CAS         21571-91-5;
InChIKey    MOUDFOLIRVUWKC-UHFFFAOYSA-N;
MW          141.035;      // g/mol [origin=calculated method=formula-sum]
Tc          579.34;      // K   [origin=predictive method=joback]
Pc          32.541;      // bar [origin=predictive method=joback]
omega       0.2780;      // -   [origin=predictive method=lee-kesler]
Tb          385.63;      // K   [origin=predictive method=joback]
HvapTb      34198.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.348 0.61824 -0.0004608 1.382e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(chloranyl)pentane" "pentane, 3,3-dichloro-" );
gibbsFormation
{
    dHf_298   -186760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29800.0
    phase     gas;
}
