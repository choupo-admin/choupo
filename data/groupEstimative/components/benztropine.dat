/*--------------------------------*- Choupo -*-----------------------*\
  Component: benztropine  (C21H25NO, CAS 80677-48-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benztropine;
formula     C21H25NO;
CAS         80677-48-1;
InChIKey    GIJXKZJWITVLHI-UHFFFAOYSA-N;
MW          307.437;      // g/mol [origin=calculated method=formula-sum]
Tc          1022.98;      // K   [origin=predictive method=joback]
Pc          18.404;      // bar [origin=predictive method=joback]
omega       0.7762;      // -   [origin=predictive method=lee-kesler]
Tb          780.94;      // K   [origin=predictive method=joback]
HvapTb      70646.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-170.55 2.17332 -0.0015244 4.123e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group ACH; count 10; } { group AC; count 2; } { group CH-O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(diphenylmethyl)oxy-8-methyl-8-azabicyclo[3.2.1]octane" "3-(diphenylmethoxy)-8-methyl-8-azabicyclo[3.2.1]octane" "3-benzhydryloxy-8-methyl-8-azabicyclo[3.2.1]octane" "benzatropina" "benzatropine" "benzatropinum" "cogentinol" "cogentine" "benzatropine [inn]" "tropine benzohydryl ether" "nk 02" "8-azabicyclo[3.2.1]octane, 3-(diphenylmethoxy)-8-methyl-, endo-" );
standardThermochemistry
{
    dHf_298   45420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=455790.0
}
