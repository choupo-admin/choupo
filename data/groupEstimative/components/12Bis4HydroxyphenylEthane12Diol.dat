/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(4-hydroxyphenyl)ethane-1,2-diol  (C14H14O4, CAS 5173-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Bis4HydroxyphenylEthane12Diol;
formula     C14H14O4;
CAS         5173-27-3;
InChIKey    GRCDZLQANHNACB-UHFFFAOYSA-N;
MW          246.262;      // g/mol [origin=calculated method=formula-sum]
Tc          1147.90;      // K   [origin=predictive method=joback]
Pc          50.875;      // bar [origin=predictive method=joback]
omega       2.0592;      // -   [origin=predictive method=lee-kesler]
Tb          918.00;      // K   [origin=predictive method=joback]
HvapTb      109920.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.27 1.565 -0.00138012 4.912e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group ACCH; count 2; } { group OH; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4'-dihydroxyhydrobenzoin" "1,2-ethanediol, 1,2-bis(4-hydroxyphenyl)-" "phenol, p,p'-(1,2-dihydroxyethylene)di-" "1,2-ethanediol, 1,2-bis(p-hydroxyphenyl)-" "1,2-dihydroxy-1,2-bis(4-hydroxyphenyl)ethane" );
standardThermochemistry
{
    dHf_298   -528870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-295940.0
}
