/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-tetrachlorobutane  (C4H6Cl4, CAS 3405-32-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234Tetrachlorobutane;
formula     C4H6Cl4;
CAS         3405-32-1;
InChIKey    IXZVKECRTHXEEW-UHFFFAOYSA-N;
MW          195.892;      // g/mol [origin=calculated method=formula-sum]
Tc          647.02;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       0.3746;      // -   [origin=predictive method=lee-kesler]
Tb          439.96;      // K   [origin=predictive method=joback]
HvapTb      41262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.452 0.4228 -0.0002818 7.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2Cl; count 2; } { group CHCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 2; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetrakis(chloranyl)butane" "butane, 1,2,3,4-tetrachloro-" "1,3,4-tetrachlorobutane" "agn-pc-00bzho" "butane,2,3,4-tetrachloro-" "butane,1,2,3,4-tetrachloro-" "(+-)-1,2,3,4-tetrachlorobutane" "meso-1,2,3,4-tetrachlorobutane" "(r*,s*)-1,2,3,4-tetrachlorobutane" "(r,s)-1,2,3,4-tetrachlorobutane" );
standardThermochemistry
{
    dHf_298   -199410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-69800.0
}
