/*--------------------------------*- Choupo -*-----------------------*\
  Component: p,p'-ddd  (C14H10Cl4, CAS 72-54-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pPDdd;
formula     C14H10Cl4;
CAS         72-54-8;
InChIKey    AHJKRLASYNVKDZ-UHFFFAOYSA-N;
MW          320.034;      // g/mol [origin=calculated method=formula-sum]
Tc          995.16;      // K   [origin=predictive method=joback]
Pc          23.519;      // bar [origin=predictive method=joback]
omega       0.6461;      // -   [origin=predictive method=lee-kesler]
Tb          732.08;      // K   [origin=predictive method=joback]
HvapTb      69398.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.85 1.096 -0.00075412 1.916e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 1; } { group CHCl2; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,2-bis(chloranyl)-1-(4-chlorophenyl)ethyl]-4-chloranyl-benzene" "rhothane" "tetrachlorodiphenylethane" "dilene" "dichlorodiphenyldichloroethane" "p,p'-tde" "rothane" "rhothane d-3" "1,1-dichloro-2,2-bis(p-chlorophenyl)ethane" "4,4'-ddd" "ddd" "tde" );
standardThermochemistry
{
    dHf_298   44310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=219960.0
}
