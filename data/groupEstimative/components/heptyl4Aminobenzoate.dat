/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptyl 4-aminobenzoate  (C14H21NO2, CAS 14309-40-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptyl4Aminobenzoate;
formula     C14H21NO2;
CAS         14309-40-1;
InChIKey    IAHJVNSZPMIREM-UHFFFAOYSA-N;
MW          235.327;      // g/mol [origin=calculated method=formula-sum]
Tc          888.59;      // K   [origin=predictive method=joback]
Pc          20.965;      // bar [origin=predictive method=joback]
omega       0.9100;      // -   [origin=predictive method=lee-kesler]
Tb          682.33;      // K   [origin=predictive method=joback]
HvapTb      67744.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.456 1.20252 -0.00065076 1.099e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptyl 4-azanylbenzoate" );
standardThermochemistry
{
    dHf_298   -390720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     691.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-74140.0
}
