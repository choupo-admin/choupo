/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-bromobenzalacetone  (C10H9BrO, CAS 72454-54-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oBromobenzalacetone;
formula     C10H9BrO;
CAS         72454-54-7;
InChIKey    YEXZDFFGPWZWBU-VOTSOKGWSA-N;
MW          225.085;      // g/mol [origin=calculated method=formula-sum]
Tc          825.24;      // K   [origin=predictive method=joback]
Pc          35.515;      // bar [origin=predictive method=joback]
omega       0.6089;      // -   [origin=predictive method=lee-kesler]
Tb          584.25;      // K   [origin=predictive method=joback]
HvapTb      53931.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.44 0.84562 -0.00062086 1.8086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-4-(2-bromophenyl)but-3-en-2-one" "3-buten-2-one, 4-(2-bromophenyl)-" );
standardThermochemistry
{
    dHf_298   6300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=101720.0
}
