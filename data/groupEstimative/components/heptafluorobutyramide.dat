/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptafluorobutyramide  (C4H2F7NO, CAS 662-50-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptafluorobutyramide;
formula     C4H2F7NO;
CAS         662-50-0;
InChIKey    FOBJABJCODOMEO-UHFFFAOYSA-N;
MW          213.052;      // g/mol [origin=calculated method=formula-sum]
Tc          564.93;      // K   [origin=predictive method=joback]
Pc          33.029;      // bar [origin=predictive method=joback]
omega       0.6165;      // -   [origin=predictive method=lee-kesler]
Tb          402.72;      // K   [origin=predictive method=joback]
HvapTb      32278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.68 0.8777 -0.0008487 2.9326e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CF3; count 1; } { group CF2; count 2; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group F; count 7; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,3,4,4,4-heptakis(fluoranyl)butanamide" "perfluorobutyramide" "heptafluorobutyroamide" "2,2,3,3,4,4,4-heptafluorobutanamide" "heptafluoro-n-butyramide" "butanamide, 2,2,3,3,4,4,4-heptafluoro-" "2,2,3,3,4,4,4-heptafluorobutyramide" "butyramide, alpha,alpha,beta,beta,gamma,gamma,gamma-heptafluoro-" "heptafluorobutanamide" "butanamide,2,3,3,4,4,4-heptafluoro-" "butyramide,2,3,3,4,4,4-heptafluoro-" "2,2,3,3,4,4,4-heptafluoro-butyramide" );
standardThermochemistry
{
    dHf_298   -1603700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1434820.0
}
