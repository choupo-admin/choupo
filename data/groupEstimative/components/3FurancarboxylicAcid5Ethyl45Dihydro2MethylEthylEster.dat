/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-furancarboxylic acid, 5-ethyl-4,5-dihydro-2-methyl-, ethyl ester  (C10H16O3, CAS 97953-23-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3FurancarboxylicAcid5Ethyl45Dihydro2MethylEthylEster;
formula     C10H16O3;
CAS         97953-23-6;
InChIKey    AQGIXJDBFOHCNW-UHFFFAOYSA-N;
MW          184.235;      // g/mol [origin=calculated method=formula-sum]
Tc          736.39;      // K   [origin=predictive method=joback]
Pc          25.100;      // bar [origin=predictive method=joback]
omega       0.6346;      // -   [origin=predictive method=lee-kesler]
Tb          537.97;      // K   [origin=predictive method=joback]
HvapTb      51644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.422 0.85276 -0.0003923 3.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH-O; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dC_ring; count 2; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-ethyl-5-methyl-2,3-dihydrofuran-4-carboxylate" );
standardThermochemistry
{
    dHf_298   -603690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-315920.0
}
