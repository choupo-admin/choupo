/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-butoxybenzyl(1r,3r)-2,2-dimethyl-3-(2-methylprop-1-en-1-yl)cyclopropanecarboxylate  (C21H30O3, CAS 115809-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Butoxybenzyl1r3r22Dimethyl32Methylprop1En1YlCyclopropanecar;
formula     C21H30O3;
CAS         115809-83-1;
InChIKey    NXVNSEVUWLFYQJ-MOPGFXCFSA-N;
MW          330.468;      // g/mol [origin=calculated method=formula-sum]
Tc          1002.36;      // K   [origin=predictive method=joback]
Pc          13.090;      // bar [origin=predictive method=joback]
omega       0.8676;      // -   [origin=predictive method=lee-kesler]
Tb          794.06;      // K   [origin=predictive method=joback]
HvapTb      73277.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.126 2.1522 -0.00160526 5.175e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group dCH; count 1; } { group dC; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-butoxyphenyl)methyl (1r,3r)-2,2-dimethyl-3-(2-methylprop-1-enyl)cyclopropane-1-carboxylate" "cyclopropanecarboxylic acid, 2,2-dimethyl-3-(2-methyl-1-propenyl)-, (3-butoxyphenyl)methyl ester, (1r-trans)-" );
standardThermochemistry
{
    dHf_298   -546420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     807.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75140.0
}
