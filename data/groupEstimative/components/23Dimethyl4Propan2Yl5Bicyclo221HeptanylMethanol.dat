/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,3-dimethyl-4-propan-2-yl-5-bicyclo[2.2.1]heptanyl)methanol  (C13H24O, CAS 110458-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethyl4Propan2Yl5Bicyclo221HeptanylMethanol;
formula     C13H24O;
CAS         110458-84-9;
InChIKey    VFFUWAHBYYGDHT-UHFFFAOYSA-N;
MW          196.334;      // g/mol [origin=calculated method=formula-sum]
Tc          782.61;      // K   [origin=predictive method=joback]
Pc          21.938;      // bar [origin=predictive method=joback]
omega       0.8217;      // -   [origin=predictive method=lee-kesler]
Tb          592.76;      // K   [origin=predictive method=joback]
HvapTb      58743.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.099 1.78338 -0.0014774 5.349e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 5; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo(2.2.1)heptane-2-methanol, 5,6-dimethyl-1-(1-methylethyl)-" "bicyclo[2.2.1]heptane-2-methanol, 5,6-dimethyl-1-(1-methylethyl)-" "[5,6-dimethyl-1-(propan-2-yl)bicyclo[2.2.1]hept-2-yl]methanol" );
gibbsFormation
{
    dHf_298   -375500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100.0
    phase     gas;
}
