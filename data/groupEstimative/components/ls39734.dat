/*--------------------------------*- Choupo -*-----------------------*\
  Component: ls-39734  (C26H19F3O3, CAS 90034-99-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ls39734;
formula     C26H19F3O3;
CAS         90034-99-4;
InChIKey    WAZOZOZFCDFHKI-UHFFFAOYSA-N;
MW          436.429;      // g/mol [origin=calculated method=formula-sum]
Tc          1294.17;      // K   [origin=predictive method=joback]
Pc          16.701;      // bar [origin=predictive method=joback]
omega       1.2245;      // -   [origin=predictive method=lee-kesler]
Tb          1040.50;      // K   [origin=predictive method=joback]
HvapTb      99738.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-147.68 2.5059 -0.00202648 6.426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 12; } { group AC; count 3; } { group ACCH2; count 1; } { group ACCH; count 2; } { group OH; count 1; } { group C=C; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 8; } { group F; count 3; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanyl-3-[3-[4-(trifluoromethyl)phenyl]-1,2,3,4-tetrahydronaphthalen-1-yl]chromen-2-one" );
standardThermochemistry
{
    dHf_298   -804550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     740.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-428370.0
}
