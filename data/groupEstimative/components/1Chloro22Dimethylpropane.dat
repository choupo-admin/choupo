/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-2,2-dimethylpropane  (C5H11Cl, CAS 753-89-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro22Dimethylpropane;
formula     C5H11Cl;
CAS         753-89-9;
InChIKey    JEKYMVBQWWZVHO-UHFFFAOYSA-N;
MW          106.593;      // g/mol [origin=calculated method=formula-sum]
Tc          532.82;      // K   [origin=predictive method=joback]
Pc          33.960;      // bar [origin=predictive method=joback]
omega       0.2248;      // -   [origin=predictive method=lee-kesler]
Tb          348.20;      // K   [origin=predictive method=joback]
HvapTb      29813.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.239 0.61146 -0.0004404 1.292e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2,2-dimethyl-propane" "neopentyl chloride" "propane, 1-chloro-2,2-dimethyl-" "2,2-dimethylpropyl chloride" "propane,1-chloro-2,2-dimethyl-" );
gibbsFormation
{
    dHf_298   -171020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     345.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17870.0
    phase     gas;
}
