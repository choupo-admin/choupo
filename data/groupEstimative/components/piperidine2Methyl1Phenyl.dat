/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperidine, 2-methyl-1-phenyl-  (C12H17N, CAS 14142-16-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperidine2Methyl1Phenyl;
formula     C12H17N;
CAS         14142-16-6;
InChIKey    BBNBOKJANATNAE-UHFFFAOYSA-N;
MW          175.275;      // g/mol [origin=calculated method=formula-sum]
Tc          756.74;      // K   [origin=predictive method=joback]
Pc          28.874;      // bar [origin=predictive method=joback]
omega       0.4437;      // -   [origin=predictive method=lee-kesler]
Tb          528.56;      // K   [origin=predictive method=joback]
HvapTb      46882.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.1 1.32052 -0.0009002 2.34e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-1-phenyl-piperidine" "2-methyl-1-phenylpiperidine" );
standardThermochemistry
{
    dHf_298   73530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=309900.0
}
