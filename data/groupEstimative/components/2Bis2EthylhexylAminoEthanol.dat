/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[bis(2-ethylhexyl)amino]ethanol  (C18H39NO, CAS 101-07-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bis2EthylhexylAminoEthanol;
formula     C18H39NO;
CAS         101-07-5;
InChIKey    FMFWSIARXFCACS-UHFFFAOYSA-N;
MW          285.516;      // g/mol [origin=calculated method=formula-sum]
Tc          881.73;      // K   [origin=predictive method=joback]
Pc          12.398;      // bar [origin=predictive method=joback]
omega       1.0776;      // -   [origin=predictive method=lee-kesler]
Tb          715.18;      // K   [origin=predictive method=joback]
HvapTb      73608.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.238 1.88358 -0.0011048 2.492e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 11; } { group CH; count 2; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-di-(2-ethylhexyl)aminoethanol" "2-(bis(2-ethylhexyl)amino)ethanol" "ethanol, 2-[bis(2-ethylhexyl)amino]-" "ethanol, 2-(bis(2-ethylhexyl)amino)-" "ethanol,2-[bis(2-ethylhexyl)amino]-" );
standardThermochemistry
{
    dHf_298   -510110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     905.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69760.0
}
