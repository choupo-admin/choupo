/*--------------------------------*- Choupo -*-----------------------*\
  Component: ai3-36420  (C17H25NO, CAS 63937-47-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ai336420;
formula     C17H25NO;
CAS         63937-47-3;
InChIKey    UGWLNAQBMGWTIZ-UHFFFAOYSA-N;
MW          259.393;      // g/mol [origin=calculated method=formula-sum]
Tc          902.61;      // K   [origin=predictive method=joback]
Pc          18.740;      // bar [origin=predictive method=joback]
omega       0.8983;      // -   [origin=predictive method=lee-kesler]
Tb          697.94;      // K   [origin=predictive method=joback]
HvapTb      65385.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.684 1.75372 -0.00123466 3.4756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH2_ring; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3,4-dihydro-1h-isoquinolin-2-yl)octan-1-one" "1,2,3,4-tetrahydro-2-(1-oxooctyl)isoquinoline" "isoquinoline, 1,2,3,4-tetrahydro-2-octanoyl-" "isoquinoline, 1,2,3,4-tetrahydro-2-(1-oxooctyl)-" );
standardThermochemistry
{
    dHf_298   -121060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     700.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=245360.0
}
