/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(1-Butoxy-2-propoxy)-2-propanol  (C10H22O3, CAS 29911-28-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Butoxy2Propoxy2Propanol;
formula     C10H22O3;
CAS         29911-28-2;
InChIKey    CUVLMZNMSPJDON-UHFFFAOYSA-N;
MW          190.283;      // g/mol [origin=calculated method=formula-sum]
Tc          728.72;      // K   [origin=predictive method=joback]
Pc          22.590;      // bar [origin=predictive method=joback]
omega       1.0430;      // -   [origin=predictive method=lee-kesler]
Tb          564.54;      // K   [origin=predictive method=joback]
HvapTb      58577.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.725 0.87326 -0.000335 7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 2; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-butoxypropan-2-yloxy)propan-2-ol" "1-((1-Butoxypropan-2-yl)oxy)propan-2-ol" "1-(2-Butoxy-1-methylethoxy)-2-propanol" "2-Propanol, 1-(2-butoxy-1-methylethoxy)-" "celtol dpnb" "solvenon dpnb" "1-(2-Butoxy-1-methylethoxy)propan-2-ol" "dipropylene glycol monobutyl ether" "di(propylene glycol) butyl ether" "dipropyleneglycolmonobutylether" "1-[(1-Butoxy-2-propanyl)oxy]-2-propanol" "1-[(1-butoxypropan-2-yl)oxy]propan-2-ol" );
standardThermochemistry
{
    dHf_298   -676960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-318380.0
}
