/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyl isobutyrate  (C10H12O2, CAS 20279-29-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylIsobutyrate;
formula     C10H12O2;
CAS         20279-29-2;
InChIKey    PIZOACXKIKXRDJ-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          727.55;      // K   [origin=predictive method=joback]
Pc          29.730;      // bar [origin=predictive method=joback]
omega       0.5044;      // -   [origin=predictive method=lee-kesler]
Tb          512.86;      // K   [origin=predictive method=joback]
HvapTb      47149.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.38 0.82604 -0.00046 7.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenyl 2-methylpropanoate" "isobutyric acid phenyl ester" "isobutyric acid, phenyl ester" "2-methyl-propionic acid phenyl ester" );
gibbsFormation
{
    dHf_298   -335760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-167080.0
    phase     gas;
}
