/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2r)-2-hexadeca-11,13-diynoxyoxane  (C21H34O2, CAS 71673-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2r2Hexadeca1113Diynoxyoxane;
formula     C21H34O2;
CAS         71673-33-1;
InChIKey    DVYGANATDQMVTE-NRFANRHFSA-N;
MW          318.501;      // g/mol [origin=calculated method=formula-sum]
Tc          975.04;      // K   [origin=predictive method=joback]
Pc          13.369;      // bar [origin=predictive method=joback]
omega       0.8168;      // -   [origin=predictive method=lee-kesler]
Tb          767.00;      // K   [origin=predictive method=joback]
HvapTb      73993.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.869 1.75512 -0.00089042 1.4276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group tC; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2h-pyran, 2-(11,13-hexadecadiyn-1-yloxy)tetrahydro-" "2-((11,13-hexadecadiynyl)oxy)tetrahydro-2h-pyran" );
standardThermochemistry
{
    dHf_298   -142070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     846.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=364870.0
}
