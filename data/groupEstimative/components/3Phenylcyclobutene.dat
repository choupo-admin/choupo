/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylcyclobutene  (C10H10, CAS 20211-64-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenylcyclobutene;
formula     C10H10;
CAS         20211-64-7;
InChIKey    PTVHQPMLCSSVQD-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          698.79;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.3197;      // -   [origin=predictive method=lee-kesler]
Tb          465.25;      // K   [origin=predictive method=joback]
HvapTb      40507.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.69 0.9602 -0.00071248 2.069e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobut-2-en-1-ylbenzene" "1-cyclobut-2-enylbenzene" );
gibbsFormation
{
    dHf_298   111220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     331.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=224340.0
    phase     gas;
}
