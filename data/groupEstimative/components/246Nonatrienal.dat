/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-nonatrienal  (C9H12O, CAS 56269-22-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Nonatrienal;
formula     C9H12O;
CAS         56269-22-8;
InChIKey    XHDSWFFUGPJMMN-UHFFFAOYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          661.82;      // K   [origin=predictive method=joback]
Pc          29.155;      // bar [origin=predictive method=joback]
omega       0.4972;      // -   [origin=predictive method=lee-kesler]
Tb          466.66;      // K   [origin=predictive method=joback]
HvapTb      42222.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.439 0.89332 -0.0007102 2.36e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 3; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 6; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nona-2,4,6-trienal" "2,4,6-nonatrienal, (2e,4e,6z)-" "2,4,6-nonatrienal, (2e,4e,6e)-" "2,4,6-nonatrienal, (2e,4e,6e)-;nona-2,4,6-trienal" );
standardThermochemistry
{
    dHf_298   36990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=166040.0
}
