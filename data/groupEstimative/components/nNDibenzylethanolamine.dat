/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dibenzylethanolamine  (C16H19NO, CAS 101-06-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDibenzylethanolamine;
formula     C16H19NO;
CAS         101-06-4;
InChIKey    WTTWSMJHJFNCQB-UHFFFAOYSA-N;
MW          241.334;      // g/mol [origin=calculated method=formula-sum]
Tc          934.17;      // K   [origin=predictive method=joback]
Pc          24.950;      // bar [origin=predictive method=joback]
omega       1.1103;      // -   [origin=predictive method=lee-kesler]
Tb          723.66;      // K   [origin=predictive method=joback]
HvapTb      74484.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.866 1.5239 -0.001052 2.774e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(phenylmethyl)amino]ethanol" "2-(dibenzylamino)ethanol" "n,n-dibenzyl-2-aminoethanol" "2-(bis(phenylmethyl)amino)ethanol" "ethanol, 2-(bis(phenylmethyl)amino)-" "ethanol, 2-[bis(phenylmethyl)amino]-" "d 01" "ethanol, 2-(dibenzylamino)- (6ci,7ci,8ci)" "2-[bisbenzylamino]ethan-1-ol" "n-(2-hydroxyethyl)dibenzylamine" "wttwsmjhjfncqb-uhfffaoysa-" "ethanol,2-(dibenzylamino)- (6ci,7ci,8ci);2-(dibenzylamino)ethanol;2-[bis(phenylmethyl)amino]ethanol;d ol;n,n-dibenzyl-2-aminoethanol;n,n-dibenzyl-b-aminoethanol;b-(n,n-dibenzylamino)ethanol;" );
gibbsFormation
{
    dHf_298   14790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=282620.0
    phase     gas;
}
