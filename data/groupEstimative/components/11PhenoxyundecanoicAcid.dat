/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11-phenoxyundecanoic acid  (C17H26O3, CAS 7170-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11PhenoxyundecanoicAcid;
formula     C17H26O3;
CAS         7170-44-7;
InChIKey    FRSQLPPSRJNREN-UHFFFAOYSA-N;
MW          278.392;      // g/mol [origin=calculated method=formula-sum]
Tc          983.19;      // K   [origin=predictive method=joback]
Pc          16.701;      // bar [origin=predictive method=joback]
omega       1.1149;      // -   [origin=predictive method=lee-kesler]
Tb          783.17;      // K   [origin=predictive method=joback]
HvapTb      75286.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.37 1.5275 -0.0008938 1.898e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undecanoic acid, 11-phenoxy-" "undecanoic acid,11-phenoxy-" );
standardThermochemistry
{
    dHf_298   -640170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     776.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-244240.0
}
