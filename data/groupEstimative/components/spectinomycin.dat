/*--------------------------------*- Choupo -*-----------------------*\
  Component: spectinomycin  (C14H24N2O7, CAS 1695-77-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spectinomycin;
formula     C14H24N2O7;
CAS         1695-77-8;
InChIKey    UNFWWIHTNXNPBV-WXKVUWSESA-N;
MW          332.353;      // g/mol [origin=calculated method=formula-sum]
Tc          1297.01;      // K   [origin=predictive method=joback]
Pc          27.995;      // bar [origin=predictive method=joback]
omega       1.9030;      // -   [origin=predictive method=lee-kesler]
Tb          1059.26;      // K   [origin=predictive method=joback]
HvapTb      125038.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.68 1.94856 -0.0012693 3.439e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 5; } { group C; count 1; } { group OH; count 3; } { group CH2CO; count 1; } { group CH-O; count 3; } { group CH3NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 8; } { group C_ring; count 1; } { group OH; count 3; } { group O_ring; count 3; } { group CdO_ring; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "actinospectacin" "trobicin" "togamycin" "spectam" "espectinomicina" "spectinomycine" "spectinomycinum" "actinospectacina" "spectinomicina" "stanilo" "spectinomycine [inn-french]" "spectinomycinum [inn-latin]" );
standardThermochemistry
{
    dHf_298   -1134940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-475630.0
}
