/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl dehydroabietate  (C21H30O2, CAS 1235-74-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylDehydroabietate;
formula     C21H30O2;
CAS         1235-74-1;
InChIKey    PGZCJOPTDHWYES-HMXCVIKNSA-N;
MW          314.469;      // g/mol [origin=calculated method=formula-sum]
Tc          1025.06;      // K   [origin=predictive method=joback]
Pc          15.343;      // bar [origin=predictive method=joback]
omega       0.7598;      // -   [origin=predictive method=lee-kesler]
Tb          792.33;      // K   [origin=predictive method=joback]
HvapTb      70518.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-202.55 2.592 -0.00228172 8.634e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 1; } { group C; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (1r,4as,10ar)-1,4a-dimethyl-7-propan-2-yl-2,3,4,9,10,10a-hexahydrophenanthrene-1-carboxylate" "methyl 8,13-abietatrien-18-oate" "methyl dehydroabietyate" "podocarpa-8,13-trien-15-oic acid, 13-isopropyl-, methyl ester" "1,3,4,4a,9,10,10a-octahydro-1,4a-dimethyl-7-(1-methylethyl)-1-phenanthrenecarboxylic acid, methyl ester" "1-phenanthrenecarboxylic acid,2,3,4,4a,9,10,10a-octahydro-1,4a-dimethyl-7-(1-methylethyl)-, methyl ester, [1r-(1.alpha.,4a.beta.,10a.alpha.)]-" "1-phenanthrenecarboxylic acid,1,2,3,4,4a,9,10,10a-octahydro-1,4a-dimethyl-7-(1-methylethyl)-, methyl ester, (1r,4as,10ar)-" "methyl 8,11,13-abietatrien-18-oate" "podocarpa-8,11,13-trien-15-oic acid, 13-isopropyl-, methyl ester (8ci)" "1-phenanthrenecarboxylic acid, 1,2,3,4,4a,9,10,10a-octahydro-1,4a-dimethyl-7-(1-methylethyl)-,methyl ester, (1r-(1alpha,4abeta,10aalpha))- (9ci)" );
standardThermochemistry
{
    dHf_298   -442320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     853.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15110.0
}
