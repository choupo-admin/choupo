/*--------------------------------*- Choupo -*-----------------------*\
  Component: triisovalerin  (C18H32O6, CAS 620-63-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triisovalerin;
formula     C18H32O6;
CAS         620-63-3;
InChIKey    HZGMZSCMYSGJTL-UHFFFAOYSA-N;
MW          344.448;      // g/mol [origin=calculated method=formula-sum]
Tc          970.64;      // K   [origin=predictive method=joback]
Pc          11.899;      // bar [origin=predictive method=joback]
omega       0.9984;      // -   [origin=predictive method=lee-kesler]
Tb          784.34;      // K   [origin=predictive method=joback]
HvapTb      76331.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.025 1.57312 -0.0006844 2.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 4; } { group CH2COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 5; } { group CH; count 4; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(3-methylbutanoyloxy)propyl 3-methylbutanoate" "glycerol triisovalerate" "glycerol triisopentanoate" "propane-1,2,3-triyl tris(3-methylbutanoate)" "butanoic acid, 3-methyl-, 1,2,3-propanetriyl ester" "1,2,3-propanetriyl 3-methylbutanoate" "butanoic acid, 3-methyl-, 1,1',1''-(1,2,3-propanetriyl) ester" "isovalerin, tri" "isovalerin, tri (6ci)" "isovaleric acid,2,3-propanetriyl ester" "isovaleric acid, 1,2,3-propanetriyl ester" "isovaleric acid, 1,2,3-propanetriyl ester (8ci)" );
standardThermochemistry
{
    dHf_298   -1387810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     972.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-840190.0
}
