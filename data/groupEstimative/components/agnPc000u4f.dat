/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-000u4f  (C23H46O5, CAS 71010-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc000u4f;
formula     C23H46O5;
CAS         71010-66-7;
InChIKey    FWGDUBYAYWFEHL-UHFFFAOYSA-N;
MW          402.616;      // g/mol [origin=calculated method=formula-sum]
Tc          1347.06;      // K   [origin=predictive method=joback]
Pc          10.286;      // bar [origin=predictive method=joback]
omega       0.6024;      // -   [origin=predictive method=lee-kesler]
Tb          1056.93;      // K   [origin=predictive method=joback]
HvapTb      122552.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.892 2.36774 -0.001399 3.062e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 17; } { group CH; count 1; } { group C; count 1; } { group OH; count 3; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group CH; count 1; } { group C; count 1; } { group OH; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2-bis(hydroxymethyl)-3-oxidanyl-propyl] 16-methylheptadecanoate" "1,3-propanediol, 2,2-bis(hydroxymethyl)-, homopolymer, isooctadecanoate" "isooctadecanoic acid, 3-hydroxy-2,2-bis(hydroxymethyl)propyl ester" );
gibbsFormation
{
    dHf_298   -1306050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1207.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-577650.0
    phase     gas;
}
