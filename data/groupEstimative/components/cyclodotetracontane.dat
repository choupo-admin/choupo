/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclodotetracontane  (C42H84, CAS 297-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclodotetracontane;
formula     C42H84;
CAS         297-58-5;
InChIKey    HGYWDMKVEUIDAK-UHFFFAOYSA-N;
MW          589.134;      // g/mol [origin=calculated method=formula-sum]
Tc          1646.57;      // K   [origin=predictive method=joback]
Pc          5.914;      // bar [origin=predictive method=joback]
omega       0.4491;      // -   [origin=predictive method=lee-kesler]
Tb          1338.50;      // K   [origin=predictive method=joback]
HvapTb      116016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-291.19 3.7968 -0.000727 -5.5e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 42; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 42; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-02xf9s" );
gibbsFormation
{
    dHf_298   -1057310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     2521.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-100680.0
    phase     gas;
}
