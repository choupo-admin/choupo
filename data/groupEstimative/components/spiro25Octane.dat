/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro(2.5)octane  (C8H14, CAS 185-65-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro25Octane;
formula     C8H14;
CAS         185-65-9;
InChIKey    FOEYMRPOKBCNCR-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          630.01;      // K   [origin=predictive method=joback]
Pc          39.160;      // bar [origin=predictive method=joback]
omega       0.2534;      // -   [origin=predictive method=lee-kesler]
Tb          409.57;      // K   [origin=predictive method=joback]
HvapTb      32730.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-171.04 1.3648 -0.001347 5.49e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro[2.5]octane" "spiro[2,5]octane" );
gibbsFormation
{
    dHf_298   -39590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116000.0
    phase     gas;
}
