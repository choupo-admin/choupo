/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-aminobenzyl alcohol  (C7H9NO, CAS 1877-77-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3AminobenzylAlcohol;
formula     C7H9NO;
CAS         1877-77-6;
InChIKey    OJZQOQNSUZLSMV-UHFFFAOYSA-N;
MW          123.155;      // g/mol [origin=calculated method=formula-sum]
Tc          767.59;      // K   [origin=predictive method=joback]
Pc          49.246;      // bar [origin=predictive method=joback]
omega       0.9197;      // -   [origin=predictive method=lee-kesler]
Tb          556.13;      // K   [origin=predictive method=joback]
HvapTb      61434.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.299 0.6263 -0.00039496 9.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group OH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-aminophenyl)methanol" "3-(hydroxymethyl)aniline" "m-aminobenzyl alcohol" "benzyl alcohol, m-amino-" "benzenemethanol, 3-amino-" "3-aminobenzylalcohol" "3-aminobenzenemethanol" "(3-aminophenyl)methan-1-ol" "3-amniobenzyl alcohol" "benzenemethanol, 3-amino- (9ci)" );
gibbsFormation
{
    dHf_298   -81190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40470.0
    phase     gas;
}
