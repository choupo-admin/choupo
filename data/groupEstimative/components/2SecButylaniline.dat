/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-sec-butylaniline  (C10H15N, CAS 55751-54-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2SecButylaniline;
formula     C10H15N;
CAS         55751-54-7;
InChIKey    XAGPXEVNCJHXCL-UHFFFAOYSA-N;
MW          149.237;      // g/mol [origin=calculated method=formula-sum]
Tc          754.06;      // K   [origin=predictive method=joback]
Pc          30.967;      // bar [origin=predictive method=joback]
omega       0.5289;      // -   [origin=predictive method=lee-kesler]
Tb          532.15;      // K   [origin=predictive method=joback]
HvapTb      51045.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.999 0.88324 -0.00053096 1.189e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butan-2-ylaniline" "2-(sec-butyl)aniline" "benzenamine, 2-(1-methylpropyl)-" "2-(methylpropyl)phenylamine" "2-sec-butylbenzenamine" "aniline, o-sec-butyl-" "agn-pc-03fes3" "benzenamine,2-(1-methylpropyl)-" "aniline,o-sec-butyl- (6ci); (rs)-2-sec-butylaniline; 2-sec-butylaniline;2-sec-butylbenzenamine; o-sec-butylaniline" );
standardThermochemistry
{
    dHf_298   3840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=200110.0
}
