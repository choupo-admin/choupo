/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl 2-chloropropanoate  (C6H9ClO2, CAS 55360-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allyl2Chloropropanoate;
formula     C6H9ClO2;
CAS         55360-11-7;
InChIKey    FDCTVCOKDZZPRP-UHFFFAOYSA-N;
MW          148.586;      // g/mol [origin=calculated method=formula-sum]
Tc          617.74;      // K   [origin=predictive method=joback]
Pc          31.704;      // bar [origin=predictive method=joback]
omega       0.4520;      // -   [origin=predictive method=lee-kesler]
Tb          428.77;      // K   [origin=predictive method=joback]
HvapTb      39684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.061 0.51172 -0.0002545 2.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CHCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl 2-chloranylpropanoate" "propanoic acid, 2-chloro-, 2-propenyl ester" "allyl 2-chloropropionate" "allyl alpha-chloropropionate" "2-propenyl 2-chloropropanoate" "2-propynyl 2-chloropropionate" "prop-2-enyl 2-chloropropanoate" );
gibbsFormation
{
    dHf_298   -380040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-237260.0
    phase     gas;
}
