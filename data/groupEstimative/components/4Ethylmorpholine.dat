/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethylmorpholine  (C6H13NO, CAS 100-74-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethylmorpholine;
formula     C6H13NO;
CAS         100-74-3;
InChIKey    HVCNXQOWACZAFN-UHFFFAOYSA-N;
MW          115.176;      // g/mol [origin=calculated method=formula-sum]
Tc          591.13;      // K   [origin=predictive method=joback]
Pc          39.456;      // bar [origin=predictive method=joback]
omega       0.3762;      // -   [origin=predictive method=lee-kesler]
Tb          396.22;      // K   [origin=predictive method=joback]
HvapTb      36069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.359 0.85292 -0.0005841 1.566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethylmorpholine" "morpholine, 4-ethyl-" "ethylmorpholine" "n-ethyl morpholine" "n-ethyl-morpholine" "n-ethylmorfolin" "4-ethyl-morpholine" "n-ethylmorpholine, reag" );
gibbsFormation
{
    dHf_298   -150820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=68560.0
    phase     gas;
}
