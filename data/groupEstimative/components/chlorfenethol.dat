/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorfenethol  (C14H12Cl2O, CAS 80-06-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorfenethol;
formula     C14H12Cl2O;
CAS         80-06-8;
InChIKey    URYAFVKLYSEINW-UHFFFAOYSA-N;
MW          267.149;      // g/mol [origin=calculated method=formula-sum]
Tc          986.38;      // K   [origin=predictive method=joback]
Pc          27.906;      // bar [origin=predictive method=joback]
omega       0.9683;      // -   [origin=predictive method=lee-kesler]
Tb          747.05;      // K   [origin=predictive method=joback]
HvapTb      76787.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.45 1.23042 -0.00090912 2.563e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group OH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(4-chlorophenyl)ethanol" "micasin" "mikazene" "quickron" "qikron" "dimit" "4,4'-dichloro-alpha-methylbenzhydrol" "bcpe" "dcpc" "dcpe" "dimite" "dichlorodiphenylethanol" );
standardThermochemistry
{
    dHf_298   -74630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114720.0
}
