/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrakis(2-ethylhexoxy)silane  (C32H68O4Si, CAS 115-82-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C32H68O4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetrakis2EthylhexoxySilane;
formula     C32H68O4Si;
CAS         115-82-2;
InChIKey    MQHSFMJHURNQIE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          544.977;      // g/mol [origin=calculated method=formula-sum]
Tc          1281.32;      // K   [origin=predictive method=joback]
Pc          5.059;      // bar [origin=predictive method=joback]
omega       0.1747;      // -   [origin=predictive method=lee-kesler]
Tb          1021.08;      // K   [origin=predictive method=joback]
HvapTb      95208.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (109.89 2.60856 -0.000871 -6.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 16; } { group CH; count 4; } { group CH2O; count 4; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 20; } { group CH; count 4; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrakis(2-ethylhexyl) silicate" "tetrakis(2-ethylhexyl) orthosilicate" "2-ethylhexyl orthosilicate" "2-ethylhexanol tetrasilicate" "2-ethyl-1-hexanol silicate" "tetra(2-ethylhexoxy) silane" "tetra(2-ethylhexyl) silicate" "tetra(2-ethylhexyl) orthosilicate" "1-hexanol, tetraester with silicic acid" "silicic acid (h4sio4),tetrakis(2-ethylhexyl) ester" "tetrakis(2-ethylhexyl) orthosilicate; 1-hexanol, 2-ethyl-, tetraester with silicic acid; silicic acid (h4sio4), tetrakis(2-ethylhexyl) ester; tetra(2-ethylhexyl) orthosilicate; tetrakis(2-ethylhexyl)" );
gibbsFormation
{
    dHf_298   -1365430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1535.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-315960.0
    phase     gas;
}
