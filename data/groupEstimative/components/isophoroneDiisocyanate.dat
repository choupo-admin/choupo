/*--------------------------------*- Choupo -*-----------------------*\
  Component: isophorone diisocyanate  (C12H18N2O2, CAS 4098-71-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isophoroneDiisocyanate;
formula     C12H18N2O2;
CAS         4098-71-9;
InChIKey    NIMLQBUJDJZYEJ-UHFFFAOYSA-N;
MW          222.288;      // g/mol [origin=calculated method=formula-sum]
Tc          841.00;      // K   [origin=predictive method=joback]
Pc          25.176;      // bar [origin=predictive method=joback]
omega       0.6772;      // -   [origin=predictive method=lee-kesler]
Tb          618.19;      // K   [origin=predictive method=joback]
HvapTb      58879.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCd; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethyl-cyclohexane" "ipdi" "5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethylcyclohexane" "isophorone diamine diisocyanate" "cyclohexane, 5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethyl-" "3-isocyanatomethyl-3,5,5-trimethylcyclohexyl isocyanate" "3-isocyanatomethyl-3,5,5-trimethylcyclohexylisocyanate" "isocyanic acid, methylene(3,5,5-trimethyl-3,1-cyclohexylene) ester" "isophorone diisocyanate [diisocyanates]" "agn-pc-03f4l6" "cyclohexane, 5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethyl-, homopolymer" "methylene(3,5,5-trimethyl-3,1-cyclohexylene) ester" );
