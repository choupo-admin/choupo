/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-di-tert-butylcatechol  (C14H22O2, CAS 1020-31-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35DiTertButylcatechol;
formula     C14H22O2;
CAS         1020-31-1;
InChIKey    PJZLSMMERMMQBJ-UHFFFAOYSA-N;
MW          222.328;      // g/mol [origin=calculated method=formula-sum]
Tc          944.72;      // K   [origin=predictive method=joback]
Pc          27.412;      // bar [origin=predictive method=joback]
omega       0.8499;      // -   [origin=predictive method=lee-kesler]
Tb          706.36;      // K   [origin=predictive method=joback]
HvapTb      73132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.23 1.75632 -0.00155828 5.66e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-ditert-butylbenzene-1,2-diol" "3,5-di-tert-butylpyrocatechol" "3,5-di-t-butylcatechol" "1,2-benzenediol, 3,5-bis(1,1-dimethylethyl)-" "4,6-di-tert-butylpyrocatechol" "1,2-benzenediol, 3,5-di(1,1-dimethylethyl)-" "3,5-di-tert-butylbenzene-1,2-diol" "3,5-bis(tert-butyl)benzene-1,2-diol" "3,5-ditert-butyl-catechol" "3,5-di(tert-butyl)catechol" "pyrocatechol,5-di-tert-butyl-" "pyrocatechol, 3,5-di-tert-butyl-" );
standardThermochemistry
{
    dHf_298   -479350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133780.0
}
