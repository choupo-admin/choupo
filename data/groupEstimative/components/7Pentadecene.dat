/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-pentadecene  (C15H30, CAS 15430-98-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Pentadecene;
formula     C15H30;
CAS         15430-98-5;
InChIKey    ZXFYKYSBFXNVIG-UHFFFAOYSA-N;
MW          210.405;      // g/mol [origin=calculated method=formula-sum]
Tc          712.06;      // K   [origin=predictive method=joback]
Pc          14.725;      // bar [origin=predictive method=joback]
omega       0.6818;      // -   [origin=predictive method=lee-kesler]
Tb          546.96;      // K   [origin=predictive method=joback]
HvapTb      48942.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.929 1.44884 -0.000876 2.147e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadec-7-ene" "8-pentadecene" "7-pentadecene, (e)-" "7-pentadecene, (z)-" );
standardThermochemistry
{
    dHf_298   -235710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     733.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=155640.0
}
