/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyltetrahydrofuran  (C6H12O, CAS 1003-30-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyltetrahydrofuran;
formula     C6H12O;
CAS         1003-30-1;
InChIKey    IHMXVSZXHFTOFN-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          575.46;      // K   [origin=predictive method=joback]
Pc          37.963;      // bar [origin=predictive method=joback]
omega       0.2923;      // -   [origin=predictive method=lee-kesler]
Tb          379.11;      // K   [origin=predictive method=joback]
HvapTb      33717.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.729 0.70252 -0.0004161 9.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyloxolane" "furan, 2-ethyltetrahydro-" "agn-pc-0d14yi" );
standardThermochemistry
{
    dHf_298   -238690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     287.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49930.0
}
