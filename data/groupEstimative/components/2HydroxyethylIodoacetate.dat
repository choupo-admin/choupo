/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyethyl iodoacetate  (C4H7IO3, CAS 63906-36-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyethylIodoacetate;
formula     C4H7IO3;
CAS         63906-36-5;
InChIKey    FOIIJWYEDSCAHL-UHFFFAOYSA-N;
MW          229.997;      // g/mol [origin=calculated method=formula-sum]
Tc          733.70;      // K   [origin=predictive method=joback]
Pc          42.887;      // bar [origin=predictive method=joback]
omega       0.8935;      // -   [origin=predictive method=lee-kesler]
Tb          534.66;      // K   [origin=predictive method=joback]
HvapTb      57957.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.643 0.402 -0.000211 2.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 1; } { group CH2COO; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group I; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hydroxyethyl 2-iodanylethanoate" "acetic acid, iodo-, monoester with ethylene glycol" "2-hydroxyethyl 2-iodoacetate" );
standardThermochemistry
{
    dHf_298   -518530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-406270.0
}
