/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-2,2,3,4,5,5-hexamethylhex-3-ene  (C12H24, CAS 54290-40-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e223455Hexamethylhex3Ene;
formula     C12H24;
CAS         54290-40-3;
InChIKey    UKVHFKANOLLXHC-UHFFFAOYSA-N;
MW          168.324;      // g/mol [origin=calculated method=formula-sum]
Tc          668.03;      // K   [origin=predictive method=joback]
Pc          19.407;      // bar [origin=predictive method=joback]
omega       0.3209;      // -   [origin=predictive method=lee-kesler]
Tb          471.62;      // K   [origin=predictive method=joback]
HvapTb      39832.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.53 1.41536 -0.001061 3.264e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group C; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group C; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,4,5,5-hexamethylhex-3-ene" "(z)-2,2,3,4,5,5-hexamethylhex-3-ene" );
gibbsFormation
{
    dHf_298   -210870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118960.0
    phase     gas;
}
