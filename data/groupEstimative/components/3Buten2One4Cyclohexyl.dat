/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-buten-2-one, 4-cyclohexyl-  (C10H16O, CAS 7152-32-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Buten2One4Cyclohexyl;
formula     C10H16O;
CAS         7152-32-1;
InChIKey    PZJXLLHDHUDWFH-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          723.27;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.4531;      // -   [origin=predictive method=lee-kesler]
Tb          505.98;      // K   [origin=predictive method=joback]
HvapTb      44987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.63 1.06792 -0.0006663 1.5576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH=CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-cyclohexylbut-3-en-2-one" "agn-pc-04uyd0" );
gibbsFormation
{
    dHf_298   -190770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9070.0
    phase     gas;
}
