/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-(-)-n-methyl-1-(1-naphthyl)ethylamine  (C13H15N, CAS 20218-55-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sNMethyl11NaphthylEthylamine;
formula     C13H15N;
CAS         20218-55-7;
InChIKey    YYETYHLXPGYQPZ-JTQLQIEISA-N;
MW          185.27;      // g/mol [origin=calculated method=formula-sum]
Tc          827.57;      // K   [origin=predictive method=joback]
Pc          28.173;      // bar [origin=predictive method=joback]
omega       0.6170;      // -   [origin=predictive method=lee-kesler]
Tb          597.41;      // K   [origin=predictive method=joback]
HvapTb      55158.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.87 1.17884 -0.00083608 2.352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 7; } { group AC; count 2; } { group ACCH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s)-n-methyl-1-naphthalen-1-yl-ethanamine" "(s)-n-methyl-1-(1-naphthyl)ethylamine" "methyl[(1s)-1-(naphthalen-1-yl)ethyl]amine" "1-naphthalenemethanamine,n,a-dimethyl-, (as)-" "1-naphthalenemethanamine,n,a-dimethyl-, (s)-;(s)-(-)-n-methyl-1-(1-naphthyl)ethylamine;" );
gibbsFormation
{
    dHf_298   152670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=354960.0
    phase     gas;
}
