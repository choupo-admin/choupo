/*--------------------------------*- Choupo -*-----------------------*\
  Component: dihydronootkatone  (C15H24O, CAS 20489-53-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dihydronootkatone;
formula     C15H24O;
CAS         20489-53-6;
InChIKey    NMALGKNZYKRHCE-CXTNEJHOSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          863.51;      // K   [origin=predictive method=joback]
Pc          19.983;      // bar [origin=predictive method=joback]
omega       0.4955;      // -   [origin=predictive method=lee-kesler]
Tb          628.64;      // K   [origin=predictive method=joback]
HvapTb      51386.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.08 1.74276 -0.00125 3.941e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,4as,6r,8as)-4,4a-dimethyl-6-prop-1-en-2-yl-1,3,4,5,6,7,8,8a-octahydronaphthalen-2-one" "1,10-dihydronootkatone" "4betah,5alpha-eremophil-11-en-2-one" "2(1h)-naphthalenone, octahydro-4,4a-dimethyl-6-(1-methylethenyl)-, (4r-(4alpha,4aalpha,6beta,8abeta))-" "octahydro-4,4a-dimethyl-6-(1-methylethenyl)-2(1h)-naphthalenone, (4r-(4alpha,4aalpha,6beta,8abeta))-" );
standardThermochemistry
{
    dHf_298   -279470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=84310.0
}
