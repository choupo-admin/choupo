/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-hexen-2-one, 6-phenyl-  (C12H14O, CAS 69371-59-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Hexen2One6Phenyl;
formula     C12H14O;
CAS         69371-59-1;
InChIKey    FQAGFMVFSPYMEW-UHFFFAOYSA-N;
MW          174.243;      // g/mol [origin=calculated method=formula-sum]
Tc          776.45;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       0.5785;      // -   [origin=predictive method=lee-kesler]
Tb          558.87;      // K   [origin=predictive method=joback]
HvapTb      51286.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.748 1.05692 -0.0007253 1.9546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-phenylhex-5-en-2-one" "agn-pc-00g7bg" );
standardThermochemistry
{
    dHf_298   -49840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113870.0
}
