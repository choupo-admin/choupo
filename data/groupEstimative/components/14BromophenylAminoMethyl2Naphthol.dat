/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-{[(4-bromophenyl)amino]methyl}-2-naphthol  (C17H14BrNO, CAS 6638-14-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BromophenylAminoMethyl2Naphthol;
formula     C17H14BrNO;
CAS         6638-14-8;
InChIKey    OIYPMGJFMGVYMC-UHFFFAOYSA-N;
MW          328.209;      // g/mol [origin=calculated method=formula-sum]
Tc          1135.33;      // K   [origin=predictive method=joback]
Pc          32.954;      // bar [origin=predictive method=joback]
omega       1.1588;      // -   [origin=predictive method=lee-kesler]
Tb          867.81;      // K   [origin=predictive method=joback]
HvapTb      86837.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.159 1.6073 -0.0013424 4.511e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 5; } { group ACOH; count 1; } { group CH2NH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 6; } { group Br; count 1; } { group OH_phenol; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[[(4-bromophenyl)amino]methyl]naphthalen-2-ol" "1-[(4-bromoanilino)methyl]naphthalen-2-ol" "1-{[(4-bromophenyl)amino]methyl}naphthalen-2-ol" "2-naphthalenol,1-[[(4-bromophenyl)amino]methyl]-" );
gibbsFormation
{
    dHf_298   149470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=353560.0
    phase     gas;
}
