/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylbenzhydrol  (C14H14O, CAS 5472-13-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylbenzhydrol;
formula     C14H14O;
CAS         5472-13-9;
InChIKey    MXHXXJOHFRHBFB-UHFFFAOYSA-N;
MW          198.265;      // g/mol [origin=calculated method=formula-sum]
Tc          895.03;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.9185;      // -   [origin=predictive method=lee-kesler]
Tb          670.00;      // K   [origin=predictive method=joback]
HvapTb      68263.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.74 1.15642 -0.00076676 1.908e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methylphenyl)-phenyl-methanol" "o-methylbenzhydrol" "(2-methylphenyl)phenylmethanol" "benzhydrol, 2-methyl-" "phenyl(o-tolyl)methanol" "phenyl-o-tolyl-methanol" "benzenemethanol, 2-methyl-.alpha.-phenyl-" "(2-methylphenyl)-phenylmethanol" "(2-methylphenyl)phenylmethan-1-ol" "2-methyl benzhydrol" "2-methyl-benzhydrol" "2-methyldiphenylmethanol" );
standardThermochemistry
{
    dHf_298   -28210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=142930.0
}
