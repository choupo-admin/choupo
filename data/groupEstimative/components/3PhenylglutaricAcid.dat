/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylglutaric acid  (C11H12O4, CAS 4165-96-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3PhenylglutaricAcid;
formula     C11H12O4;
CAS         4165-96-2;
InChIKey    RZOKZOYSUCSPDF-UHFFFAOYSA-N;
MW          208.213;      // g/mol [origin=calculated method=formula-sum]
Tc          997.24;      // K   [origin=predictive method=joback]
Pc          32.393;      // bar [origin=predictive method=joback]
omega       1.2324;      // -   [origin=predictive method=lee-kesler]
Tb          768.54;      // K   [origin=predictive method=joback]
HvapTb      76296.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.498 1.0774 -0.0007542 2.007e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylpentanedioic acid" "3-phenyl-pentanedioic acid" "pentanedioic acid, 3-phenyl-" "glutaricacid, 3-phenyl- (6ci,7ci,8ci); 3-phenylglutaric acid; 3-phenylpentanedioicacid; b-phenylglutaric acid" );
gibbsFormation
{
    dHf_298   -739660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-536110.0
    phase     gas;
}
