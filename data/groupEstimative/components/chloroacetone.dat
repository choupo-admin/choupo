/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloroacetone  (C3H5ClO, CAS 78-95-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloroacetone;
formula     C3H5ClO;
CAS         78-95-5;
InChIKey    BULLHNJGPPOUOX-UHFFFAOYSA-N;
MW          92.522;      // g/mol [origin=calculated method=formula-sum]
Tc          548.07;      // K   [origin=predictive method=joback]
Pc          45.654;      // bar [origin=predictive method=joback]
omega       0.3388;      // -   [origin=predictive method=lee-kesler]
Tb          359.54;      // K   [origin=predictive method=joback]
HvapTb      33403.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.411 0.26762 -0.0001411 2.446e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylpropan-2-one" "1-chloropropan-2-one" "2-propanone, 1-chloro-" "chloropropanone" "acetonyl chloride" "monochloroacetone" "1-chloroacetone" "tonite" "monochloracetone" "3-chloro-2-propanone" "1-chloro-2-propanone" "acetone, chloro-" );
gibbsFormation
{
    dHf_298   -233570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     332.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-166470.0
    phase     gas;
}
