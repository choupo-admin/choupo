/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-penten-1-yne, 4-methyl-3-(1-methylethyl)-  (C9H14, CAS 61786-07-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Penten1Yne4Methyl31Methylethyl;
formula     C9H14;
CAS         61786-07-0;
InChIKey    KKGAIKSIOQULJJ-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          594.65;      // K   [origin=predictive method=joback]
Pc          28.781;      // bar [origin=predictive method=joback]
omega       0.2657;      // -   [origin=predictive method=lee-kesler]
Tb          399.12;      // K   [origin=predictive method=joback]
HvapTb      35216.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.76 0.79068 -0.00055333 1.6479e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 1; } { group CH_C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dC; count 2; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-3-propan-2-yl-pent-3-en-1-yne" "4-methyl-3-propan-2-ylpent-3-en-1-yne" );
standardThermochemistry
{
    dHf_298   155170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=308650.0
}
