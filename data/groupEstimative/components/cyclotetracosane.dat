/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclotetracosane  (C24H48, CAS 297-03-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclotetracosane;
formula     C24H48;
CAS         297-03-0;
InChIKey    OOTMSKDHDITFHF-UHFFFAOYSA-N;
MW          336.648;      // g/mol [origin=calculated method=formula-sum]
Tc          1121.11;      // K   [origin=predictive method=joback]
Pc          12.451;      // bar [origin=predictive method=joback]
omega       0.4802;      // -   [origin=predictive method=lee-kesler]
Tb          849.80;      // K   [origin=predictive method=joback]
HvapTb      72852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-182.65 2.2596 -0.000583 -2.26e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 24; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 24; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -574910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1461.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34440.0
    phase     gas;
}
