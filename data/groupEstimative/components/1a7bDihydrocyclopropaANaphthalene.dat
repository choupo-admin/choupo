/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1a,7b-dihydrocyclopropa[a]naphthalene  (C11H10, CAS 3463-79-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1a7bDihydrocyclopropaANaphthalene;
formula     C11H10;
CAS         3463-79-4;
InChIKey    ZCFVFGSTMMICOZ-UHFFFAOYSA-N;
MW          142.201;      // g/mol [origin=calculated method=formula-sum]
Tc          722.85;      // K   [origin=predictive method=joback]
Pc          35.137;      // bar [origin=predictive method=joback]
omega       0.3940;      // -   [origin=predictive method=lee-kesler]
Tb          491.31;      // K   [origin=predictive method=joback]
HvapTb      42964.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.3 1.1658 -0.00101284 3.53e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1a,7b-dihydro-1h-cyclopropa[a]naphthalene" "1a,7b-dihydrocyclopropa(a)naphthalene" );
gibbsFormation
{
    dHf_298   164230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     234.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=308080.0
    phase     gas;
}
