/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,5-dimethyldihydrofuran-2(3h)-one  (C6H10O2, CAS 6971-63-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        45Dimethyldihydrofuran23hOne;
formula     C6H10O2;
CAS         6971-63-7;
InChIKey    PXIPZIPSDBXFQR-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          585.30;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.3843;      // -   [origin=predictive method=lee-kesler]
Tb          397.17;      // K   [origin=predictive method=joback]
HvapTb      35961.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.46 0.64344 -0.0003728 7.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,5-dimethyloxolan-2-one" "4-hydroxy-3-methylpentanoic acid lactone" "2(3h)-furanone, dihydro-4,5-dimethyl-" "(s)-methyl 2-(tert-butoxycarbonyl)-2-(dimethoxyphosphoryl)acetate" );
gibbsFormation
{
    dHf_298   -431990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     308.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-257690.0
    phase     gas;
}
