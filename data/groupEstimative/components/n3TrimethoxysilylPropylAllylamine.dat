/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(3-(trimethoxysilyl)propyl)allylamine  (C9H21NO3Si, CAS 31024-46-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H21NO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        n3TrimethoxysilylPropylAllylamine;
formula     C9H21NO3Si;
CAS         31024-46-1;
InChIKey    UBVMBXTYMSRUDX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          219.356;      // g/mol [origin=calculated method=formula-sum]
Tc          695.68;      // K   [origin=predictive method=joback]
Pc          20.699;      // bar [origin=predictive method=joback]
omega       0.7003;      // -   [origin=predictive method=lee-kesler]
Tb          521.03;      // K   [origin=predictive method=joback]
HvapTb      48918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (107.824 0.51926 0.0002105 -2.578e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 1; } { group CH3O; count 3; } { group CH2NH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 3; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-prop-2-enyl-3-trimethoxysilyl-propan-1-amine" "3-(n-allylamino)propyltrimethoxysilane" "2-propen-1-amine, n-(3-(trimethoxysilyl)propyl)-" "2-propen-1-amine, n-[3-(trimethoxysilyl)propyl]-" "trimethoxysilylpropylallylamine" "n-prop-2-enyl-3-trimethoxysilylpropan-1-amine" );
gibbsFormation
{
    dHf_298   -558470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     702.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-217630.0
    phase     gas;
}
