/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-benzenedimethanamine, n,n,n',n'-tetraethyl-  (C16H28N2, CAS 40828-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BenzenedimethanamineNNNNTetraethyl;
formula     C16H28N2;
CAS         40828-00-0;
InChIKey    AALVUMWHVZETDU-UHFFFAOYSA-N;
MW          248.414;      // g/mol [origin=calculated method=formula-sum]
Tc          808.60;      // K   [origin=predictive method=joback]
Pc          16.769;      // bar [origin=predictive method=joback]
omega       0.7816;      // -   [origin=predictive method=lee-kesler]
Tb          622.22;      // K   [origin=predictive method=joback]
HvapTb      58234.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.644 1.63328 -0.00103596 2.546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group ACH; count 4; } { group ACCH2; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[[4-(diethylaminomethyl)phenyl]methyl]-n-ethyl-ethanamine" "1,4-benzenedimethanamine, n1,n1,n4,n4-tetraethyl-" "n-[[4-(diethylaminomethyl)phenyl]methyl]-n-ethylethanamine" );
gibbsFormation
{
    dHf_298   -13450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     698.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=408180.0
    phase     gas;
}
