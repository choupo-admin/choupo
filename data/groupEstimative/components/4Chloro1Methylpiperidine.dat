/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-1-methylpiperidine  (C6H12ClN, CAS 5570-77-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro1Methylpiperidine;
formula     C6H12ClN;
CAS         5570-77-4;
InChIKey    MYGXGCCFTPKWIH-UHFFFAOYSA-N;
MW          133.619;      // g/mol [origin=calculated method=formula-sum]
Tc          603.97;      // K   [origin=predictive method=joback]
Pc          36.598;      // bar [origin=predictive method=joback]
omega       0.3200;      // -   [origin=predictive method=lee-kesler]
Tb          402.03;      // K   [origin=predictive method=joback]
HvapTb      35635.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.85 0.83622 -0.000563 1.461e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH3N; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-1-methyl-piperidine" "4-chloro-n-methylpiperidine" "n-methyl-4-chloropiperidine" "4-chlor-1-methylpiperidin" "1-methyl-4-chloropiperidine" "n-methyl-4-chloro-piperidine" "piperidine, 4-chloro-1-methyl-" "4-chloro-n-methylpiperidine hydrochloride" "4-chloro-1-methyl-piperidine" "1-methyl-4-chloro-piperidine" "h587" "1-methyl-4-chloropiperidine;1-methyl-4-piperidinyl chloride;1-methyl-4-piperidyl chloride;4-chloro-1-methylpiperidine;n-methyl-4-chloropiperidine;piperidine,4-chloro-1-methyl-;" );
standardThermochemistry
{
    dHf_298   -54900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135040.0
}
