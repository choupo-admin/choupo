/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-69150  (C25H48O7, CAS 69226-90-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG69150;
formula     C25H48O7;
CAS         69226-90-0;
InChIKey    VWDTZCFZPQOQKB-UHFFFAOYSA-N;
MW          460.652;      // g/mol [origin=calculated method=formula-sum]
Tc          1681.73;      // K   [origin=predictive method=joback]
Pc          9.335;      // bar [origin=predictive method=joback]
omega       0.1958;      // -   [origin=predictive method=lee-kesler]
Tb          1248.95;      // K   [origin=predictive method=joback]
HvapTb      144780.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.817 2.26234 -0.0010222 8.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 17; } { group CH; count 2; } { group CH2=C; count 1; } { group OH; count 3; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group CH; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 3; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(oxidanyl)propyl 2-methylprop-2-enoate;2-oxidanyloctadecanoic acid" );
standardThermochemistry
{
    dHf_298   -1690110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1466.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-935470.0
}
