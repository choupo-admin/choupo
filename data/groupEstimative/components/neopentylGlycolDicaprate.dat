/*--------------------------------*- Choupo -*-----------------------*\
  Component: neopentyl glycol dicaprate  (C25H48O4, CAS 27841-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        neopentylGlycolDicaprate;
formula     C25H48O4;
CAS         27841-06-1;
InChIKey    BJDAUCLANVMIOB-UHFFFAOYSA-N;
MW          412.655;      // g/mol [origin=calculated method=formula-sum]
Tc          1083.64;      // K   [origin=predictive method=joback]
Pc          7.763;      // bar [origin=predictive method=joback]
omega       0.7343;      // -   [origin=predictive method=lee-kesler]
Tb          884.81;      // K   [origin=predictive method=joback]
HvapTb      84762.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.508 2.39508 -0.0013188 2.44e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 16; } { group C; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 18; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-decanoyloxy-2,2-dimethyl-propyl) decanoate" "neopentyl glycol didecanoate" "2,2-dimethyl-1,3-propanediyl didecanoate" "decanoic acid, 1,1'-(2,2-dimethyl-1,3-propanediyl) ester" "(3-decanoyloxy-2,2-dimethylpropyl) decanoate" "3-(decanoyloxy)-2,2-dimethylpropyl decanoate" "decanoic acid, 2,2-dimethyl-1,3-propanediyl ester" "decanoic acid, 2,2-dimethyl-1,3-propanediol diester" "decanoic acid,1,1'-(2,2-dimethyl-1,3-propanediyl) ester" "decanoicacid, 2,2-dimethyl-1,3-propanediyl ester (9ci); decanoic acid,2,2-dimethyltrimethylene ester (6ci,8ci); 1,3-propanediol, 2,2-dimethyl-,didecanoate (8ci); 2,2-dimethylpropane-1,3-diol didecanoate; estemol n 01;npdc; neopentyl glycol bis(decanoate); neopentyl glycol didecanoate;neopentylglycol dicaprate" );
standardThermochemistry
{
    dHf_298   -1202640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1193.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-458280.0
}
