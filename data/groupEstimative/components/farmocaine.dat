/*--------------------------------*- Choupo -*-----------------------*\
  Component: farmocaine  (C17H28N2O2, CAS 3772-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        farmocaine;
formula     C17H28N2O2;
CAS         3772-42-7;
InChIKey    JQMCLLAJJLVYOC-UHFFFAOYSA-N;
MW          292.423;      // g/mol [origin=calculated method=formula-sum]
Tc          933.66;      // K   [origin=predictive method=joback]
Pc          15.772;      // bar [origin=predictive method=joback]
omega       1.0307;      // -   [origin=predictive method=lee-kesler]
Tb          741.05;      // K   [origin=predictive method=joback]
HvapTb      72260.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.663 1.62576 -0.00093176 1.825e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group ACH; count 4; } { group AC; count 2; } { group CH2NH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethyl 4-(butylamino)benzoate" "t-caine" "4-n-butylamino-benzoesaeure-diaethylaminoaethyl ester [german]" "benzoic acid, p-butylamino-, 2-(diethylamino)ethyl ester" "p-butylaminobenzoyldiethylaminoethyl hydrochloride" "2-diethylaminoethyl 4-(butylamino)benzoate" "4-n-butylamino-benzoesaeure-diaethylaminoaethyl ester" "benzoic acid,4-(butylamino)-,2-(diethylamino)- ethyl ester" );
standardThermochemistry
{
    dHf_298   -365430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     813.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=84840.0
}
