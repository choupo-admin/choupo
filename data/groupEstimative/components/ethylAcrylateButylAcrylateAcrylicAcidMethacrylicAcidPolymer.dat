/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl acrylate, butyl acrylate, acrylic acid, methacrylic acid polymer  (C19H30O8, CAS 62766-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylAcrylateButylAcrylateAcrylicAcidMethacrylicAcidPolymer;
formula     C19H30O8;
CAS         62766-55-6;
InChIKey    NCFYFBKODFMZFE-UHFFFAOYSA-N;
MW          386.441;      // g/mol [origin=calculated method=formula-sum]
Tc          1371.28;      // K   [origin=predictive method=joback]
Pc          12.260;      // bar [origin=predictive method=joback]
omega       1.1502;      // -   [origin=predictive method=lee-kesler]
Tb          1119.75;      // K   [origin=predictive method=joback]
HvapTb      115149.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (135.934 1.20766 1.52e-05 -3.366e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH2=CH; count 2; } { group CH2=C; count 2; } { group COOH; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH2; count 4; } { group dCH; count 2; } { group dC; count 2; } { group COOH; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate;2-methylidenebutanoic acid;2-methylprop-2-enoic acid;prop-2-enoic acid" "butyl prop-2-enoate; 2-methylidenebutanoic acid; 2-methylprop-2-enoic acid; prop-2-enoic acid" "2-propenoic acid, 2-methyl-, polymer with butyl 2-propenoate, ethyl 2-propenoate and 2-propenoic acid" );
gibbsFormation
{
    dHf_298   -1656300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1403.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1213020.0
    phase     gas;
}
