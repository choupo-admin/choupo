/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzeneacetic acid, 3-phenyl-2-propyl ester  (C17H16O2, CAS 7492-65-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneaceticAcid3Phenyl2PropylEster;
formula     C17H16O2;
CAS         7492-65-1;
InChIKey    SFXQCOMMEMBETJ-KPKJPENVSA-N;
MW          252.313;      // g/mol [origin=calculated method=formula-sum]
Tc          940.19;      // K   [origin=predictive method=joback]
Pc          22.021;      // bar [origin=predictive method=joback]
omega       0.7378;      // -   [origin=predictive method=lee-kesler]
Tb          704.30;      // K   [origin=predictive method=joback]
HvapTb      65353.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.148 1.4262 -0.0009526 2.324e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-3-phenylprop-2-enyl] 2-phenylethanoate" "benzeneacetic acid, 3-phenyl-2-propenyl ester" "cinnamyl phenylacetate" "3-phenylallyl phenylacetate" "cinnamylalphatoluate" "cinnamyl alpha-toluate" "cinnamyl phenylacetate [fifh]" "3-phenyl-2-propenyl benzeneacetate" "acetic acid, phenyl-, cinnamyl ester" "3-phenyl-2-propen-1-yl phenylacetate" "(2e)-3-phenyl-2-propenyl phenylacetate" "[(e)-3-phenylprop-2-enyl] 2-phenylacetate" );
gibbsFormation
{
    dHf_298   -121210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86930.0
    phase     gas;
}
