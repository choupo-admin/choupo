/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenoic acid, ethenyl ester, polymer with ethyl 2-propenoate and 2-methyl-2-propenoic acid  (C15H22O6, CAS 78266-08-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenoicAcidEthenylEsterPolymerWithEthyl2PropenoateAnd2Meth;
formula     C15H22O6;
CAS         78266-08-7;
InChIKey    HAOMDXDRNZUFEI-RQCPZROWSA-N;
MW          298.335;      // g/mol [origin=calculated method=formula-sum]
Tc          1008.76;      // K   [origin=predictive method=joback]
Pc          15.355;      // bar [origin=predictive method=joback]
omega       1.0228;      // -   [origin=predictive method=lee-kesler]
Tb          801.63;      // K   [origin=predictive method=joback]
HvapTb      79578.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (103.461 0.91756 -8e-07 -2.519e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH2=CH; count 2; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 3; } { group dCH; count 4; } { group dC; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl (e)-but-2-enoate;ethyl prop-2-enoate;2-methylprop-2-enoic acid" "ethyl acrylate, methacrylic acid, vinyl crotonate polymer" );
standardThermochemistry
{
    dHf_298   -1077280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1086.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-763560.0
}
