/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl bicyclo(2.2.1)hepta-2,5-dienecarboxylate  (C9H10O2, CAS 3604-36-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylBicyclo221Hepta25Dienecarboxylate;
formula     C9H10O2;
CAS         3604-36-2;
InChIKey    ABYXLSPPPNXLTQ-UHFFFAOYSA-N;
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          696.14;      // K   [origin=predictive method=joback]
Pc          33.220;      // bar [origin=predictive method=joback]
omega       0.4886;      // -   [origin=predictive method=lee-kesler]
Tb          484.79;      // K   [origin=predictive method=joback]
HvapTb      44279.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.63 0.92472 -0.00067272 1.91e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl bicyclo[2.2.1]hepta-2,5-diene-3-carboxylate" "methyl bicyclo[2.2.1]hepta-2,5-diene carboxylate" "bicyclo[2.2.1]hepta-2,5-diene-2-carboxylicacid, methyl ester" "methylester of bicyclo[2.2.1]hepta-2,5-dien-2-carboxylic acid" "2,5-norbornadiene-2-carboxylicacid, methyl ester (6ci,7ci,8ci); 2-methoxycarbonylbicyclo[2.2.1]hepta-2,5-diene;2-methoxycarbonylnorbornadiene; methyl 2,5-norbornadiene-2-carboxylate; methylbicyclo[2.2.1]hepta-2,5-diene-2-carboxylate; methyl norbornadiene-2-carboxylate" );
gibbsFormation
{
    dHf_298   -302840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     316.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125780.0
    phase     gas;
}
