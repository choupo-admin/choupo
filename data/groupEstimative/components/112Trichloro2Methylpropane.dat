/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2-trichloro-2-methylpropane  (C4H7Cl3, CAS 29559-52-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112Trichloro2Methylpropane;
formula     C4H7Cl3;
CAS         29559-52-2;
InChIKey    FRRHZKFKOHHEJR-UHFFFAOYSA-N;
MW          161.45;      // g/mol [origin=calculated method=formula-sum]
Tc          608.39;      // K   [origin=predictive method=joback]
Pc          35.179;      // bar [origin=predictive method=joback]
omega       0.2561;      // -   [origin=predictive method=lee-kesler]
Tb          399.74;      // K   [origin=predictive method=joback]
HvapTb      35969.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.77 0.53594 -0.00043 1.348e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 2; } { group CH; count 1; } { group C; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2-tris(chloranyl)-2-methyl-propane" "propane, 1,1,2-trichloro-2-methyl-" "frrhzkfkohhejr-uhfffaoysa-" "propane,1,1,2-trichloro-2-methyl-" );
gibbsFormation
{
    dHf_298   -187140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-52590.0
    phase     gas;
}
