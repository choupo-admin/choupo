/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-methylenebis(4-methylphenol)  (C15H16O2, CAS 3236-63-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Methylenebis4Methylphenol;
formula     C15H16O2;
CAS         3236-63-3;
InChIKey    XZXYQEHISUMZAT-UHFFFAOYSA-N;
MW          228.291;      // g/mol [origin=calculated method=formula-sum]
Tc          1018.93;      // K   [origin=predictive method=joback]
Pc          33.490;      // bar [origin=predictive method=joback]
omega       1.0281;      // -   [origin=predictive method=lee-kesler]
Tb          767.36;      // K   [origin=predictive method=joback]
HvapTb      80888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.799 1.46124 -0.00123324 4.347e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 1; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-[(5-methyl-2-oxidanyl-phenyl)methyl]phenol" "phenol, 2,2'-methylenebis(4-methyl-" "phenol, 2,2'-methylenebis[4-methyl-" "2,2'-methylenedi-p-cresol" "2,2'-methylenebis(p-cresol)" "bis(2-hydroxy-5-methylphenyl)methane" "2,2'-dihydroxy-5,5'-dimethyldiphenylmethane" "2-[(2-hydroxy-5-methylphenyl)methyl]-4-methylphenol" );
gibbsFormation
{
    dHf_298   -257430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28260.0
    phase     gas;
}
