/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylstilbestrol  (C16H16O2, CAS 3691-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylstilbestrol;
formula     C16H16O2;
CAS         3691-71-2;
InChIKey    PIEBWUHNLFOEHS-ACCUITESSA-N;
MW          240.302;      // g/mol [origin=calculated method=formula-sum]
Tc          1042.65;      // K   [origin=predictive method=joback]
Pc          33.144;      // bar [origin=predictive method=joback]
omega       1.0117;      // -   [origin=predictive method=lee-kesler]
Tb          784.32;      // K   [origin=predictive method=joback]
HvapTb      81828.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.179 1.69512 -0.00150782 5.456e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(e)-2-(4-hydroxyphenyl)but-1-enyl]phenol" "ethylstilboestrol" "alpha-ethyl-4,4'-stilbenediol" "4,4'-stilbenediol, alpha-ethyl-" );
gibbsFormation
{
    dHf_298   -147700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71090.0
    phase     gas;
}
