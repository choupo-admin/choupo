/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-azabicyclo[3.2.1]octane,2-(1,1-dimethylethyl)-  (C11H21N, CAS 71017-52-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Azabicyclo321Octane211Dimethylethyl;
formula     C11H21N;
CAS         71017-52-2;
InChIKey    RAQRBBIUOYHIPI-UHFFFAOYSA-N;
MW          167.296;      // g/mol [origin=calculated method=formula-sum]
Tc          683.49;      // K   [origin=predictive method=joback]
Pc          25.715;      // bar [origin=predictive method=joback]
omega       0.4024;      // -   [origin=predictive method=lee-kesler]
Tb          478.24;      // K   [origin=predictive method=joback]
HvapTb      40825.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-147.88 1.59076 -0.001253 3.977e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-tert-butyl-4-azabicyclo[3.2.1]octane" "2-azabicyclo(3.2.1)octane, 2-(1,1-dimethylethyl)-" );
standardThermochemistry
{
    dHf_298   -72150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=264760.0
}
