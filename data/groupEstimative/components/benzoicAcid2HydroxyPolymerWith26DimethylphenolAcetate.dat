/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 2-hydroxy-, polymer with 2,6-dimethylphenol, acetate  (C17H18O5, CAS 193561-59-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid2HydroxyPolymerWith26DimethylphenolAcetate;
formula     C17H18O5;
CAS         193561-59-0;
InChIKey    XFZKIAROECJLOF-UHFFFAOYSA-N;
MW          302.326;      // g/mol [origin=calculated method=formula-sum]
Tc          1185.11;      // K   [origin=predictive method=joback]
Pc          23.496;      // bar [origin=predictive method=joback]
omega       1.3005;      // -   [origin=predictive method=lee-kesler]
Tb          937.63;      // K   [origin=predictive method=joback]
HvapTb      97191.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.13 1.28646 -0.00064888 7.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 2; } { group ACCH3; count 2; } { group ACOH; count 1; } { group CH3COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,6-dimethylphenyl) ethanoate;2-oxidanylbenzoic acid" );
standardThermochemistry
{
    dHf_298   -900570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     831.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-615840.0
}
