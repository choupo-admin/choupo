/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylbutanamide  (C5H11NO, CAS 17794-44-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylbutanamide;
formula     C5H11NO;
CAS         17794-44-4;
InChIKey    OLLZXQIFCRIRMH-UHFFFAOYSA-N;
MW          101.149;      // g/mol [origin=calculated method=formula-sum]
Tc          601.49;      // K   [origin=predictive method=joback]
Pc          38.010;      // bar [origin=predictive method=joback]
omega       0.5352;      // -   [origin=predictive method=lee-kesler]
Tb          418.04;      // K   [origin=predictive method=joback]
HvapTb      39906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.492 0.52704 -0.0002781 4.976e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanamide, n-methyl-" "n-methylbutyramide" "butyramide, n-methyl-" "methyl butyric acid amide" "n-methylbuttersaureamid [german]" "n-methylbuttersaureamid" "butanamide, n-methyl- (9ci)" );
standardThermochemistry
{
    dHf_298   -205640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-48310.0
}
