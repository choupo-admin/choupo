/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butyl-4-methoxybenzene  (C11H16O, CAS 18272-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butyl4Methoxybenzene;
formula     C11H16O;
CAS         18272-84-9;
InChIKey    PRBLRGZSVKMPDX-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          707.00;      // K   [origin=predictive method=joback]
Pc          25.637;      // bar [origin=predictive method=joback]
omega       0.5130;      // -   [origin=predictive method=lee-kesler]
Tb          505.36;      // K   [origin=predictive method=joback]
HvapTb      45428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.217 0.84724 -0.00042776 6.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butyl-4-methoxy-benzene" "benzene, 1-butyl-4-methoxy-" "4-butylanisole" );
gibbsFormation
{
    dHf_298   -177530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39520.0
    phase     gas;
}
