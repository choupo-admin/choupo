/*--------------------------------*- Choupo -*-----------------------*\
  Component: ctk0i0750  (C18H24, CAS 13349-10-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ctk0i0750;
formula     C18H24;
CAS         13349-10-5;
InChIKey    AMFOXYRZVYMNIR-UHFFFAOYSA-N;
MW          240.39;      // g/mol [origin=calculated method=formula-sum]
Tc          853.75;      // K   [origin=predictive method=joback]
Pc          20.699;      // bar [origin=predictive method=joback]
omega       0.5708;      // -   [origin=predictive method=lee-kesler]
Tb          627.37;      // K   [origin=predictive method=joback]
HvapTb      52150.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-376.04 2.9848 -0.002947 1.173e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 10; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 10; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   47110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     65.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=525900.0
    phase     gas;
}
