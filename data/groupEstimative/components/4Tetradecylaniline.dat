/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tetradecylaniline  (C20H35N, CAS 91323-12-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Tetradecylaniline;
formula     C20H35N;
CAS         91323-12-5;
InChIKey    WKYFQPQIOXXPGE-UHFFFAOYSA-N;
MW          289.507;      // g/mol [origin=calculated method=formula-sum]
Tc          954.08;      // K   [origin=predictive method=joback]
Pc          13.080;      // bar [origin=predictive method=joback]
omega       0.9412;      // -   [origin=predictive method=lee-kesler]
Tb          761.39;      // K   [origin=predictive method=joback]
HvapTb      73693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.407 1.82732 -0.00107176 2.384e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-tetradecylaniline" "4-tetradecylphenylamine" "4-n-tetradecylanilin" );
standardThermochemistry
{
    dHf_298   -197280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     874.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=286750.0
}
