/*--------------------------------*- Choupo -*-----------------------*\
  Component: nicotine-d-bitartrate  (C18H26N2O12, CAS 65-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nicotineDBitartrate;
formula     C18H26N2O12;
CAS         65-31-6;
InChIKey    RFEJUZJILGIRHQ-WBPXWQEISA-N;
MW          462.408;      // g/mol [origin=calculated method=formula-sum]
Tc          2343.44;      // K   [origin=predictive method=joback]
Pc          28.263;      // bar [origin=predictive method=joback]
omega       0.5317;      // -   [origin=predictive method=lee-kesler]
Tb          1667.07;      // K   [origin=predictive method=joback]
HvapTb      200684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.1 1.88428 -0.00087746 5.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 5; } { group OH; count 4; } { group CH3N; count 1; } { group C5H4N; count 1; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group OH; count 4; } { group COOH; count 4; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3r)-2,3-bis(oxidanyl)butanedioic acid;3-(1-methylpyrrolidin-2-yl)pyridine" "nicotine tartrate (van)" "nicotine hydrogen tartrate" "nikotinbitartrat [german]" "nicotine hydrogen tartarate" "nicotine tartrate dihydrate" "nicotine, tartrate (1:2)" "nicotine dihydrogen ditartrate" "tartrate de nicotine [french]" "nicotine ditartrate" "nicotine acid tartrate" "(2r,3r)-2,3-dihydroxysuccinic acid- 3-(1-methylpyrrolidin-2-yl)pyridine(2:1)" );
gibbsFormation
{
    dHf_298   -2265720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1302.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1692630.0
    phase     gas;
}
