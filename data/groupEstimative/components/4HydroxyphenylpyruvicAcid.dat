/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxyphenylpyruvic acid  (C9H8O4, CAS 156-39-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HydroxyphenylpyruvicAcid;
formula     C9H8O4;
CAS         156-39-8;
InChIKey    KKADPXVIOXHVKN-UHFFFAOYSA-N;
MW          180.159;      // g/mol [origin=calculated method=formula-sum]
Tc          951.33;      // K   [origin=predictive method=joback]
Pc          47.562;      // bar [origin=predictive method=joback]
omega       1.1792;      // -   [origin=predictive method=lee-kesler]
Tb          712.20;      // K   [origin=predictive method=joback]
HvapTb      74828.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.159 0.9573 -0.00080726 2.7346e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-hydroxyphenyl)-2-oxidanylidene-propanoic acid" "testacid" "p-hydroxyphenylpyruvic acid" "4-hydroxyphenylpyruvate" "testacide" "3-(4-hydroxyphenyl)-2-oxopropanoic acid" "3-(p-hydroxyphenyl)pyruvic acid" "3-(4-hydroxyphenyl)pyruvic acid" "(p-hydroxyphenyl)pyruvic acid" "(p-hydroxyphenyl)-pyruvic acid" "pyruvic acid, p-hydroxyphenyl-" "3-(p-hydroxyphenyl)-2-oxopropanoic acid" );
gibbsFormation
{
    dHf_298   -632720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-490140.0
    phase     gas;
}
