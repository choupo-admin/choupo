/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentatetracontane  (C45H90, CAS 297-60-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentatetracontane;
formula     C45H90;
CAS         297-60-9;
InChIKey    CABNOHVKWOZUCB-UHFFFAOYSA-N;
MW          631.215;      // g/mol [origin=calculated method=formula-sum]
Tc          1740.67;      // K   [origin=predictive method=joback]
Pc          5.346;      // bar [origin=predictive method=joback]
omega       0.3877;      // -   [origin=predictive method=lee-kesler]
Tb          1419.95;      // K   [origin=predictive method=joback]
HvapTb      123210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-309.28 4.053 -0.000751 -6.04e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 45; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 45; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -1137710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     2697.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-111720.0
}
