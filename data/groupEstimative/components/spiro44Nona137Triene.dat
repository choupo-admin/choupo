/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[4.4]nona-1,3,7-triene  (C9H10, CAS 24430-29-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro44Nona137Triene;
formula     C9H10;
CAS         24430-29-3;
InChIKey    QWUJRJVGSSNVCN-UHFFFAOYSA-N;
MW          118.179;      // g/mol [origin=calculated method=formula-sum]
Tc          668.57;      // K   [origin=predictive method=joback]
Pc          41.039;      // bar [origin=predictive method=joback]
omega       0.2651;      // -   [origin=predictive method=lee-kesler]
Tb          434.20;      // K   [origin=predictive method=joback]
HvapTb      36004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-153.73 1.2822 -0.00131684 5.436e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group CH=CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro(4.4)nona-1,3,7-triene" "spiro[4.4]nona-1,3,7-trien" "spiro[4.4]nona-2,6,8-triene" );
gibbsFormation
{
    dHf_298   106950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=202200.0
    phase     gas;
}
