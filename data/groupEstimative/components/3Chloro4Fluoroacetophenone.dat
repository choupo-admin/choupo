/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-4-fluoroacetophenone  (C8H6ClFO, CAS 2923-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro4Fluoroacetophenone;
formula     C8H6ClFO;
CAS         2923-66-2;
InChIKey    PCJPESKRPOTNGU-UHFFFAOYSA-N;
MW          172.583;      // g/mol [origin=calculated method=formula-sum]
Tc          728.02;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       0.5339;      // -   [origin=predictive method=lee-kesler]
Tb          509.85;      // K   [origin=predictive method=joback]
HvapTb      47316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.65 0.55652 -0.00032662 6.526e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CH3CO; count 1; } { group ACCl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-chloranyl-4-fluoranyl-phenyl)ethanone" "3'-chloro-4'-fluoroacetophenone" "1-(3-chloro-4-fluorophenyl)ethanone" "1-(3-chloro-4-fluorophenyl)ethan-1-one" "1-acetyl-3-chloro-4-fluorobenzene" "3-chloro-4-fluoro acetophenone" );
standardThermochemistry
{
    dHf_298   -319290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-226030.0
}
