/*--------------------------------*- Choupo -*-----------------------*\
  Component: malonic acid mono-tert-butyl ester  (C7H12O4, CAS 40052-13-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        malonicAcidMonoTertButylEster;
formula     C7H12O4;
CAS         40052-13-9;
InChIKey    NGGGZUAEOKRHMA-UHFFFAOYSA-N;
MW          160.169;      // g/mol [origin=calculated method=formula-sum]
Tc          763.08;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       0.7911;      // -   [origin=predictive method=lee-kesler]
Tb          560.26;      // K   [origin=predictive method=joback]
HvapTb      54451.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.061 0.79066 -0.0005068 1.149e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(2-methylpropan-2-yl)oxy]-3-oxidanylidene-propanoic acid" "3-tert-butoxy-3-oxopropanoic acid" "mono-tert-butyl malonate" "(tert-butoxycarbonyl)acetic acid" "tert-butyl hydrogen malonate" "3-(tert-butoxy)-3-oxopropanoic acid" "3-(tert-butoxy)-3-oxopropionic acid" "2-[(tert-butyl)oxycarbonyl]acetic acid" "s387" "3-[(2-methylpropan-2-yl)oxy]-3-oxopropanoic acid" );
gibbsFormation
{
    dHf_298   -864110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-643380.0
    phase     gas;
}
