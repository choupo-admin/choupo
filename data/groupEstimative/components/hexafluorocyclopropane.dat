/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexafluorocyclopropane  (C3F6, CAS 931-91-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexafluorocyclopropane;
formula     C3F6;
CAS         931-91-9;
InChIKey    GQUXQQYWQKRCPL-UHFFFAOYSA-N;
MW          150.021;      // g/mol [origin=calculated method=formula-sum]
Tc          400.49;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.2850;      // -   [origin=predictive method=lee-kesler]
Tb          261.98;      // K   [origin=predictive method=joback]
HvapTb      13212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-151.63 1.3332 -0.001945 9.95e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CF2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 3; } { group F; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2,3,3-hexakis(fluoranyl)cyclopropane" "cyclopropane, hexafluoro-" "1,1,2,2,3,3-hexafluorocyclopropane" "perfluorocyclopropane" "cyclopropane, 1,1,2,2,3,3-hexafluoro-" );
standardThermochemistry
{
    dHf_298   -1204070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1165620.0
}
