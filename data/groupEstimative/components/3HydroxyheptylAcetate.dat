/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxyheptyl acetate  (C9H18O3, CAS 39920-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3HydroxyheptylAcetate;
formula     C9H18O3;
CAS         39920-56-4;
InChIKey    WFLFWEJJPIIYBD-UHFFFAOYSA-N;
MW          174.24;      // g/mol [origin=calculated method=formula-sum]
Tc          723.40;      // K   [origin=predictive method=joback]
Pc          25.585;      // bar [origin=predictive method=joback]
omega       1.0401;      // -   [origin=predictive method=lee-kesler]
Tb          555.48;      // K   [origin=predictive method=joback]
HvapTb      59326.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.725 0.84394 -0.0004048 4.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanylheptyl ethanoate" "acetic acid, 3-heptanol ester" "1-ethylamylester kyseliny octove" );
gibbsFormation
{
    dHf_298   -703880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-424730.0
    phase     gas;
}
