/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dibromo-5-fluoro-2-iodobenzene  (C6H2Br2FI, CAS 62720-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dibromo5Fluoro2Iodobenzene;
formula     C6H2Br2FI;
CAS         62720-29-0;
InChIKey    LIWKANDEJFABTQ-UHFFFAOYSA-N;
MW          379.788;      // g/mol [origin=calculated method=formula-sum]
Tc          881.89;      // K   [origin=predictive method=joback]
Pc          48.427;      // bar [origin=predictive method=joback]
omega       0.5505;      // -   [origin=predictive method=lee-kesler]
Tb          603.23;      // K   [origin=predictive method=joback]
HvapTb      54638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.59 0.4436 -0.00037328 1.247e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group I; count 1; } { group Br; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 1; } { group Br; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(bromanyl)-5-fluoranyl-2-iodanyl-benzene" "2,6-dibromo-4-fluoroiodobenzene" "1,3-dibromo-5-fluoro-2-iodobenzene;" "benzene,1,3-dibromo-5-fluoro-2-iodo-" "benzene, 1,3-dibromo-5-fluoro-2-iodo-" );
gibbsFormation
{
    dHf_298   -31630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-24890.0
    phase     gas;
}
