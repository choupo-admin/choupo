/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-diisopropyl-5,5-dimethyl-1,3-dioxane  (C12H24O2, CAS 3494-76-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Diisopropyl55Dimethyl13Dioxane;
formula     C12H24O2;
CAS         3494-76-6;
InChIKey    SVYIRYSQKUXBPY-UHFFFAOYSA-N;
MW          200.322;      // g/mol [origin=calculated method=formula-sum]
Tc          744.00;      // K   [origin=predictive method=joback]
Pc          20.888;      // bar [origin=predictive method=joback]
omega       0.4752;      // -   [origin=predictive method=lee-kesler]
Tb          537.63;      // K   [origin=predictive method=joback]
HvapTb      49210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.46 1.51072 -0.0011104 3.644e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH; count 3; } { group C; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethyl-2,4-di(propan-2-yl)-1,3-dioxane" "1,3-dioxane, 5,5-dimethyl-2,4-bis(1-methylethyl)-" "1,3-dioxane, 2,4-diisopropyl-5,5-dimethyl-" );
standardThermochemistry
{
    dHf_298   -536690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-123420.0
}
