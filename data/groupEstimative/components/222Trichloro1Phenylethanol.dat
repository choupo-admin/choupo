/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,2-trichloro-1-phenylethanol  (C8H7Cl3O, CAS 2000-43-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222Trichloro1Phenylethanol;
formula     C8H7Cl3O;
CAS         2000-43-3;
InChIKey    ABFRBTDJEKZSRM-UHFFFAOYSA-N;
MW          225.493;      // g/mol [origin=calculated method=formula-sum]
Tc          838.42;      // K   [origin=predictive method=joback]
Pc          36.865;      // bar [origin=predictive method=joback]
omega       0.8058;      // -   [origin=predictive method=lee-kesler]
Tb          610.12;      // K   [origin=predictive method=joback]
HvapTb      63828.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.48 0.871 -0.0007092 2.177e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(chloranyl)-1-phenyl-ethanol" "efiran 99" "alpha-(trichloromethyl)benzyl alcohol" "phenyl(trichloromethyl)carbinol" "2,2,2-trichloro-1-phenylethan-1-ol" "trichloromethylphenyl carbinol" "1-phenyl-2,2,2-trichloroethanol" "alpha-(trichloromethyl)benzenemethanol" "benzenemethanol, alpha-(trichloromethyl)-" "benzenemethanol, .alpha.-(trichloromethyl)-" "benzyl alcohol, alpha-(trichloromethyl)-" "1-phenyl-2,2-trichloroethanol" );
gibbsFormation
{
    dHf_298   -185400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-43320.0
    phase     gas;
}
