/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-{[2-(benzylamino)ethyl]amino}ethanol  (C11H18N2O, CAS 54119-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BenzylaminoEthylAminoEthanol;
formula     C11H18N2O;
CAS         54119-37-8;
InChIKey    PEORPEBHZUHNFF-UHFFFAOYSA-N;
MW          194.278;      // g/mol [origin=calculated method=formula-sum]
Tc          862.95;      // K   [origin=predictive method=joback]
Pc          30.024;      // bar [origin=predictive method=joback]
omega       1.2693;      // -   [origin=predictive method=lee-kesler]
Tb          670.48;      // K   [origin=predictive method=joback]
HvapTb      71907.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.145 1.1563 -0.0007334 1.76e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[(phenylmethyl)amino]ethylamino]ethanol" "ethanol, 2-((2-((phenylmethyl)amino)ethyl)amino)-" "ethanol, 2-[[2-[(phenylmethyl)amino]ethyl]amino]-" "2-[2-(benzylamino)ethylamino]ethanol" );
standardThermochemistry
{
    dHf_298   -79130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     610.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196110.0
}
