/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-acetyltetralin  (C12H14O, CAS 774-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Acetyltetralin;
formula     C12H14O;
CAS         774-55-0;
InChIKey    VEPUKHYQNXSSKV-UHFFFAOYSA-N;
MW          174.243;      // g/mol [origin=calculated method=formula-sum]
Tc          814.48;      // K   [origin=predictive method=joback]
Pc          30.256;      // bar [origin=predictive method=joback]
omega       0.5728;      // -   [origin=predictive method=lee-kesler]
Tb          580.35;      // K   [origin=predictive method=joback]
HvapTb      53046.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.27 1.08572 -0.00073662 1.9586e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(5,6,7,8-tetrahydronaphthalen-2-yl)ethanone" "6-acetyl tetralin" "6-acetyltetrahydronaphthalene" "ethanone, 1-(5,6,7,8-tetrahydro-2-naphthalenyl)-" "6-acetyl-1,2,3,4-tetrahydronaphthalene" "2-acetyl-5,6,7,8-tetrahydronaphthalene" "5',6',7',8'-tetrahydro-2'-acetonaphthone" "1-(5,6,7,8-tetrahydro-2-naphthyl)ethan-1-one" "1-(5,6,7,8-tetrahydronaphthalen-2-yl)ethan-1-one" );
standardThermochemistry
{
    dHf_298   -103020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70750.0
}
