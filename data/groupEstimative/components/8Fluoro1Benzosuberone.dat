/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-fluoro-1-benzosuberone  (C11H11FO, CAS 24484-21-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Fluoro1Benzosuberone;
formula     C11H11FO;
CAS         24484-21-7;
InChIKey    INDIENDTRXERIX-UHFFFAOYSA-N;
MW          178.206;      // g/mol [origin=calculated method=formula-sum]
Tc          816.42;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       0.5309;      // -   [origin=predictive method=lee-kesler]
Tb          574.96;      // K   [origin=predictive method=joback]
HvapTb      47676.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.32 0.8526 -0.00042692 5.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2CO; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-fluoranyl-6,7,8,9-tetrahydrobenzo[7]annulen-5-one" "3-fluoro-6,7,8,9-tetrahydro-5h-benzo[a]cyclohepten-5-one" "3-fluoro-6,7,8,9-tetrahydrobenzo[7]annulen-5-one" "8-fluoro-2,3,4,5-tetrahydrobenzo[a][7]annulen-1-one" );
standardThermochemistry
{
    dHf_298   -309770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-138250.0
}
