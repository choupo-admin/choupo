/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl isopropylidenesuccinate  (C9H14O4, CAS 87384-00-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylIsopropylidenesuccinate;
formula     C9H14O4;
CAS         87384-00-7;
InChIKey    MILMBEYRSAHUMS-UHFFFAOYSA-N;
MW          186.207;      // g/mol [origin=calculated method=formula-sum]
Tc          716.37;      // K   [origin=predictive method=joback]
Pc          24.752;      // bar [origin=predictive method=joback]
omega       0.6592;      // -   [origin=predictive method=lee-kesler]
Tb          525.88;      // K   [origin=predictive method=joback]
HvapTb      50560.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.961 0.76908 -0.000365 3.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2COO; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dC; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-propan-2-ylidenebutanedioate" "dimethyl 2-(1-methylethylidene)succinate" "butanedioic acid, (1-methylethylidene)-, dimethyl ester" );
standardThermochemistry
{
    dHf_298   -766010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-532720.0
}
