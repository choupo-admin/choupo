/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholesteryl decanoate  (C37H64O2, CAS 1183-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholesterylDecanoate;
formula     C37H64O2;
CAS         1183-04-6;
InChIKey    LJGMGXXCKVFFIS-SWKHNIQGSA-N;
MW          540.917;      // g/mol [origin=calculated method=formula-sum]
Tc          1405.43;      // K   [origin=predictive method=joback]
Pc          5.972;      // bar [origin=predictive method=joback]
omega       0.4573;      // -   [origin=predictive method=lee-kesler]
Tb          1142.42;      // K   [origin=predictive method=joback]
HvapTb      102824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-295.359 4.42032 -0.00336884 1.1094e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 18; } { group CH; count 7; } { group C; count 2; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 11; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] decanoate" "(3" "a,8xi)-cholest-5-en-3-yl decanoate" "cholest-5-en-3-beta-yl decanoate" "(3beta)-cholest-5-en-3-ol, decanoate" "cholest-5-en-3-ol (3beta)-, decanoate" "cholest-5-en-3-ol (3beta)-, 3-decanoate" "decanoic acid [(3s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] ester" );
gibbsFormation
{
    dHf_298   -858680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1336.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114130.0
    phase     gas;
}
