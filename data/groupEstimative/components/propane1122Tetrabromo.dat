/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane, 1,1,2,2-tetrabromo-  (C3H4Br4, CAS 34570-59-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propane1122Tetrabromo;
formula     C3H4Br4;
CAS         34570-59-7;
InChIKey    JXKZURFTWZXOOD-UHFFFAOYSA-N;
MW          359.681;      // g/mol [origin=calculated method=formula-sum]
Tc          798.13;      // K   [origin=predictive method=joback]
Pc          69.099;      // bar [origin=predictive method=joback]
omega       0.5288;      // -   [origin=predictive method=lee-kesler]
Tb          529.21;      // K   [origin=predictive method=joback]
HvapTb      46328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.77 0.57332 -0.0006 2.323e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group C; count 1; } { group Br; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group C; count 1; } { group Br; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetrakis(bromanyl)propane" "agn-pc-00mmlh" );
standardThermochemistry
{
    dHf_298   -13960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32060.0
}
