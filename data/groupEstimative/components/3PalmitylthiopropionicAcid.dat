/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-palmitylthiopropionic acid  (C19H38O2S, CAS 41622-39-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3PalmitylthiopropionicAcid;
formula     C19H38O2S;
CAS         41622-39-3;
InChIKey    UZRGHARRXDESET-UHFFFAOYSA-N;
MW          330.571;      // g/mol [origin=calculated method=formula-sum]
Tc          1042.96;      // K   [origin=predictive method=joback]
Pc          11.601;      // bar [origin=predictive method=joback]
omega       1.0565;      // -   [origin=predictive method=lee-kesler]
Tb          848.61;      // K   [origin=predictive method=joback]
HvapTb      81869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.817 1.85401 -0.0010422 2.153e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-hexadecylsulfanylpropanoic acid" "propanoic acid, 3-(hexadecylthio)-" "3-hexadecylthiopropanoic acid" "3-(hexadecylthio)propionic acid" "3-(hexadecylsulfanyl)propanoic acid" );
standardThermochemistry
{
    dHf_298   -743890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1010.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-201690.0
}
