/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-1-phenylethanol  (C8H11NO, CAS 7568-93-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino1Phenylethanol;
formula     C8H11NO;
CAS         7568-93-6;
InChIKey    ULSIYEODSMZIPX-UHFFFAOYSA-N;
MW          137.182;      // g/mol [origin=calculated method=formula-sum]
Tc          785.03;      // K   [origin=predictive method=joback]
Pc          44.563;      // bar [origin=predictive method=joback]
omega       0.9339;      // -   [origin=predictive method=lee-kesler]
Tb          573.59;      // K   [origin=predictive method=joback]
HvapTb      62610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.189 0.7867 -0.0005196 1.298e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-1-phenyl-ethanol" "phenylethanolamine" "2-hydroxy-2-phenylethylamine" "bisnorephedrine" "beta-hydroxyphenethylamine" "beta-phenethanolamine" "phenethanolamine" "alpha-(aminomethyl)benzyl alcohol" "2-phenyl-2-hydroxyethylamine" "phenylethanolamin" "2-amino-1-phenyl-1-ethanol" "beta-hydroxy-beta-phenylethylamine" );
standardThermochemistry
{
    dHf_298   -95640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56080.0
}
