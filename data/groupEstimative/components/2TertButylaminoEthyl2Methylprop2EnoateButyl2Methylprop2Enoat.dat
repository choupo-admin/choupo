/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(tert-butylamino)ethyl 2-methylprop-2-enoate;butyl 2-methylprop-2-enoate;prop-2-enenitrile  (C21H36N2O4, CAS 65970-58-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TertButylaminoEthyl2Methylprop2EnoateButyl2Methylprop2Enoat;
formula     C21H36N2O4;
CAS         65970-58-3;
InChIKey    PBQYODMSABCJLK-UHFFFAOYSA-N;
MW          380.529;      // g/mol [origin=calculated method=formula-sum]
Tc          1152.24;      // K   [origin=predictive method=joback]
Pc          9.427;      // bar [origin=predictive method=joback]
omega       0.8788;      // -   [origin=predictive method=lee-kesler]
Tb          938.14;      // K   [origin=predictive method=joback]
HvapTb      91510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (99.215 1.55352 -0.0003625 -1.78e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 4; } { group C; count 1; } { group CH2=C; count 2; } { group CH2NH; count 1; } { group ACRY; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 5; } { group C; count 1; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group COO; count 2; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(tert-butylamino)ethyl 2-methylprop-2-enoate; butyl 2-methylprop-2-enoate; prop-2-enenitrile" "2-propenoic acid, 2-methyl-, butyl ester, polymer with 2-((1,1-dimethylethyl)amino)ethyl 2-methyl-2-propenoate and 2-propenenitrile" );
standardThermochemistry
{
    dHf_298   -768260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1277.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-232490.0
}
