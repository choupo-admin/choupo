/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylpentadecanoic acid  (C16H32O2, CAS 25354-92-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylpentadecanoicAcid;
formula     C16H32O2;
CAS         25354-92-1;
InChIKey    XEFOHUNTIRSZAC-UHFFFAOYSA-N;
MW          256.43;      // g/mol [origin=calculated method=formula-sum]
Tc          889.12;      // K   [origin=predictive method=joback]
Pc          14.165;      // bar [origin=predictive method=joback]
omega       1.0230;      // -   [origin=predictive method=lee-kesler]
Tb          710.75;      // K   [origin=predictive method=joback]
HvapTb      67986.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.738 1.58054 -0.0009224 2.067e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadecanoic acid, 2-methyl-" "pentadecanoic acid, methyl-" );
standardThermochemistry
{
    dHf_298   -729120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     822.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-262510.0
}
