/*--------------------------------*- Choupo -*-----------------------*\
  Component: [2.2]paracyclophane  (C16H16, CAS 1633-22-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Paracyclophane;
formula     C16H16;
CAS         1633-22-3;
InChIKey    OOLUVSIJOMLOCB-UHFFFAOYSA-N;
MW          208.304;      // g/mol [origin=calculated method=formula-sum]
Tc          902.16;      // K   [origin=predictive method=joback]
Pc          26.735;      // bar [origin=predictive method=joback]
omega       0.5313;      // -   [origin=predictive method=lee-kesler]
Tb          644.68;      // K   [origin=predictive method=joback]
HvapTb      57480.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.17 1.4148 -0.00100412 2.78e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "di-p-xylylene" "di-1,4-xylylene" "(2.2)paracyclophane" "[2.2]paracyclophan" "cyclobis(benzene-1,4-dimethylene)" "tricyclo[8.2.2.24,7]hexadeca-4,6,10,12,13,15-hexaene" "[2.2]paracylophan" "tricyclo[8.2.2.2(4,7)]hexadeca-4,6,10,12,13,15-hexaene" "tricyclo[8.2.2.2~4,7~]hexadeca-1(12),4,6,10,13,15-hexaene" "tricyclo(8.2.2.24,7)hexadeca-4,6,10,12,13,15-hexaene" "tricyclo[8,2,2,24,7]hexadeca-4,6,10,12,13,15-hexaene" "tricyclo(8.2.2.24,7)hexadeca-1(12),4,6,10,13,15-hexaene" );
gibbsFormation
{
    dHf_298   163530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=345760.0
    phase     gas;
}
