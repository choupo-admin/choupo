/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethylcyclohexanone  (C8H14O, CAS 932-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethylcyclohexanone;
formula     C8H14O;
CAS         932-51-4;
InChIKey    LUGFNAYTNQMMMY-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          685.54;      // K   [origin=predictive method=joback]
Pc          31.597;      // bar [origin=predictive method=joback]
omega       0.3472;      // -   [origin=predictive method=lee-kesler]
Tb          465.34;      // K   [origin=predictive method=joback]
HvapTb      37769.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.62 0.69114 -0.000193 -4.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dimethylcyclohexan-1-one" "2,5-dimethylcyclohexanone,c&t" "cyclohexanone, 2,5-dimethyl-" "2,5-dimethyl cyclohexanone" );
standardThermochemistry
{
    dHf_298   -312170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     315.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-89370.0
}
