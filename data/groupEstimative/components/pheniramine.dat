/*--------------------------------*- Choupo -*-----------------------*\
  Component: pheniramine  (C16H20N2, CAS 86-21-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pheniramine;
formula     C16H20N2;
CAS         86-21-5;
InChIKey    IJHNSHDBIRRJRN-UHFFFAOYSA-N;
MW          240.35;      // g/mol [origin=calculated method=formula-sum]
Tc          922.01;      // K   [origin=predictive method=joback]
Pc          23.003;      // bar [origin=predictive method=joback]
omega       0.6996;      // -   [origin=predictive method=lee-kesler]
Tb          684.74;      // K   [origin=predictive method=joback]
HvapTb      63627.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.778 1.5296 -0.00103406 2.689e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group CH3N; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 2; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-3-phenyl-3-pyridin-2-yl-propan-1-amine" "prophenpyridamine" "tripoton" "avil" "feniramine" "propheniramine" "pyriton" "trimeton" "metron" "histapyridamine" "pheniraminum" "feniramina" );
gibbsFormation
{
    dHf_298   194530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=494050.0
    phase     gas;
}
