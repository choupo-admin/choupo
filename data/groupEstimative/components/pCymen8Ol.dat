/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-cymen-8-ol  (C10H14O, CAS 1197-01-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pCymen8Ol;
formula     C10H14O;
CAS         1197-01-9;
InChIKey    XLPDVYGDNRIQFV-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          754.13;      // K   [origin=predictive method=joback]
Pc          32.616;      // bar [origin=predictive method=joback]
omega       0.7461;      // -   [origin=predictive method=lee-kesler]
Tb          549.01;      // K   [origin=predictive method=joback]
HvapTb      56175.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.99 0.97526 -0.00068656 1.901e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methylphenyl)propan-2-ol" "8-hydroxy-p-cymene" "cymen-8-ol, p-" "2-(4-methylphenyl)-2-propanol" "2-p-tolyl-2-propanol" "dimethyl-p-tolyl carbinol" "p,alpha,alpha-trimethylbenzyl alcohol" "2-(p-methylphenyl)-2-propanol" "1-methyl-4-(1-hydroxy-1-methylethyl)benzene" "benzenemethanol, .alpha.,.alpha.,4-trimethyl-" "alpha,alpha,4-trimethylbenzyl alcohol" "alpha,alpha,4-trimethylbenzenemethanol" );
gibbsFormation
{
    dHf_298   -185650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=2120.0
    phase     gas;
}
