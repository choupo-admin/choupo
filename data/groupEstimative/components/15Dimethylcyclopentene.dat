/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-dimethylcyclopentene  (C7H12, CAS 16491-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Dimethylcyclopentene;
formula     C7H12;
CAS         16491-15-9;
InChIKey    RIICRLQIUAAOOE-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          577.03;      // K   [origin=predictive method=joback]
Pc          35.054;      // bar [origin=predictive method=joback]
omega       0.2554;      // -   [origin=predictive method=lee-kesler]
Tb          379.18;      // K   [origin=predictive method=joback]
HvapTb      32387.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.88 0.68504 -0.00040464 9.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dimethyl-2-cyclopentene" "cyclopentene, 1,5-dimethyl-" "cyclopentene,1,5-dimethyl-" "1,2-dimethyl-2-cyclopentene;1,5-dimethylcyclopentene; 2,3-dimethylcyclopentene" );
standardThermochemistry
{
    dHf_298   -81020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64940.0
}
