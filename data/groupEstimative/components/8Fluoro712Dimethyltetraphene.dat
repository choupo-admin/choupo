/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-fluoro-7,12-dimethyltetraphene  (C20H15F, CAS 2023-60-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Fluoro712Dimethyltetraphene;
formula     C20H15F;
CAS         2023-60-1;
InChIKey    LPUIOFMNAMJTCW-UHFFFAOYSA-N;
MW          274.338;      // g/mol [origin=calculated method=formula-sum]
Tc          1008.06;      // K   [origin=predictive method=joback]
Pc          20.812;      // bar [origin=predictive method=joback]
omega       0.8049;      // -   [origin=predictive method=lee-kesler]
Tb          764.99;      // K   [origin=predictive method=joback]
HvapTb      69803.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.94 1.52814 -0.00118676 3.767e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 6; } { group ACCH3; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 9; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-fluoranyl-7,12-dimethyl-benzo[a]anthracene" "7,12-dimethyl-8-fluorobenz(a)anthracene" "8-fluoro-7,12-dimethylbenz(a)anthracene" "8-fluoro-7,12-dimethylbenzo[a]anthracene" "benz(a)anthracene, 7,12-dimethyl-8-fluoro-" );
gibbsFormation
{
    dHf_298   100150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=306920.0
    phase     gas;
}
