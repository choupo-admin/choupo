/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-2-methylaniline  (C7H8BrN, CAS 55289-36-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo2Methylaniline;
formula     C7H8BrN;
CAS         55289-36-6;
InChIKey    IILVSKMKMOJHMA-UHFFFAOYSA-N;
MW          186.052;      // g/mol [origin=calculated method=formula-sum]
Tc          781.36;      // K   [origin=predictive method=joback]
Pc          46.721;      // bar [origin=predictive method=joback]
omega       0.5423;      // -   [origin=predictive method=lee-kesler]
Tb          535.09;      // K   [origin=predictive method=joback]
HvapTb      51852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.9 0.57102 -0.00036892 9.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACNH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-2-methyl-aniline" "2-amino-6-bromotoluene" "3-bromo-o-toluidine" "3-brom-2-methylanilin" "2-bromo-6-aminotoluene" "3-bromo-2-methyl-phenylamine" "benzenamine, 3-bromo-2-methyl-" "3-bromo-2-methylanilin" "3-bromo-2-methylbenzenamine" "3-bromo-2-methylphenylamine" "3-bromo-2-methyl-benzenamine" "benzenamine,3-bromo-2-methyl-" );
standardThermochemistry
{
    dHf_298   85900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=181980.0
}
