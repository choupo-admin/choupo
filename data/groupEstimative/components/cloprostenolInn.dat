/*--------------------------------*- Choupo -*-----------------------*\
  Component: cloprostenol (inn)  (C22H29ClO6, CAS 40665-92-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cloprostenolInn;
formula     C22H29ClO6;
CAS         40665-92-7;
InChIKey    VJGGHXVGBSZVMZ-CHPNCWRZSA-N;
MW          424.918;      // g/mol [origin=calculated method=formula-sum]
Tc          1531.72;      // K   [origin=predictive method=joback]
Pc          15.873;      // bar [origin=predictive method=joback]
omega       1.1263;      // -   [origin=predictive method=lee-kesler]
Tb          1225.67;      // K   [origin=predictive method=joback]
HvapTb      140358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.565 2.1499 -0.00134236 3.12e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 4; } { group CH=CH; count 2; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 2; } { group COOH; count 1; } { group ACCl; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group CH; count 1; } { group dCH; count 4; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 3; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-7-[(1s,2s,3s,5r)-2-[(e,3s)-4-(3-chloranylphenoxy)-3-oxidanyl-but-1-enyl]-3,5-bis(oxidanyl)cyclopentyl]hept-5-enoic acid" "dalmazin [veterinary] (tn)" "(z)-7-[(1s,2s,3s,5r)-2-[(e,3s)-4-(3-chlorophenoxy)-3-hydroxybut-1-enyl]-3,5-dihydroxycyclopentyl]-5-heptenoic acid" );
gibbsFormation
{
    dHf_298   -998650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     950.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-462740.0
    phase     gas;
}
