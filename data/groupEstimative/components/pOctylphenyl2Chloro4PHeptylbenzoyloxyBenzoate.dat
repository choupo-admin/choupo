/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-octylphenyl 2-chloro-4-(p-heptylbenzoyloxy)benzoate  (C35H43ClO4, CAS 41161-57-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pOctylphenyl2Chloro4PHeptylbenzoyloxyBenzoate;
formula     C35H43ClO4;
CAS         41161-57-3;
InChIKey    PVPLJWOWXVOSPP-UHFFFAOYSA-N;
MW          563.175;      // g/mol [origin=calculated method=formula-sum]
Tc          1550.36;      // K   [origin=predictive method=joback]
Pc          7.416;      // bar [origin=predictive method=joback]
omega       0.6046;      // -   [origin=predictive method=lee-kesler]
Tb          1254.23;      // K   [origin=predictive method=joback]
HvapTb      122179.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.737 2.75134 -0.00153684 2.77e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group ACH; count 11; } { group AC; count 4; } { group ACCH2; count 2; } { group ACCl; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group Cl; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-octylphenyl) 2-chloranyl-4-(4-heptylphenyl)carbonyloxy-benzoate" "benzoic acid, 2-chloro-4-((4-heptylbenzoyl)oxy)-, 4-octylphenyl ester" "benzoic acid, 2-chloro-4-[(4-heptylbenzoyl)oxy]-, 4-octylphenyl ester" "(4-octylphenyl) 2-chloro-4-(4-heptylbenzoyl)oxybenzoate" );
gibbsFormation
{
    dHf_298   -752320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1311.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90140.0
    phase     gas;
}
