/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanamide, n,n'-1,2-ethanediylbis[3-mercapto-  (C8H16N2O2S2, CAS 818-41-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanamideNN12Ethanediylbis3Mercapto;
formula     C8H16N2O2S2;
CAS         818-41-7;
InChIKey    BSICYDQQORWGMR-UHFFFAOYSA-N;
MW          236.348;      // g/mol [origin=calculated method=formula-sum]
Tc          936.68;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       1.1922;      // -   [origin=predictive method=lee-kesler]
Tb          716.44;      // K   [origin=predictive method=joback]
HvapTb      73240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.696 0.9148 -0.000516 9.812e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2SH; count 2; } { group CONHCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CdO; count 2; } { group NH; count 2; } { group SH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-sulfanyl-n-[2-(3-sulfanylpropanoylamino)ethyl]propanamide" );
gibbsFormation
{
    dHf_298   -249710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     727.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3800.0
    phase     gas;
}
