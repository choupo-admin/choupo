/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-benzyl-4-heptanone  (C14H20O, CAS 7492-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Benzyl4Heptanone;
formula     C14H20O;
CAS         7492-37-7;
InChIKey    CGTCWTIGDNJZOX-UHFFFAOYSA-N;
MW          204.313;      // g/mol [origin=calculated method=formula-sum]
Tc          806.01;      // K   [origin=predictive method=joback]
Pc          21.433;      // bar [origin=predictive method=joback]
omega       0.6769;      // -   [origin=predictive method=lee-kesler]
Tb          600.03;      // K   [origin=predictive method=joback]
HvapTb      55392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.066 1.23284 -0.0007535 1.7136e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(phenylmethyl)heptan-4-one" "benzyl dipropyl ketone" "morellone" "4-heptanone, 3-(phenylmethyl)-" "3-(phenylmethyl)-4-heptanone" "1-benzyldipropyl ketone" "1-benzyl dipropyl ketone" "4-heptanone, 3-benzyl-" "3-benzylheptan-4-one" "4-heptanone, 3-benzyl- (8ci)" );
gibbsFormation
{
    dHf_298   -213620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48050.0
    phase     gas;
}
