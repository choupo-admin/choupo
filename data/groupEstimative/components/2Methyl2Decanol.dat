/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-2-decanol  (C11H24O, CAS 3396-02-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl2Decanol;
formula     C11H24O;
CAS         3396-02-9;
InChIKey    WTXBAYPZJKPZHX-UHFFFAOYSA-N;
MW          172.312;      // g/mol [origin=calculated method=formula-sum]
Tc          705.97;      // K   [origin=predictive method=joback]
Pc          21.374;      // bar [origin=predictive method=joback]
omega       0.8920;      // -   [origin=predictive method=lee-kesler]
Tb          540.23;      // K   [origin=predictive method=joback]
HvapTb      55463.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.293 1.20866 -0.0007768 2.014e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group C; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyldecan-2-ol" "2-methyl-decan-2-ol" "2-decanol, 2-methyl-" "2-methyl decanol-2" );
standardThermochemistry
{
    dHf_298   -431350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-92240.0
}
