/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromanylpent-2-ene  (C5H9Br, CAS 21964-23-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromanylpent2Ene;
formula     C5H9Br;
CAS         21964-23-8;
InChIKey    OPGVCEGMOFKBOL-UHFFFAOYSA-N;
MW          149.031;      // g/mol [origin=calculated method=formula-sum]
Tc          583.18;      // K   [origin=predictive method=joback]
Pc          40.466;      // bar [origin=predictive method=joback]
omega       0.3143;      // -   [origin=predictive method=lee-kesler]
Tb          384.20;      // K   [origin=predictive method=joback]
HvapTb      33197.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.339 0.53694 -0.0004057 1.316e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -12770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77210.0
}
