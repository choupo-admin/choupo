/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylenecyclooctane  (C9H16, CAS 3618-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylenecyclooctane;
formula     C9H16;
CAS         3618-18-6;
InChIKey    GQRWNDZUODCEAJ-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          655.72;      // K   [origin=predictive method=joback]
Pc          31.740;      // bar [origin=predictive method=joback]
omega       0.2776;      // -   [origin=predictive method=lee-kesler]
Tb          437.44;      // K   [origin=predictive method=joback]
HvapTb      36869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.79 0.8707 -0.000417 4.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 7; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylidenecyclooctane" "cyclooctane, methylene-" );
standardThermochemistry
{
    dHf_298   -82510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85940.0
}
