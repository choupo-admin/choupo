/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(beta-(diethylamino)ethoxy)propyl p-aminobenzoate  (C16H26N2O3, CAS 63917-76-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3BetaDiethylaminoEthoxyPropylPAminobenzoate;
formula     C16H26N2O3;
CAS         63917-76-0;
InChIKey    PZABEXWNZYLYEY-UHFFFAOYSA-N;
MW          294.395;      // g/mol [origin=calculated method=formula-sum]
Tc          962.18;      // K   [origin=predictive method=joback]
Pc          17.434;      // bar [origin=predictive method=joback]
omega       1.0976;      // -   [origin=predictive method=lee-kesler]
Tb          762.95;      // K   [origin=predictive method=joback]
HvapTb      76649.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.447 1.45324 -0.00076116 1.163e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-(diethylamino)ethoxy]propyl 4-azanylbenzoate" "benzoic acid, p-amino-, 3-(beta-(diethylamino)ethoxy)propyl ester" "3-(2-diethylaminoethyloxy)propyl 4-aminobenzoate" );
gibbsFormation
{
    dHf_298   -496690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     796.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51520.0
    phase     gas;
}
