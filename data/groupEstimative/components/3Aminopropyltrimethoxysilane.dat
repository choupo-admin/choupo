/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-aminopropyltrimethoxysilane  (C6H17NO3Si, CAS 13822-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H17NO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Aminopropyltrimethoxysilane;
formula     C6H17NO3Si;
CAS         13822-56-5;
InChIKey    SJECZPVISLOESU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          179.291;      // g/mol [origin=calculated method=formula-sum]
Tc          662.65;      // K   [origin=predictive method=joback]
Pc          27.469;      // bar [origin=predictive method=joback]
omega       0.6009;      // -   [origin=predictive method=lee-kesler]
Tb          478.07;      // K   [origin=predictive method=joback]
HvapTb      47115.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (121.243 0.23996 0.0004018 -3.104e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3O; count 3; } { group CH2NH2; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group O; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-trimethoxysilylpropan-1-amine" "(3-aminopropyl)trimethoxysilane" "1-propanamine, 3-(trimethoxysilyl)-" "3-(trimethoxysilyl)propylamine" "3-(trimethoxysilyl)-1-propanamine" "3-(trimethoxysilyl)propan-1-amine" "n-(trimethoxysilylpropyl)amine" "propylamine, 3-(trimethoxysilyl)-" "3-aminopropyl-trimethoxy silane" "3-(trimethoxysilyl)-propylamine" "(gamma-aminopropyl)trimethoxysilane" "(.gamma.-aminopropyl)trimethoxysilane" );
standardThermochemistry
{
    dHf_298   -641660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-353670.0
}
