/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-acetylphenanthrene  (C16H12O, CAS 2039-76-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Acetylphenanthrene;
formula     C16H12O;
CAS         2039-76-1;
InChIKey    JKVNPRNAHRHQDD-UHFFFAOYSA-N;
MW          220.271;      // g/mol [origin=calculated method=formula-sum]
Tc          943.75;      // K   [origin=predictive method=joback]
Pc          27.701;      // bar [origin=predictive method=joback]
omega       0.7326;      // -   [origin=predictive method=lee-kesler]
Tb          694.15;      // K   [origin=predictive method=joback]
HvapTb      64836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.49 1.29052 -0.00099846 3.0806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 5; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 5; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenanthren-3-ylethanone" "1-(3-phenanthryl)ethanone" "1-(phenanthren-3-yl)ethanone" "ethanone, 1-(3-phenanthrenyl)-" "methyl 3-phenanthryl ketone" "3-acetyl phenanthrene" "ketone, methyl 3-phenanthryl" "1-(3-phenanthryl)ethan-1-one" "jkvnprnahrhqdd-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   109580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=261370.0
}
