/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-benzylphenyl)ethanone  (C15H14O, CAS 782-92-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BenzylphenylEthanone;
formula     C15H14O;
CAS         782-92-3;
InChIKey    PPYJQGBEZQOXHC-UHFFFAOYSA-N;
MW          210.276;      // g/mol [origin=calculated method=formula-sum]
Tc          897.40;      // K   [origin=predictive method=joback]
Pc          26.353;      // bar [origin=predictive method=joback]
omega       0.6540;      // -   [origin=predictive method=lee-kesler]
Tb          655.01;      // K   [origin=predictive method=joback]
HvapTb      60944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.899 1.18352 -0.00076886 1.8436e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-(phenylmethyl)phenyl]ethanone" "4-acetyldiphenylmethane" "(4-acetylphenyl)phenylmethane" "4-(acetylphenyl)phenylmethane" "1-(4-benzylphenyl)ethan-1-one" "1-acetyl-4-benzylbenzene" "ethanone,1-[4-(phenylmethyl)phenyl]-" );
standardThermochemistry
{
    dHf_298   -3920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161690.0
}
