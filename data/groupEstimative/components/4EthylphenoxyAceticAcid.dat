/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-ethylphenoxy)acetic acid  (C10H12O3, CAS 24431-27-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4EthylphenoxyAceticAcid;
formula     C10H12O3;
CAS         24431-27-4;
InChIKey    WVELHLIHMYYZAT-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          846.22;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.8642;      // -   [origin=predictive method=lee-kesler]
Tb          627.99;      // K   [origin=predictive method=joback]
HvapTb      60366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.292 0.80302 -0.00044596 8.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-ethylphenoxy)ethanoic acid" "2-(4-ethylphenoxy)acetic acid" "4-ethylphenoxyacetic acid" "(4-ethyl-phenoxy)-acetic acid" "acetic acid, (4-ethylphenoxy)-" "acetic acid,2-(4-ethylphenoxy)-" "aceticacid, (4-ethylphenoxy)- (9ci); acetic acid, (p-ethylphenoxy)- (6ci,7ci,8ci);4-ethylphenoxyacetic acid" );
gibbsFormation
{
    dHf_298   -507160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-312810.0
    phase     gas;
}
