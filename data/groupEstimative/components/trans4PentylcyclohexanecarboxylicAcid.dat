/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-4-pentylcyclohexanecarboxylic acid  (C12H22O2, CAS 38289-29-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans4PentylcyclohexanecarboxylicAcid;
formula     C12H22O2;
CAS         38289-29-1;
InChIKey    RVLAXPQGTRTHEV-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          840.85;      // K   [origin=predictive method=joback]
Pc          22.483;      // bar [origin=predictive method=joback]
omega       0.8071;      // -   [origin=predictive method=lee-kesler]
Tb          634.55;      // K   [origin=predictive method=joback]
HvapTb      59590.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.086 1.29022 -0.0007272 1.41e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-pentylcyclohexane-1-carboxylic acid" "4-pentylcyclohexanecarboxylic acid" "trans-4-n-pentylcyclohexanecarboxylic acid" "trans-4-amylcyclohexanecarboxylic acid" "4-pentylcyclohexanecarboxylicacid" "4-n-pentylcyclohexane carboxylic acid" "cyclohexanecarboxylic acid, 4-pentyl-" "rvlaxpqgtrthev-uhfffaoysa-" "4-pentyl-cyclohexanecarboxylic acid" "trans-4-pentylcyclohexyl carboxylic acid" "trans-4-pentylcyclohexanecarboxylic acid," "cyclohexanecarboxylicacid, 4-pentyl-, trans-" );
gibbsFormation
{
    dHf_298   -607300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-277010.0
    phase     gas;
}
