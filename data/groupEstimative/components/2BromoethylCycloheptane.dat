/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-bromoethyl)cycloheptane  (C9H17Br, CAS 22579-30-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromoethylCycloheptane;
formula     C9H17Br;
CAS         22579-30-2;
InChIKey    YFWUUIKFHYDTGJ-UHFFFAOYSA-N;
MW          205.139;      // g/mol [origin=calculated method=formula-sum]
Tc          720.43;      // K   [origin=predictive method=joback]
Pc          31.456;      // bar [origin=predictive method=joback]
omega       0.4046;      // -   [origin=predictive method=lee-kesler]
Tb          495.50;      // K   [origin=predictive method=joback]
HvapTb      42664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.828 1.0095 -0.0005718 1.097e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromoethylcycloheptane" "cycloheptane,(2-bromoethyl)-" );
standardThermochemistry
{
    dHf_298   -154600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=51570.0
}
