/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-tert-butyltoluene  (C11H16, CAS 1075-38-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3TertButyltoluene;
formula     C11H16;
CAS         1075-38-3;
InChIKey    JTIAYWZZZOZUTK-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          696.60;      // K   [origin=predictive method=joback]
Pc          26.598;      // bar [origin=predictive method=joback]
omega       0.3422;      // -   [origin=predictive method=lee-kesler]
Tb          479.71;      // K   [origin=predictive method=joback]
HvapTb      41722.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.19 1.03628 -0.00071056 1.922e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-3-methyl-benzene" "toluene, m-tert-butyl-" "1-tert-butyl-3-methylbenzene" "benzene, 1-(1,1-dimethylethyl)-3-methyl-" "m-tert-butyltoluene" "agn-pc-0crsf4" "1-methyl-3-tert-butylbenzene" "1-(tert-butyl)-3-methylbenzene" "jtiaywzzzozutk-uhfffaoysa-" "benzene,1-dimethylethyl)-3-methyl-" );
standardThermochemistry
{
    dHf_298   -54060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147360.0
}
