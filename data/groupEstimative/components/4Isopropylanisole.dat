/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropylanisole  (C10H14O, CAS 4132-48-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Isopropylanisole;
formula     C10H14O;
CAS         4132-48-3;
InChIKey    JULZQKLZSNOEEJ-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          691.23;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.4312;      // -   [origin=predictive method=lee-kesler]
Tb          482.04;      // K   [origin=predictive method=joback]
HvapTb      42814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.99 0.75816 -0.00037656 5.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-4-propan-2-yl-benzene" "4-methoxycumene" "anisole, p-isopropyl-" "1-isopropyl-4-methoxybenzene" "p-isopropylanisole" "benzene, 1-methoxy-4-(1-methylethyl)-" "2-(4-methoxyphenyl)propane" "4-isopropyl-1-methoxybenzene" "2-(4'-methoxyphenyl)propane" "agn-pc-0d0s49" "4-isopropylphenyl methyl ether" "1-methoxy-4-propan-2-ylbenzene" );
gibbsFormation
{
    dHf_298   -162170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28660.0
    phase     gas;
}
