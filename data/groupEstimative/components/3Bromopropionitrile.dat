/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromopropionitrile  (C3H4BrN, CAS 2417-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromopropionitrile;
formula     C3H4BrN;
CAS         2417-90-5;
InChIKey    CQZIEDXCLQOOEH-UHFFFAOYSA-N;
MW          133.976;      // g/mol [origin=calculated method=formula-sum]
Tc          650.46;      // K   [origin=predictive method=joback]
Pc          46.785;      // bar [origin=predictive method=joback]
omega       0.4439;      // -   [origin=predictive method=lee-kesler]
Tb          436.48;      // K   [origin=predictive method=joback]
HvapTb      39185.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.352 0.2618 -0.0001798 5.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2CN; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group Br; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylpropanenitrile" "3-bromopropanenitrile" "propanenitrile, 3-bromo-" "propionitrile, 3-bromo-" "2-bromoethyl cyanide" "1-bromo-2-cyanoethane" "usaf do-51" "2-cyanoethyl bromide" "3-bromopropiononitrile" "beta-bromopropionitrile" "beta-bromopriopionitrile" "propionitrile, beta-bromo-" );
standardThermochemistry
{
    dHf_298   85960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=121880.0
}
