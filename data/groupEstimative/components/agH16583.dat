/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-h-16583  (C11H16O, CAS 78985-13-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agH16583;
formula     C11H16O;
CAS         78985-13-4;
InChIKey    QVMOEEBACLJUFD-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          784.03;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       0.9026;      // -   [origin=predictive method=lee-kesler]
Tb          590.06;      // K   [origin=predictive method=joback]
HvapTb      61683.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.471 0.76598 -0.00036804 5.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group ACCH3; count 4; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,3,5,6-tetramethylphenyl)methanol" "2,3,5,6-tetramethyl-benzyl alcohol" "benzenemethanol,2,3,5,6-tetramethyl-" "(2,3,5,6-tetramethylphenyl)methan-1-ol" "(2,3,5,6-tetramethylphenyl)methanol;2,3,5,6-tetramethylbenzyl alcohol" );
gibbsFormation
{
    dHf_298   -231950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-21190.0
    phase     gas;
}
