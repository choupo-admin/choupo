/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzyl azelaate  (C23H28O4, CAS 1932-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzylAzelaate;
formula     C23H28O4;
CAS         1932-84-9;
InChIKey    AEPUKSBIJZXFCI-UHFFFAOYSA-N;
MW          368.473;      // g/mol [origin=calculated method=formula-sum]
Tc          1111.69;      // K   [origin=predictive method=joback]
Pc          13.185;      // bar [origin=predictive method=joback]
omega       1.0515;      // -   [origin=predictive method=lee-kesler]
Tb          895.64;      // K   [origin=predictive method=joback]
HvapTb      86158.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.011 1.9214 -0.0011006 1.993e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 10; } { group ACCH2; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(phenylmethyl) nonanedioate" "nonanedioic acid, bis(phenylmethyl) ester" "nonanedioic acid, 1,9-bis(phenylmethyl) ester" "dibenzyl azelate" "dibenzyl nonanedioate" "nonanedioic acid,1,9-bis(phenylmethyl) ester" "azelaicacid, dibenzyl ester (6ci,7ci,8ci); nonanedioic acid, bis(phenylmethyl) ester(9ci); dibenzyl azelate" );
gibbsFormation
{
    dHf_298   -679550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     941.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-253140.0
    phase     gas;
}
