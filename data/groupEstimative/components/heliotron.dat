/*--------------------------------*- Choupo -*-----------------------*\
  Component: heliotron  (C16H27NO5, CAS 303-33-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heliotron;
formula     C16H27NO5;
CAS         303-33-3;
InChIKey    LMFKRLGHEKVMNT-UHFFFAOYSA-N;
MW          313.394;      // g/mol [origin=calculated method=formula-sum]
Tc          1058.77;      // K   [origin=predictive method=joback]
Pc          19.877;      // bar [origin=predictive method=joback]
omega       1.5257;      // -   [origin=predictive method=lee-kesler]
Tb          860.90;      // K   [origin=predictive method=joback]
HvapTb      95308.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.219 1.91208 -0.00130684 3.432e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 4; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 2; } { group CH3O; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 2; } { group O; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(7-oxidanyl-5,6,7,8-tetrahydro-3h-pyrrolizin-1-yl)methyl 2-(1-methoxyethyl)-3-methyl-2-oxidanyl-butanoate" "heliotrine" "(1-hydroxy-2,3,5,7a-tetrahydro-1h-pyrrolizin-7-yl)methyl-2-hydroxy-2-isopropyl-3-methoxybutanoat" "7s-heliotrine" "(+)-heliotrine" "agn-pc-00hnkb" "butanoic acid, 2-hydroxy-2-(1-methoxyethyl)-3-methyl-, (2,3,5,7a-tetrahydro-1-hydroxy-1h-pyrrolizin-7-yl)methyl ester, (1s-(1 alpha,7(2r*,3s*),7a alpha))-" "(7-hydroxy-5,6,7,8-tetrahydro-3h-pyrrolizin-1-yl)methyl 2-hydroxy-2-(1-methoxyethyl)-3-methylbutanoate" "[(7r,8r)-7-hydroxy-5,6,7,8-tetrahydro-3h-pyrrolizin-1-yl]methyl (2s)-2-hydroxy-2-[(1r)-1-methoxyethyl]-3-methylbutanoate" "butanoic acid, 2-hydroxy-2-(1-methoxyethyl)-3-methyl-, (2,3,5,7a-tetrahydro-1-hydroxy-1h-pyrrolizin-7-yl)methyl ester, [1s-[1.alpha.,7(2r*,3s*),7a.alpha.]]-" "butanoic acid,2-hydroxy-2-[(1r)-1-methoxyethyl]-3-methyl-,[(1s,7ar)-2,3,5,7a-tetrahydro-1-hydroxy-1h-pyrrolizin-7-yl]methyl ester, (2s)-" "butanoicacid, 2-hydroxy-2-(1-methoxyethyl)-3-methyl-,(2,3,5,7a-tetrahydro-1-hydroxy-1h-pyrrolizin-7-yl)methyl ester, [1s-[1a,7[r*(s*)],7aa]]-; heliotrine (6ci,8ci);(+)-heliotrine; 7s-heliotrine" );
standardThermochemistry
{
    dHf_298   -893560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     697.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-366700.0
}
