/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hexyl-1,3-dioxane  (C10H20O2, CAS 2244-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hexyl13Dioxane;
formula     C10H20O2;
CAS         2244-85-1;
InChIKey    MNIXGQSLDFHHHN-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          697.60;      // K   [origin=predictive method=joback]
Pc          25.227;      // bar [origin=predictive method=joback]
omega       0.5421;      // -   [origin=predictive method=lee-kesler]
Tb          501.85;      // K   [origin=predictive method=joback]
HvapTb      47303.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.165 1.06992 -0.0005734 1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxane, 4-hexyl-" "m-dioxane,4-hexyl- (6ci,7ci,8ci); 4-hexyl-1,3-dioxacyclohexane; 4-hexyl-1,3-dioxane;4-n-hexyl-1,3-dioxane" );
standardThermochemistry
{
    dHf_298   -459410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114470.0
}
