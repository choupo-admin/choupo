name        propanol1Methyl12EthanediylBisOxyBisPolymerWith11Methylenebi;
formula     C30H44N2O9;
CAS         146817-69-8;
InChIKey    BSBPMRMHVQNFPY-UHFFFAOYSA-N;
MW          576.687;      // g/mol [origin=calculated method=formula-sum]
Tc          2229.82;      // K   [origin=predictive method=joback]
Pc          9.958;      // bar [origin=predictive method=joback]
omega       -0.0845;      // -   [origin=predictive method=lee-kesler]
Tb          1521.00;      // K   [origin=predictive method=joback]
HvapTb      181460.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 4; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group CH; count 1; } { group dCd; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 4; } { group O; count 3; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene;3-(3-oxidanylpropoxy)propan-1-ol;3-[2-(3-oxidanylpropoxy)propoxy]propan-1-ol" );
