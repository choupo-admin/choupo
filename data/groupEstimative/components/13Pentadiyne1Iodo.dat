/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-pentadiyne, 1-iodo-  (C5H3I, CAS 40201-91-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Pentadiyne1Iodo;
formula     C5H3I;
CAS         40201-91-0;
InChIKey    ZYWAFJXPPXRZAM-UHFFFAOYSA-N;
MW          189.979;      // g/mol [origin=calculated method=formula-sum]
Tc          695.75;      // K   [origin=predictive method=joback]
Pc          51.020;      // bar [origin=predictive method=joback]
omega       0.1363;      // -   [origin=predictive method=lee-kesler]
Tb          425.14;      // K   [origin=predictive method=joback]
HvapTb      40401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.15 0.21822 -0.00014532 4.616e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group I; count 1; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tC; count 4; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanylpenta-1,3-diyne" "1-iodopenta-1,3-diyne" );
gibbsFormation
{
    dHf_298   474940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=454940.0
    phase     gas;
}
