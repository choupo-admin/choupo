/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl bromoacetate  (C4H7BrO2, CAS 105-36-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylBromoacetate;
formula     C4H7BrO2;
CAS         105-36-2;
InChIKey    PQJJJMRNHATNKG-UHFFFAOYSA-N;
MW          167.002;      // g/mol [origin=calculated method=formula-sum]
Tc          610.58;      // K   [origin=predictive method=joback]
Pc          42.831;      // bar [origin=predictive method=joback]
omega       0.4764;      // -   [origin=predictive method=lee-kesler]
Tb          415.50;      // K   [origin=predictive method=joback]
HvapTb      38340.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.852 0.36722 -0.0001706 1.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2COO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-bromanylethanoate" "antol" "ethyl 2-bromoacetate" "acetic acid, bromo-, ethyl ester" "ethyl bromacetate" "ethoxycarbonylmethyl bromide" "ethyl monobromoacetate" "bromoacetic acid ethyl ester" "bromoacetic acid, ethyl ester" "ethyl alpha-bromoacetate" "acetic acid, 2-bromo-, ethyl ester" "ethyl bromo acetate" );
standardThermochemistry
{
    dHf_298   -416840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-313250.0
}
