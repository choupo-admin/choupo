/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-030n12  (C20H37NO, CAS 63021-11-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc030n12;
formula     C20H37NO;
CAS         63021-11-4;
InChIKey    VGKVWFYBHNBKPA-UHFFFAOYSA-N;
MW          307.522;      // g/mol [origin=calculated method=formula-sum]
Tc          911.48;      // K   [origin=predictive method=joback]
Pc          11.998;      // bar [origin=predictive method=joback]
omega       0.9793;      // -   [origin=predictive method=lee-kesler]
Tb          734.81;      // K   [origin=predictive method=joback]
HvapTb      68911.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.866 2.20672 -0.0015639 4.5996e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH=CH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group dCH; count 2; } { group CH2_ring; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(aziridin-1-yl)octadec-9-en-1-one" "(z)-1-(aziridin-1-yl)octadec-9-en-1-one" );
standardThermochemistry
{
    dHf_298   -284660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     903.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=260160.0
}
