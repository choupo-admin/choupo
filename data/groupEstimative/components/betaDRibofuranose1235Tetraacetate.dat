/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-d-ribofuranose 1,2,3,5-tetraacetate  (C13H18O9, CAS 13035-61-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaDRibofuranose1235Tetraacetate;
formula     C13H18O9;
CAS         13035-61-5;
InChIKey    IHNHAHWGVLXCCI-FDYHWXHSSA-N;
MW          318.278;      // g/mol [origin=calculated method=formula-sum]
Tc          956.75;      // K   [origin=predictive method=joback]
Pc          17.743;      // bar [origin=predictive method=joback]
omega       1.1038;      // -   [origin=predictive method=lee-kesler]
Tb          758.14;      // K   [origin=predictive method=joback]
HvapTb      78000.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (67.361 1.06888 -0.0002523 -1.387e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 3; } { group CH3COO; count 4; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH_ring; count 4; } { group O_ring; count 1; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2r,3r,4r,5s)-3,4,5-triacetyloxyoxolan-2-yl]methyl ethanoate" "tetra-o-acetyl-beta-d-ribofuranose" "1,2,3,5-tetra-o-acetyl-beta-d-ribofuranose" "tetra-o-acetyl-b-d-ribofuranose" "1,2,3,5-tetraacetyl-beta-d-ribofuranose" "tetraacetylribofuranose" "tetraacetylribose" "ribofuranose tetraacetate" "beta(r)-d-tetraacetyl ribose" "a-d-ribofuranose, tetraacetate" "ss-d-ribofuranose, tetraacetate" "tetraacetyl-beta-d-ribofuranoside" );
gibbsFormation
{
    dHf_298   -1713310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1255600.0
    phase     gas;
}
