/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dibromo-2,3,5,6-tetramethylbenzene  (C10H12Br2, CAS 1646-54-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dibromo2356Tetramethylbenzene;
formula     C10H12Br2;
CAS         1646-54-4;
InChIKey    IEWAQZBDJDWANM-UHFFFAOYSA-N;
MW          292.014;      // g/mol [origin=calculated method=formula-sum]
Tc          852.31;      // K   [origin=predictive method=joback]
Pc          31.420;      // bar [origin=predictive method=joback]
omega       0.6401;      // -   [origin=predictive method=lee-kesler]
Tb          612.30;      // K   [origin=predictive method=joback]
HvapTb      56310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.77 0.65388 -0.000359 7.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 2; } { group ACCH3; count 4; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC_ring; count 6; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(bromanyl)-2,3,5,6-tetramethyl-benzene" "3,6-dibromodurene" "benzene, 1,4-dibromo-2,3,5,6-tetramethyl-" "benzene,4-dibromo-2,3,5,6-tetramethyl-" );
gibbsFormation
{
    dHf_298   -17890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=126220.0
    phase     gas;
}
