/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-dimethylidenecyclohexa-1,4-diene  (C8H8, CAS 502-86-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Dimethylidenecyclohexa14Diene;
formula     C8H8;
CAS         502-86-3;
InChIKey    NRNFFDZCBYOZJY-UHFFFAOYSA-N;
MW          104.152;      // g/mol [origin=calculated method=formula-sum]
Tc          613.22;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       0.2813;      // -   [origin=predictive method=lee-kesler]
Tb          403.50;      // K   [origin=predictive method=joback]
HvapTb      35042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.79 0.5654 -0.00033756 7.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-cyclohexadiene, 3,6-bis(methylene)-" "p-xylylene" "1,4-quinodimethane" "1,4-cyclohexadiene,3,6-bis(methylene)-" "3,6-bis(methylene)-1,4-cyclohexadiene" );
gibbsFormation
{
    dHf_298   150250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=214720.0
    phase     gas;
}
