/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyloxytrimethylsilane  (C6H14OSi, CAS 18146-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H14OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        allyloxytrimethylsilane;
formula     C6H14OSi;
CAS         18146-00-4;
InChIKey    MNMVKGDEKPPREK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          130.262;      // g/mol [origin=calculated method=formula-sum]
Tc          531.67;      // K   [origin=predictive method=joback]
Pc          28.024;      // bar [origin=predictive method=joback]
omega       0.2615;      // -   [origin=predictive method=lee-kesler]
Tb          357.38;      // K   [origin=predictive method=joback]
HvapTb      30984.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.761 0.28446 0.0002003 -1.944e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2=CH; count 1; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(prop-2-enoxy)silane" "allyl trimethylsilyl ether" "3-(trimethylsiloxy)propene" "trimethyl(2-propenyloxy)silane" "silane, trimethyl(2-propen-1-yloxy)-" "o-trimethylsilylallyl alcohol" "silane, trimethyl(2-propenyloxy)-" "silane,(allyloxy)trimethyl- (6ci,7ci,8ci);silane, trimethyl(2-propenyloxy)- (9ci);(allyloxy)trimethylsilane;1-trimethylsiloxy-2-propene;1-trimethylsilyloxy-2-propene;allyl trimethylsilyl ether;trimethyl(2-propenyloxy)silane;trimethylallyloxysilane;trimethylsilylallylether;" );
gibbsFormation
{
    dHf_298   -285580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122280.0
    phase     gas;
}
