/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloundecanemethanol  (C12H24O, CAS 29518-02-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloundecanemethanol;
formula     C12H24O;
CAS         29518-02-3;
InChIKey    XSFJMMWTLXMXTK-UHFFFAOYSA-N;
MW          184.323;      // g/mol [origin=calculated method=formula-sum]
Tc          820.69;      // K   [origin=predictive method=joback]
Pc          26.353;      // bar [origin=predictive method=joback]
omega       0.7482;      // -   [origin=predictive method=lee-kesler]
Tb          607.24;      // K   [origin=predictive method=joback]
HvapTb      60274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.939 1.2519 -0.0005084 1.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloundecylmethanol" "methanol, cycloundecane-" );
standardThermochemistry
{
    dHf_298   -419720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     743.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122710.0
}
