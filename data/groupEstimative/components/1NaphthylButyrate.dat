/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-naphthyl butyrate  (C14H14O2, CAS 3121-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1NaphthylButyrate;
formula     C14H14O2;
CAS         3121-70-8;
InChIKey    XIVJNRXPRQKFRZ-UHFFFAOYSA-N;
MW          214.264;      // g/mol [origin=calculated method=formula-sum]
Tc          852.97;      // K   [origin=predictive method=joback]
Pc          25.100;      // bar [origin=predictive method=joback]
omega       0.6953;      // -   [origin=predictive method=lee-kesler]
Tb          628.78;      // K   [origin=predictive method=joback]
HvapTb      58743.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.478 1.13692 -0.00074408 1.8e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 7; } { group AC; count 3; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalen-1-yl butanoate" ".alpha.-naphthyl butyrate" "butyric acid 1-naphthyl ester" "alpha-naphthyl butyrate" "butanoic acid, 1-naphthalenyl ester" "butanoic acid 1-naphthyl ester" "butyric acid, 1-naphthyl ester" "naphthyl butanoate" "alpha-naphthyl-n-butyrate" "a-naphthyl butyrate" ".alpha.-naphthyl-n-butyrate" "butanoic acid, naphthalenyl ester" );
gibbsFormation
{
    dHf_298   -233440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-33940.0
    phase     gas;
}
