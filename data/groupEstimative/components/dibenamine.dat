/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenamine  (C16H18ClN, CAS 51-50-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenamine;
formula     C16H18ClN;
CAS         51-50-3;
InChIKey    GSLWSSUWNCJILM-UHFFFAOYSA-N;
MW          259.777;      // g/mol [origin=calculated method=formula-sum]
Tc          898.47;      // K   [origin=predictive method=joback]
Pc          22.021;      // bar [origin=predictive method=joback]
omega       0.6927;      // -   [origin=predictive method=lee-kesler]
Tb          668.91;      // K   [origin=predictive method=joback]
HvapTb      62190.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.266 1.4967 -0.001042 2.766e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2N; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n,n-bis(phenylmethyl)ethanamine" "dibenzylchlorethamine" "dibenzyl chlorethylamine" "n-(2-chloroethyl)dibenzylamine" "dibenzylchlorethylamine" "n,n-dibenzyl-2-chloroethanamine" "dibenzylamine, n-(2-chloroethyl)-" "2-chloroethyldibenzylamine" "dibenzyl-2-chloroethylamine" "dibenzyl(2-chloroethyl)amine" "2-(dibenzylamino)ethyl chloride" "n,n-dibenzyl-2-chloroethylamine" );
standardThermochemistry
{
    dHf_298   151280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     615.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=407510.0
}
