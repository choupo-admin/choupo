/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-butoxy-2-methylene-4-oxobutanoic acid  (C9H14O4, CAS 27216-48-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Butoxy2Methylene4OxobutanoicAcid;
formula     C9H14O4;
CAS         27216-48-4;
InChIKey    VVAAYFMMXYRORI-UHFFFAOYSA-N;
MW          186.207;      // g/mol [origin=calculated method=formula-sum]
Tc          799.27;      // K   [origin=predictive method=joback]
Pc          26.543;      // bar [origin=predictive method=joback]
omega       0.9444;      // -   [origin=predictive method=lee-kesler]
Tb          605.81;      // K   [origin=predictive method=joback]
HvapTb      59609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.034 0.83472 -0.000469 8.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=C; count 1; } { group CH2COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-butoxy-2-methylidene-4-oxidanylidene-butanoic acid" "butanedioic acid, methylene-, monobutyl ester" "butanedioic acid, 2-methylene-, monobutyl ester" "mono-butyl itaconate" "beta-butyl itaconate" "mono-n-butyl itaconate" "4-butyl methylenesuccinate" "itaconic acid monobutyl ester" "2-(2-butoxy-2-oxoethyl)acrylic acid" "4-butoxy-2-methylidene-4-oxobutanoic acid" );
standardThermochemistry
{
    dHf_298   -781000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-550090.0
}
