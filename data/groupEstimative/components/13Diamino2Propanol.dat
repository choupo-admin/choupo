/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diamino-2-propanol  (C3H10N2O, CAS 616-29-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diamino2Propanol;
formula     C3H10N2O;
CAS         616-29-5;
InChIKey    UYBWIEGTWASWSR-UHFFFAOYSA-N;
MW          90.126;      // g/mol [origin=calculated method=formula-sum]
Tc          698.13;      // K   [origin=predictive method=joback]
Pc          59.907;      // bar [origin=predictive method=joback]
omega       1.0058;      // -   [origin=predictive method=lee-kesler]
Tb          505.04;      // K   [origin=predictive method=joback]
HvapTb      59845.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.752 0.4525 -0.0002598 5.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group OH; count 1; } { group CH2NH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(azanyl)propan-2-ol" "1,3-diamino-2-hydroxypropane" "1,3-diaminopropan-2-ol" "diaminoisopropanol" "2-hydroxy-1,3-diaminopropane" "2-propanol, 1,3-diamino-" "2-hydroxy-1,3-propanediamine" "1,3-diamino-2-hydroxy-propane" "2-propanol,3-diamino-" "p173" );
gibbsFormation
{
    dHf_298   -195180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31980.0
    phase     gas;
}
