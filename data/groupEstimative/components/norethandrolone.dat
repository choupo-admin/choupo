/*--------------------------------*- Choupo -*-----------------------*\
  Component: norethandrolone  (C20H30O2, CAS 52-78-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norethandrolone;
formula     C20H30O2;
CAS         52-78-8;
InChIKey    ZDHCJEIGTNNEMY-XGXHKTLJSA-N;
MW          302.458;      // g/mol [origin=calculated method=formula-sum]
Tc          1094.03;      // K   [origin=predictive method=joback]
Pc          18.563;      // bar [origin=predictive method=joback]
omega       1.0615;      // -   [origin=predictive method=lee-kesler]
Tb          860.79;      // K   [origin=predictive method=joback]
HvapTb      79586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-266.169 2.74044 -0.00237404 8.902e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s,17s)-17-ethyl-13-methyl-17-oxidanyl-1,2,6,7,8,9,10,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-3-one" "pronabol" "nilevar" "solevar" "17-ethyl-19-nortestosterone" "17-ent" "nileva" "ethylnortestosteron" "19-nortestosterone, 17-ethyl-" "noretandrolone [dcit]" "19-norethyltestosterone" "17-alpha-nortestosterone" );
gibbsFormation
{
    dHf_298   -449550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     656.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=34540.0
    phase     gas;
}
