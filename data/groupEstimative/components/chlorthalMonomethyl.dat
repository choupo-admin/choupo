/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorthal monomethyl  (C9H4Cl4O4, CAS 887-54-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorthalMonomethyl;
formula     C9H4Cl4O4;
CAS         887-54-7;
InChIKey    SXINVWXSZUQKSW-UHFFFAOYSA-N;
MW          317.927;      // g/mol [origin=calculated method=formula-sum]
Tc          1050.93;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       1.1503;      // -   [origin=predictive method=lee-kesler]
Tb          810.55;      // K   [origin=predictive method=joback]
HvapTb      83325.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (113.87 0.50562 -0.0002214 3.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group AC; count 2; } { group COOH; count 1; } { group ACCl; count 4; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dC_ring; count 6; } { group Cl; count 4; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,5,6-tetrakis(chloranyl)-4-methoxycarbonyl-benzoic acid" "chlorthal-monomethyl" "monomethyl 2,3,5,6-tetrachloroterephthalate" "1,4-benzenedicarboxylic acid, 2,3,5,6-tetrachloro-, monomethyl ester" "monomethyl tetrachloroterephthalate" "dacthal monoacid" "chlorthal-monomethyl [iso]" "methyl 2,3,5,6-tetrachloroterephthalate" "tetrachloroterephthalic acid monomethyl ester" "2,3,5,6-tetrachloro-4-methoxycarbonylbenzoic acid" "2,3,5,6-tetrachloro-4-(methoxycarbonyl)benzoic acid" "2,3,5,6-tetrachloro-1,4-benzenedicarboxylic acid 4-methyl ester" );
gibbsFormation
{
    dHf_298   -780420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-612840.0
    phase     gas;
}
