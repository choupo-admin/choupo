/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-iodobenzotrifluoride  (C7H4F3I, CAS 455-13-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Iodobenzotrifluoride;
formula     C7H4F3I;
CAS         455-13-0;
InChIKey    SKGRFPGOGCHDPC-UHFFFAOYSA-N;
MW          272.003;      // g/mol [origin=calculated method=formula-sum]
Tc          708.05;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.3632;      // -   [origin=predictive method=lee-kesler]
Tb          479.14;      // K   [origin=predictive method=joback]
HvapTb      39740.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.59 0.7306 -0.00062356 2.013e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group I; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyl-4-(trifluoromethyl)benzene" "p-iodobenzotrifluoride" "1-iodo-4-(trifluoromethyl)benzene" "4-iodo-alpha,alpha,alpha-trifluorotoluene" "4-(trifluoromethyl)iodobenzene" "4-iodobenztrifluoride" "benzene, 1-iodo-4-(trifluoromethyl)-" "4-iodo-1-trifluoromethylbenzene" "p-iodotrifluorotoluene" "alpha,alpha,alpha-trifluoro-4-iodotoluene" "4 iodobenzotrifluoride" "4-iodobenzo trifluoride" );
standardThermochemistry
{
    dHf_298   -482960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-412630.0
}
