/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetonicotinic acid  (C8H7NO3, CAS 89942-59-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AcetonicotinicAcid;
formula     C8H7NO3;
CAS         89942-59-6;
InChIKey    JYUCDFZMJMRPHS-UHFFFAOYSA-N;
MW          165.148;      // g/mol [origin=calculated method=formula-sum]
Tc          910.55;      // K   [origin=predictive method=joback]
Pc          43.454;      // bar [origin=predictive method=joback]
omega       0.9452;      // -   [origin=predictive method=lee-kesler]
Tb          667.38;      // K   [origin=predictive method=joback]
HvapTb      66460.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.97 0.68198 -0.00043872 1.0536e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 1; } { group C5H3N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethanoylpyridine-3-carboxylic acid" "3-pyridinecarboxylicacid, 2-acetyl-" "2-actylnicotinic acid" "2-acetylnicotinic acid" "2-actyl nicotinic acid" "2-acetyl nicotinic acid" "2-acetyl-3-pyridinecarboxylic acid" "3-pyridinecarboxylic acid, 2-acetyl-" "i178" "nicotinicacid, 2-acetyl- (6ci,7ci);2-acetylnicotinic acid;2-acetylpyridine-3-carboxylic acid;" );
standardThermochemistry
{
    dHf_298   -413450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-276520.0
}
