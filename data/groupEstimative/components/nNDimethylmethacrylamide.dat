/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylmethacrylamide  (C6H11NO, CAS 6976-91-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylmethacrylamide;
formula     C6H11NO;
CAS         6976-91-6;
InChIKey    QRWZCJXEAOZAAW-UHFFFAOYSA-N;
MW          113.16;      // g/mol [origin=calculated method=formula-sum]
Tc          583.11;      // K   [origin=predictive method=joback]
Pc          35.179;      // bar [origin=predictive method=joback]
omega       0.4343;      // -   [origin=predictive method=lee-kesler]
Tb          399.75;      // K   [origin=predictive method=joback]
HvapTb      37149.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.58 0.64966 -0.0004217 1.0776e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,2-trimethylprop-2-enamide" "2-propenamide, n,n,2-trimethyl-" "n,n,2-trimethylacrylamide" "acrylamide, n,n,2-trimethyl-" "2-propenamide,n,n,2-trimethyl-" );
standardThermochemistry
{
    dHf_298   -96580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60790.0
}
