/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-1,5-benzodiazepine, 2,3,4,5-tetrahydro-1,5-dimethyl-  (C11H16N2, CAS 19560-66-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1h15Benzodiazepine2345Tetrahydro15Dimethyl;
formula     C11H16N2;
CAS         19560-66-8;
InChIKey    OUXSQIUQOPQARQ-UHFFFAOYSA-N;
MW          176.263;      // g/mol [origin=calculated method=formula-sum]
Tc          732.86;      // K   [origin=predictive method=joback]
Pc          30.899;      // bar [origin=predictive method=joback]
omega       0.5498;      // -   [origin=predictive method=lee-kesler]
Tb          519.23;      // K   [origin=predictive method=joback]
HvapTb      47326.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.28 1.33564 -0.00103956 3.226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-dimethyl-3,4-dihydro-2h-1,5-benzodiazepine" "1,5-dimethyl-2,3,4,5-tetrahydro-1h-1,5-benzodiazepine" );
gibbsFormation
{
    dHf_298   182890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=434540.0
    phase     gas;
}
