/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, 3-hydroxypropyl ester  (C7H12O3, CAS 2761-09-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2Methyl3HydroxypropylEster;
formula     C7H12O3;
CAS         2761-09-3;
InChIKey    GNSFRPWPOGYVLO-UHFFFAOYSA-N;
MW          144.17;      // g/mol [origin=calculated method=formula-sum]
Tc          679.45;      // K   [origin=predictive method=joback]
Pc          32.803;      // bar [origin=predictive method=joback]
omega       0.9320;      // -   [origin=predictive method=lee-kesler]
Tb          506.72;      // K   [origin=predictive method=joback]
HvapTb      54672.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.543 0.62792 -0.000318 4.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanylpropyl 2-methylprop-2-enoate" "1,3-propylene glycol methacrylate" "3-hydroxypropyl 2-methylprop-2-enoate" "3-hydroxypropyl methacrylate" "2-propenoic acid,2-methyl-, 3-hydroxypropyl ester" "poly(oxy(methyl-1,2-ethanediyl)), alpha-(2-methyl-1-oxo-2-propen-1-yl)-omega-hydroxy-" "poly(oxy(methyl-1,2-ethanediyl)), alpha-(2-methyl-1-oxo-2-propenyl)-omega-hydroxy-" "methacrylicacid, 3-hydroxypropyl ester (7ci); 1,3-propanediol monomethacrylate;1,3-propylene glycol methacrylate; 3-hydroxypropyl methacrylate;3-methacryloyloxypropanol" );
gibbsFormation
{
    dHf_298   -541680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-359840.0
    phase     gas;
}
