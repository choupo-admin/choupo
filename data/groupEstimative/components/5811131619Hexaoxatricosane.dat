/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,8,11,13,16,19-hexaoxatricosane  (C17H36O6, CAS 143-29-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5811131619Hexaoxatricosane;
formula     C17H36O6;
CAS         143-29-3;
InChIKey    DKWHHTWSTXZKDW-UHFFFAOYSA-N;
MW          336.469;      // g/mol [origin=calculated method=formula-sum]
Tc          890.60;      // K   [origin=predictive method=joback]
Pc          11.475;      // bar [origin=predictive method=joback]
omega       1.0214;      // -   [origin=predictive method=lee-kesler]
Tb          723.08;      // K   [origin=predictive method=joback]
HvapTb      67896.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (140.435 1.23964 -0.000235 -1.377e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH2O; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group O; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-[2-[2-(2-butoxyethoxy)ethoxymethoxy]ethoxy]ethoxy]butane" "butylcarbitol formal" "cryoflex" "dibutylcarbitol formal" "bis(butylcarbitol)formal" "dibutoxyethoxyethyl formal" "bis(butoxyethoxyethyl)formal" "bis(butoxyethoxyethoxy)methane" "dibutylcarbitolformal" "tp 90b" "methane, bis(2-(2-butoxyethoxy)ethoxy)-" "bis(2-(2-butoxyethoxy)ethoxy)methane" );
gibbsFormation
{
    dHf_298   -1187530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     885.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-537740.0
    phase     gas;
}
