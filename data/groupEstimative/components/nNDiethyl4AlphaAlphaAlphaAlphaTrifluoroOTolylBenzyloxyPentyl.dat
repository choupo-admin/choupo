/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethyl-4-(alpha-(alpha,alpha,alpha-trifluoro-o-tolyl)benzyloxy)pentylamine citrate  (C29H38F3NO8, CAS 3218-37-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethyl4AlphaAlphaAlphaAlphaTrifluoroOTolylBenzyloxyPentyl;
formula     C29H38F3NO8;
CAS         3218-37-9;
InChIKey    RAAJXWASYMJQFQ-UHFFFAOYSA-N;
MW          585.616;      // g/mol [origin=calculated method=formula-sum]
Tc          1937.35;      // K   [origin=predictive method=joback]
Pc          9.864;      // bar [origin=predictive method=joback]
omega       0.3714;      // -   [origin=predictive method=lee-kesler]
Tb          1476.90;      // K   [origin=predictive method=joback]
HvapTb      152461.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.303 2.88126 -0.00178336 3.788e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group C; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACCH; count 1; } { group OH; count 1; } { group CH-O; count 1; } { group CH2N; count 1; } { group COOH; count 3; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 2; } { group C; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group F; count 3; } { group OH; count 1; } { group O; count 1; } { group COOH; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-4-[phenyl-[2-(trifluoromethyl)phenyl]methoxy]pentan-1-amine;2-oxidanylpropane-1,2,3-tricarboxylic acid" "pentylamine, n,n-diethyl-4-(alpha-(alpha,alpha,alpha-trifluoro-o-tolyl)benzyloxy)-, citrate" "n,n-diethyl-4-[phenyl-[2-(trifluoromethyl)phenyl]methoxy]pentan-1-amine; 2-hydroxypropane-1,2,3-tricarboxylic acid" );
standardThermochemistry
{
    dHf_298   -2176040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1410.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1442670.0
}
