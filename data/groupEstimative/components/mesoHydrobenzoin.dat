/*--------------------------------*- Choupo -*-----------------------*\
  Component: meso-hydrobenzoin  (C14H14O2, CAS 579-43-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mesoHydrobenzoin;
formula     C14H14O2;
CAS         579-43-1;
InChIKey    IHPDTPWNFBQHEB-OKILXGFUSA-N;
MW          214.264;      // g/mol [origin=calculated method=formula-sum]
Tc          969.75;      // K   [origin=predictive method=joback]
Pc          34.602;      // bar [origin=predictive method=joback]
omega       1.4192;      // -   [origin=predictive method=lee-kesler]
Tb          756.76;      // K   [origin=predictive method=joback]
HvapTb      83892.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.43 1.2558 -0.0008674 2.25e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group ACCH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2s)-1,2-diphenylethane-1,2-diol" "meso-1,2-diphenyl-1,2-ethanediol" "meso-1,2-diphenylethylene glycol" );
gibbsFormation
{
    dHf_298   -174250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13300.0
    phase     gas;
}
