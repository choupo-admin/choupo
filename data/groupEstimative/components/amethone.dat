/*--------------------------------*- Choupo -*-----------------------*\
  Component: amethone  (C20H23NO2, CAS 6009-67-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amethone;
formula     C20H23NO2;
CAS         6009-67-2;
InChIKey    HPITVGRITATAFY-UHFFFAOYSA-N;
MW          309.409;      // g/mol [origin=calculated method=formula-sum]
Tc          1006.42;      // K   [origin=predictive method=joback]
Pc          17.909;      // bar [origin=predictive method=joback]
omega       0.9437;      // -   [origin=predictive method=lee-kesler]
Tb          784.64;      // K   [origin=predictive method=joback]
HvapTb      73196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.076 2.21764 -0.00192316 6.903e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group ACH; count 9; } { group AC; count 3; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-(diethylamino)ethyl]-3-phenyl-1-benzofuran-2-one" "amolanone" "amocaine" "amolanone [inn]" "ap 43" "amolanonum [inn-latin]" "3-[2-(diethylamino)ethyl]-3-phenyl-2(3h)-benzofuranone" "3-(beta-diethylaminoethyl)-3-phenyl-2-benzofuranone" "3-(2-(diethylamino)ethyl)-3-phenyl-2(3h)-benzofuranone" "2(3h)-benzofuranone, 3-(.beta.-diethylaminoethyl)-3-phenyl-" "2(3h)-benzofuranone, 3-(beta-diethylaminoethyl)-3-phenyl-" "3-(2-(diethylamino)ethyl)-2-oxo-3-phenyl-2,3-dihydrobenzofuran" );
gibbsFormation
{
    dHf_298   -143930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     722.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212580.0
    phase     gas;
}
