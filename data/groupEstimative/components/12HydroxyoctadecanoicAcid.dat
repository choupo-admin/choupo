/*--------------------------------*- Choupo -*-----------------------*\
  Component: 12-hydroxyoctadecanoic acid  (C18H36O3, CAS 106-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12HydroxyoctadecanoicAcid;
formula     C18H36O3;
CAS         106-14-9;
InChIKey    ULQISTXYYBZJSJ-UHFFFAOYSA-N;
MW          300.483;      // g/mol [origin=calculated method=formula-sum]
Tc          1039.33;      // K   [origin=predictive method=joback]
Pc          13.156;      // bar [origin=predictive method=joback]
omega       1.2143;      // -   [origin=predictive method=lee-kesler]
Tb          848.69;      // K   [origin=predictive method=joback]
HvapTb      89117.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.265 1.80452 -0.0010616 2.403e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "12-oxidanyloctadecanoic acid" "12-hydroxystearic acid" "octadecanoic acid, 12-hydroxy-" "harwax a" "cerit fac 3" "ceroxin gl" "barolub fto" "dl-12-hydroxystearic acid" "stearic acid, 12-hydroxy-" "loxiol g 21" "d-12-hydroxystearic acid" "dl-12-hydroxy stearic acid" );
gibbsFormation
{
    dHf_298   -922630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     951.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-382490.0
    phase     gas;
}
