/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,10-diacetoxydecane  (C14H26O4, CAS 26118-61-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        110Diacetoxydecane;
formula     C14H26O4;
CAS         26118-61-6;
InChIKey    NMOLZWLFORPIME-UHFFFAOYSA-N;
MW          258.358;      // g/mol [origin=calculated method=formula-sum]
Tc          807.35;      // K   [origin=predictive method=joback]
Pc          15.355;      // bar [origin=predictive method=joback]
omega       0.9388;      // -   [origin=predictive method=lee-kesler]
Tb          636.36;      // K   [origin=predictive method=joback]
HvapTb      61572.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.98 1.22424 -0.0005486 4.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-acetyloxydecyl ethanoate" "1,10-decanediol, diacetate" "decamethylene diacetate" "1,10-decanediol, 1,10-diacetate" "10-acetyloxydecyl acetate" "1,10-decanediol diacetate" "decamethylene glycol diacetate" "1,10-decanediol,1,10-diacetate" "1,10-decanediol,diacetate (6ci,7ci,8ci,9ci); 1,10-diacetoxydecane; decaethylene glycoldiacetate" );
gibbsFormation
{
    dHf_298   -966850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     803.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-553740.0
    phase     gas;
}
