/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylthio-2-butanone  (C5H10OS, CAS 53475-15-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylthio2Butanone;
formula     C5H10OS;
CAS         53475-15-3;
InChIKey    HFVLNCDRAMUMCC-UHFFFAOYSA-N;
MW          118.194;      // g/mol [origin=calculated method=formula-sum]
Tc          644.32;      // K   [origin=predictive method=joback]
Pc          38.579;      // bar [origin=predictive method=joback]
omega       0.4120;      // -   [origin=predictive method=lee-kesler]
Tb          436.21;      // K   [origin=predictive method=joback]
HvapTb      39899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.62 0.45115 -0.0001925 1.116e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH3CO; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CdO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylsulfanylbutan-2-one" "3-(methylthio)-2-butanone" "3-methylmercapto-2-butanone" "2-butanone, 3-(methylthio)-" "dl-3-(methylthio)butanone" "2-butanone,3-(methylthio)-" "3-(methylthio)-2-butanone;" "hfvlncdramumcc-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -222520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-107020.0
    phase     gas;
}
