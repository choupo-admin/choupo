/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-tert-butyl-2-methoxy-4-prop-1-enyl-phenol  (C14H20O2, CAS 67907-33-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5TertButyl2Methoxy4Prop1EnylPhenol;
formula     C14H20O2;
CAS         67907-33-9;
InChIKey    GOSYKXZLWIQKJI-UHFFFAOYSA-N;
MW          220.312;      // g/mol [origin=calculated method=formula-sum]
Tc          884.80;      // K   [origin=predictive method=joback]
Pc          23.611;      // bar [origin=predictive method=joback]
omega       0.7522;      // -   [origin=predictive method=lee-kesler]
Tb          660.53;      // K   [origin=predictive method=joback]
HvapTb      64444.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.22 1.3732 -0.00103588 3.287e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group C; count 1; } { group dCH; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(1,1-dimethylethyl)-2-methoxy-4-(1-propenyl)phenol" "phenol, 5-(1,1-dimethylethyl)-2-methoxy-4-(1-propenyl)-" "phenol, 5-(1,1-dimethylethyl)-2-methoxy-4-(1-propen-1-yl)-" "5-tert-butyl-2-methoxy-4-[(z)-prop-1-enyl]phenol" );
gibbsFormation
{
    dHf_298   -319760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-16410.0
    phase     gas;
}
