/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexaethylcyclohexane  (C18H36, CAS 98803-61-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexaethylcyclohexane;
formula     C18H36;
CAS         98803-61-3;
InChIKey    OBFMYPMABCVIFZ-UHFFFAOYSA-N;
MW          252.486;      // g/mol [origin=calculated method=formula-sum]
Tc          820.75;      // K   [origin=predictive method=joback]
Pc          14.006;      // bar [origin=predictive method=joback]
omega       0.5551;      // -   [origin=predictive method=lee-kesler]
Tb          622.37;      // K   [origin=predictive method=joback]
HvapTb      52020.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-217.174 2.65872 -0.0025234 1.0502e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 9; } { group C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group CH2_ring; count 3; } { group C_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2,3,3-hexaethylcyclohexane" );
gibbsFormation
{
    dHf_298   -355490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     950.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93240.0
    phase     gas;
}
