/*--------------------------------*- Choupo -*-----------------------*\
  Component: butamirate citrate  (C24H37NO10, CAS 18109-81-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butamirateCitrate;
formula     C24H37NO10;
CAS         18109-81-4;
InChIKey    JVKMHUAWFDGPTF-UHFFFAOYSA-N;
MW          499.557;      // g/mol [origin=calculated method=formula-sum]
Tc          1797.10;      // K   [origin=predictive method=joback]
Pc          11.833;      // bar [origin=predictive method=joback]
omega       0.6165;      // -   [origin=predictive method=lee-kesler]
Tb          1394.92;      // K   [origin=predictive method=joback]
HvapTb      149935.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.139 2.32276 -0.0012284 1.734e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group COOH; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O; count 1; } { group COOH; count 3; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(diethylamino)ethoxy]ethyl 2-phenylbutanoate;2-oxidanylpropane-1,2,3-tricarboxylic acid" "acodeen" "butamirate" "sincodeen" "sincodin" "sincodix" "sinecod" "sincodex" "butamyrate citrate" "butamirate citrate (usan)" "butamirate citrate [usan]" "phenyl acetic acid diethylaminoethoxyethanol ester citrate" );
gibbsFormation
{
    dHf_298   -2012820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1332.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1313890.0
    phase     gas;
}
