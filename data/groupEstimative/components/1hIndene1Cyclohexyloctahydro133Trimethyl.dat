/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-indene, 1-cyclohexyloctahydro-1,3,3-trimethyl-  (C18H32, CAS 22236-61-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1hIndene1Cyclohexyloctahydro133Trimethyl;
formula     C18H32;
CAS         22236-61-9;
InChIKey    XZTRZJDPHSPEAO-UHFFFAOYSA-N;
MW          248.454;      // g/mol [origin=calculated method=formula-sum]
Tc          888.66;      // K   [origin=predictive method=joback]
Pc          17.624;      // bar [origin=predictive method=joback]
omega       0.4441;      // -   [origin=predictive method=lee-kesler]
Tb          648.42;      // K   [origin=predictive method=joback]
HvapTb      53513.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-283.03 2.63976 -0.002292 8.611e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 3; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 10; } { group CH_ring; count 3; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexyl-1,3,3-trimethyl-3a,4,5,6,7,7a-hexahydro-2h-indene" "1-cyclohexyl-1,3,3-trimethyloctahydro-1h-indene" );
standardThermochemistry
{
    dHf_298   -243610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     760.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=183930.0
}
