/*--------------------------------*- Choupo -*-----------------------*\
  Component: methacrylic acid  (C4H6O2, CAS 79-41-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methacrylicAcid;
formula     C4H6O2;
CAS         79-41-4;
InChIKey    CERQOIWHTDAKMF-UHFFFAOYSA-N;
MW          86.09;      // g/mol [origin=calculated method=formula-sum]
Tc          634.59;      // K   [origin=predictive method=joback]
Pc          46.530;      // bar [origin=predictive method=joback]
omega       0.5243;      // -   [origin=predictive method=lee-kesler]
Tb          433.19;      // K   [origin=predictive method=joback]
HvapTb      41072.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.17 0.41452 -0.0002916 8.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylprop-2-enoic acid" "2-propenoic acid, 2-methyl-" "2-methylacrylic acid" "2-methylpropenoic acid" "2-methyl-2-propenoic acid" "methylacrylic acid" "alpha-methylacrylic acid" "2-methylenepropionic acid" "acrylic acid, 2-methyl-" "propionic acid, 2-methylene-" "propenoic acid, 2-methyl" "acide methacrylique [french]" );
gibbsFormation
{
    dHf_298   -360520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-281820.0
    phase     gas;
}
