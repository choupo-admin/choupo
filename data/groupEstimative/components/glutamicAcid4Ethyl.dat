/*--------------------------------*- Choupo -*-----------------------*\
  Component: glutamic acid, 4-ethyl-  (C7H13NO4, CAS 20913-68-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glutamicAcid4Ethyl;
formula     C7H13NO4;
CAS         20913-68-2;
InChIKey    JPMICTZIAZZHCD-AKGZTFGVSA-N;
MW          175.184;      // g/mol [origin=calculated method=formula-sum]
Tc          937.67;      // K   [origin=predictive method=joback]
Pc          37.226;      // bar [origin=predictive method=joback]
omega       1.3218;      // -   [origin=predictive method=lee-kesler]
Tb          722.43;      // K   [origin=predictive method=joback]
HvapTb      75369.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.852 0.84412 -0.000552 1.381e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CHNH2; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 2; } { group COOH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-4-ethyl-pentanedioic acid" "u197" );
standardThermochemistry
{
    dHf_298   -865120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-618190.0
}
