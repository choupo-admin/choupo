/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydrazine, 1,2-diethyl-  (C4H12N2, CAS 1615-80-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydrazine12Diethyl;
formula     C4H12N2;
CAS         1615-80-1;
InChIKey    YCBOYOYVDOUXLH-UHFFFAOYSA-N;
MW          88.154;      // g/mol [origin=calculated method=formula-sum]
Tc          568.16;      // K   [origin=predictive method=joback]
Pc          40.261;      // bar [origin=predictive method=joback]
omega       0.5136;      // -   [origin=predictive method=lee-kesler]
Tb          391.46;      // K   [origin=predictive method=joback]
HvapTb      37370.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.168 0.53624 -0.000291 5.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-diethyldiazane" "n,n'-diethylhydrazine" "hydrazoethane" "1,2-diethylhydrazine" "hydroazoethane" "sym-diethylhydrazine" "sdeh" "n-n'-diethylhydrazine" "symmetrical-diethylhydrazine" "1,2-diaethylhydrazin [german]" "1,2-diaethylhydrazin" "1,2-diethyl-hydrazine" );
gibbsFormation
{
    dHf_298   -18950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161580.0
    phase     gas;
}
