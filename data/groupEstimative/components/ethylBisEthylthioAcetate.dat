/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl bis(ethylthio)acetate  (C8H16O2S2, CAS 20461-95-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylBisEthylthioAcetate;
formula     C8H16O2S2;
CAS         20461-95-4;
InChIKey    DGQHHBMWVOYSHU-UHFFFAOYSA-N;
MW          208.334;      // g/mol [origin=calculated method=formula-sum]
Tc          792.12;      // K   [origin=predictive method=joback]
Pc          26.598;      // bar [origin=predictive method=joback]
omega       0.6566;      // -   [origin=predictive method=lee-kesler]
Tb          577.98;      // K   [origin=predictive method=joback]
HvapTb      54055.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.543 0.70374 -0.0002396 -2.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group COO; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group COO; count 1; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,2-bis(ethylsulfanyl)ethanoate" "ethyl di(ethylthio)acetate" "ethyl bis(ethylsulfanyl)acetate" "glyoxylic acid ethyl ester diethyl mercaptal" "ethyl 2,2-bis(ethylsulfanyl)acetate" "ethyl-bis(ethythio)acetate" "dgqhhbmwvoyshu-uhfffaoysa-" "2,2-bis(ethylthio)acetic acid ethyl ester" "acetic acid,2,2-bis(ethylthio)-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -447270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230090.0
}
