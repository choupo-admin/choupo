/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl acetate, ethyl acrylate, methyl acrylate polymer  (C13H20O6, CAS 63181-88-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylAcetateEthylAcrylateMethylAcrylatePolymer;
formula     C13H20O6;
CAS         63181-88-4;
InChIKey    PUEIANKNEAPNKQ-UHFFFAOYSA-N;
MW          272.297;      // g/mol [origin=calculated method=formula-sum]
Tc          857.44;      // K   [origin=predictive method=joback]
Pc          15.987;      // bar [origin=predictive method=joback]
omega       0.8106;      // -   [origin=predictive method=lee-kesler]
Tb          664.54;      // K   [origin=predictive method=joback]
HvapTb      65331.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (139.961 0.60206 0.0003613 -4.1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2=CH; count 3; } { group CH3COO; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 3; } { group dCH; count 3; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl ethanoate;ethyl prop-2-enoate;methyl prop-2-enoate" "2-propenoic acid, ethyl ester, polymer with ethenyl acetate and methyl 2-propenoate" "ethenyl acetate; ethyl prop-2-enoate; methyl prop-2-enoate" );
standardThermochemistry
{
    dHf_298   -1110440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1017.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-818530.0
}
