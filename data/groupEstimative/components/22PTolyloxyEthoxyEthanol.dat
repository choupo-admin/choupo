/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-(p-tolyloxy)ethoxy)ethanol  (C11H16O3, CAS 104-39-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22PTolyloxyEthoxyEthanol;
formula     C11H16O3;
CAS         104-39-2;
InChIKey    DXYXGWDDTLAPGM-UHFFFAOYSA-N;
MW          196.246;      // g/mol [origin=calculated method=formula-sum]
Tc          808.54;      // K   [origin=predictive method=joback]
Pc          27.701;      // bar [origin=predictive method=joback]
omega       1.0779;      // -   [origin=predictive method=lee-kesler]
Tb          619.96;      // K   [origin=predictive method=joback]
HvapTb      64517.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.574 0.81802 -0.00034716 2.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(4-methylphenoxy)ethoxy]ethanol" "ethanol, 2-(2-(4-methylphenoxy)ethoxy)-" "ethanol, 2-[2-(4-methylphenoxy)ethoxy]-" );
standardThermochemistry
{
    dHf_298   -461980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-202300.0
}
