/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(dicyclohexylamino)ethanol  (C14H27NO, CAS 4500-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DicyclohexylaminoEthanol;
formula     C14H27NO;
CAS         4500-31-6;
InChIKey    LLTGNYZQUXACFO-UHFFFAOYSA-N;
MW          225.376;      // g/mol [origin=calculated method=formula-sum]
Tc          868.38;      // K   [origin=predictive method=joback]
Pc          23.519;      // bar [origin=predictive method=joback]
omega       0.9416;      // -   [origin=predictive method=lee-kesler]
Tb          663.64;      // K   [origin=predictive method=joback]
HvapTb      66338.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.448 1.7359 -0.0010428 2.218e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 2; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 10; } { group CH_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanol, 2-(dicyclohexylamino)-" "n,n-dicyclohexylethanolamine" "ethanol, 2-(dicyclohexylamino)-," );
gibbsFormation
{
    dHf_298   -308350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     707.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89860.0
    phase     gas;
}
