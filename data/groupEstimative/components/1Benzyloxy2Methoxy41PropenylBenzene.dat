/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-benzyloxy-2-methoxy-4-(1-propenyl)benzene  (C17H18O2, CAS 120-11-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Benzyloxy2Methoxy41PropenylBenzene;
formula     C17H18O2;
CAS         120-11-6;
InChIKey    YKSSSKBJDZDZTD-UHFFFAOYSA-N;
MW          254.329;      // g/mol [origin=calculated method=formula-sum]
Tc          931.16;      // K   [origin=predictive method=joback]
Pc          20.661;      // bar [origin=predictive method=joback]
omega       0.7364;      // -   [origin=predictive method=lee-kesler]
Tb          700.88;      // K   [origin=predictive method=joback]
HvapTb      64090.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.959 1.23564 -0.00069112 1.301e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-1-phenylmethoxy-4-prop-1-enyl-benzene" "benzyl isoeugenol" "benzene, 2-methoxy-1-(phenylmethoxy)-4-(1-propen-1-yl)-" "2-methoxy-1-phenylmethoxy-4-prop-1-enylbenzene" "2-methoxy-1-(phenylmethoxy)-4-[(z)-prop-1-enyl]benzene" );
standardThermochemistry
{
    dHf_298   -91310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=168040.0
}
