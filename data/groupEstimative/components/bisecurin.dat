/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisecurin  (C44H56O6, CAS 8075-78-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisecurin;
formula     C44H56O6;
CAS         8075-78-3;
InChIKey    STZJJZZLAXIFHB-DIRPKPHOSA-N;
MW          680.926;      // g/mol [origin=calculated method=formula-sum]
Tc          1954.90;      // K   [origin=predictive method=joback]
Pc          7.953;      // bar [origin=predictive method=joback]
omega       0.5854;      // -   [origin=predictive method=lee-kesler]
Tb          1567.68;      // K   [origin=predictive method=joback]
HvapTb      156393.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-476.88 5.63918 -0.00499882 1.87738e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 7; } { group C; count 4; } { group CH=C; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH3COO; count 2; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group tCH; count 2; } { group tC; count 2; } { group CH2_ring; count 14; } { group CH_ring; count 8; } { group C_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,8r,9s,10r,13s,14s,17r)-17-acetyloxy-17-ethynyl-13-methyl-2,3,6,7,8,9,10,11,12,14,15,16-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] ethanoate;(8r,9s,13s,14s,17r)-17-ethynyl-13-methyl-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthrene-3,17-diol" "bisecurin ii" "conova 30" "zovia" "ovamin 30" "ovulen 30" "kelnor 1/35" "zovia 1/35e-28" "zovia 1/50e-28" "ethynodiol diacetate and ethinyl estradiol" "ethynodiol diacetate mixt. with ethynylestradiol" "ethynylestradiol mixt. with ethynodiol diacetate" );
gibbsFormation
{
    dHf_298   -746300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1514.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=151950.0
    phase     gas;
}
