/*--------------------------------*- Choupo -*-----------------------*\
  Component: resveratrol  (C14H12O3, CAS 501-36-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        resveratrol;
formula     C14H12O3;
CAS         501-36-0;
InChIKey    LUKBXSAWLPMMSZ-OWOJBTEDSA-N;
MW          228.247;      // g/mol [origin=calculated method=formula-sum]
Tc          1090.40;      // K   [origin=predictive method=joback]
Pc          50.948;      // bar [origin=predictive method=joback]
omega       1.2549;      // -   [origin=predictive method=lee-kesler]
Tb          819.30;      // K   [origin=predictive method=joback]
HvapTb      90310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-118.59 1.6598 -0.00165308 6.531e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 7; } { group AC; count 2; } { group ACOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group OH_phenol; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-[(e)-2-(4-hydroxyphenyl)ethenyl]benzene-1,3-diol" "trans-resveratrol" "3,4',5-trihydroxystilbene" "3,5,4'-trihydroxystilbene" "resvida" "3,4',5-stilbenetriol" "(e)-resveratrol" "3,4',5-trihydroxy-trans-stilbene" "(e)-5-(4-hydroxystyryl)benzene-1,3-diol" "resveratrol, e-" "prestwick_619" "s1396_selleck" );
standardThermochemistry
{
    dHf_298   -273940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-91820.0
}
