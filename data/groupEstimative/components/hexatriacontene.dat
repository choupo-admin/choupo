/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexatriacontene  (C36H72, CAS 61868-14-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexatriacontene;
formula     C36H72;
CAS         61868-14-2;
InChIKey    SIXQKCKYEKKFRC-UHFFFAOYSA-N;
MW          504.972;      // g/mol [origin=calculated method=formula-sum]
Tc          1300.00;      // K   [origin=predictive method=joback]
Pc          4.661;      // bar [origin=predictive method=joback]
omega       0.0255;      // -   [origin=predictive method=lee-kesler]
Tb          1019.96;      // K   [origin=predictive method=joback]
HvapTb      95060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.827 3.40382 -0.0019575 4.346e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 33; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 33; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexatriacont-1-ene" "1-hexatriacontene" "agn-pc-00o5on" );
standardThermochemistry
{
    dHf_298   -660940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1553.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=340080.0
}
