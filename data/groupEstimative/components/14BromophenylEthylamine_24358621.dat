/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-bromophenyl)ethylamine  (C8H10BrN, CAS 24358-62-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BromophenylEthylamine;
formula     C8H10BrN;
CAS         24358-62-1;
InChIKey    SOZMSEPDYJGBEK-UHFFFAOYSA-N;
MW          200.079;      // g/mol [origin=calculated method=formula-sum]
Tc          798.26;      // K   [origin=predictive method=joback]
Pc          42.386;      // bar [origin=predictive method=joback]
omega       0.5591;      // -   [origin=predictive method=lee-kesler]
Tb          552.55;      // K   [origin=predictive method=joback]
HvapTb      53028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.99 0.73142 -0.00049356 1.292e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CHNH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-bromophenyl)ethanamine" "4-bromo-alpha-methylbenzylamine" "4-bromo-alpha-phenethylamine" "4-bromo-a-methylbenzylamine" "1-(4-bromophenyl)ethan-1-amine" "(+)-p-bromo-.alpha.-phenethylamine" "benzenemethanamine, 4-bromo-.alpha.-methyl-, (r)-" "(-)-1-(4-bromophenyl)ethylamine" "p-bromo-alpha-methylbenzylamine" "[1-(4-bromophenyl)ethyl]amine" "p-bromo-a-methylbenzylamine" "(r)-4-bromo-alpha-methylbenzylamine" );
standardThermochemistry
{
    dHf_298   71450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197590.0
}
