/*--------------------------------*- Choupo -*-----------------------*\
  Component: salbutamol  (C13H21NO3, CAS 18559-94-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        salbutamol;
formula     C13H21NO3;
CAS         18559-94-9;
InChIKey    NDAUXUAQIAJITI-UHFFFAOYSA-N;
MW          239.315;      // g/mol [origin=calculated method=formula-sum]
Tc          1044.11;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       1.7695;      // -   [origin=predictive method=lee-kesler]
Tb          840.18;      // K   [origin=predictive method=joback]
HvapTb      98594.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.238 1.53096 -0.00118832 3.787e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 2; } { group ACOH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 2; } { group OH_phenol; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(tert-butylamino)-1-oxidanyl-ethyl]-2-(hydroxymethyl)phenol" "albuterol" "proventil" "aerolin" "asthalin" "salamol" "sultanol" "asmol" "broncovaleas" "buventol" "cobutolin" "salbulin" );
standardThermochemistry
{
    dHf_298   -528920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     670.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-177110.0
}
