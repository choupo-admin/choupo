/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-piperazin-1-ylethoxy)ethanol  (C8H18N2O2, CAS 13349-82-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Piperazin1YlethoxyEthanol;
formula     C8H18N2O2;
CAS         13349-82-1;
InChIKey    FLNQAPQQAZVRDA-UHFFFAOYSA-N;
MW          174.244;      // g/mol [origin=calculated method=formula-sum]
Tc          764.54;      // K   [origin=predictive method=joback]
Pc          35.643;      // bar [origin=predictive method=joback]
omega       1.1038;      // -   [origin=predictive method=lee-kesler]
Tb          578.18;      // K   [origin=predictive method=joback]
HvapTb      61858.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.786 1.0033 -0.0005656 1.112e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2NH; count 1; } { group CH2N; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 4; } { group OH; count 1; } { group O; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-(2-hydroxyethoxy)ethyl]piperazine" "2-[2-(1-piperazinyl)ethoxy]ethanol" "1-(2-(2-hydroxyethoxy)ethyl)piperazine" "2-[2-(piperazin-1-yl)ethoxy]ethanol" "2-(2-(piperazin-1-yl)ethoxy)ethanol" "1-[2-(2-hydroxyethoxyl)-ethyl] piperazine" "2-(2-piperazinylethoxy)ethan-1-ol" "1-[2-(2-hydroxy)ethoxy]ethylpiperazine" "1-[2-(2-hydroxy ethoxy)-ethyl]piperazine" "1-(2-(2-hydroxyethoxy)ethyl) piperazine" "n-hydroxyethoxyethyl piperazine; 1-[2-(2-hydroxyethoxy)ethyl]piperazine" );
gibbsFormation
{
    dHf_298   -306740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17410.0
    phase     gas;
}
