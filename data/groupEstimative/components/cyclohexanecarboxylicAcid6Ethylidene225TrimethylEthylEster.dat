/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanecarboxylic acid, 6-ethylidene-2,2,5-trimethyl-, ethyl ester  (C14H24O2, CAS 94333-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanecarboxylicAcid6Ethylidene225TrimethylEthylEster;
formula     C14H24O2;
CAS         94333-51-4;
InChIKey    DGWVYBNIXRBVCF-UHFFFAOYSA-N;
MW          224.344;      // g/mol [origin=calculated method=formula-sum]
Tc          799.68;      // K   [origin=predictive method=joback]
Pc          18.201;      // bar [origin=predictive method=joback]
omega       0.5836;      // -   [origin=predictive method=lee-kesler]
Tb          595.23;      // K   [origin=predictive method=joback]
HvapTb      53612.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.049 1.5626 -0.0011145 3.504e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 6-ethylidene-2,2,5-trimethyl-cyclohexane-1-carboxylate" );
gibbsFormation
{
    dHf_298   -544660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     678.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-194370.0
    phase     gas;
}
