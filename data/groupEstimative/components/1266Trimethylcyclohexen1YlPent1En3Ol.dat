/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,6,6-trimethylcyclohexen-1-yl)pent-1-en-3-ol  (C14H24O, CAS 68259-41-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1266Trimethylcyclohexen1YlPent1En3Ol;
formula     C14H24O;
CAS         68259-41-6;
InChIKey    DZSNHSUUMHDJRJ-UHFFFAOYSA-N;
MW          208.345;      // g/mol [origin=calculated method=formula-sum]
Tc          843.03;      // K   [origin=predictive method=joback]
Pc          21.553;      // bar [origin=predictive method=joback]
omega       0.8921;      // -   [origin=predictive method=lee-kesler]
Tb          644.73;      // K   [origin=predictive method=joback]
HvapTb      63901.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.629 1.63278 -0.001322 4.741e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-penten-3-ol, 1-(2,2,6-trimethylcyclohexyl)-, didehydro deriv." );
gibbsFormation
{
    dHf_298   -268180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     725.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37620.0
    phase     gas;
}
