/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2094084  (C13H16O, CAS 6809-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2094084;
formula     C13H16O;
CAS         6809-93-4;
InChIKey    XCLXRGHHJAIZOY-UHFFFAOYSA-N;
MW          188.27;      // g/mol [origin=calculated method=formula-sum]
Tc          798.53;      // K   [origin=predictive method=joback]
Pc          25.456;      // bar [origin=predictive method=joback]
omega       0.6609;      // -   [origin=predictive method=lee-kesler]
Tb          585.04;      // K   [origin=predictive method=joback]
HvapTb      53957.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.297 1.23292 -0.00089546 2.6426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(7-bicyclo[4.2.0]octa-1,3,5-trienyl)pentan-1-one" "1-benzocyclobutenyl n-butyl ketone" "bicyclo(4.2.0)octa-1,3,5-triene, 7-valeryl-" "1-bicyclo(4.2.0)octa-1,3,5-trien-7-yl-1-pentanone" "1-pentanone, 1-bicyclo(4.2.0)octa-1,3,5-trien-7-yl-" "ketone, bicyclo(4.2.0)octa-1,3,5-trien-7-yl butyl" );
standardThermochemistry
{
    dHf_298   -120210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105290.0
}
