/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-hydroxyoctadecyl docosanoate  (C40H80O3, CAS 67801-69-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9HydroxyoctadecylDocosanoate;
formula     C40H80O3;
CAS         67801-69-8;
InChIKey    IGBQVHZKDCXCLW-UHFFFAOYSA-N;
MW          609.077;      // g/mol [origin=calculated method=formula-sum]
Tc          1849.60;      // K   [origin=predictive method=joback]
Pc          4.076;      // bar [origin=predictive method=joback]
omega       -0.4315;      // -   [origin=predictive method=lee-kesler]
Tb          1264.76;      // K   [origin=predictive method=joback]
HvapTb      128332.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.454 3.78894 -0.0020912 4.17e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 35; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 36; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-oxidanyloctadecyl docosanoate" "9-hydroxystearyl behenate" "docosanoic acid, 9-hydroxyoctadecyl ester" "docosanoic acid 9-hydroxyoctadecyl ester" "behenic acid, 9-hydroxystearyl ester" );
standardThermochemistry
{
    dHf_298   -1343720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1806.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-163710.0
}
