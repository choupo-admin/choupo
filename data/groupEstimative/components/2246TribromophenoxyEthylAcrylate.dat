/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2,4,6-tribromophenoxy)ethyl acrylate  (C11H9Br3O3, CAS 7347-19-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2246TribromophenoxyEthylAcrylate;
formula     C11H9Br3O3;
CAS         7347-19-5;
InChIKey    AMBJXYFIMKHOQE-UHFFFAOYSA-N;
MW          428.902;      // g/mol [origin=calculated method=formula-sum]
Tc          1013.86;      // K   [origin=predictive method=joback]
Pc          32.616;      // bar [origin=predictive method=joback]
omega       1.0738;      // -   [origin=predictive method=lee-kesler]
Tb          768.70;      // K   [origin=predictive method=joback]
HvapTb      72794.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.372 0.768 -0.00043618 7.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group ACH; count 2; } { group AC; count 4; } { group CH2O; count 1; } { group Br; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 3; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4,6-tris(bromanyl)phenoxy]ethyl prop-2-enoate" "2-propenoic acid, 2-(2,4,6-tribromophenoxy)ethyl ester" "tribromophenoxyethyl acrylate" "2-(2,4,6-tribromophenoxy)ethyl prop-2-enoate" "2-propenoic acid,esters,2-(2,4,6-tribromophenoxy) ethyl ester" );
gibbsFormation
{
    dHf_298   -313330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     670.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-159310.0
    phase     gas;
}
