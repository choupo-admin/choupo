/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-hexyl-4-methyloxolan-2-one  (C11H20O2, CAS 67663-01-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Hexyl4Methyloxolan2One;
formula     C11H20O2;
CAS         67663-01-8;
InChIKey    XNRLAEXLQFIKEY-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          691.39;      // K   [origin=predictive method=joback]
Pc          21.197;      // bar [origin=predictive method=joback]
omega       0.6286;      // -   [origin=predictive method=lee-kesler]
Tb          511.57;      // K   [origin=predictive method=joback]
HvapTb      47091.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.005 1.11844 -0.0006448 1.337e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-hexyl-4-methyl-oxolan-2-one" "2(3h)-furanone, 5-hexyldihydro-4-methyl-" "5-hexyl-4-methyldihydrofuran-2(3h)-one" "5-hexyldihydro-4-methylfuran-2(3h)-one" "5-hexyl-4-methyldihydro-2(3h)-furanone" "cis-4-hydroxy-3-methyldecanoic acid lactone" "2(3h)-furanone, 5-hexyldihydro-4-methyl-, (4r,5r)-" "2(3h)-furanone,5-hexyldihydro-4-methyl-" "trans-4-hydroxy-3-methyldecanoic acid lactone" "2(3h)-furanone, 5-hexyldihydro-4-methyl-, (4r-cis)-" "2(3h)-furanone, 5-hexyldihydro-4-methyl-, trans-(.+-.)-" );
gibbsFormation
{
    dHf_298   -535190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-215590.0
    phase     gas;
}
