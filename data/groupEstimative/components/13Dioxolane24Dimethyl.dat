/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxolane, 2,4-dimethyl-  (C5H10O2, CAS 3390-12-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxolane24Dimethyl;
formula     C5H10O2;
CAS         3390-12-3;
InChIKey    ROSFUFIOLRQOON-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          576.50;      // K   [origin=predictive method=joback]
Pc          40.621;      // bar [origin=predictive method=joback]
omega       0.3024;      // -   [origin=predictive method=lee-kesler]
Tb          378.51;      // K   [origin=predictive method=joback]
HvapTb      35692.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.56 0.57804 -0.0002924 4.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-dimethyl-1,3-dioxolane" "acetaldehyde pg acetal" "agn-pc-03f40l" "trans-2,4-dimethyl-1,3-dioxolane" "1,3-dioxolane, 2,4-dimethyl, cis" "1,3-dioxolane,2,4-dimethyl-, trans- (8ci,9ci)" );
gibbsFormation
{
    dHf_298   -370390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     155.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-152180.0
    phase     gas;
}
