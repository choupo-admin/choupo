/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxy-2-methyl-7-phenylpentadecan-3-one  (C22H36O2, CAS 68400-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxy2Methyl7Phenylpentadecan3One;
formula     C22H36O2;
CAS         68400-53-3;
InChIKey    NRQOJDAHMFRJKC-UHFFFAOYSA-N;
MW          332.528;      // g/mol [origin=calculated method=formula-sum]
Tc          1072.43;      // K   [origin=predictive method=joback]
Pc          12.602;      // bar [origin=predictive method=joback]
omega       1.1219;      // -   [origin=predictive method=lee-kesler]
Tb          872.02;      // K   [origin=predictive method=joback]
HvapTb      88583.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.52 2.15266 -0.0013909 3.4826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-2-oxidanyl-7-phenyl-pentadecan-3-one" "3-pentadecanone, 2-hydroxy-2-methyl-7-phenyl-" "1-(4-phenyldodecyl)-2-hydroxy-2-methyl-1-propanone" );
standardThermochemistry
{
    dHf_298   -539720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     935.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18570.0
}
