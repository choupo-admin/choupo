/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(pentafluorophenyl)ethanol  (C8H5F5O, CAS 653-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PentafluorophenylEthanol;
formula     C8H5F5O;
CAS         653-31-6;
InChIKey    UBDFNSASHPESJX-UHFFFAOYSA-N;
MW          212.117;      // g/mol [origin=calculated method=formula-sum]
Tc          684.02;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       1.0712;      // -   [origin=predictive method=lee-kesler]
Tb          522.75;      // K   [origin=predictive method=joback]
HvapTb      51582.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.952 0.4804 -0.0002198 2.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group ACF; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dC_ring; count 6; } { group F; count 5; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,3,4,5,6-pentakis(fluoranyl)phenyl]ethanol" "2-(2,3,4,5,6-pentafluorophenyl)ethan-1-ol" "benzeneethanol,2,3,4,5,6-pentafluoro-" "2,3,4,5,6-pentafluorophenethyl alcohol" "2-(2,3,4,5,6-pentafluorophenyl)ethanol" "benzeneethanol, 2,3,4,5,6-pentafluoro-" );
gibbsFormation
{
    dHf_298   -1162050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1030130.0
    phase     gas;
}
