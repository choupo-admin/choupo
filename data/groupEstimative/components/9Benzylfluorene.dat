/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-benzylfluorene  (C20H16, CAS 1572-46-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Benzylfluorene;
formula     C20H16;
CAS         1572-46-9;
InChIKey    ZBQLAOVNDBNMFI-UHFFFAOYSA-N;
MW          256.348;      // g/mol [origin=calculated method=formula-sum]
Tc          1004.43;      // K   [origin=predictive method=joback]
Pc          22.784;      // bar [origin=predictive method=joback]
omega       0.6890;      // -   [origin=predictive method=lee-kesler]
Tb          745.40;      // K   [origin=predictive method=joback]
HvapTb      67835.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.409 1.7182 -0.00133672 4.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 13; } { group AC; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 13; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-(phenylmethyl)-9h-fluorene" "9-benzyl-9h-fluorene" "9h-fluorene,9-(phenylmethyl)-" "fluorene,9-benzyl- (6ci,7ci,8ci);9-benzyl-9h-fluorene;9-benzylfluorene;" );
gibbsFormation
{
    dHf_298   315640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=520440.0
    phase     gas;
}
