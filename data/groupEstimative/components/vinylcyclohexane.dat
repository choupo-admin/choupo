/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinylcyclohexane  (C8H14, CAS 695-12-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylcyclohexane;
formula     C8H14;
CAS         695-12-5;
InChIKey    LDLDYFCCDKENPD-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          604.43;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.2509;      // -   [origin=predictive method=lee-kesler]
Tb          398.87;      // K   [origin=predictive method=joback]
HvapTb      33161.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.98 0.8659 -0.0005153 1.11e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenylcyclohexane" "cyclohexylethylene" "cyclohexane, ethenyl-" "cyclohexane, vinyl-" "cyclohexylethene" "vinyl-cyclohexane" "cyclohexane, ethenyl- (9ci)" "ldldyfccdkenpd-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -28700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128770.0
    phase     gas;
}
