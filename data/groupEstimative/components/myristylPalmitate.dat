/*--------------------------------*- Choupo -*-----------------------*\
  Component: myristyl palmitate  (C30H60O2, CAS 4536-26-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        myristylPalmitate;
formula     C30H60O2;
CAS         4536-26-9;
InChIKey    UULYVBBLIYLRCU-UHFFFAOYSA-N;
MW          452.808;      // g/mol [origin=calculated method=formula-sum]
Tc          1171.53;      // K   [origin=predictive method=joback]
Pc          5.969;      // bar [origin=predictive method=joback]
omega       0.3883;      // -   [origin=predictive method=lee-kesler]
Tb          944.22;      // K   [origin=predictive method=joback]
HvapTb      89781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.027 2.79904 -0.0015136 2.887e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 26; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 27; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecyl hexadecanoate" "tetradecyl palmitate" "hexadecanoic acid, tetradecyl ester" "palmitic acid, tetradecyl ester" "tetradecanyl hexadecanoate" "hexadecanoic acid,tetradecyl ester" "palmitic acid myristyl ester" "we(14:0/16:0)" "palmiticacid, tetradecyl ester (6ci,8ci); 1-tetradecanol, palmitate (8ci); myristylpalmitate; tetradecyl hexadecanoate; tetradecyl palmitate" );
gibbsFormation
{
    dHf_298   -979810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1375.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-108650.0
    phase     gas;
}
