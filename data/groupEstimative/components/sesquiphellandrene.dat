/*--------------------------------*- Choupo -*-----------------------*\
  Component: sesquiphellandrene  (C15H24, CAS 20307-83-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sesquiphellandrene;
formula     C15H24;
CAS         20307-83-9;
InChIKey    PHWISBHSBNDZDX-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          768.42;      // K   [origin=predictive method=joback]
Pc          18.373;      // bar [origin=predictive method=joback]
omega       0.5030;      // -   [origin=predictive method=lee-kesler]
Tb          564.27;      // K   [origin=predictive method=joback]
HvapTb      49514.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.838 1.40326 -0.00085738 2.007e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(6-methylhept-5-en-2-yl)-6-methylidene-cyclohexene" ".beta.-sesquiphellandrene" "cyclohexene, 3-(1,5-dimethyl-4-hexenyl)-6-methylene-, [s-(r*,s*)]-" "beta-sesquiphellandrene" "cyclohexene, 3-(1,5-dimethyl-4-hexenyl)-6-methylene-, (s-(r*,s*))-" "3-(6-methylhept-5-en-2-yl)-6-methylidenecyclohexene" "3-(1,5-dimethyl-4-hexenyl)-6-methylene-1-cyclohexene" "2-methyl-6-(4-methylidene-1-cyclohex-2-enyl)hept-2-ene" );
gibbsFormation
{
    dHf_298   -54440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252140.0
    phase     gas;
}
