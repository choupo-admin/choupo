/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-tetrahydro-3-isoquinolinecarboxylic acid  (C10H11NO2, CAS 74163-81-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sTetrahydro3IsoquinolinecarboxylicAcid;
formula     C10H11NO2;
CAS         74163-81-8;
InChIKey    BWKMGYQJPOAASG-VIFPVBQESA-N;
MW          177.203;      // g/mol [origin=calculated method=formula-sum]
Tc          912.74;      // K   [origin=predictive method=joback]
Pc          39.407;      // bar [origin=predictive method=joback]
omega       0.8500;      // -   [origin=predictive method=lee-kesler]
Tb          665.13;      // K   [origin=predictive method=joback]
HvapTb      64799.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.65 0.9941 -0.00067016 1.729e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s)-1,2,3,4-tetrahydroisoquinoline-3-carboxylic acid" "l-1,2,3,4-tetrahydroisoquinoline-3-carboxylic acid" "(s)-1,2,3,4-tetrahydroisoquinoline-3-carboxylic acid" "(s)-1,2,3,4-tetrahydro-3-isoquinolinecarboxylic acid" "(s)-(-)-1,2,3,4-tetrahydroisoquinoline-3-carboxylic acid" "1,2,3,4-tetrahydroisoquinoline-3(r)-carboxylic acid" "h-tic-oh" "l-1,2,3,4-tetrahydroisoquinoline-3-carboxylicacid" "al081-1" "3-isoquinolinecarboxylicacid, 1,2,3,4-tetrahydro-, (s)-;(-)-1,2,3,4-tetrahydroisoquinoline-3-carboxylicacid;(3s)-1,2,3,4-tetrahydro-3-isoquinolinecarboxylic acid;(s)-1,2,3,4-tetrahydroisoquinoline-3-carboxylic acid;" );
standardThermochemistry
{
    dHf_298   -270490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-71450.0
}
