/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl (r)-(+)-methylsuccinate  (C7H12O4, CAS 22644-27-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylRMethylsuccinate;
formula     C7H12O4;
CAS         22644-27-5;
InChIKey    NFOQJNGQQXICBY-RXMQYKEDSA-N;
MW          160.169;      // g/mol [origin=calculated method=formula-sum]
Tc          659.39;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       0.6201;      // -   [origin=predictive method=lee-kesler]
Tb          475.76;      // K   [origin=predictive method=joback]
HvapTb      45602.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.661 0.56516 -0.000171 -4.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl (2r)-2-methylbutanedioate" "dimethyl (r)-methylsuccinate" "(r)dimethyl-2-methylsuccinate" "nfoqjngqqxicby-rxmqykedsa-" "dimethyl (r)-(+)-pyrotartarate" "(+)-dimethyl (r)-methylsuccinate" "p621" "(r)-2-methyl-succinic acid dimethyl ester" "(r)-(+)-pyrotartaric acid dimethyl ester" "(r)-(+)-methylsuccinic acid dimethyl ester" "(r)-pyrotartaric acid dimethyl ester" "butanedioic acid,2-methyl-, 1,4-dimethyl ester, (2r)-" );
standardThermochemistry
{
    dHf_298   -827650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-615120.0
}
