/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-octynal  (C8H12O, CAS 1846-68-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Octynal;
formula     C8H12O;
CAS         1846-68-0;
InChIKey    DUUGWLGPIZCNLM-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          634.73;      // K   [origin=predictive method=joback]
Pc          32.579;      // bar [origin=predictive method=joback]
omega       0.4604;      // -   [origin=predictive method=lee-kesler]
Tb          440.30;      // K   [origin=predictive method=joback]
HvapTb      42274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.574 0.58852 -0.00031226 6.088e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CHO; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group tC; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oct-2-ynal" "2-octynal  97;oct-2-ynal" );
gibbsFormation
{
    dHf_298   -21730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=119760.0
    phase     gas;
}
