/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimorpholamine  (C20H38N4O4, CAS 119-48-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimorpholamine;
formula     C20H38N4O4;
CAS         119-48-2;
InChIKey    HZTMGWSBSDLALI-UHFFFAOYSA-N;
MW          398.548;      // g/mol [origin=calculated method=formula-sum]
Tc          1117.17;      // K   [origin=predictive method=joback]
Pc          14.657;      // bar [origin=predictive method=joback]
omega       1.2574;      // -   [origin=predictive method=lee-kesler]
Tb          908.50;      // K   [origin=predictive method=joback]
HvapTb      91930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.542 2.65384 -0.001815 4.7632e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group FCH2O; count 2; } { group CH2N; count 2; } { group CON_CH2_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH2_ring; count 8; } { group O_ring; count 2; } { group CdO; count 2; } { group N; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-butyl-n-[2-[butyl(morpholin-4-ylcarbonyl)amino]ethyl]morpholine-4-carboxamide" "theraleptique" "theraptique" "atmurin" "prontodin" "amipan t" "n,n'-ethylenebis(n-butyl-4-morpholinecarboxamide)" "n,n'-ethylenebis(n-butylmorpholine-4-carboxamide)" "4-morpholinecarboxamide, n,n'-ethylenebis(n-butyl-" "n,n'-dibutyl-n,n'-dicarboxyethylene diaminemorpholide" "n,n'-dibutyl-n,n'-dicarboxymorpholide-ethylenediamine" "n,n'-1,2-ethanediylbis(n-butyl-4-morpholinecarboxamide)" );
standardThermochemistry
{
    dHf_298   -513530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     934.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=219080.0
}
