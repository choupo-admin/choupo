/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromonortricyclene  (C7H9Br, CAS 31991-53-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromonortricyclene;
formula     C7H9Br;
CAS         31991-53-4;
InChIKey    YCRRTQBETAOLNQ-UHFFFAOYSA-N;
MW          173.053;      // g/mol [origin=calculated method=formula-sum]
Tc          658.23;      // K   [origin=predictive method=joback]
Pc          46.340;      // bar [origin=predictive method=joback]
omega       0.3565;      // -   [origin=predictive method=lee-kesler]
Tb          433.17;      // K   [origin=predictive method=joback]
HvapTb      35546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-179.82 1.4443 -0.001659 7.337e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 3; } { group C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 3; } { group C_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-bromanyl-1,2,3,4,5,7-hexahydrotricyclo[2.2.1.0^{2,6}]heptane" "3-bromotricyclo(2.2.1.o2,6)heptane" );
standardThermochemistry
{
    dHf_298   64140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     196.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=215630.0
}
