/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylbenzyl cyanide  (C9H9N, CAS 2947-60-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethylbenzylCyanide;
formula     C9H9N;
CAS         2947-60-6;
InChIKey    WOJADIOTNFDWNQ-UHFFFAOYSA-N;
MW          131.178;      // g/mol [origin=calculated method=formula-sum]
Tc          767.93;      // K   [origin=predictive method=joback]
Pc          31.175;      // bar [origin=predictive method=joback]
omega       0.5049;      // -   [origin=predictive method=lee-kesler]
Tb          539.26;      // K   [origin=predictive method=joback]
HvapTb      49044.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.899 0.65522 -0.00039896 9.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-methylphenyl)ethanenitrile" "2-(3-methylphenyl)acetonitrile" "m-tolylacetonitrile" "m-xylyl cyanide" "(3-methylphenyl)acetonitrile" "m-methylbenzyl cyanide" "3-methylphenylacetonitrile" "m-tolyacetonitrile" "3-methylbenzylcyanide" "m-methylphenylacetonitrile" "2-m-tolylacetonitrile" "benzeneacetonitrile,3-methyl-" );
gibbsFormation
{
    dHf_298   160850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=260860.0
    phase     gas;
}
