/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2r)-2-methylbutyl 3-(4-aminophenyl)-2-methylacrylate  (C15H21NO2, CAS 63815-60-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2r2Methylbutyl34Aminophenyl2Methylacrylate;
formula     C15H21NO2;
CAS         63815-60-1;
InChIKey    DLZHYQUKEWUPSX-LWMMSDEHSA-N;
MW          247.338;      // g/mol [origin=calculated method=formula-sum]
Tc          926.54;      // K   [origin=predictive method=joback]
Pc          20.382;      // bar [origin=predictive method=joback]
omega       0.8589;      // -   [origin=predictive method=lee-kesler]
Tb          708.81;      // K   [origin=predictive method=joback]
HvapTb      69620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.008 1.32336 -0.00079446 1.705e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2r)-2-methylbutyl] (e)-3-(4-aminophenyl)-2-methyl-prop-2-enoate" "2-propenoic acid, 3-(4-aminophenyl)-2-methyl-, (2r)-2-methylbutyl ester" "2-propenoic acid, 3-(4-aminophenyl)-2-methyl-, 2-methylbutyl ester, (r)-" );
gibbsFormation
{
    dHf_298   -309210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     710.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=3510.0
    phase     gas;
}
