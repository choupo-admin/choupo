/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyanoethoxyethyl acrylate  (C8H11NO3, CAS 7790-03-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2CyanoethoxyethylAcrylate;
formula     C8H11NO3;
CAS         7790-03-6;
InChIKey    GUSHIGISBYPHRV-UHFFFAOYSA-N;
MW          169.18;      // g/mol [origin=calculated method=formula-sum]
Tc          757.99;      // K   [origin=predictive method=joback]
Pc          25.689;      // bar [origin=predictive method=joback]
omega       0.7439;      // -   [origin=predictive method=lee-kesler]
Tb          561.60;      // K   [origin=predictive method=joback]
HvapTb      52639.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.852 0.56652 -0.0002009 -1.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2O; count 1; } { group CH2CN; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } { group COO; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-cyanoethoxy)ethyl prop-2-enoate" "2-propenoic acid,2-(2-cyanoethoxy)ethyl ester" "acrylicacid, 2-(2-cyanoethoxy)ethyl ester (6ci,8ci); propionitrile,3-(2-hydroxyethoxy)-, acrylate (5ci); 2-(2-cyanoethoxy)ethyl acrylate" );
standardThermochemistry
{
    dHf_298   -372920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180310.0
}
