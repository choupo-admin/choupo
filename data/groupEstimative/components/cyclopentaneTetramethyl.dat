/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentane, tetramethyl-  (C9H18, CAS 67784-41-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentaneTetramethyl;
formula     C9H18;
CAS         67784-41-2;
InChIKey    YXDMSFJDVHXFCV-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          625.08;      // K   [origin=predictive method=joback]
Pc          29.377;      // bar [origin=predictive method=joback]
omega       0.2462;      // -   [origin=predictive method=lee-kesler]
Tb          416.61;      // K   [origin=predictive method=joback]
HvapTb      33274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-159.82 1.54788 -0.001603 7.032e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 3; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetramethylcyclopentane" "agn-pc-03cz5c" );
standardThermochemistry
{
    dHf_298   -158470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     552.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42760.0
}
