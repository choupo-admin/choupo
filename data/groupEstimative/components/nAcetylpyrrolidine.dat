/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-acetylpyrrolidine  (C6H11NO, CAS 4030-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nAcetylpyrrolidine;
formula     C6H11NO;
CAS         4030-18-6;
InChIKey    LNWWQYYLZVZXKS-UHFFFAOYSA-N;
MW          113.16;      // g/mol [origin=calculated method=formula-sum]
Tc          618.44;      // K   [origin=predictive method=joback]
Pc          41.893;      // bar [origin=predictive method=joback]
omega       0.4454;      // -   [origin=predictive method=lee-kesler]
Tb          418.87;      // K   [origin=predictive method=joback]
HvapTb      38133.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.2 0.83752 -0.0006257 1.8616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pyrrolidin-1-ylethanone" "1-acetylpyrrolidine" "pyrrolidine, 1-acetyl-" "1-pyrrolidin-1-yl-ethanone" );
standardThermochemistry
{
    dHf_298   -125240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37860.0
}
