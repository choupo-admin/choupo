/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-menth-1(7)-en-2-one  (C10H16O, CAS 15297-07-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pMenth17En2One;
formula     C10H16O;
CAS         15297-07-1;
InChIKey    QIHBCMQXRORFNY-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          734.94;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       0.4321;      // -   [origin=predictive method=lee-kesler]
Tb          514.49;      // K   [origin=predictive method=joback]
HvapTb      42301.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.77 0.79604 -0.000268 -2.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylidene-5-propan-2-yl-cyclohexan-1-one" "cyclohexanone, 2-methylene-5-(1-methylethyl)-" "2-methylidene-5-propan-2-ylcyclohexan-1-one" );
gibbsFormation
{
    dHf_298   -254150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14180.0
    phase     gas;
}
