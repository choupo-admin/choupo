/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,7-dimethyltetralin  (C12H16, CAS 21693-54-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        57Dimethyltetralin;
formula     C12H16;
CAS         21693-54-9;
InChIKey    MDAXYSXRAMOWLY-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          758.44;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.4439;      // -   [origin=predictive method=lee-kesler]
Tb          531.46;      // K   [origin=predictive method=joback]
HvapTb      46962.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.33 1.05424 -0.00068828 1.8e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 2; } { group ACCH3; count 2; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,7-dimethyl-1,2,3,4-tetrahydronaphthalene" "5,7-dimethyl-[1,2,3,4-tetrahydronaphthalene]" "naphthalene, 1,2,3,4-tetrahydro-5,7-dimethyl-" "5,2,3,4-tetrahydronaphthalene]" "naphthalene,2,3,4-tetrahydro-5,7-dimethyl-" "5,7-dimethyl-1,2,3,4-tetrahydro-naphthalene" "naphthalene,1,2,3,4-tetrahydro-5,7-dimethyl-" );
standardThermochemistry
{
    dHf_298   -1910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=190040.0
}
