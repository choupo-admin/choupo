/*--------------------------------*- Choupo -*-----------------------*\
  Component: demissidine  (C27H45NO, CAS 50409-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        demissidine;
formula     C27H45NO;
CAS         50409-83-1;
InChIKey    JALVTHFTYRPDMB-HRRTYWNUSA-N;
MW          399.663;      // g/mol [origin=calculated method=formula-sum]
Tc          1183.69;      // K   [origin=predictive method=joback]
Pc          11.704;      // bar [origin=predictive method=joback]
omega       0.9812;      // -   [origin=predictive method=lee-kesler]
Tb          956.23;      // K   [origin=predictive method=joback]
HvapTb      90600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-418.46 4.00898 -0.00341 1.2304e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 10; } { group C; count 2; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 11; } { group CH_ring; count 10; } { group C_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "demissidin" "dihydrosolanidine" "solanine d" "5-alpha-solanidan-3-beta-ol" "(3" "a,5" "a)-solanidan-3-ol" "(3beta,5alpha)-solanidan-3-ol" "(3-beta,5-alpha)-solanidan-3-ol" "solanidan-3-ol, (3beta,5alpha)-" "22r,25s-5alpha-solanidanine-3beta-ol" "(22r,25s)-5alpha-solanidan-3beta-ol" "(22s,25s)-5alpha-solanidan-3beta-ol" "(22s,25s)-5-alpha-solanidan-3-beta-ol" );
standardThermochemistry
{
    dHf_298   -370870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     717.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=397180.0
}
