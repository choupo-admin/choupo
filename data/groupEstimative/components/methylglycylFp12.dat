/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylglycyl fp-12  (C15H22O2, CAS 139953-97-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylglycylFp12;
formula     C15H22O2;
CAS         139953-97-2;
InChIKey    INZXMQZBAFIWAU-ZSYFSEQKSA-N;
MW          234.339;      // g/mol [origin=calculated method=formula-sum]
Tc          864.12;      // K   [origin=predictive method=joback]
Pc          18.659;      // bar [origin=predictive method=joback]
omega       1.0326;      // -   [origin=predictive method=lee-kesler]
Tb          677.76;      // K   [origin=predictive method=joback]
HvapTb      67475.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.548 1.50554 -0.0011338 3.588e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 5; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 10; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(1z,3z,5z,7z,9z)-dodeca-1,3,5,7,9-pentaenoxy]propan-2-ol" "methylglycyl fecapentaene-12" "2'-(1,3,5,7,9-dodecapentaenyloxy)-2'-propanol" "(all e)-1-(2-hydroxypropoxy)-1,3,5,7,9-dodecapentaene" "2-propanol, 1-(1,3,5,7,9-dodecapentaenyloxy)-, (all-e)-" "1,3,5,7,9-dodecapentaene, 1-(2-hydroxypropoxy)-, (all-e)-" );
standardThermochemistry
{
    dHf_298   -56560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     760.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=232260.0
}
