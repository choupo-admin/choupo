/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2,3-dibromopropyl) phthalate  (C14H14Br4O4, CAS 7415-86-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis23DibromopropylPhthalate;
formula     C14H14Br4O4;
CAS         7415-86-3;
InChIKey    IVARTEJQLIMVJT-UHFFFAOYSA-N;
MW          565.878;      // g/mol [origin=calculated method=formula-sum]
Tc          1179.26;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       1.3747;      // -   [origin=predictive method=lee-kesler]
Tb          931.78;      // K   [origin=predictive method=joback]
HvapTb      89474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.774 1.2504 -0.00080476 1.772e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group Br; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[2,3-bis(bromanyl)propyl] benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid, 1,2-bis(2,3-dibromopropyl) ester" "bis(2,3-dibromopropyl) benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid, bis(2,3-dibromopropyl) ester" "1,2-benzenedicarboxylicacid, 1,2-bis(2,3-dibromopropyl) ester" "1,2-benzenedicarboxylicacid, bis(2,3-dibromopropyl) ester (9ci); phthalic acid, bis(2,3-dibromopropyl)ester (7ci,8ci); 1-propanol, 2,3-dibromo-, phthalate (2:1) (8ci);bis(2,3-dibromopropyl) phthalate" );
gibbsFormation
{
    dHf_298   -647030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     876.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-398560.0
    phase     gas;
}
