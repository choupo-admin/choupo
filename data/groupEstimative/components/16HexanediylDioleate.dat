/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-hexanediyl dioleate  (C42H78O4, CAS 21224-03-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16HexanediylDioleate;
formula     C42H78O4;
CAS         21224-03-3;
InChIKey    ZNRNSKNVPBUUNI-UHFFFAOYSA-N;
MW          647.082;      // g/mol [origin=calculated method=formula-sum]
Tc          1826.15;      // K   [origin=predictive method=joback]
Pc          3.791;      // bar [origin=predictive method=joback]
omega       -0.4182;      // -   [origin=predictive method=lee-kesler]
Tb          1285.32;      // K   [origin=predictive method=joback]
HvapTb      123816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.836 3.92424 -0.0022394 4.692e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 32; } { group CH=CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 34; } { group dCH; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-octadec-9-enoyloxyhexyl octadec-9-enoate" "9-octadecenoic acid (9z)-, 1,6-hexanediyl ester" "9-octadecenoic acid (9z)-, 1,1'-(1,6-hexanediyl) ester" );
gibbsFormation
{
    dHf_298   -1310330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1881.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-157540.0
    phase     gas;
}
