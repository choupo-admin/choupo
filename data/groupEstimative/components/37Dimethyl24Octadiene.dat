/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethyl-2,4-octadiene  (C10H18, CAS 116595-45-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethyl24Octadiene;
formula     C10H18;
CAS         116595-45-0;
InChIKey    NXFMFYVNTLULFW-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          622.26;      // K   [origin=predictive method=joback]
Pc          23.542;      // bar [origin=predictive method=joback]
omega       0.3725;      // -   [origin=predictive method=lee-kesler]
Tb          436.16;      // K   [origin=predictive method=joback]
HvapTb      37462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.939 0.99968 -0.0006933 2.039e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 3; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethylocta-2,4-diene" "2,4-octadiene, 3,7-dimethyl-, (z,e)-" "2,4-octadiene, 3,7-dimethyl-, (e,e)-" "2,4-octadiene, 3,7-dimethyl-, (e,z)-" );
standardThermochemistry
{
    dHf_298   -30360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=182770.0
}
