/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-thiabicyclo(3.2.1)octa-3,6-diene  (C7H8S, CAS 39066-37-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Thiabicyclo321Octa36Diene;
formula     C7H8S;
CAS         39066-37-0;
InChIKey    SYQWATXRWSZIAD-UHFFFAOYSA-N;
MW          124.201;      // g/mol [origin=calculated method=formula-sum]
Tc          662.53;      // K   [origin=predictive method=joback]
Pc          43.626;      // bar [origin=predictive method=joback]
omega       0.2653;      // -   [origin=predictive method=lee-kesler]
Tb          427.93;      // K   [origin=predictive method=joback]
HvapTb      37742.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.82 0.85381 -0.00069786 2.281e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 2; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-thiabicyclo[3.2.1]octa-2,6-diene" "2-thiabicyclo[3.2.1]octa-3,6-diene" );
gibbsFormation
{
    dHf_298   106290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     263.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=205140.0
    phase     gas;
}
