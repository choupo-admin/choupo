/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(dimethylamino)cinnamic acid  (C11H13NO2, CAS 1552-96-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4DimethylaminoCinnamicAcid;
formula     C11H13NO2;
CAS         1552-96-1;
InChIKey    CQNPVMCASGWEHM-VMPITWQZSA-N;
MW          191.23;      // g/mol [origin=calculated method=formula-sum]
Tc          867.81;      // K   [origin=predictive method=joback]
Pc          30.223;      // bar [origin=predictive method=joback]
omega       0.8589;      // -   [origin=predictive method=lee-kesler]
Tb          645.05;      // K   [origin=predictive method=joback]
HvapTb      62183.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.99 1.10514 -0.00080776 2.331e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-[4-(dimethylamino)phenyl]prop-2-enoic acid" "p-(dimethylamino)cinnamic acid" "4-(n,n-dimethylamino)cinnamic acid" "4-dimethylaminocinnamic acid" "(2e)-3-[4-(dimethylamino)phenyl]prop-2-enoic acid" "3-(4-(dimethylamino)phenyl)acrylic acid" "3-[4-(dimethylamino)phenyl]acrylic acid" "4-dimethylamino cinnamic acid" "p-dimethylaminocinnamic acid" "p-n,n-dimethylaminocinnamic acid" "4-(n,n-dimethyamino)cinnamic acid" "(e)-3-(4-(dimethylamino)phenyl)acrylic acid" );
standardThermochemistry
{
    dHf_298   -210830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-8390.0
}
