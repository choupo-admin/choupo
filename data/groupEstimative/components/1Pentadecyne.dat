/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentadecyne  (C15H28, CAS 765-13-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pentadecyne;
formula     C15H28;
CAS         765-13-9;
InChIKey    DONJGKADZJEXRJ-UHFFFAOYSA-N;
MW          208.389;      // g/mol [origin=calculated method=formula-sum]
Tc          700.58;      // K   [origin=predictive method=joback]
Pc          15.873;      // bar [origin=predictive method=joback]
omega       0.6553;      // -   [origin=predictive method=lee-kesler]
Tb          532.92;      // K   [origin=predictive method=joback]
HvapTb      48842.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.032 1.33492 -0.00078813 1.8569e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadec-1-yne" "1-penatdecyne" "pentadec-1-in" "tridecylacetylene" "timtec-bb sbb009125;n-tridecylacetylene;1-penatdecyne;1-pentadecyne;pentadec-1-yne;1-pentadecyne,97%" );
gibbsFormation
{
    dHf_298   -61030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     709.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=298490.0
    phase     gas;
}
