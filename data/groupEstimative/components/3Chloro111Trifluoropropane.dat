/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-1,1,1-trifluoropropane  (C3H4ClF3, CAS 460-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro111Trifluoropropane;
formula     C3H4ClF3;
CAS         460-35-5;
InChIKey    ZPIFKCVYZBVZIV-UHFFFAOYSA-N;
MW          132.509;      // g/mol [origin=calculated method=formula-sum]
Tc          453.95;      // K   [origin=predictive method=joback]
Pc          36.334;      // bar [origin=predictive method=joback]
omega       0.2923;      // -   [origin=predictive method=lee-kesler]
Tb          300.25;      // K   [origin=predictive method=joback]
HvapTb      22910.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.852 0.4568 -0.0003808 1.222e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2Cl; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group F; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-1,1,1-tris(fluoranyl)propane" "1-chloro-3,3,3-trifluoropropane" "1,1,1-trifluoro-3-chloropropane" "propane, 3-chloro-1,1,1-trifluoro-" "chlorotrifluoropropane" "monochlorotrifluoropropane" "3,3,3-trifluoro-1-chloropropane" "propane,3-chloro-1,1,1-trifluoro-" "1,1,1-trifluoro-3-chloropropane;1-chloro-3,3,3-trifluoropropane; 3,3,3-trifluoro-1-chloropropane;3,3,3-trifluorochloropropane; 3-chloro-1,1,1-trifluoropropane; hcfc 253fb; r253fb" );
gibbsFormation
{
    dHf_298   -718070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-619140.0
    phase     gas;
}
