/*--------------------------------*- Choupo -*-----------------------*\
  Component: biphenyl-2,2'-diylbis(piperidin-1-ylmethanone)  (C24H28N2O2, CAS 52882-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        biphenyl22DiylbisPiperidin1Ylmethanone;
formula     C24H28N2O2;
CAS         52882-84-5;
InChIKey    UXIXVQXMZNDJAI-UHFFFAOYSA-N;
MW          376.5;      // g/mol [origin=calculated method=formula-sum]
Tc          1239.48;      // K   [origin=predictive method=joback]
Pc          18.232;      // bar [origin=predictive method=joback]
omega       1.1520;      // -   [origin=predictive method=lee-kesler]
Tb          984.56;      // K   [origin=predictive method=joback]
HvapTb      93604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-197.65 2.5152 -0.00176352 4.6772e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group ACH; count 8; } { group AC; count 4; } { group CON_CH2_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group CdO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperidin-1-yl-[2-(2-piperidin-1-ylcarbonylphenyl)phenyl]methanone" "piperidine,1,1'-([1,1'-biphenyl]-2,2-diyldicarbonyl)bis-" "piperidine, 1,1'-((1,1'-biphenyl)-2,2-diyldicarbonyl)bis-" "[2-[2-(piperidine-1-carbonyl)phenyl]phenyl]-piperidin-1-ylmethanone" );
standardThermochemistry
{
    dHf_298   -17030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     935.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=409000.0
}
