/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrachloroethylene  (C2Cl4, CAS 127-18-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrachloroethylene;
formula     C2Cl4;
CAS         127-18-4;
InChIKey    CYTYCFOTNPOANT-UHFFFAOYSA-N;
MW          165.822;      // g/mol [origin=calculated method=formula-sum]
Tc          620.69;      // K   [origin=predictive method=joback]
Pc          44.682;      // bar [origin=predictive method=joback]
omega       0.2560;      // -   [origin=predictive method=lee-kesler]
Tb          399.00;      // K   [origin=predictive method=joback]
HvapTb      37704.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.07 0.2408 -0.000255 9.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Cl_C=C_; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC; count 2; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetrakis(chloranyl)ethene" "perchloroethylene" "tetrachloroethene" "ethene, tetrachloro-" "perc" "tetrachlorethylene" "perchlorethylene" "ethylene tetrachloride" "ankilostin" "didakene" "perclene" "tetracap" );
gibbsFormation
{
    dHf_298   -49930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18640.0
    phase     gas;
}
