/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolpropane tridecanoate  (C36H68O6, CAS 78-17-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolpropaneTridecanoate;
formula     C36H68O6;
CAS         78-17-1;
InChIKey    QQGBDFMKLXCNHD-UHFFFAOYSA-N;
MW          596.934;      // g/mol [origin=calculated method=formula-sum]
Tc          1588.20;      // K   [origin=predictive method=joback]
Pc          4.645;      // bar [origin=predictive method=joback]
omega       -0.1523;      // -   [origin=predictive method=lee-kesler]
Tb          1194.71;      // K   [origin=predictive method=joback]
HvapTb      116655.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.918 3.38528 -0.0018226 3.178e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 25; } { group C; count 1; } { group CH2COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 28; } { group C; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(decanoyloxymethyl)butyl decanoate" "2-ethyl-2-[[(1-oxodecyl)oxy]methyl]-1,3-propanediyl didecanoate" "trimethylolpropane tricaprate" "2-ethyl-2-(((1-oxodecyl)oxy)methyl)-1,3-propanediyl didecanoate" "decanoic acid, 1,1'-(2-ethyl-2-(((1-oxodecyl)oxy)methyl)-1,3-propanediyl) ester" "decanoic acid, 1,1'-[2-ethyl-2-[[(1-oxodecyl)oxy]methyl]-1,3-propanediyl] ester" "trimethylolpropane caprate" "decanoic acid, 2-ethyl-2-(((1-oxodecyl)oxy)methyl)-1,3-propanediyl ester" "decanoic acid,1,1'-[2-ethyl-2-[[(1-oxodecyl)oxy]methyl]-1,3-propanediyl] ester" );
gibbsFormation
{
    dHf_298   -1746960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1673.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-676030.0
    phase     gas;
}
