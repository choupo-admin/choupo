/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-di-tert-butyl-4-hydroxybenzaldehyde  (C15H22O2, CAS 1620-98-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H22O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        35DiTertButyl4Hydroxybenzaldehyde;
formula     C15H22O2;
CAS         1620-98-0;
InChIKey    DOZRDZLFLOODMB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          234.339;      // g/mol [origin=calculated method=formula-sum]
Tc          857.76;      // K   [origin=predictive method=joback]
Pc          22.125;      // bar [origin=predictive method=joback]
omega       0.6033;      // -   [origin=predictive method=lee-kesler]
Tb          630.02;      // K   [origin=predictive method=joback]
HvapTb      60633.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.42 1.64532 -0.00144228 5.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-ditert-butyl-4-oxidanyl-benzaldehyde" "3,5-ditert-butyl-4-hydroxybenzaldehyde" "benzaldehyde, 3,5-bis(1,1-dimethylethyl)-4-hydroxy-" "3,5-di-t-butyl-4-hydroxybenzaldehyde" "3,5-ditert-butyl-4-hydroxy-benzaldehyde" "3,5-bis(tert-butyl)-4-hydroxybenzaldehyde" "benzaldehyde, 3,5-di-tert-butyl-4-hydroxy-" "4-hydroxy-3,5-di-tert-butylbenzaldehyde" "benzaldehyde,5-di-tert-butyl-4-hydroxy-" "3,5-di-tert-butyl-4-hydroxy-benzaldehyde" "3,5-di-(tert-butyl)-4-hydroxybenzaldehyde" "benzaldehyde,5-bis(1,1-dimethylethyl)-4-hydroxy-" );
gibbsFormation
{
    dHf_298   -257700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     651.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63590.0
    phase     gas;
}
