/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutanol, 1-ethyl-  (C6H12O, CAS 84256-19-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobutanol1Ethyl;
formula     C6H12O;
CAS         84256-19-9;
InChIKey    ZQXBPTKCIMXYMS-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          628.67;      // K   [origin=predictive method=joback]
Pc          44.326;      // bar [origin=predictive method=joback]
omega       0.6442;      // -   [origin=predictive method=lee-kesler]
Tb          440.31;      // K   [origin=predictive method=joback]
HvapTb      44563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.629 1.04102 -0.0010394 4.374e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethylcyclobutan-1-ol" );
standardThermochemistry
{
    dHf_298   -237520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94020.0
}
