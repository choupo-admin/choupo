/*--------------------------------*- Choupo -*-----------------------*\
  Component: eucatropine  (C17H25NO3, CAS 100-91-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eucatropine;
formula     C17H25NO3;
CAS         100-91-4;
InChIKey    QSAVEGSLJISCDF-UHFFFAOYSA-N;
MW          291.391;      // g/mol [origin=calculated method=formula-sum]
Tc          993.41;      // K   [origin=predictive method=joback]
Pc          19.631;      // bar [origin=predictive method=joback]
omega       1.1333;      // -   [origin=predictive method=lee-kesler]
Tb          783.82;      // K   [origin=predictive method=joback]
HvapTb      79941.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.74 2.01958 -0.001533 4.873e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1,2,2,6-tetramethylpiperidin-4-yl) 2-oxidanyl-2-phenyl-ethanoate" "n-methyl-b-vinyldiacetonaikamine mandelate" "benzeneacetic acid, .alpha.-hydroxy-, 1,2,2,6-tetramethyl-4-piperidinyl ester" "eucatropina" "eucatropinum" "eucatropinum [inn-latin]" "brd-a37942872-003-03-2" "1,2,2,6-tetramethylpiperidin-4-yl hydroxy(phenyl)acetate" "(1,2,2,6-tetramethylpiperidin-4-yl) 2-hydroxy-2-phenylacetate" );
standardThermochemistry
{
    dHf_298   -529900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     754.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-118540.0
}
