/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trimethoxycinnamic acid ethyl ester  (C14H18O5, CAS 67827-53-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246TrimethoxycinnamicAcidEthylEster;
formula     C14H18O5;
CAS         67827-53-6;
InChIKey    NGOZXDZLACOEPS-UHFFFAOYSA-N;
MW          266.293;      // g/mol [origin=calculated method=formula-sum]
Tc          894.15;      // K   [origin=predictive method=joback]
Pc          19.407;      // bar [origin=predictive method=joback]
omega       0.9189;      // -   [origin=predictive method=lee-kesler]
Tb          691.18;      // K   [origin=predictive method=joback]
HvapTb      65615.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (86.881 0.85208 -0.00022408 -6.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-(2,4,6-trimethoxyphenyl)prop-2-enoate" );
gibbsFormation
{
    dHf_298   -726890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     654.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-394630.0
    phase     gas;
}
