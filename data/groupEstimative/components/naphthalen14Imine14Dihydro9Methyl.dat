/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalen-1,4-imine,1,4-dihydro-9-methyl-  (C11H11N, CAS 55258-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphthalen14Imine14Dihydro9Methyl;
formula     C11H11N;
CAS         55258-00-9;
InChIKey    PHCSHNYKFNLHSN-UHFFFAOYSA-N;
MW          157.216;      // g/mol [origin=calculated method=formula-sum]
Tc          718.89;      // K   [origin=predictive method=joback]
Pc          34.039;      // bar [origin=predictive method=joback]
omega       0.4870;      // -   [origin=predictive method=lee-kesler]
Tb          499.48;      // K   [origin=predictive method=joback]
HvapTb      44835.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.87 1.29932 -0.00117184 4.203e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group ACCH; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalen-1,4-imine, 1,4-dihydro-9-methyl-" "n-methyl-11-aza-tricyclo[6.2.1.0(2,7)]undec-2,4,6,9-tetraene" );
standardThermochemistry
{
    dHf_298   237920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     230.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=430960.0
}
