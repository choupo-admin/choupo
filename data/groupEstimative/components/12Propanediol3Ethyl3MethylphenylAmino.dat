/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-propanediol, 3-(ethyl(3-methylphenyl)amino)-  (C12H19NO2, CAS 92-11-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Propanediol3Ethyl3MethylphenylAmino;
formula     C12H19NO2;
CAS         92-11-5;
InChIKey    SJLAXYZNPAEOOM-UHFFFAOYSA-N;
MW          209.289;      // g/mol [origin=calculated method=formula-sum]
Tc          885.61;      // K   [origin=predictive method=joback]
Pc          28.781;      // bar [origin=predictive method=joback]
omega       1.4827;      // -   [origin=predictive method=lee-kesler]
Tb          702.18;      // K   [origin=predictive method=joback]
HvapTb      80257.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.417 1.20324 -0.00076976 1.887e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[ethyl-(3-methylphenyl)amino]propane-1,2-diol" "3-(n-ethyl-m-toluidino)propane-1,2-diol" "1,2-propanediol, 3-[ethyl(3-methylphenyl)amino]-" "3-(n-ethyl-3-methylanilino)propane-1,2-diol" );
gibbsFormation
{
    dHf_298   -308160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12360.0
    phase     gas;
}
