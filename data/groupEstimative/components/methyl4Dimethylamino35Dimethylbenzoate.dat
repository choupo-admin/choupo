/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-(dimethylamino)-3,5-dimethylbenzoate  (C12H17NO2, CAS 56066-86-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4Dimethylamino35Dimethylbenzoate;
formula     C12H17NO2;
CAS         56066-86-5;
InChIKey    WIJWZUPWOWXGTD-UHFFFAOYSA-N;
MW          207.273;      // g/mol [origin=calculated method=formula-sum]
Tc          790.29;      // K   [origin=predictive method=joback]
Pc          23.092;      // bar [origin=predictive method=joback]
omega       0.6959;      // -   [origin=predictive method=lee-kesler]
Tb          586.44;      // K   [origin=predictive method=joback]
HvapTb      56018.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.69 0.9556 -0.00047708 6.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 2; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-(dimethylamino)-3,5-dimethyl-benzoate" "n,n,2,6-tetramethylaniline,4-carboxylic acid, methyl ester" );
standardThermochemistry
{
    dHf_298   -338640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-65910.0
}
