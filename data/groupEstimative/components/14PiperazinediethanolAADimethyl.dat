/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-piperazinediethanol, |a,|a'-dimethyl-,  (C10H22N2O2, CAS 7672-76-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14PiperazinediethanolAADimethyl;
formula     C10H22N2O2;
CAS         7672-76-6;
InChIKey    ZRMOLCPODIMNPJ-UHFFFAOYSA-N;
MW          202.298;      // g/mol [origin=calculated method=formula-sum]
Tc          825.18;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       1.5047;      // -   [origin=predictive method=lee-kesler]
Tb          652.44;      // K   [origin=predictive method=joback]
HvapTb      74916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.668 1.44924 -0.0010418 2.988e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2_ring; count 4; } { group OH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-(2-oxidanylpropyl)piperazin-1-yl]propan-2-ol" "alpha,alpha'-dimethylpiperazine-1,4-diethanol" "1,4-piperazinediethanol, alpha,alpha'-dimethyl-," "1,4-piperazinediethanol, .alpha.,.alpha.'-dimethyl-" "1-[4-(2-hydroxypropyl)piperazin-1-yl]propan-2-ol" "(2r,2'r)-1,1'-piperazine-1,4-diyldipropan-2-ol" "(2r,2's)-1,1'-piperazine-1,4-diyldipropan-2-ol" );
gibbsFormation
{
    dHf_298   -342710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32720.0
    phase     gas;
}
