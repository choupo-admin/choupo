/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,n'-trimethylethylenediamine  (C5H14N2, CAS 142-25-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNNTrimethylethylenediamine;
formula     C5H14N2;
CAS         142-25-6;
InChIKey    HVOYZOQVDYHUPF-UHFFFAOYSA-N;
MW          102.181;      // g/mol [origin=calculated method=formula-sum]
Tc          545.76;      // K   [origin=predictive method=joback]
Pc          35.137;      // bar [origin=predictive method=joback]
omega       0.4658;      // -   [origin=predictive method=lee-kesler]
Tb          376.61;      // K   [origin=predictive method=joback]
HvapTb      35203.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.558 0.67896 -0.0004094 9.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH3NH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n',n'-trimethylethane-1,2-diamine" "1,2-ethanediamine, n,n,n'-trimethyl-" "ethylenediamine, n,n,n'-trimethyl-" "n1,n1,n2-trimethyl-1,2-ethanediamine" "n,n,n-trimethylethylenediamine" "[2-(dimethylamino)ethyl](methyl)amine" "n1,n1,n2-trimethylethane-1,2-diamine" "1,2-ethanediamine, n1,n1,n2-trimethyl-" "agn-pc-0cj6lc" "hvoyzoqvdyhupf-uhfffaoysa-" "dimethyl(2-(methylamino)ethyl)amine" "n,n,n'-trimethylethane-1,2-diamine" );
gibbsFormation
{
    dHf_298   -25530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191390.0
    phase     gas;
}
