/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-methoxyethyl)-2,6-xylidine  (C11H17NO, CAS 50563-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2Methoxyethyl26Xylidine;
formula     C11H17NO;
CAS         50563-55-8;
InChIKey    OTKGPBKVICJCOU-UHFFFAOYSA-N;
MW          179.263;      // g/mol [origin=calculated method=formula-sum]
Tc          764.14;      // K   [origin=predictive method=joback]
Pc          25.585;      // bar [origin=predictive method=joback]
omega       0.6715;      // -   [origin=predictive method=lee-kesler]
Tb          560.51;      // K   [origin=predictive method=joback]
HvapTb      52526.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.872 0.86396 -0.00040932 5.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CH3O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-methoxyethyl)-2,6-dimethyl-aniline" "n-(2-methoxyethyl)-2,6-dimethylaniline" "benzenamine, n-(2-methoxyethyl)-2,6-dimethyl-" "2,6-dimethyl-n-(2'-methoxyethyl)aniline" "benzenamine,n-(2-methoxyethyl)-2,6-dimethyl-" );
gibbsFormation
{
    dHf_298   -135530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=119280.0
    phase     gas;
}
