/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5,8,8-tetramethyl-5,6,7,8-tetrahydronaphthalen-2-ol  (C14H20O, CAS 22824-31-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5588Tetramethyl5678Tetrahydronaphthalen2Ol;
formula     C14H20O;
CAS         22824-31-3;
InChIKey    UZHCJGSIRIFQTO-UHFFFAOYSA-N;
MW          204.313;      // g/mol [origin=calculated method=formula-sum]
Tc          883.79;      // K   [origin=predictive method=joback]
Pc          28.143;      // bar [origin=predictive method=joback]
omega       0.6266;      // -   [origin=predictive method=lee-kesler]
Tb          639.02;      // K   [origin=predictive method=joback]
HvapTb      60184.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-187.77 2.04868 -0.00214192 9.263e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5,8,8-tetramethyl-6,7-dihydronaphthalen-2-ol" "2-naphthalenol,5,6,7,8-tetrahydro-5,5,8,8-tetramethyl-" "6-hydroxy-1,1,4,4-tetramethyl-1,2,3,4-tetrahydronaphthalene" );
gibbsFormation
{
    dHf_298   -207760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45120.0
    phase     gas;
}
