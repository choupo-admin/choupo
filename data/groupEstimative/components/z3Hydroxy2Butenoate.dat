/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-3-hydroxy-2-butenoate  (C5H8O3, CAS 4525-25-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        z3Hydroxy2Butenoate;
formula     C5H8O3;
CAS         4525-25-1;
InChIKey    DHVOJYDALVUWPZ-ARJAWSKDSA-N;
MW          116.116;      // g/mol [origin=calculated method=formula-sum]
Tc          648.58;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       0.8170;      // -   [origin=predictive method=lee-kesler]
Tb          468.44;      // K   [origin=predictive method=joback]
HvapTb      50848.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.17 0.47794 -0.0002701 5.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (z)-3-oxidanylbut-2-enoate" "4-hydroxy-4-methoxybut-3-en-2-one" "(e)-4-hydroxy-4-methoxybut-3-en-2-one" "2-butenoic acid, 3-hydroxy-, methyl ester, (e)-" );
standardThermochemistry
{
    dHf_298   -508610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-384300.0
}
