/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-allyloxypropionitrile  (C6H9NO, CAS 3088-44-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Allyloxypropionitrile;
formula     C6H9NO;
CAS         3088-44-6;
InChIKey    IXXSWIVBWMKRHZ-UHFFFAOYSA-N;
MW          111.144;      // g/mol [origin=calculated method=formula-sum]
Tc          650.24;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.5205;      // -   [origin=predictive method=lee-kesler]
Tb          458.06;      // K   [origin=predictive method=joback]
HvapTb      41168.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.943 0.4254 -0.0001835 1.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH2O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-prop-2-enoxypropanenitrile" "2-cyanoethyl allyl ether" "allyl 2-cyanoethyl ether" "propionitrile, 3-allyloxy-" "allyl beta-cyanoethyl ether" "propionitrile, beta-allyloxy-" "propanenitrile, 3-(2-propenyloxy)-" "3-allyloxypropannitril" "3-(allyloxy)propionitrile" "allyl .beta.-cyanoethyl ether" "beta-allyloxypropionitrile" "propionitrile, 3-(allyloxy)-" );
standardThermochemistry
{
    dHf_298   -9080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=115660.0
}
