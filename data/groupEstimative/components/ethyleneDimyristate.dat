/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylene dimyristate  (C30H58O4, CAS 627-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyleneDimyristate;
formula     C30H58O4;
CAS         627-84-9;
InChIKey    AMOSICMEJHNLEP-UHFFFAOYSA-N;
MW          482.79;      // g/mol [origin=calculated method=formula-sum]
Tc          1254.56;      // K   [origin=predictive method=joback]
Pc          5.984;      // bar [origin=predictive method=joback]
omega       0.3264;      // -   [origin=predictive method=lee-kesler]
Tb          1002.44;      // K   [origin=predictive method=joback]
HvapTb      97188.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.436 2.74424 -0.001419 2.316e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 24; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 26; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tetradecanoyloxyethyl tetradecanoate" );
standardThermochemistry
{
    dHf_298   -1297090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1427.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-419020.0
}
