/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-4-methylbenzoic acid  (C8H7ClO2, CAS 5162-82-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro4MethylbenzoicAcid;
formula     C8H7ClO2;
CAS         5162-82-3;
InChIKey    SDKUOEOJAXGCLU-UHFFFAOYSA-N;
MW          170.592;      // g/mol [origin=calculated method=formula-sum]
Tc          836.53;      // K   [origin=predictive method=joback]
Pc          37.500;      // bar [origin=predictive method=joback]
omega       0.7395;      // -   [origin=predictive method=lee-kesler]
Tb          602.22;      // K   [origin=predictive method=joback]
HvapTb      58551.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.8 0.62352 -0.00040152 9.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-4-methyl-benzoic acid" "3-chloro-p-toluic acid" "p-toluic acid, 3-chloro-" "benzoic acid, 3-chloro-4-methyl-" "3-chloro-4-methyl benzoic acid" "3-chloro-4-toluic acid" "3-chloro-4-methyl-benzoic acid" "benzoicacid, 3-chloro-4-methyl-" "p-toluicacid, 3-chloro- (6ci,7ci,8ci);3-chloro-4-methylbenzoic acid;3-chloro-p-toluicacid;" );
gibbsFormation
{
    dHf_298   -360870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246210.0
    phase     gas;
}
