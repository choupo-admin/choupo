/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dichloroacetamide  (C2H3Cl2NO, CAS 683-72-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dichloroacetamide;
formula     C2H3Cl2NO;
CAS         683-72-7;
InChIKey    WCGGWVOVFQNRRS-UHFFFAOYSA-N;
MW          127.952;      // g/mol [origin=calculated method=formula-sum]
Tc          665.67;      // K   [origin=predictive method=joback]
Pc          54.385;      // bar [origin=predictive method=joback]
omega       0.4940;      // -   [origin=predictive method=lee-kesler]
Tb          446.18;      // K   [origin=predictive method=joback]
HvapTb      45815.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.02 0.2472 -0.0001537 3.206e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl2; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group Cl; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)ethanamide" "dichloroacetamide" "acetamide, 2,2-dichloro-" "2,2-dichloro-acetamide" "2,2'-dichloroacetamide" "acetamide,2,2-dichloro-" "i441" );
standardThermochemistry
{
    dHf_298   -200160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122810.0
}
