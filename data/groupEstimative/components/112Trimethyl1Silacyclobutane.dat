/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2-trimethyl-1-silacyclobutane  (C6H14Si, CAS 30681-90-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H14Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        112Trimethyl1Silacyclobutane;
formula     C6H14Si;
CAS         30681-90-4;
InChIKey    IBURGXLWVCHMET-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          114.263;      // g/mol [origin=calculated method=formula-sum]
Tc          530.52;      // K   [origin=predictive method=joback]
Pc          31.420;      // bar [origin=predictive method=joback]
omega       0.1823;      // -   [origin=predictive method=lee-kesler]
Tb          345.02;      // K   [origin=predictive method=joback]
HvapTb      29157.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.99 0.51856 -0.000108 -5.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2-trimethylsiletane" "silacyclobutane, 1,1,2-trimethyl-" );
standardThermochemistry
{
    dHf_298   -205990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-44370.0
}
