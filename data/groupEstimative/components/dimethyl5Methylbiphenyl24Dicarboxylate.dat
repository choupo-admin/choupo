/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 5-methylbiphenyl-2,4'-dicarboxylate  (C17H16O4, CAS 67801-56-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl5Methylbiphenyl24Dicarboxylate;
formula     C17H16O4;
CAS         67801-56-3;
InChIKey    WYSSHTHBSQSSNM-UHFFFAOYSA-N;
MW          284.311;      // g/mol [origin=calculated method=formula-sum]
Tc          1003.58;      // K   [origin=predictive method=joback]
Pc          20.236;      // bar [origin=predictive method=joback]
omega       0.9178;      // -   [origin=predictive method=lee-kesler]
Tb          773.30;      // K   [origin=predictive method=joback]
HvapTb      74788.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.34 1.17296 -0.00057308 5.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 7; } { group AC; count 4; } { group ACCH3; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-(4-methoxycarbonylphenyl)-4-methyl-benzoate" "(1,1'-biphenyl)-2,4'-dicarboxylic acid, 5-methyl-, dimethyl ester" "[1,1'-biphenyl]-2,4'-dicarboxylic acid, 5-methyl-, dimethyl ester" "(1,1'-biphenyl)-2,4'-dicarboxylic acid, 5-methyl-, 2,4'-dimethyl ester" "[1,1'-biphenyl]-2,4'-dicarboxylic acid, 5-methyl-, 2,4'-dimethyl ester" "dimethyl 5-methyl(1,1'-biphenyl)-2,4'-dicarboxylate" "methyl 2-(4-methoxycarbonylphenyl)-4-methylbenzoate" );
standardThermochemistry
{
    dHf_298   -590120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-332550.0
}
