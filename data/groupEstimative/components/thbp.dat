/*--------------------------------*- Choupo -*-----------------------*\
  Component: thbp  (C10H12O4, CAS 1421-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thbp;
formula     C10H12O4;
CAS         1421-63-2;
InChIKey    SRUQARLMFOLRDN-UHFFFAOYSA-N;
MW          196.202;      // g/mol [origin=calculated method=formula-sum]
Tc          993.40;      // K   [origin=predictive method=joback]
Pc          55.942;      // bar [origin=predictive method=joback]
omega       1.3713;      // -   [origin=predictive method=lee-kesler]
Tb          750.81;      // K   [origin=predictive method=joback]
HvapTb      85918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.508 1.31072 -0.00130178 5.2356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 3; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,4,5-tris(oxidanyl)phenyl]butan-1-one" "2',4',5'-trihydroxybutyrophenone" "2,4,5-trihydroxybutyrophenone" "usaf ek" "1-butanone, 1-(2,4,5-trihydroxyphenyl)-" "butyrophenone, 2',4',5'-trihydroxy-" "1-(2,4,5-trihydroxyphenyl)butan-1-one" "1-(2,4,5-trihydroxyphenyl)-1-butanone" "2,5-trihydroxybutyrophenone" "2',5'-trihydroxybutyrophenone" "butyrophenone,4',5'-trihydroxy-" "2,'4',5'-trihydroxybutyrophenone" );
gibbsFormation
{
    dHf_298   -657710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-447050.0
    phase     gas;
}
