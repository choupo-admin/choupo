/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tetradecanethiol  (C14H30S, CAS 2079-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Tetradecanethiol;
formula     C14H30S;
CAS         2079-95-0;
InChIKey    GEKDEMKPCKTKEC-UHFFFAOYSA-N;
MW          230.454;      // g/mol [origin=calculated method=formula-sum]
Tc          758.25;      // K   [origin=predictive method=joback]
Pc          16.026;      // bar [origin=predictive method=joback]
omega       0.7419;      // -   [origin=predictive method=lee-kesler]
Tb          582.78;      // K   [origin=predictive method=joback]
HvapTb      53495.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.053 1.36112 -0.0007602 1.61e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecane-1-thiol" "myristyl mercaptan" "tetradecyl mercaptan" "tetradecanethiol" "n-tetradecyl mercaptan" "1-mercaptotetradecane" );
standardThermochemistry
{
    dHf_298   -293810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     763.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=96390.0
}
