/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pentylpyridine  (C10H15N, CAS 2294-76-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Pentylpyridine;
formula     C10H15N;
CAS         2294-76-0;
InChIKey    HSDXVAOHEOSTFZ-UHFFFAOYSA-N;
MW          149.237;      // g/mol [origin=calculated method=formula-sum]
Tc          723.62;      // K   [origin=predictive method=joback]
Pc          29.345;      // bar [origin=predictive method=joback]
omega       0.4849;      // -   [origin=predictive method=lee-kesler]
Tb          508.78;      // K   [origin=predictive method=joback]
HvapTb      46340.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.046 0.90868 -0.00056066 1.351e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-amylpyridine" "pyridine, 2-pentyl-" "2-n-pentylpyridine" "2-amyl pyridine" "2-amyl pyridine; 1-(2-pyridyl)pentane" "s154" );
standardThermochemistry
{
    dHf_298   19590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222780.0
}
