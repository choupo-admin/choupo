/*--------------------------------*- Choupo -*-----------------------*\
  Component: alkaloid q  (C29H47NO3, CAS 36069-45-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alkaloidQ;
formula     C29H47NO3;
CAS         36069-45-1;
InChIKey    ZVYUDNWAHWVPPN-WGMPUXNISA-N;
MW          457.699;      // g/mol [origin=calculated method=formula-sum]
Tc          1361.58;      // K   [origin=predictive method=joback]
Pc          10.569;      // bar [origin=predictive method=joback]
omega       1.0039;      // -   [origin=predictive method=lee-kesler]
Tb          1110.76;      // K   [origin=predictive method=joback]
HvapTb      108652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-317.92 3.7441 -0.00287044 9.448e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 9; } { group CH; count 9; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group CH3COO; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 8; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,8s,9s,10r,13s,14s,16r,17r)-10,13-dimethyl-17-[(1s)-1-[(2s,5s)-5-methylpiperidin-2-yl]ethyl]-3-oxidanyl-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-16-yl] ethanoate" "teinemine 16-acetate" "muldamine" "alkaloid q, from veratrum californicum" "veratraman-3,11-diol, 12,13-dihydro-, 11-acetate, (3beta,11alpha,12beta,13beta)-" "5-veratranine-3" "a,11" "a-diol 11-acetate" "(3" "a,16" "a,22" "a)-16,28-secosolanid-5-ene-3,16-diol 16-acetate" );
gibbsFormation
{
    dHf_298   -789060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     963.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9130.0
    phase     gas;
}
