/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethyltridecane  (C15H32, CAS 61868-05-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dimethyltridecane;
formula     C15H32;
CAS         61868-05-1;
InChIKey    JDFJCABQSZLDMZ-UHFFFAOYSA-N;
MW          212.421;      // g/mol [origin=calculated method=formula-sum]
Tc          706.56;      // K   [origin=predictive method=joback]
Pc          14.326;      // bar [origin=predictive method=joback]
omega       0.6523;      // -   [origin=predictive method=lee-kesler]
Tb          541.92;      // K   [origin=predictive method=joback]
HvapTb      48208.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.111 1.44068 -0.0007986 1.663e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 9; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 9; } { group CH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -363490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70540.0
    phase     gas;
}
