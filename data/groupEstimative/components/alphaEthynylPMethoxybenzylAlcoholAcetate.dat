/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-ethynyl-p-methoxybenzyl alcohol acetate  (C12H12O3, CAS 99520-55-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaEthynylPMethoxybenzylAlcoholAcetate;
formula     C12H12O3;
CAS         99520-55-5;
InChIKey    OZDNWQAJSDYSCG-UHFFFAOYSA-N;
MW          204.225;      // g/mol [origin=calculated method=formula-sum]
Tc          797.29;      // K   [origin=predictive method=joback]
Pc          27.412;      // bar [origin=predictive method=joback]
omega       0.6098;      // -   [origin=predictive method=lee-kesler]
Tb          576.14;      // K   [origin=predictive method=joback]
HvapTb      54531.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.38 0.79944 -0.00038669 3.819e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH3COO; count 1; } { group CH3O; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methoxyphenyl)prop-2-ynyl ethanoate" "1'-acetoxy-2',3'-dehydroestragole" "benzyl alcohol, alpha-ethynyl-p-methoxy-, acetate" "benzenemethanol, alpha-ethynyl-4-methoxy-, acetate" "1-(4-methoxyphenyl)prop-2-ynyl acetate" );
gibbsFormation
{
    dHf_298   -228830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41800.0
    phase     gas;
}
