/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzo(a)triphenylene  (C22H14, CAS 196-78-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoATriphenylene;
formula     C22H14;
CAS         196-78-1;
InChIKey    JZOIZKBKSZMVRV-UHFFFAOYSA-N;
MW          278.354;      // g/mol [origin=calculated method=formula-sum]
Tc          1090.15;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.8117;      // -   [origin=predictive method=lee-kesler]
Tb          820.50;      // K   [origin=predictive method=joback]
HvapTb      75388.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.89 1.8216 -0.00154996 5.258e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 14; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzo(g)chrysene" "naphthophenanthrene" "benzo[g]chrysene" "benzochrysene" "1,2,3,4-dibenzphenanthrene" "1,2,3,4-dibenzophenanthrene" "1,2:3,4:7,8-tribenznaphthalene" "1,2,3,4-dibenzphenanthrene;1,2:3,4-dibenzophenanthrene; 1,2:3,4:7,8-tribenznaphthalene;benzo[a]triphenylene" );
standardThermochemistry
{
    dHf_298   468990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=644480.0
}
