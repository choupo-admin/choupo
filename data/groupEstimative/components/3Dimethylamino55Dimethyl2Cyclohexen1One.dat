/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(dimethylamino)-5,5-dimethyl-2-cyclohexen-1-one  (C10H17NO, CAS 31039-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Dimethylamino55Dimethyl2Cyclohexen1One;
formula     C10H17NO;
CAS         31039-88-0;
InChIKey    XHNTVKASLQLNFM-UHFFFAOYSA-N;
MW          167.252;      // g/mol [origin=calculated method=formula-sum]
Tc          755.25;      // K   [origin=predictive method=joback]
Pc          28.475;      // bar [origin=predictive method=joback]
omega       0.4871;      // -   [origin=predictive method=lee-kesler]
Tb          532.59;      // K   [origin=predictive method=joback]
HvapTb      44376.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.98 1.20798 -0.00092264 3.191e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(dimethylamino)-5,5-dimethyl-cyclohex-2-en-1-one" "2-cyclohexenone,3-(n,n-dimethylamino)-5,5-dimethyl-" "5,5-dimethyl-3-(n,n-dimethylamino)cyclohex-2-enone" "3-(dimethylamino)-5,5-dimethylcyclohex-2-en-1-one" "2-cyclohexen-1-one,3-(dimethylamino)-5,5-dimethyl-" );
standardThermochemistry
{
    dHf_298   -204030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60800.0
}
