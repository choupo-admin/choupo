/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol 25  (C19H32N2O2, CAS 64604-91-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol25;
formula     C19H32N2O2;
CAS         64604-91-7;
InChIKey    BAPROVDXKNPHAM-UHFFFAOYSA-N;
MW          320.477;      // g/mol [origin=calculated method=formula-sum]
Tc          1148.49;      // K   [origin=predictive method=joback]
Pc          17.061;      // bar [origin=predictive method=joback]
omega       1.2198;      // -   [origin=predictive method=lee-kesler]
Tb          921.69;      // K   [origin=predictive method=joback]
HvapTb      95733.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.916 2.12732 -0.00158018 4.7996e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2NH2; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-azanylethyl)-3-(3,5-ditert-butyl-4-oxidanyl-phenyl)propanamide" "fenol 25" "f 25" "benzenepropanamide, n-(2-aminoethyl)-3,5-bis(1,1-dimethylethyl)-4-hydroxy-" "n-(2-aminoethyl)-3,5-bis(1,1-dimethylethyl)-4-hydroxybenzenepropanamide" "n-(2-aminoethyl)-3-(3,5-di-tert-butyl-4-hydroxyphenyl)propanamide" "n-(2-aminoethyl)-3-(3,5-ditert-butyl-4-hydroxyphenyl)propanamide" "n-(2-aminoethyl)-3-[3,5-bis(tert-butyl)-4-hydroxyphenyl]propanamide" );
gibbsFormation
{
    dHf_298   -442030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     845.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80230.0
    phase     gas;
}
