/*--------------------------------*- Choupo -*-----------------------*\
  Component: trichloro-5,10-diethoxyviolanthrene  (C38H23Cl3O2, CAS 40537-72-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trichloro510Diethoxyviolanthrene;
formula     C38H23Cl3O2;
CAS         40537-72-2;
InChIKey    ZKTIYNAZFIWRSM-UHFFFAOYSA-N;
MW          617.95;      // g/mol [origin=calculated method=formula-sum]
Tc          1780.76;      // K   [origin=predictive method=joback]
Pc          10.596;      // bar [origin=predictive method=joback]
omega       0.9768;      // -   [origin=predictive method=lee-kesler]
Tb          1449.05;      // K   [origin=predictive method=joback]
HvapTb      140225.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.918 2.83574 -0.00241412 8.451e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 13; } { group AC; count 18; } { group CH2O; count 2; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 13; } { group dC_ring; count 21; } { group Cl; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,15,16-trichloro-5,10-diethoxyanthra[9,1,2-cde]benzo[rst]pentaphene" "anthra[9,1,2-cde]benzo[rst]pentaphene,trichloro-5,10-diethoxy-" "dinaphtho(1,2,3-cd:3',2',1'-lm)perylene, trichloro-5,10-diethoxy-" );
standardThermochemistry
{
    dHf_298   397220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     702.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=861820.0
}
