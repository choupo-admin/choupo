/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-aminoethanethiol  (C2H7NS, CAS 60-23-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Aminoethanethiol;
formula     C2H7NS;
CAS         60-23-1;
InChIKey    UFULAYFCSOUIOV-UHFFFAOYSA-N;
MW          77.145;      // g/mol [origin=calculated method=formula-sum]
Tc          592.45;      // K   [origin=predictive method=joback]
Pc          60.186;      // bar [origin=predictive method=joback]
omega       0.3490;      // -   [origin=predictive method=lee-kesler]
Tb          380.75;      // K   [origin=predictive method=joback]
HvapTb      37424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.452 0.283 -0.0001508 2.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2NH2; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group NH2; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanylethanethiol" "cysteamine" "mercaptamine" "thioethanolamine" "becaptan" "beta-mercaptoethylamine" "cysteinamine" "mercamine" "decarboxycysteine" "beta-aminoethanethiol" "cystagon" "cysteamin" );
gibbsFormation
{
    dHf_298   -12340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61800.0
    phase     gas;
}
