/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-azetidino-isobutene  (C7H13N, CAS 81156-88-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1AzetidinoIsobutene;
formula     C7H13N;
CAS         81156-88-9;
InChIKey    MAQZILNLVNBMOU-UHFFFAOYSA-N;
MW          111.188;      // g/mol [origin=calculated method=formula-sum]
Tc          578.35;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       0.3402;      // -   [origin=predictive method=lee-kesler]
Tb          387.65;      // K   [origin=predictive method=joback]
HvapTb      33479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.22 0.99004 -0.0008313 2.862e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=C; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methylprop-1-enyl)azetidine" "1-azetidin-1-yl-isobutene" );
standardThermochemistry
{
    dHf_298   80290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=258970.0
}
