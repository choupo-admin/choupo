/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butyl-n-methylaniline  (C11H17N, CAS 5279-59-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylNMethylaniline;
formula     C11H17N;
CAS         5279-59-4;
InChIKey    VPSMEEGFQMCUTH-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          747.47;      // K   [origin=predictive method=joback]
Pc          26.958;      // bar [origin=predictive method=joback]
omega       0.4906;      // -   [origin=predictive method=lee-kesler]
Tb          529.88;      // K   [origin=predictive method=joback]
HvapTb      48158.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.4 1.11248 -0.00075916 2.027e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-tert-butyl-n-methyl-aniline" "aniline, p-tert-butyl-n-methyl-" "4-methylamino-t-butylbenzene" "benzenamine, 4-(1,1-dimethylethyl)-n-methyl-" );
gibbsFormation
{
    dHf_298   -590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=236750.0
    phase     gas;
}
