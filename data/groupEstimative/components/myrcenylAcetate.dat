/*--------------------------------*- Choupo -*-----------------------*\
  Component: myrcenyl acetate  (C12H20O2, CAS 1118-39-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        myrcenylAcetate;
formula     C12H20O2;
CAS         1118-39-4;
InChIKey    DCXXKSXLKWAZNO-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          708.26;      // K   [origin=predictive method=joback]
Pc          19.631;      // bar [origin=predictive method=joback]
omega       0.5659;      // -   [origin=predictive method=lee-kesler]
Tb          522.39;      // K   [origin=predictive method=joback]
HvapTb      47157.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.757 1.17476 -0.0007543 1.83e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-6-methylidene-oct-7-en-2-yl) ethanoate" "acetic acid, myrcenyl ester" "7-octen-2-ol, 2-methyl-6-methylene-, acetate" "2-methyl-6-methylideneoct-7-en-2-yl acetate" "2-methyl-6-methylene-7-octen-2-yl acetate" "3-methylene-7-methyl-1-octen-7-yl acetate" "7-octen-2-ol, 2-methyl-6-methylene-, 2-acetate" "acetic acid, 2-methyl-6-methylene-7-octen-2-yl ester" "neobergamate" "pseudolinalyl acetate" "terpenes and terpenoids, turpentine-oil, myrcene fraction, hydroxy, acetates" "2-acetoxy-2-methyl-6-methylene-7-octene" );
standardThermochemistry
{
    dHf_298   -375970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90240.0
}
