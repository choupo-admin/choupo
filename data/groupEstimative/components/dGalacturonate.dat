/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-galacturonate  (C6H10O7, CAS 9046-38-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dGalacturonate;
formula     C6H10O7;
CAS         9046-38-2;
InChIKey    AEMOLEFTQBMNLQ-YMDCURPLSA-N;
MW          194.139;      // g/mol [origin=calculated method=formula-sum]
Tc          1077.79;      // K   [origin=predictive method=joback]
Pc          61.708;      // bar [origin=predictive method=joback]
omega       2.5907;      // -   [origin=predictive method=lee-kesler]
Tb          878.93;      // K   [origin=predictive method=joback]
HvapTb      116533.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.33 0.7737 -0.0003423 1.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 4; } { group OH; count 4; } { group CH-O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 5; } { group OH; count 4; } { group O_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,3r,4s,5r)-3,4,5,6-tetrakis(oxidanyl)oxane-2-carboxylic acid" "pectate" "d-(+)-galacturonic acid monohydrate" "(2s,3r,4s,5r)-3,4,5,6-tetrahydroxyoxane-2-carboxylic acid" );
standardThermochemistry
{
    dHf_298   -1285400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-984060.0
}
