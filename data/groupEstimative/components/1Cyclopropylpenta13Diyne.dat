/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclopropylpenta-1,3-diyne  (C8H8, CAS 116316-76-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclopropylpenta13Diyne;
formula     C8H8;
CAS         116316-76-8;
InChIKey    ZEKLXAZDDKNQBK-UHFFFAOYSA-N;
MW          104.152;      // g/mol [origin=calculated method=formula-sum]
Tc          643.11;      // K   [origin=predictive method=joback]
Pc          42.386;      // bar [origin=predictive method=joback]
omega       0.1907;      // -   [origin=predictive method=lee-kesler]
Tb          407.38;      // K   [origin=predictive method=joback]
HvapTb      37619.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.51 0.61512 -0.00044732 1.4126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tC; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "penta-1,3-diynylcyclopropane" "cyclopropane,1,3-pentadiyn-1-yl-" "cyclopropane,1,3-pentadiynyl- (9ci); 1-cyclopropyl-1,3-pentadiyne" );
standardThermochemistry
{
    dHf_298   408950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     320.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=482830.0
}
