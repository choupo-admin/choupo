/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-azanylpropan-2-ol;6-(2-ethylhexanoylamino)hexanoic acid  (C17H36N2O4, CAS 75113-49-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Azanylpropan2Ol62EthylhexanoylaminoHexanoicAcid;
formula     C17H36N2O4;
CAS         75113-49-4;
InChIKey    CYZZRDBHDIUZHS-UHFFFAOYSA-N;
MW          332.485;      // g/mol [origin=calculated method=formula-sum]
Tc          1229.43;      // K   [origin=predictive method=joback]
Pc          14.702;      // bar [origin=predictive method=joback]
omega       1.3074;      // -   [origin=predictive method=lee-kesler]
Tb          1003.34;      // K   [origin=predictive method=joback]
HvapTb      110620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.42 1.61936 -0.0006689 2.316e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 2; } { group OH; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 2; } { group OH; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanoic acid, 6-((2-ethyl-1-oxohexyl)amino)-, compd. with 1-amino-2-propanol (1:1)" "hexanoic acid, 6-((2-ethylhexanoyl)amino)-, compd. with 1-amino-2-propanol (1:1)" );
gibbsFormation
{
    dHf_298   -1044210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1129.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-471190.0
    phase     gas;
}
