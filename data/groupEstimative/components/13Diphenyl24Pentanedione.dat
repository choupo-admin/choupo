/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diphenyl-2,4-pentanedione  (C17H16O2, CAS 19588-08-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diphenyl24Pentanedione;
formula     C17H16O2;
CAS         19588-08-0;
InChIKey    ZRPKYWOSTUYAPU-UHFFFAOYSA-N;
MW          252.313;      // g/mol [origin=calculated method=formula-sum]
Tc          990.97;      // K   [origin=predictive method=joback]
Pc          23.703;      // bar [origin=predictive method=joback]
omega       0.8539;      // -   [origin=predictive method=lee-kesler]
Tb          749.22;      // K   [origin=predictive method=joback]
HvapTb      71092.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.339 1.41092 -0.0009292 2.2352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diphenylpentane-2,4-dione" );
gibbsFormation
{
    dHf_298   -151590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     649.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56800.0
    phase     gas;
}
