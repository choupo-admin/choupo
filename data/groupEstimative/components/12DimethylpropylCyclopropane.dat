/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,2-dimethylpropyl)cyclopropane  (C8H16, CAS 6976-27-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12DimethylpropylCyclopropane;
formula     C8H16;
CAS         6976-27-8;
InChIKey    JSDZSLGMRRSAHD-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          574.68;      // K   [origin=predictive method=joback]
Pc          29.537;      // bar [origin=predictive method=joback]
omega       0.3042;      // -   [origin=predictive method=lee-kesler]
Tb          388.50;      // K   [origin=predictive method=joback]
HvapTb      32539.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.99 0.92656 -0.000638 1.823e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutan-2-ylcyclopropane" "cyclopropane, (1,2-dimethylpropyl)-" "cyclopropane,2-dimethylpropyl)-" "cyclopropane,(1,2-dimethylpropyl)-" );
gibbsFormation
{
    dHf_298   -146210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72350.0
    phase     gas;
}
