/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r,2s,5r)-2-isopropyl-5-methylcyclohexanecarboxylic acid  (C11H20O2, CAS 16052-40-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2s5r2Isopropyl5MethylcyclohexanecarboxylicAcid;
formula     C11H20O2;
CAS         16052-40-7;
InChIKey    MNVSUVYRIVXDBK-KXUCPTDWSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          820.27;      // K   [origin=predictive method=joback]
Pc          24.076;      // bar [origin=predictive method=joback]
omega       0.6943;      // -   [origin=predictive method=lee-kesler]
Tb          606.56;      // K   [origin=predictive method=joback]
HvapTb      56667.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.92 1.17466 -0.0006206 1.004e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 4; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2s,5r)-5-methyl-2-propan-2-yl-cyclohexane-1-carboxylic acid" "cyclohexanecarboxylic acid, 5-methyl-2-(1-methylethyl)-, (1r,2s,5r)-" "(1r,2s,5r)-2-isopropyl-5-methyl-cyclohexanecarboxylic acid" "(-)-(1r,3r,4s)-4-isopropyl-1-methylcyclohexane-3-carboxylic acid" "(1r,2s,5r)-5-methyl-2-propan-2-ylcyclohexane-1-carboxylic acid" "cyclohexanecarboxylicacid, 5-methyl-2-(1-methylethyl)-, (1r,2s,5r)-" "(1r-(1alpha,2beta,5alpha))-2-(isopropyl)-5-methylcyclohexanecarboxylic acid" "cyclohexanecarboxylicacid, 5-methyl-2-(1-methylethyl)-, [1r-(1a,2b,5a)]-; p-menthane-3-carboxylicacid, (1r,3r,4s)-(-)- (8ci); (1r,3r,4s)-p-menthane-3-carboxylic acid" );
standardThermochemistry
{
    dHf_298   -612280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-295580.0
}
