/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipropyleneglycol dibenzoate  (C20H22O5, CAS 20109-39-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipropyleneglycolDibenzoate;
formula     C20H22O5;
CAS         20109-39-1;
InChIKey    LXODQLXKQIJVNK-UHFFFAOYSA-N;
MW          342.391;      // g/mol [origin=calculated method=formula-sum]
Tc          1072.51;      // K   [origin=predictive method=joback]
Pc          16.431;      // bar [origin=predictive method=joback]
omega       1.0283;      // -   [origin=predictive method=lee-kesler]
Tb          848.54;      // K   [origin=predictive method=joback]
HvapTb      81114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.148 1.58504 -0.0008328 1.078e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(phenylcarbonyloxy)propoxy]propyl benzoate" "1-propanol, 2-[2-(benzoyloxy)propoxy]-, benzoate" "2-(2-(benzoyloxy)propoxy)propyl benzoate" "2-[2-(benzoyloxy)propoxy]propyl benzoate" "1-propanol, 2-(2-(benzoyloxy)propoxy)-, benzoate" "1-propanol, 2-(2-(benzoyloxy)propoxy)-, 1-benzoate" "1-propanol, 2-[2-(benzoyloxy)propoxy]-, 1-benzoate" "2-(2-benzoyloxypropoxy)propyl benzoate" "dipropylene glycol dibenzoate (plasticizer dpgdb)" "1-((1-(benzoyloxy)propan-2-yl)oxy)propan-2-yl benzoate" );
gibbsFormation
{
    dHf_298   -760410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     817.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-388280.0
    phase     gas;
}
