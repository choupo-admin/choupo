/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dimethylpentylamine  (C7H17N, CAS 105-41-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dimethylpentylamine;
formula     C7H17N;
CAS         105-41-9;
InChIKey    YAHRDLICUYEDAU-UHFFFAOYSA-N;
MW          115.22;      // g/mol [origin=calculated method=formula-sum]
Tc          618.44;      // K   [origin=predictive method=joback]
Pc          30.289;      // bar [origin=predictive method=joback]
omega       0.4578;      // -   [origin=predictive method=lee-kesler]
Tb          431.41;      // K   [origin=predictive method=joback]
HvapTb      41041.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.348 0.74256 -0.0004068 8.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylhexan-2-amine" "methylhexaneamine" "2-amino-4-methylhexane" "forthan" "forthane" "1,3-dimethylamylamine" "4-methyl-2-hexylamine" "2-hexanamine, 4-methyl-" "methylhexanamine" "dimethylamylamine" "pentylamine, 1,3-dimethyl-" "4-methyl-2-hexanamine" );
standardThermochemistry
{
    dHf_298   -164580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69630.0
}
