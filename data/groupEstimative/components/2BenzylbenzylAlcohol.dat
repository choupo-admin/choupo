/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-benzylbenzyl alcohol  (C14H14O, CAS 1586-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BenzylbenzylAlcohol;
formula     C14H14O;
CAS         1586-00-1;
InChIKey    GTKWHQWJTVWORA-UHFFFAOYSA-N;
MW          198.265;      // g/mol [origin=calculated method=formula-sum]
Tc          891.14;      // K   [origin=predictive method=joback]
Pc          30.090;      // bar [origin=predictive method=joback]
omega       0.9556;      // -   [origin=predictive method=lee-kesler]
Tb          670.44;      // K   [origin=predictive method=joback]
HvapTb      68651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.058 1.1505 -0.00076356 1.913e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(phenylmethyl)phenyl]methanol" "(2-benzylphenyl)methanol" "benzyl alcohol, o-benzyl-" "benzenemethanol, 2-(phenylmethyl)-" "[2-benzylphenyl]methan-1-ol" "gtkwhqwjtvwora-uhfffaoysa-" "benzenemethanol,2-(phenylmethyl)-" );
gibbsFormation
{
    dHf_298   -22930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=145370.0
    phase     gas;
}
