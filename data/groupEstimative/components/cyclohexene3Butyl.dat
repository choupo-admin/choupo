/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene,3-butyl-  (C10H18, CAS 3983-07-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene3Butyl;
formula     C10H18;
CAS         3983-07-1;
InChIKey    DPWVJRLEBPJBSR-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          645.99;      // K   [origin=predictive method=joback]
Pc          26.653;      // bar [origin=predictive method=joback]
omega       0.3659;      // -   [origin=predictive method=lee-kesler]
Tb          447.11;      // K   [origin=predictive method=joback]
HvapTb      38575.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.027 1.01992 -0.00058848 1.216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-butylcyclohexene" "3-butyl-1-cyclohexene" "cyclohexene, 3-butyl-" );
standardThermochemistry
{
    dHf_298   -137630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87730.0
}
