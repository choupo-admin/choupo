/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclooct-2-en-1-ol  (C8H14O, CAS 3212-75-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclooct2En1Ol;
formula     C8H14O;
CAS         3212-75-7;
InChIKey    UJZBDMYKNUWDPM-XQRVVYSFSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          709.10;      // K   [origin=predictive method=joback]
Pc          38.916;      // bar [origin=predictive method=joback]
omega       0.6511;      // -   [origin=predictive method=lee-kesler]
Tb          502.07;      // K   [origin=predictive method=joback]
HvapTb      51146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.16 0.8447 -0.00041728 4.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2z)-cyclooct-2-en-1-ol" );
standardThermochemistry
{
    dHf_298   -260900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90130.0
}
