/*--------------------------------*- Choupo -*-----------------------*\
  Component: trideceth-5  (C15H32O2, CAS 38471-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trideceth5;
formula     C15H32O2;
CAS         38471-49-7;
InChIKey    OJDDJQYSKDIXOE-UHFFFAOYSA-N;
MW          244.419;      // g/mol [origin=calculated method=formula-sum]
Tc          817.60;      // K   [origin=predictive method=joback]
Pc          14.988;      // bar [origin=predictive method=joback]
omega       1.1356;      // -   [origin=predictive method=lee-kesler]
Tb          657.40;      // K   [origin=predictive method=joback]
HvapTb      68073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.044 1.39962 -0.0007116 1.223e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tridecoxyethanol" "trideceth-6" "trideceth-8" "trideceth-9" "trideceth-10" "trideceth-11" "trideceth-12" "trideceth-15" "trideceth-20" "trideceth-50" "peg-5 tridecyl ether" "peg-6 tridecyl ether" );
standardThermochemistry
{
    dHf_298   -637380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     802.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-166400.0
}
