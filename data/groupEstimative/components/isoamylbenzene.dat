/*--------------------------------*- Choupo -*-----------------------*\
  Component: isoamylbenzene  (C11H16, CAS 2049-94-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isoamylbenzene;
formula     C11H16;
CAS         2049-94-7;
InChIKey    XNXIYYFOYIUJIW-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          684.21;      // K   [origin=predictive method=joback]
Pc          26.708;      // bar [origin=predictive method=joback]
omega       0.4063;      // -   [origin=predictive method=lee-kesler]
Tb          477.52;      // K   [origin=predictive method=joback]
HvapTb      41968.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.698 0.97584 -0.000609 1.447e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutylbenzene" "isopentylbenzene" "benzene, (3-methylbutyl)-" "benzene, isopentyl-" "(3-methylbutyl)benzene" "(3-methyl-1-butyl)benzene" "1-isopentylbenzene" "3-methyl-butyl-benzene" "1-phenyl-3-methylbutane" "2-methyl-4-phenylbutane" "3-methyl-1-phenylbutane" "benzene,1-butyl-3-methyl-" );
standardThermochemistry
{
    dHf_298   -39120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=151710.0
}
