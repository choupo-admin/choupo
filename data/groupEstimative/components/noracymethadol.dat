/*--------------------------------*- Choupo -*-----------------------*\
  Component: noracymethadol  (C22H29NO2, CAS 1477-39-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        noracymethadol;
formula     C22H29NO2;
CAS         1477-39-0;
InChIKey    VWCUGCYZZGRKEE-UHFFFAOYSA-N;
MW          339.479;      // g/mol [origin=calculated method=formula-sum]
Tc          1087.97;      // K   [origin=predictive method=joback]
Pc          14.624;      // bar [origin=predictive method=joback]
omega       0.9375;      // -   [origin=predictive method=lee-kesler]
Tb          860.60;      // K   [origin=predictive method=joback]
HvapTb      80889.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.558 2.09508 -0.0013676 3.259e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH3COO; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[6-(methylamino)-4,4-diphenyl-heptan-3-yl] ethanoate" "paracymethadol" "noracimetadolo [dcit]" "noracymethadol [inn:ban]" "noracymethadolum [inn-latin]" "nor-laam" "alpha-ethyl-beta-(2-(methylamino)propyl)-beta-phenylbenzeneethanol, acetate (ester)" "benzeneethanol, .alpha.-ethyl-.beta.-[2-(methylamino)propyl]-.beta.-phenyl-, acetate (ester)" "l-alpha-noracetylmethadol" "noracimetadol" "noracimetadolo" "noracymethadolum" );
standardThermochemistry
{
    dHf_298   -307470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     834.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136160.0
}
