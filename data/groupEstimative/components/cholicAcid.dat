/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholic acid  (C24H40O5, CAS 81-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholicAcid;
formula     C24H40O5;
CAS         81-25-4;
InChIKey    BHQCQFFYRZLCQQ-OELDTZBJSA-N;
MW          408.579;      // g/mol [origin=calculated method=formula-sum]
Tc          1473.31;      // K   [origin=predictive method=joback]
Pc          14.657;      // bar [origin=predictive method=joback]
omega       1.1826;      // -   [origin=predictive method=lee-kesler]
Tb          1191.10;      // K   [origin=predictive method=joback]
HvapTb      132187.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-291.058 3.42296 -0.0028304 1.0058e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 9; } { group C; count 2; } { group OH; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 8; } { group C_ring; count 2; } { group OH; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r)-4-[(3r,5s,7r,8r,9s,10s,12s,13r,14s,17r)-10,13-dimethyl-3,7,12-tris(oxidanyl)-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthren-17-yl]pentanoic acid" "cholate" "cholanic acid" "cholalin" "colalin" "cholalic acid" "3alpha,7alpha,12alpha-trihydroxy-5beta-cholanic acid" "cholsaeure" "3alpha,7alpha,12alpha-trihydroxy-5beta-cholan-24-oic acid" "chd" "3alpha,7alpha,12alpha-trihydroxy-5beta-cholanoic acid" "3alpha,7alpha,12alpha-trihydroxy-5beta-cholanate" );
standardThermochemistry
{
    dHf_298   -1182090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     910.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-480350.0
}
