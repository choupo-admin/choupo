/*--------------------------------*- Choupo -*-----------------------*\
  Component: (6|a)-hopane-6,22-diol  (C30H52O2, CAS 22570-53-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6AHopane622Diol;
formula     C30H52O2;
CAS         22570-53-2;
InChIKey    KYBLAIAGFNCVHL-PMVHANJISA-N;
MW          444.744;      // g/mol [origin=calculated method=formula-sum]
Tc          1346.96;      // K   [origin=predictive method=joback]
Pc          10.624;      // bar [origin=predictive method=joback]
omega       1.0173;      // -   [origin=predictive method=lee-kesler]
Tb          1099.63;      // K   [origin=predictive method=joback]
HvapTb      107424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-534.53 5.04516 -0.004994 2.0752e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 10; } { group CH; count 6; } { group C; count 6; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group C; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 6; } { group C_ring; count 5; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,3as,5ar,5br,7s,7as,11ar,11br,13ar,13bs)-5a,5b,8,8,11a,13b-hexamethyl-3-(2-oxidanylpropan-2-yl)-1,2,3,3a,4,5,6,7,7a,9,10,11,11b,12,13,13a-hexadecahydrocyclopenta[a]chrysen-7-ol" "a'-neogammacerane-6,22-diol, (6alpha)-" "zeorin" "zeorin, zeorine" "(3s,3as,5ar,5br,7s,7as,11ar,11br,13ar,13bs)-3-(2-hydroxypropan-2-yl)-5a,5b,8,8,11a,13b-hexamethyl-1,2,3,3a,4,5,6,7,7a,9,10,11,11b,12,13,13a-hexadecahydrocyclopenta[a]chrysen-7-ol" "(6s,9s,20s,1r,2r,14r)-6-(1-hydroxy-isopropyl)-1,2,9,14,18,18-hexamethylpentacyclo[11.8.0.0<2,10>.0<5,9>.0<14,19>]henicosan-20-ol; a'-neogammacerane-6,22-diol, (6alpha)-" );
gibbsFormation
{
    dHf_298   -694540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1149.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=88360.0
    phase     gas;
}
