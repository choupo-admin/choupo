/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-anilino-3-phenoxy-2-propanol  (C15H17NO2, CAS 16112-55-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Anilino3Phenoxy2Propanol;
formula     C15H17NO2;
CAS         16112-55-3;
InChIKey    DSXTWXWHWLDHFS-UHFFFAOYSA-N;
MW          243.306;      // g/mol [origin=calculated method=formula-sum]
Tc          977.65;      // K   [origin=predictive method=joback]
Pc          27.701;      // bar [origin=predictive method=joback]
omega       1.2263;      // -   [origin=predictive method=lee-kesler]
Tb          760.49;      // K   [origin=predictive method=joback]
HvapTb      78673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.658 1.3239 -0.0008258 1.833e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CH2NH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenoxy-3-phenylazanyl-propan-2-ol" "2-propanol, 1-phenoxy-3-(phenylamino)-" "1-anilino-3-phenoxypropan-2-ol" "n-(3-phenoxy-2-hydroxypropyl)aniline" );
standardThermochemistry
{
    dHf_298   -116130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=145370.0
}
