/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butylthiophene  (C8H12S, CAS 1455-20-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butylthiophene;
formula     C8H12S;
CAS         1455-20-5;
InChIKey    MNDZHERKKXUTOE-UHFFFAOYSA-N;
MW          140.244;      // g/mol [origin=calculated method=formula-sum]
Tc          667.98;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       0.3752;      // -   [origin=predictive method=lee-kesler]
Tb          453.72;      // K   [origin=predictive method=joback]
HvapTb      41026.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.127 0.76493 -0.00052042 1.44e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-n-butylthiophene" "thiophene, 2-butyl-" "2-butylthiophene;" "thiophene, butyl-" );
standardThermochemistry
{
    dHf_298   21720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=150890.0
}
