/*--------------------------------*- Choupo -*-----------------------*\
  Component: da 1529  (C20H22ClN3O2, CAS 4415-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        da1529;
formula     C20H22ClN3O2;
CAS         4415-51-4;
InChIKey    BBSJPRAFZYZZGW-RMKNXTFCSA-N;
MW          371.865;      // g/mol [origin=calculated method=formula-sum]
Tc          1154.22;      // K   [origin=predictive method=joback]
Pc          19.136;      // bar [origin=predictive method=joback]
omega       1.1012;      // -   [origin=predictive method=lee-kesler]
Tb          909.61;      // K   [origin=predictive method=joback]
HvapTb      87768.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.308 2.10786 -0.00153282 4.264e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2N; count 2; } { group C5H4N; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group Cl; count 1; } { group COO; count 1; } { group N; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(4-chlorophenyl)piperazin-1-yl]ethyl (e)-3-pyridin-2-ylprop-2-enoate" "piperazine, 1-(4-chlorophenyl)-4-(2-(3-(2-pyridyl)acryloxy)ethyl)-" "2-pyridineacrylic acid, 2-(4-(p-chlorophenyl)-1-piperazinyl) ethyl ester" "2-propenoic acid, 3-(2-pyridinyl)-, 2-(4-(4-chlorophenyl)-1-piperazinyl)ethyl ester" "2-propenoic acid, 3-(2-pyridinyl)-, 2-(4-(4-chlorophenyl)-1-piperazinyl)ethyl ester (9ci)" );
standardThermochemistry
{
    dHf_298   44490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     811.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=445600.0
}
