/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentafluorobenzamide  (C7H2F5NO, CAS 652-31-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentafluorobenzamide;
formula     C7H2F5NO;
CAS         652-31-3;
InChIKey    WPWWHXPRJFDTTJ-UHFFFAOYSA-N;
MW          211.089;      // g/mol [origin=calculated method=formula-sum]
Tc          722.70;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.8635;      // -   [origin=predictive method=lee-kesler]
Tb          534.09;      // K   [origin=predictive method=joback]
HvapTb      50064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (78.42 0.3853 -0.0001597 3.06e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group ACF; count 5; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group F; count 5; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5,6-pentakis(fluoranyl)benzamide" "2,3,4,5,6-pentafluorobenzamide" "benzamide, 2,3,4,5,6-pentafluoro-" "benzamide, pentafluoro-" "benzamide,3,4,5,6-pentafluoro-" "2,3,4,5,6-pentafluoro-benzamide" "benzamide,2,3,4,5,6-pentafluoro-" "p105" );
gibbsFormation
{
    dHf_298   -1067970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-964200.0
    phase     gas;
}
