/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenyldivinylsilane  (C16H16Si, CAS 17937-68-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diphenyldivinylsilane;
formula     C16H16Si;
CAS         17937-68-7;
InChIKey    JRMHUZLFQVKRNB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          236.389;      // g/mol [origin=calculated method=formula-sum]
Tc          861.89;      // K   [origin=predictive method=joback]
Pc          22.083;      // bar [origin=predictive method=joback]
omega       0.4229;      // -   [origin=predictive method=lee-kesler]
Tb          613.80;      // K   [origin=predictive method=joback]
HvapTb      54716.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.63 1.1198 -0.00054 4.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group ACH; count 10; } { group AC; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(ethenyl)-diphenyl-silane" "diethenyldiphenylsilane" "bis(ethenyl)-diphenylsilane" "benzene,1,1'-(diethenylsilylene)bis-" );
gibbsFormation
{
    dHf_298   238730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     683.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=379580.0
    phase     gas;
}
