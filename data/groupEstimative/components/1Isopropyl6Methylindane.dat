/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-isopropyl-6-methylindane  (C13H18, CAS 828-97-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Isopropyl6Methylindane;
formula     C13H18;
CAS         828-97-7;
InChIKey    VTHXZGHOXXVVSE-UHFFFAOYSA-N;
MW          174.287;      // g/mol [origin=calculated method=formula-sum]
Tc          758.65;      // K   [origin=predictive method=joback]
Pc          24.338;      // bar [origin=predictive method=joback]
omega       0.4653;      // -   [origin=predictive method=lee-kesler]
Tb          539.98;      // K   [origin=predictive method=joback]
HvapTb      47657.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.16 1.19776 -0.00080392 2.18e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-1-propan-2-yl-2,3-dihydro-1h-indene" "1h-indene, 2,3-dihydro-6-methyl-1-propan-2-yl-" );
standardThermochemistry
{
    dHf_298   -30540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=210040.0
}
