/*--------------------------------*- Choupo -*-----------------------*\
  Component: valeronitrile  (C5H9N, CAS 110-59-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        valeronitrile;
formula     C5H9N;
CAS         110-59-8;
InChIKey    RFFFKMOABOFIDF-UHFFFAOYSA-N;
MW          83.134;      // g/mol [origin=calculated method=formula-sum]
Tc          606.80;      // K   [origin=predictive method=joback]
Pc          33.684;      // bar [origin=predictive method=joback]
omega       0.4179;      // -   [origin=predictive method=lee-kesler]
Tb          416.08;      // K   [origin=predictive method=joback]
HvapTb      37202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.343 0.41362 -0.0002172 4.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentanenitrile" "butyl cyanide" "n-valeronitrile" "1-cyanobutane" "1-butyl cyanide" "n-butyl cyanide" "agn-pc-0d3aby" "1-butyl cyanide;1-cyanobutane;butane, 1-cyano-;butyl cyanide;n-butyl cyanide;n-pentanenitrile;n-valeronitrile;pentanenitrile;" );
gibbsFormation
{
    dHf_298   18350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124400.0
    phase     gas;
}
