/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-[3-(dimethylamino)propyl]octadec-9-enamide;propanoic acid  (C26H52N2O3, CAS 67801-61-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3DimethylaminoPropylOctadec9EnamidePropanoicAcid;
formula     C26H52N2O3;
CAS         67801-61-0;
InChIKey    HONKGNKLCZDPJO-UHFFFAOYSA-N;
MW          440.713;      // g/mol [origin=calculated method=formula-sum]
Tc          1317.47;      // K   [origin=predictive method=joback]
Pc          7.772;      // bar [origin=predictive method=joback]
omega       0.6123;      // -   [origin=predictive method=lee-kesler]
Tb          1062.03;      // K   [origin=predictive method=joback]
HvapTb      106111.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.948 2.51058 -0.0012747 1.9526e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 17; } { group CH=CH; count 1; } { group CH3N; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 18; } { group dCH; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propanoic acid compd. with (9z)-n-[3-(dimethylamino)propyl]-9-octadecenamide (1:1)" );
standardThermochemistry
{
    dHf_298   -916220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1406.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-129160.0
}
