/*--------------------------------*- Choupo -*-----------------------*\
  Component: ac1ldmdx  (C23H28O8, CAS 82508-31-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ac1ldmdx;
formula     C23H28O8;
CAS         82508-31-4;
InChIKey    VDGOFNMYZYBUDT-UHFFFAOYSA-N;
MW          432.469;      // g/mol [origin=calculated method=formula-sum]
Tc          1331.02;      // K   [origin=predictive method=joback]
Pc          14.240;      // bar [origin=predictive method=joback]
omega       1.2408;      // -   [origin=predictive method=lee-kesler]
Tb          1083.16;      // K   [origin=predictive method=joback]
HvapTb      103448.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-248.17 3.28238 -0.00321654 1.299e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group C; count 3; } { group CH=CH; count 1; } { group CH=C; count 2; } { group CH3COO; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 3; } { group dC; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COOH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -1317740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1133.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-826150.0
    phase     gas;
}
