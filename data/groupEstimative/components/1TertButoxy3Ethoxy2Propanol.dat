/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tert-butoxy-3-ethoxy-2-propanol  (C9H20O3, CAS 42910-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButoxy3Ethoxy2Propanol;
formula     C9H20O3;
CAS         42910-64-5;
InChIKey    MRRMNHYRTIBHOF-UHFFFAOYSA-N;
MW          176.256;      // g/mol [origin=calculated method=formula-sum]
Tc          709.15;      // K   [origin=predictive method=joback]
Pc          25.075;      // bar [origin=predictive method=joback]
omega       0.9314;      // -   [origin=predictive method=lee-kesler]
Tb          538.87;      // K   [origin=predictive method=joback]
HvapTb      55443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.843 0.89818 -0.0004492 6.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxy-3-[(2-methylpropan-2-yl)oxy]propan-2-ol" );
gibbsFormation
{
    dHf_298   -659790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-321520.0
    phase     gas;
}
