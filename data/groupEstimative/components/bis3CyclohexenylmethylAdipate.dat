/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(3-cyclohexenylmethyl) adipate  (C20H30O4, CAS 63905-29-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis3CyclohexenylmethylAdipate;
formula     C20H30O4;
CAS         63905-29-3;
InChIKey    PJRVYFKLOAROIV-UHFFFAOYSA-N;
MW          334.456;      // g/mol [origin=calculated method=formula-sum]
Tc          1023.34;      // K   [origin=predictive method=joback]
Pc          14.283;      // bar [origin=predictive method=joback]
omega       0.9393;      // -   [origin=predictive method=lee-kesler]
Tb          811.06;      // K   [origin=predictive method=joback]
HvapTb      76370.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.124 1.9264 -0.00101156 1.402e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 2; } { group CH=CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(cyclohex-3-en-1-ylmethyl) hexanedioate" "bis(cyclohex-3-enylmethyl) adipate" "adipic acid, bis(3-cyclohexenylmethyl) ester" "adipic acid, 3-cyclohexenylmethanol diester" "hexanedioic acid, bis(3-cyclohexen-1-ylmethyl) ester" "hexanedioic acid, 1,6-bis(3-cyclohexen-1-ylmethyl) ester" "hexanedioic acid,1,6-bis(3-cyclohexen-1-ylmethyl) ester" "hexanedioicacid, bis(3-cyclohexen-1-ylmethyl) ester (9ci)" );
standardThermochemistry
{
    dHf_298   -866490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     901.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-394400.0
}
