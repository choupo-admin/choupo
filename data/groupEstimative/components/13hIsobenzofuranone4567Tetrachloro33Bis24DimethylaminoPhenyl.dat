/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1(3h)-isobenzofuranone, 4,5,6,7-tetrachloro-3,3-bis[2-[4-(dimethylamino)phenyl]-2-(4-methoxyphenyl)ethenyl]-  (C43H38Cl4N2O3, CAS 113915-68-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13hIsobenzofuranone4567Tetrachloro33Bis24DimethylaminoPhenyl;
formula     C43H38Cl4N2O3;
CAS         113915-68-7;
InChIKey    HAIAEJWPQOBGFW-UHFFFAOYSA-N;
MW          772.588;      // g/mol [origin=calculated method=formula-sum]
Tc          2083.46;      // K   [origin=predictive method=joback]
Pc          7.352;      // bar [origin=predictive method=joback]
omega       0.4880;      // -   [origin=predictive method=lee-kesler]
Tb          1663.98;      // K   [origin=predictive method=joback]
HvapTb      158181.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.4 3.62182 -0.00263384 7.878e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH=C; count 2; } { group ACH; count 16; } { group AC; count 10; } { group CH2CO; count 1; } { group CH3O; count 2; } { group CH3N; count 2; } { group ACCl; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH; count 2; } { group dC; count 2; } { group CH2_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 16; } { group dC_ring; count 14; } { group Cl; count 4; } { group O; count 2; } { group CdO_ring; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,5,6,7-tetrakis(chloranyl)-3,3-bis[2-[4-(dimethylamino)phenyl]-2-(4-methoxyphenyl)ethenyl]-2h-inden-1-one" );
standardThermochemistry
{
    dHf_298   121430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1310.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=826410.0
}
