/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dimethyl-2-cyclohexen-1-one  (C8H12O, CAS 1123-09-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dimethyl2Cyclohexen1One;
formula     C8H12O;
CAS         1123-09-7;
InChIKey    NOQKKFBBAODEHN-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          698.29;      // K   [origin=predictive method=joback]
Pc          33.606;      // bar [origin=predictive method=joback]
omega       0.3724;      // -   [origin=predictive method=lee-kesler]
Tb          474.15;      // K   [origin=predictive method=joback]
HvapTb      39032.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.48 0.60214 -0.00016864 -4.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-dimethylcyclohex-2-en-1-one" "2-cyclohexen-1-one, 3,5-dimethyl-" "2-cyclohexen-1-one,5-dimethyl-" "3,5-dimethyl-2-cyclohexene-1-one" "3,5-dimethyl-cyclohex-2-en-1-one" );
gibbsFormation
{
    dHf_298   -245520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     314.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-61330.0
    phase     gas;
}
