/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methylnonane-1,9-diamine  (C10H24N2, CAS 45024-21-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methylnonane19Diamine;
formula     C10H24N2;
CAS         45024-21-3;
InChIKey    MBRGOFWKNLPACT-UHFFFAOYSA-N;
MW          172.316;      // g/mol [origin=calculated method=formula-sum]
Tc          760.78;      // K   [origin=predictive method=joback]
Pc          23.657;      // bar [origin=predictive method=joback]
omega       0.8222;      // -   [origin=predictive method=lee-kesler]
Tb          573.02;      // K   [origin=predictive method=joback]
HvapTb      58748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.098 1.08352 -0.0006102 1.293e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group CH2NH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,9-nonanediamine, 5-methyl-" "5-methyl-1,9-nonanediamine" );
gibbsFormation
{
    dHf_298   -187430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=163780.0
    phase     gas;
}
