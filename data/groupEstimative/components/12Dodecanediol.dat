/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dodecanediol  (C12H26O2, CAS 1119-87-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dodecanediol;
formula     C12H26O2;
CAS         1119-87-5;
InChIKey    ZITKDVFRMRXIJQ-UHFFFAOYSA-N;
MW          202.338;      // g/mol [origin=calculated method=formula-sum]
Tc          818.89;      // K   [origin=predictive method=joback]
Pc          21.081;      // bar [origin=predictive method=joback]
omega       1.4120;      // -   [origin=predictive method=lee-kesler]
Tb          658.08;      // K   [origin=predictive method=joback]
HvapTb      75276.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.88 1.21772 -0.000693 1.507e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecane-1,2-diol" "1,2-dihydroxydodecane" "(s)-1,2-dodecanediol" "lauryl glycol" "k866" );
standardThermochemistry
{
    dHf_298   -600750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     715.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-225920.0
}
