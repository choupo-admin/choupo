/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-2,2-dimethyl-1,3-dioxolane-4-propanol;  (C8H16O3, CAS 51268-87-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s22Dimethyl13Dioxolane4Propanol;
formula     C8H16O3;
CAS         51268-87-2;
InChIKey    BSLDYXOPGSOQGZ-ZETCQYMHSA-N;
MW          160.213;      // g/mol [origin=calculated method=formula-sum]
Tc          729.35;      // K   [origin=predictive method=joback]
Pc          33.802;      // bar [origin=predictive method=joback]
omega       0.8838;      // -   [origin=predictive method=lee-kesler]
Tb          539.57;      // K   [origin=predictive method=joback]
HvapTb      57898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.987 1.18894 -0.0010186 3.857e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group OH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(4s)-2,2-dimethyl-1,3-dioxolan-4-yl]propan-1-ol" "3-((4s)-2,2-dimethyl-1,3-dioxolan-4-yl)propan-1-ol" "1,3-dioxolane-4-propanol,2,2-dimethyl-, (4s)-" );
standardThermochemistry
{
    dHf_298   -569300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-269230.0
}
