/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-cyclohexyl 2,5-dihydropyrrole  (C10H17N, CAS 68109-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nCyclohexyl25Dihydropyrrole;
formula     C10H17N;
CAS         68109-75-1;
InChIKey    MKLOLLWXCNJJKG-UHFFFAOYSA-N;
MW          151.253;      // g/mol [origin=calculated method=formula-sum]
Tc          696.70;      // K   [origin=predictive method=joback]
Pc          32.616;      // bar [origin=predictive method=joback]
omega       0.3811;      // -   [origin=predictive method=lee-kesler]
Tb          475.23;      // K   [origin=predictive method=joback]
HvapTb      41012.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.02 1.3116 -0.00093028 2.566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexyl-2,5-dihydropyrrole" "1-cyclohexyl-2,5-dihydro-1h-pyrrole" "1h-pyrrole, 1-cyclohexyl-2,5-dihydro-" );
standardThermochemistry
{
    dHf_298   16880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=254870.0
}
