/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentylphenylacetic acid  (C13H16O2, CAS 3900-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentylphenylaceticAcid;
formula     C13H16O2;
CAS         3900-93-4;
InChIKey    BCJIDGDYYYBNNB-UHFFFAOYSA-N;
MW          204.269;      // g/mol [origin=calculated method=formula-sum]
Tc          926.06;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.7878;      // -   [origin=predictive method=lee-kesler]
Tb          684.07;      // K   [origin=predictive method=joback]
HvapTb      63841.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.4 1.3483 -0.0009178 2.36e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyclopentyl-2-phenyl-ethanoic acid" "cyclopentyl(phenyl)acetic acid" "2-cyclopentyl-2-phenylacetic acid" "benzeneacetic acid, .alpha.-cyclopentyl-" "alpha-phenylcyclopentaneacetic acid" ".alpha.-phenylcyclopentaneacetic acid" "acetic acid, cyclopentyphenyl-" "acetic acid, cyclopentylphenyl-" "alpha-cyclopentylphenylacetic acid" "alpha-phenylcyclopentylacetic acid" "a-cyclopentylphenylacetic acid" "a-phenylcyclopentaneacetic acid" );
standardThermochemistry
{
    dHf_298   -370190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-138810.0
}
