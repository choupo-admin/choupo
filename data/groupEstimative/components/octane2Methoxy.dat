/*--------------------------------*- Choupo -*-----------------------*\
  Component: octane, 2-methoxy-  (C9H20O, CAS 1541-09-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octane2Methoxy;
formula     C9H20O;
CAS         1541-09-9;
InChIKey    DILJBLUOUOALOF-UHFFFAOYSA-N;
MW          144.258;      // g/mol [origin=calculated method=formula-sum]
Tc          594.45;      // K   [origin=predictive method=joback]
Pc          22.871;      // bar [origin=predictive method=joback]
omega       0.4925;      // -   [origin=predictive method=lee-kesler]
Tb          427.50;      // K   [origin=predictive method=joback]
HvapTb      37650.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.525 0.80156 -0.000358 4.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxyoctane" );
gibbsFormation
{
    dHf_298   -366590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-82540.0
    phase     gas;
}
