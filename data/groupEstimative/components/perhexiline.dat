/*--------------------------------*- Choupo -*-----------------------*\
  Component: perhexiline  (C19H35N, CAS 6621-47-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        perhexiline;
formula     C19H35N;
CAS         6621-47-2;
InChIKey    CYXKNKQEMFBLER-UHFFFAOYSA-N;
MW          277.496;      // g/mol [origin=calculated method=formula-sum]
Tc          987.52;      // K   [origin=predictive method=joback]
Pc          17.448;      // bar [origin=predictive method=joback]
omega       0.6149;      // -   [origin=predictive method=lee-kesler]
Tb          741.08;      // K   [origin=predictive method=joback]
HvapTb      65545.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-195.959 2.1676 -0.0011954 2.103e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 14; } { group CH; count 4; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 14; } { group CH_ring; count 3; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,2-dicyclohexylethyl)piperidine" "perhexilene" "perhexilina" "perhexilinum" "perhexilinum [inn-latin]" "piperidine, 2-(2,2-dicyclohexylethyl)-" "perhexilline" "perhexiline [inn:ban]" "perhexiline (inn)" "(-)-2-(2,2-dicyclohexylethyl)piperidine" "(+)-2-(2,2-dicyclohexylethyl)piperidine" "(1)-2-(2,2-dicyclohexylethyl)piperidine" );
standardThermochemistry
{
    dHf_298   -240000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     788.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=267720.0
}
