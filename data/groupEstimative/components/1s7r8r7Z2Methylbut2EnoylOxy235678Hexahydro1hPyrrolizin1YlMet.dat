/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(1s,7r,8r)-7-[(z)-2-methylbut-2-enoyl]oxy-2,3,5,6,7,8-hexahydro-1h-pyrrolizin-1-yl]methyl (z)-2-(hydroxymethyl)but-2-enoate  (C18H27NO5, CAS 2492-09-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1s7r8r7Z2Methylbut2EnoylOxy235678Hexahydro1hPyrrolizin1YlMet;
formula     C18H27NO5;
CAS         2492-09-3;
InChIKey    YMUQRQKYYOWGPN-SLEGRLQASA-N;
MW          337.416;      // g/mol [origin=calculated method=formula-sum]
Tc          1055.45;      // K   [origin=predictive method=joback]
Pc          16.259;      // bar [origin=predictive method=joback]
omega       1.2773;      // -   [origin=predictive method=lee-kesler]
Tb          853.66;      // K   [origin=predictive method=joback]
HvapTb      88963.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.468 2.06766 -0.00142 3.749e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 3; } { group CH=C; count 2; } { group OH; count 1; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH; count 2; } { group dC; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group OH; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -800150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     802.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-301070.0
}
