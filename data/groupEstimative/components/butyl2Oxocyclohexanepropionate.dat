/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 2-oxocyclohexanepropionate  (C13H22O3, CAS 68134-23-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl2Oxocyclohexanepropionate;
formula     C13H22O3;
CAS         68134-23-6;
InChIKey    AISJENNWEMLKIH-UHFFFAOYSA-N;
MW          226.316;      // g/mol [origin=calculated method=formula-sum]
Tc          849.27;      // K   [origin=predictive method=joback]
Pc          20.272;      // bar [origin=predictive method=joback]
omega       0.7657;      // -   [origin=predictive method=lee-kesler]
Tb          642.63;      // K   [origin=predictive method=joback]
HvapTb      56615.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.695 1.13782 -0.0004258 -1.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 3-(2-oxidanylidenecyclohexyl)propanoate" "butyl 3-(2-oxocyclohexyl)propanoate" "cyclohexanepropanoic acid, 2-oxo-, butyl ester" "3-(2-oxocyclohexyl)propanoic acid, butyl ester" );
gibbsFormation
{
    dHf_298   -712310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     604.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-349930.0
    phase     gas;
}
