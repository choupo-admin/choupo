/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-phenylpentan-2-one  (C11H14O, CAS 2235-83-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Phenylpentan2One;
formula     C11H14O;
CAS         2235-83-8;
InChIKey    DGMYRPFYNFQCHM-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          743.37;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       0.5648;      // -   [origin=predictive method=lee-kesler]
Tb          531.83;      // K   [origin=predictive method=joback]
HvapTb      49102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.657 0.94192 -0.0005871 1.3616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pentanone, 5-phenyl-" "methyl 3-phenylpropyl ketone" "5-phenyl-2-pentanone" );
standardThermochemistry
{
    dHf_298   -146420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25230.0
}
