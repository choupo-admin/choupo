/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)1-methoxy-3-methyl-1-butene  (C6H12O, CAS 31915-76-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e1Methoxy3Methyl1Butene;
formula     C6H12O;
CAS         31915-76-1;
InChIKey    NDACTLNPNAMFLK-SNAWJCMRSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          540.62;      // K   [origin=predictive method=joback]
Pc          32.616;      // bar [origin=predictive method=joback]
omega       0.3137;      // -   [origin=predictive method=lee-kesler]
Tb          363.02;      // K   [origin=predictive method=joback]
HvapTb      30930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.07 0.53656 -0.0002786 5.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-methoxy-3-methyl-but-1-ene" "(e)-1-methoxy-3-methylbut-1-ene" "(e)-1-methoxy-3-methyl-1-butene" "trans-1-methoxy-3-methyl-1-butene" );
standardThermochemistry
{
    dHf_298   -187450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-27580.0
}
