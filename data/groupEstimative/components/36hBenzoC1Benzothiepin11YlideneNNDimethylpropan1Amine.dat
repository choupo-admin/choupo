/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(6h-benzo[c][1]benzothiepin-11-ylidene)-n,n-dimethylpropan-1-amine  (C19H21NS, CAS 113-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36hBenzoC1Benzothiepin11YlideneNNDimethylpropan1Amine;
formula     C19H21NS;
CAS         113-53-1;
InChIKey    PHTUQLWOUWZIMZ-UHFFFAOYSA-N;
MW          295.444;      // g/mol [origin=calculated method=formula-sum]
Tc          1020.59;      // K   [origin=predictive method=joback]
Pc          20.181;      // bar [origin=predictive method=joback]
omega       0.8011;      // -   [origin=predictive method=lee-kesler]
Tb          775.96;      // K   [origin=predictive method=joback]
HvapTb      72628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.548 1.77025 -0.00131352 3.907e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3N; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 5; } { group N; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(6h-benzo[c][1]benzothiepin-11-ylidene)-n,n-dimethyl-propan-1-amine" "dibenzo[b,e]thiepin-d11(6h),g-propylamine, n,n-dimethyl-(7ci,8ci);dibenzo[b,e]thiepin, 1-propanamine deriv.;dosulepin;dosulepine;dothep;dothiepin;iz 914;prothiaden;prothiadene;" );
gibbsFormation
{
    dHf_298   296590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     661.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=579220.0
    phase     gas;
}
