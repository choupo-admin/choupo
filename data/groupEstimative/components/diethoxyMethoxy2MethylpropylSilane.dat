/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethoxy(methoxy)(2-methylpropyl)silane  (C9H22O3Si, CAS 70776-21-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H22O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diethoxyMethoxy2MethylpropylSilane;
formula     C9H22O3Si;
CAS         70776-21-5;
InChIKey    NZDYJVYQVAVJAF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          206.357;      // g/mol [origin=calculated method=formula-sum]
Tc          645.80;      // K   [origin=predictive method=joback]
Pc          19.841;      // bar [origin=predictive method=joback]
omega       0.5376;      // -   [origin=predictive method=lee-kesler]
Tb          473.74;      // K   [origin=predictive method=joback]
HvapTb      42764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (110.343 0.469 0.0002788 -2.862e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group CH3O; count 1; } { group CH2O; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethoxy-methoxy-(2-methylpropyl)silane" "silane, diethoxymethoxy(2-methylpropyl)-" "diethoxymethoxy(2-methylpropyl)silane" );
gibbsFormation
{
    dHf_298   -742650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     657.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-397300.0
    phase     gas;
}
