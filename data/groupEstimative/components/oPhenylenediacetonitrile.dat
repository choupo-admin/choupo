/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-phenylenediacetonitrile  (C10H8N2, CAS 613-73-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oPhenylenediacetonitrile;
formula     C10H8N2;
CAS         613-73-0;
InChIKey    FWPFXBANOKKNBR-UHFFFAOYSA-N;
MW          156.188;      // g/mol [origin=calculated method=formula-sum]
Tc          902.36;      // K   [origin=predictive method=joback]
Pc          27.354;      // bar [origin=predictive method=joback]
omega       0.7313;      // -   [origin=predictive method=lee-kesler]
Tb          664.22;      // K   [origin=predictive method=joback]
HvapTb      61748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.192 0.685 -0.00042236 9.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(cyanomethyl)phenyl]ethanenitrile" "1,2-bis(cyanomethyl)benzene" "o-xylylene dicyanide" "1,2-phenylenediacetonitrile" "o-benzenediacetonitrile" "o-bis(cyanomethyl)benzene" "1,2-benzenediacetonitrile" "2,2'-(1,2-phenylene)diacetonitrile" "2-[2-(cyanomethyl)phenyl]acetonitrile" "o-xylylene cyanide" "o-benzendiacetonitrile" "alpha,alpha'-dicyano-o-xylene" );
standardThermochemistry
{
    dHf_298   305090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=402460.0
}
