/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentanol  (C5H10O, CAS 96-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentanol;
formula     C5H10O;
CAS         96-41-3;
InChIKey    XCIXKGXIYUWCLL-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          610.88;      // K   [origin=predictive method=joback]
Pc          49.177;      // bar [origin=predictive method=joback]
omega       0.6026;      // -   [origin=predictive method=lee-kesler]
Tb          421.46;      // K   [origin=predictive method=joback]
HvapTb      43660.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.85 0.6445 -0.000406 9.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentyl alcohol" "hydroxycyclopentane" "1-cyclopentanol" "mfw" );
standardThermochemistry
{
    dHf_298   -238280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-109050.0
}
