/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-iodophenylacetonitrile  (C8H6IN, CAS 40400-15-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Iodophenylacetonitrile;
formula     C8H6IN;
CAS         40400-15-5;
InChIKey    FPSGTRJUQLYLHE-UHFFFAOYSA-N;
MW          243.043;      // g/mol [origin=calculated method=formula-sum]
Tc          874.20;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.5037;      // -   [origin=predictive method=lee-kesler]
Tb          609.52;      // K   [origin=predictive method=joback]
HvapTb      56191.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.701 0.5992 -0.00042596 1.182e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2CN; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-iodanylphenyl)ethanenitrile" "2-iodobenzyl cyanide" "2-(2-iodophenyl)acetonitrile" "o-iodophenylacetonitrile" "o-iodobenzyl cyanide" "2-(2-iodophenyl)ethanenitrile" "acetonitrile,(o-iodophenyl)- (6ci,7ci); 2-(iodophenyl)acetonitrile;2-iodobenzeneacetonitrile; 2-iodobenzyl cyanide" );
gibbsFormation
{
    dHf_298   258360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=310560.0
    phase     gas;
}
