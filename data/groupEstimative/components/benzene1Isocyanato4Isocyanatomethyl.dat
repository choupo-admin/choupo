/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-isocyanato-4-(isocyanatomethyl)-  (C9H6N2O2, CAS 99741-73-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1Isocyanato4Isocyanatomethyl;
formula     C9H6N2O2;
CAS         99741-73-8;
InChIKey    XEOANEVNYYOZOX-UHFFFAOYSA-N;
MW          174.159;      // g/mol [origin=calculated method=formula-sum]
Tc          796.74;      // K   [origin=predictive method=joback]
Pc          38.198;      // bar [origin=predictive method=joback]
omega       0.7131;      // -   [origin=predictive method=lee-kesler]
Tb          570.52;      // K   [origin=predictive method=joback]
HvapTb      57630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 1; } { group dCd; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-4-(isocyanatomethyl)benzene" "tolylene-alpha,4-diisocyanate" "1-isocyanato-4-(isocyanatomethyl)-benzene" );
