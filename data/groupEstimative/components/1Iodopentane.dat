/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodopentane  (C5H11I, CAS 628-17-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodopentane;
formula     C5H11I;
CAS         628-17-1;
InChIKey    BLXSFCHWMBESKV-UHFFFAOYSA-N;
MW          198.043;      // g/mol [origin=calculated method=formula-sum]
Tc          609.66;      // K   [origin=predictive method=joback]
Pc          33.802;      // bar [origin=predictive method=joback]
omega       0.3045;      // -   [origin=predictive method=lee-kesler]
Tb          407.14;      // K   [origin=predictive method=joback]
HvapTb      36097.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.034 0.51782 -0.0003296 8.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanylpentane" "n-amyl iodide" "amyl iodide" "pentane, 1-iodo-" "pentyl iodide" "n-pentyl iodide" "1-pentyl iodide" "iodopentane" "1-jodpentan" "pentane, iodo-" "agn-pc-00cuwz" "blxsfchwmbeskv-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -69660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49340.0
}
