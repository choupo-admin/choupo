    dHf_298   -735050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     936.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-344550.0
    phase     gas;
}
