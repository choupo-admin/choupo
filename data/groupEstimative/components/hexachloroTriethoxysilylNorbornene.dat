name        hexachloroTriethoxysilylNorbornene;
formula     C13H18Cl6O3Si;
CAS         18052-83-0;
InChIKey    AMPGOMIFIUKMJG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          463.069;      // g/mol [origin=calculated method=formula-sum]
Tc          1044.50;      // K   [origin=predictive method=joback]
Pc          16.013;      // bar [origin=predictive method=joback]
omega       0.8011;      // -   [origin=predictive method=lee-kesler]
Tb          808.53;      // K   [origin=predictive method=joback]
HvapTb      75909.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.587 1.82376 -0.0017922 7.766e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2O; count 3; } { group CCl2; count 1; } { group Cl_C=C_; count 2; } { group C=C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 3; } { group dC_ring; count 2; } { group Cl; count 6; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethoxy-[1,2,3,4,7,7-hexakis(chloranyl)-5-bicyclo[2.2.1]hept-2-enyl]silane" "triethoxy(1,4,5,6,7,7-hexachloro-5-norbornen-2-yl)silane" "silane, triethoxy(1,4,5,6,7,7-hexachlorobicyclo[2.2.1]hept-5-en-2-yl)-" "silane, triethoxy(1,4,5,6,7,7-hexachlorobicyclo(2.2.1)hept-5-en-2-yl)-" "silane,triethoxy(1,4,5,6,7,7-hexachloro-5-norbornen-2-yl)- (8ci)" "silane,triethoxy(1,4,5,6,7,7-hexachlorobicyclo[2.2.1]hept-5-en-2-yl)-" "triethoxy(1,4,5,6,7,7-hexachlorobicyclo[2.2.1]hept-5-en-2-yl)silane" "triethoxy-(1,2,3,4,7,7-hexachloro-5-bicyclo[2.2.1]hept-2-enyl)silane" );
