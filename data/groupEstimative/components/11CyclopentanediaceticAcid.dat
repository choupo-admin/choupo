/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-cyclopentanediacetic acid  (C9H14O4, CAS 16713-66-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11CyclopentanediaceticAcid;
formula     C9H14O4;
CAS         16713-66-9;
InChIKey    FWPVKDFOUXHOKQ-UHFFFAOYSA-N;
MW          186.207;      // g/mol [origin=calculated method=formula-sum]
Tc          939.27;      // K   [origin=predictive method=joback]
Pc          35.473;      // bar [origin=predictive method=joback]
omega       1.1242;      // -   [origin=predictive method=lee-kesler]
Tb          712.06;      // K   [origin=predictive method=joback]
HvapTb      69062.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.568 1.384 -0.001271 4.894e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1-(2-hydroxy-2-oxoethyl)cyclopentyl]ethanoic acid" "3,3-tetramethyleneglutaric acid" "tetramethyleneglutaric acid" "tetramethylene glutaric acid" "1,1-cyclopentanediaceticacid" "cyclopentane-1,1-diacetic acid" "3,3'-tetramethylene glutaric acid" "beta,beta-tetramethyleneglutaric acid" ".beta.,.beta.-tetramethyleneglutaric acid" "[1-(carboxymethyl)cyclopentyl]acetic acid" "2-[(carboxymethyl)cyclopentyl]acetic acid" "2,2'-(cyclopentane-1,1-diyl)diacetic acid" );
gibbsFormation
{
    dHf_298   -853910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     631.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-631860.0
    phase     gas;
}
