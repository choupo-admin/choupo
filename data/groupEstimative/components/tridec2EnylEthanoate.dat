/*--------------------------------*- Choupo -*-----------------------*\
  Component: tridec-2-enyl ethanoate  (C15H28O2, CAS 68480-26-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tridec2EnylEthanoate;
formula     C15H28O2;
CAS         68480-26-2;
InChIKey    UEGGJCHDRZTQMF-UHFFFAOYSA-N;
MW          240.387;      // g/mol [origin=calculated method=formula-sum]
Tc          775.70;      // K   [origin=predictive method=joback]
Pc          14.782;      // bar [origin=predictive method=joback]
omega       0.8145;      // -   [origin=predictive method=lee-kesler]
Tb          605.18;      // K   [origin=predictive method=joback]
HvapTb      56349.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.48 1.39404 -0.0007814 1.576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH=CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tridecen-1-ol, acetate" "2-tridecen-1-ol, 1-acetate" "trans-2-tridecenyl acetate" "2-tridecen-1-ol,1-acetate" "(2e)-tridec-2-en-1-yl acetate;" );
standardThermochemistry
{
    dHf_298   -552990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     784.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154730.0
}
