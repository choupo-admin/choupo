/*--------------------------------*- Choupo -*-----------------------*\
  Component: buclosamide  (C11H14ClNO2, CAS 575-74-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        buclosamide;
formula     C11H14ClNO2;
CAS         575-74-6;
InChIKey    ZGJHIFYEQJEUKA-UHFFFAOYSA-N;
MW          227.688;      // g/mol [origin=calculated method=formula-sum]
Tc          929.94;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       1.0600;      // -   [origin=predictive method=lee-kesler]
Tb          705.03;      // K   [origin=predictive method=joback]
HvapTb      73599.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.597 1.12002 -0.00084542 2.6386e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 1; } { group ACCl; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH_phenol; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-butyl-4-chloranyl-2-oxidanyl-benzamide" "n-butyl-4-chloro-2-hydroxybenzamide" "n-butyl-4-chlorosalicylamide" "buclosamida" "buclosamidum" "buclosamidum [inn-latin]" "n-butyl-4-chlorsalicylamide" "buclosamide [inn:ban:dcf]" "n-butyl-4-chlor-2-hydroxybenzamid" "benzamide, n-butyl-4-chloro-2-hydroxy-" "u488" );
standardThermochemistry
{
    dHf_298   -297470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-61560.0
}
