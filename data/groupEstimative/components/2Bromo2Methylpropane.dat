/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-2-methylpropane  (C4H9Br, CAS 507-19-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo2Methylpropane;
formula     C4H9Br;
CAS         507-19-7;
InChIKey    RKSOPLXZQNSWAS-UHFFFAOYSA-N;
MW          137.02;      // g/mol [origin=calculated method=formula-sum]
Tc          553.00;      // K   [origin=predictive method=joback]
Pc          43.626;      // bar [origin=predictive method=joback]
omega       0.2346;      // -   [origin=predictive method=lee-kesler]
Tb          354.05;      // K   [origin=predictive method=joback]
HvapTb      29637.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.03 0.54786 -0.000437 1.424e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-2-methyl-propane" "tert-butyl bromide" "trimethylbromomethane" "propane, 2-bromo-2-methyl-" "t-butyl bromide" "bromotrimethylmethane" "2-bromoisobutane" "tertiarybutyl bromide" "2-methyl-2-bromopropane" "1,1-dimethylethyl chloride" "1-bromo-1,1-dimethylethane" "sjphabimup@" );
gibbsFormation
{
    dHf_298   -108310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40.0
    phase     gas;
}
