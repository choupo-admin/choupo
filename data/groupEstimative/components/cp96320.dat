/*--------------------------------*- Choupo -*-----------------------*\
  Component: cp 96320  (C8H12O4, CAS 83145-58-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cp96320;
formula     C8H12O4;
CAS         83145-58-8;
InChIKey    OGLBQMIRAQXHHD-UHFFFAOYSA-N;
MW          172.18;      // g/mol [origin=calculated method=formula-sum]
Tc          779.16;      // K   [origin=predictive method=joback]
Pc          29.473;      // bar [origin=predictive method=joback]
omega       0.8922;      // -   [origin=predictive method=lee-kesler]
Tb          582.61;      // K   [origin=predictive method=joback]
HvapTb      56915.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.952 0.74572 -0.0004155 7.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH3COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-acetyloxyhex-5-enoic acid" "5(or 4)-hexenoic acid, 4(or 6)-(acetyloxy)-" "5-hexenoic acid, 4-(acetyloxy)-" );
gibbsFormation
{
    dHf_298   -755850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-552400.0
    phase     gas;
}
