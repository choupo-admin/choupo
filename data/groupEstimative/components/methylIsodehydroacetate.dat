/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl isodehydroacetate  (C9H10O4, CAS 41264-06-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylIsodehydroacetate;
formula     C9H10O4;
CAS         41264-06-6;
InChIKey    VLYBFLKIZIACQH-UHFFFAOYSA-N;
MW          182.175;      // g/mol [origin=calculated method=formula-sum]
Tc          753.61;      // K   [origin=predictive method=joback]
Pc          28.999;      // bar [origin=predictive method=joback]
omega       0.7139;      // -   [origin=predictive method=lee-kesler]
Tb          550.90;      // K   [origin=predictive method=joback]
HvapTb      53406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.68 0.62656 -0.00027924 1.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH=C; count 1; } { group C=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,4-dimethyl-6-oxidanylidene-pyran-3-carboxylate" "methylisodehydroacetate" "methyl 4,6-dimethyl-2-oxo-2h-pyran-5-carboxylate" "2h-pyran-5-carboxylic acid, 4,6-dimethyl-2-oxo-, methyl ester" "methyl isodehydracetate" "methyl isodehydrocetate" "methyl 2,4-dimethyl-6-oxopyran-3-carboxylate" "methyl 4,6-dimethyl-2-oxopyran-5-carboxylate" "2,4-dimethyl-6-oxo-3-pyrancarboxylic acid methyl ester" );
gibbsFormation
{
    dHf_298   -695520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-508450.0
    phase     gas;
}
