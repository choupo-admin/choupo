/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9h-fluoren-9-amine  (C13H11N, CAS 525-03-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9hFluoren9Amine;
formula     C13H11N;
CAS         525-03-1;
InChIKey    OUGMRQJTULXVDC-UHFFFAOYSA-N;
MW          181.238;      // g/mol [origin=calculated method=formula-sum]
Tc          885.93;      // K   [origin=predictive method=joback]
Pc          34.725;      // bar [origin=predictive method=joback]
omega       0.6354;      // -   [origin=predictive method=lee-kesler]
Tb          631.09;      // K   [origin=predictive method=joback]
HvapTb      60618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.65 1.194 -0.00096812 3.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-aminofluorene" "fluoren-9-amine" "fluoren-9-ylamine" "fluorene-9-ylamine" "9h-fluoren-9-yl-amine" "l894" );
gibbsFormation
{
    dHf_298   257380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=415540.0
    phase     gas;
}
