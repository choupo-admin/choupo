/*--------------------------------*- Choupo -*-----------------------*\
  Component: 16-chlorohexadeca-5,9-diyne  (C16H25Cl, CAS 58444-07-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Chlorohexadeca59Diyne;
formula     C16H25Cl;
CAS         58444-07-8;
InChIKey    KALOSERCJZNJMW-UHFFFAOYSA-N;
MW          252.826;      // g/mol [origin=calculated method=formula-sum]
Tc          819.14;      // K   [origin=predictive method=joback]
Pc          16.378;      // bar [origin=predictive method=joback]
omega       0.6508;      // -   [origin=predictive method=lee-kesler]
Tb          621.11;      // K   [origin=predictive method=joback]
HvapTb      59899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.351 1.23102 -0.00068272 1.4616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH2Cl; count 1; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group tC; count 4; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "16-chloranylhexadeca-5,9-diyne" "5,9-hexadecadiyne, 16-chloro-" "16-chloro-5,9-hexadecadiyne" );
standardThermochemistry
{
    dHf_298   155290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     756.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=477510.0
}
