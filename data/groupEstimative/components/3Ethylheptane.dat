/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethylheptane  (C9H20, CAS 15869-80-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethylheptane;
formula     C9H20;
CAS         15869-80-4;
InChIKey    PSVQKOKKLWHNRP-UHFFFAOYSA-N;
MW          128.259;      // g/mol [origin=calculated method=formula-sum]
Tc          571.85;      // K   [origin=predictive method=joback]
Pc          23.248;      // bar [origin=predictive method=joback]
omega       0.4191;      // -   [origin=predictive method=lee-kesler]
Tb          405.08;      // K   [origin=predictive method=joback]
HvapTb      35240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.975 0.86476 -0.000469 9.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptane, 3-ethyl-" "3-ethylhepane" "3-ethyl heptane" "3-ethyl-heptane" );
standardThermochemistry
{
    dHf_298   -234370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22460.0
}
