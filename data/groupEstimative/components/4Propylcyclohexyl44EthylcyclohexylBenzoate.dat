/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-propylcyclohexyl 4-(4-ethylcyclohexyl)benzoate  (C24H36O2, CAS 72928-03-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Propylcyclohexyl44EthylcyclohexylBenzoate;
formula     C24H36O2;
CAS         72928-03-1;
InChIKey    HDTDVUVMQFJBQI-UHFFFAOYSA-N;
MW          356.55;      // g/mol [origin=calculated method=formula-sum]
Tc          1097.20;      // K   [origin=predictive method=joback]
Pc          12.251;      // bar [origin=predictive method=joback]
omega       0.8079;      // -   [origin=predictive method=lee-kesler]
Tb          868.36;      // K   [origin=predictive method=joback]
HvapTb      79603.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.457 2.28184 -0.00120256 1.807e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-propylcyclohexyl) 4-(4-ethylcyclohexyl)benzoate" "benzoic acid, 4-(trans-4-ethylcyclohexyl)-, trans-4-propylcyclohexyl ester" "trans-4-(4-ethylcyclohexyl)benzoic acid, trans-4-propylcyclohexyl ester" "(trans(trans))-4-propylcyclohexyl 4-(4-ethylcyclohexyl)benzoate" );
standardThermochemistry
{
    dHf_298   -562950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     883.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-22910.0
}
