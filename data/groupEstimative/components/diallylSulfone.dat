/*--------------------------------*- Choupo -*-----------------------*\
  Component: diallyl sulfone  (C6H10O2S, CAS 16841-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H10O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diallylSulfone;
formula     C6H10O2S;
CAS         16841-48-8;
InChIKey    NZEDMAWEJPYWCD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          146.204;      // g/mol [origin=calculated method=formula-sum]
Tc          453.70;      // K   [origin=predictive method=joback]
Pc          38.868;      // bar [origin=predictive method=joback]
omega       0.4463;      // -   [origin=predictive method=lee-kesler]
Tb          309.24;      // K   [origin=predictive method=joback]
HvapTb      39428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.092 0.573 -0.000323 5.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-prop-2-enylsulfonylprop-1-ene" "allyl sulfone" "1-propene, 3,3'-sulfonylbis-" "diallylsulfone" "3-(allylsulfonyl)-1-propene" "3,3'-sulfonylbis(prop-1-ene)" "1-propene,3-(2-propen-1-ylsulfonyl)-" );
standardThermochemistry
{
    dHf_298   -411530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-326340.0
}
