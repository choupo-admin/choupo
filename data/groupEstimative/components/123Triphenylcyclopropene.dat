/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-triphenylcyclopropene  (C21H16, CAS 16510-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Triphenylcyclopropene;
formula     C21H16;
CAS         16510-49-9;
InChIKey    UFTDGVXRVMJEDI-UHFFFAOYSA-N;
MW          268.359;      // g/mol [origin=calculated method=formula-sum]
Tc          1047.57;      // K   [origin=predictive method=joback]
Pc          22.568;      // bar [origin=predictive method=joback]
omega       0.6708;      // -   [origin=predictive method=lee-kesler]
Tb          775.98;      // K   [origin=predictive method=joback]
HvapTb      70697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.78 1.738 -0.0012856 3.689e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 15; } { group AC; count 2; } { group ACCH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,3-diphenylcyclopropen-1-yl)benzene" "1,1',1''-cycloprop-1-ene-1,2,3-triyltribenzene" "(2,3-diphenyl-1-cyclopropenyl)-benzene" "benzene,(2,3-diphenyl-1-cyclopropen-1-yl)-" "1,1',1''-(1-cyclopropene-1,2,3-triyl)trisbenzene" );
gibbsFormation
{
    dHf_298   340460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=534620.0
    phase     gas;
}
