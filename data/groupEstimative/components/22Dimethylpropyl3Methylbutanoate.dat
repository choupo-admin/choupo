/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethylpropyl 3-methylbutanoate  (C10H20O2, CAS 5340-68-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethylpropyl3Methylbutanoate;
formula     C10H20O2;
CAS         5340-68-1;
InChIKey    KJHHLUGEJAXBEI-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          666.14;      // K   [origin=predictive method=joback]
Pc          21.714;      // bar [origin=predictive method=joback]
omega       0.5134;      // -   [origin=predictive method=lee-kesler]
Tb          482.95;      // K   [origin=predictive method=joback]
HvapTb      43577.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.948 1.0308 -0.0006006 1.221e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbutanoic acid, neopentyl ester" "butanoic acid,3-methyl-, 2,2-dimethylpropyl ester" );
gibbsFormation
{
    dHf_298   -581040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-276650.0
    phase     gas;
}
