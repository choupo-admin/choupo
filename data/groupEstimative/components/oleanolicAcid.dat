/*--------------------------------*- Choupo -*-----------------------*\
  Component: oleanolic acid  (C30H48O3, CAS 508-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oleanolicAcid;
formula     C30H48O3;
CAS         508-02-1;
InChIKey    MIJYXULNPSFWEK-GTOFXWBISA-N;
MW          456.711;      // g/mol [origin=calculated method=formula-sum]
Tc          1433.85;      // K   [origin=predictive method=joback]
Pc          11.367;      // bar [origin=predictive method=joback]
omega       1.0676;      // -   [origin=predictive method=lee-kesler]
Tb          1169.51;      // K   [origin=predictive method=joback]
HvapTb      109489.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-549.72 5.12944 -0.00532624 2.2971e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 10; } { group CH; count 4; } { group C; count 6; } { group CH=C; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2_ring; count 10; } { group CH_ring; count 4; } { group C_ring; count 6; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4as,6ar,6as,6br,8ar,10s,12ar,14bs)-2,2,6a,6b,9,9,12a-heptamethyl-10-oxidanyl-1,3,4,5,6,6a,7,8,8a,10,11,12,13,14b-tetradecahydropicene-4a-carboxylic acid" "oleanic acid" "caryophyllin" "astrantiagenin c" "giganteumgenin c" "virgaureagenin b" "3beta-hydroxyolean-12-en-28-oic acid" "oleanolic_acid" "3-beta-hydroxyolean-12-en-28-oic acid" "(3-beta)-3-hydroxyolean-12-en-28-oic acid" "olean-12-en-28-oic acid, 3-hydroxy-, (3beta)-" "olean-12-en-28-oic acid, 3-hydroxy-, (3-beta)-" );
gibbsFormation
{
    dHf_298   -808100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1278.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-111120.0
    phase     gas;
}
