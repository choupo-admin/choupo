/*--------------------------------*- Choupo -*-----------------------*\
  Component: propargyldipropylamine  (C9H17N, CAS 6323-79-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propargyldipropylamine;
formula     C9H17N;
CAS         6323-79-1;
InChIKey    ATTMKPWGJILFFV-UHFFFAOYSA-N;
MW          139.242;      // g/mol [origin=calculated method=formula-sum]
Tc          580.96;      // K   [origin=predictive method=joback]
Pc          26.680;      // bar [origin=predictive method=joback]
omega       0.4379;      // -   [origin=predictive method=lee-kesler]
Tb          408.08;      // K   [origin=predictive method=joback]
HvapTb      37529.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.205 0.88884 -0.00057433 1.5169e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2N; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group tCH; count 1; } { group tC; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-propyl-n-prop-2-ynyl-propan-1-amine" "3-di-n-propylamino-1-propyne" "n,n-dipropyl-2-propyn-1-amine" "3-dipropylamino-1-propyne" "prop-2-ynyldipropylamine" "n-propyl-n-prop-2-ynylpropan-1-amine" );
standardThermochemistry
{
    dHf_298   130340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=358750.0
}
