/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylethyl heptanoate  (C15H22O2, CAS 5454-11-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylethylHeptanoate;
formula     C15H22O2;
CAS         5454-11-5;
InChIKey    YMPDQHXHLKFWNN-UHFFFAOYSA-N;
MW          234.339;      // g/mol [origin=calculated method=formula-sum]
Tc          823.04;      // K   [origin=predictive method=joback]
Pc          18.547;      // bar [origin=predictive method=joback]
omega       0.7732;      // -   [origin=predictive method=lee-kesler]
Tb          627.70;      // K   [origin=predictive method=joback]
HvapTb      58667.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.243 1.29512 -0.0007288 1.357e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylethyl heptanoate" "heptanoic acid, 2-phenylethyl ester" "phenylethyl heptylate" "phenethyl heptanoate" "heptanoic acid,2-phenylethyl ester" );
standardThermochemistry
{
    dHf_298   -433680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     685.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122540.0
}
