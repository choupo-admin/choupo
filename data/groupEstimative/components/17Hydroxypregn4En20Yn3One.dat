/*--------------------------------*- Choupo -*-----------------------*\
  Component: 17-hydroxypregn-4-en-20-yn-3-one  (C21H28O2, CAS 434-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17Hydroxypregn4En20Yn3One;
formula     C21H28O2;
CAS         434-03-7;
InChIKey    CHNXZKVNWQUJIB-UHFFFAOYSA-N;
MW          312.453;      // g/mol [origin=calculated method=formula-sum]
Tc          1122.53;      // K   [origin=predictive method=joback]
Pc          20.218;      // bar [origin=predictive method=joback]
omega       1.0162;      // -   [origin=predictive method=lee-kesler]
Tb          874.03;      // K   [origin=predictive method=joback]
HvapTb      80519.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-303.29 3.03344 -0.00295697 1.21849e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 3; } { group C; count 3; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 3; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "17-ethynyl-10,13-dimethyl-17-oxidanyl-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthren-3-one" "aethisteron" "nugestoral" "pregneninolone" "progestoral" "syngestrotabs" "colutoid" "ethinone" "gestoral" "nalutoral" "pregnin" "prodoxan" );
gibbsFormation
{
    dHf_298   -163050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     734.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=260540.0
    phase     gas;
}
