/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylazepane  (C12H17N, CAS 40832-99-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenylazepane;
formula     C12H17N;
CAS         40832-99-3;
InChIKey    YMDZJGQBSPNMEF-UHFFFAOYSA-N;
MW          175.275;      // g/mol [origin=calculated method=formula-sum]
Tc          774.39;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       0.4394;      // -   [origin=predictive method=lee-kesler]
Tb          537.50;      // K   [origin=predictive method=joback]
HvapTb      47363.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-124.16 1.3374 -0.0009092 2.323e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-h-azepine, hexahydro-1-phenyl" );
standardThermochemistry
{
    dHf_298   87710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=305510.0
}
