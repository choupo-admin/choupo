/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-butoxyphenylacetonitrile  (C12H15NO, CAS 38746-93-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Butoxyphenylacetonitrile;
formula     C12H15NO;
CAS         38746-93-9;
InChIKey    SKTHXBXIQFAXPC-UHFFFAOYSA-N;
MW          189.258;      // g/mol [origin=calculated method=formula-sum]
Tc          844.28;      // K   [origin=predictive method=joback]
Pc          22.762;      // bar [origin=predictive method=joback]
omega       0.7318;      // -   [origin=predictive method=lee-kesler]
Tb          630.32;      // K   [origin=predictive method=joback]
HvapTb      58132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.874 0.87702 -0.00045116 7.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-butoxyphenyl)ethanenitrile" "2-(4-butoxyphenyl)acetonitrile" "4-n-butoxyphenylacetonitrile" "(4-butoxyphenyl)acetonitrile" );
gibbsFormation
{
    dHf_298   -33290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=181120.0
    phase     gas;
}
