/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dibutylnonane  (C17H36, CAS 6008-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dibutylnonane;
formula     C17H36;
CAS         6008-17-9;
InChIKey    WAEWWNSCMZXJML-UHFFFAOYSA-N;
MW          240.475;      // g/mol [origin=calculated method=formula-sum]
Tc          750.70;      // K   [origin=predictive method=joback]
Pc          12.477;      // bar [origin=predictive method=joback]
omega       0.6897;      // -   [origin=predictive method=lee-kesler]
Tb          585.33;      // K   [origin=predictive method=joback]
HvapTb      52140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.038 1.74468 -0.0010728 2.63e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dibutylnonane;nonane,5,5-dibutyl" );
standardThermochemistry
{
    dHf_298   -402960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     779.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95100.0
}
