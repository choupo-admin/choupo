/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9h-fluorene, 4-methyl-  (C14H12, CAS 1556-99-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9hFluorene4Methyl;
formula     C14H12;
CAS         1556-99-6;
InChIKey    OPFILOLCFWFBNT-UHFFFAOYSA-N;
MW          180.25;      // g/mol [origin=calculated method=formula-sum]
Tc          834.59;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       0.5312;      // -   [origin=predictive method=lee-kesler]
Tb          591.09;      // K   [origin=predictive method=joback]
HvapTb      53174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.69 1.19412 -0.00096748 3.19e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group ACCH3; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-9h-fluorene" "4-methylfluorene" "fluorene, 4-methyl-" "fluorene,4-methyl- (6ci,7ci,8ci); 4-methyl-9h-fluorene; 4-methylfluorene" );
gibbsFormation
{
    dHf_298   211820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=355590.0
    phase     gas;
}
