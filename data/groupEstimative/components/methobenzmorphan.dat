/*--------------------------------*- Choupo -*-----------------------*\
  Component: methobenzmorphan  (C15H21NO, CAS 3734-52-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methobenzmorphan;
formula     C15H21NO;
CAS         3734-52-9;
InChIKey    YGSVZRIZCHZUHB-UHFFFAOYSA-N;
MW          231.339;      // g/mol [origin=calculated method=formula-sum]
Tc          911.61;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       0.7849;      // -   [origin=predictive method=lee-kesler]
Tb          676.57;      // K   [origin=predictive method=joback]
HvapTb      65345.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-194.5 2.13616 -0.00204292 8.068e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "metazocine" "2,6-methano-3-benzazocin-8-ol, 1,2,3,4,5,6-hexahydro-3,6,11-trimethyl-" "metazocina" "metazocinum" "metazocina [dcit]" "metazocinum [latin]" "metazocinum [inn-latin]" "agn-pc-03g30n" "3,6,11-trimethyl-1,2,3,4,5,6-hexahydro-2,6-methano-3-benzazocin-8-ol" "(2s,6s)-3,6,11-trimethyl-1,2,3,4,5,6-hexahydro-2,6-methano-3-benzazocin-8-ol" "1,2,3,4,5,6-hexahydro-8-hydroxy-3,6,11-trimethyl-2,6-methano-3-benzazocine" );
gibbsFormation
{
    dHf_298   -97150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=242660.0
    phase     gas;
}
