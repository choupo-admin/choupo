/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(decylamino)ethanethiol  (C12H27NS, CAS 5891-06-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DecylaminoEthanethiol;
formula     C12H27NS;
CAS         5891-06-5;
InChIKey    WOWHRXFAFVDNAP-UHFFFAOYSA-N;
MW          217.415;      // g/mol [origin=calculated method=formula-sum]
Tc          767.70;      // K   [origin=predictive method=joback]
Pc          19.019;      // bar [origin=predictive method=joback]
omega       0.8130;      // -   [origin=predictive method=lee-kesler]
Tb          587.19;      // K   [origin=predictive method=joback]
HvapTb      55479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.661 1.24732 -0.0007 1.477e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH2NH; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group NH; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanethiol, 2-(decylamino)-" "n-(n-decyl)aminoethanethiol" "2-(n-decylamino)ethanethiol" "2-(n-decylamino)-ethanethiol" );
gibbsFormation
{
    dHf_298   -199060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     726.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=168940.0
    phase     gas;
}
