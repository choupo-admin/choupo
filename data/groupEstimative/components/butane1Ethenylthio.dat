/*--------------------------------*- Choupo -*-----------------------*\
  Component: butane, 1-(ethenylthio)-  (C6H12S, CAS 4789-70-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butane1Ethenylthio;
formula     C6H12S;
CAS         4789-70-2;
InChIKey    LBMGSGLAWRZARD-UHFFFAOYSA-N;
MW          116.222;      // g/mol [origin=calculated method=formula-sum]
Tc          595.41;      // K   [origin=predictive method=joback]
Pc          33.220;      // bar [origin=predictive method=joback]
omega       0.3468;      // -   [origin=predictive method=lee-kesler]
Tb          402.34;      // K   [origin=predictive method=joback]
HvapTb      35097.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.043 0.54821 -0.0002853 5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenylsulfanylbutane" "1-(butylsulfanyl)ethylene" "1-(ethenylsulfanyl)butane" );
gibbsFormation
{
    dHf_298   130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120600.0
    phase     gas;
}
