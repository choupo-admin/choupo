/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(3-tridecoxypropyl)-1,3-propanediamine mono-n-lauroylsarcosinate  (C34H71N3O4, CAS 70776-14-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3Tridecoxypropyl13PropanediamineMonoNLauroylsarcosinate;
formula     C34H71N3O4;
CAS         70776-14-6;
InChIKey    LZUSKSPGLBOIOA-UHFFFAOYSA-N;
MW          585.959;      // g/mol [origin=calculated method=formula-sum]
Tc          1857.55;      // K   [origin=predictive method=joback]
Pc          5.244;      // bar [origin=predictive method=joback]
omega       -0.2223;      // -   [origin=predictive method=lee-kesler]
Tb          1335.86;      // K   [origin=predictive method=joback]
HvapTb      137012.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.849 3.24926 -0.0015585 1.9926e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 25; } { group CH2O; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } { group CONCH3CH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 29; } { group O; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[dodecanoyl(methyl)amino]ethanoic acid;n'-(3-tridecoxypropyl)propane-1,3-diamine" "glycine, n-methyl-n-(1-oxododecyl)-, compd. with n-(3-(tridecyloxy)propyl)-1,3-propanediamine (1:1)" "glycine, n-methyl-n-(1-oxododecyl)-, compd. with n1-(3-(tridecyloxy)propyl)-1,3-propanediamine (1:1)" );
standardThermochemistry
{
    dHf_298   -1296990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1787.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180570.0
}
