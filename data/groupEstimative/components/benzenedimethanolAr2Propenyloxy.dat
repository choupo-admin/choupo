/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenedimethanol, ar-(2-propenyloxy)-  (C11H14O3, CAS 28655-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenedimethanolAr2Propenyloxy;
formula     C11H14O3;
CAS         28655-63-2;
InChIKey    PBVPXGDABWOZGU-UHFFFAOYSA-N;
MW          194.23;      // g/mol [origin=calculated method=formula-sum]
Tc          896.18;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       0.9951;      // -   [origin=predictive method=lee-kesler]
Tb          668.26;      // K   [origin=predictive method=joback]
HvapTb      71448.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.749 1.07694 -0.00089634 3.242e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 1; } { group AC; count 1; } { group ACCH3; count 2; } { group ACOH; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group OH_phenol; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dimethyl-4-prop-2-enoxy-benzene-1,3-diol" "benzenedimethanol, ar-(2-propen-1-yloxy)-" "2,5-dimethyl-4-(prop-2-en-1-yloxy)benzene-1,3-diol" "allyloxy bis(hydroxymethyl)benzene" "ar-(allyloxy)xylene-alpha,alpha'-diol" "xylene-alpha,alpha'-diol, ar-(allyloxy)-" "2,5-dimethyl-4-prop-2-enoxybenzene-1,3-diol" );
standardThermochemistry
{
    dHf_298   -418190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-191510.0
}
