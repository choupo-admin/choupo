/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-[1,3-dimethyl-2-[(2-oxochromen-7-yl)oxymethyl]-6-prop-1-en-2-ylcyclohex-3-en-1-yl]propanoic acid  (C24H28O5, CAS 21800-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        313Dimethyl22Oxochromen7YlOxymethyl6Prop1En2Ylcyclohex3En1Yl;
formula     C24H28O5;
CAS         21800-49-7;
InChIKey    DRASTJFRZGDAQT-UHFFFAOYSA-N;
MW          396.483;      // g/mol [origin=calculated method=formula-sum]
Tc          1267.67;      // K   [origin=predictive method=joback]
Pc          13.536;      // bar [origin=predictive method=joback]
omega       1.1633;      // -   [origin=predictive method=lee-kesler]
Tb          1028.96;      // K   [origin=predictive method=joback]
HvapTb      98965.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.327 2.37516 -0.00180344 5.775e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH2O; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group O; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[1,3-dimethyl-2-[(2-oxidanylidenechromen-7-yl)oxymethyl]-6-prop-1-en-2-yl-cyclohex-3-en-1-yl]propanoic acid" "3-[(1s,2s,6s)-6-isopropenyl-1,3-dimethyl-2-(2-oxo-2h-chromen-7-yloxymethyl)-cyclohex-3-enyl]-propionic acid" );
gibbsFormation
{
    dHf_298   -776960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     884.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-301250.0
    phase     gas;
}
