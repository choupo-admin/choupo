/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclopropylhexane  (C9H18, CAS 6976-28-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclopropylhexane;
formula     C9H18;
CAS         6976-28-9;
InChIKey    IYZQDBIQGSJSEX-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          592.54;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.3823;      // -   [origin=predictive method=lee-kesler]
Tb          411.82;      // K   [origin=predictive method=joback]
HvapTb      35153.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.217 1.01564 -0.0006892 1.947e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexan-2-ylcyclopropane" "1-methylpentyl cyclopropane" "(1-methylpentyl)cyclopropane" "cyclopropane,(1-methylpentyl)-" );
standardThermochemistry
{
    dHf_298   -161570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83210.0
}
