/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-methylethylidene)cyclopentane  (C8H14, CAS 765-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1MethylethylideneCyclopentane;
formula     C8H14;
CAS         765-83-3;
InChIKey    RIYRLXGSAJWZRO-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          614.25;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.2860;      // -   [origin=predictive method=lee-kesler]
Tb          409.11;      // K   [origin=predictive method=joback]
HvapTb      34835.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.4 0.84444 -0.000565 1.544e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH2_ring; count 4; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-ylidenecyclopentane" "cyclopentane, (1-methylethylidene)-" "isopropylidenecyclopentane" );
gibbsFormation
{
    dHf_298   -61390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97650.0
    phase     gas;
}
