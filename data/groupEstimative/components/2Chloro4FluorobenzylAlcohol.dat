/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-4-fluorobenzyl alcohol  (C7H6ClFO, CAS 208186-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro4FluorobenzylAlcohol;
formula     C7H6ClFO;
CAS         208186-84-9;
InChIKey    ZUHMDLLAHZUDRE-UHFFFAOYSA-N;
MW          160.572;      // g/mol [origin=calculated method=formula-sum]
Tc          722.96;      // K   [origin=predictive method=joback]
Pc          40.108;      // bar [origin=predictive method=joback]
omega       0.8373;      // -   [origin=predictive method=lee-kesler]
Tb          525.28;      // K   [origin=predictive method=joback]
HvapTb      55023.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.491 0.5235 -0.00032132 7.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH2; count 1; } { group OH; count 1; } { group ACCl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-chloranyl-4-fluoranyl-phenyl)methanol" "(2-chloro-4-fluorophenyl)methanol" "2-chloro-4-fluorobenzylalcohol" "(2-chloro-4-fluorophenyl)methan-1-ol" "2-chloro-4-fluorobenzyl alcohol 97%" "(2-chloro-4-fluoro-phenyl)methanol" "(2-chloro-4-fluorophenyl)methanol;2-chloro-4-fluorobenzyl alcohol;" );
gibbsFormation
{
    dHf_298   -338300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-242350.0
    phase     gas;
}
