/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-piperidinoacetophenone  (C13H17NO, CAS 10342-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Piperidinoacetophenone;
formula     C13H17NO;
CAS         10342-85-5;
InChIKey    JCMZZYSPSGHBNM-UHFFFAOYSA-N;
MW          203.285;      // g/mol [origin=calculated method=formula-sum]
Tc          847.59;      // K   [origin=predictive method=joback]
Pc          28.414;      // bar [origin=predictive method=joback]
omega       0.6534;      // -   [origin=predictive method=lee-kesler]
Tb          614.96;      // K   [origin=predictive method=joback]
HvapTb      56825.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.29 1.35452 -0.00092426 2.4016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-piperidin-1-ylphenyl)ethanone" "p-(1-piperidino)acetophenone" "4-piperidinoacetophenone" "1-(4-(piperidin-1-yl)phenyl)ethanone" "ethanone, 1-[4-(1-piperidinyl)phenyl]-" "1-acetyl-4-piperidylbenzene" "ethanone, 1-(4-(1-piperidinyl)phenyl)-" "1-[4-(1-piperidinyl)]phenyl]ethanone" "ethanone,1-[4-(1-piperidinyl)phenyl]-" "1-(4-(piperidin-1-yl)phenyl)ethan-1-one" "4 inverted exclamation marka-piperidinoacetophenone" );
standardThermochemistry
{
    dHf_298   -50820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=187480.0
}
