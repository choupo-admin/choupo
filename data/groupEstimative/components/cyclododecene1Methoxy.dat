/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclododecene, 1-methoxy-  (C13H24O, CAS 51238-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclododecene1Methoxy;
formula     C13H24O;
CAS         51238-63-2;
InChIKey    QKXCGPJJHMULFJ-UHFFFAOYSA-N;
MW          196.334;      // g/mol [origin=calculated method=formula-sum]
Tc          809.37;      // K   [origin=predictive method=joback]
Pc          23.248;      // bar [origin=predictive method=joback]
omega       0.4200;      // -   [origin=predictive method=lee-kesler]
Tb          573.44;      // K   [origin=predictive method=joback]
HvapTb      49666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.62 1.15112 -0.00035064 -7.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 10; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxycyclododecene" "cyclododecene, 1-methoxy-, (e)-" );
standardThermochemistry
{
    dHf_298   -359860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     761.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-66530.0
}
