/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-butyroylpyrocatechol  (C10H12O3, CAS 17386-89-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Butyroylpyrocatechol;
formula     C10H12O3;
CAS         17386-89-9;
InChIKey    NLERVTXJOGYIKC-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          905.64;      // K   [origin=predictive method=joback]
Pc          45.286;      // bar [origin=predictive method=joback]
omega       1.0469;      // -   [origin=predictive method=lee-kesler]
Tb          670.19;      // K   [origin=predictive method=joback]
HvapTb      72904.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.588 1.15612 -0.00104542 3.9046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[3,4-bis(oxidanyl)phenyl]butan-1-one" "3',4'-dihydroxybutyrophenone" "1-(3,4-dihydroxyphenyl)butan-1-one" "butyrophenone, 3',4'-dihydroxy-" "1-(3,4-dihydroxyphenyl)-1-butanone" "3',4'-dihydroxy-1-phenyl-2-butanone" "1-butanone, 1-(3,4-dihydroxyphenyl)-" "1-butanone, 1-(3,4-dihydroxyphenyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   -480400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-292430.0
}
