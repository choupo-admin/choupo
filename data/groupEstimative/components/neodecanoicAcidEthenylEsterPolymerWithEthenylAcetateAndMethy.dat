/*--------------------------------*- Choupo -*-----------------------*\
  Component: neodecanoic acid, ethenyl ester, polymer with ethenyl acetate and methyl 2-methyl-2-propenoate  (C21H36O6, CAS 96247-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        neodecanoicAcidEthenylEsterPolymerWithEthenylAcetateAndMethy;
formula     C21H36O6;
CAS         96247-28-8;
InChIKey    HHRXZEIERKGVNO-UHFFFAOYSA-N;
MW          384.513;      // g/mol [origin=calculated method=formula-sum]
Tc          1041.94;      // K   [origin=predictive method=joback]
Pc          9.497;      // bar [origin=predictive method=joback]
omega       0.8334;      // -   [origin=predictive method=lee-kesler]
Tb          844.23;      // K   [origin=predictive method=joback]
HvapTb      81923.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (108.525 1.48782 -0.000248 -2.411e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group C; count 1; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group CH3COO; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 5; } { group C; count 1; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl 7,7-dimethyloctanoate;ethenyl ethanoate;methyl 2-methylprop-2-enoate" );
standardThermochemistry
{
    dHf_298   -1294100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1286.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-756880.0
}
