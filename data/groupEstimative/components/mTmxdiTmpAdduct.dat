/*--------------------------------*- Choupo -*-----------------------*\
  Component: m-tmxdi/tmp adduct  (C20H30N2O5, CAS 94857-19-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mTmxdiTmpAdduct;
formula     C20H30N2O5;
CAS         94857-19-9;
InChIKey    PUDFXELQRPQEHN-UHFFFAOYSA-N;
MW          378.469;      // g/mol [origin=calculated method=formula-sum]
Tc          1339.49;      // K   [origin=predictive method=joback]
Pc          16.949;      // bar [origin=predictive method=joback]
omega       1.4011;      // -   [origin=predictive method=lee-kesler]
Tb          1090.45;      // K   [origin=predictive method=joback]
HvapTb      128559.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group C; count 3; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group C; count 3; } { group dCd; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 3; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(2-isocyanatopropan-2-yl)benzene;2-ethyl-2-(hydroxymethyl)propane-1,3-diol" "1,3-propanediol, 2-ethyl-2-(hydroxymethyl)-, polymer with 1,3-bis(1-isocyanato-1-methylethyl)benzene" "m-tetramethylxylene diisocyanate/trimethylol propane adduct" "1,3-bis(2-isocyanatopropan-2-yl)benzene; 2-ethyl-2-(hydroxymethyl)propane-1,3-diol" "2-ethyl-2-(hydroxymethyl)propane-1,3-diol- 1,3-bis(2-isocyanatopropan-2-yl)benzene(1:1)" );
