/*--------------------------------*- Choupo -*-----------------------*\
  Component: ptychodiscus brevis toxin  (C48H68O13, CAS 98225-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ptychodiscusBrevisToxin;
formula     C48H68O13;
CAS         98225-48-0;
InChIKey    NQICGQXVXIAURW-UUSBQWGHSA-N;
MW          853.059;      // g/mol [origin=calculated method=formula-sum]
Tc          2480.38;      // K   [origin=predictive method=joback]
Pc          5.688;      // bar [origin=predictive method=joback]
omega       -0.1094;      // -   [origin=predictive method=lee-kesler]
Tb          1827.06;      // K   [origin=predictive method=joback]
HvapTb      191371.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-408.319 5.65896 -0.00357906 8.444e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 14; } { group CH; count 12; } { group C; count 1; } { group CH=CH; count 2; } { group CH2=C; count 1; } { group OH; count 1; } { group CHO; count 1; } { group CH2COO; count 1; } { group CH-O; count 9; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 14; } { group CH_ring; count 21; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group OH; count 1; } { group O_ring; count 9; } { group OdCH_al; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -2163820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-549710.0
}
