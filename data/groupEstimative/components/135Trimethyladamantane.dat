/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-trimethyladamantane  (C13H22, CAS 707-35-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Trimethyladamantane;
formula     C13H22;
CAS         707-35-7;
InChIKey    WCACLGXPFTYVEL-UHFFFAOYSA-N;
MW          178.319;      // g/mol [origin=calculated method=formula-sum]
Tc          749.58;      // K   [origin=predictive method=joback]
Pc          26.325;      // bar [origin=predictive method=joback]
omega       0.3501;      // -   [origin=predictive method=lee-kesler]
Tb          517.58;      // K   [origin=predictive method=joback]
HvapTb      40681.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-308.81 2.53116 -0.00284 1.2773e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ambap707-35-7" "tricyclo[3.3.1.13,7]decane,1,3,5-trimethyl-" "tricyclo[3.3.1.1~3,7~]decane, 1,3,5-trimethyl-" "adamantane,1,3,5-trimethyl- (7ci,8ci);1,3,5-trimethyladamantane;" );
gibbsFormation
{
    dHf_298   -74030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=204550.0
    phase     gas;
}
