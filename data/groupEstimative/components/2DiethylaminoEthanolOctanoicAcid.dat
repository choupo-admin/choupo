/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(diethylamino)ethanol;octanoic acid  (C14H31NO3, CAS 68052-35-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DiethylaminoEthanolOctanoicAcid;
formula     C14H31NO3;
CAS         68052-35-7;
InChIKey    SBKDOVGGFMYFDW-UHFFFAOYSA-N;
MW          261.406;      // g/mol [origin=calculated method=formula-sum]
Tc          952.14;      // K   [origin=predictive method=joback]
Pc          16.378;      // bar [origin=predictive method=joback]
omega       1.3064;      // -   [origin=predictive method=lee-kesler]
Tb          771.45;      // K   [origin=predictive method=joback]
HvapTb      82938.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.18 1.33636 -0.0005386 1.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group OH; count 1; } { group CH2N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group OH; count 1; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octanoic acid diethylethanolamine salt" "octanoic acid, compd. with 2-(diethylamino)ethanol (1:1)" "2-(diethylamino)ethanol; octanoic acid" "octanoic acid - 2-(diethylamino)ethanol (1:1)" "octanoic acid, compound with 2-(diethylamino)ethanol (1:1)" "octanoic acid compd. with 2-(diethylamino)ethanol (1:1)" );
gibbsFormation
{
    dHf_298   -878880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     929.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-407710.0
    phase     gas;
}
