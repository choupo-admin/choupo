/*--------------------------------*- Choupo -*-----------------------*\
  Component: ricinoleic acid  (C18H34O3, CAS 141-22-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ricinoleicAcid;
formula     C18H34O3;
CAS         141-22-0;
InChIKey    WBHHMMIMDMUBKC-KQPPXVQYSA-N;
MW          298.467;      // g/mol [origin=calculated method=formula-sum]
Tc          1045.08;      // K   [origin=predictive method=joback]
Pc          13.667;      // bar [origin=predictive method=joback]
omega       1.2406;      // -   [origin=predictive method=lee-kesler]
Tb          852.85;      // K   [origin=predictive method=joback]
HvapTb      89075.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.447 1.82452 -0.0011454 2.877e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group dCH; count 2; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e,12s)-12-oxidanyloctadec-9-enoic acid" "ricinoleic acid, calcium salt" "12s-home(9e)" "12s-hydroxy-9e-octadecenoic acid" "9-octadecenoic acid, 12-hydroxy-, calcium salt, (9z,12r)-" "9-octadecenoic acid, 12-hydroxy-, calcium salt (1:?), (9z,12r)-" "(e,12s)-12-hydroxyoctadec-9-enoic acid" "9-octadecenoic acid, 12-hydroxy-, [s-(e)]-" );
gibbsFormation
{
    dHf_298   -805410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     945.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-302270.0
    phase     gas;
}
