/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropylamine, n,n-diallyl-,  (C9H17N, CAS 10542-47-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylamineNNDiallyl;
formula     C9H17N;
CAS         10542-47-9;
InChIKey    DFSQFCRJLMWKBA-UHFFFAOYSA-N;
MW          139.242;      // g/mol [origin=calculated method=formula-sum]
Tc          583.04;      // K   [origin=predictive method=joback]
Pc          25.201;      // bar [origin=predictive method=joback]
omega       0.4291;      // -   [origin=predictive method=lee-kesler]
Tb          410.88;      // K   [origin=predictive method=joback]
HvapTb      35943.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.648 0.94864 -0.0006274 1.676e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(prop-2-enyl)propan-2-amine" "2-propen-1-amine, n-(1-methylethyl)-n-2-propenyl-" );
standardThermochemistry
{
    dHf_298   84020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=308920.0
}
