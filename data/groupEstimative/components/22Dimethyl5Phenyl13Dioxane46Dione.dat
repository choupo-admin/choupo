/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-5-phenyl-1,3-dioxane-4,6-dione  (C12H12O4, CAS 15231-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl5Phenyl13Dioxane46Dione;
formula     C12H12O4;
CAS         15231-78-4;
InChIKey    NTUAHNQWHPQAMB-UHFFFAOYSA-N;
MW          220.224;      // g/mol [origin=calculated method=formula-sum]
Tc          837.42;      // K   [origin=predictive method=joback]
Pc          27.354;      // bar [origin=predictive method=joback]
omega       0.7188;      // -   [origin=predictive method=lee-kesler]
Tb          615.32;      // K   [origin=predictive method=joback]
HvapTb      57677.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.28 1.38124 -0.0012148 4.419e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxane-4,6-dione, 2,2-dimethyl-5-phenyl-" "5-phenylmeldrum's acid" "1,3-dioxane-4,6-dione,2,2-dimethyl-5-phenyl-" "malonicacid, phenyl-, cyclic isopropylidene ester (8ci); malonic acid, phenyl-,monoisopropylidene cyclic ester (6ci);2,2-dimethyl-5-phenyl-1,3-dioxane-4,6-dione; 5-phenyl meldrum's acid" );
standardThermochemistry
{
    dHf_298   -615180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-398520.0
}
