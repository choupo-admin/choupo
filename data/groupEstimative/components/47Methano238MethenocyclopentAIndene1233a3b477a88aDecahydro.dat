/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7-methano-2,3,8-methenocyclopent(a)indene, 1,2,3,3a,3b,4,7,7a,8,8a-decahydro-  (C14H16, CAS 7781-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        47Methano238MethenocyclopentAIndene1233a3b477a88aDecahydro;
formula     C14H16;
CAS         7781-74-0;
InChIKey    IGKDVUVITBCBRG-UHFFFAOYSA-N;
MW          184.282;      // g/mol [origin=calculated method=formula-sum]
Tc          735.86;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       0.4880;      // -   [origin=predictive method=lee-kesler]
Tb          523.76;      // K   [origin=predictive method=joback]
HvapTb      44604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-259.27 2.1156 -0.00201028 7.622e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 10; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 10; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7-methano-2,3,8-methenocyclopent[a]indene, 1,2,3,3a,3b,4,7,7a,8,8a-decahydro-" "hexacyclo[9.2.1.02,10.03,7.04,9.06,8]tetradecane-12-ene" "4,7-methano-2,3,8-methenocyclpenta[a]indene,1,2,3,3a,3b,4,7,7a,8,8a-decahydro-" );
standardThermochemistry
{
    dHf_298   105570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     -126.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=479020.0
}
