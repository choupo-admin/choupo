/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-chloro-8-quinolinol; 7-chloro-8-quinolinol; 5,7-dichloro-8-quinolinol  (C27H17Cl4N3O3, CAS 8067-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Chloro8Quinolinol7Chloro8Quinolinol57Dichloro8Quinolinol;
formula     C27H17Cl4N3O3;
CAS         8067-69-4;
InChIKey    XCQBENAYFZFNAR-UHFFFAOYSA-N;
MW          573.251;      // g/mol [origin=calculated method=formula-sum]
Tc          1876.94;      // K   [origin=predictive method=joback]
Pc          24.605;      // bar [origin=predictive method=joback]
omega       1.7522;      // -   [origin=predictive method=lee-kesler]
Tb          1529.74;      // K   [origin=predictive method=joback]
HvapTb      165892.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.88 2.26288 -0.00172946 5.366e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACOH; count 3; } { group C5H3N; count 3; } { group ACCl; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 14; } { group dC_ring; count 13; } { group Cl; count 4; } { group OH_phenol; count 3; } { group Nd_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,7-bis(chloranyl)quinolin-8-ol;5-chloranylquinolin-8-ol;7-chloranylquinolin-8-ol" "5-chloroquinolin-8-ol; 7-chloroquinolin-8-ol; 5,7-dichloroquinolin-8-ol" "5,7-dichloro-8-quinolino & 5-chloro-8-quinolino & 7-chloro-8-quinnolinol" "5,7-bis(chloranyl)quinolin-8-ol; 5-chloranylquinolin-8-ol; 7-chloranylquinolin-8-ol" );
standardThermochemistry
{
    dHf_298   -83450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1003.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=305170.0
}
