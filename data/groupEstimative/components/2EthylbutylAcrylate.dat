/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylbutyl acrylate  (C9H16O2, CAS 3953-10-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylbutylAcrylate;
formula     C9H16O2;
CAS         3953-10-4;
InChIKey    JGRXEBOFWPLEAV-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          637.63;      // K   [origin=predictive method=joback]
Pc          24.338;      // bar [origin=predictive method=joback]
omega       0.5408;      // -   [origin=predictive method=lee-kesler]
Tb          459.98;      // K   [origin=predictive method=joback]
HvapTb      41977.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.443 0.78994 -0.0003973 5.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH2=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylbutyl prop-2-enoate" "2-propenoic acid, 2-ethylbutyl ester" "acrylic acid, 2-ethylbutyl ester" "2-ethylbutylacrylate" "2-ethylbutyl 2-propenoate" "2-ethylbutylester kyseliny akrylove" "2-propenoic acid,2-ethylbutyl ester" );
gibbsFormation
{
    dHf_298   -426220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     543.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200070.0
    phase     gas;
}
