/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylene-2h-indene  (C10H8, CAS 6596-86-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylene2hIndene;
formula     C10H8;
CAS         6596-86-7;
InChIKey    HYLYEVKPDNDZPJ-UHFFFAOYSA-N;
MW          128.174;      // g/mol [origin=calculated method=formula-sum]
Tc          697.96;      // K   [origin=predictive method=joback]
Pc          37.000;      // bar [origin=predictive method=joback]
omega       0.3705;      // -   [origin=predictive method=lee-kesler]
Tb          469.79;      // K   [origin=predictive method=joback]
HvapTb      41465.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.92 0.8193 -0.00065484 2.11e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group CH2=C; count 1; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylideneindene" );
standardThermochemistry
{
    dHf_298   210490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     321.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=287600.0
}
