/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-amino-3-(diethylamino)propan-2-ol  (C7H18N2O, CAS 6322-01-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Amino3DiethylaminoPropan2Ol;
formula     C7H18N2O;
CAS         6322-01-6;
InChIKey    LEJMOTVCCRDZNE-UHFFFAOYSA-N;
MW          146.234;      // g/mol [origin=calculated method=formula-sum]
Tc          709.81;      // K   [origin=predictive method=joback]
Pc          33.220;      // bar [origin=predictive method=joback]
omega       1.0557;      // -   [origin=predictive method=lee-kesler]
Tb          536.47;      // K   [origin=predictive method=joback]
HvapTb      60151.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.066 0.89454 -0.0005466 1.298e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group CH2NH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azanyl-3-(diethylamino)propan-2-ol" "1-amino-3-diethylamino-propan-2-ol" "1-amino-3-diethylaminopropan-2-ol" "3-amino-1-(diethylamino)propan-2-ol" "1-amino-3-(diethylamino)-2-propanol" "1-amino-3-diethylamino-2-propanol" );
gibbsFormation
{
    dHf_298   -244000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46030.0
    phase     gas;
}
