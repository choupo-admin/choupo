/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-chloro-4-(tert-pentyl)toluene  (C12H17Cl, CAS 28162-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaChloro4TertPentylToluene;
formula     C12H17Cl;
CAS         28162-11-0;
InChIKey    GZSVKIJGGVPFGX-UHFFFAOYSA-N;
MW          196.718;      // g/mol [origin=calculated method=formula-sum]
Tc          758.50;      // K   [origin=predictive method=joback]
Pc          23.293;      // bar [origin=predictive method=joback]
omega       0.4463;      // -   [origin=predictive method=lee-kesler]
Tb          540.02;      // K   [origin=predictive method=joback]
HvapTb      48333.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.208 1.13806 -0.00078536 2.131e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(chloromethyl)-4-(2-methylbutan-2-yl)benzene" "p-t-amyl chlorobenzyl" "toluene, alpha-chloro-p-(1,1-dimethyl-propyl)-" "1-(chloromethyl)-4-(1,1-dimethylpropyl)-benzene" "toluene, .alpha.-chloro-p-(1,1-dimethyl-propyl)-," );
gibbsFormation
{
    dHf_298   -90440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143850.0
    phase     gas;
}
