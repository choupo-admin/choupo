/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r,2r)-n,n'-dimethyl-1,2-diphenyl-1,2-ethanediamine  (C16H20N2, CAS 118628-68-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2rNNDimethyl12Diphenyl12Ethanediamine;
formula     C16H20N2;
CAS         118628-68-5;
InChIKey    BTHYVQUNQHWNLS-HZPDHXFCSA-N;
MW          240.35;      // g/mol [origin=calculated method=formula-sum]
Tc          953.74;      // K   [origin=predictive method=joback]
Pc          23.795;      // bar [origin=predictive method=joback]
omega       0.8273;      // -   [origin=predictive method=lee-kesler]
Tb          718.50;      // K   [origin=predictive method=joback]
HvapTb      67858.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.25 1.53024 -0.0010126 2.502e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group ACCH; count 2; } { group CH3NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2r)-n,n'-dimethyl-1,2-diphenyl-ethane-1,2-diamine" "(1r,2r)-n1,n2-dimethyl-1,2-diphenylethane-1,2-diamine" "(1r,2r)-n,n'-dimethyl-1,2-diphenylethane-1,2-diamine" "(1r,2r)-(+)-n,n'-dimethyl-1,2-diphenylethylenediamine" "(1r,2r)-(+)-n,n'-dimethyl-1,2-diphenyl-1,2-ethane diamine" "(1r,2r)-n,n inverted exclamation marka-dimethyl-1,2-diphenylethane-1,2-diamine" );
standardThermochemistry
{
    dHf_298   195870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     628.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=482560.0
}
