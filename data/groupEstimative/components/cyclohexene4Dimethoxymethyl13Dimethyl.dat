/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene, 4-(dimethoxymethyl)-1,3-dimethyl-  (C11H20O2, CAS 72845-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene4Dimethoxymethyl13Dimethyl;
formula     C11H20O2;
CAS         72845-78-4;
InChIKey    OIZNJBIUUHUFAI-NXEZZACHSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          713.67;      // K   [origin=predictive method=joback]
Pc          22.525;      // bar [origin=predictive method=joback]
omega       0.5013;      // -   [origin=predictive method=lee-kesler]
Tb          514.70;      // K   [origin=predictive method=joback]
HvapTb      45586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.62 0.90848 -0.00030164 -2.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 3; } { group CH=C; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,4r)-4-(dimethoxymethyl)-1,3-dimethyl-cyclohexene" "(3r,4r)-4-(dimethoxymethyl)-1,3-dimethylcyclohexene" );
standardThermochemistry
{
    dHf_298   -459800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133630.0
}
