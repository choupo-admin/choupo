/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 5,5-dimethoxyvalerate  (C8H16O4, CAS 23068-91-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl55Dimethoxyvalerate;
formula     C8H16O4;
CAS         23068-91-9;
InChIKey    YOFAONQHOIRLCQ-UHFFFAOYSA-N;
MW          176.212;      // g/mol [origin=calculated method=formula-sum]
Tc          659.90;      // K   [origin=predictive method=joback]
Pc          24.826;      // bar [origin=predictive method=joback]
omega       0.6724;      // -   [origin=predictive method=lee-kesler]
Tb          485.26;      // K   [origin=predictive method=joback]
HvapTb      45241.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (70.343 0.58856 -9.8e-05 -8.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2COO; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 5,5-dimethoxypentanoate" "pentanoic acid,5,5-dimethoxy-, methyl ester" "pentanoic acid, 5,5-dimethoxy-, methyl ester" "glutaraldehydicacid, methyl ester, dimethyl acetal (7ci,8ci); methyl 4-formylbutyrate dimethylacetal; methyl 5,5-bis(methyloxy)pentanoate; methyl 5,5-dimethoxypentanoate;methyl 5,5-dimethoxyvalerate" );
gibbsFormation
{
    dHf_298   -795450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-506330.0
    phase     gas;
}
