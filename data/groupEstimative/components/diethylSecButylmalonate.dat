/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl sec-butylmalonate  (C11H20O4, CAS 83-27-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylSecButylmalonate;
formula     C11H20O4;
CAS         83-27-2;
InChIKey    MIIZSUOEOUHAIZ-UHFFFAOYSA-N;
MW          216.277;      // g/mol [origin=calculated method=formula-sum]
Tc          746.81;      // K   [origin=predictive method=joback]
Pc          19.788;      // bar [origin=predictive method=joback]
omega       0.7752;      // -   [origin=predictive method=lee-kesler]
Tb          566.84;      // K   [origin=predictive method=joback]
HvapTb      54118.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.343 0.95108 -0.0003918 4.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-butan-2-ylpropanedioate" "diethyl 1-methylpropylmalonate" "diethyl 2-(sec-butyl)malonate" "sec-butylmalonic acid diethyl ester" "sec-butylmalonic acid, diethyl ester" "diethyl 2-sec-butylmalonate" "diethyl (1-methylpropyl)malonate" "miizsuoeouhaiz-uhfffaoysa-" "1,3-diethyl 2-(sec-butyl)propanedioate" "diethyl 2-(methylpropyl)propane-1,3-dioate" "2-(1-methyl-propyl)-propanedioic acid diethyl ester" "2-(1-methylpropyl)-propanedioic acid 1,3-diethyl ester" );
gibbsFormation
{
    dHf_298   -915490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     667.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-583880.0
    phase     gas;
}
