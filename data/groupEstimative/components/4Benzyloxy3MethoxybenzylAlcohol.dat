/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-benzyloxy-3-methoxybenzyl alcohol  (C15H16O3, CAS 33693-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Benzyloxy3MethoxybenzylAlcohol;
formula     C15H16O3;
CAS         33693-48-0;
InChIKey    PDBXFVPMVYQICB-UHFFFAOYSA-N;
MW          244.29;      // g/mol [origin=calculated method=formula-sum]
Tc          956.71;      // K   [origin=predictive method=joback]
Pc          25.820;      // bar [origin=predictive method=joback]
omega       1.1620;      // -   [origin=predictive method=lee-kesler]
Tb          743.14;      // K   [origin=predictive method=joback]
HvapTb      76359.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.332 1.05962 -0.00052892 6.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-methoxy-4-phenylmethoxy-phenyl)methanol" "benzenemethanol, 3-methoxy-4-(phenylmethoxy)-" "o-benzylvanillyl alcohol" "vanillyl alcohol benzyl ether" "agn-pc-04y219" "(4-benzyloxy-3-methoxyphenyl)methanol" "4-benzyl-oxy-3-methoxybenzyl alcohol" "3-methoxy-4-(benzyloxy)benzyl alcohol" "4-(benzyloxy)-3-methoxybenzyl alcohol" "[4-(benzyloxy)-3-methoxyphenyl]methanol" "4-(benzyloxy)-3-methoxy-benzyl alcohol" "(3-methoxy-4-phenylmethoxyphenyl)methanol" );
standardThermochemistry
{
    dHf_298   -319480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-65840.0
}
