/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(3-hexyl)phenol  (C12H18O, CAS 6925-42-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        43HexylPhenol;
formula     C12H18O;
CAS         6925-42-4;
InChIKey    AFXYCMIKKCWXCT-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          796.67;      // K   [origin=predictive method=joback]
Pc          28.233;      // bar [origin=predictive method=joback]
omega       0.6842;      // -   [origin=predictive method=lee-kesler]
Tb          581.02;      // K   [origin=predictive method=joback]
HvapTb      57208.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.527 1.22544 -0.00091976 2.897e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 4; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-hexan-3-ylphenol" );
standardThermochemistry
{
    dHf_298   -237070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5510.0
}
