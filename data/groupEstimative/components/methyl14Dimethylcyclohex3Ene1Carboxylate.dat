/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 1,4-dimethylcyclohex-3-ene-1-carboxylate  (C10H16O2, CAS 23733-88-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl14Dimethylcyclohex3Ene1Carboxylate;
formula     C10H16O2;
CAS         23733-88-2;
InChIKey    PAXHLOIQWUFMQI-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          724.89;      // K   [origin=predictive method=joback]
Pc          27.643;      // bar [origin=predictive method=joback]
omega       0.4674;      // -   [origin=predictive method=lee-kesler]
Tb          510.55;      // K   [origin=predictive method=joback]
HvapTb      45493.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.31 1.19756 -0.00095944 3.376e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cyclohexene-1-carboxylic acid, 1,4-dimethyl-, methyl ester" "methyl 1,4-dimethyl-3-cyclohexene-1-carboxylate" "methyl (1)-1,4-dimethylcyclohexene-1-carboxylate" );
gibbsFormation
{
    dHf_298   -451140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-237760.0
    phase     gas;
}
