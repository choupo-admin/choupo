/*--------------------------------*- Choupo -*-----------------------*\
  Component: propiophenone  (C9H10O, CAS 93-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propiophenone;
formula     C9H10O;
CAS         93-55-0;
InChIKey    KRIOVPPHQSLHCZ-UHFFFAOYSA-N;
MW          134.178;      // g/mol [origin=calculated method=formula-sum]
Tc          704.52;      // K   [origin=predictive method=joback]
Pc          35.096;      // bar [origin=predictive method=joback]
omega       0.4643;      // -   [origin=predictive method=lee-kesler]
Tb          486.07;      // K   [origin=predictive method=joback]
HvapTb      44650.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.839 0.75192 -0.0004783 1.1236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylpropan-1-one" "ethyl phenyl ketone" "propionylbenzene" "1-propanone, 1-phenyl-" "1-phenyl-1-propanone" "phenyl ethyl ketone" "ketone, ethyl phenyl" "1-phenyl-propan-1-one" "propionphenone" "phenylethyl ketone" "m855" "1-propanone,1-phenyl   propiophenone" );
standardThermochemistry
{
    dHf_298   -105140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8390.0
}
