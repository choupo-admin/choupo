/*--------------------------------*- Choupo -*-----------------------*\
  Component: perfluorohexamethylprismane  (C12F18, CAS 22736-20-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        perfluorohexamethylprismane;
formula     C12F18;
CAS         22736-20-5;
InChIKey    JFELTPAOLMOQHL-UHFFFAOYSA-N;
MW          486.096;      // g/mol [origin=calculated method=formula-sum]
Tc          565.34;      // K   [origin=predictive method=joback]
Pc          16.103;      // bar [origin=predictive method=joback]
omega       0.7557;      // -   [origin=predictive method=lee-kesler]
Tb          435.08;      // K   [origin=predictive method=joback]
HvapTb      10920.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-503.53 4.4706 -0.006199 2.972e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 6; } { group CF3; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 6; } { group C_ring; count 6; } { group F; count 18; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5,6-hexakis(trifluoromethyl)prismane" "1,2,3,4,5,6-hexakis(trifluoromethyl)tetracyclo[2.2.0.02,6.03,5]hexane" "tetracyclo[2.2.0.02,6.03,5]hexane,hexakis(trifluoromethyl)-(8ci)" "tetracyclo[2.2.0.02,6.03,5]hexane,1,2,3,4,5,6-hexakis(trifluoromethyl)-" );
standardThermochemistry
{
    dHf_298   -3494570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     812.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3172140.0
}
