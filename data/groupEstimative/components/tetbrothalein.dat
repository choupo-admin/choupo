/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetbrothalein  (C20H10Br4O4, CAS 76-62-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetbrothalein;
formula     C20H10Br4O4;
CAS         76-62-0;
InChIKey    OBRGVMYQZVQHGO-UHFFFAOYSA-N;
MW          633.912;      // g/mol [origin=calculated method=formula-sum]
Tc          1551.37;      // K   [origin=predictive method=joback]
Pc          43.511;      // bar [origin=predictive method=joback]
omega       1.9855;      // -   [origin=predictive method=lee-kesler]
Tb          1244.68;      // K   [origin=predictive method=joback]
HvapTb      127845.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.17 2.2388 -0.00237192 9.814e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 8; } { group AC; count 8; } { group ACOH; count 2; } { group Br; count 4; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 10; } { group Br; count 4; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis[3,5-bis(bromanyl)-4-oxidanyl-phenyl]-2-benzofuran-1-one" "tetrabromophenolphthalein" "3',3'',5',5''-tetrabromophenolphthalein" "phenol tetrabromophthalein" "phenolphthalein, tetrabromo-" "1(3h)-isobenzofuranone, 3,3-bis(3,5-dibromo-4-hydroxyphenyl)-" "phenolphthalein, 3',3'',5',5''-tetrabromo-" "3,3-bis(3,5-dibromo-4-hydroxyphenyl)-2-benzofuran-1-one" "3,3-bis(3,5-dibromo-4-hydroxyphenyl)-3-hydroisobenzofuran-1-one" "tetrabromophenolphthalein (van)" "3',5',5''-tetrabromophenolphthalein" "3',3',5',5'-tetrabromophenolphthalein" );
standardThermochemistry
{
    dHf_298   -270110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     832.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76270.0
}
