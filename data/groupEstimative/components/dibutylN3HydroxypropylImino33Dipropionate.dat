/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibutyl n-(3-hydroxypropyl)imino-3,3'-dipropionate  (C17H33NO5, CAS 71042-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibutylN3HydroxypropylImino33Dipropionate;
formula     C17H33NO5;
CAS         71042-71-2;
InChIKey    ANVCGYUJBUYFDC-UHFFFAOYSA-N;
MW          331.453;      // g/mol [origin=calculated method=formula-sum]
Tc          991.76;      // K   [origin=predictive method=joback]
Pc          13.223;      // bar [origin=predictive method=joback]
omega       1.2153;      // -   [origin=predictive method=lee-kesler]
Tb          809.62;      // K   [origin=predictive method=joback]
HvapTb      86972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.853 1.66714 -0.0008548 1.241e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group OH; count 1; } { group CH2COO; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group OH; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 3-[(3-butoxy-3-oxidanylidene-propyl)-(3-oxidanylpropyl)amino]propanoate" "butyl 3-(2-butoxycarbonylethyl-(3-hydroxypropyl)amino)propanoate" "dibutyl 3,3'-[(3-hydroxypropyl)imino]dipropanoate(non-preferred name)" "beta-alanine, n-(3-butoxy-3-oxopropyl)-n-(3-hydroxypropyl)-, butyl ester" "butyl 3-[(3-butoxy-3-oxopropyl)-(3-hydroxypropyl)amino]propanoate" ".beta.-alanine, n-(3-butoxy-3-oxopropyl)-n-(3-hydroxypropyl)-, butyl ester" );
gibbsFormation
{
    dHf_298   -1113470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     987.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-554520.0
    phase     gas;
}
