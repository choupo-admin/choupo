/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-di-o-tolylethylene  (C16H16, CAS 2919-19-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11DiOTolylethylene;
formula     C16H16;
CAS         2919-19-9;
InChIKey    MUZMRKGPXHDTOF-UHFFFAOYSA-N;
MW          208.304;      // g/mol [origin=calculated method=formula-sum]
Tc          866.87;      // K   [origin=predictive method=joback]
Pc          23.225;      // bar [origin=predictive method=joback]
omega       0.5198;      // -   [origin=predictive method=lee-kesler]
Tb          625.56;      // K   [origin=predictive method=joback]
HvapTb      56496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.55 1.22694 -0.00080012 1.996e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-2-[1-(2-methylphenyl)ethenyl]benzene" "1,1-di(o-tolyl)ethylene" "1-methyl-2-[1-(2-methylphenyl)vinyl]benzene" "2-methyl-1-[1-(2-methylphenyl)vinyl]benzene" );
gibbsFormation
{
    dHf_298   192190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=368690.0
    phase     gas;
}
