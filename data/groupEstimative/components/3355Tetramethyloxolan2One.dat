/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,5,5-tetramethyloxolan-2-one  (C8H14O2, CAS 4237-83-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3355Tetramethyloxolan2One;
formula     C8H14O2;
CAS         4237-83-6;
InChIKey    DTPSINDCVZJYPO-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          644.97;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.3977;      // -   [origin=predictive method=lee-kesler]
Tb          443.41;      // K   [origin=predictive method=joback]
HvapTb      38111.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.26 1.41728 -0.0015468 6.94e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 1; } { group C_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,5,5-tetramethyl-tetrahydro-furan-2-one" "3,3,5,5-tetramethyldihydro-2(3h)-furanone" "2(3h)-furanone, dihydro-3,3,5,5-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -442790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-251830.0
}
