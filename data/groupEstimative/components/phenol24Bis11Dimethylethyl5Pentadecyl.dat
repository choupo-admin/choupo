/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 2,4-bis(1,1-dimethylethyl)-5-pentadecyl-  (C29H52O, CAS 32360-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol24Bis11Dimethylethyl5Pentadecyl;
formula     C29H52O;
CAS         32360-04-6;
InChIKey    SOHBNMLQQDWLAV-UHFFFAOYSA-N;
MW          416.734;      // g/mol [origin=calculated method=formula-sum]
Tc          1192.45;      // K   [origin=predictive method=joback]
Pc          8.098;      // bar [origin=predictive method=joback]
omega       0.7755;      // -   [origin=predictive method=lee-kesler]
Tb          973.92;      // K   [origin=predictive method=joback]
HvapTb      94170.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.646 2.96724 -0.00205088 5.865e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 13; } { group C; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 14; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-ditert-butyl-5-pentadecyl-phenol" "2,4-ditert-butyl-5-pentadecylphenol" );
standardThermochemistry
{
    dHf_298   -623110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1115.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=137510.0
}
