/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butene-3-yne, 4-iodo-  (C4H3I, CAS 40589-39-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butene3Yne4Iodo;
formula     C4H3I;
CAS         40589-39-7;
InChIKey    QWYPSOSNPXRMAA-UHFFFAOYSA-N;
MW          177.968;      // g/mol [origin=calculated method=formula-sum]
Tc          632.45;      // K   [origin=predictive method=joback]
Pc          49.454;      // bar [origin=predictive method=joback]
omega       0.1532;      // -   [origin=predictive method=lee-kesler]
Tb          389.94;      // K   [origin=predictive method=joback]
HvapTb      35353.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.51 0.253 -0.00020596 7.268e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group I; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group tC; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-iodanylbut-1-en-3-yne" "4-iodobut-1-en-3-yne" );
standardThermochemistry
{
    dHf_298   348710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=331560.0
}
