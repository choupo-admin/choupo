/*--------------------------------*- Choupo -*-----------------------*\
  Component: exalamide  (C13H19NO2, CAS 53370-90-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        exalamide;
formula     C13H19NO2;
CAS         53370-90-4;
InChIKey    CKSJXOVLXUMMFF-UHFFFAOYSA-N;
MW          221.3;      // g/mol [origin=calculated method=formula-sum]
Tc          888.75;      // K   [origin=predictive method=joback]
Pc          23.865;      // bar [origin=predictive method=joback]
omega       0.9288;      // -   [origin=predictive method=lee-kesler]
Tb          677.52;      // K   [origin=predictive method=joback]
HvapTb      67267.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.815 1.07112 -0.00056126 9.126e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexoxybenzamide" "2-(hexyloxy)benzamide" "hyperan" "2-n-hexyloxybenzamide" "o-hexyloxybenzamide" "2-hexyloxybenzamide" "o-(hexyloxy)benzamide" "exalamidum" "exalamida" "benzamide, 2-(hexyloxy)-" "exalamidum [inn-latin]" "benzamide, o-hexyloxy-" );
gibbsFormation
{
    dHf_298   -297600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6110.0
    phase     gas;
}
