/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-1,3-dioxolan-4-methylamine  (C6H13NO2, CAS 22195-47-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl13Dioxolan4Methylamine;
formula     C6H13NO2;
CAS         22195-47-7;
InChIKey    HXOYWCSTHVTLOW-UHFFFAOYSA-N;
MW          131.175;      // g/mol [origin=calculated method=formula-sum]
Tc          693.72;      // K   [origin=predictive method=joback]
Pc          40.934;      // bar [origin=predictive method=joback]
omega       0.4801;      // -   [origin=predictive method=lee-kesler]
Tb          474.16;      // K   [origin=predictive method=joback]
HvapTb      47408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.969 1.02684 -0.0009228 3.631e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,2-dimethyl-1,3-dioxolan-4-yl)methanamine" "2,2-dimethyl-1,3-dioxolane-4-methanamine" "1-(2,2-dimethyl-1,3-dioxolan-4-yl)methanamine" "1,3-dioxolane-4-methanamine, 2,2-dimethyl-" "(2,2-dimethyl-[1,3]-dioxolan-4-yl)methylamine" "( r )-(-)-(2,2-dimethyl-[1,3]-dioxolan-4-yl)-" "( s )-(+)-(2,2-dimethyl-[1,3]-dioxolan-4-yl)-" );
standardThermochemistry
{
    dHf_298   -342000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     315.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-82800.0
}
