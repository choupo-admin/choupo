/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-5-ethyloctane  (C11H24, CAS 62016-21-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl5Ethyloctane;
formula     C11H24;
CAS         62016-21-1;
InChIKey    LZFCEXJTLLKGPW-UHFFFAOYSA-N;
MW          156.313;      // g/mol [origin=calculated method=formula-sum]
Tc          619.09;      // K   [origin=predictive method=joback]
Pc          19.613;      // bar [origin=predictive method=joback]
omega       0.4822;      // -   [origin=predictive method=lee-kesler]
Tb          450.40;      // K   [origin=predictive method=joback]
HvapTb      39304.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.475 1.06068 -0.000581 1.187e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethyl-3-methyl-octane" "agn-pc-02xiv7" );
gibbsFormation
{
    dHf_298   -280930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36860.0
    phase     gas;
}
