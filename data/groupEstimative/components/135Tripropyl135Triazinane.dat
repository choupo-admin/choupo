/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-tripropyl-1,3,5-triazinane  (C12H27N3, CAS 13036-81-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Tripropyl135Triazinane;
formula     C12H27N3;
CAS         13036-81-2;
InChIKey    DPHBVWJGMBYPMK-UHFFFAOYSA-N;
MW          213.369;      // g/mol [origin=calculated method=formula-sum]
Tc          691.43;      // K   [origin=predictive method=joback]
Pc          20.419;      // bar [origin=predictive method=joback]
omega       0.7655;      // -   [origin=predictive method=lee-kesler]
Tb          522.89;      // K   [origin=predictive method=joback]
HvapTb      48657.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.274 1.69296 -0.0012424 3.713e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH2N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH2_ring; count 3; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-triazine, hexahydro-1,3,5-tripropyl-" "s-triazine, hexahydro-1,3,5-tripropyl-" "hexahydro-1,3,5-tripropyl-1,3,5-triazine" );
gibbsFormation
{
    dHf_298   4720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=450960.0
    phase     gas;
}
