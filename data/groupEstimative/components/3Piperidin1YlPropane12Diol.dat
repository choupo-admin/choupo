/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(piperidin-1-yl)propane-1,2-diol  (C8H17NO2, CAS 4847-93-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Piperidin1YlPropane12Diol;
formula     C8H17NO2;
CAS         4847-93-2;
InChIKey    MECNWXGGNCJFQJ-UHFFFAOYSA-N;
MW          159.229;      // g/mol [origin=calculated method=formula-sum]
Tc          776.49;      // K   [origin=predictive method=joback]
Pc          39.906;      // bar [origin=predictive method=joback]
omega       1.3812;      // -   [origin=predictive method=lee-kesler]
Tb          598.95;      // K   [origin=predictive method=joback]
HvapTb      68981.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.598 1.1198 -0.0007708 2.082e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 5; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-piperidin-1-ylpropane-1,2-diol" "3-piperidino-1,2-propanediol" "1-n-piperidino-2,3-propanediol" "3-piperidylpropane-1,2-diol" "3-piperidinopropane-1,2-diol" "1,2-propanediol,3-(1-piperidinyl)-" );
standardThermochemistry
{
    dHf_298   -369840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-104560.0
}
