/*--------------------------------*- Choupo -*-----------------------*\
  Component: penbutolol  (C18H29NO2, CAS 38363-40-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        penbutolol;
formula     C18H29NO2;
CAS         38363-40-5;
InChIKey    KQXKVJAGOJTNJS-HNNXBMFYSA-N;
MW          291.435;      // g/mol [origin=calculated method=formula-sum]
Tc          1029.89;      // K   [origin=predictive method=joback]
Pc          18.341;      // bar [origin=predictive method=joback]
omega       1.1763;      // -   [origin=predictive method=lee-kesler]
Tb          819.48;      // K   [origin=predictive method=joback]
HvapTb      82698.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.138 1.88586 -0.00118996 2.8e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2NH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-1-(tert-butylamino)-3-(2-cyclopentylphenoxy)propan-2-ol" "betapressin" "levatol" "levopenbutol" "penbutololum" "lobeta" "l-penbutolol" "hoe 893d" "(-)-penbutolol" "s(-)-penbutolol" "levatolol" "paginol" );
gibbsFormation
{
    dHf_298   -374320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     748.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87980.0
    phase     gas;
}
