/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-azabicyclo[4.2.1]non-7-ene  (C8H13N, CAS 51787-59-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Azabicyclo421Non7Ene;
formula     C8H13N;
CAS         51787-59-8;
InChIKey    BBISWXDOHPTYAD-UHFFFAOYSA-N;
MW          123.199;      // g/mol [origin=calculated method=formula-sum]
Tc          685.94;      // K   [origin=predictive method=joback]
Pc          39.555;      // bar [origin=predictive method=joback]
omega       0.3483;      // -   [origin=predictive method=lee-kesler]
Tb          456.64;      // K   [origin=predictive method=joback]
HvapTb      40794.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.53 0.9674 -0.00063928 1.642e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-azabicyclo(4.2.1)non-7-ene" );
gibbsFormation
{
    dHf_298   14260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     303.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=219350.0
    phase     gas;
}
