/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-5-heptene  (C8H16, CAS 73548-72-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl5Heptene;
formula     C8H16;
CAS         73548-72-8;
InChIKey    LXBJRNXXTAWCKU-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          562.34;      // K   [origin=predictive method=joback]
Pc          26.958;      // bar [origin=predictive method=joback]
omega       0.3375;      // -   [origin=predictive method=lee-kesler]
Tb          386.36;      // K   [origin=predictive method=joback]
HvapTb      32972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.248 0.78976 -0.0004984 1.309e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylhept-2-ene" );
gibbsFormation
{
    dHf_298   -96510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94260.0
    phase     gas;
}
