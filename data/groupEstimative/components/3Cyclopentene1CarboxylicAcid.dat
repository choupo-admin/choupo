/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cyclopentene-1-carboxylic acid  (C6H8O2, CAS 7686-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Cyclopentene1CarboxylicAcid;
formula     C6H8O2;
CAS         7686-77-3;
InChIKey    XVSYDLITVYBCBD-UHFFFAOYSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          719.08;      // K   [origin=predictive method=joback]
Pc          45.104;      // bar [origin=predictive method=joback]
omega       0.5749;      // -   [origin=predictive method=lee-kesler]
Tb          496.83;      // K   [origin=predictive method=joback]
HvapTb      46663.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.67 0.7003 -0.00048988 1.319e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopent-3-ene-1-carboxylic acid" "3-cyclopentenecarboxylic acid" "cyclopent-3-enecarboxylic acid" "3-cyclopentene-1-carboxylicacid" "3-cyclopentene-1-carhoxylic acid" "ghl.pd_mitscher_leg0.243" "cyclopent-3-ene carboxylic acid" "xvsydlitvybcbd-uhfffaoysa-" "4-carboxycyclopent-1-ene" "cyclopent-3-ene-1-carboxylic acid," "cyclopentene-3-carboxylic acid" "h304" );
gibbsFormation
{
    dHf_298   -399180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-277760.0
    phase     gas;
}
