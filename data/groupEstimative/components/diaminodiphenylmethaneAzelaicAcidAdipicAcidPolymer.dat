/*--------------------------------*- Choupo -*-----------------------*\
  Component: diaminodiphenylmethane, azelaic acid, adipic acid polymer  (C28H40N2O8, CAS 66787-20-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diaminodiphenylmethaneAzelaicAcidAdipicAcidPolymer;
formula     C28H40N2O8;
CAS         66787-20-0;
InChIKey    QULMOARDXPGTBG-UHFFFAOYSA-N;
MW          532.634;      // g/mol [origin=calculated method=formula-sum]
Tc          2141.02;      // K   [origin=predictive method=joback]
Pc          11.261;      // bar [origin=predictive method=joback]
omega       0.4601;      // -   [origin=predictive method=lee-kesler]
Tb          1633.46;      // K   [origin=predictive method=joback]
HvapTb      174324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.242 2.3016 -0.00097532 2.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group ACH; count 8; } { group AC; count 1; } { group ACCH2; count 1; } { group ACNH2; count 2; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COOH; count 4; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(4-aminophenyl)methyl]aniline;hexanedioic acid;nonanedioic acid" "4-[(4-aminophenyl)methyl]aniline; hexanedioic acid; nonanedioic acid" "nonanedioic acid, polymer with hexanedioic acid and 4,4'-methylenebis(benzenamine)" );
standardThermochemistry
{
    dHf_298   -1727870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1552.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1061820.0
}
