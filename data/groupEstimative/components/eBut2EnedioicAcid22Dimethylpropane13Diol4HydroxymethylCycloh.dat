/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-but-2-enedioic acid;2,2-dimethylpropane-1,3-diol;[4-(hydroxymethyl)cyclohexyl]methanol  (C17H32O8, CAS 68239-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eBut2EnedioicAcid22Dimethylpropane13Diol4HydroxymethylCycloh;
formula     C17H32O8;
CAS         68239-91-8;
InChIKey    QHCAMHHGYTZSQT-WXXKFALUSA-N;
MW          364.435;      // g/mol [origin=calculated method=formula-sum]
Tc          1609.91;      // K   [origin=predictive method=joback]
Pc          19.983;      // bar [origin=predictive method=joback]
omega       1.1179;      // -   [origin=predictive method=lee-kesler]
Tb          1266.91;      // K   [origin=predictive method=joback]
HvapTb      153850.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.114 1.68544 -0.0006194 -4.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group dCH; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butenedioic acid (2e)-, polymer with 1,4-cyclohexanedimethanol and 2,2-dimethyl-1,3-propanediol" "(e)-but-2-enedioic acid; 2,2-dimethylpropane-1,3-diol; [4-(hydroxymethyl)cyclohexyl]methanol" );
standardThermochemistry
{
    dHf_298   -1784460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1225.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1252560.0
}
