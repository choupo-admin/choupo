/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorobenzoic acid  (C7H5ClO2, CAS 74-11-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorobenzoicAcid;
formula     C7H5ClO2;
CAS         74-11-3;
InChIKey    XRHGYUZYPHTUJZ-UHFFFAOYSA-N;
MW          156.565;      // g/mol [origin=calculated method=formula-sum]
Tc          812.49;      // K   [origin=predictive method=joback]
Pc          43.169;      // bar [origin=predictive method=joback]
omega       0.6884;      // -   [origin=predictive method=lee-kesler]
Tb          574.36;      // K   [origin=predictive method=joback]
HvapTb      55663.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.59 0.588 -0.00041416 1.097e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranylbenzoic acid" "p-chlorobenzoic acid" "benzoic acid, 4-chloro-" "p-chlorbenzoic acid" "benzoic acid, p-chloro-" "chlorodracylic acid" "p-carboxychlorobenzene" "4-chloro-benzoic acid" "para-chlorobenzoic acid" "pcba" "mycosid" "acido p-clorobenzoico" );
gibbsFormation
{
    dHf_298   -328760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-245000.0
    phase     gas;
}
