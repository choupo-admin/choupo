/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-chloroethoxy)-1,1'-biphenyl  (C14H13ClO, CAS 607-04-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Chloroethoxy11Biphenyl;
formula     C14H13ClO;
CAS         607-04-5;
InChIKey    CGVSPABEGAOUOK-UHFFFAOYSA-N;
MW          232.707;      // g/mol [origin=calculated method=formula-sum]
Tc          878.47;      // K   [origin=predictive method=joback]
Pc          25.793;      // bar [origin=predictive method=joback]
omega       0.6119;      // -   [origin=predictive method=lee-kesler]
Tb          638.11;      // K   [origin=predictive method=joback]
HvapTb      58767.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.958 1.0601 -0.00064256 1.357e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group CH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-chloroethyloxy)-2-phenyl-benzene" "1-(2-chloroethoxy)-2-phenylbenzene" "1, 2-(2-chloroethoxy)-" "2-chloroethyl-2-xenyl ether" );
gibbsFormation
{
    dHf_298   -18660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=165260.0
    phase     gas;
}
