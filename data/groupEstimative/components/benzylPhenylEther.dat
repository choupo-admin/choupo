/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl phenyl ether  (C13H12O, CAS 946-80-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylPhenylEther;
formula     C13H12O;
CAS         946-80-5;
InChIKey    BOTNYLSAWDQNEX-UHFFFAOYSA-N;
MW          184.238;      // g/mol [origin=calculated method=formula-sum]
Tc          813.92;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       0.5020;      // -   [origin=predictive method=lee-kesler]
Tb          572.82;      // K   [origin=predictive method=joback]
HvapTb      51494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.239 1.0178 -0.0006348 1.397e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenoxymethylbenzene" "(benzyloxy)benzene" "benzene, (phenoxymethyl)-" "benzyloxy-benzene" "phenyl benzyl ether" "ether, benzyl phenyl" "(phenylmethoxy)benzene" "phenoxytoluene" "alpha-phenylanisole" ".alpha.-phenylanisole" "benzylphenylether" "anisole, alpha-phenyl-" );
standardThermochemistry
{
    dHf_298   29190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=178400.0
}
