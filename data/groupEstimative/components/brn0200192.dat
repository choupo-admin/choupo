/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 0200192  (C14H19NO2, CAS 64058-44-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn0200192;
formula     C14H19NO2;
CAS         64058-44-2;
InChIKey    RNAGZQQIHXIDQH-UHFFFAOYSA-N;
MW          233.311;      // g/mol [origin=calculated method=formula-sum]
Tc          953.01;      // K   [origin=predictive method=joback]
Pc          31.002;      // bar [origin=predictive method=joback]
omega       0.8807;      // -   [origin=predictive method=lee-kesler]
Tb          709.05;      // K   [origin=predictive method=joback]
HvapTb      69943.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-166.47 1.92904 -0.00177926 6.7986e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH3CO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-(3-hydroxyphenyl)-1-methyl-piperidin-4-yl]ethanone" "methyl (4-(m-hydroxyphenyl)-1-methyl)-4-piperidyl ketone" "ketone, 4-(m-hydroxyphenyl)-1-methylisonipecotinoyl methyl" );
gibbsFormation
{
    dHf_298   -242400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     683.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37710.0
    phase     gas;
}
