/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,7,11-dodecatriyn-1-ol  (C12H14O, CAS 76379-66-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5711Dodecatriyn1Ol;
formula     C12H14O;
CAS         76379-66-3;
InChIKey    TWBPLYADCPQACM-UHFFFAOYSA-N;
MW          174.243;      // g/mol [origin=calculated method=formula-sum]
Tc          779.34;      // K   [origin=predictive method=joback]
Pc          30.524;      // bar [origin=predictive method=joback]
omega       0.8004;      // -   [origin=predictive method=lee-kesler]
Tb          574.46;      // K   [origin=predictive method=joback]
HvapTb      63147.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.166 0.7843 -0.00047105 1.1775e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group OH; count 1; } { group CH_C; count 1; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group tCH; count 1; } { group tC; count 5; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodeca-5,7,11-triyn-1-ol" );
gibbsFormation
{
    dHf_298   393260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=542010.0
    phase     gas;
}
