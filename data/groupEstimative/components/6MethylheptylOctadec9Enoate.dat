/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methylheptyl octadec-9-enoate  (C26H50O2, CAS 26761-50-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6MethylheptylOctadec9Enoate;
formula     C26H50O2;
CAS         26761-50-2;
InChIKey    SAUIGQBKPDQYHL-UHFFFAOYSA-N;
MW          394.684;      // g/mol [origin=calculated method=formula-sum]
Tc          1048.61;      // K   [origin=predictive method=joback]
Pc          7.510;      // bar [origin=predictive method=joback]
omega       0.7067;      // -   [origin=predictive method=lee-kesler]
Tb          856.42;      // K   [origin=predictive method=joback]
HvapTb      80447.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.201 2.44496 -0.001383 2.88e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 18; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 19; } { group CH; count 1; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-octadecenoic acid (9z)-, isooctyl ester" "agn-pc-03ldps" "6-methylheptyl (e)-octadec-9-enoate" "9-octadecenoic acid(9z)-, isooctyl ester" );
gibbsFormation
{
    dHf_298   -785310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1203.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64550.0
    phase     gas;
}
