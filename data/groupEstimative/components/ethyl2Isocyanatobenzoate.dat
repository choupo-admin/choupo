/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-isocyanatobenzoate  (C10H9NO3, CAS 76393-16-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Isocyanatobenzoate;
formula     C10H9NO3;
CAS         76393-16-3;
InChIKey    HXVGHXDQGUPUKY-UHFFFAOYSA-N;
MW          191.186;      // g/mol [origin=calculated method=formula-sum]
Tc          803.24;      // K   [origin=predictive method=joback]
Pc          31.456;      // bar [origin=predictive method=joback]
omega       0.7298;      // -   [origin=predictive method=lee-kesler]
Tb          584.95;      // K   [origin=predictive method=joback]
HvapTb      57731.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-carboethoxyphenyl isocyanate" "2-ethoxycarbonylphenyl isocyanate" "2-(ethoxycarbonyl)phenyl isocyanate" "2-carbethoxyphenyl isocyanate" "2-isocyanatobenzoic acid ethyl ester" "benzoic acid,2-isocyanato-, ethyl ester" "2-(ethoxycarbonyl)phenylisocyanate; 2-isocyanatobenzoic acid ethyl ester; ethyl 2-isocyanatobenzoate" );
// formation datum unavailable (element entropy missing): dHf_298=-347360.0 dGf_298=None
