/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorobenzylamine  (C7H8ClN, CAS 89-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorobenzylamine;
formula     C7H8ClN;
CAS         89-97-4;
InChIKey    KDDNKZCVYQDGKE-UHFFFAOYSA-N;
MW          141.598;      // g/mol [origin=calculated method=formula-sum]
Tc          735.35;      // K   [origin=predictive method=joback]
Pc          41.409;      // bar [origin=predictive method=joback]
omega       0.4726;      // -   [origin=predictive method=lee-kesler]
Tb          501.38;      // K   [origin=predictive method=joback]
HvapTb      49140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.699 0.5991 -0.00038496 9.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH2NH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-chlorophenyl)methanamine" "o-chlorobenzylamine" "benzenemethanamine, 2-chloro-" "2-chlorobenzenemethanamine" "o-chlorobenzyl amine" "benzylamine, o-chloro-" "(2-chlorophenyl)methylamine" "2-chloro benzylamine" "ocam" "2-chloro-benzylamine" "(2-chlorophenyl)-methyl-amine" "benzylamine, o-chloro- (8ci)" );
standardThermochemistry
{
    dHf_298   55300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=165360.0
}
