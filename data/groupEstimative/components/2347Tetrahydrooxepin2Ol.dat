/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,7-tetrahydrooxepin-2-ol  (C6H10O2, CAS 41793-28-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2347Tetrahydrooxepin2Ol;
formula     C6H10O2;
CAS         41793-28-6;
InChIKey    JXMYHVAOAIWGIK-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          683.09;      // K   [origin=predictive method=joback]
Pc          47.892;      // bar [origin=predictive method=joback]
omega       0.6849;      // -   [origin=predictive method=lee-kesler]
Tb          478.99;      // K   [origin=predictive method=joback]
HvapTb      51032.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.9 0.6613 -0.00034098 4.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group OH; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -345460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     341.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180990.0
}
