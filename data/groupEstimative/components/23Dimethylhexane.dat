/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethylhexane  (C8H18, CAS 584-94-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethylhexane;
formula     C8H18;
CAS         584-94-1;
InChIKey    JXPOLSKBTUYKJB-UHFFFAOYSA-N;
MW          114.232;      // g/mol [origin=calculated method=formula-sum]
Tc          552.93;      // K   [origin=predictive method=joback]
Pc          25.767;      // bar [origin=predictive method=joback]
omega       0.3408;      // -   [origin=predictive method=lee-kesler]
Tb          381.76;      // K   [origin=predictive method=joback]
HvapTb      32626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.748 0.77568 -0.0004178 8.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexane, 2,3-dimethyl-" "2,3-dimethyl hexane" "agn-pc-04t8rv" "hexane, 2,3-dimethyl- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -219010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11600.0
}
