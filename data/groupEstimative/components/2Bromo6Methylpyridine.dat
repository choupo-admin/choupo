/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-6-methylpyridine  (C6H6BrN, CAS 5315-25-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo6Methylpyridine;
formula     C6H6BrN;
CAS         5315-25-3;
InChIKey    SOHDPICLICFSOP-UHFFFAOYSA-N;
MW          172.025;      // g/mol [origin=calculated method=formula-sum]
Tc          737.72;      // K   [origin=predictive method=joback]
Pc          50.442;      // bar [origin=predictive method=joback]
omega       0.4111;      // -   [origin=predictive method=lee-kesler]
Tb          488.40;      // K   [origin=predictive method=joback]
HvapTb      44533.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.92 0.50738 -0.00034742 9.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C5H3N; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group Br; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-6-methyl-pyridine" "6-bromo-2-picoline" "6-bromo-2-methylpyridine" "2-bromo-6-picoline" "2-bromo-6-methyl-pyridine" "2-brom-6-methylpyridin" "2-bromo-6-methyl pyridine" "agn-pc-0dbetm" "tpc-py078" "pyridine, 2-bromo-6-methyl-" "b243" );
gibbsFormation
{
    dHf_298   117010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     340.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=193790.0
    phase     gas;
}
