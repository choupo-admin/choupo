/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-thiophenedicarboxylic acid  (C6H4O4S, CAS 4282-31-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25ThiophenedicarboxylicAcid;
formula     C6H4O4S;
CAS         4282-31-9;
InChIKey    YCGAZNXXGKTASZ-UHFFFAOYSA-N;
MW          172.154;      // g/mol [origin=calculated method=formula-sum]
Tc          951.48;      // K   [origin=predictive method=joback]
Pc          53.513;      // bar [origin=predictive method=joback]
omega       1.1366;      // -   [origin=predictive method=lee-kesler]
Tb          703.96;      // K   [origin=predictive method=joback]
HvapTb      71564.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.19 0.61701 -0.00048978 1.513e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 2; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 2; } { group COOH; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thiophene-2,5-dicarboxylic acid" "2,5-dicarboxythiophene" "2,5-thiophene dicarboxylic acid" "2,5-thiophenedicarboxylicacid, monomethyl ester (9ci); 5-(methoxycarbonyl)thiophene-2-carboxylic acid;methyl thiophene-2,5-dicarboxylate" );
standardThermochemistry
{
    dHf_298   -649010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-563400.0
}
