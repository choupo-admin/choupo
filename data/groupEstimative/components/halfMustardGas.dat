/*--------------------------------*- Choupo -*-----------------------*\
  Component: half mustard gas  (C4H9ClOS, CAS 693-30-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        halfMustardGas;
formula     C4H9ClOS;
CAS         693-30-1;
InChIKey    ZGFPMAMREQRRRB-UHFFFAOYSA-N;
MW          140.625;      // g/mol [origin=calculated method=formula-sum]
Tc          679.44;      // K   [origin=predictive method=joback]
Pc          42.719;      // bar [origin=predictive method=joback]
omega       0.8084;      // -   [origin=predictive method=lee-kesler]
Tb          489.51;      // K   [origin=predictive method=joback]
HvapTb      52379.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.034 0.41899 -0.0002044 2.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 1; } { group CH2Cl; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group Cl; count 1; } { group OH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-chloroethylsulfanyl)ethanol" "hemisulfur mustard" "half sulfur mustard" "mustard chlorohydrin" "sulfur half-mustard" "ethanol, 2-(2-chloro-ethylthio)-" "2-hydroxyethyl 2-chloroethyl sulfide" "2-chloroethyl 2-hydroxyethyl sulfide" "sulfide, 2-chloroethyl 2-hydroxyethyl" "ethanol, 2-((2-chloroethyl)thio)-" "2-((2-chloroethyl)thio)ethanol" "beta-chloroethyl beta-hydroxyethyl sulfide" );
gibbsFormation
{
    dHf_298   -251990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-132830.0
    phase     gas;
}
