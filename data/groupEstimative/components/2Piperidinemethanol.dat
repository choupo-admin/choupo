/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-piperidinemethanol  (C6H13NO, CAS 3433-37-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Piperidinemethanol;
formula     C6H13NO;
CAS         3433-37-2;
InChIKey    PRAYXGYYVXRDDW-UHFFFAOYSA-N;
MW          115.176;      // g/mol [origin=calculated method=formula-sum]
Tc          698.62;      // K   [origin=predictive method=joback]
Pc          46.151;      // bar [origin=predictive method=joback]
omega       0.7615;      // -   [origin=predictive method=lee-kesler]
Tb          497.16;      // K   [origin=predictive method=joback]
HvapTb      52816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.959 0.7165 -0.0003534 4.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group OH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperidin-2-ylmethanol" "2-piperidinylmethanol" "2-hydroxymethylpiperidine" "piperidin-2-yl-methanol" "2-(hydroxymethyl)piperidine" "2-piperidylmethan-1-ol" "2- piperidinemethanol" "prayxgyyvxrddw-uhfffaoysa-" "l338" "2-piperidine-methanol (2-(hydroxymethyl)-piperidine)" );
standardThermochemistry
{
    dHf_298   -227270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-25020.0
}
