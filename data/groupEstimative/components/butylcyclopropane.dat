/*--------------------------------*- Choupo -*-----------------------*\
  Component: butylcyclopropane  (C7H14, CAS 930-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylcyclopropane;
formula     C7H14;
CAS         930-57-4;
InChIKey    SXZVSSJONMPJMN-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          544.75;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       0.3178;      // -   [origin=predictive method=lee-kesler]
Tb          366.50;      // K   [origin=predictive method=joback]
HvapTb      31089.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.717 0.81972 -0.0005772 1.714e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropane, butyl-" "butane, 1-cyclopropyl-" "butyl-cyclopropane" );
standardThermochemistry
{
    dHf_298   -115010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     338.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=68810.0
}
