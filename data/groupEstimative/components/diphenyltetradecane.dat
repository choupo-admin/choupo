/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenyltetradecane  (C26H38, CAS 97392-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diphenyltetradecane;
formula     C26H38;
CAS         97392-71-7;
InChIKey    RHISRDQWNQEBBY-UHFFFAOYSA-N;
MW          350.59;      // g/mol [origin=calculated method=formula-sum]
Tc          1054.41;      // K   [origin=predictive method=joback]
Pc          10.792;      // bar [origin=predictive method=joback]
omega       0.8576;      // -   [origin=predictive method=lee-kesler]
Tb          847.40;      // K   [origin=predictive method=joback]
HvapTb      77634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.238 2.32192 -0.0014562 3.487e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyltetradecylbenzene" "1,1-diphenyltetradecane" "benzene, 1,1'-tetradecylidenebis-" );
standardThermochemistry
{
    dHf_298   -112190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     946.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=390420.0
}
