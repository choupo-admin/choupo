/*--------------------------------*- Choupo -*-----------------------*\
  Component: octylamine  (C8H19N, CAS 111-86-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octylamine;
formula     C8H19N;
CAS         111-86-4;
InChIKey    IOQPZZOEVPZRBK-UHFFFAOYSA-N;
MW          129.247;      // g/mol [origin=calculated method=formula-sum]
Tc          632.54;      // K   [origin=predictive method=joback]
Pc          26.874;      // bar [origin=predictive method=joback]
omega       0.5745;      // -   [origin=predictive method=lee-kesler]
Tb          455.17;      // K   [origin=predictive method=joback]
HvapTb      44043.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.107 0.82572 -0.0004548 9.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octan-1-amine" "n-octylamine" "1-octanamine" "1-aminooctane" "1-octylamine" "caprylamine" "caprylylamine" "armeen 8" "armeen 8d" "n-octylamine, mono-" "monoctylamine" "1-octanamin" );
gibbsFormation
{
    dHf_298   -174660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82930.0
    phase     gas;
}
