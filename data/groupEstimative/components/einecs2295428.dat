name        einecs2295428;
formula     C19H28O4;
CAS         6600-31-3;
InChIKey    WKTJXDHLMJKSGI-UHFFFAOYSA-N;
MW          320.429;      // g/mol [origin=calculated method=formula-sum]
Tc          1079.20;      // K   [origin=predictive method=joback]
Pc          20.680;      // bar [origin=predictive method=joback]
omega       0.7150;      // -   [origin=predictive method=lee-kesler]
Tb          809.94;      // K   [origin=predictive method=joback]
HvapTb      76596.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-230.89 2.4482 -0.00177636 5.266e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 4; } { group C; count 1; } { group CH=CH; count 2; } { group FCH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
