/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-decanol, 9,10-dibromo-  (C10H20Br2O, CAS 114838-32-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Decanol910Dibromo;
formula     C10H20Br2O;
CAS         114838-32-3;
InChIKey    BJSFINRBAUPBKA-UHFFFAOYSA-N;
MW          316.077;      // g/mol [origin=calculated method=formula-sum]
Tc          837.92;      // K   [origin=predictive method=joback]
Pc          26.570;      // bar [origin=predictive method=joback]
omega       1.2082;      // -   [origin=predictive method=lee-kesler]
Tb          652.46;      // K   [origin=predictive method=joback]
HvapTb      67015.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.789 1.0701 -0.0006966 1.853e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH; count 1; } { group OH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group CH; count 1; } { group Br; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10-bis(bromanyl)decan-1-ol" "9,10-dibromo decanol" );
standardThermochemistry
{
    dHf_298   -354580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     688.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77300.0
}
