/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-((2,2,3-trimethyl-3-cyclopenten-1-yl)methyl)-3-methyl-2-cyclohexen-1-ol  (C16H26O, CAS 71820-54-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5223Trimethyl3Cyclopenten1YlMethyl3Methyl2Cyclohexen1Ol;
formula     C16H26O;
CAS         71820-54-7;
InChIKey    CEWHOLRJBQGQBR-KKUMJFAQSA-N;
MW          234.383;      // g/mol [origin=calculated method=formula-sum]
Tc          899.01;      // K   [origin=predictive method=joback]
Pc          19.648;      // bar [origin=predictive method=joback]
omega       0.8872;      // -   [origin=predictive method=lee-kesler]
Tb          691.87;      // K   [origin=predictive method=joback]
HvapTb      68714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.409 1.81958 -0.00134768 4.383e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 3; } { group C; count 1; } { group CH=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,5r)-3-methyl-5-[[(1r)-2,2,3-trimethylcyclopent-3-en-1-yl]methyl]cyclohex-2-en-1-ol" );
gibbsFormation
{
    dHf_298   -343820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=27770.0
    phase     gas;
}
