/*--------------------------------*- Choupo -*-----------------------*\
  Component: dmes  (C20H24, CAS 34983-45-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dmes;
formula     C20H24;
CAS         34983-45-4;
InChIKey    AOSATGCSEIIZPL-FMQUCBEESA-N;
MW          264.412;      // g/mol [origin=calculated method=formula-sum]
Tc          955.48;      // K   [origin=predictive method=joback]
Pc          16.742;      // bar [origin=predictive method=joback]
omega       0.6639;      // -   [origin=predictive method=lee-kesler]
Tb          724.44;      // K   [origin=predictive method=joback]
HvapTb      66108.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.068 1.64688 -0.00108092 2.79e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-[(e)-4-(4-methylphenyl)hex-3-en-3-yl]benzene" "trans-4,4'-dimethyl-alpha,alpha'-diethylstilbene" "stilbene, alpha,alpha'-diethyl-4,4'-dimethyl-, (e)-" );
standardThermochemistry
{
    dHf_298   91630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     694.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=386200.0
}
