/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-3-chloropropane  (C3H6BrCl, CAS 109-70-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo3Chloropropane;
formula     C3H6BrCl;
CAS         109-70-6;
InChIKey    MFESCIUQSIBMSM-UHFFFAOYSA-N;
MW          157.435;      // g/mol [origin=calculated method=formula-sum]
Tc          567.50;      // K   [origin=predictive method=joback]
Pc          46.026;      // bar [origin=predictive method=joback]
omega       0.3367;      // -   [origin=predictive method=lee-kesler]
Tb          371.83;      // K   [origin=predictive method=joback]
HvapTb      33092.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.243 0.3338 -0.0002312 6.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2Cl; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-3-chloranyl-propane" "1-chloro-3-bromopropane" "propane, 1-bromo-3-chloro-" "3-bromopropyl chloride" "trimethylene chlorobromide" "3-chloropropyl bromide" "3-chloro-1-bromopropane" "3-bromo-1-chloropropane" ".omega.-chlorobromopropane" "trimethylene bromide chloride" "1,3-chlorbromopropane" "omega-chlorobromopropane" );
standardThermochemistry
{
    dHf_298   -94660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23230.0
}
