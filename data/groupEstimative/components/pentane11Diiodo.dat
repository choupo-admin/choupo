/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentane, 1,1-diiodo-  (C5H10I2, CAS 66688-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentane11Diiodo;
formula     C5H10I2;
CAS         66688-35-5;
InChIKey    QGZMPDWGZXYBQS-UHFFFAOYSA-N;
MW          323.935;      // g/mol [origin=calculated method=formula-sum]
Tc          744.79;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       0.3185;      // -   [origin=predictive method=lee-kesler]
Tb          499.84;      // K   [origin=predictive method=joback]
HvapTb      45082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.043 0.56272 -0.0004142 1.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(iodanyl)pentane" "1,1-diiodopentane" "diiodopentane" );
gibbsFormation
{
    dHf_298   1930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105020.0
    phase     gas;
}
