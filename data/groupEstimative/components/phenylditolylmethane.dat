/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylditolylmethane  (C21H20, CAS 67881-18-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylditolylmethane;
formula     C21H20;
CAS         67881-18-9;
InChIKey    FXEMFMZCJUUOPF-UHFFFAOYSA-N;
MW          272.391;      // g/mol [origin=calculated method=formula-sum]
Tc          1027.13;      // K   [origin=predictive method=joback]
Pc          19.527;      // bar [origin=predictive method=joback]
omega       0.6699;      // -   [origin=predictive method=lee-kesler]
Tb          769.64;      // K   [origin=predictive method=joback]
HvapTb      70104.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.0 1.64904 -0.00108132 2.649e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 13; } { group AC; count 2; } { group ACCH3; count 2; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 13; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-2-[(2-methylphenyl)-phenyl-methyl]benzene" "1,1'-(phenylmethanediyl)bis(2-methylbenzene)" "benzene, 1,1'-(phenylmethylene)bis(methyl-" "benzene, 1,1'-(phenylmethylene)bis[methyl-" "ditolylphenylmethane;phenylditolylmethane" "benzene,1,1'-(phenylmethylene)bis[methyl-" "1-methyl-2-[(2-methylphenyl)-phenylmethyl]benzene" );
gibbsFormation
{
    dHf_298   204600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=441470.0
    phase     gas;
}
