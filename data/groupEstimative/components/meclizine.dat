/*--------------------------------*- Choupo -*-----------------------*\
  Component: meclizine  (C25H27ClN2, CAS 569-65-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        meclizine;
formula     C25H27ClN2;
CAS         569-65-3;
InChIKey    OCJYIGYOJCODJL-UHFFFAOYSA-N;
MW          390.955;      // g/mol [origin=calculated method=formula-sum]
Tc          1192.32;      // K   [origin=predictive method=joback]
Pc          16.000;      // bar [origin=predictive method=joback]
omega       0.9626;      // -   [origin=predictive method=lee-kesler]
Tb          939.15;      // K   [origin=predictive method=joback]
HvapTb      87873.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-164.429 2.45142 -0.00177372 4.939e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 13; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2N; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group Cl; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(4-chlorophenyl)-phenyl-methyl]-4-[(3-methylphenyl)methyl]piperazine" "meclozine" "chiclida" "bonine" "parachloramine" "navicalm" "sea-legs" "bonadettes" "histamethine" "histamethizine" "histametizine" "histametizyne" );
gibbsFormation
{
    dHf_298   328340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     826.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=741140.0
    phase     gas;
}
