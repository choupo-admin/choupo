/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(methylthio)hexanal  (C7H14OS, CAS 38433-74-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethylthioHexanal;
formula     C7H14OS;
CAS         38433-74-8;
InChIKey    VIVJHDGDCOQORO-UHFFFAOYSA-N;
MW          146.248;      // g/mol [origin=calculated method=formula-sum]
Tc          674.36;      // K   [origin=predictive method=joback]
Pc          31.175;      // bar [origin=predictive method=joback]
omega       0.5418;      // -   [origin=predictive method=lee-kesler]
Tb          476.76;      // K   [origin=predictive method=joback]
HvapTb      44325.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.843 0.64363 -0.000313 4.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CHO; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group OdCH_al; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylsulfanylhexanal" "hexanal,3-(methylthio)-;" );
gibbsFormation
{
    dHf_298   -236800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60780.0
    phase     gas;
}
