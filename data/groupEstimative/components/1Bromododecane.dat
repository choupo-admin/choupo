/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromododecane  (C12H25Br, CAS 143-15-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromododecane;
formula     C12H25Br;
CAS         143-15-7;
InChIKey    PBLNBZIONSLZBU-UHFFFAOYSA-N;
MW          249.236;      // g/mol [origin=calculated method=formula-sum]
Tc          714.99;      // K   [origin=predictive method=joback]
Pc          18.887;      // bar [origin=predictive method=joback]
omega       0.7127;      // -   [origin=predictive method=lee-kesler]
Tb          540.32;      // K   [origin=predictive method=joback]
HvapTb      48741.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.171 1.18202 -0.0007004 1.657e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyldodecane" "dodecyl bromide" "lauryl bromide" "n-dodecyl bromide" "dodecane, 1-bromo-" "bromododecane" "1-bromo-dodecane" "1-bromo-n-dodecane" "dodecane, 1-bromo-;lauryl bromide;1-bromo-dodecane;" );
gibbsFormation
{
    dHf_298   -264680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     674.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64480.0
    phase     gas;
}
