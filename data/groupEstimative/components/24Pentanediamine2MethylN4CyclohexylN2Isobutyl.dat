/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-pentanediamine, 2-methyl-n4-cyclohexyl-n2-isobutyl-  (C16H34N2, CAS 67990-16-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Pentanediamine2MethylN4CyclohexylN2Isobutyl;
formula     C16H34N2;
CAS         67990-16-3;
InChIKey    ZYRAUVPYOBILQC-UHFFFAOYSA-N;
MW          254.462;      // g/mol [origin=calculated method=formula-sum]
Tc          883.61;      // K   [origin=predictive method=joback]
Pc          16.155;      // bar [origin=predictive method=joback]
omega       0.7756;      // -   [origin=predictive method=lee-kesler]
Tb          681.46;      // K   [origin=predictive method=joback]
HvapTb      62439.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.518 1.936 -0.001203 2.807e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group CH2NH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n4-cyclohexyl-2-methyl-n2-(2-methylpropyl)pentane-2,4-diamine" "2,4-pentanediamine, n4-cyclohexyl-2-methyl-n2-(2-methylpropyl)-" "n-cyclohexyl-n'-isobutyl-2,4-diamino-2-methylpentane" "4-n-cyclohexyl-2-methyl-2-n-(2-methylpropyl)pentane-2,4-diamine" );
standardThermochemistry
{
    dHf_298   -231620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     772.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=285030.0
}
