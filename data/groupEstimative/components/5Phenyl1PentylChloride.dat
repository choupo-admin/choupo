/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-phenyl-1-pentyl chloride  (C11H15Cl, CAS 15733-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Phenyl1PentylChloride;
formula     C11H15Cl;
CAS         15733-63-8;
InChIKey    UXJLBVYYDZDPBV-UHFFFAOYSA-N;
MW          182.691;      // g/mol [origin=calculated method=formula-sum]
Tc          722.85;      // K   [origin=predictive method=joback]
Pc          25.508;      // bar [origin=predictive method=joback]
omega       0.4966;      // -   [origin=predictive method=lee-kesler]
Tb          515.39;      // K   [origin=predictive method=joback]
HvapTb      46741.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.125 0.9767 -0.0006262 1.542e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-chloranylpentylbenzene" "(5-chloropentyl)benzene" "1-chloro-5-phenylpentane" "5-chloropentylbenzene" "benzene,(5-chloropentyl)-" "5-phenylpentylchloride" "benzene, (5-chloropentyl)-" "5-phenylpentyl chloride" "(5-chloropentyl)benzene;1-chloro-5-phenylpentane;5-phenyl-1-chloropentane;5-phenylpentyl chloride;" );
gibbsFormation
{
    dHf_298   -49580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=142220.0
    phase     gas;
}
