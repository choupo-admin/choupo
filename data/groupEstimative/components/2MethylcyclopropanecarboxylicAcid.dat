/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylcyclopropanecarboxylic acid  (C5H8O2, CAS 29555-02-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylcyclopropanecarboxylicAcid;
formula     C5H8O2;
CAS         29555-02-0;
InChIKey    AYEGPMGNMOIHDL-UHFFFAOYSA-N;
MW          100.117;      // g/mol [origin=calculated method=formula-sum]
Tc          668.13;      // K   [origin=predictive method=joback]
Pc          43.742;      // bar [origin=predictive method=joback]
omega       0.5617;      // -   [origin=predictive method=lee-kesler]
Tb          461.58;      // K   [origin=predictive method=joback]
HvapTb      43492.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.36 0.65402 -0.0004856 1.474e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylcyclopropane-1-carboxylic acid" "cyclopropanecarboxylic acid, 2-methyl-" "cyclopropanecarboxylicacid, 2-methyl-" "2-methyl-1-cyclopropanecarboxylic acid" "cis-2-methylcyclopropanecarboxylic acid" "trans-2-methylcyclopropanecarboxylic acid" "(1r,2s)-2-methylcyclopropanecarboxylic acid" );
gibbsFormation
{
    dHf_298   -444340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     271.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-299650.0
    phase     gas;
}
