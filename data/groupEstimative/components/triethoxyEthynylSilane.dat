/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethoxy(ethynyl)silane  (C8H16O3Si, CAS 5700-28-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H16O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        triethoxyEthynylSilane;
formula     C8H16O3Si;
CAS         5700-28-7;
InChIKey    CDZULFMEYKOAEF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          188.298;      // g/mol [origin=calculated method=formula-sum]
Tc          622.63;      // K   [origin=predictive method=joback]
Pc          24.777;      // bar [origin=predictive method=joback]
omega       0.4525;      // -   [origin=predictive method=lee-kesler]
Tb          441.42;      // K   [origin=predictive method=joback]
HvapTb      40784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (126.713 0.27416 0.00034047 -2.7921e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2O; count 3; } { group CH_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group tCH; count 1; } { group tC; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "silane, triethoxyethynyl-" "ethynyltriethoxysilane" "triethoxyethynylsilane" "acetyleneorthosiliconic acid triethyl ester" );
gibbsFormation
{
    dHf_298   -424830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180210.0
    phase     gas;
}
