/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,9-nonanediol  (C9H20O2, CAS 3937-56-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        19Nonanediol;
formula     C9H20O2;
CAS         3937-56-2;
InChIKey    ALVZNPYWJMLXKV-UHFFFAOYSA-N;
MW          160.257;      // g/mol [origin=calculated method=formula-sum]
Tc          746.83;      // K   [origin=predictive method=joback]
Pc          27.759;      // bar [origin=predictive method=joback]
omega       1.4063;      // -   [origin=predictive method=lee-kesler]
Tb          589.88;      // K   [origin=predictive method=joback]
HvapTb      68986.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.289 0.9268 -0.0005266 1.155e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonane-1,9-diol" "nonamethylene glycol" "1,9-dihydroxynonane" ".alpha.,.omega.-nonanediol" "alpha,omega-nonanediol" "r903" );
gibbsFormation
{
    dHf_298   -533550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-248740.0
    phase     gas;
}
