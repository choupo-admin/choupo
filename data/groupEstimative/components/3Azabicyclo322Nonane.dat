/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-azabicyclo[3.2.2]nonane  (C8H15N, CAS 283-24-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Azabicyclo322Nonane;
formula     C8H15N;
CAS         283-24-9;
InChIKey    LICHZOBEUWVYSY-UHFFFAOYSA-N;
MW          125.215;      // g/mol [origin=calculated method=formula-sum]
Tc          684.33;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.3495;      // -   [origin=predictive method=lee-kesler]
Tb          457.48;      // K   [origin=predictive method=joback]
HvapTb      40502.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.31 1.0234 -0.000652 1.6e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azabicyclo(3.2.2)nonane" );
standardThermochemistry
{
    dHf_298   -43520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     340.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=189390.0
}
