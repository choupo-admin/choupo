/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-amino-2,3,5,6-tetrafluorobenzamide  (C7H4F4N2O, CAS 1548-74-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Amino2356Tetrafluorobenzamide;
formula     C7H4F4N2O;
CAS         1548-74-9;
InChIKey    CAERPAFTLPIDJT-UHFFFAOYSA-N;
MW          208.114;      // g/mol [origin=calculated method=formula-sum]
Tc          813.91;      // K   [origin=predictive method=joback]
Pc          37.317;      // bar [origin=predictive method=joback]
omega       1.0103;      // -   [origin=predictive method=lee-kesler]
Tb          607.35;      // K   [origin=predictive method=joback]
HvapTb      61522.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (78.82 0.4354 -0.0001867 8.46e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group ACNH2; count 1; } { group ACF; count 4; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group F; count 4; } { group CdO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanyl-2,3,5,6-tetrakis(fluoranyl)benzamide" "4-aminotetrafluorobenzamide" "benzamide,4-amino-2,3,5,6-tetrafluoro-" "4-amino-2,3,5,6-tetrafluorobenzamide 97%" );
gibbsFormation
{
    dHf_298   -838070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-702940.0
    phase     gas;
}
