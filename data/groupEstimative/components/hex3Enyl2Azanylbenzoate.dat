/*--------------------------------*- Choupo -*-----------------------*\
  Component: hex-3-enyl 2-azanylbenzoate  (C13H17NO2, CAS 65405-76-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hex3Enyl2Azanylbenzoate;
formula     C13H17NO2;
CAS         65405-76-7;
InChIKey    VZWCCPAVZNSCEO-UHFFFAOYSA-N;
MW          219.284;      // g/mol [origin=calculated method=formula-sum]
Tc          880.99;      // K   [origin=predictive method=joback]
Pc          24.124;      // bar [origin=predictive method=joback]
omega       0.8344;      // -   [origin=predictive method=lee-kesler]
Tb          663.61;      // K   [origin=predictive method=joback]
HvapTb      65476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.817 1.12752 -0.00068016 1.454e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-hex-3-enyl] 2-aminobenzoate" "3-hexen-1-ol, 1-(2-aminobenzoate), (3z)-" "agn-pc-01zif3" "3-hexen-1-ol,1-(2-aminobenzoate), (3z)-" "3-hexen-1-ol,2-aminobenzoate, (3z)- (9ci); 3-hexen-1-ol, 2-aminobenzoate, (z)-;cis-3-hexenyl anthranilate" );
standardThermochemistry
{
    dHf_298   -252860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2340.0
}
