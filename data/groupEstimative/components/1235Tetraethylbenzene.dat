/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,5-tetraethylbenzene  (C14H22, CAS 38842-05-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1235Tetraethylbenzene;
formula     C14H22;
CAS         38842-05-6;
InChIKey    QJEXLOSCNXHBAX-UHFFFAOYSA-N;
MW          190.33;      // g/mol [origin=calculated method=formula-sum]
Tc          758.70;      // K   [origin=predictive method=joback]
Pc          19.304;      // bar [origin=predictive method=joback]
omega       0.5792;      // -   [origin=predictive method=lee-kesler]
Tb          561.54;      // K   [origin=predictive method=joback]
HvapTb      51020.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.846 1.07648 -0.00056788 1.062e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 2; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene, 1,2,3,5-tetraethyl-" );
gibbsFormation
{
    dHf_298   -130170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=150520.0
    phase     gas;
}
