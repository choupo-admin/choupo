/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-isobutyl-1-cyclohexene  (C10H18, CAS 3983-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Isobutyl1Cyclohexene;
formula     C10H18;
CAS         3983-03-7;
InChIKey    NQIVPQHOBXSALG-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          661.61;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       0.3611;      // -   [origin=predictive method=lee-kesler]
Tb          456.32;      // K   [origin=predictive method=joback]
HvapTb      39158.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.349 0.99284 -0.00058004 1.244e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methylpropyl)cyclohexene" "cyclohexene,1-(2-methylpropyl)-" "cyclohexene, 1-(2-methylpropyl)-" "cyclohexene,1-isobutyl- (6ci,7ci,8ci); 1-isobutyl-1-cyclohexene; 1-isobutylcyclohexene" );
gibbsFormation
{
    dHf_298   -134040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83370.0
    phase     gas;
}
