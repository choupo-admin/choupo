/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-nonen-2-yne, (e)-  (C9H14, CAS 53497-79-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Nonen2YneE;
formula     C9H14;
CAS         53497-79-3;
InChIKey    AIDMRHRNBMILQM-CMDGGOBGSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          614.32;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       0.3258;      // -   [origin=predictive method=lee-kesler]
Tb          418.68;      // K   [origin=predictive method=joback]
HvapTb      37738.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.917 0.72904 -0.00045746 1.2228e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH=CH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-non-4-en-2-yne" "non-2-yn-4-ene, (e)-" );
gibbsFormation
{
    dHf_298   160430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=307920.0
    phase     gas;
}
