/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-dimethylpiperidine  (C7H15N, CAS 4045-30-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dimethylpiperidine;
formula     C7H15N;
CAS         4045-30-1;
InChIKey    IECMOFZIMWVOAS-UHFFFAOYSA-N;
MW          113.204;      // g/mol [origin=calculated method=formula-sum]
Tc          649.50;      // K   [origin=predictive method=joback]
Pc          38.340;      // bar [origin=predictive method=joback]
omega       0.2975;      // -   [origin=predictive method=lee-kesler]
Tb          428.10;      // K   [origin=predictive method=joback]
HvapTb      37212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.15 1.06944 -0.00091 3.468e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperidine, 4,4-dimethyl-" "4,4-dimethyl-piperidine" "4-methyl-4-pipecoline" );
standardThermochemistry
{
    dHf_298   -80440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114730.0
}
