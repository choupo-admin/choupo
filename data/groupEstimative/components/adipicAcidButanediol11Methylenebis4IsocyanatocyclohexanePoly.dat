name        adipicAcidButanediol11Methylenebis4IsocyanatocyclohexanePoly;
formula     C25H42N2O8;
CAS         68958-79-2;
InChIKey    NVSGSFCKVQJZFO-UHFFFAOYSA-N;
MW          498.617;      // g/mol [origin=calculated method=formula-sum]
Tc          1818.55;      // K   [origin=predictive method=joback]
Pc          11.632;      // bar [origin=predictive method=joback]
omega       0.6095;      // -   [origin=predictive method=lee-kesler]
Tb          1412.44;      // K   [origin=predictive method=joback]
HvapTb      158434.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 5; } { group OH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group dCd; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group OH; count 2; } { group COOH; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,1-diol;hexanedioic acid;1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane" "hexanedioic acid, polymer with butanediol and 1,1'-methylenebis(4-isocyanatocyclohexane)" );
