/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethane-1,2-diyl bis(2-hydroxybenzoate)  (C16H14O6, CAS 20210-97-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethane12DiylBis2Hydroxybenzoate;
formula     C16H14O6;
CAS         20210-97-3;
InChIKey    FDXIVRQIMPXJGE-UHFFFAOYSA-N;
MW          302.282;      // g/mol [origin=calculated method=formula-sum]
Tc          1141.99;      // K   [origin=predictive method=joback]
Pc          31.420;      // bar [origin=predictive method=joback]
omega       1.4255;      // -   [origin=predictive method=lee-kesler]
Tb          896.72;      // K   [origin=predictive method=joback]
HvapTb      96604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.488 1.5656 -0.00123252 3.822e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyphenyl)carbonyloxyethyl 2-oxidanylbenzoate" "ethylene disalicylate" "2-[(2-hydroxybenzoyl)oxy]ethyl salicylate" "2-(2-hydroxybenzoyl)oxyethyl 2-hydroxybenzoate" "benzoic acid,2-hydroxy-, 1,1'-(1,2-ethanediyl) ester" "benzoicacid, 2-hydroxy-, 1,2-ethanediyl ester (9ci); salicylic acid, ethylene ester(6ci,8ci); ethylene glycol, disalicylate (8ci); ethylene disalicylate" );
gibbsFormation
{
    dHf_298   -889690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-621320.0
    phase     gas;
}
