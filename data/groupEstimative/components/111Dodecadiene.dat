/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,11-dodecadiene  (C12H22, CAS 5876-87-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Dodecadiene;
formula     C12H22;
CAS         5876-87-9;
InChIKey    IYPLTVKTLDQUGG-UHFFFAOYSA-N;
MW          166.308;      // g/mol [origin=calculated method=formula-sum]
Tc          634.55;      // K   [origin=predictive method=joback]
Pc          19.136;      // bar [origin=predictive method=joback]
omega       0.5453;      // -   [origin=predictive method=lee-kesler]
Tb          467.52;      // K   [origin=predictive method=joback]
HvapTb      40966.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.002 1.1038 -0.0006748 1.664e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodeca-1,11-diene" "dodecadiene, 1,11-" "1,11-dodecadiene;1,11-dodecadiene 99+%" );
standardThermochemistry
{
    dHf_298   -40150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     614.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225840.0
}
