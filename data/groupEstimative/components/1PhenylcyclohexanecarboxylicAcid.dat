/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylcyclohexanecarboxylic acid  (C13H16O2, CAS 1135-67-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PhenylcyclohexanecarboxylicAcid;
formula     C13H16O2;
CAS         1135-67-7;
InChIKey    QXXHHHWXFHPNOS-UHFFFAOYSA-N;
MW          204.269;      // g/mol [origin=calculated method=formula-sum]
Tc          943.31;      // K   [origin=predictive method=joback]
Pc          31.002;      // bar [origin=predictive method=joback]
omega       0.7431;      // -   [origin=predictive method=lee-kesler]
Tb          689.02;      // K   [origin=predictive method=joback]
HvapTb      63250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-153.83 1.6247 -0.0014008 5.046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylcyclohexane-1-carboxylic acid" "1-phenyl-1-cyclohexanecarboxylic acid" "qxxhhhwxfhpnos-uhfffaoysa-" "cyclohexanecarboxylicacid, 1-phenyl-" "cyclohexanecarboxylic acid, 1-phenyl-" "[bicyclohexyl]-1-carboxylicacid (6ci,7ci)" );
gibbsFormation
{
    dHf_298   -355830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-153960.0
    phase     gas;
}
