/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexenal  (C6H10O, CAS 4440-65-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexenal;
formula     C6H10O;
CAS         4440-65-7;
InChIKey    GXANMBISFKBPEX-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          571.25;      // K   [origin=predictive method=joback]
Pc          35.942;      // bar [origin=predictive method=joback]
omega       0.4197;      // -   [origin=predictive method=lee-kesler]
Tb          389.70;      // K   [origin=predictive method=joback]
HvapTb      35628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.348 0.56832 -0.0003794 1.055e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-3-enal" "3-hexenal, (3z)-" "hex-3-enal;" "agn-pc-0d5h6p" "3-hexenal,(z)- (8ci); 3-hexenal, cis- (7ci); (z)-3-hexenal; (z)-hex-3-enal;3-(z)-hexenal; cis-3-hexenal" );
standardThermochemistry
{
    dHf_298   -135530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19660.0
}
