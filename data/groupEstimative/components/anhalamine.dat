/*--------------------------------*- Choupo -*-----------------------*\
  Component: anhalamine  (C11H15NO3, CAS 643-60-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anhalamine;
formula     C11H15NO3;
CAS         643-60-7;
InChIKey    DVQVXTPSJBCBJI-UHFFFAOYSA-N;
MW          209.245;      // g/mol [origin=calculated method=formula-sum]
Tc          920.27;      // K   [origin=predictive method=joback]
Pc          36.290;      // bar [origin=predictive method=joback]
omega       0.9439;      // -   [origin=predictive method=lee-kesler]
Tb          682.59;      // K   [origin=predictive method=joback]
HvapTb      69328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.42 0.97404 -0.00060764 1.587e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 1; } { group AC; count 3; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3O; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group O; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,7-dimethoxy-1,2,3,4-tetrahydroisoquinolin-8-ol" "n-demethylanhalidine" "8-isoquinolinol, 1,2,3,4-tetrahydro-6,7-dimethoxy-" );
standardThermochemistry
{
    dHf_298   -385210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-95290.0
}
