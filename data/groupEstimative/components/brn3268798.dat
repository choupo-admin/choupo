/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3268798  (C18H16, CAS 24684-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3268798;
formula     C18H16;
CAS         24684-41-1;
InChIKey    XZIIXGOAGARMHM-UHFFFAOYSA-N;
MW          232.326;      // g/mol [origin=calculated method=formula-sum]
Tc          958.68;      // K   [origin=predictive method=joback]
Pc          24.459;      // bar [origin=predictive method=joback]
omega       0.6882;      // -   [origin=predictive method=lee-kesler]
Tb          707.41;      // K   [origin=predictive method=joback]
HvapTb      64088.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.25 1.56692 -0.00126748 4.186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 7; } { group AC; count 4; } { group ACCH3; count 1; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 7; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-methyl-16,17-dihydro-15h-cyclopenta[a]phenanthrene" "11-methyl-15,16-dihydro-17h-cyclopenta(a)phenanthrene" "15h-cyclopenta(a)phenanthrene, 16,17-dihydro-11-methyl-" "17h-cyclopenta(a)phenanthrene, 15,16-dihydro-11-methyl-" );
gibbsFormation
{
    dHf_298   251080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=456330.0
    phase     gas;
}
