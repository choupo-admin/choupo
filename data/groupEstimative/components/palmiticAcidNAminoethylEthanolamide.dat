/*--------------------------------*- Choupo -*-----------------------*\
  Component: palmitic acid, n-(aminoethyl)ethanolamide  (C20H42N2O2, CAS 25065-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        palmiticAcidNAminoethylEthanolamide;
formula     C20H42N2O2;
CAS         25065-63-8;
InChIKey    YAGLIFQYQDBQLD-UHFFFAOYSA-N;
MW          342.568;      // g/mol [origin=calculated method=formula-sum]
Tc          1108.75;      // K   [origin=predictive method=joback]
Pc          11.437;      // bar [origin=predictive method=joback]
omega       1.0630;      // -   [origin=predictive method=lee-kesler]
Tb          903.59;      // K   [origin=predictive method=joback]
HvapTb      96411.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.062 2.06222 -0.0011731 2.4856e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group OH; count 1; } { group CH2NH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group OH; count 1; } { group CdO; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[2-(2-hydroxyethylamino)ethyl]hexadecanamide" "n-{2-[(2-hydroxyethyl)amino]ethyl}hexadecanamide" "n-(2-((2-hydroxyethyl)amino)ethyl)hexadecan-1-amide" "hexadecanamide, n-(2-((2-hydroxyethyl)amino)ethyl)-" "hexadecanamide, n-[2-[(2-hydroxyethyl)amino]ethyl]-" "n-[2-[(2-hydroxyethyl)amino]ethyl]hexadecan-1-amide" "hexadecanamide,n-[2-[(2-hydroxyethyl)amino]ethyl]-" );
standardThermochemistry
{
    dHf_298   -614000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1093.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=30560.0
}
