/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-allyl-4-(4-methylpent-3-en-1-yl)cyclohex-3-ene-1-carbaldehyde  (C16H24O, CAS 66310-72-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Allyl44Methylpent3En1YlCyclohex3Ene1Carbaldehyde;
formula     C16H24O;
CAS         66310-72-3;
InChIKey    YITNGWUNAUULCK-UHFFFAOYSA-N;
MW          232.367;      // g/mol [origin=calculated method=formula-sum]
Tc          849.51;      // K   [origin=predictive method=joback]
Pc          18.740;      // bar [origin=predictive method=joback]
omega       0.6735;      // -   [origin=predictive method=lee-kesler]
Tb          638.99;      // K   [origin=predictive method=joback]
HvapTb      57530.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.637 1.79674 -0.00148244 5.306e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=C; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-methylpent-3-enyl)-1-prop-2-enyl-cyclohex-3-ene-1-carbaldehyde" "1-allyl-4-(4-methyl-3-pentenyl)cyclohex-3-ene-1-carbaldehyde" "3-cyclohexene-1-carboxaldehyde, 4-(4-methyl-3-pentenyl)-1-(2-propenyl)-" "3-cyclohexene-1-carboxaldehyde, 4-(4-methyl-3-penten-1-yl)-1-(2-propen-1-yl)-" "4-(4-methylpent-3-enyl)-1-prop-2-enylcyclohex-3-ene-1-carbaldehyde" );
standardThermochemistry
{
    dHf_298   -110420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     778.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=183120.0
}
