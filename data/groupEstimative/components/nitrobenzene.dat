/*--------------------------------*- Choupo -*-----------------------*\
  Component: nitrobenzene  (C6H5NO2, CAS 98-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nitrobenzene;
formula     C6H5NO2;
CAS         98-95-3;
InChIKey    LQNUZADURLCDLV-UHFFFAOYSA-N;
MW          123.111;      // g/mol [origin=calculated method=formula-sum]
Tc          769.56;      // K   [origin=predictive method=joback]
Pc          47.497;      // bar [origin=predictive method=joback]
omega       0.4406;      // -   [origin=predictive method=lee-kesler]
Tb          515.40;      // K   [origin=predictive method=joback]
HvapTb      47817.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.98 0.59426 -0.0004122 1.055e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACNO2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NO2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nitrobenzol" "benzene, nitro-" "oil of mirbane" "nitro-benzene" "essence of mirbane" "mirbane oil" "nitrobenzeen" "mononitrobenzene" "oil of myrbane" "nitrobenzen" "p-nitrobenzene" "1-nitrobenzene" );
gibbsFormation
{
    dHf_298   58600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147600.0
    phase     gas;
}
