/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2,4,5-trifluorobenzene  (C6H2BrF3, CAS 327-52-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo245Trifluorobenzene;
formula     C6H2BrF3;
CAS         327-52-6;
InChIKey    DVTULTINXNWGJY-UHFFFAOYSA-N;
MW          210.98;      // g/mol [origin=calculated method=formula-sum]
Tc          645.43;      // K   [origin=predictive method=joback]
Pc          40.364;      // bar [origin=predictive method=joback]
omega       0.4892;      // -   [origin=predictive method=lee-kesler]
Tb          442.47;      // K   [origin=predictive method=joback]
HvapTb      37196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.89 0.39 -0.00025328 6.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group Br; count 1; } { group ACF; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2,4,5-tris(fluoranyl)benzene" "2,4,5-trifluorobromobenzene" "fr bf df ee" "2-bromo-1,4,5-trifluorobenzene" "benzene, 1-bromo-2,4,5-trifluoro-" "5-bromo-1,2,4-trifluorobenzene" "1-bromo-2,4,5-trifluoro-benzene" "2,4,5-trifluoro bromo benzene;2,4,5-trifluoro bromobenzene;" );
standardThermochemistry
{
    dHf_298   -527050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-486950.0
}
