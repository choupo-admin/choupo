/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetic acid, 2-propenyl ester, polymer with ethenylbenzene and 2-propen-1-ol  (C16H22O3, CAS 70776-40-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aceticAcid2PropenylEsterPolymerWithEthenylbenzeneAnd2Propen1;
formula     C16H22O3;
CAS         70776-40-8;
InChIKey    DULFERUCIWCLFF-UHFFFAOYSA-N;
MW          262.349;      // g/mol [origin=calculated method=formula-sum]
Tc          937.99;      // K   [origin=predictive method=joback]
Pc          17.714;      // bar [origin=predictive method=joback]
omega       0.9934;      // -   [origin=predictive method=lee-kesler]
Tb          735.60;      // K   [origin=predictive method=joback]
HvapTb      76150.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.802 0.95172 -5.27e-05 -2.248e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 3; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 3; } { group dCH; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenylbenzene;prop-2-en-1-ol;prop-2-enyl ethanoate" "acetic acid, 2-propen-1-yl ester, polymer with ethenylbenzene and 2-propen-1-ol" "styrene, allyl alcohol, allyl acetate polymer" );
standardThermochemistry
{
    dHf_298   -453500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     976.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-196940.0
}
