/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-2-phenylacetamide  (C10H13NO, CAS 18925-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyl2Phenylacetamide;
formula     C10H13NO;
CAS         18925-69-4;
InChIKey    FHVMATOIMUHQRC-UHFFFAOYSA-N;
MW          163.22;      // g/mol [origin=calculated method=formula-sum]
Tc          733.27;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.5771;      // -   [origin=predictive method=lee-kesler]
Tb          521.39;      // K   [origin=predictive method=joback]
HvapTb      48919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.439 0.97084 -0.0006453 1.6166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-2-phenyl-ethanamide" "n,n-dimethylphenylacetamide" "benzeneacetamide, n,n-dimethyl-" "n,n-dimethylbenzeneacetamide" "phenyl-n,n-dimethylacetamide" "phenylacetic acid n,n-dimethylamide" "acetamide, n,n-dimethyl-2-phenyl-" "benzeneacetamide,n,n-dimethyl-" "acetamide,n-dimethyl-2-phenyl-" "acetamide, n,n-dimethyl-2-phenyl- (8ci)" );
gibbsFormation
{
    dHf_298   -58250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127590.0
    phase     gas;
}
