/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,10-trioxaadamantane  (C7H10O3, CAS 281-32-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2410Trioxaadamantane;
formula     C7H10O3;
CAS         281-32-3;
InChIKey    VUIDKQHXAUDXKD-UHFFFAOYSA-N;
MW          142.154;      // g/mol [origin=calculated method=formula-sum]
Tc          680.40;      // K   [origin=predictive method=joback]
Pc          42.441;      // bar [origin=predictive method=joback]
omega       0.4463;      // -   [origin=predictive method=lee-kesler]
Tb          460.43;      // K   [origin=predictive method=joback]
HvapTb      44308.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.42 1.0764 -0.0008741 2.858e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH-O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 4; } { group O_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "vuidkqhxaudxkd-uhfffaoysa-" "2,4,10-trioxatricyclo[3.3.1.13,7]decane" "2,4,10-trioxatricyclo-[3.3.1.13,7]decane" "2,4,10-trioxatricyclo(3.3.1.1(3,7))decane" "2,4,10-trioxatricyclo[3.3.1.13,7]decane(9ci)" "2,4,10-trioxaadamantane(8ci); orthoformic acid, cyclic 1,3,5-cyclohexanetriyl ester (7ci);1,3,5-cyclohexanetriol, cyclic orthoformate; 2,8,9-trioxaadamantane;orthoformic acid, cyclic ester with 1,3,5-cyclohexanetriol" );
standardThermochemistry
{
    dHf_298   -391910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     -18.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87860.0
}
