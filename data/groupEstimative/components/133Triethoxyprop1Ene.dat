/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,3-triethoxyprop-1-ene  (C9H18O3, CAS 125072-37-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        133Triethoxyprop1Ene;
formula     C9H18O3;
CAS         125072-37-9;
InChIKey    ATAQLIDYIFWHFW-UHFFFAOYSA-N;
MW          174.24;      // g/mol [origin=calculated method=formula-sum]
Tc          650.79;      // K   [origin=predictive method=joback]
Pc          23.270;      // bar [origin=predictive method=joback]
omega       0.6096;      // -   [origin=predictive method=lee-kesler]
Tb          476.50;      // K   [origin=predictive method=joback]
HvapTb      42428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.343 0.69516 -0.0002198 -2.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group dCH; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propene, 1,3,3-triethoxy-, (1z)-" "(z)-1,3,3-triethoxyprop-1-ene" );
gibbsFormation
{
    dHf_298   -513810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-212320.0
    phase     gas;
}
