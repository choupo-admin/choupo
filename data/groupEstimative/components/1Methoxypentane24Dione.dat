/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxypentane-2,4-dione  (C6H10O3, CAS 6290-50-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxypentane24Dione;
formula     C6H10O3;
CAS         6290-50-2;
InChIKey    RZCMFVQMQKCVEN-UHFFFAOYSA-N;
MW          130.143;      // g/mol [origin=calculated method=formula-sum]
Tc          655.93;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.6393;      // -   [origin=predictive method=lee-kesler]
Tb          467.04;      // K   [origin=predictive method=joback]
HvapTb      44852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.652 0.45464 -0.0001542 -1.268e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group O; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2,4-pentanedione" "2,4-pentanedione,1-methoxy-" "1-methoxy-2,4-pentandione" );
standardThermochemistry
{
    dHf_298   -524550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-363200.0
}
