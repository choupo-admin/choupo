/*--------------------------------*- Choupo -*-----------------------*\
  Component: carbestrol  (C17H22O3, CAS 1755-52-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carbestrol;
formula     C17H22O3;
CAS         1755-52-8;
InChIKey    VJKVHUZOVAWKEB-UHFFFAOYSA-N;
MW          274.36;      // g/mol [origin=calculated method=formula-sum]
Tc          1040.78;      // K   [origin=predictive method=joback]
Pc          19.169;      // bar [origin=predictive method=joback]
omega       1.0003;      // -   [origin=predictive method=lee-kesler]
Tb          812.15;      // K   [origin=predictive method=joback]
HvapTb      77684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.359 1.38866 -0.00070556 1.007e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COOH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-4-(4-methoxyphenyl)-2-methyl-cyclohex-3-ene-1-carboxylic acid" "3-ethyl-4-(p-methoxyphenyl)-2-methyl-3-cyclohexene-1-carboxylic acid" "3-cyclohexene-1-carboxylic acid, 3-ethyl-4-(p-methoxyphenyl)-2-methyl-" "3-ethyl-4-(4-methoxyphenyl)-2-methylcyclohex-3-ene-1-carboxylic acid" "2-methyl-3-ethyl-4-p-methoxyphenyl-delta(sup 3)-cyclohexene carboxylic acid" "3-cyclohexene-1-carboxylic acid, 3-ethyl-4-(4-methoxyphenyl)-2-methyl-" "3-cyclohexene-1-carboxylicacid, 3-ethyl-4-(4-methoxyphenyl)-2-methyl-" "3-cyclohexene-1-carboxylic acid, 3-ethyl-4-(4-methoxyphenyl)-2-methyl- (9ci)" "6-ethyl-4'-methoxy-5-methyl-2,3,4,5-tetrahydro-[1,1'-biphenyl]-4-carboxylic acid" );
gibbsFormation
{
    dHf_298   -582820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-226430.0
    phase     gas;
}
