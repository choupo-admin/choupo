/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromopentachloroethane  (C2BrCl5, CAS 79504-02-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromopentachloroethane;
formula     C2BrCl5;
CAS         79504-02-2;
InChIKey    YVDACVUIWDTEJU-UHFFFAOYSA-N;
MW          281.176;      // g/mol [origin=calculated method=formula-sum]
Tc          752.44;      // K   [origin=predictive method=joback]
Pc          45.164;      // bar [origin=predictive method=joback]
omega       0.3240;      // -   [origin=predictive method=lee-kesler]
Tb          492.21;      // K   [origin=predictive method=joback]
HvapTb      45814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.77 0.5176 -0.000602 2.355e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl2; count 1; } { group CCl3; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group Cl; count 5; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-1,1,2,2,2-pentakis(chloranyl)ethane" "1-bromo-1,1,2,2,2-pentachloroethane" );
standardThermochemistry
{
    dHf_298   -154480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-73690.0
}
