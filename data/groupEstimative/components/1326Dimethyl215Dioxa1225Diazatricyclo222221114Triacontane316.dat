/*--------------------------------*- Choupo -*-----------------------*\
  Component: 13,26-dimethyl-2,15-dioxa-12,25-diazatricyclo[22.2.2.211,14]triacontane-3,16-dione  (C28H50N2O4, CAS 3463-92-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1326Dimethyl215Dioxa1225Diazatricyclo222221114Triacontane316;
formula     C28H50N2O4;
CAS         3463-92-1;
InChIKey    AMSCMASJCYVAIF-UHFFFAOYSA-N;
MW          478.718;      // g/mol [origin=calculated method=formula-sum]
Tc          1397.24;      // K   [origin=predictive method=joback]
Pc          10.207;      // bar [origin=predictive method=joback]
omega       0.9006;      // -   [origin=predictive method=lee-kesler]
Tb          1132.58;      // K   [origin=predictive method=joback]
HvapTb      107988.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-157.87 2.73744 -0.0008946 -1.53e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group CH; count 4; } { group CH2COO; count 2; } { group CHNH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 18; } { group CH_ring; count 6; } { group COO; count 2; } { group NH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "13,26-dimethyl-2,15-dioxa-12,25-diazatricyclotriacontane-3,16-dione" "12,25-diaza-13,26-dimethyl-2,15-dioxatricyclo[22.2.2.2<11,14>]triacontane-3,16-dione" );
standardThermochemistry
{
    dHf_298   -1127530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1277.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-307020.0
}
