/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonyl methacrylate  (C13H24O2, CAS 2696-43-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonylMethacrylate;
formula     C13H24O2;
CAS         2696-43-7;
InChIKey    LKEDKQWWISEKSW-UHFFFAOYSA-N;
MW          212.333;      // g/mol [origin=calculated method=formula-sum]
Tc          723.24;      // K   [origin=predictive method=joback]
Pc          17.160;      // bar [origin=predictive method=joback]
omega       0.7274;      // -   [origin=predictive method=lee-kesler]
Tb          551.82;      // K   [origin=predictive method=joback]
HvapTb      51349.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.798 1.16394 -0.000614 1.056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, nonyl ester" "n-nonyl methacrylate" "nonyl 2-methyl-2-propenoate" );
gibbsFormation
{
    dHf_298   -513290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-172500.0
    phase     gas;
}
