/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-acetylpyridine  (C7H7NO, CAS 350-03-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Acetylpyridine;
formula     C7H7NO;
CAS         350-03-8;
InChIKey    WEGYGNROSJDEIW-UHFFFAOYSA-N;
MW          121.139;      // g/mol [origin=calculated method=formula-sum]
Tc          730.43;      // K   [origin=predictive method=joback]
Pc          44.742;      // bar [origin=predictive method=joback]
omega       0.4637;      // -   [origin=predictive method=lee-kesler]
Tb          494.01;      // K   [origin=predictive method=joback]
HvapTb      46408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.96 0.59568 -0.00037876 9.036e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group CdO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pyridin-3-ylethanone" "3-acetopyridine" "ethanone, 1-(3-pyridinyl)-" "methyl 3-pyridyl ketone" "1-(3-pyridinyl)ethanone" "ketone, methyl 3-pyridyl" "3-pyridyl methyl ketone" "beta-acetylpyridine" "1-(pyridin-3-yl)ethanone" "methyl pyridyl ketone" "pyridine, 3-acetyl-" "1-(pyridin-3-yl)ethan-1-one" );
standardThermochemistry
{
    dHf_298   -31070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     361.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=68600.0
}
