/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1380048  (C12H12O5, CAS 13988-26-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1380048;
formula     C12H12O5;
CAS         13988-26-6;
InChIKey    LZEGUDFMCKJMPX-UHFFFAOYSA-N;
MW          236.223;      // g/mol [origin=calculated method=formula-sum]
Tc          902.90;      // K   [origin=predictive method=joback]
Pc          29.537;      // bar [origin=predictive method=joback]
omega       0.8233;      // -   [origin=predictive method=lee-kesler]
Tb          669.16;      // K   [origin=predictive method=joback]
HvapTb      65134.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.91 1.051 -0.00057286 7.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 2; } { group FCH2O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6,9-trioxabicyclo[9.4.0]pentadeca-1(15),11,13-triene-2,10-dione" "2,5,8-benzotrioxacycloundecin-1,9-dione, 3,4,6,7-tetrahydro-" "phthalic acid, cyclic oxydiethylene ester" "3,4,6,7-tetrahydro-2,5,8-benzotrioxacycloundecin-1,9-dione" "3,4,6,7-tetrahydro-2,5,8-benzotrioxacycloundecine-1,9-dione" "phthalicacid, cyclic oxydiethylene ester (8ci);diethylene glycol, cyclic phthalate(8ci);diethylene glycol bisphthalate;" );
standardThermochemistry
{
    dHf_298   -751690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-509660.0
}
