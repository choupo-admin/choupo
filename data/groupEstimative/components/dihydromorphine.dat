/*--------------------------------*- Choupo -*-----------------------*\
  Component: dihydromorphine  (C17H21NO3, CAS 509-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dihydromorphine;
formula     C17H21NO3;
CAS         509-60-4;
InChIKey    IJVCSMSMFSCRME-KBQPJGBKSA-N;
MW          287.359;      // g/mol [origin=calculated method=formula-sum]
Tc          1084.59;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       1.4612;      // -   [origin=predictive method=lee-kesler]
Tb          855.65;      // K   [origin=predictive method=joback]
HvapTb      91302.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-254.77 2.60902 -0.00258798 1.0353e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group C; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH-O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,4ar,7s,7ar,12bs)-3-methyl-2,4,4a,5,6,7,7a,13-octahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-7,9-diol" "paramorphan" "hydromorphine" "paramorfan" "morphine, dihydro-" "6-alpha-hydromorphol" "7,8-dihydromorphine" "morphinan-3,6alpha-diol, 4,5alpha-epoxy-17-methyl-" "morphinan-3,6-alpha-diol, 4,5-alpha-epoxy-17-methyl-" "dihydromorfin" "7,8-dihydromorphin" "7,8-dihydromorphin [iupac]" );
gibbsFormation
{
    dHf_298   -282370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160530.0
    phase     gas;
}
