/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 4-propan-2-ylbenzoate  (C12H16O2, CAS 19024-50-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl4Propan2Ylbenzoate;
formula     C12H16O2;
CAS         19024-50-1;
InChIKey    MKVMNGIAVDCPOZ-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          772.54;      // K   [origin=predictive method=joback]
Pc          24.006;      // bar [origin=predictive method=joback]
omega       0.6027;      // -   [origin=predictive method=lee-kesler]
Tb          563.60;      // K   [origin=predictive method=joback]
HvapTb      52263.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.899 0.95656 -0.00050176 7.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, 4-isopropyl-, ethyl ester" "ethyl 4-(propan-2-yl)benzoate" );
standardThermochemistry
{
    dHf_298   -388510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     552.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-159870.0
}
