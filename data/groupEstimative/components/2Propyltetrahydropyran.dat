/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propyltetrahydropyran  (C8H16O, CAS 3857-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propyltetrahydropyran;
formula     C8H16O;
CAS         3857-17-8;
InChIKey    YHQBBDKFBJYMPJ-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          630.22;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.3561;      // -   [origin=predictive method=lee-kesler]
Tb          429.14;      // K   [origin=predictive method=joback]
HvapTb      38341.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.668 0.88292 -0.0004785 8.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propyloxane" "2-propyltetrahydro-2h-pyran" "2-n-propyltetrahydropyran" );
gibbsFormation
{
    dHf_298   -286130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-45190.0
    phase     gas;
}
