/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-carvomenthenol  (C10H18O, CAS 562-74-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Carvomenthenol;
formula     C10H18O;
CAS         562-74-3;
InChIKey    WRYLYDPHFGVWKC-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          744.33;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.7418;      // -   [origin=predictive method=lee-kesler]
Tb          544.07;      // K   [origin=predictive method=joback]
HvapTb      54377.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.11 1.29226 -0.00108764 4.04e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-1-propan-2-yl-cyclohex-3-en-1-ol" "p-menth-1-en-4-ol" "4-terpineol" "terpinen-4-ol" "1-terpinen-4-ol" "terpinenol-4" "terpene-4-ol" "terpinene-4-ol" "3-cyclohexen-1-ol, 4-methyl-1-(1-methylethyl)-" "4-terpinenol" "1-menthene-4-ol" "1-p-menthen-4-ol" );
gibbsFormation
{
    dHf_298   -291370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-66650.0
    phase     gas;
}
