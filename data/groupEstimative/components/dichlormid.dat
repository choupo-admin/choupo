/*--------------------------------*- Choupo -*-----------------------*\
  Component: dichlormid  (C8H11Cl2NO, CAS 37764-25-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dichlormid;
formula     C8H11Cl2NO;
CAS         37764-25-3;
InChIKey    YRMLFORXOOIJDR-UHFFFAOYSA-N;
MW          208.082;      // g/mol [origin=calculated method=formula-sum]
Tc          713.33;      // K   [origin=predictive method=joback]
Pc          27.498;      // bar [origin=predictive method=joback]
omega       0.6268;      // -   [origin=predictive method=lee-kesler]
Tb          516.73;      // K   [origin=predictive method=joback]
HvapTb      49233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.402 0.8392 -0.0005951 1.6466e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group CHCl2; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group Cl; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)-n,n-bis(prop-2-enyl)ethanamide" "n,n-diallyldichloroacetamide" "dichloromid" "n,n-diallyl-2,2-dichloroacetamide" "acetamide, 2,2-dichloro-n,n-di-2-propenyl-" "acetamide, n,n-diallyl-2,2-dichloro-" "n,n-diallyl-2,3-dichloroacetamide" "2,2-dichloro-n,n-di-2-propenylacetamide" "2,2-dichloro-n,n-bis(prop-2-enyl)acetamide" "acetamide, 2,2-dichloro-n,n-di-2-propen-1-yl-" "yrmlforxooijdr-uhfffaoysa-" "2,2-dichloro-n,n-diprop-2-enylacetamide" );
gibbsFormation
{
    dHf_298   -39400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147720.0
    phase     gas;
}
