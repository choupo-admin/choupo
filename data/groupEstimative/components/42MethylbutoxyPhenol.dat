/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2-methylbutoxy)phenol  (C11H16O2, CAS 67599-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        42MethylbutoxyPhenol;
formula     C11H16O2;
CAS         67599-20-6;
InChIKey    GCQBIYCSSJYFJX-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          797.40;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       0.7167;      // -   [origin=predictive method=lee-kesler]
Tb          580.56;      // K   [origin=predictive method=joback]
HvapTb      57392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.118 1.06724 -0.00075436 2.23e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 4-(2-methylbutoxy)-" "4-(2-methylbutoxy)benzenol" "4-(2-methyl-butoxy)benzenol" "4-(2'-methyl-1'-butoxy)phenol" );
standardThermochemistry
{
    dHf_298   -348650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-107910.0
}
