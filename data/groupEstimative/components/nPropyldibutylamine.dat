/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-propyldibutylamine  (C11H25N, CAS 36874-77-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nPropyldibutylamine;
formula     C11H25N;
CAS         36874-77-8;
InChIKey    VEBPYKMCKZTFPJ-UHFFFAOYSA-N;
MW          171.328;      // g/mol [origin=calculated method=formula-sum]
Tc          624.31;      // K   [origin=predictive method=joback]
Pc          19.304;      // bar [origin=predictive method=joback]
omega       0.6026;      // -   [origin=predictive method=lee-kesler]
Tb          463.72;      // K   [origin=predictive method=joback]
HvapTb      42123.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.802 1.17276 -0.0006872 1.571e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-butyl-n-propyl-butan-1-amine" "n-butyl-n-propyl-1-butanamine" "dibutyl-propyl-amine" "n-butyl-n-propylbutan-1-amine" "1-butanamine,n-butyl-n-propyl-" "1-butanamine, n-butyl-n-propyl-" "1-butanamine, n-butyl-n-propyl- (9ci)" );
gibbsFormation
{
    dHf_298   -202840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     600.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=152520.0
    phase     gas;
}
