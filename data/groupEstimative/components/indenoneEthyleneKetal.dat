/*--------------------------------*- Choupo -*-----------------------*\
  Component: indenone ethylene ketal  (C11H10O2, CAS 6710-43-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        indenoneEthyleneKetal;
formula     C11H10O2;
CAS         6710-43-6;
InChIKey    PGDSXGALIMPOPC-UHFFFAOYSA-N;
MW          174.199;      // g/mol [origin=calculated method=formula-sum]
Tc          813.71;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.4951;      // -   [origin=predictive method=lee-kesler]
Tb          558.66;      // K   [origin=predictive method=joback]
HvapTb      51486.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-145.83 1.459 -0.00148024 6.02e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro[1,3-dioxolane-2,1'-indene]" "indenone ethyl ene ketal" "spiro[1,3-dioxolane-2,1'-[1h]indene](9ci)" "spiro[1,3-dioxolane-2,1'-indene](6ci,8ci); 1h-inden-1-one, cyclic 1,2-ethanediyl acetal; inden-1-one ethyleneketal" );
standardThermochemistry
{
    dHf_298   -76510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     283.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113860.0
}
