/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(methylthio)-2-propanol  (C5H12OS2, CAS 31805-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BisMethylthio2Propanol;
formula     C5H12OS2;
CAS         31805-83-1;
InChIKey    BTQNSLFPJKRBQK-UHFFFAOYSA-N;
MW          152.27;      // g/mol [origin=calculated method=formula-sum]
Tc          748.88;      // K   [origin=predictive method=joback]
Pc          40.881;      // bar [origin=predictive method=joback]
omega       0.8361;      // -   [origin=predictive method=lee-kesler]
Tb          543.30;      // K   [origin=predictive method=joback]
HvapTb      56649.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.152 0.50752 -0.0002014 2.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group CH3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(methylsulfanyl)propan-2-ol" "2-propanol, 1,3-bis(methylthio)-" "1,3-bis(methylthio)propan-2-ol" "2-propanol,1,3-bis(methylthio)-" "1,3-bis(methylsulfanyl)-2-propanol" "1,3-bis(methylsulfanyl)-propan-2-ol" );
standardThermochemistry
{
    dHf_298   -220300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-81800.0
}
