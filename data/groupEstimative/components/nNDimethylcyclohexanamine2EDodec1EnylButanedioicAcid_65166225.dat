/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylcyclohexanamine;2-[(e)-dodec-1-enyl]butanedioic acid  (C24H45NO4, CAS 65166-22-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylcyclohexanamine2EDodec1EnylButanedioicAcid;
formula     C24H45NO4;
CAS         65166-22-5;
InChIKey    AHTKPOUIVSGITC-CALJPSDSSA-N;
MW          411.627;      // g/mol [origin=calculated method=formula-sum]
Tc          1319.66;      // K   [origin=predictive method=joback]
Pc          9.958;      // bar [origin=predictive method=joback]
omega       0.9532;      // -   [origin=predictive method=lee-kesler]
Tb          1076.85;      // K   [origin=predictive method=joback]
HvapTb      105682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.07 2.45116 -0.0012928 2.071e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 2; } { group CH=CH; count 1; } { group CH3N; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COOH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecenylsuccinic acid, compound with n,n-dimethylcyclohexylamine (1:1)" "butanedioic acid, 2-dodecenyl-, compd. with n,n-dimethylcyclohexanamine (1:1)" "succinic acid, dodecenyl-, compd. with n,n-dimethylcyclohexylamine (1:1)" );
gibbsFormation
{
    dHf_298   -1117060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1274.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-428370.0
    phase     gas;
}
