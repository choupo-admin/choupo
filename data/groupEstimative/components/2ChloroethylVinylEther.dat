/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloroethyl vinyl ether  (C4H7ClO, CAS 110-75-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroethylVinylEther;
formula     C4H7ClO;
CAS         110-75-8;
InChIKey    DNJRKFKAFWSXSE-UHFFFAOYSA-N;
MW          106.549;      // g/mol [origin=calculated method=formula-sum]
Tc          524.99;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.3162;      // -   [origin=predictive method=lee-kesler]
Tb          347.65;      // K   [origin=predictive method=joback]
HvapTb      30623.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.652 0.3074 -0.0001261 8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-ethenoxy-ethane" "(2-chloroethoxy)ethene" "ethene, (2-chloroethoxy)-" "ether, 2-chloroethyl vinyl" "2-vinyloxyethyl chloride" "vinyl 2-chloroethyl ether" "ethene, 2-chloroethoxy-" "2-chlorethyl vinyl ether" "ether, 2-chlorethyl vinyl" "beta-chloroethyl vinyl ether" "vinyl beta-chloroethyl ether" "2-chloro-1-vinyloxyethane" );
gibbsFormation
{
    dHf_298   -148420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-46290.0
    phase     gas;
}
