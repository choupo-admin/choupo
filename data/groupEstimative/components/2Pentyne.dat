/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pentyne  (C5H8, CAS 627-21-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Pentyne;
formula     C5H8;
CAS         627-21-4;
InChIKey    NKTDTMONXHODTI-UHFFFAOYSA-N;
MW          68.119;      // g/mol [origin=calculated method=formula-sum]
Tc          512.13;      // K   [origin=predictive method=joback]
Pc          42.275;      // bar [origin=predictive method=joback]
omega       0.1763;      // -   [origin=predictive method=lee-kesler]
Tb          323.00;      // K   [origin=predictive method=joback]
HvapTb      28876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.901 0.32904 -0.00015606 2.728e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-2-yne" "ethylmethylacetylene" "1-ethyl-2-methylacetylene" "2-pentyne(6ci,7ci,8ci,9ci)" );
gibbsFormation
{
    dHf_298   125770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     322.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=194020.0
    phase     gas;
}
