/*--------------------------------*- Choupo -*-----------------------*\
  Component: dl-beta-(4-methoxyphenyl)alaninol  (C10H15NO2, CAS 68208-24-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dlBeta4MethoxyphenylAlaninol;
formula     C10H15NO2;
CAS         68208-24-2;
InChIKey    WHWMCHUIUINGOD-UHFFFAOYSA-N;
MW          181.235;      // g/mol [origin=calculated method=formula-sum]
Tc          850.59;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       1.1216;      // -   [origin=predictive method=lee-kesler]
Tb          646.75;      // K   [origin=predictive method=joback]
HvapTb      70134.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.792 0.85402 -0.00045036 7.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 1; } { group CH3O; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azanyl-3-(4-methoxyphenyl)propan-1-ol" "3-amino-3-(4-methoxyphenyl)propan-1-ol" "3-amino-3-(4-methoxy-phenyl)-propan-1-ol" "3-(4-methoxyphenyl)-dl-beta-alaninol" "3-amino-3-(4-methoxyphenyl)-1-propanol" "3-amino-3-(p-methoxyphenyl)-1-propanol" "(s)-2-amino-3-(4-methoxyphenyl)propan-1-ol" "(r)-?(4-methoxyphenyl)alaninol" "aa261" "3-amino-3-(4-methoxyphenyl)-propan-1-ol" );
standardThermochemistry
{
    dHf_298   -280610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41710.0
}
