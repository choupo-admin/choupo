/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-methylprop-2-enyl)aniline  (C10H13N, CAS 22774-81-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2Methylprop2EnylAniline;
formula     C10H13N;
CAS         22774-81-8;
InChIKey    JCBGGIHYIHYKEX-UHFFFAOYSA-N;
MW          147.221;      // g/mol [origin=calculated method=formula-sum]
Tc          716.82;      // K   [origin=predictive method=joback]
Pc          31.315;      // bar [origin=predictive method=joback]
omega       0.4904;      // -   [origin=predictive method=lee-kesler]
Tb          501.81;      // K   [origin=predictive method=joback]
HvapTb      45976.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.999 0.93102 -0.0006252 1.63e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-methylprop-2-en-1-yl)aniline" "(2-methyl-allyl)-phenyl-amine" "aniline, n-(beta-methylallyl)-" "n-(2-methyl-2-propenyl)aniline" );
standardThermochemistry
{
    dHf_298   155910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=314410.0
}
