/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyethyl prop-2-enoate; 2-methylprop-2-enoic acid; styrene  (C17H22O5, CAS 65616-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyethylProp2Enoate2Methylprop2EnoicAcidStyrene;
formula     C17H22O5;
CAS         65616-74-2;
InChIKey    WCUQBORFDPSLKP-UHFFFAOYSA-N;
MW          306.358;      // g/mol [origin=calculated method=formula-sum]
Tc          1121.04;      // K   [origin=predictive method=joback]
Pc          17.684;      // bar [origin=predictive method=joback]
omega       1.3083;      // -   [origin=predictive method=lee-kesler]
Tb          903.87;      // K   [origin=predictive method=joback]
HvapTb      95620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.802 1.09742 -0.000182 -1.831e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenylbenzene;2-hydroxyethyl prop-2-enoate;2-methylprop-2-enoic acid" "2-propenoic acid, 2-methyl-, polymer with ethenylbenzene and 2-hydroxyethyl 2-propenoate" );
standardThermochemistry
{
    dHf_298   -834200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1064.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-540980.0
}
