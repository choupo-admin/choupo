/*--------------------------------*- Choupo -*-----------------------*\
  Component: quinuclidine  (C7H13N, CAS 100-76-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        quinuclidine;
formula     C7H13N;
CAS         100-76-5;
InChIKey    SBYHFKPVCBCYGV-UHFFFAOYSA-N;
MW          111.188;      // g/mol [origin=calculated method=formula-sum]
Tc          596.06;      // K   [origin=predictive method=joback]
Pc          40.364;      // bar [origin=predictive method=joback]
omega       0.3329;      // -   [origin=predictive method=lee-kesler]
Tb          394.62;      // K   [origin=predictive method=joback]
HvapTb      33526.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-125.71 1.1114 -0.000919 3.064e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azabicyclo[2.2.2]octane" "1,4-ethanopiperidine" "1,4-ethylenepiperidine" "quinuclidinehydrochloride" "1-azabicyclo(2.2.2)octane" "chinuclidin" "quinuclidine hcl" "abco" "azabicyclo[2.2.2]octane" "quinuclidinone hydrochloride" "4-azabicyclo[2.2.2]octane" "1-azoniabicyclo[2.2.2]octane" );
standardThermochemistry
{
    dHf_298   39500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     326.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=235950.0
}
