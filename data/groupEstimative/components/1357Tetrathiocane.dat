/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5,7-tetrathiocane  (C4H8S4, CAS 2373-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1357Tetrathiocane;
formula     C4H8S4;
CAS         2373-00-4;
InChIKey    QRGGVNODEBZTBI-UHFFFAOYSA-N;
MW          184.348;      // g/mol [origin=calculated method=formula-sum]
Tc          820.82;      // K   [origin=predictive method=joback]
Pc          55.858;      // bar [origin=predictive method=joback]
omega       0.2425;      // -   [origin=predictive method=lee-kesler]
Tb          515.20;      // K   [origin=predictive method=joback]
HvapTb      48828.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.75 0.57084 -0.0003122 4.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2S; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group S_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5,7-tetrathiacyclooctane" );
standardThermochemistry
{
    dHf_298   117490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=150200.0
}
