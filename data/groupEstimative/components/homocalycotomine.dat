/*--------------------------------*- Choupo -*-----------------------*\
  Component: homocalycotomine  (C13H19NO3, CAS 14029-02-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        homocalycotomine;
formula     C13H19NO3;
CAS         14029-02-8;
InChIKey    VIWOJGACEJJOIU-UHFFFAOYSA-N;
MW          237.299;      // g/mol [origin=calculated method=formula-sum]
Tc          941.76;      // K   [origin=predictive method=joback]
Pc          26.516;      // bar [origin=predictive method=joback]
omega       1.2355;      // -   [origin=predictive method=lee-kesler]
Tb          735.24;      // K   [origin=predictive method=joback]
HvapTb      77136.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.912 1.01694 -0.00043508 3.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH3O; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(6,7-dimethoxy-1,2,3,4-tetrahydroisoquinolin-1-yl)ethanol" "2-(6,7-dimethoxy-1,2,3,4-tetrahydroisoquinolyl)ethan-1-ol" "aa280" "1-isoquinolineethanol,1,2,3,4-tetrahydro-6,7-dimethoxy-" "2-(6,7-dimethoxy-1,2,3,4-tetrahydro-isoquinolin-1-yl)-ethanol" );
gibbsFormation
{
    dHf_298   -421750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68360.0
    phase     gas;
}
