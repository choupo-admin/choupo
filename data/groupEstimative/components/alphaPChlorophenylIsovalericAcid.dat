/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-(p-chlorophenyl)isovaleric acid  (C11H13ClO2, CAS 2012-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaPChlorophenylIsovalericAcid;
formula     C11H13ClO2;
CAS         2012-74-0;
InChIKey    VTJMSIIXXKNIDJ-UHFFFAOYSA-N;
MW          212.673;      // g/mol [origin=calculated method=formula-sum]
Tc          894.25;      // K   [origin=predictive method=joback]
Pc          27.995;      // bar [origin=predictive method=joback]
omega       0.8193;      // -   [origin=predictive method=lee-kesler]
Tb          665.00;      // K   [origin=predictive method=joback]
HvapTb      63791.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.59 0.97984 -0.00063816 1.563e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chlorophenyl)-3-methyl-butanoic acid" "2-(p-chlorophenyl)-3-methylbutyric acid" "2-(4-chlorophenyl)-3-methylbutyric acid" "2-(4-chlorophenyl)-3-methylbutanoic acid" "alpha-isopropyl-4-chlorophenylacetic acid" "alpha-isopropyl-p-chlorophenylacetic acid" ".alpha.-(p-chlorophenyl)isovaleric acid" "benzeneacetic acid, 4-chloro-alpha-(1-methylethyl)-" "butyric acid, 2-(p-chlorophenyl)-3-methyl-" "(r)-2-(4-chlorophenyl)-3-methylbutyric acid" "2-(4-chlorophenyl)-3-methylbutyricacid" "s829" );
standardThermochemistry
{
    dHf_298   -421880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-216200.0
}
