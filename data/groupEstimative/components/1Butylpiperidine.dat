/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butylpiperidine  (C9H19N, CAS 4945-48-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butylpiperidine;
formula     C9H19N;
CAS         4945-48-6;
InChIKey    AXWLKJWVMMAXBD-UHFFFAOYSA-N;
MW          141.258;      // g/mol [origin=calculated method=formula-sum]
Tc          627.45;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.4352;      // -   [origin=predictive method=lee-kesler]
Tb          437.91;      // K   [origin=predictive method=joback]
HvapTb      38237.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.407 1.14092 -0.0007612 2.01e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperidine, 1-butyl-" "n-butylpiperidine" "butylpiperidine" "1-butyl-piperidine" );
gibbsFormation
{
    dHf_298   -80740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=179940.0
    phase     gas;
}
