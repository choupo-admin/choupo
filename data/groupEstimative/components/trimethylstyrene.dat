/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylstyrene  (C11H14, CAS 769-57-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylstyrene;
formula     C11H14;
CAS         769-57-3;
InChIKey    ZTHJQCDAHYOPIK-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          702.32;      // K   [origin=predictive method=joback]
Pc          28.263;      // bar [origin=predictive method=joback]
omega       0.3504;      // -   [origin=predictive method=lee-kesler]
Tb          481.88;      // K   [origin=predictive method=joback]
HvapTb      42474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.58 0.98976 -0.0006942 1.962e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 5; } { group AC; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbut-2-en-2-ylbenzene" ".alpha.,.beta.,.beta.-trimethylstyrene" "alpha,beta,beta-trimethylstyrene" "(3-methylbut-2-en-2-yl)benzene" "(1,2-dimethyl-1-propenyl)benzene" "benzene, (1,2-dimethyl-1-propenyl)-" );
standardThermochemistry
{
    dHf_298   63800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=217270.0
}
