/*--------------------------------*- Choupo -*-----------------------*\
  Component: flecainide  (C17H20F6N2O3, CAS 54143-55-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        flecainide;
formula     C17H20F6N2O3;
CAS         54143-55-4;
InChIKey    DJBNUMBKLMJRSA-UHFFFAOYSA-N;
MW          414.346;      // g/mol [origin=calculated method=formula-sum]
Tc          1033.67;      // K   [origin=predictive method=joback]
Pc          15.885;      // bar [origin=predictive method=joback]
omega       1.1870;      // -   [origin=predictive method=lee-kesler]
Tb          831.34;      // K   [origin=predictive method=joback]
HvapTb      74731.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.807 1.7738 -0.00106842 2.1276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH2O; count 2; } { group CH2NH; count 1; } { group CF3; count 2; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group C; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 6; } { group O; count 2; } { group CdO; count 1; } { group NH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(piperidin-2-ylmethyl)-2,5-bis[2,2,2-tris(fluoranyl)ethoxy]benzamide" "flecaine" "tambocor" "flecainida" "flecainidum" "(+-)-flecainide" "flecainidum [inn-latin]" "n-(piperidin-2-ylmethyl)-2,5-bis(2,2,2-trifluoroethoxy)benzamide" "flecainide (inn)" "benzamide, n-(2-piperidinylmethyl)-2,5-bis(2,2,2-trifluoroethoxy)-" "flecainide [inn:ban]" "r818" );
standardThermochemistry
{
    dHf_298   -1606200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     865.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1115140.0
}
