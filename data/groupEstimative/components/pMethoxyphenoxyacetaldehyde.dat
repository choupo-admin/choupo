/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-methoxyphenoxyacetaldehyde  (C9H10O3, CAS 68426-09-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pMethoxyphenoxyacetaldehyde;
formula     C9H10O3;
CAS         68426-09-5;
InChIKey    CUMIGPPRWNRSMW-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          740.58;      // K   [origin=predictive method=joback]
Pc          33.567;      // bar [origin=predictive method=joback]
omega       0.6560;      // -   [origin=predictive method=lee-kesler]
Tb          530.68;      // K   [origin=predictive method=joback]
HvapTb      50106.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.501 0.56852 -0.00020096 -1.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methoxyphenoxy)ethanal" "(4-methoxyphenoxy)acetaldehyde" "acetaldehyde, (4-methoxyphenoxy)-" "acetaldehyde, 2-(4-methoxyphenoxy)-" "2-(4-methoxyphenoxy)acetaldehyde" );
standardThermochemistry
{
    dHf_298   -354050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-181840.0
}
