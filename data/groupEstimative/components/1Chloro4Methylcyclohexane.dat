/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-4-methylcyclohexane  (C7H13Cl, CAS 931-68-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro4Methylcyclohexane;
formula     C7H13Cl;
CAS         931-68-0;
InChIKey    KNEUJTFLMQRIFD-UHFFFAOYSA-N;
MW          132.631;      // g/mol [origin=calculated method=formula-sum]
Tc          622.50;      // K   [origin=predictive method=joback]
Pc          32.467;      // bar [origin=predictive method=joback]
omega       0.2561;      // -   [origin=predictive method=lee-kesler]
Tb          412.07;      // K   [origin=predictive method=joback]
HvapTb      35681.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.25 0.77122 -0.000403 6.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-methyl-cyclohexane" "cyclohexane, 1-chloro-4-methyl-, cis-" "cis-1-chloro-4-methylcyclohexane" "trans-1-chloro-4-methylcyclohexane" "cyclohexane, 1-chloro-4-methyl-, trans-" );
standardThermochemistry
{
    dHf_298   -169570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12870.0
}
