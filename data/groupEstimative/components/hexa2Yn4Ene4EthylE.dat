/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexa-2-yn-4-ene, 4-ethyl-, (e)-  (C8H12, CAS 70058-03-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexa2Yn4Ene4EthylE;
formula     C8H12;
CAS         70058-03-6;
InChIKey    GWVWHRMKPSRNDX-VMPITWQZSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          597.17;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.2541;      // -   [origin=predictive method=lee-kesler]
Tb          395.68;      // K   [origin=predictive method=joback]
HvapTb      35592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.699 0.63396 -0.00040536 1.1218e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH=C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-ethylhex-2-en-4-yne" "hexa-2-yn-4-ene, 4-ethyl-,(e)-" );
standardThermochemistry
{
    dHf_298   171280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=290950.0
}
