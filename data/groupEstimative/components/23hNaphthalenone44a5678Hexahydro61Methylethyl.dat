/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2(3h)-naphthalenone, 4,4a,5,6,7,8-hexahydro-6-(1-methylethyl)-  (C13H20O, CAS 34131-96-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23hNaphthalenone44a5678Hexahydro61Methylethyl;
formula     C13H20O;
CAS         34131-96-9;
InChIKey    XQKOWLJBFQBFMO-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          833.17;      // K   [origin=predictive method=joback]
Pc          23.982;      // bar [origin=predictive method=joback]
omega       0.5151;      // -   [origin=predictive method=lee-kesler]
Tb          599.12;      // K   [origin=predictive method=joback]
HvapTb      49859.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.07 1.22434 -0.00061764 8.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 3; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-propan-2-yl-4,4a,5,6,7,8-hexahydro-3h-naphthalen-2-one" "4,4a,5,6,7,8-hexahydro-6-isopropyl-2(3h)naphthalenone" "4,4a,5,6,7,8-hexahydro-6-(1-methylethyl)naphthalen-2(3h)-one" );
standardThermochemistry
{
    dHf_298   -287360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=26980.0
}
