/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-diphenylpentanoic acid  (C17H18O2, CAS 841-32-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DiphenylpentanoicAcid;
formula     C17H18O2;
CAS         841-32-7;
InChIKey    IVYXLCYENQNVHM-UHFFFAOYSA-N;
MW          254.329;      // g/mol [origin=calculated method=formula-sum]
Tc          1029.19;      // K   [origin=predictive method=joback]
Pc          23.114;      // bar [origin=predictive method=joback]
omega       0.9044;      // -   [origin=predictive method=lee-kesler]
Tb          784.20;      // K   [origin=predictive method=joback]
HvapTb      73856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.248 1.63762 -0.0012078 3.42e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diphenylpropylacetic acid" "2,2-diphenylvaleric acid" "valeric acid, 2,2-diphenyl-" "benzeneacetic acid, .alpha.-phenyl-.alpha.-propyl-" "valeric acid,2-diphenyl-" "benzeneacetic acid, a-phenyl-a-propyl-" "benzeneacetic acid, alpha-phenyl-alpha-propyl-" );
gibbsFormation
{
    dHf_298   -280170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23990.0
    phase     gas;
}
