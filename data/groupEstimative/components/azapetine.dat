/*--------------------------------*- Choupo -*-----------------------*\
  Component: azapetine  (C17H17N, CAS 146-36-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        azapetine;
formula     C17H17N;
CAS         146-36-1;
InChIKey    NYGHGTMKALXFIA-UHFFFAOYSA-N;
MW          235.33;      // g/mol [origin=calculated method=formula-sum]
Tc          904.63;      // K   [origin=predictive method=joback]
Pc          24.029;      // bar [origin=predictive method=joback]
omega       0.6848;      // -   [origin=predictive method=lee-kesler]
Tb          668.14;      // K   [origin=predictive method=joback]
HvapTb      60735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.519 1.6329 -0.00128682 4.045e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-prop-2-enyl-5,7-dihydrobenzo[d][2]benzazepine" "ilidar base" "6-allyl-6,7-dihydro-5h-dibenz(c,e)azepine" "azapetine (ban)" "azapetine [ban]" "5h-dibenz(c,e)azepine, 6,7-dihydro-6-allyl-" "5h-dibenz[c,e]azepine, 6,7-dihydro-6-(2-propenyl)-" "azapetina" "65-15-6 (hydrochloride)" "130-83-6 (phosphate[1:1])" "6-allil-6,7-diidro-5h-dibenzo(c,l)azepina" "6-allyl-6,7-dihydro-5h-benzo[d][2]benzazepine" );
gibbsFormation
{
    dHf_298   348170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=577000.0
    phase     gas;
}
