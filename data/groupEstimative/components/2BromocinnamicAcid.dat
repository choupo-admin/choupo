/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromocinnamic acid  (C9H7BrO2, CAS 7345-79-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromocinnamicAcid;
formula     C9H7BrO2;
CAS         7345-79-1;
InChIKey    OMHDOOAFLCMRFX-AATRIKPKSA-N;
MW          227.057;      // g/mol [origin=calculated method=formula-sum]
Tc          900.63;      // K   [origin=predictive method=joback]
Pc          41.303;      // bar [origin=predictive method=joback]
omega       0.8371;      // -   [origin=predictive method=lee-kesler]
Tb          653.01;      // K   [origin=predictive method=joback]
HvapTb      62123.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.29 0.8294 -0.00065776 2.06e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-(2-bromophenyl)prop-2-enoic acid" "o-bromocinnamic acid" "bromocinnamic acid,2-" "trans-2-bromocinnamic acid" "(2e)-3-(2-bromophenyl)prop-2-enoic acid" "3-(2-bromophenyl)acrylic acid" "3-(2-bromo-phenyl)-acrylic acid" "3-(2-bromophenyl)prop-2-enoic acid" "2-bromo cinnamic acid" "trans-2-bromocinnamic acid," "rarechem bk hc t304" "omhdooaflcmrfx-aatrikpksa-" );
standardThermochemistry
{
    dHf_298   -210750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-121690.0
}
