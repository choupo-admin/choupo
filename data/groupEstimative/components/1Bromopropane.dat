/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromopropane  (C3H7Br, CAS 106-94-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromopropane;
formula     C3H7Br;
CAS         106-94-5;
InChIKey    CYNYIHKIEHGYOZ-UHFFFAOYSA-N;
MW          122.993;      // g/mol [origin=calculated method=formula-sum]
Tc          520.33;      // K   [origin=predictive method=joback]
Pc          48.427;      // bar [origin=predictive method=joback]
omega       0.2805;      // -   [origin=predictive method=lee-kesler]
Tb          334.40;      // K   [origin=predictive method=joback]
HvapTb      28707.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.352 0.32702 -0.0002108 5.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylpropane" "n-propyl bromide" "propyl bromide" "propane, 1-bromo-" "propane, bromo-" "bromopropane" "1-bromo-propane" "3br" "bromomethylethane" "1-propyl bromide" "1-propyl bromide;ascusol mc;drysolv;leksol;propyl bromide;n-propyl bromide;" );
gibbsFormation
{
    dHf_298   -78920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11300.0
    phase     gas;
}
