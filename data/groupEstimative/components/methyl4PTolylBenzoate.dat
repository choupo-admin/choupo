/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-(p-tolyl)benzoate  (C15H14O2, CAS 49742-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4PTolylBenzoate;
formula     C15H14O2;
CAS         49742-56-5;
InChIKey    NSUWJKRQGXBISO-UHFFFAOYSA-N;
MW          226.275;      // g/mol [origin=calculated method=formula-sum]
Tc          902.03;      // K   [origin=predictive method=joback]
Pc          24.483;      // bar [origin=predictive method=joback]
omega       0.6755;      // -   [origin=predictive method=lee-kesler]
Tb          664.34;      // K   [origin=predictive method=joback]
HvapTb      62267.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.55 1.09724 -0.00062592 1.114e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-(4-methylphenyl)benzoate" "methyl 4'-methyl[1,1'-biphenyl]-4-carboxylate" "methyl 4'-methyl(1,1'-biphenyl)-4-carboxylate" "(1,1'-biphenyl)-4-carboxylic acid, 4'-methyl-, methyl ester" "[1,1'-biphenyl]-4-carboxylic acid, 4'-methyl-, methyl ester" "4-[4-(methoxycarbonyl)phenyl]toluene" "4-(methoxycarbonyl)-4'-methylbiphenyl" "methyl 4'-methylbiphenyl-4-carboxylate" "4'-methyl-biphenyl-4-carboxylic acid methyl ester" "methyl 4'-methyl-(1,1'-biphenyl)-4-carboxylate" );
standardThermochemistry
{
    dHf_298   -220090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29390.0
}
