/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethenyl-1,1,3,3-tetramethylcyclobutane  (C10H18, CAS 66438-87-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethenyl1133Tetramethylcyclobutane;
formula     C10H18;
CAS         66438-87-7;
InChIKey    VYQSEHNZACAPGH-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          629.26;      // K   [origin=predictive method=joback]
Pc          26.111;      // bar [origin=predictive method=joback]
omega       0.2746;      // -   [origin=predictive method=lee-kesler]
Tb          427.23;      // K   [origin=predictive method=joback]
HvapTb      34349.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-152.66 1.60598 -0.0016713 7.342e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group C; count 2; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethenyl-1,1,3,3-tetramethyl-cyclobutane" "cyclobutane,2-ethenyl-1,1,3,3-tetramethyl" "cyclobutane, 2-ethenyl-1,1,3,3-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -67860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143410.0
}
