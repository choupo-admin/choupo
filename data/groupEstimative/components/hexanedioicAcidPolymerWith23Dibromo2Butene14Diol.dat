/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid, polymer with 2,3-dibromo-2-butene-1,4-diol  (C10H16Br2O6, CAS 69725-52-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcidPolymerWith23Dibromo2Butene14Diol;
formula     C10H16Br2O6;
CAS         69725-52-6;
InChIKey    OFFRXWBDNPCTPA-SCBDLNNBSA-N;
MW          392.04;      // g/mol [origin=calculated method=formula-sum]
Tc          1275.24;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       2.0904;      // -   [origin=predictive method=lee-kesler]
Tb          1041.42;      // K   [origin=predictive method=joback]
HvapTb      118822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.216 1.0134 -0.0005426 8.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group OH; count 2; } { group COOH; count 2; } { group Br; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dC; count 2; } { group Br; count 2; } { group OH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-2,3-bis(bromanyl)but-2-ene-1,4-diol;hexanedioic acid" "adipic acid, 2,3-dibromobutene-1,4-diol polymer" );
standardThermochemistry
{
    dHf_298   -1216050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     948.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-941140.0
}
