/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxy-3-methylenecyclohexene  (C8H12O, CAS 2773-58-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxy3Methylenecyclohexene;
formula     C8H12O;
CAS         2773-58-2;
InChIKey    LCJLBMWGZXUTRM-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          638.68;      // K   [origin=predictive method=joback]
Pc          33.606;      // bar [origin=predictive method=joback]
omega       0.3613;      // -   [origin=predictive method=lee-kesler]
Tb          432.58;      // K   [origin=predictive method=joback]
HvapTb      37663.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.06 0.61622 -0.00026464 1.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=C; count 1; } { group CH=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-3-methylidene-cyclohexene" "1-methoxy-3-methylidenecyclohexene" );
standardThermochemistry
{
    dHf_298   -135460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17050.0
}
