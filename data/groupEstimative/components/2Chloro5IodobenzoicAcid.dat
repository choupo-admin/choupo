/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-5-iodobenzoic acid  (C7H4ClIO2, CAS 19094-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro5IodobenzoicAcid;
formula     C7H4ClIO2;
CAS         19094-56-5;
InChIKey    GEBYSTBEDVQOTK-UHFFFAOYSA-N;
MW          282.457;      // g/mol [origin=calculated method=formula-sum]
Tc          940.14;      // K   [origin=predictive method=joback]
Pc          41.144;      // bar [origin=predictive method=joback]
omega       0.7415;      // -   [origin=predictive method=lee-kesler]
Tb          672.48;      // K   [origin=predictive method=joback]
HvapTb      65698.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.4 0.5675 -0.00042852 1.247e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group COOH; count 1; } { group ACCl; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group I; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-5-iodanyl-benzoic acid" "2-chloro-5-iodo-benzoic acid" "5-iodo-2-chlorobenzoic acid;" "benzoicacid, 2-chloro-5-iodo-" "buttpark 100\01-43" "q991" );
standardThermochemistry
{
    dHf_298   -263360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-196510.0
}
