/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluorophenyl isocyanate  (C7H4FNO, CAS 1195-45-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4FluorophenylIsocyanate;
formula     C7H4FNO;
CAS         1195-45-5;
InChIKey    DSVGFKBFFICWLZ-UHFFFAOYSA-N;
MW          137.113;      // g/mol [origin=calculated method=formula-sum]
Tc          670.93;      // K   [origin=predictive method=joback]
Pc          41.893;      // bar [origin=predictive method=joback]
omega       0.4761;      // -   [origin=predictive method=lee-kesler]
Tb          457.36;      // K   [origin=predictive method=joback]
HvapTb      42829.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-4-isocyanato-benzene" "1-fluoro-4-isocyanatobenzene" "p-fluorophenyl isocyanate" "4-fluorophenylisocyanate" "isocyanic acid 4-fluorophenyl ester" "4-fluorobenzenisocyanate" "p-fluoro phenyl isocyanic ester" "4-isocyanatofluorobenzene" "benzene,1-fluoro-4-isocyanato-" "dsvgfkbfficwlz-uhfffaoysa-" "benzene, 1-fluoro-4-isocyanato-" );
