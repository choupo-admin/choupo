/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methyl-1,2,3,4-tetrahydroquinoline  (C10H13N, CAS 91-61-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methyl1234Tetrahydroquinoline;
formula     C10H13N;
CAS         91-61-2;
InChIKey    XOKMRXSMOHCNIX-UHFFFAOYSA-N;
MW          147.221;      // g/mol [origin=calculated method=formula-sum]
Tc          768.49;      // K   [origin=predictive method=joback]
Pc          36.115;      // bar [origin=predictive method=joback]
omega       0.4673;      // -   [origin=predictive method=lee-kesler]
Tb          529.27;      // K   [origin=predictive method=joback]
HvapTb      48606.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.89 0.91032 -0.00058592 1.482e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "civettal" "1,2,3,4-tetrahydro-6-methylquinoline" "quinoline, 1,2,3,4-tetrahydro-6-methyl-" "p-methyltetrahydroquinoline" "quinoline, tetrahydro-6-methyl-" "xokmrxsmohcnix-uhfffaoysa-" "1,3,4-tetrahydro-6-methylquinoline" "6-methyl-1,3,4-tetrahydroquinoline" "quinoline,2,3,4-tetrahydro-6-methyl-" );
standardThermochemistry
{
    dHf_298   88650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=270540.0
}
