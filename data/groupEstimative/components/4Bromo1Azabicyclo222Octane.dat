/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-1-azabicyclo[2.2.2]octane  (C7H12BrN, CAS 2181-19-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo1Azabicyclo222Octane;
formula     C7H12BrN;
CAS         2181-19-3;
InChIKey    ZUEBXWFONILVTP-UHFFFAOYSA-N;
MW          190.084;      // g/mol [origin=calculated method=formula-sum]
Tc          692.03;      // K   [origin=predictive method=joback]
Pc          46.913;      // bar [origin=predictive method=joback]
omega       0.4125;      // -   [origin=predictive method=lee-kesler]
Tb          461.02;      // K   [origin=predictive method=joback]
HvapTb      38810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-167.51 1.4415 -0.001523 6.385e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group CH2N; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group C_ring; count 1; } { group Br; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-1-azabicyclo[2.2.2]octane" "4-bromo-1-azabicyclo(2.2.2)octane" "1-azabicyclo[2.2.2]octane,4-bromo-" );
standardThermochemistry
{
    dHf_298   81070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=244780.0
}
