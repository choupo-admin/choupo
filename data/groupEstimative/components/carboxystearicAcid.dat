/*--------------------------------*- Choupo -*-----------------------*\
  Component: carboxystearic acid  (C19H36O4, CAS 4371-64-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carboxystearicAcid;
formula     C19H36O4;
CAS         4371-64-6;
InChIKey    MVDKKZZVTWHVMC-UHFFFAOYSA-N;
MW          328.493;      // g/mol [origin=calculated method=formula-sum]
Tc          1132.48;      // K   [origin=predictive method=joback]
Pc          12.260;      // bar [origin=predictive method=joback]
omega       1.1522;      // -   [origin=predictive method=lee-kesler]
Tb          924.90;      // K   [origin=predictive method=joback]
HvapTb      91828.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.865 1.91632 -0.0011582 2.704e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexadecylpropanedioic acid" "hexadecylmalonic acid" "2-hexadecylmalonic acid" "2-hexadecyl-malonic acid" "malonic acid, hexadecyl-" "propanedioic acid, hexadecyl-" "n-hexadecylmalonic acid" "1,1-heptadecanedicarboxylic acid" "2-hexadecylmalonic acid; 1,1-heptadecanedicarboxylic acid" );
gibbsFormation
{
    dHf_298   -1141310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     992.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-581160.0
    phase     gas;
}
