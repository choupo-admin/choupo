/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylaminomethanol  (C3H9NO, CAS 14002-21-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylaminomethanol;
formula     C3H9NO;
CAS         14002-21-2;
InChIKey    XQKRYBXCYCKQLL-UHFFFAOYSA-N;
MW          75.111;      // g/mol [origin=calculated method=formula-sum]
Tc          534.03;      // K   [origin=predictive method=joback]
Pc          49.874;      // bar [origin=predictive method=joback]
omega       0.6767;      // -   [origin=predictive method=lee-kesler]
Tb          372.86;      // K   [origin=predictive method=joback]
HvapTb      40994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.239 0.44674 -0.0002824 7.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methanol, (dimethylamino)-" "methanol, 1-(dimethylamino)-" "methanol,1-(dimethylamino)-" "methanol,(dimethylamino)- (8ci,9ci); (dimethylamino)methanol;(hydroxymethyl)dimethylamine; n,n-dimethylcarbinolamine; n,n-dimethylmethanolamine" );
gibbsFormation
{
    dHf_298   -189950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     339.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51660.0
    phase     gas;
}
