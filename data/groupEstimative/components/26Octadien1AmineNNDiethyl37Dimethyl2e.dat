/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-octadien-1-amine, n,n-diethyl-3,7-dimethyl-, (2e)-  (C14H27N, CAS 40267-53-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Octadien1AmineNNDiethyl37Dimethyl2e;
formula     C14H27N;
CAS         40267-53-6;
InChIKey    XDEJHXKVKISANH-UHFFFAOYSA-N;
MW          209.377;      // g/mol [origin=calculated method=formula-sum]
Tc          717.14;      // K   [origin=predictive method=joback]
Pc          16.660;      // bar [origin=predictive method=joback]
omega       0.6170;      // -   [origin=predictive method=lee-kesler]
Tb          540.44;      // K   [origin=predictive method=joback]
HvapTb      48877.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.275 1.4976 -0.0010226 2.912e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group CH=C; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group dCH; count 2; } { group dC; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-3,7-dimethyl-octa-2,6-dien-1-amine" "n,n-diethyl-3,7-dimethyl-2,6-octadiene-1-amine" "n,n-diethyl-3,7-dimethylocta-2,6-dien-1-amine" );
gibbsFormation
{
    dHf_298   -49900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     695.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=321120.0
    phase     gas;
}
