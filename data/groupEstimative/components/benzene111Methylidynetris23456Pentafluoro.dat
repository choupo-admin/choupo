/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,1',1''-methylidynetris[2,3,4,5,6-pentafluoro-  (C19HF15, CAS 4780-60-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene111Methylidynetris23456Pentafluoro;
formula     C19HF15;
CAS         4780-60-3;
InChIKey    BUNRVRQQXIMBBK-UHFFFAOYSA-N;
MW          514.187;      // g/mol [origin=calculated method=formula-sum]
Tc          954.17;      // K   [origin=predictive method=joback]
Pc          11.561;      // bar [origin=predictive method=joback]
omega       1.0736;      // -   [origin=predictive method=lee-kesler]
Tb          777.67;      // K   [origin=predictive method=joback]
HvapTb      62003.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (188.07 0.8625 -0.000347 1.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 2; } { group ACCH; count 1; } { group ACF; count 15; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dC_ring; count 18; } { group F; count 15; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[bis[2,3,4,5,6-pentakis(fluoranyl)phenyl]methyl]-2,3,4,5,6-pentakis(fluoranyl)benzene" );
gibbsFormation
{
    dHf_298   -2844880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     950.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2622710.0
    phase     gas;
}
