/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-3,5,5-trimethylhexane  (C9H19Br, CAS 50915-80-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo355Trimethylhexane;
formula     C9H19Br;
CAS         50915-80-5;
InChIKey    JUHBYLSCAJAHEH-UHFFFAOYSA-N;
MW          207.155;      // g/mol [origin=calculated method=formula-sum]
Tc          662.98;      // K   [origin=predictive method=joback]
Pc          25.354;      // bar [origin=predictive method=joback]
omega       0.4405;      // -   [origin=predictive method=lee-kesler]
Tb          468.01;      // K   [origin=predictive method=joback]
HvapTb      40379.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.257 1.02878 -0.0007122 2.014e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-3,5,5-trimethyl-hexane" "1-bromo-3,5,5-trimethyl hexane" "hexane,1-bromo-3,5,5-trimethyl-" "3,5,5-trimethylhexyl bromide" "1-bromo-3,5,5-trimethylhexane;3,5,5-trimethylhexyl bromide" );
gibbsFormation
{
    dHf_298   -216790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39620.0
    phase     gas;
}
