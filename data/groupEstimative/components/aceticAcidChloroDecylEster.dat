/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetic acid, chloro-, decyl ester  (C12H23ClO2, CAS 6974-05-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aceticAcidChloroDecylEster;
formula     C12H23ClO2;
CAS         6974-05-6;
InChIKey    WLAYVQKPZABXSY-UHFFFAOYSA-N;
MW          234.764;      // g/mol [origin=calculated method=formula-sum]
Tc          741.89;      // K   [origin=predictive method=joback]
Pc          17.332;      // bar [origin=predictive method=joback]
omega       0.7876;      // -   [origin=predictive method=lee-kesler]
Tb          569.81;      // K   [origin=predictive method=joback]
HvapTb      54098.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.28 1.09582 -0.0005548 8.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decyl 2-chloranylethanoate" "decyl 2-chloroacetate" "decyl chloroacetate" "acetic acid, chloro-, n-decyl ester" );
gibbsFormation
{
    dHf_298   -624030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     708.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-272140.0
    phase     gas;
}
