/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyrrolidine, 1-(2-methylpropenyl)-  (C8H15N, CAS 2403-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyrrolidine12Methylpropenyl;
formula     C8H15N;
CAS         2403-57-8;
InChIKey    PAXNHQZTZQFBPC-UHFFFAOYSA-N;
MW          125.215;      // g/mol [origin=calculated method=formula-sum]
Tc          611.96;      // K   [origin=predictive method=joback]
Pc          32.916;      // bar [origin=predictive method=joback]
omega       0.3567;      // -   [origin=predictive method=lee-kesler]
Tb          414.80;      // K   [origin=predictive method=joback]
HvapTb      35877.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.25 1.07544 -0.0008393 2.682e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH=C; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methylprop-1-enyl)pyrrolidine" "pyrrolidine, 1-(2-methyl-1-propenyl)-" "1-(2-methyl-1-propenyl)pyrrolidine" "1-(2-methyl-prop-1-enyl)-pyrrolidine" "pyrrolidine,1-(2-methyl-1-propen-1-yl)-" "pyrrolidine,1-(2-methyl-1-propenyl)- (9ci); pyrrolidine, 1-(2-methylpropenyl)-(6ci,7ci,8ci); 1-(2-methyl-1-propen-1-yl)pyrrolidine;1-(2-methyl-1-propenyl)pyrrolidine; 1-(2-methylpropenyl)pyrrolidine;1-pyrrolidino-2-methylpropene; 1-pyrrolidinoisobutene;2-methyl-1-pyrrolidinopropene; isobutyraldehyde pyrrolidine enamine;n-(2-methyl-1-propenyl)pyrrolidine; n-isobutenylpyrrolidine" );
gibbsFormation
{
    dHf_298   53490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=255290.0
    phase     gas;
}
