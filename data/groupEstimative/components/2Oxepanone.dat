/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxepanone  (C6H10O2, CAS 502-44-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Oxepanone;
formula     C6H10O2;
CAS         502-44-3;
InChIKey    PAPBSGBWRJIAAV-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          620.36;      // K   [origin=predictive method=joback]
Pc          40.261;      // bar [origin=predictive method=joback]
omega       0.3757;      // -   [origin=predictive method=lee-kesler]
Tb          415.05;      // K   [origin=predictive method=joback]
HvapTb      36923.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.58 0.6772 -0.0003908 7.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxepan-2-one" "6-hexanolactone" "epsilon-caprolactone" "caprolactone" "hexan-6-olide" "6-hexanolide" "hexano-6-lactone" "1-oxa-2-oxocycloheptane" "e-caprolactone" "1,6-hexanolide" "epsilon-caprolactone monomer" ".epsilon.-caprolactone" );
standardThermochemistry
{
    dHf_298   -403630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-266470.0
}
