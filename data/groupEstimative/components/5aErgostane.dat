/*--------------------------------*- Choupo -*-----------------------*\
  Component: (5a)-ergostane  (C28H50, CAS 511-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5aErgostane;
formula     C28H50;
CAS         511-20-6;
InChIKey    WAAWMJYYKITCGF-WTPIMUJOSA-N;
MW          386.708;      // g/mol [origin=calculated method=formula-sum]
Tc          1096.53;      // K   [origin=predictive method=joback]
Pc          9.491;      // bar [origin=predictive method=joback]
omega       0.6713;      // -   [origin=predictive method=lee-kesler]
Tb          873.70;      // K   [origin=predictive method=joback]
HvapTb      74041.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-336.348 3.74152 -0.0030568 1.0796e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 12; } { group CH; count 8; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 3; } { group CH2_ring; count 10; } { group CH_ring; count 5; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5r,8r,9s,10s,13r,14s,17r)-17-[(2r,5s)-5,6-dimethylheptan-2-yl]-10,13-dimethyl-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthrene" "ergostane, (5alpha)-" "5alpha-ergostane" );
standardThermochemistry
{
    dHf_298   -407230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     968.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=325950.0
}
