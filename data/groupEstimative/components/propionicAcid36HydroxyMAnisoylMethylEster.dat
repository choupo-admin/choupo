/*--------------------------------*- Choupo -*-----------------------*\
  Component: propionic acid, 3-(6-hydroxy-m-anisoyl)-, methyl ester  (C12H14O5, CAS 59701-66-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propionicAcid36HydroxyMAnisoylMethylEster;
formula     C12H14O5;
CAS         59701-66-5;
InChIKey    DDZBYCVFPQTSNL-UHFFFAOYSA-N;
MW          238.239;      // g/mol [origin=calculated method=formula-sum]
Tc          939.38;      // K   [origin=predictive method=joback]
Pc          29.092;      // bar [origin=predictive method=joback]
omega       1.1189;      // -   [origin=predictive method=lee-kesler]
Tb          720.95;      // K   [origin=predictive method=joback]
HvapTb      74821.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.722 1.01404 -0.00062522 1.4436e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-(5-methoxy-2-oxidanyl-phenyl)-4-oxidanylidene-butanoate" "methyl 4-(2-hydroxy-5-methoxyphenyl)-4-oxobutanoate" );
gibbsFormation
{
    dHf_298   -805340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     626.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-545970.0
    phase     gas;
}
