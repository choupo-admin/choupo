/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxypyridine  (C6H7NO, CAS 620-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxypyridine;
formula     C6H7NO;
CAS         620-08-6;
InChIKey    XQABVLBGNWBWIV-UHFFFAOYSA-N;
MW          109.128;      // g/mol [origin=calculated method=formula-sum]
Tc          666.19;      // K   [origin=predictive method=joback]
Pc          45.716;      // bar [origin=predictive method=joback]
omega       0.3637;      // -   [origin=predictive method=lee-kesler]
Tb          439.68;      // K   [origin=predictive method=joback]
HvapTb      39846.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.91 0.46548 -0.00023206 3.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3O; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group O; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyridine, 4-methoxy-" "4-methoxypyridin" ".gamma.-methoxypyridine" "4- methoxypyridine" "pyridine, 4-methoxy-;" "methyl pyridin-4-yl ether" "l745" );
standardThermochemistry
{
    dHf_298   -30070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     307.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=84100.0
}
