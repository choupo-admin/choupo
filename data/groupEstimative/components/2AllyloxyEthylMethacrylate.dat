/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(allyloxy)ethyl methacrylate  (C9H14O3, CAS 16839-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AllyloxyEthylMethacrylate;
formula     C9H14O3;
CAS         16839-48-8;
InChIKey    ZCYIYBNDJKVCBR-UHFFFAOYSA-N;
MW          170.208;      // g/mol [origin=calculated method=formula-sum]
Tc          659.38;      // K   [origin=predictive method=joback]
Pc          24.875;      // bar [origin=predictive method=joback]
omega       0.5992;      // -   [origin=predictive method=lee-kesler]
Tb          479.40;      // K   [origin=predictive method=joback]
HvapTb      44185.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.943 0.70072 -0.0003083 2.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-prop-2-enoxyethyl 2-methylprop-2-enoate" "2-allyloxyethyl methacrylate" "2-propenoic acid, 2-methyl-, 2-(2-propenyloxy)ethyl ester" "2-propenoic acid, 2-methyl-, 2-(2-propen-1-yloxy)ethyl ester" "allyloxyethyl methacrylate" "2-(2-allyloxy)ethyl methacrylate" "2-propenoic acid,2-methyl-, 2-(2-propen-1-yloxy)ethyl ester" "2-propenoicacid, 2-methyl-, 2-(2-propenyloxy)ethyl ester (9ci); methacrylic acid,2-(allyloxy)ethyl ester (7ci,8ci); ethanol, 2-(allyloxy)-, methacrylate (8ci);2-(allyloxy)ethyl methacrylate; b-(allyloxy)ethyl methacrylate" );
standardThermochemistry
{
    dHf_298   -437520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-223340.0
}
