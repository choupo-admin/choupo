/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 4-pyridyl ketone  (C10H13NO, CAS 1701-73-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl4PyridylKetone;
formula     C10H13NO;
CAS         1701-73-1;
InChIKey    AZZKIOQLDYOUSM-UHFFFAOYSA-N;
MW          163.22;      // g/mol [origin=calculated method=formula-sum]
Tc          786.24;      // K   [origin=predictive method=joback]
Pc          31.456;      // bar [origin=predictive method=joback]
omega       0.6168;      // -   [origin=predictive method=lee-kesler]
Tb          562.65;      // K   [origin=predictive method=joback]
HvapTb      53086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.687 0.88068 -0.00054196 1.2606e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2CO; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group CdO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pyridin-4-ylpentan-1-one" "4-valerylpyridine" "pyridine, 4-valeryl-" "ketone, butyl 4-pyridyl" "1-(4-pyridyl)-1-pentanone" "1-(pyridin-4-yl)pentan-1-one" "1-pentanone, 1-(4-pyridyl)-" );
gibbsFormation
{
    dHf_298   -92990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93860.0
    phase     gas;
}
