/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-bromo-1,4-benzodioxane  (C8H7BrO2, CAS 52287-51-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Bromo14Benzodioxane;
formula     C8H7BrO2;
CAS         52287-51-1;
InChIKey    LFCURAJBHDNUNG-UHFFFAOYSA-N;
MW          215.046;      // g/mol [origin=calculated method=formula-sum]
Tc          809.43;      // K   [origin=predictive method=joback]
Pc          47.826;      // bar [origin=predictive method=joback]
omega       0.5582;      // -   [origin=predictive method=lee-kesler]
Tb          555.02;      // K   [origin=predictive method=joback]
HvapTb      52851.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.16 0.7659 -0.00058132 1.74e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group FCH2O; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-bromanyl-2,3-dihydro-1,4-benzodioxine" "6-bromo-2,3-dihydrobenzo[b][1,4]dioxine" "6-bromo-2,3-dihydro-1,4-benzodioxine" "3,4-ethylenedioxybromobenzene" "4-bromo-1,2-ethylenedioxybenzene" "6-bromo-2,3-dihydro-1,4-benzodioxin" "1,4-benzodioxin, 6-bromo-2,3-dihydro-" "3,4-ethylendioxybromobenzene" "6-bromo-2,3-dihydro-benzo[1,4]dioxine" "buttpark 95\50-63" "6-bromo-2h,3h-benzo[e]1,4-dioxin" "6-bromo-2h,3h-benzo[e]1,4-dioxane" );
gibbsFormation
{
    dHf_298   -145550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     269.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8070.0
    phase     gas;
}
