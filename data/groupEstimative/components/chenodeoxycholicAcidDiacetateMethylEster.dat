/*--------------------------------*- Choupo -*-----------------------*\
  Component: chenodeoxycholic acid diacetate methyl ester  (C29H46O6, CAS 2616-71-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chenodeoxycholicAcidDiacetateMethylEster;
formula     C29H46O6;
CAS         2616-71-9;
InChIKey    ZKHVKSAMEUAGEN-JSWGAMEVSA-N;
MW          490.681;      // g/mol [origin=calculated method=formula-sum]
Tc          1302.19;      // K   [origin=predictive method=joback]
Pc          8.605;      // bar [origin=predictive method=joback]
omega       0.8229;      // -   [origin=predictive method=lee-kesler]
Tb          1062.78;      // K   [origin=predictive method=joback]
HvapTb      98646.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-245.788 3.60732 -0.0027102 8.648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 9; } { group CH; count 8; } { group C; count 2; } { group CH3COO; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 7; } { group C_ring; count 2; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (4r)-4-[(3r,5s,7r,8r,9s,10s,13r,14s,17r)-3,7-diacetyloxy-10,13-dimethyl-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthren-17-yl]pentanoate" "3" "a,7" "a-diacetoxy-5" "a-cholan-24-oic acid methyl ester" "3alpha,7alpha-diacetoxy-5beta-cholan-24-oic acid methyl ester" "methyl (4r)-4-((1s,2s,7s,11s,5r,9r,10r,14r,15r)-5,9-diacetyloxy-2,15-dimethylt etracyclo[8.7.0.0<2,7>.0<11,15>]heptadec-14-yl)pentanoate" );
standardThermochemistry
{
    dHf_298   -1409830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1095.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-607280.0
}
