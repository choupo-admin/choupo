/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-(ethoxymethyl)tricyclo[5.2.1.02,6]decan-8-ol  (C13H22O2, CAS 34748-63-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8EthoxymethylTricyclo521026Decan8Ol;
formula     C13H22O2;
CAS         34748-63-5;
InChIKey    AZHWRHJDAMOKPR-UHFFFAOYSA-N;
MW          210.317;      // g/mol [origin=calculated method=formula-sum]
Tc          824.19;      // K   [origin=predictive method=joback]
Pc          25.075;      // bar [origin=predictive method=joback]
omega       0.9419;      // -   [origin=predictive method=lee-kesler]
Tb          627.03;      // K   [origin=predictive method=joback]
HvapTb      61763.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-172.098 1.89162 -0.0016388 6.081e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 4; } { group C; count 1; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 4; } { group C_ring; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7-methano-1h-inden-5-ol, 5-(ethoxymethyl)octahydro-" "5-(ethoxymethyl)octahydro-1h-4,7-methanoinden-5-ol" "5-(ethoxymethyl)octahydro-4,7-methano-1h-inden-5-ol" "9-ethoxymethyl-9-hydroxytricyclo(5.2.1.02,6)decane" );
standardThermochemistry
{
    dHf_298   -409300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34000.0
}
