/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-amino-5-(4-amino-3-methoxybenzyl)benzoate  (C16H18N2O3, CAS 66037-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Amino54Amino3MethoxybenzylBenzoate;
formula     C16H18N2O3;
CAS         66037-57-8;
InChIKey    BOBSHSYHQVONGD-UHFFFAOYSA-N;
MW          286.331;      // g/mol [origin=calculated method=formula-sum]
Tc          1105.88;      // K   [origin=predictive method=joback]
Pc          23.795;      // bar [origin=predictive method=joback]
omega       1.1748;      // -   [origin=predictive method=lee-kesler]
Tb          864.66;      // K   [origin=predictive method=joback]
HvapTb      89509.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.621 1.13384 -0.00052204 4.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 1; } { group ACNH2; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 1; } { group COO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-azanyl-5-[(4-azanyl-3-methoxy-phenyl)methyl]benzoate" "benzoic acid, 2-amino-5-((4-amino-3-methoxyphenyl)methyl)-, methyl ester" "benzoic acid, 2-amino-5-[(4-amino-3-methoxyphenyl)methyl]-, methyl ester" "methyl 2-amino-5-[(4-amino-3-methoxyphenyl)methyl]benzoate" );
gibbsFormation
{
    dHf_298   -328310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     707.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12330.0
    phase     gas;
}
