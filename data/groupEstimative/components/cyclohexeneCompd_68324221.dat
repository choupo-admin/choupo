/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene compd.  (C25H47NO6, CAS 68324-22-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexeneCompd;
formula     C25H47NO6;
CAS         68324-22-1;
InChIKey    DCDKFIZYBRYJPR-UHFFFAOYSA-N;
MW          457.652;      // g/mol [origin=calculated method=formula-sum]
Tc          1715.16;      // K   [origin=predictive method=joback]
Pc          10.040;      // bar [origin=predictive method=joback]
omega       0.3844;      // -   [origin=predictive method=lee-kesler]
Tb          1307.92;      // K   [origin=predictive method=joback]
HvapTb      145763.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.394 2.43152 -0.00113348 1.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH; count 3; } { group CH=CH; count 1; } { group OH; count 2; } { group CH2NH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group OH; count 2; } { group COOH; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexyl-5-(8-oxidanyl-8-oxidanylidene-octyl)cyclohex-3-ene-1-carboxylic acid;2-(2-hydroxyethylamino)ethanol" "5-(7-carboxyheptyl)-2-hexylcyclohex-3-ene-1-carboxylic acid- 2,2'-iminodiethanol(1:1)" "2-cyclohexene-1-octanoic acid, 5-carboxy-4-hexyl-, compd. with 2,2'-iminobis(ethanol) (1:1)" "5(or 6)-carboxy-4-hexylcyclohex-2-ene-1-octanoic acid, compound with 2,2'-iminodiethanol (1:1)" "3-hexyl-4-carboxy-6-(8-octanoic) cyclohexene-1-2, with diethanolamine" "5-(7-carboxyheptyl)-2-hexylcyclohex-3-ene-1-carboxylic acid - 2,2'-iminodiethanol (1:1)" "5-carboxy-4-hexylcyclohex-2-ene-1-octanoic acid, compound with 2,2'-iminodiethanol (1:1)" "2-cyclohexene-1-octanoic acid, 5(or 6)-carboxy-4-hexyl-, compd. with 2,2'-iminobis(ethanol) (1:1)" "2-hexyl-5-(8-hydroxy-8-oxooctyl)cyclohex-3-ene-1-carboxylic acid; 2-(2-hydroxyethylamino)ethanol" );
standardThermochemistry
{
    dHf_298   -1551060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1333.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-778220.0
}
