/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4,5-pentachloro-6-iodobenzene  (C6Cl5I, CAS 16478-18-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12345Pentachloro6Iodobenzene;
formula     C6Cl5I;
CAS         16478-18-5;
InChIKey    JUOZURBHPHLQGX-UHFFFAOYSA-N;
MW          376.216;      // g/mol [origin=calculated method=formula-sum]
Tc          951.32;      // K   [origin=predictive method=joback]
Pc          32.840;      // bar [origin=predictive method=joback]
omega       0.5336;      // -   [origin=predictive method=lee-kesler]
Tb          668.75;      // K   [origin=predictive method=joback]
HvapTb      65834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (111.17 0.2704 -0.000182 4.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group ACCl; count 5; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group Cl; count 5; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(chloranyl)-6-iodanyl-benzene" "benzene,pentachloroiodo-" "benzene, pentachloroiodo-" "1,2,3,4,6-pentachloro-5-iodobenzene" "benzene,1,2,3,4,5-pentachloro-6-iodo-" "benzene,pentachloroiodo- (6ci,8ci,9ci); 2,3,4,5,6-pentachloroiodobenzene;iodopentachlorobenzene; pentachloroiodobenzene" );
standardThermochemistry
{
    dHf_298   10180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62370.0
}
