/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,6-dimethyl-2-prop-2-enyl-3-oxabicyclo[2.2.2]octane  (C12H20O, CAS 71477-76-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        46Dimethyl2Prop2Enyl3Oxabicyclo222Octane;
formula     C12H20O;
CAS         71477-76-4;
InChIKey    PEUAQZVDQYVDLY-UHFFFAOYSA-N;
MW          180.291;      // g/mol [origin=calculated method=formula-sum]
Tc          721.84;      // K   [origin=predictive method=joback]
Pc          23.842;      // bar [origin=predictive method=joback]
omega       0.4244;      // -   [origin=predictive method=lee-kesler]
Tb          510.71;      // K   [origin=predictive method=joback]
HvapTb      44547.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.529 1.64234 -0.0014074 5.207e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group C_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxabicyclo[2.2.2]octane, 1,5-dimethyl-3-(2-propenyl)-" "agn-pc-02vk54" "2-oxabicyclo[2.2.2]octane, 1,5-dimethyl-3-(2-propen-1-yl)-" "1,5-dimethyl-3-(2-propenyl)-2-oxabicyclo[2.2.2]octane" );
gibbsFormation
{
    dHf_298   -189740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128270.0
    phase     gas;
}
