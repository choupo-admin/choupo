/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-phenoxypentoxybenzene  (C17H20O2, CAS 40339-96-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Phenoxypentoxybenzene;
formula     C17H20O2;
CAS         40339-96-6;
InChIKey    PMRSVBNDSJTASL-UHFFFAOYSA-N;
MW          256.345;      // g/mol [origin=calculated method=formula-sum]
Tc          906.77;      // K   [origin=predictive method=joback]
Pc          20.254;      // bar [origin=predictive method=joback]
omega       0.7723;      // -   [origin=predictive method=lee-kesler]
Tb          686.76;      // K   [origin=predictive method=joback]
HvapTb      62808.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.375 1.3346 -0.0007414 1.325e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene,1,1'-[1,5-pentanediylbis(oxy)]bis-" "benzene, 1,1'-(1,5-pentanediylbis(oxy))bis-" );
gibbsFormation
{
    dHf_298   -185590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107080.0
    phase     gas;
}
