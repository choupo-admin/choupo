/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(piperidin-4-yl)pyridine  (C10H14N2, CAS 581-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Piperidin4YlPyridine;
formula     C10H14N2;
CAS         581-45-3;
InChIKey    RGBWBVGQZFJTEO-UHFFFAOYSA-N;
MW          162.236;      // g/mol [origin=calculated method=formula-sum]
Tc          840.96;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.4713;      // -   [origin=predictive method=lee-kesler]
Tb          576.88;      // K   [origin=predictive method=joback]
HvapTb      53527.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.73 1.01736 -0.00058106 1.118e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH2NH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group NH_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-piperidin-4-ylpyridine" "4-piperidine-4-yl-pyridine" "1,2,3,4,5,6-hexahydro-[4,4']bipyridinyl" "4-(4-piperidyl)pyridine" "4-(4-pyridyl)piperidine" "4-(4-pyridinyl)piperidine" "4-pyridin-4-yl-piperidine" "4-(pyridin-4-yl)piperidine" "4-(4-piperidino)pyridine" "4aan-p04-0" );
gibbsFormation
{
    dHf_298   111720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=334940.0
    phase     gas;
}
