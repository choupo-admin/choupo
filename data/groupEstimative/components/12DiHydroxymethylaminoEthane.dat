/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-di(hydroxymethylamino)ethane  (C4H12N2O2, CAS 70495-38-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12DiHydroxymethylaminoEthane;
formula     C4H12N2O2;
CAS         70495-38-4;
InChIKey    HUKGOLYOCFANQI-UHFFFAOYSA-N;
MW          120.152;      // g/mol [origin=calculated method=formula-sum]
Tc          741.15;      // K   [origin=predictive method=joback]
Pc          51.609;      // bar [origin=predictive method=joback]
omega       1.6440;      // -   [origin=predictive method=lee-kesler]
Tb          575.82;      // K   [origin=predictive method=joback]
HvapTb      70728.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.414 0.6042 -0.0003518 7.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group OH; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(hydroxymethylamino)ethylamino]methanol" "methanol, (1,2-ethanediyldiimino)bis-" "methanol, 1,1'-(1,2-ethanediyldiimino)bis-" );
standardThermochemistry
{
    dHf_298   -323410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-112060.0
}
