/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodoprop-1-ene  (C3H5I, CAS 7796-54-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodoprop1Ene;
formula     C3H5I;
CAS         7796-54-5;
InChIKey    QYQQTZFOFMPYCA-UHFFFAOYSA-N;
MW          167.973;      // g/mol [origin=calculated method=formula-sum]
Tc          583.11;      // K   [origin=predictive method=joback]
Pc          45.902;      // bar [origin=predictive method=joback]
omega       0.1816;      // -   [origin=predictive method=lee-kesler]
Tb          365.54;      // K   [origin=predictive method=joback]
HvapTb      31603.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.33 0.34782 -0.0003046 1.118e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanylprop-1-ene" "1-propene, 1-iodo-,(1e)- (9ci)" "1-propene,1-iodo-, (e)-; propene, 1-iodo-, (e)- (8ci); trans-1-iodopropene" );
standardThermochemistry
{
    dHf_298   88840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     321.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112720.0
}
