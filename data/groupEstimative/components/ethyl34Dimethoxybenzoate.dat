/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3,4-dimethoxybenzoate  (C11H14O4, CAS 3943-77-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl34Dimethoxybenzoate;
formula     C11H14O4;
CAS         3943-77-9;
InChIKey    AYYNUGSDPRDVCH-UHFFFAOYSA-N;
MW          210.229;      // g/mol [origin=calculated method=formula-sum]
Tc          795.65;      // K   [origin=predictive method=joback]
Pc          24.950;      // bar [origin=predictive method=joback]
omega       0.7460;      // -   [origin=predictive method=lee-kesler]
Tb          590.98;      // K   [origin=predictive method=joback]
HvapTb      55907.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.991 0.66976 -0.00015512 -7.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl veratrate" "3,4-dimethoxybenzoic acid ethyl ester" "veratric acid, ethyl ester (7ci,8ci)" "benzoic acid, 3,4-dimethoxy-, ethyl ester" "veratric acid, ethyl ester" "ethyl-3,4-dimethoxybenzoate" "benzoic acid,3,4-dimethoxy-, ethyl ester" "veratricacid, ethyl ester (7ci,8ci);3,4-dimethoxybenzoic acid ethyl ester;ethyl3,4-dimethoxybenzoate;" );
gibbsFormation
{
    dHf_298   -638500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-385480.0
    phase     gas;
}
