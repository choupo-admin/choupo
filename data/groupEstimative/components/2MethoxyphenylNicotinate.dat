/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxyphenyl nicotinate  (C13H11NO3, CAS 15057-98-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethoxyphenylNicotinate;
formula     C13H11NO3;
CAS         15057-98-4;
InChIKey    KVPUDAXRVGUATI-UHFFFAOYSA-N;
MW          229.235;      // g/mol [origin=calculated method=formula-sum]
Tc          938.75;      // K   [origin=predictive method=joback]
Pc          29.861;      // bar [origin=predictive method=joback]
omega       0.7649;      // -   [origin=predictive method=lee-kesler]
Tb          689.72;      // K   [origin=predictive method=joback]
HvapTb      65773.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.47 0.93728 -0.00048242 5.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group C5H4N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group O; count 1; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methoxyphenyl) pyridine-3-carboxylate" "2-methoxyphenyl pyridine-3-carboxylate" "guaiacyl nicotinate" "nicotinic acid, 2-methoxyphenyl ester" "3-pyridinecarboxylic acid, 2-methoxyphenyl ester" );
gibbsFormation
{
    dHf_298   -266770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64550.0
    phase     gas;
}
