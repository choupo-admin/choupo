/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-5-chlorobenzamide  (C7H7ClN2O, CAS 5202-85-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino5Chlorobenzamide;
formula     C7H7ClN2O;
CAS         5202-85-7;
InChIKey    DNRVZOZGQHHDAT-UHFFFAOYSA-N;
MW          170.596;      // g/mol [origin=calculated method=formula-sum]
Tc          884.06;      // K   [origin=predictive method=joback]
Pc          47.628;      // bar [origin=predictive method=joback]
omega       0.8152;      // -   [origin=predictive method=lee-kesler]
Tb          632.76;      // K   [origin=predictive method=joback]
HvapTb      67189.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.45 0.5735 -0.00034262 6.976e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group CdO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-5-chloranyl-benzamide" "5-chloroanthranilamide" "benzamide, 2-amino-5-chloro-" "2-amino-5-chloro-benzamide" "5-chloro-2-amino-benzamide" );
standardThermochemistry
{
    dHf_298   -34960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93260.0
}
