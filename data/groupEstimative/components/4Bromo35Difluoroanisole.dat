/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-3,5-difluoroanisole  (C7H5BrF2O, CAS 202865-61-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo35Difluoroanisole;
formula     C7H5BrF2O;
CAS         202865-61-0;
InChIKey    GEJMNTXYFBBTFH-UHFFFAOYSA-N;
MW          223.016;      // g/mol [origin=calculated method=formula-sum]
Tc          698.36;      // K   [origin=predictive method=joback]
Pc          37.090;      // bar [origin=predictive method=joback]
omega       0.5596;      // -   [origin=predictive method=lee-kesler]
Tb          488.50;      // K   [origin=predictive method=joback]
HvapTb      42649.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.39 0.41002 -0.00018028 1.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group CH3O; count 1; } { group Br; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 2; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-1,3-bis(fluoranyl)-5-methoxy-benzene" "2-bromo-1,3-difluoro-5-methoxybenzene" "3,5-difluoro-4-bromoanisole" "4-bromo-3,5-difluorophenyl methyl ether" "q244" );
gibbsFormation
{
    dHf_298   -483800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-388720.0
    phase     gas;
}
