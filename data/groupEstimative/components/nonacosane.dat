/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonacosane  (C29H60, CAS 630-03-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonacosane;
formula     C29H60;
CAS         630-03-5;
InChIKey    IGGUPRCHHJZPBS-UHFFFAOYSA-N;
MW          408.799;      // g/mol [origin=calculated method=formula-sum]
Tc          1060.77;      // K   [origin=predictive method=joback]
Pc          6.244;      // bar [origin=predictive method=joback]
omega       0.5053;      // -   [origin=predictive method=lee-kesler]
Tb          863.12;      // K   [origin=predictive method=joback]
HvapTb      80148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.473 2.75884 -0.0015538 3.339e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 27; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 27; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "celidoniol, deoxy-" "n-nonacosane" "ai3-36284" "nonacosane -" "octacosane, methyl-" "CH3-(CH2)27-CH3" "CH3-[CH2]27-ch3" "Nonacosane; Celidoniol, deoxy- (7CI); n-Nonacosane" "nonacosane, analytical standard" "CHEMBL428955" "HY-N5127" "N-c-29" );
gibbsFormation
{
    dHf_298   -641890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1285.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=193300.0
    phase     gas;
}
