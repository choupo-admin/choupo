/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimyristin  (C45H86O6, CAS 555-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimyristin;
formula     C45H86O6;
CAS         555-45-3;
InChIKey    DUXYWXYOBMKGIN-UHFFFAOYSA-N;
MW          723.177;      // g/mol [origin=calculated method=formula-sum]
Tc          2247.81;      // K   [origin=predictive method=joback]
Pc          3.288;      // bar [origin=predictive method=joback]
omega       -0.5834;      // -   [origin=predictive method=lee-kesler]
Tb          1403.42;      // K   [origin=predictive method=joback]
HvapTb      137597.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.528 4.12036 -0.0021436 3.525e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 35; } { group CH; count 1; } { group CH2COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 38; } { group CH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-di(tetradecanoyloxy)propyl tetradecanoate" "glycerol trimyristate" "glyceryl trimyristate" "myristin" "myristic acid triglyceride" "propane-1,2,3-triyl tritetradecanoate" "1,2,3-tritetradecanoylglycerol" "tetradecanoic acid, 1,2,3-propanetriyl ester" "1,2,3-tritetradecanoyl-rac-glycerol" "tetradecanoic acid, 1,1',1''-(1,2,3-propanetriyl) ester" "myristin, tri-" "myristin, tri- (8ci)" );
standardThermochemistry
{
    dHf_298   -1929250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     2053.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-605530.0
}
