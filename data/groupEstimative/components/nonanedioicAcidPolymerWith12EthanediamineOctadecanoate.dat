/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonanedioic acid, polymer with 1,2-ethanediamine, octadecanoate  (C29H60N2O6, CAS 68409-62-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonanedioicAcidPolymerWith12EthanediamineOctadecanoate;
formula     C29H60N2O6;
CAS         68409-62-1;
InChIKey    OOCQSDVZSQJQTO-UHFFFAOYSA-N;
MW          532.807;      // g/mol [origin=calculated method=formula-sum]
Tc          1975.57;      // K   [origin=predictive method=joback]
Pc          6.936;      // bar [origin=predictive method=joback]
omega       -0.0225;      // -   [origin=predictive method=lee-kesler]
Tb          1447.51;      // K   [origin=predictive method=joback]
HvapTb      153510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (84.945 2.62262 -0.0010288 5.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 23; } { group CH2NH2; count 2; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 25; } { group COOH; count 3; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-diamine;nonanedioic acid;octadecanoic acid" "ethane-1,2-diamine; nonanedioic acid; octadecanoic acid" );
standardThermochemistry
{
    dHf_298   -1848360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1763.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-915050.0
}
