/*--------------------------------*- Choupo -*-----------------------*\
  Component: norhyoscyamine  (C16H21NO3, CAS 537-29-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norhyoscyamine;
formula     C16H21NO3;
CAS         537-29-1;
InChIKey    ATKYNAZQGVYHIB-MLGYPOCJSA-N;
MW          275.348;      // g/mol [origin=calculated method=formula-sum]
Tc          1030.41;      // K   [origin=predictive method=joback]
Pc          24.605;      // bar [origin=predictive method=joback]
omega       1.2343;      // -   [origin=predictive method=lee-kesler]
Tb          808.22;      // K   [origin=predictive method=joback]
HvapTb      83803.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.409 1.6727 -0.0010484 2.346e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CHNH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-azabicyclo[3.2.1]octan-3-yl (2s)-3-oxidanyl-2-phenyl-propanoate" "tropic acid, 3alpha-nortropanyl ester" "8-azabicyclo[3.2.1]octan-3-yl (2s)-3-hydroxy-2-phenylpropanoate" "benzeneacetic acid, alpha-(hydroxymethyl)-, (3-endo)-8-azabicyclo(3.2.1)oct-3-yl ester, (alphas)-" );
standardThermochemistry
{
    dHf_298   -461080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76080.0
}
