/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,6,7,8,11,12-octahydrobenzo(e)pyren-9(10h)-one  (C20H20O, CAS 68151-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1236781112OctahydrobenzoEPyren910hOne;
formula     C20H20O;
CAS         68151-08-6;
InChIKey    UIJOUFUKJPLQEK-UHFFFAOYSA-N;
MW          276.379;      // g/mol [origin=calculated method=formula-sum]
Tc          1100.58;      // K   [origin=predictive method=joback]
Pc          22.611;      // bar [origin=predictive method=joback]
omega       0.8953;      // -   [origin=predictive method=lee-kesler]
Tb          839.06;      // K   [origin=predictive method=joback]
HvapTb      73087.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.08 1.8185 -0.00136628 4.236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 5; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group dCH_ring; count 2; } { group dC_ring; count 8; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,6,7,8,10,11,12-octahydro-1h-benzo[e]pyren-9-one" "1,2,3,6,7,8,11,12-octahydrobenzo[e]pyren-9(10h)-one" "1,3,6,7,8,10,11,12-octahydrobenzo[e]pyren-9(2h)-one" "benzo[e]pyren-9(2h)-one, 1,3,6,7,8,10,11,12-octahydro-" );
gibbsFormation
{
    dHf_298   38210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=349490.0
    phase     gas;
}
