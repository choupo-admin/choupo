/*--------------------------------*- Choupo -*-----------------------*\
  Component: methanol, bis(4-amino-3,5-xylyl)(2,6-dichlorophenyl)-  (C23H24Cl2N2O, CAS 64365-65-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methanolBis4Amino35Xylyl26Dichlorophenyl;
formula     C23H24Cl2N2O;
CAS         64365-65-7;
InChIKey    ZKGNNLGZTFBGLG-UHFFFAOYSA-N;
MW          415.358;      // g/mol [origin=calculated method=formula-sum]
Tc          1420.01;      // K   [origin=predictive method=joback]
Pc          17.332;      // bar [origin=predictive method=joback]
omega       1.4038;      // -   [origin=predictive method=lee-kesler]
Tb          1154.59;      // K   [origin=predictive method=joback]
HvapTb      124351.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.24 1.77338 -0.00111448 2.615e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 7; } { group AC; count 3; } { group ACCH3; count 4; } { group OH; count 1; } { group ACNH2; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 11; } { group Cl; count 2; } { group OH; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(4-azanyl-3,5-dimethyl-phenyl)-[2,6-bis(chloranyl)phenyl]methanol" "bis(4-amino-3,5-dimethylphenyl)-(2,6-dichlorophenyl)methanol" "benzenemethanol, 4-amino-.alpha.-(4-amino-3,5-dimethylphenyl)-.alpha.-(2,6-dichlorophenyl)-3,5-dimethyl-" "benzenemethanol, 4-amino-alpha-(4-amino-3,5-dimethylphenyl)-alpha-(2,6-dichlorophenyl)-3,5-dimethyl-" );
gibbsFormation
{
    dHf_298   -25100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     865.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=378030.0
    phase     gas;
}
