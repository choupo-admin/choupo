/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-bis(dimethylamino)naphtalene  (C14H18N2, CAS 20734-58-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18BisDimethylaminoNaphtalene;
formula     C14H18N2;
CAS         20734-58-1;
InChIKey    GJFNRSDCSTVPCJ-UHFFFAOYSA-N;
MW          214.312;      // g/mol [origin=calculated method=formula-sum]
Tc          816.82;      // K   [origin=predictive method=joback]
Pc          24.507;      // bar [origin=predictive method=joback]
omega       0.6629;      // -   [origin=predictive method=lee-kesler]
Tb          600.42;      // K   [origin=predictive method=joback]
HvapTb      56084.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.97 1.38008 -0.00099684 2.87e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 6; } { group AC; count 4; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n1,n8,n8-tetramethylnaphthalene-1,8-diamine" "1,8-bis(dimethylamino)naphthalene" "1,8-naphthalenediamine, n,n,n',n'-tetramethyl-" "n,n,n',n'-tetramethyl-1,8-naphthalenediamine" "1,8-bis[dimethylamino]naphthalene" "n,n,n',n'-tetramethyl-1,8-naphthalene diamine" "n,n,n',n'-tetramethylnaphthalene-1,8-diamine" "1-n,1-n,8-n,8-n-tetramethylnaphthalene-1,8-diamine" "[8-(dimethylamino)naphthyl]dimethylamine" "proton sponge" "proton-sponge" "proton-sponge(r)" );
gibbsFormation
{
    dHf_298   207430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=488360.0
    phase     gas;
}
