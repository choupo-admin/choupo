/*--------------------------------*- Choupo -*-----------------------*\
  Component: oleyl isostearate  (C36H70O2, CAS 67989-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oleylIsostearate;
formula     C36H70O2;
CAS         67989-86-0;
InChIKey    AVIRVCOMMNJIBK-UHFFFAOYSA-N;
MW          534.954;      // g/mol [origin=calculated method=formula-sum]
Tc          1395.74;      // K   [origin=predictive method=joback]
Pc          4.707;      // bar [origin=predictive method=joback]
omega       -0.0112;      // -   [origin=predictive method=lee-kesler]
Tb          1085.22;      // K   [origin=predictive method=joback]
HvapTb      102707.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.291 3.39496 -0.001927 4.07e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 28; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 29; } { group CH; count 1; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadec-9-enyl 16-methylheptadecanoate" "isooctadecanoic acid, (9z)-9-octadecen-1-yl ester" );
standardThermochemistry
{
    dHf_298   -991710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1593.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=19650.0
}
