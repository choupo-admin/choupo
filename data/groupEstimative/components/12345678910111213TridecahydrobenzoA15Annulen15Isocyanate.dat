name        12345678910111213TridecahydrobenzoA15Annulen15Isocyanate;
formula     C15H19NO6;
CAS         83935-62-0;
InChIKey    YJNIAJAKNITJDO-UHFFFAOYSA-N;
MW          309.318;      // g/mol [origin=calculated method=formula-sum]
Tc          1102.32;      // K   [origin=predictive method=joback]
Pc          27.269;      // bar [origin=predictive method=joback]
omega       0.9553;      // -   [origin=predictive method=lee-kesler]
Tb          834.97;      // K   [origin=predictive method=joback]
HvapTb      86608.0;      // J/mol [origin=predictive method=joback]

