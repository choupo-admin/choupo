/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 3,3'-thiodipropionate  (C8H14O4S, CAS 4131-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl33Thiodipropionate;
formula     C8H14O4S;
CAS         4131-74-2;
InChIKey    MYWWWNVEZBAKHR-UHFFFAOYSA-N;
MW          206.256;      // g/mol [origin=calculated method=formula-sum]
Tc          763.68;      // K   [origin=predictive method=joback]
Pc          26.057;      // bar [origin=predictive method=joback]
omega       0.7785;      // -   [origin=predictive method=lee-kesler]
Tb          567.86;      // K   [origin=predictive method=joback]
HvapTb      55033.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (66.034 0.64863 -0.000182 -5.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2COO; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group COO; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-(3-methoxy-3-oxidanylidene-propyl)sulfanylpropanoate" "dimethyl thiodipropionate" "propanoic acid, 3,3'-thiobis-, dimethyl ester" "dimethyl 3,3'-thiodipropanoate" "3,3'-thiodipropionic acid dimethyl ester" "bis(2-methoxycarbonylethyl)sulfide" "propanoic acid, 3,3'-thiobis-, 1,1'-dimethyl ester" "propionic acid,3'-thiodi-, dimethyl ester" "propanoic acid,3'-thiobis-, dimethyl ester" ".beta.,.beta.'-dicarbomethoxydiethyl sulfide" "dimethyl 3,3?-thiodipropionate" "dimethyl 3,3'-thiobispropionate" );
standardThermochemistry
{
    dHf_298   -801140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     631.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-571140.0
}
