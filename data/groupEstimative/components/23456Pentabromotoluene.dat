/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,5,6-pentabromotoluene  (C7H3Br5, CAS 87-83-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23456Pentabromotoluene;
formula     C7H3Br5;
CAS         87-83-2;
InChIKey    OZHJEQVYCBTHJT-UHFFFAOYSA-N;
MW          486.621;      // g/mol [origin=calculated method=formula-sum]
Tc          1035.23;      // K   [origin=predictive method=joback]
Pc          60.186;      // bar [origin=predictive method=joback]
omega       0.9384;      // -   [origin=predictive method=lee-kesler]
Tb          742.14;      // K   [origin=predictive method=joback]
HvapTb      68937.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (75.07 0.48342 -0.00041 1.436e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 5; } { group ACCH3; count 1; } { group Br; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dC_ring; count 6; } { group Br; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(bromanyl)-6-methyl-benzene" "pentabromotoluene" "pentabromomethylbenzene" "benzene, pentabromomethyl-" "flammex 5bt" "1,2,3,4,5-pentabromo-6-methylbenzene" "toluene, 2,3,4,5,6-pentabromo-" "benzene, 1,2,3,4,5-pentabromo-6-methyl-" "benzene, methyl-, pentabromo deriv." "benzene,pentabromomethyl- (9ci);toluene, 2,3,4,5,6-pentabromo- (6ci,7ci,8ci);2,3,4,5,6-pentabromomethylbenzene;2,3,4,5,6-pentabromotoluene;flammex 5bt;pbt;pbt (flame retardant);pentabromomethylbenzene;pentabromotoluene;" );
gibbsFormation
{
    dHf_298   123020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143920.0
    phase     gas;
}
