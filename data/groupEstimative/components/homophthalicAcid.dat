/*--------------------------------*- Choupo -*-----------------------*\
  Component: homophthalic acid  (C9H8O4, CAS 89-51-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        homophthalicAcid;
formula     C9H8O4;
CAS         89-51-0;
InChIKey    ZHQLTKAVLJKSKR-UHFFFAOYSA-N;
MW          180.159;      // g/mol [origin=calculated method=formula-sum]
Tc          961.61;      // K   [origin=predictive method=joback]
Pc          39.655;      // bar [origin=predictive method=joback]
omega       1.1819;      // -   [origin=predictive method=lee-kesler]
Tb          728.20;      // K   [origin=predictive method=joback]
HvapTb      72894.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.699 0.822 -0.00057516 1.525e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxy-2-oxoethyl)benzoic acid" "benzeneacetic acid, 2-carboxy-" "2-(carboxymethyl)benzoic acid" "2-carboxyphenylacetic acid" "alpha-carboxy-o-toluic acid" "2-carboxybenzeneacetic acid" "(2-carboxyphenyl)acetic acid" "(o-carboxymethyl)benzoic acid" "o-toluic acid, alpha-carboxy-" "o-toluic acid, .alpha.-carboxy-" "toluene-alpha,2-dicarboxylic acid" ".alpha.-carboxy-o-toluic acid" );
standardThermochemistry
{
    dHf_298   -704570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-560140.0
}
