/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-amino-2-butanol  (C4H11NO, CAS 13552-21-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Amino2Butanol;
formula     C4H11NO;
CAS         13552-21-1;
InChIKey    KODLUXHSIZOKTG-UHFFFAOYSA-N;
MW          89.138;      // g/mol [origin=calculated method=formula-sum]
Tc          635.06;      // K   [origin=predictive method=joback]
Pc          47.892;      // bar [origin=predictive method=joback]
omega       0.8308;      // -   [origin=predictive method=lee-kesler]
Tb          455.39;      // K   [origin=predictive method=joback]
HvapTb      51430.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.352 0.48562 -0.0002708 5.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azanylbutan-2-ol" "1-aminobutan-2-ol" "2-butanol, 1-amino-" "monobutanolamine" "mono-sec-butanolamine" "1-amino-butan-2-ol" "amino-2-butanol" "kodluxhsizoktg-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -249610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90010.0
    phase     gas;
}
