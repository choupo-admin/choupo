/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromoadamantane  (C10H15Br, CAS 768-90-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromoadamantane;
formula     C10H15Br;
CAS         768-90-1;
InChIKey    VQHPRVYDKRESCL-UHFFFAOYSA-N;
MW          215.134;      // g/mol [origin=calculated method=formula-sum]
Tc          755.59;      // K   [origin=predictive method=joback]
Pc          35.347;      // bar [origin=predictive method=joback]
omega       0.4056;      // -   [origin=predictive method=lee-kesler]
Tb          514.62;      // K   [origin=predictive method=joback]
HvapTb      42740.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-197.91 1.7005 -0.001683 6.797e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyladamantane" "1-adamantyl bromide" "adamantyl bromide" "1-bromo-adamantane" "bromoadamantane" "1-bromotricyclo(3.3.1.13,7)decane" "tricyclo[3.3.1.1(3,7)-]decane, 1-bromo-" "adamantane, 1-bromo-" "1-bromo adamantane" "adamantane,1-bromo" "ambap768-90-1" "(3s,5s,7s)-1-bromoadamantane" );
standardThermochemistry
{
    dHf_298   -16260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=204590.0
}
