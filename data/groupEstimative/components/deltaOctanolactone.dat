/*--------------------------------*- Choupo -*-----------------------*\
  Component: delta-octanolactone  (C8H14O2, CAS 698-76-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        deltaOctanolactone;
formula     C8H14O2;
CAS         698-76-0;
InChIKey    FYTRVXSHONWYNE-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          644.61;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       0.4787;      // -   [origin=predictive method=lee-kesler]
Tb          451.87;      // K   [origin=predictive method=joback]
HvapTb      40894.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.338 0.85032 -0.0004906 9.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-propyloxan-2-one" "5-octanolide" "delta-octalactone" "2h-pyran-2-one, tetrahydro-6-propyl-" "5-octalactone" ".delta.-octalactone" "5-hydroxyoctanoic acid lactone" "tetrahydro-6-propyl-2h-pyran-2-one" "delta-propyl-delta-valerolactone" "5-propyl-5-hydroxypentanoic acid lactone" "delta-octanolide" "6-propyl-tetrahydropyran-2-one" );
gibbsFormation
{
    dHf_298   -459090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-245240.0
    phase     gas;
}
