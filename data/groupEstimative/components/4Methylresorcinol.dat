/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylresorcinol  (C7H8O2, CAS 496-73-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylresorcinol;
formula     C7H8O2;
CAS         496-73-1;
InChIKey    FNYDIAAMUCQQDE-UHFFFAOYSA-N;
MW          124.139;      // g/mol [origin=calculated method=formula-sum]
Tc          791.14;      // K   [origin=predictive method=joback]
Pc          62.888;      // bar [origin=predictive method=joback]
omega       0.7236;      // -   [origin=predictive method=lee-kesler]
Tb          547.68;      // K   [origin=predictive method=joback]
HvapTb      59480.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.22 0.89912 -0.00090092 3.638e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylbenzene-1,3-diol" "2,4-toluenediol" "1,3-benzenediol, 4-methyl-" "2,4-dihydroxytoluene" "2,4-dihydroxyphenylmethane" "4-methyl-1,3-benzenediol" "1,3-dihydroxy-4-methylbenzene" "1,3-benzenediol,4-methyl-" "ghl.pd_mitscher_leg0.301" );
gibbsFormation
{
    dHf_298   -305900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-188770.0
    phase     gas;
}
