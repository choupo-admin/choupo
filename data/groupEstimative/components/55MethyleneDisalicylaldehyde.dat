/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5'-methylene disalicylaldehyde  (C15H12O4, CAS 3046-82-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H12O4 (delta C+2H+2O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        55MethyleneDisalicylaldehyde;
formula     C15H12O4;
CAS         3046-82-0;
InChIKey    OWPBOKWFRAIKTD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          256.257;      // g/mol [origin=calculated method=formula-sum]
Tc          975.79;      // K   [origin=predictive method=joback]
Pc          37.180;      // bar [origin=predictive method=joback]
omega       0.9172;      // -   [origin=predictive method=lee-kesler]
Tb          720.20;      // K   [origin=predictive method=joback]
HvapTb      76142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.799 1.4774 -0.00153924 6.281e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } { group CHO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-[(3-methanoyl-4-oxidanyl-phenyl)methyl]-2-oxidanyl-benzaldehyde" "5,5'-methylenebis(2-hydroxybenzaldehyde)" "benzaldehyde, 3,3'-methylenebis[6-hydroxy-" );
standardThermochemistry
{
    dHf_298   -104530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     729.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=59660.0
}
