/*--------------------------------*- Choupo -*-----------------------*\
  Component: methane, di-sec-butoxy-  (C9H20O2, CAS 2568-92-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methaneDiSecButoxy;
formula     C9H20O2;
CAS         2568-92-5;
InChIKey    YJBUXLCNFNPNEB-UHFFFAOYSA-N;
MW          160.257;      // g/mol [origin=calculated method=formula-sum]
Tc          619.97;      // K   [origin=predictive method=joback]
Pc          22.676;      // bar [origin=predictive method=joback]
omega       0.5352;      // -   [origin=predictive method=lee-kesler]
Tb          449.48;      // K   [origin=predictive method=joback]
HvapTb      39672.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.343 0.74428 -0.0002502 -1.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH-O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(butan-2-yloxymethoxy)butane" "butane, 2,2'-[methylenebis(oxy)]bis-" "di(sec-butoxy)methane" );
standardThermochemistry
{
    dHf_298   -504090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-189980.0
}
