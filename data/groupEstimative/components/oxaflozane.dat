/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxaflozane  (C14H18F3NO, CAS 26629-87-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxaflozane;
formula     C14H18F3NO;
CAS         26629-87-8;
InChIKey    FVYUQFQCEOZYHZ-UHFFFAOYSA-N;
MW          273.298;      // g/mol [origin=calculated method=formula-sum]
Tc          805.68;      // K   [origin=predictive method=joback]
Pc          20.946;      // bar [origin=predictive method=joback]
omega       0.6710;      // -   [origin=predictive method=lee-kesler]
Tb          600.39;      // K   [origin=predictive method=joback]
HvapTb      52371.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.18 1.61514 -0.00115226 3.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-propan-2-yl-2-[3-(trifluoromethyl)phenyl]morpholine" "conflictan" "oxaflozane (inn)" );
gibbsFormation
{
    dHf_298   -713580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-353040.0
    phase     gas;
}
