/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexamethylenediamine sebacate  (C16H34N2O4, CAS 6422-99-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexamethylenediamineSebacate;
formula     C16H34N2O4;
CAS         6422-99-7;
InChIKey    YWJUZWOHLHBWQY-UHFFFAOYSA-N;
MW          318.458;      // g/mol [origin=calculated method=formula-sum]
Tc          1228.33;      // K   [origin=predictive method=joback]
Pc          15.379;      // bar [origin=predictive method=joback]
omega       1.3580;      // -   [origin=predictive method=lee-kesler]
Tb          1003.16;      // K   [origin=predictive method=joback]
HvapTb      107114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.344 1.543 -0.0006638 4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH2NH2; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 14; } { group COOH; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decanedioic acid;hexane-1,6-diamine" "nylon 6-10 salt" "decanedioic acid, polymer with 1,6-hexanediamine" "decanedioic acid, compd. with 1,6-hexanediamine (1:1)" "hexamethylenediammonium sebacate" "decanedioic acid - hexane-1,6-diamine (1:1)" "sebacic acid, compd. with 1,6-hexanediamine (1:1)" "sebacic acid, compound with hexane-1,6-diamine (1:1)" "nylon 6/10" "sebakan hexamethylendiaminu" "poly(hexamethylene sebacamide)" "decanedioic acid; hexane-1,6-diamine" );
gibbsFormation
{
    dHf_298   -1118150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1096.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-575840.0
    phase     gas;
}
