/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7,7-trimethyl-3-(3-methyl-2-butenyl)bicyclo(4.1.0)heptan-4-one  (C15H24O, CAS 74499-59-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        377Trimethyl33Methyl2ButenylBicyclo410Heptan4One;
formula     C15H24O;
CAS         74499-59-5;
InChIKey    FWQHAOBZTWZRCE-UHFFFAOYSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          849.22;      // K   [origin=predictive method=joback]
Pc          19.631;      // bar [origin=predictive method=joback]
omega       0.5377;      // -   [origin=predictive method=lee-kesler]
Tb          623.55;      // K   [origin=predictive method=joback]
HvapTb      50347.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-181.899 2.1035 -0.0019827 8.118e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 2; } { group C; count 2; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7,7-trimethyl-4-(3-methylbut-2-enyl)bicyclo[4.1.0]heptan-3-one" "4,7,7-trimethyl-4-(3-methyl-2-butenyl)bicyclo(4.1.0)heptan-3-one" "bicyclo(4.1.0)heptan-3-one, 4,7,7-trimethyl-4-(3-methyl-2-butenyl)-" "bicyclo[4.1.0]heptan-3-one,4,7,7-trimethyl-4-(3-methyl-2-buten-1-yl)-" "bicyclo(4.1.0)heptan-3-one, 4,7,7-trimethyl-4-(3-methyl-2-buten-1-yl)-" "bicyclo[4.1.0]heptan-3-one,4,7,7-trimethyl-4-(3-methyl-2-butenyl)- (9ci)" );
gibbsFormation
{
    dHf_298   -253960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107500.0
    phase     gas;
}
