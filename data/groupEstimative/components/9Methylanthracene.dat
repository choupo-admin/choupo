/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-methylanthracene  (C15H12, CAS 779-02-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Methylanthracene;
formula     C15H12;
CAS         779-02-2;
InChIKey    CPGPAVAKSZHMBP-UHFFFAOYSA-N;
MW          192.261;      // g/mol [origin=calculated method=formula-sum]
Tc          866.63;      // K   [origin=predictive method=joback]
Pc          28.689;      // bar [origin=predictive method=joback]
omega       0.5469;      // -   [origin=predictive method=lee-kesler]
Tb          617.40;      // K   [origin=predictive method=joback]
HvapTb      55864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.94 1.22352 -0.00096276 3.052e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 4; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "anthracene, 9-methyl-" "9-methyl-anthracene" );
standardThermochemistry
{
    dHf_298   242800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=381870.0
}
