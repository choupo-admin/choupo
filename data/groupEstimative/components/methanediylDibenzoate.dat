/*--------------------------------*- Choupo -*-----------------------*\
  Component: methanediyl dibenzoate  (C15H12O4, CAS 5342-31-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methanediylDibenzoate;
formula     C15H12O4;
CAS         5342-31-4;
InChIKey    BDDYZHKLKHFEBJ-UHFFFAOYSA-N;
MW          256.257;      // g/mol [origin=calculated method=formula-sum]
Tc          949.05;      // K   [origin=predictive method=joback]
Pc          25.354;      // bar [origin=predictive method=joback]
omega       0.8382;      // -   [origin=predictive method=lee-kesler]
Tb          712.60;      // K   [origin=predictive method=joback]
HvapTb      68350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.739 1.1614 -0.0006654 1.041e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 10; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenylcarbonyloxymethyl benzoate" "benzoyloxymethyl benzoate" "(benzoyloxy)methyl benzoate" "methanediol, dibenzoate" );
gibbsFormation
{
    dHf_298   -514430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-320500.0
    phase     gas;
}
