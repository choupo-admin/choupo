/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,7,8,9-tetrahydro-5h-5,9-methanobenzo[7]annulene  (C12H14, CAS 15391-62-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6789Tetrahydro5h59Methanobenzo7Annulene;
formula     C12H14;
CAS         15391-62-5;
InChIKey    ZFJANHNOMPZUJM-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          753.08;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.4119;      // -   [origin=predictive method=lee-kesler]
Tb          519.30;      // K   [origin=predictive method=joback]
HvapTb      45070.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.11 1.3072 -0.00103356 3.308e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,9-methano-5h-benzocycloheptene,6,7,8,9-tetrahydro-" "5,9-methano-5h-benzocycloheptene, 6,7,8,9-tetrahydro-" );
standardThermochemistry
{
    dHf_298   79650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=274440.0
}
