/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-cyano-1-butyne  (C5H5N, CAS 19596-07-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Cyano1Butyne;
formula     C5H5N;
CAS         19596-07-7;
InChIKey    VMUWIDHKAIGONP-UHFFFAOYSA-N;
MW          79.102;      // g/mol [origin=calculated method=formula-sum]
Tc          611.38;      // K   [origin=predictive method=joback]
Pc          40.312;      // bar [origin=predictive method=joback]
omega       0.3469;      // -   [origin=predictive method=lee-kesler]
Tb          406.20;      // K   [origin=predictive method=joback]
HvapTb      37060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.122 0.3197 -0.00021313 6.039e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2CN; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group tCH; count 1; } { group tC; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-4-ynenitrile" "4-pentynenitrile" "1-cyano-3-butyne;4-cyano-1-butyne;" );
gibbsFormation
{
    dHf_298   310250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     326.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=347470.0
    phase     gas;
}
