/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-2-(hydroxymethyl)propane-1,3-diol;2-(2-hydroxyethylsulfanyl)ethanol;1-(2-hydroxyethylsulfanyl)propan-2-ol  (C15H36O7S2, CAS 109037-70-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl2HydroxymethylPropane13Diol22HydroxyethylsulfanylEthan;
formula     C15H36O7S2;
CAS         109037-70-9;
InChIKey    MDDFYFJOTGVVAB-UHFFFAOYSA-N;
MW          392.566;      // g/mol [origin=calculated method=formula-sum]
Tc          1853.01;      // K   [origin=predictive method=joback]
Pc          22.062;      // bar [origin=predictive method=joback]
omega       0.4429;      // -   [origin=predictive method=lee-kesler]
Tb          1324.75;      // K   [origin=predictive method=joback]
HvapTb      178275.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (120.971 1.37492 -0.00027 -1.823e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group C; count 1; } { group OH; count 7; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 1; } { group C; count 1; } { group OH; count 7; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-propanediol, 2-ethyl-2-(hydroxymethyl)-, polymer with 1-((2-hydroxyethyl)thio)-2-propanol and 2,2'-thiobis(ethanol)" );
gibbsFormation
{
    dHf_298   -1572070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1386.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1025200.0
    phase     gas;
}
