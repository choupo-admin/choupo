/*--------------------------------*- Choupo -*-----------------------*\
  Component: methoxyacetone  (C4H8O2, CAS 5878-19-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methoxyacetone;
formula     C4H8O2;
CAS         5878-19-3;
InChIKey    CUZLJOLBIRPEFB-UHFFFAOYSA-N;
MW          88.106;      // g/mol [origin=calculated method=formula-sum]
Tc          546.78;      // K   [origin=predictive method=joback]
Pc          41.303;      // bar [origin=predictive method=joback]
omega       0.4040;      // -   [origin=predictive method=lee-kesler]
Tb          367.41;      // K   [origin=predictive method=joback]
HvapTb      33654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.111 0.29264 -6.41e-05 -2.744e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxypropan-2-one" "methoxy-2-propanone" "2-propanone, 1-methoxy-" "1-methoxyacetone" "methoxyaceton" "1-methoxy-2-propanone" "methoxymethyl methyl ketone" "u020" "2-propanone,methoxy- (7ci);1-methoxy-2-propanone;1-methoxyacetone;methoxy-2-propanone;methoxyacetone;methoxymethyl methyl ketone;methyl methoxymethyl ketone;a-methoxyacetone;a-methoxypropanone;" );
standardThermochemistry
{
    dHf_298   -370690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-251120.0
}
