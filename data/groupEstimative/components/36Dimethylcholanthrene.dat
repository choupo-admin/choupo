/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-dimethylcholanthrene  (C22H18, CAS 85923-37-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Dimethylcholanthrene;
formula     C22H18;
CAS         85923-37-1;
InChIKey    IZPMYOTWMHCZPI-UHFFFAOYSA-N;
MW          282.386;      // g/mol [origin=calculated method=formula-sum]
Tc          1075.38;      // K   [origin=predictive method=joback]
Pc          20.364;      // bar [origin=predictive method=joback]
omega       0.8680;      // -   [origin=predictive method=lee-kesler]
Tb          823.60;      // K   [origin=predictive method=joback]
HvapTb      75784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.61 1.83384 -0.00153412 5.274e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 6; } { group ACCH3; count 2; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-dimethyl-1,2-dihydrobenzo[j]aceanthrylene" "cholanthrene, 3,6-dimethyl-" "3,6-dimethyl-1,2-dihydrocyclopenta[ij]tetraphene" "1,2-dihydro-3,6-dimethylbenz(j)aceanthrylene" "benz(j)aceanthrylene, 1,2-dihydro-3,6-dimethyl-" "benz(j)aceanthrylene, 1,2-dihydro-3,6-dimethyl- (9ci)" );
gibbsFormation
{
    dHf_298   342810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=589500.0
    phase     gas;
}
