/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 2,2'-(1,2-ethanediyl)bis[6-(1,1-dimethylethyl)-4-methyl-  (C24H34O2, CAS 6766-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol2212EthanediylBis611Dimethylethyl4Methyl;
formula     C24H34O2;
CAS         6766-56-9;
InChIKey    YKUUUTAPMKKPTK-UHFFFAOYSA-N;
MW          354.534;      // g/mol [origin=calculated method=formula-sum]
Tc          1218.53;      // K   [origin=predictive method=joback]
Pc          14.977;      // bar [origin=predictive method=joback]
omega       1.0993;      // -   [origin=predictive method=lee-kesler]
Tb          976.78;      // K   [origin=predictive method=joback]
HvapTb      99654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.328 2.44896 -0.00193236 6.358e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } { group ACCH3; count 2; } { group ACCH2; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 2; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tert-butyl-6-[2-(3-tert-butyl-5-methyl-2-oxidanyl-phenyl)ethyl]-4-methyl-phenol" "2-tert-butyl-6-[2-(3-tert-butyl-2-hydroxy-5-methylphenyl)ethyl]-4-methylphenol" );
standardThermochemistry
{
    dHf_298   -483630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     828.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=33940.0
}
