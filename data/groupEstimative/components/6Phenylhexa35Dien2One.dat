/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-phenylhexa-3,5-dien-2-one  (C12H12O, CAS 4173-44-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Phenylhexa35Dien2One;
formula     C12H12O;
CAS         4173-44-8;
InChIKey    PRNUCJKOERXADE-UHFFFAOYSA-N;
MW          172.227;      // g/mol [origin=calculated method=formula-sum]
Tc          790.60;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       0.5423;      // -   [origin=predictive method=lee-kesler]
Tb          563.03;      // K   [origin=predictive method=joback]
HvapTb      51244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.93 1.07692 -0.0008091 2.4286e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e,5e)-6-phenylhexa-3,5-dien-2-one" );
gibbsFormation
{
    dHf_298   67380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=194090.0
    phase     gas;
}
