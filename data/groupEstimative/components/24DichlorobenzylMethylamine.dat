/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,4-dichlorobenzyl)methylamine  (C8H9Cl2N, CAS 5013-77-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24DichlorobenzylMethylamine;
formula     C8H9Cl2N;
CAS         5013-77-4;
InChIKey    GUJXWKXDISDARD-UHFFFAOYSA-N;
MW          190.067;      // g/mol [origin=calculated method=formula-sum]
Tc          769.98;      // K   [origin=predictive method=joback]
Pc          32.803;      // bar [origin=predictive method=joback]
omega       0.5643;      // -   [origin=predictive method=lee-kesler]
Tb          544.31;      // K   [origin=predictive method=joback]
HvapTb      52208.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.881 0.65572 -0.00039792 8.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH2; count 1; } { group CH3NH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,4-dichlorophenyl)-n-methyl-methanamine" "n-methyl-2,4-dichlorobenzylamine" "n-(2,4-dichlorobenzyl)-n-methylamine" "2,4-dichloro-n-methylbenzylamine" "1-(2,4-dichlorophenyl)-n-methylmethanamine" "benzenemethanamine, 2,4-dichloro-n-methyl-" "2,4-dichlorobenzyl methyl amine" "[(2,4-dichlorophenyl)methyl]methylamine" "[(2,4-dichlorophenyl)methyl](methyl)amine" "(2,4-dichlorophenyl)-n-methylmethanamine" "benzylamine,2,4-dichloro-n-methyl- (6ci,7ci,8ci);n-methyl-2,4-dichlorobenzylamine;(2,4-dichlorobenzyl)methylamine;n-(2,4-ddichlorobenzyl)-n-methylamine;(2,4-dichlorobenzyl)methylamine95%;(2,4-dichlorophenyl)-n-methylmethanamine;" );
standardThermochemistry
{
    dHf_298   27130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175160.0
}
