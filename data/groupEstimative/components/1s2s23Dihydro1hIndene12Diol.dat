/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1s,2s)-2,3-dihydro-1h-indene-1,2-diol  (C9H10O2, CAS 4647-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1s2s23Dihydro1hIndene12Diol;
formula     C9H10O2;
CAS         4647-43-2;
InChIKey    YKXXBEOXRPZVCC-IUCAKERBSA-N;
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          820.62;      // K   [origin=predictive method=joback]
Pc          45.347;      // bar [origin=predictive method=joback]
omega       1.3002;      // -   [origin=predictive method=lee-kesler]
Tb          623.61;      // K   [origin=predictive method=joback]
HvapTb      71528.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.62 0.9128 -0.00065556 1.872e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trans-2,3-dihydro-1h-indene-1,2-diol" );
standardThermochemistry
{
    dHf_298   -256030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-92920.0
}
