/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,4-dimethoxy-5-methyl-phenyl)propan-2-amine  (C12H19NO2, CAS 79440-50-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        124Dimethoxy5MethylPhenylPropan2Amine;
formula     C12H19NO2;
CAS         79440-50-9;
InChIKey    NOEGLABJKXQKEG-UHFFFAOYSA-N;
MW          209.289;      // g/mol [origin=calculated method=formula-sum]
Tc          844.10;      // K   [origin=predictive method=joback]
Pc          23.726;      // bar [origin=predictive method=joback]
omega       0.7859;      // -   [origin=predictive method=lee-kesler]
Tb          632.71;      // K   [origin=predictive method=joback]
HvapTb      61641.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.781 0.82788 -0.00028368 -1.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH3O; count 2; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzeneethanamine, 2,4-dimethoxy-alpha,5-dimethyl-" "benzeneethanamine,2,4-dimethoxy-.alpha.,5-dimethyl-" );
gibbsFormation
{
    dHf_298   -324820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12310.0
    phase     gas;
}
