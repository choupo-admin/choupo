/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-bromo-2-iodotoluene  (C7H6BrI, CAS 116632-39-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Bromo2Iodotoluene;
formula     C7H6BrI;
CAS         116632-39-4;
InChIKey    GHTUADBHTFHMNI-UHFFFAOYSA-N;
MW          296.929;      // g/mol [origin=calculated method=formula-sum]
Tc          827.18;      // K   [origin=predictive method=joback]
Pc          42.056;      // bar [origin=predictive method=joback]
omega       0.4097;      // -   [origin=predictive method=lee-kesler]
Tb          555.70;      // K   [origin=predictive method=joback]
HvapTb      50584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.1 0.54812 -0.00040692 1.218e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group I; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-1-iodanyl-2-methyl-benzene" "4-bromo-1-iodo-2-methylbenzene" "1-bromo-4-iodo-5-methylbenzene" "5-bromo-2-iodotoluene," "5-bromo-2-iodomethylbenzene" "benzene,4-bromo-1-iodo-2-methyl-" "1-iodo-2-methyl-4-bromobenzene;4-bromo-1-iodo-2-methylbenzene;5-bromo-2-iodotoluene;" );
gibbsFormation
{
    dHf_298   128980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173650.0
    phase     gas;
}
