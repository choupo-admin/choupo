/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-isopropylpiperidine  (C8H17N, CAS 766-79-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nIsopropylpiperidine;
formula     C8H17N;
CAS         766-79-0;
InChIKey    KXIXHISTUVHOCY-UHFFFAOYSA-N;
MW          127.231;      // g/mol [origin=calculated method=formula-sum]
Tc          610.44;      // K   [origin=predictive method=joback]
Pc          32.028;      // bar [origin=predictive method=joback]
omega       0.3548;      // -   [origin=predictive method=lee-kesler]
Tb          414.59;      // K   [origin=predictive method=joback]
HvapTb      35623.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.18 1.05184 -0.00071 1.886e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propan-2-ylpiperidine" "1-isopropyl-piperidine" "1-(propan-2-yl)piperidine" "agn-pc-0d3t3s" "piperidine, 1-(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -65380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=169080.0
    phase     gas;
}
