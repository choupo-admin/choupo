/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-diethoxybutanenitrile  (C8H15NO2, CAS 18381-45-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Diethoxybutanenitrile;
formula     C8H15NO2;
CAS         18381-45-8;
InChIKey    DRZCPHGVEATLFR-UHFFFAOYSA-N;
MW          157.213;      // g/mol [origin=calculated method=formula-sum]
Tc          716.08;      // K   [origin=predictive method=joback]
Pc          24.100;      // bar [origin=predictive method=joback]
omega       0.6896;      // -   [origin=predictive method=lee-kesler]
Tb          529.12;      // K   [origin=predictive method=joback]
HvapTb      48312.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.934 0.57814 -0.0001616 -3.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2O; count 2; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group O; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cyanopropionaldehyde diethyl acetal" "butanenitrile, 4,4-diethoxy-" "butanenitrile,4,4-diethoxy-" "succinaldehydonitrile diethyl acetal" "3-cyano propionaldehyde diethylacetal" "propionaldehyde,3-cyano-, diethyl acetal (6ci,7ci);succinaldehydonitrile, diethyl acetal(8ci);3-cyanopropionaldehyde diethyl acetal;4,4-diethoxybutanenitrile;4,4-diethoxybutyronitrile;" );
gibbsFormation
{
    dHf_298   -313290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-62780.0
    phase     gas;
}
