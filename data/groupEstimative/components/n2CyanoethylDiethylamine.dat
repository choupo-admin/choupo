/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-cyanoethyl)diethylamine  (C7H14N2, CAS 5351-04-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2CyanoethylDiethylamine;
formula     C7H14N2;
CAS         5351-04-2;
InChIKey    LFFKXGFSDGRFQA-UHFFFAOYSA-N;
MW          126.203;      // g/mol [origin=calculated method=formula-sum]
Tc          659.33;      // K   [origin=predictive method=joback]
Pc          27.212;      // bar [origin=predictive method=joback]
omega       0.5784;      // -   [origin=predictive method=lee-kesler]
Tb          474.28;      // K   [origin=predictive method=joback]
HvapTb      43697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.834 0.72754 -0.0004386 1.032e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(diethylamino)propanenitrile" "propanenitrile, 3-(diethylamino)-" "3-diethylaminopropiononitrile" "3-(diethylamino)propionitrile" "propionitrile, 3-(diethylamino)-" "propanenitrile,3-(diethylamino)-" "propionitrile, 3-(diethylamino)- (8ci)" );
gibbsFormation
{
    dHf_298   44600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252020.0
    phase     gas;
}
