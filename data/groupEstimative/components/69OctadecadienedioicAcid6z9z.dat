/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,9-octadecadienedioic acid, (6z,9z)-  (C18H30O4, CAS 45267-68-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        69OctadecadienedioicAcid6z9z;
formula     C18H30O4;
CAS         45267-68-3;
InChIKey    UANZCTRZDQLPDX-PQZOIKATSA-N;
MW          310.434;      // g/mol [origin=calculated method=formula-sum]
Tc          1117.93;      // K   [origin=predictive method=joback]
Pc          14.091;      // bar [origin=predictive method=joback]
omega       1.2461;      // -   [origin=predictive method=lee-kesler]
Tb          910.78;      // K   [origin=predictive method=joback]
HvapTb      89906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.638 1.8554 -0.0012682 3.538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH=CH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group dCH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6z,9z)-octadeca-6,9-dienedioic acid" );
gibbsFormation
{
    dHf_298   -880950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     950.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-426700.0
    phase     gas;
}
