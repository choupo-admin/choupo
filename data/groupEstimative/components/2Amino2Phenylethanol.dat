/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-2-phenylethanol  (C8H11NO, CAS 7568-92-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino2Phenylethanol;
formula     C8H11NO;
CAS         7568-92-5;
InChIKey    IJXJGQCXFSSHNL-UHFFFAOYSA-N;
MW          137.182;      // g/mol [origin=calculated method=formula-sum]
Tc          785.03;      // K   [origin=predictive method=joback]
Pc          44.563;      // bar [origin=predictive method=joback]
omega       0.9339;      // -   [origin=predictive method=lee-kesler]
Tb          573.59;      // K   [origin=predictive method=joback]
HvapTb      62610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.189 0.7867 -0.0005196 1.298e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-2-phenyl-ethanol" "dl-2-phenylglycinol" "2-phenylglycinol" "beta-aminophenethyl alcohol" "benzeneethanol, beta-amino-" "2-amino-2-phenylethan-1-ol" "phenethyl alcohol, beta-amino-" "alpha-phenyl-alpha-amino-beta-oxyethane" "benzeneethanol, .beta.-amino-, (r)-" "d-(-)-alpha-phenylglycinol" "d(-)-.alpha.-phenylglycinol" "(r)-beta-aminophenethyl alcohol" );
standardThermochemistry
{
    dHf_298   -95640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56080.0
}
