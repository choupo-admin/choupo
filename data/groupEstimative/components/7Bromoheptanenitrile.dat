/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-bromoheptanenitrile  (C7H12BrN, CAS 20965-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Bromoheptanenitrile;
formula     C7H12BrN;
CAS         20965-27-9;
InChIKey    HVVQSKCGHAPHMV-UHFFFAOYSA-N;
MW          190.084;      // g/mol [origin=calculated method=formula-sum]
Tc          730.24;      // K   [origin=predictive method=joback]
Pc          29.345;      // bar [origin=predictive method=joback]
omega       0.6474;      // -   [origin=predictive method=lee-kesler]
Tb          528.00;      // K   [origin=predictive method=joback]
HvapTb      48089.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.716 0.6418 -0.0003974 9.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2CN; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group Br; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-bromanylheptanenitrile" "7-bromoheptanonitrile" "6-cyanohexyl bromide" "heptanenitrile, 7-bromo-" "l877" "7-bromoheptanonitrile; 6-bromohexyl cyanide" );
standardThermochemistry
{
    dHf_298   3400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=155560.0
}
