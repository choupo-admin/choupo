/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexyl-3-pentyldecanenitrile  (C21H41N, CAS 5345-33-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexyl3Pentyldecanenitrile;
formula     C21H41N;
CAS         5345-33-5;
InChIKey    SOULKXPPGBPHBK-UHFFFAOYSA-N;
MW          307.566;      // g/mol [origin=calculated method=formula-sum]
Tc          961.45;      // K   [origin=predictive method=joback]
Pc          9.526;      // bar [origin=predictive method=joback]
omega       0.8351;      // -   [origin=predictive method=lee-kesler]
Tb          778.93;      // K   [origin=predictive method=joback]
HvapTb      71522.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.674 2.05946 -0.0012594 3.043e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 15; } { group C; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 16; } { group C; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-hexyl-3-pentyl-decanenitrile" );
standardThermochemistry
{
    dHf_298   -320640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     941.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=261960.0
}
