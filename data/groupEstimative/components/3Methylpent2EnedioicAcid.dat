/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylpent-2-enedioic acid  (C6H8O4, CAS 5746-90-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylpent2EnedioicAcid;
formula     C6H8O4;
CAS         5746-90-7;
InChIKey    WKRBKYFIJPGYQC-UHFFFAOYSA-N;
MW          144.126;      // g/mol [origin=calculated method=formula-sum]
Tc          847.47;      // K   [origin=predictive method=joback]
Pc          41.144;      // bar [origin=predictive method=joback]
omega       1.0597;      // -   [origin=predictive method=lee-kesler]
Tb          631.94;      // K   [origin=predictive method=joback]
HvapTb      63316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.239 0.69532 -0.0005339 1.654e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl glutaconic acid" "2-pentenedioic acid,3-methyl-" );
gibbsFormation
{
    dHf_298   -760280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-616510.0
    phase     gas;
}
