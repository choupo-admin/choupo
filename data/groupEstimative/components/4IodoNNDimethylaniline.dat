/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-iodo-n,n-dimethylaniline  (C8H10IN, CAS 698-70-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4IodoNNDimethylaniline;
formula     C8H10IN;
CAS         698-70-4;
InChIKey    QYOPPZJZMFMBDN-UHFFFAOYSA-N;
MW          247.075;      // g/mol [origin=calculated method=formula-sum]
Tc          763.97;      // K   [origin=predictive method=joback]
Pc          34.848;      // bar [origin=predictive method=joback]
omega       0.3962;      // -   [origin=predictive method=lee-kesler]
Tb          519.88;      // K   [origin=predictive method=joback]
HvapTb      47756.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.99 0.78834 -0.00056956 1.619e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-iodanyl-n,n-dimethyl-aniline" "n,n-dimethyl-4-iodoaniline" "p-iodo-n,n-dimethylaniline" "(4-iodophenyl)-dimethyl-amine" "aniline, p-iodo-n,n-dimethyl-" );
gibbsFormation
{
    dHf_298   161010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=288160.0
    phase     gas;
}
