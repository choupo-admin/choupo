/*--------------------------------*- Choupo -*-----------------------*\
  Component: 16-[4-(2,4-dihydroxy-5-methyl-6-propan-2-yloxan-2-yl)-3-hydroxypentan-2-yl]-8-hydroxy-3,15-dimethoxy-5,7,9,11-tetramethyl-1-oxacyclohexadeca-3,5,11,13-tetraen-2-one  (C35H58O9, CAS 88899-55-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16424Dihydroxy5Methyl6Propan2Yloxan2Yl3Hydroxypentan2Yl8Hydr;
formula     C35H58O9;
CAS         88899-55-2;
InChIKey    XDHNQDDQEHDUTM-UHFFFAOYSA-N;
MW          622.84;      // g/mol [origin=calculated method=formula-sum]
Tc          2192.91;      // K   [origin=predictive method=joback]
Pc          7.332;      // bar [origin=predictive method=joback]
omega       -0.1137;      // -   [origin=predictive method=lee-kesler]
Tb          1549.76;      // K   [origin=predictive method=joback]
HvapTb      177479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.34 3.17572 -0.0013677 8.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 9; } { group CH2; count 2; } { group CH; count 11; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 3; } { group OH; count 4; } { group CH3O; count 2; } { group CH-O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 11; } { group CH; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 8; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group OH; count 4; } { group O; count 2; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,15-dimethoxy-5,7,9,11-tetramethyl-16-[4-[5-methyl-2,4-bis(oxidanyl)-6-propan-2-yl-oxan-2-yl]-3-oxidanyl-pentan-2-yl]-8-oxidanyl-1-oxacyclohexadeca-3,5,11,13-tetraen-2-one" "bafilomycin a1, from streptomyces griseus" "(3z,5e,7r,8s,9s,11e,13e,15s,16r)-16-[(2s,3r,4s)-4-[(2s,4r,5s,6s)-2,4-dihydroxy-5-methyl-6-propan-2-yloxan-2-yl]-3-hydroxypentan-2-yl]-8-hydroxy-3,15-dimethoxy-5,7,9,11-tetramethyl-1-oxacyclohexadeca-3,5,11,13-tetraen-2-one" );
standardThermochemistry
{
    dHf_298   -1980560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1410.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-936120.0
}
