/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenyl-1-cyclopentene  (C11H12, CAS 37689-22-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenyl1Cyclopentene;
formula     C11H12;
CAS         37689-22-8;
InChIKey    ZOZIUVMYACMJGS-UHFFFAOYSA-N;
MW          144.217;      // g/mol [origin=calculated method=formula-sum]
Tc          731.14;      // K   [origin=predictive method=joback]
Pc          33.529;      // bar [origin=predictive method=joback]
omega       0.3361;      // -   [origin=predictive method=lee-kesler]
Tb          492.40;      // K   [origin=predictive method=joback]
HvapTb      42905.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.72 1.0456 -0.00072048 1.889e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopent-2-en-1-ylbenzene" "benzene,2-cyclopenten-1-yl-" "benzene, 3-cyclopenten-1-yl-" "benzene, 2-cyclopenten-1-yl-" "phenylcyclopenten" "1-cyclopent-2-enyl-benzene" "[(1s)-cyclopent-2-en-1-yl]benzene" );
gibbsFormation
{
    dHf_298   84420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=220660.0
    phase     gas;
}
