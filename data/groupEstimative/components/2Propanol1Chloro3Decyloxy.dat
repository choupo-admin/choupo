/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propanol, 1-chloro-3-(decyloxy)-  (C13H27ClO2, CAS 18371-72-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propanol1Chloro3Decyloxy;
formula     C13H27ClO2;
CAS         18371-72-7;
InChIKey    YIEWJUDIKXQGKF-UHFFFAOYSA-N;
MW          250.807;      // g/mol [origin=calculated method=formula-sum]
Tc          814.41;      // K   [origin=predictive method=joback]
Pc          17.075;      // bar [origin=predictive method=joback]
omega       1.1308;      // -   [origin=predictive method=lee-kesler]
Tb          648.63;      // K   [origin=predictive method=joback]
HvapTb      67618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.071 1.22232 -0.0006264 1.07e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH2Cl; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 1; } { group Cl; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-decoxy-propan-2-ol" "1-chloro-3-(decyloxy)propan-2-ol" "1-chloro-3-decoxypropan-2-ol" );
standardThermochemistry
{
    dHf_298   -617120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     748.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197610.0
}
