/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-((2-chloroethyl)ethylamino)-o-tolualdehyde  (C12H16ClNO, CAS 92-10-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H16ClNO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        42ChloroethylEthylaminoOTolualdehyde;
formula     C12H16ClNO;
CAS         92-10-4;
InChIKey    VPQJPICTQVMGOG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          225.716;      // g/mol [origin=calculated method=formula-sum]
Tc          740.63;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.5541;      // -   [origin=predictive method=lee-kesler]
Tb          537.09;      // K   [origin=predictive method=joback]
HvapTb      49961.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.627 1.08474 -0.00081212 2.504e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CHO; count 1; } { group CH2N; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-chloroethyl(ethyl)amino]-2-methyl-benzaldehyde" "4-[2-chloroethyl(ethyl)amino]-2-methylbenzaldehyde" "4-((2-chloroethyl)(ethyl)amino)-2-methylbenzaldehyde" "4-((2-chloroethyl)ethylamino)-2-methylbenzaldehyde" "benzaldehyde, 4-((2-chloroethyl)ethylamino)-2-methyl-" "benzaldehyde, 4-[(2-chloroethyl)ethylamino]-2-methyl-" "4-(2-chloroethyl-ethylamino)-2-methylbenzaldehyde" );
gibbsFormation
{
    dHf_298   50820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=286120.0
    phase     gas;
}
