/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tridecene  (C13H26, CAS 2437-56-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Tridecene;
formula     C13H26;
CAS         2437-56-1;
InChIKey    VQOXUMQBYILCKR-UHFFFAOYSA-N;
MW          182.351;      // g/mol [origin=calculated method=formula-sum]
Tc          656.82;      // K   [origin=predictive method=joback]
Pc          17.019;      // bar [origin=predictive method=joback]
omega       0.6117;      // -   [origin=predictive method=lee-kesler]
Tb          493.72;      // K   [origin=predictive method=joback]
HvapTb      43862.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.92 1.21882 -0.0007063 1.609e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridec-1-ene" "n-tridec-1-ene" "tridecylene" "undecylethylene" "alpha-tridecene" );
gibbsFormation
{
    dHf_298   -186220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     657.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=146420.0
    phase     gas;
}
