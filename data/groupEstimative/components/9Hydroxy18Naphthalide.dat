/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-hydroxy-1,8-naphthalide  (C12H8O3, CAS 5656-90-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Hydroxy18Naphthalide;
formula     C12H8O3;
CAS         5656-90-6;
InChIKey    IKHBRFXMNHCNDC-UHFFFAOYSA-N;
MW          200.193;      // g/mol [origin=calculated method=formula-sum]
Tc          894.50;      // K   [origin=predictive method=joback]
Pc          36.865;      // bar [origin=predictive method=joback]
omega       1.1516;      // -   [origin=predictive method=lee-kesler]
Tb          678.38;      // K   [origin=predictive method=joback]
HvapTb      71201.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.07 1.0915 -0.00091164 3.002e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACCH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h,3h-naphtho(1,8-cd)pyran-1-one, 3-hydroxy-" "1h,3h-naphtho[1,8-cd]pyran-1-one, 3-hydroxy-" "1h,8-cd]pyran-1-one, 3-hydroxy-" "3-hydroxy-1h,3h-benzo[de]isochromen-1-one" "3-hydroxy-1h,3h-naphtho(1,8-cd)pyran-1-one" "1-naphthalenecarboxylic acid, 8-(dihydroxymethyl)-, .delta.-lactone" "1-naphthalenecarboxylic acid, 8-(dihydroxymethyl)-, delta-lactone" );
standardThermochemistry
{
    dHf_298   -270740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     367.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-112280.0
}
