/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4:7,8-dibenzo-2,5-dioxabicyclo[4.2.0]octa-3,7-diene  (C14H10O2, CAS 42896-18-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3478Dibenzo25Dioxabicyclo420Octa37Diene;
formula     C14H10O2;
CAS         42896-18-4;
InChIKey    SSPWYTLOLFBHPK-UHFFFAOYSA-N;
MW          210.232;      // g/mol [origin=calculated method=formula-sum]
Tc          895.33;      // K   [origin=predictive method=joback]
Pc          33.106;      // bar [origin=predictive method=joback]
omega       0.6543;      // -   [origin=predictive method=lee-kesler]
Tb          642.08;      // K   [origin=predictive method=joback]
HvapTb      61136.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.65 1.372 -0.00117152 3.976e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group CH-O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzo(b)benzo(3,4)cyclobuta(1,2-e)(1,4)dioxin, 4b,10a-dihydro-" "benzo[b]benzo[3,4]cyclobuta[1,2-e][1,4]dioxin, 4b,10a-dihydro-" "4b,10a-dihydrobenzo[b]benzo[3,4]cyclobuta[1,2-e][1,4]dioxine" );
gibbsFormation
{
    dHf_298   11750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     153.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=246020.0
    phase     gas;
}
