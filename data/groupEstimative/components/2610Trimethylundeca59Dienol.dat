/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6,10-trimethylundeca-5,9-dienol  (C14H26O, CAS 24048-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2610Trimethylundeca59Dienol;
formula     C14H26O;
CAS         24048-14-4;
InChIKey    SVHDKVPXRARVAO-UHFFFAOYSA-N;
MW          210.361;      // g/mol [origin=calculated method=formula-sum]
Tc          794.56;      // K   [origin=predictive method=joback]
Pc          18.139;      // bar [origin=predictive method=joback]
omega       0.9569;      // -   [origin=predictive method=lee-kesler]
Tb          619.74;      // K   [origin=predictive method=joback]
HvapTb      63125.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.975 1.41358 -0.0009436 2.631e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group CH=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group dCH; count 2; } { group dC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6,10-trimethylundeca-5,9-dien-1-ol" "5,9-undecadien-1-ol, 2,6,10-trimethyl-" "2,6,10-trimethyl-5,9-undecadien-1-ol" "(e)-2,6,10-trimethylundeca-5,9-dienol" "5,9-undecadien-1-ol, 2,6,10-trimethyl-, (e)-" "apofarnesol,dihydro-; dihydroapofarnesol" "5,9-undecadien-1-ol,2,6,10-trimethyl-" "5,9-undecadien-1-ol,2,6,10-trimethyl-, (e)-; (e)-2,6,10-trimethyl-5,9-undecadien-1-ol.;(e)-dihydroapofarnesol" );
standardThermochemistry
{
    dHf_298   -274940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71080.0
}
