/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-heptanoylbiphenyl  (C19H22O, CAS 59662-27-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Heptanoylbiphenyl;
formula     C19H22O;
CAS         59662-27-0;
InChIKey    YCPKHSFFVZYFMP-UHFFFAOYSA-N;
MW          266.384;      // g/mol [origin=calculated method=formula-sum]
Tc          971.09;      // K   [origin=predictive method=joback]
Pc          18.388;      // bar [origin=predictive method=joback]
omega       0.8341;      // -   [origin=predictive method=lee-kesler]
Tb          746.53;      // K   [origin=predictive method=joback]
HvapTb      69848.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.535 1.56352 -0.00098646 2.3196e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 9; } { group AC; count 3; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-phenylphenyl)heptan-1-one" "1-heptanone, 1-[1,1'-biphenyl]-4-yl-" "p-heptanoylbiphenyl" "1-heptanone, 1-(1,1'-biphenyl)-4-yl-" "4-enanthoylbiphenyl" "4-heptanoyldiphenyl" "1-[1,1'-biphenyl]-4-yl-1-heptanone" );
gibbsFormation
{
    dHf_298   -86480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     703.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195370.0
    phase     gas;
}
