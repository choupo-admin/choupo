/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-[(4s,7r,7ar)-3,7-dimethyl-2,4,5,6,7,7a-hexahydro-1h-inden-4-yl]-2-methyl-prop-2-enoic acid  (C15H22O2, CAS 3569-10-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34s7r7ar37Dimethyl245677aHexahydro1hInden4Yl2MethylProp2Enoi;
formula     C15H22O2;
CAS         3569-10-6;
InChIKey    FEBNTWHYQKGEIQ-JIMOISOXSA-N;
MW          234.339;      // g/mol [origin=calculated method=formula-sum]
Tc          947.31;      // K   [origin=predictive method=joback]
Pc          20.586;      // bar [origin=predictive method=joback]
omega       0.8463;      // -   [origin=predictive method=lee-kesler]
Tb          723.09;      // K   [origin=predictive method=joback]
HvapTb      67835.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.55 1.57106 -0.0010499 2.796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 3; } { group CH=C; count 1; } { group COOH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -454150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-108630.0
}
