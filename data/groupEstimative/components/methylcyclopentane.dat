/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylcyclopentane  (C6H12, CAS 96-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylcyclopentane;
formula     C6H12;
CAS         96-37-7;
InChIKey    GDOPTJXRTPNYNR-UHFFFAOYSA-N;
MW          84.162;      // g/mol [origin=calculated method=formula-sum]
Tc          547.19;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.2120;      // -   [origin=predictive method=lee-kesler]
Tb          352.16;      // K   [origin=predictive method=joback]
HvapTb      29207.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.05 0.70552 -0.00043 9.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentane, methyl-" "methyl cyclopentane" "methylpentamethylene" "methyl-cyclopentane" );
standardThermochemistry
{
    dHf_298   -106690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     339.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36190.0
}
