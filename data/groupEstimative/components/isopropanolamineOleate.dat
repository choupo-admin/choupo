/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropanolamine oleate  (C21H43NO3, CAS 25525-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropanolamineOleate;
formula     C21H43NO3;
CAS         25525-60-4;
InChIKey    BUBXSAWBUBKGAQ-UHFFFAOYSA-N;
MW          357.579;      // g/mol [origin=calculated method=formula-sum]
Tc          1222.25;      // K   [origin=predictive method=joback]
Pc          10.935;      // bar [origin=predictive method=joback]
omega       1.0148;      // -   [origin=predictive method=lee-kesler]
Tb          995.42;      // K   [origin=predictive method=joback]
HvapTb      106688.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.135 1.96524 -0.0009372 1.172e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 1; } { group dCH; count 2; } { group OH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azanylpropan-2-ol;octadec-9-enoic acid" "agn-pc-02jfrm" "oleic acid, compound with 1-aminopropan-2-ol (1:1)" "1-aminopropan-2-ol; octadec-9-enoic acid" "1-aminopropan-2-ol;(e)-octadec-9-enoic acid" );
gibbsFormation
{
    dHf_298   -945160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1221.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-315320.0
    phase     gas;
}
