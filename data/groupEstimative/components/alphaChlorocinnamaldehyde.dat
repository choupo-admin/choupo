/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-chlorocinnamaldehyde  (C9H7ClO, CAS 18365-42-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaChlorocinnamaldehyde;
formula     C9H7ClO;
CAS         18365-42-9;
InChIKey    SARRRAKOHPKFBW-TWGQIWQCSA-N;
MW          166.604;      // g/mol [origin=calculated method=formula-sum]
Tc          755.52;      // K   [origin=predictive method=joback]
Pc          36.421;      // bar [origin=predictive method=joback]
omega       0.4899;      // -   [origin=predictive method=lee-kesler]
Tb          522.33;      // K   [origin=predictive method=joback]
HvapTb      49047.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.78 0.7811 -0.0005965 1.775e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CHO; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-2-chloranyl-3-phenyl-prop-2-enal" "2-chloro-3-phenyl-2-propenal" "2-propenal, 2-chloro-3-phenyl-" "cinnamaldehyde, alpha-chloro-" "2-chloro-3-phenylprop-2-enal" "a-chlorocinnamaldehyde" ".alpha.-chlorocinnamaldehyde" "2-chloro-3-phenylacrylaldehyde" "(z)-2-chloro-3-phenylprop-2-enal" "(2z)-2-chloro-3-phenylprop-2-enal" "2-propenal, 2-chloro-3-phenyl- (9ci)" );
gibbsFormation
{
    dHf_298   13550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97530.0
    phase     gas;
}
