/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2',4'-dichloropropiophenone  (C9H8Cl2O, CAS 37885-41-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dichloropropiophenone;
formula     C9H8Cl2O;
CAS         37885-41-9;
InChIKey    FBMTWRZQBRHOPF-UHFFFAOYSA-N;
MW          203.062;      // g/mol [origin=calculated method=formula-sum]
Tc          801.27;      // K   [origin=predictive method=joback]
Pc          31.140;      // bar [origin=predictive method=joback]
omega       0.5857;      // -   [origin=predictive method=lee-kesler]
Tb          570.89;      // K   [origin=predictive method=joback]
HvapTb      54744.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.541 0.64652 -0.00038502 8.056e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CH2CO; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,4-dichlorophenyl)propan-1-one" "2,4-dichloropropiophenone" "1-(2,4-dichlorophenyl)-1-propanone" "2 ,4 -dichloropropiophenone" "1-propanone,1-(2,4-dichlorophenyl)-" "1-propanone, 1-(2,4-dichlorophenyl)-" "1-(2,4-dichloro-phenyl)-propan-1-one" "1-(2,4-dichlorophenyl)-1-propanone;2,4-dichloropropiophenone;" );
gibbsFormation
{
    dHf_298   -159560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34730.0
    phase     gas;
}
