/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-3-(4-fluorophenyl)cyclohex-2-enone  (C14H15FO, CAS 72036-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl34FluorophenylCyclohex2Enone;
formula     C14H15FO;
CAS         72036-55-6;
InChIKey    FTHQUDLJYHQIKT-UHFFFAOYSA-N;
MW          218.271;      // g/mol [origin=calculated method=formula-sum]
Tc          889.11;      // K   [origin=predictive method=joback]
Pc          25.379;      // bar [origin=predictive method=joback]
omega       0.5727;      // -   [origin=predictive method=lee-kesler]
Tb          642.60;      // K   [origin=predictive method=joback]
HvapTb      53358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.44 1.33744 -0.0010082 3.355e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group F; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-fluorophenyl)-5,5-dimethyl-cyclohex-2-en-1-one" "3-(4-fluorophenyl)-5,5-dimethyl-2-cyclohexenone" "3-(4-fluorophenyl)-5,5-dimethylcyclohex-2-en-1-one" "5,5-dimethyl-3-(4-fluorophenyl)cyclohex-2-en-1-one" "2-cyclohexen-1-one,3-(4-fluorophenyl)-5,5-dimethyl-" "5,5-dimethyl-3-(4-fluorophenyl)-cyclohex-2-en-1-one" );
standardThermochemistry
{
    dHf_298   -325170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-108330.0
}
