/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-2-ethylaniline  (C8H10BrN, CAS 45762-41-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo2Ethylaniline;
formula     C8H10BrN;
CAS         45762-41-2;
InChIKey    LGOZNQPHTIGMQJ-UHFFFAOYSA-N;
MW          200.079;      // g/mol [origin=calculated method=formula-sum]
Tc          799.16;      // K   [origin=predictive method=joback]
Pc          41.144;      // bar [origin=predictive method=joback]
omega       0.5940;      // -   [origin=predictive method=lee-kesler]
Tb          557.97;      // K   [origin=predictive method=joback]
HvapTb      54078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.991 0.66602 -0.00042332 1.048e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACNH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-2-ethyl-aniline" "4-bromo-2-ethylphenylamine" "benzenamine, 4-bromo-2-ethyl-" );
gibbsFormation
{
    dHf_298   65260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=190400.0
    phase     gas;
}
