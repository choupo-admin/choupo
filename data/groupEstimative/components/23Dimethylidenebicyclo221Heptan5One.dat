/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethylidenebicyclo[2.2.1]heptan-5-one  (C9H10O, CAS 62289-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethylidenebicyclo221Heptan5One;
formula     C9H10O;
CAS         62289-63-8;
InChIKey    YBKLICDDXPIOLH-UHFFFAOYSA-N;
MW          134.178;      // g/mol [origin=calculated method=formula-sum]
Tc          711.06;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.4354;      // -   [origin=predictive method=lee-kesler]
Tb          489.41;      // K   [origin=predictive method=joback]
HvapTb      40191.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.89 0.7477 -0.000431 9.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group CH2=C; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicycllo(2.2.1)heptan-2-one, 5,6-dimethylene-" "bicycllo[2.2.1]heptan-2-one, 5,6-dimethylene-" "bicyclo[2.2.1]heptan-2-one, 5,6-dimethylene-" "bicyclo[2.2.1]heptan-2-one, 5,6-bis(methylene)-, (1s)-" "5,6-dimethylidenebicyclo[2.2.1]heptan-2-one" );
standardThermochemistry
{
    dHf_298   -58870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     214.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117870.0
}
