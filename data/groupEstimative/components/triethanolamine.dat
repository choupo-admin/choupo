/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethanolamine  (C6H15NO3, CAS 102-71-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triethanolamine;
formula     C6H15NO3;
CAS         102-71-6;
InChIKey    GSEJCLTVZPLZKY-UHFFFAOYSA-N;
MW          149.19;      // g/mol [origin=calculated method=formula-sum]
Tc          782.39;      // K   [origin=predictive method=joback]
Pc          43.283;      // bar [origin=predictive method=joback]
omega       1.9330;      // -   [origin=predictive method=lee-kesler]
Tb          625.86;      // K   [origin=predictive method=joback]
HvapTb      81030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.616 0.7997 -0.0005064 1.27e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group OH; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group OH; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2-hydroxyethyl)amino]ethanol" "trolamine" "2,2',2''-nitrilotriethanol" "daltogen" "sterolamide" "tris(2-hydroxyethyl)amine" "triethylolamine" "trihydroxytriethylamine" "nitrilotriethanol" "triethanolamin" "thiofaco t-35" "sodium isa" );
standardThermochemistry
{
    dHf_298   -556330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-300040.0
}
