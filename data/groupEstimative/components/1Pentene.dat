/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentene  (C5H10, CAS 109-67-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pentene;
formula     C5H10;
CAS         109-67-1;
InChIKey    YWAKXRMUMFPDSH-UHFFFAOYSA-N;
MW          70.135;      // g/mol [origin=calculated method=formula-sum]
Tc          476.76;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.2384;      // -   [origin=predictive method=lee-kesler]
Tb          310.68;      // K   [origin=predictive method=joback]
HvapTb      26054.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.648 0.45882 -0.0002711 6.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-1-ene" "pentene" "propylethylene" "pentylene" "1-n-pentene" "penten" "alpha-amylene" "alpha-n-amylene" "1-pentylene" ".alpha.-n-amylene" "1-amylene" "pentene (petroleum)" );
gibbsFormation
{
    dHf_298   -21100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79060.0
    phase     gas;
}
