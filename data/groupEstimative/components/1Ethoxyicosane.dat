/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethoxyicosane  (C22H46O, CAS 67763-08-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethoxyicosane;
formula     C22H46O;
CAS         67763-08-0;
InChIKey    PRGOMPHKWHPFFI-UHFFFAOYSA-N;
MW          326.609;      // g/mol [origin=calculated method=formula-sum]
Tc          891.93;      // K   [origin=predictive method=joback]
Pc          8.927;      // bar [origin=predictive method=joback]
omega       0.8182;      // -   [origin=predictive method=lee-kesler]
Tb          725.38;      // K   [origin=predictive method=joback]
HvapTb      66976.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.39 2.03064 -0.001062 1.958e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 19; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 20; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "alcohols, c20-28, ethoxylated" "alcohols, c20-30, ethoxylated" "aliphatic (c20-c30)alchol, ethoxylated" "poly(oxy-1,2-ethanediyl)-alpha-(c20-c28)alkyl-omega-hydroxy" );
standardThermochemistry
{
    dHf_298   -629630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1024.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29360.0
}
