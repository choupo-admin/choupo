/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1, n,n'-dimethyl-n,n'-bis(phenylmethyl)-  (C18H24N2, CAS 102-18-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1NNDimethylNNBisPhenylmethyl;
formula     C18H24N2;
CAS         102-18-1;
InChIKey    VRPZLDIUBCEYBA-UHFFFAOYSA-N;
MW          268.404;      // g/mol [origin=calculated method=formula-sum]
Tc          905.20;      // K   [origin=predictive method=joback]
Pc          19.102;      // bar [origin=predictive method=joback]
omega       0.7839;      // -   [origin=predictive method=lee-kesler]
Tb          689.68;      // K   [origin=predictive method=joback]
HvapTb      64300.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.666 1.80384 -0.001243 3.288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 10; } { group ACCH2; count 2; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-dimethyl-n,n'-bis(phenylmethyl)ethane-1,2-diamine" "n,n'-dibenzyl-n,n'-dimethylethylenediamine" "1,2-ethanediamine, n,n'-dimethyl-n,n'-bis(phenylmethyl)-" "ethylenediamine, n,n'-dibenzyl-n,n'-dimethyl-" "1,2-ethanediamine, n1,n2-dimethyl-n1,n2-bis(phenylmethyl)-" "ethylenediamine,n'-dibenzyl-n,n'-dimethyl-" "n,n'-dibenzyl-n,n'-dimethylethane-1,2-diamine" "benzyl({2-[benzyl(methyl)amino]ethyl})methylamine" "ethylenediamine, n,n'-dibenzyl-n,n'-dimethyl- (8ci)" "n, n'-dibenzyl-n, n'-dimethylethylenediamine" );
gibbsFormation
{
    dHf_298   193270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     676.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=547060.0
    phase     gas;
}
