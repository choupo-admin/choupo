/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetone-d6  (C3D6O, CAS 666-52-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C3D6O (delta D+6H-6; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        acetoneD6;
formula     C3D6O;
CAS         666-52-4;
InChIKey    CSCPPACGZOOCGX-WFGJKAKNSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          64.116;      // g/mol [origin=calculated method=formula-sum]
Tc          500.56;      // K   [origin=predictive method=joback]
Pc          48.025;      // bar [origin=predictive method=joback]
omega       0.2825;      // -   [origin=predictive method=lee-kesler]
Tb          322.11;      // K   [origin=predictive method=joback]
HvapTb      29018.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.52 0.26084 -0.0001207 1.546e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,3,3,3-hexadeuteriopropan-2-one" "hexadeuteroacetone" "d6-acetone" "2-propanone-1,1,1,3,3,3-d6-" "deuterated acetone" "(2h6)acetone" "e(r) u+/-ui feminine" "de10g" "acetone-d6 >99.9 atom % d" );
standardThermochemistry
{
    dHf_298   -217830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     299.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154540.0
}
