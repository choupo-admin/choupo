/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylmalonic acid  (C7H12O4, CAS 510-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylmalonicAcid;
formula     C7H12O4;
CAS         510-20-3;
InChIKey    LTMRRSWNXVJMBA-UHFFFAOYSA-N;
MW          160.169;      // g/mol [origin=calculated method=formula-sum]
Tc          859.39;      // K   [origin=predictive method=joback]
Pc          34.889;      // bar [origin=predictive method=joback]
omega       1.0573;      // -   [origin=predictive method=lee-kesler]
Tb          647.55;      // K   [origin=predictive method=joback]
HvapTb      64208.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.748 0.89624 -0.000674 2e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-diethylpropanedioic acid" "propanedioic acid, diethyl-" "malonic acid, diethyl-" "3,3-pentanedicarboxylic acid" "2,2-diethylmalonic acid" "propanedioic acid, 2,2-diethyl-" "diethyl malonic acid" "diethyl-malonic acid" "2,2-diethyl-malonic acid" "malonic acid, diethyl- (8ci)" "propanedioic acid,2,2-diethyl-" "ltmrrswnxvjmba-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -897100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-676920.0
}
