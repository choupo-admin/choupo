/*--------------------------------*- Choupo -*-----------------------*\
  Component: pandurol  (C6H8Br2O4, CAS 3785-34-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pandurol;
formula     C6H8Br2O4;
CAS         3785-34-0;
InChIKey    WGHAPLWNJPAJDE-UHFFFAOYSA-N;
MW          303.934;      // g/mol [origin=calculated method=formula-sum]
Tc          795.61;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.8922;      // -   [origin=predictive method=lee-kesler]
Tb          585.64;      // K   [origin=predictive method=joback]
HvapTb      56634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.634 0.5406 -0.0002562 1.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2COO; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group Br; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-bromanylethanoyloxy)ethyl 2-bromanylethanoate" "1,2-bis(bromoacetoxy)ethane" "ethylene bromoacetate" "ethylene bis(bromoacetate)" "ethylene glycol, bis(bromoacetate)" "bromoacetic acid 1,2-ethanediyl ester" "ethane-1,2-diyl bis(2-bromoacetate)" "1,2-ethanediyl bromoacetate" "s 13" "bromoacetic acid ethylene ester" "bromoacetic acid, ethylene ester" "1,2-bis-(bromoacetoxy)-ethane" );
gibbsFormation
{
    dHf_298   -749070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-592460.0
    phase     gas;
}
