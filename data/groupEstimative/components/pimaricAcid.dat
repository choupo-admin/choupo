/*--------------------------------*- Choupo -*-----------------------*\
  Component: pimaric acid  (C20H30O2, CAS 127-27-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pimaricAcid;
formula     C20H30O2;
CAS         127-27-5;
InChIKey    MHVJRKBZMUDEEV-UHFFFAOYSA-N;
MW          302.458;      // g/mol [origin=calculated method=formula-sum]
Tc          1081.01;      // K   [origin=predictive method=joback]
Pc          17.332;      // bar [origin=predictive method=joback]
omega       0.8516;      // -   [origin=predictive method=lee-kesler]
Tb          836.48;      // K   [origin=predictive method=joback]
HvapTb      74090.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-306.03 3.04656 -0.00299554 1.2375e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 2; } { group C; count 3; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-ethenyl-1,4a,7-trimethyl-3,4,4b,5,6,9,10,10a-octahydro-2h-phenanthrene-1-carboxylic acid" "pimara-8(14),15-dien-18-oic acid" "sandaracopimaric acid" "isopimaric acid (d)" "delta8(14)-isopimaric acid" "agn-pc-02lrw2" "podocarp-8(14)-en-15-oic acid, 13beta-methyl-13-vinyl-" "podocarp-8(14)-en-15-oic acid, 13.beta.-methyl-13-vinyl-" "13beta-methyl-13-vinylpodocarp-8(14)-en-15-oic acid" "podocarp-8(14)-en-15-oic acid, 13beta-methyl-13-vinyl- (8ci)" "(1r,4ar,4bs,7s)-7-ethenyl-1,4a,7-trimethyl-3,4,4b,5,6,9,10,10a-octahydro-2h-phenanthrene-1-carboxylic acid" "1-phenanthrenecarboxylic acid, 7-ethenyl-1,2,3,4,4a,4b,5, 6,7,9,10,10a-dodecahydro-1,4a,7-trimethyl-, [1r-(1?,4ass,4b? ,7?,10a?)]-" );
standardThermochemistry
{
    dHf_298   -442020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     892.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28360.0
}
