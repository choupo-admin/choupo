/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-d-fructopyranose  (C6H12O6, CAS 7660-25-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaDFructopyranose;
formula     C6H12O6;
CAS         7660-25-5;
InChIKey    LKDRXBCSQODPBY-ARQDHWQXSA-N;
MW          180.156;      // g/mol [origin=calculated method=formula-sum]
Tc          1018.09;      // K   [origin=predictive method=joback]
Pc          70.380;      // bar [origin=predictive method=joback]
omega       2.7161;      // -   [origin=predictive method=lee-kesler]
Tb          830.51;      // K   [origin=predictive method=joback]
HvapTb      115206.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.569 1.0753 -0.0008881 3.235e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 3; } { group C; count 1; } { group OH; count 5; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group C_ring; count 1; } { group OH; count 5; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3s,4r,5r)-2-(hydroxymethyl)oxane-2,3,4,5-tetrol" "fructosteril" "laevoral" "laevosan" "levugen" "frutabs" "fructopyranose, beta-d-" "bdf" "ss-d-fructopyranose" "a-d-fructopyranose" "fructose, pyranose form" );
gibbsFormation
{
    dHf_298   -1051780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-774750.0
    phase     gas;
}
