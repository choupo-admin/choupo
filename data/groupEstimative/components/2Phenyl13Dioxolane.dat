/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenyl-1,3-dioxolane  (C9H10O2, CAS 936-51-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenyl13Dioxolane;
formula     C9H10O2;
CAS         936-51-6;
InChIKey    LYINTWKRUWVLBA-UHFFFAOYSA-N;
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          741.82;      // K   [origin=predictive method=joback]
Pc          39.605;      // bar [origin=predictive method=joback]
omega       0.4144;      // -   [origin=predictive method=lee-kesler]
Tb          501.38;      // K   [origin=predictive method=joback]
HvapTb      47181.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.04 0.9056 -0.0005966 1.435e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzaldehyde ethylene acetal" "1,3-dioxolane, 2-phenyl-" "2-phenyl-[1,3]dioxolane" );
standardThermochemistry
{
    dHf_298   -196080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     247.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1620.0
}
