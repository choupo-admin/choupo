/*--------------------------------*- Choupo -*-----------------------*\
  Component: tachysterol  (C28H44O, CAS 115-61-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tachysterol;
formula     C28H44O;
CAS         115-61-7;
InChIKey    XQFJZHAVTPYDIQ-LETJEVNCSA-N;
MW          396.659;      // g/mol [origin=calculated method=formula-sum]
Tc          1222.63;      // K   [origin=predictive method=joback]
Pc          10.359;      // bar [origin=predictive method=joback]
omega       0.9475;      // -   [origin=predictive method=lee-kesler]
Tb          994.09;      // K   [origin=predictive method=joback]
HvapTb      95234.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-217.73 3.12562 -0.00233984 7.471e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 7; } { group CH; count 6; } { group C; count 1; } { group CH=CH; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 3; } { group dCH; count 4; } { group CH2_ring; count 7; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s)-3-[(e)-2-[(1r,3ar,7ar)-1-[(e,2r,5r)-5,6-dimethylhept-3-en-2-yl]-7a-methyl-1,2,3,3a,6,7-hexahydroinden-4-yl]ethenyl]-4-methyl-cyclohex-3-en-1-ol" "(3" "a,6e,22e)-9,10-secoergosta-5(10),6,8,22-tetraen-3-ol" "(6e,22e)-(3s)-9,10-seco-5(10),6,8,22-ergostatetraen-3-ol" "(1s)-3-[(1e)-2-[(1r,3ar,7ar)-2,3,3a,6,7,7a-hexahydro-7a-methyl-1-[(1r,2e,4r)-1,4,5-trimethyl-2-hexen-1-yl]-1h-inden-4-yl]ethenyl]-4-methyl-3-cyclohexen-1-ol" );
gibbsFormation
{
    dHf_298   -297390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1038.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=328660.0
    phase     gas;
}
