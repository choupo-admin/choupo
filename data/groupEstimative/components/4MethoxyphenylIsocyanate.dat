/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxyphenyl isocyanate  (C8H7NO2, CAS 5416-93-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethoxyphenylIsocyanate;
formula     C8H7NO2;
CAS         5416-93-3;
InChIKey    FMDGXCSMDZMDHZ-UHFFFAOYSA-N;
MW          149.149;      // g/mol [origin=calculated method=formula-sum]
Tc          723.43;      // K   [origin=predictive method=joback]
Pc          38.435;      // bar [origin=predictive method=joback]
omega       0.5463;      // -   [origin=predictive method=lee-kesler]
Tb          503.39;      // K   [origin=predictive method=joback]
HvapTb      48282.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-4-methoxy-benzene" "1-isocyanato-4-methoxybenzene" "4-methoxyphenylisocyanate" "benzene, 1-isocyanato-4-methoxy-" "p-methoxyphenyl isocyanate" "p-anisyl isocyanate" "isocyanic acid, p-methoxyphenyl ester" "4-methoxybenzenisocyanate" "4-methoxyisocyanatobenzene" "fmdgxcsmdzmdhz-uhfffaoysa-" "benzene,1-isocyanato-4-methoxy-" "isocyanic acid 4-methoxyphenyl ester" );
