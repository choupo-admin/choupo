/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-diethylaminopropylamine  (C7H18N2, CAS 104-78-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Diethylaminopropylamine;
formula     C7H18N2;
CAS         104-78-9;
InChIKey    QOHMWDJIBGVPIF-UHFFFAOYSA-N;
MW          130.235;      // g/mol [origin=calculated method=formula-sum]
Tc          621.74;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.5868;      // -   [origin=predictive method=lee-kesler]
Tb          444.73;      // K   [origin=predictive method=joback]
HvapTb      43860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.675 0.85464 -0.000513 1.205e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH2NH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n',n'-diethylpropane-1,3-diamine" "3-(diethylamino)propylamine" "n,n-diethyl-1,3-diaminopropane" "n,n-diethyl-1,3-propanediamine" "1,3-propanediamine, n,n-diethyl-" "diethylaminotrimethylenamine" "n,n-diethylpropylenediamine" "n-diethyltrimethylenediamine" "(3-aminopropyl)diethylamine" "n,n-diethyltrimethylenediamine" "n-(3-diethylaminopropyl)amine" "1-(diethylamino)propylamine-3" );
gibbsFormation
{
    dHf_298   -86490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185290.0
    phase     gas;
}
