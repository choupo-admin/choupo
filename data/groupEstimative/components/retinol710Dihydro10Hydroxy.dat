/*--------------------------------*- Choupo -*-----------------------*\
  Component: retinol,7,10-dihydro-10-hydroxy-  (C20H32O2, CAS 3230-76-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        retinol710Dihydro10Hydroxy;
formula     C20H32O2;
CAS         3230-76-0;
InChIKey    FRMVBNPEOHCJAG-UHFFFAOYSA-N;
MW          304.474;      // g/mol [origin=calculated method=formula-sum]
Tc          1087.01;      // K   [origin=predictive method=joback]
Pc          15.697;      // bar [origin=predictive method=joback]
omega       1.2925;      // -   [origin=predictive method=lee-kesler]
Tb          882.27;      // K   [origin=predictive method=joback]
HvapTb      94012.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.538 2.2766 -0.001851 6.537e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 2; } { group OH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 4; } { group dC; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyl-9-(2,6,6-trimethylcyclohexen-1-yl)nona-2,4,7-triene-1,6-diol" "agn-pc-00l2sz" "3,7-dimethyl-9-(2,6,6-trimethylcyclohex-1-enyl)nona-2,4,7-triene-1,6-diol" "(2z,4e,7e)-3,7-dimethyl-9-(2,6,6-trimethylcyclohexen-1-yl)nona-2,4,7-triene-1,6-diol" "2,4,7-nonatriene-1,6-diol,3,7-dimethyl-9-(2,6,6-trimethyl-1-cyclohexen-1-yl)- (6ci,7ci,8ci);1,6-dihydroxy-3,7-dimethyl-9-(2,6,6-trimethyl-1-cyclohexen-1-yl)-2,4,7-nonatriene" );
gibbsFormation
{
    dHf_298   -329390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     988.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94660.0
    phase     gas;
}
