/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-ethylphenanthrene  (C16H14, CAS 3674-75-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Ethylphenanthrene;
formula     C16H14;
CAS         3674-75-7;
InChIKey    ZWANHXINCHPSIK-UHFFFAOYSA-N;
MW          206.288;      // g/mol [origin=calculated method=formula-sum]
Tc          884.04;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       0.5967;      // -   [origin=predictive method=lee-kesler]
Tb          640.28;      // K   [origin=predictive method=joback]
HvapTb      58090.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.849 1.31852 -0.00101716 3.171e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 9; } { group AC; count 4; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenanthrene, 9-ethyl-" "phenanthrene, 9-ethyl- (8ci)(9ci)" "phenanthrene, 9-ethyl-;phenanthrene, 9-ethyl- (8ci)(9ci);9-ethyl-phenanthrene;" );
standardThermochemistry
{
    dHf_298   222160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=390290.0
}
