/*--------------------------------*- Choupo -*-----------------------*\
  Component: (17|a)-3-oxoandrost-5-en-17-yl benzoate  (C26H32O3, CAS 581-12-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17A3Oxoandrost5En17YlBenzoate;
formula     C26H32O3;
CAS         581-12-4;
InChIKey    OHAHNLVPTSLFSI-IXKNJLPQSA-N;
MW          392.539;      // g/mol [origin=calculated method=formula-sum]
Tc          1253.68;      // K   [origin=predictive method=joback]
Pc          14.208;      // bar [origin=predictive method=joback]
omega       0.9067;      // -   [origin=predictive method=lee-kesler]
Tb          990.79;      // K   [origin=predictive method=joback]
HvapTb      85946.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-285.41 3.14274 -0.00260664 9.202e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8r,9s,10r,13s,14s,17s)-10,13-dimethyl-3-oxidanylidene-1,2,4,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-17-yl] benzoate" "[(8r,9s,10r,13s,14s,17s)-10,13-dimethyl-3-oxo-1,2,4,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-17-yl] benzoate" );
standardThermochemistry
{
    dHf_298   -501910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     784.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23920.0
}
