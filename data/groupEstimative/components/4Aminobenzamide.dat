/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-aminobenzamide  (C7H8N2O, CAS 2835-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Aminobenzamide;
formula     C7H8N2O;
CAS         2835-68-9;
InChIKey    QIKYZXDTTPVVAC-UHFFFAOYSA-N;
MW          136.154;      // g/mol [origin=calculated method=formula-sum]
Tc          837.48;      // K   [origin=predictive method=joback]
Pc          51.240;      // bar [origin=predictive method=joback]
omega       0.7476;      // -   [origin=predictive method=lee-kesler]
Tb          590.35;      // K   [origin=predictive method=joback]
HvapTb      62142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.74 0.6262 -0.00038926 8.566e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanylbenzamide" "p-aminobenzamide" "benzamide, 4-amino-" "4-amino-benzamide" "benzamide, p-amino-" "p-carbamoylaniline" "p-aminobenzoic acid amide" "benzamide, p-amino- (8ci)" "l629" );
standardThermochemistry
{
    dHf_298   -7750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114820.0
}
