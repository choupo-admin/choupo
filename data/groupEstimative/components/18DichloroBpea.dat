/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-dichloro-bpea  (C30H16Cl2, CAS 51749-83-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18DichloroBpea;
formula     C30H16Cl2;
CAS         51749-83-8;
InChIKey    YONGNHJIWAYNLC-UHFFFAOYSA-N;
MW          447.358;      // g/mol [origin=calculated method=formula-sum]
Tc          1429.62;      // K   [origin=predictive method=joback]
Pc          16.742;      // bar [origin=predictive method=joback]
omega       0.9578;      // -   [origin=predictive method=lee-kesler]
Tb          1121.76;      // K   [origin=predictive method=joback]
HvapTb      108866.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.59 2.0262 -0.00149656 4.3596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 16; } { group AC; count 8; } { group ACCl; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 4; } { group dCH_ring; count 16; } { group dC_ring; count 10; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,8-bis(chloranyl)-9,10-bis(2-phenylethynyl)anthracene" "1,8-dichloro-9,10-bis(phenylethynyl)anthracene" "1,8-dichloro-9,10-bis(phenylethynyl) anthracene" "1,8-dichloro-9,10-bis(2-phenylethynyl)anthracene" "1,8-dichloro-9,10-bis[phenylethenyl]anthracene" "9,10-bis(2-phenylethynyl)-1,8-dichloroanthracene" "1,8-dichloro-9,10-bis-(phenylethynl)anthracene(dbea)" "anthracene,1,8-dichloro-9,10-bis(phenylethynyl)- (9ci);1,8-dichloro-9,10-bis(phenylethynyl)anthracene;9,10-bis(phenylethynl)-1,8-dichloroanthracene;" );
standardThermochemistry
{
    dHf_298   884970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     767.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1085840.0
}
