/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromobenzyl alcohol  (C7H7BrO, CAS 873-75-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BromobenzylAlcohol;
formula     C7H7BrO;
CAS         873-75-6;
InChIKey    VEDDBHYQWFOITD-UHFFFAOYSA-N;
MW          187.036;      // g/mol [origin=calculated method=formula-sum]
Tc          765.99;      // K   [origin=predictive method=joback]
Pc          50.086;      // bar [origin=predictive method=joback]
omega       0.8585;      // -   [origin=predictive method=lee-kesler]
Tb          549.76;      // K   [origin=predictive method=joback]
HvapTb      57228.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.599 0.6026 -0.00042296 1.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-bromophenyl)methanol" "p-bromobenzyl alcohol" "p-bromo-benzyl alcohol" "para-bromobenzyl alcohol" "benzenemethanol, 4-bromo-" "4-bromobenzylalcohol" "benzyl alcohol, p-bromo-" "(4-bromophenyl)methan-1-ol" "brb" "4-bromobenzyl alcohol," "(4-bromophenyl)-methanol" "veddbhyqwfoitd-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -88650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11660.0
}
