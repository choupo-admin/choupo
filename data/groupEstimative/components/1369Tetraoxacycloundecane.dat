/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,6,9-tetraoxacycloundecane  (C7H14O4, CAS 294-59-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1369Tetraoxacycloundecane;
formula     C7H14O4;
CAS         294-59-7;
InChIKey    QCADYFDKCVNNSX-UHFFFAOYSA-N;
MW          162.185;      // g/mol [origin=calculated method=formula-sum]
Tc          757.44;      // K   [origin=predictive method=joback]
Pc          40.934;      // bar [origin=predictive method=joback]
omega       0.4376;      // -   [origin=predictive method=lee-kesler]
Tb          513.13;      // K   [origin=predictive method=joback]
HvapTb      50814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.34 0.7574 -0.0002058 -7.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group FCH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,6,9-tetraoxacycloundecane(7ci,8ci,9ci)" );
gibbsFormation
{
    dHf_298   -671950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-364760.0
    phase     gas;
}
