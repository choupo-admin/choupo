/*--------------------------------*- Choupo -*-----------------------*\
  Component: citral dimethylacetal  (C12H22O2, CAS 7549-37-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        citralDimethylacetal;
formula     C12H22O2;
CAS         7549-37-3;
InChIKey    ZSKAJFSSXURRGL-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          710.54;      // K   [origin=predictive method=joback]
Pc          19.203;      // bar [origin=predictive method=joback]
omega       0.5855;      // -   [origin=predictive method=lee-kesler]
Tb          526.64;      // K   [origin=predictive method=joback]
HvapTb      46814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.552 1.0632 -0.0005824 1.199e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } { group dC; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethoxy-3,7-dimethyl-octa-2,6-diene" "2,6-octadiene, 1,1-dimethoxy-3,7-dimethyl-" "2,6-octadienal,3,7-dimethyl-, dimethyl acetal (7ci,8ci); citral dimethyl acetal (6ci);1,1-dimethoxy-3,7-dimethyl-2,6-octadiene; 3,7-dimethyl-2,6-octadienal dimethylacetal" );
gibbsFormation
{
    dHf_298   -345870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     614.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18940.0
    phase     gas;
}
