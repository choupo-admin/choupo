/*--------------------------------*- Choupo -*-----------------------*\
  Component: prenyl acetate  (C7H12O2, CAS 1191-16-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        prenylAcetate;
formula     C7H12O2;
CAS         1191-16-8;
InChIKey    XXIKYCPRDXIMQM-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          606.97;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.4362;      // -   [origin=predictive method=lee-kesler]
Tb          422.02;      // K   [origin=predictive method=joback]
HvapTb      38621.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.061 0.63396 -0.0003485 6.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbut-2-enyl ethanoate" "3-methyl-2-butenyl acetate" "isopent-2-enyl acetate" "3,3-dimethylallyl acetate" "2-buten-1-ol, 3-methyl-, acetate" "dimethylallyl acetate" "3-methyl-2-buten-1-yl acetate" "3,3-dimethyl allyl acetate" "3-methylbut-2-enyl acetate" "3-methyl-2-buten-1-ol acetate" "3-methylbut-2-en-1-yl acetate" "3-methyl-2-buten-1-ol, acetate" );
standardThermochemistry
{
    dHf_298   -397660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230640.0
}
