/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-octadiene, 1-methoxy-3,7-dimethyl-, (2e)-  (C11H20O, CAS 2565-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Octadiene1Methoxy37Dimethyl2e;
formula     C11H20O;
CAS         2565-83-5;
InChIKey    AVJMJMPVWWWELJ-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          664.75;      // K   [origin=predictive method=joback]
Pc          21.100;      // bar [origin=predictive method=joback]
omega       0.4971;      // -   [origin=predictive method=lee-kesler]
Tb          481.78;      // K   [origin=predictive method=joback]
HvapTb      42566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.357 1.02548 -0.0006358 1.633e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH=C; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group dCH; count 2; } { group dC; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-3,7-dimethyl-octa-2,6-diene" "2,6-octadiene, 1-methoxy-3,7-dimethyl-, (2z)-" );
gibbsFormation
{
    dHf_298   -187730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80080.0
    phase     gas;
}
