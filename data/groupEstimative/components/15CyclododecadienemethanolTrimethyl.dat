/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-cyclododecadienemethanol, trimethyl-  (C16H26O, CAS 71735-83-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15CyclododecadienemethanolTrimethyl;
formula     C16H26O;
CAS         71735-83-6;
InChIKey    PUXPCEIAIWOVKB-FBYPFSEASA-N;
MW          234.383;      // g/mol [origin=calculated method=formula-sum]
Tc          940.25;      // K   [origin=predictive method=joback]
Pc          20.181;      // bar [origin=predictive method=joback]
omega       0.9236;      // -   [origin=predictive method=lee-kesler]
Tb          725.10;      // K   [origin=predictive method=joback]
HvapTb      73183.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.099 1.24286 -0.00042868 -3.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH=C; count 2; } { group OH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 6; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1z,5e,9e)-6,9,10-trimethylcyclododeca-1,5,9-trien-1-yl]methanol" "trimethylcyclododeca-1,5-dienemethanol" );
gibbsFormation
{
    dHf_298   -360640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     824.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42060.0
    phase     gas;
}
