/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-cresol, 4-methylthio-  (C8H10OS, CAS 3795-76-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oCresol4Methylthio;
formula     C8H10OS;
CAS         3795-76-4;
InChIKey    DXLSPFDSUIZAON-UHFFFAOYSA-N;
MW          154.227;      // g/mol [origin=calculated method=formula-sum]
Tc          812.63;      // K   [origin=predictive method=joback]
Pc          44.208;      // bar [origin=predictive method=joback]
omega       0.5883;      // -   [origin=predictive method=lee-kesler]
Tb          563.70;      // K   [origin=predictive method=joback]
HvapTb      56171.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.31 0.77443 -0.00059172 1.901e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-4-methylsulfanyl-phenol" "o-cresol, 4-methylthio-," "2-methyl-4-methylsulfanylphenol" "2-methyl-4-(methylsulfanyl)phenol" );
standardThermochemistry
{
    dHf_298   -118830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2240.0
}
