/*--------------------------------*- Choupo -*-----------------------*\
  Component: amixetrine  (C17H27NO, CAS 24622-72-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amixetrine;
formula     C17H27NO;
CAS         24622-72-8;
InChIKey    ISRODTBNJUAWEJ-UHFFFAOYSA-N;
MW          261.409;      // g/mol [origin=calculated method=formula-sum]
Tc          873.48;      // K   [origin=predictive method=joback]
Pc          18.357;      // bar [origin=predictive method=joback]
omega       0.7514;      // -   [origin=predictive method=lee-kesler]
Tb          664.90;      // K   [origin=predictive method=joback]
HvapTb      59783.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.327 1.78024 -0.0011694 2.958e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-(3-methylbutoxy)-2-phenyl-ethyl]pyrrolidine" "somagest" "amixetrina" "amixetrinum" "amixetrine [inn:dcf]" "amixetrinum [inn-latin]" "24622-52-4 (hydrochloride)" "n-(2-phenyl-2-isoamyloxy)ethylpyrrolidine" "1-(beta-(isopentyloxy)phenethyl)pyrrolidine" "pyrrolidine, n-(2-phenyl-2-isoamyloxy)ethyl-" "1-[2-(3-methylbutoxy)-2-phenylethyl]pyrrolidine" );
standardThermochemistry
{
    dHf_298   -145950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     692.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=261930.0
}
