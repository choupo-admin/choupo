/*--------------------------------*- Choupo -*-----------------------*\
  Component: triphenylethylene  (C20H16, CAS 58-72-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triphenylethylene;
formula     C20H16;
CAS         58-72-0;
InChIKey    MKYQPGPNVYRMHI-UHFFFAOYSA-N;
MW          256.348;      // g/mol [origin=calculated method=formula-sum]
Tc          1013.31;      // K   [origin=predictive method=joback]
Pc          22.937;      // bar [origin=predictive method=joback]
omega       0.5964;      // -   [origin=predictive method=lee-kesler]
Tb          741.28;      // K   [origin=predictive method=joback]
HvapTb      66980.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-130.88 1.687 -0.0012439 3.525e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 15; } { group AC; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-diphenylethenylbenzene" "triphenylethene" "ethylene, triphenyl-" "benzilidenediphenylmethane" "(1,2-diphenylvinyl)benzene" "benzene, 1,1',1''-(1-ethenyl-2-ylidene)tris-" "1,1,2-triphenylethylene" "1,2,2-triphenylethylene" "1,1',1''-ethen-1,1,2-triyltribenzol" "ethene-1,1,2-triyltribenzene" "triphenylethyl ene" "1,2-triphenylethylene" );
gibbsFormation
{
    dHf_298   360890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=526420.0
    phase     gas;
}
