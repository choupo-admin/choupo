/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4',4''-methylidynetris(n,n-dipropylaniline)  (C37H55N3, CAS 60813-12-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        444MethylidynetrisNNDipropylaniline;
formula     C37H55N3;
CAS         60813-12-9;
InChIKey    UXBWXMXAXJKBSA-UHFFFAOYSA-N;
MW          541.868;      // g/mol [origin=calculated method=formula-sum]
Tc          1453.67;      // K   [origin=predictive method=joback]
Pc          6.853;      // bar [origin=predictive method=joback]
omega       0.5515;      // -   [origin=predictive method=lee-kesler]
Tb          1178.02;      // K   [origin=predictive method=joback]
HvapTb      112511.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.318 3.48132 -0.00222248 5.426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 9; } { group ACH; count 12; } { group AC; count 5; } { group ACCH; count 1; } { group CH2N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 12; } { group CH; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[bis[4-(dipropylamino)phenyl]methyl]-n,n-dipropyl-aniline" "benzenamine, 4,4',4''-methylidynetris(n,n-dipropyl-" "benzenamine, 4,4',4''-methylidynetris[n,n-dipropyl-" "4,4',4''-methanetriyltris(n,n-dipropylaniline)" "4-[bis[4-(dipropylamino)phenyl]methyl]-n,n-dipropylaniline" );
gibbsFormation
{
    dHf_298   65480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1298.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=898900.0
    phase     gas;
}
