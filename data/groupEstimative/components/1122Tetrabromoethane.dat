/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2,2-tetrabromoethane  (C2H2Br4, CAS 79-27-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1122Tetrabromoethane;
formula     C2H2Br4;
CAS         79-27-6;
InChIKey    QXSZNDIIPUOQMB-UHFFFAOYSA-N;
MW          345.654;      // g/mol [origin=calculated method=formula-sum]
Tc          771.87;      // K   [origin=predictive method=joback]
Pc          80.005;      // bar [origin=predictive method=joback]
omega       0.5549;      // -   [origin=predictive method=lee-kesler]
Tb          509.12;      // K   [origin=predictive method=joback]
HvapTb      45010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.47 0.3584 -0.000377 1.48e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group Br; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group Br; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetrakis(bromanyl)ethane" "acetylene tetrabromide" "muthmann's liquid" "ethane, 1,1,2,2-tetrabromo-" "tetrabromoacetylene" "sym-tetrabromoethane" "s-tetrabromoethane" "muthmanns liquid" "tbe" "1,1,2,2-tetrabromaethan [german]" "1,1,2,2-tetrabroomethaan [dutch]" "acetylene tetrabomide" );
gibbsFormation
{
    dHf_298   10150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18360.0
    phase     gas;
}
