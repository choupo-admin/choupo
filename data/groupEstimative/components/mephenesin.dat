/*--------------------------------*- Choupo -*-----------------------*\
  Component: mephenesin  (C10H14O3, CAS 59-47-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mephenesin;
formula     C10H14O3;
CAS         59-47-2;
InChIKey    JWDYCNIAQWPBHD-UHFFFAOYSA-N;
MW          182.219;      // g/mol [origin=calculated method=formula-sum]
Tc          852.68;      // K   [origin=predictive method=joback]
Pc          35.137;      // bar [origin=predictive method=joback]
omega       1.4484;      // -   [origin=predictive method=lee-kesler]
Tb          666.40;      // K   [origin=predictive method=joback]
HvapTb      76172.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.592 0.82612 -0.00043736 7.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group OH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-methylphenoxy)propane-1,2-diol" "decontractyl" "decontractil" "myodetensine" "anatensin" "cresodiol" "cresoxydiol" "lissenphan" "lissephen" "mefenesina" "memphenesin" "mephedan" );
standardThermochemistry
{
    dHf_298   -466630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-244980.0
}
