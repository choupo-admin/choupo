/*--------------------------------*- Choupo -*-----------------------*\
  Component: propylene sulfide  (C3H6S, CAS 1072-43-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propyleneSulfide;
formula     C3H6S;
CAS         1072-43-1;
InChIKey    MBNVSWHUJDDZRH-UHFFFAOYSA-N;
MW          74.141;      // g/mol [origin=calculated method=formula-sum]
Tc          521.16;      // K   [origin=predictive method=joback]
Pc          52.358;      // bar [origin=predictive method=joback]
omega       0.1825;      // -   [origin=predictive method=lee-kesler]
Tb          322.81;      // K   [origin=predictive method=joback]
HvapTb      27997.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.26 0.45413 -0.0003783 1.326e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylthiirane" "thiirane, methyl-" "thiirane, 2-methyl-" "propene sulfide" "propylene episulfide" "1,2-epithiopropane" "methylthiirane" "2-methylthiacyclopropane" "propylene sulphide" "propane,2-epithio-" "methylethylene sulfide" "agn-pc-03fb5p" );
standardThermochemistry
{
    dHf_298   12810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     232.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74990.0
}
