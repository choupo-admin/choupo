/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-thiopyran,3,4-dihydro-4,4-dimethyl-  (C7H12S, CAS 53520-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hThiopyran34Dihydro44Dimethyl;
formula     C7H12S;
CAS         53520-28-8;
InChIKey    NWXHIGBIQIBWGJ-UHFFFAOYSA-N;
MW          128.233;      // g/mol [origin=calculated method=formula-sum]
Tc          659.03;      // K   [origin=predictive method=joback]
Pc          38.579;      // bar [origin=predictive method=joback]
omega       0.2329;      // -   [origin=predictive method=lee-kesler]
Tb          426.54;      // K   [origin=predictive method=joback]
HvapTb      36558.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.47 1.04125 -0.00097658 3.927e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4-dimethyl-2,3-dihydrothiopyran" "4,4-dimethyl-3,4-dihydro-2h-thiopyran" );
gibbsFormation
{
    dHf_298   -15210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=96840.0
    phase     gas;
}
