/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-1-butenyl ethyl ether  (C6H12O, CAS 4884-01-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis1ButenylEthylEther;
formula     C6H12O;
CAS         4884-01-9;
InChIKey    AQTYNINXYJFSHD-AATRIKPKSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          536.86;      // K   [origin=predictive method=joback]
Pc          32.320;      // bar [origin=predictive method=joback]
omega       0.3445;      // -   [origin=predictive method=lee-kesler]
Tb          363.46;      // K   [origin=predictive method=joback]
HvapTb      31318.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.752 0.53064 -0.0002754 5.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-ethoxybut-1-ene" "trans-1-butenyl ethyl ether" "1-butene, 1-ethoxy-, (e)-" "trans-1-ethoxy-1-butene" );
gibbsFormation
{
    dHf_298   -182170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-25140.0
    phase     gas;
}
