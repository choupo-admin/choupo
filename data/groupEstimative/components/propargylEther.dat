/*--------------------------------*- Choupo -*-----------------------*\
  Component: propargyl ether  (C6H6O, CAS 6921-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propargylEther;
formula     C6H6O;
CAS         6921-27-3;
InChIKey    HRDCVMSNCBAMAM-UHFFFAOYSA-N;
MW          94.113;      // g/mol [origin=calculated method=formula-sum]
Tc          529.16;      // K   [origin=predictive method=joback]
Pc          43.569;      // bar [origin=predictive method=joback]
omega       0.2418;      // -   [origin=predictive method=lee-kesler]
Tb          339.54;      // K   [origin=predictive method=joback]
HvapTb      31076.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.492 0.3228 -0.00018346 4.218e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2O; count 1; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group tCH; count 2; } { group tC; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-prop-2-ynoxyprop-1-yne" "dipropargyl ether" "2-propynyl ether" "1-propyne, 3,3'-oxybis-" "dipropynyl ether" "1-prop-2-ynyloxyprop-2-yne" );
standardThermochemistry
{
    dHf_298   284410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     339.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=340780.0
}
