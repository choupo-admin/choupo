/*--------------------------------*- Choupo -*-----------------------*\
  Component: novocebrin  (C20H21NOS2, CAS 66788-41-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        novocebrin;
formula     C20H21NOS2;
CAS         66788-41-8;
InChIKey    JQSHEDRVRBSFCZ-YWZLYKJASA-N;
MW          355.514;      // g/mol [origin=calculated method=formula-sum]
Tc          1223.89;      // K   [origin=predictive method=joback]
Pc          22.654;      // bar [origin=predictive method=joback]
omega       1.3130;      // -   [origin=predictive method=lee-kesler]
Tb          971.55;      // K   [origin=predictive method=joback]
HvapTb      100015.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.839 1.96904 -0.00148494 4.408e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CH2NH; count 1; } { group C4H3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 3; } { group OH; count 1; } { group NH; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2s)-2-[3,3-di(thiophen-3-yl)prop-2-enylamino]-1-phenyl-propan-1-ol" "tinofedrine" "tinofedrina" "tinofedrinum" "tinofedrinum [inn-latin]" "(+)-(r)-alpha-((s)-1-((3,3-di-3-thienylallyl)amino)ethyl)benzyl alcohol" "(1r,2s)-2-[3,3-di(thiophen-3-yl)prop-2-enylamino]-1-phenylpropan-1-ol" );
gibbsFormation
{
    dHf_298   238850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     812.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=518110.0
    phase     gas;
}
