/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-di-tert-butyl-2,6-toluenediamine  (C15H26N2, CAS 103596-73-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35DiTertButyl26Toluenediamine;
formula     C15H26N2;
CAS         103596-73-2;
InChIKey    IUWZLTGXALKGRP-UHFFFAOYSA-N;
MW          234.387;      // g/mol [origin=calculated method=formula-sum]
Tc          960.18;      // K   [origin=predictive method=joback]
Pc          20.019;      // bar [origin=predictive method=joback]
omega       0.7738;      // -   [origin=predictive method=lee-kesler]
Tb          728.00;      // K   [origin=predictive method=joback]
HvapTb      72598.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.42 1.48744 -0.00098564 2.59e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 1; } { group AC; count 2; } { group ACCH3; count 1; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group C; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,6-ditert-butyl-2-methyl-benzene-1,3-diamine" "1,3-benzenediamine, 4,6-bis(1,1-dimethylethyl)-2-methyl-" "4,6-ditert-butyl-2-methylbenzene-1,3-diamine" "4,6-di-tert-butyl-2-methylbenzene-1,3-diamine" );
standardThermochemistry
{
    dHf_298   -112200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     634.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=287890.0
}
