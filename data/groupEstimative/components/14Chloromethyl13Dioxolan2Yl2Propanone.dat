/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-chloromethyl-1,3-dioxolan-2-yl)-2-propanone  (C7H11ClO3, CAS 53460-80-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Chloromethyl13Dioxolan2Yl2Propanone;
formula     C7H11ClO3;
CAS         53460-80-3;
InChIKey    UTSVYFOQXVPABD-UHFFFAOYSA-N;
MW          178.612;      // g/mol [origin=calculated method=formula-sum]
Tc          727.02;      // K   [origin=predictive method=joback]
Pc          33.220;      // bar [origin=predictive method=joback]
omega       0.5882;      // -   [origin=predictive method=lee-kesler]
Tb          515.57;      // K   [origin=predictive method=joback]
HvapTb      51275.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.128 0.74682 -0.0004029 6.596e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH3CO; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group Cl; count 1; } { group O_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-(chloromethyl)-1,3-dioxolan-2-yl]propan-2-one" "2-propanone, 1-(4-(chloromethyl)-1,3-dioxolan-2-yl)-" "1-(4-(chloromethyl)-1,3-dioxolan-2-yl)-2-propanone" );
gibbsFormation
{
    dHf_298   -539990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     293.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-276190.0
    phase     gas;
}
