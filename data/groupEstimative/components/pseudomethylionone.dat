/*--------------------------------*- Choupo -*-----------------------*\
  Component: pseudomethylionone  (C14H22O, CAS 26651-96-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pseudomethylionone;
formula     C14H22O;
CAS         26651-96-7;
InChIKey    SPHLZZZXIWUZNM-UHFFFAOYSA-N;
MW          206.329;      // g/mol [origin=calculated method=formula-sum]
Tc          780.27;      // K   [origin=predictive method=joback]
Pc          18.373;      // bar [origin=predictive method=joback]
omega       0.6510;      // -   [origin=predictive method=lee-kesler]
Tb          586.03;      // K   [origin=predictive method=joback]
HvapTb      53538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.407 1.36568 -0.0009751 2.9216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH=CH; count 1; } { group CH=C; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group dCH; count 4; } { group dC; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,11-dimethyldodeca-4,6,10-trien-3-one" "pseudo methyl ionones" "4,6,10-dodecatrien-3-one, 7,11-dimethyl-" "2,6-dimethyldodeca-2,6,8-trien-10-one" "7,11-dimethyl-4,6,10-dodecatrien-3-one" "4,6,10-dodecatrien-3-one,7,11-dimethyl-" "7,11-dimethyl-4,6,10-dodecatrien-3-one;methylpseudoionone; pseudoionone, n-methyl-; pseudomethylionone" );
gibbsFormation
{
    dHf_298   -112790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     699.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161640.0
    phase     gas;
}
