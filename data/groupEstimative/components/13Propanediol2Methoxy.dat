/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-propanediol, 2-methoxy-  (C4H10O3, CAS 761-06-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Propanediol2Methoxy;
formula     C4H10O3;
CAS         761-06-8;
InChIKey    RKOGJKGQMPZCGG-UHFFFAOYSA-N;
MW          106.121;      // g/mol [origin=calculated method=formula-sum]
Tc          659.14;      // K   [origin=predictive method=joback]
Pc          49.108;      // bar [origin=predictive method=joback]
omega       1.2776;      // -   [origin=predictive method=lee-kesler]
Tb          497.46;      // K   [origin=predictive method=joback]
HvapTb      59878.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.652 0.39452 -0.0001468 7e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group OH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxypropane-1,3-diol" );
standardThermochemistry
{
    dHf_298   -567850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-398280.0
}
