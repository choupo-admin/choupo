/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-2-octyn-4-ol  (C9H16O, CAS 74514-59-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl2Octyn4Ol;
formula     C9H16O;
CAS         74514-59-3;
InChIKey    HWVNLGPDLREHJB-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          691.97;      // K   [origin=predictive method=joback]
Pc          30.490;      // bar [origin=predictive method=joback]
omega       0.7077;      // -   [origin=predictive method=lee-kesler]
Tb          503.47;      // K   [origin=predictive method=joback]
HvapTb      53163.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.917 0.86886 -0.00057586 1.5658e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyloct-2-yn-4-ol" "2-octyn-4-ol, 4-methyl-" "4-methyl-2-octyn-4-ol;4-methyloct-2-yn-4-ol;" );
gibbsFormation
{
    dHf_298   -117770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93720.0
    phase     gas;
}
