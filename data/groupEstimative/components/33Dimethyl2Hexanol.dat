/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyl-2-hexanol  (C8H18O, CAS 22025-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyl2Hexanol;
formula     C8H18O;
CAS         22025-20-3;
InChIKey    LTTHCWFPLXSQOD-UHFFFAOYSA-N;
MW          130.231;      // g/mol [origin=calculated method=formula-sum]
Tc          643.59;      // K   [origin=predictive method=joback]
Pc          28.689;      // bar [origin=predictive method=joback]
omega       0.7182;      // -   [origin=predictive method=lee-kesler]
Tb          471.15;      // K   [origin=predictive method=joback]
HvapTb      48397.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.248 0.92958 -0.0006168 1.652e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylhexan-2-ol" "2-hexanol,3,3-dimethyl-" );
standardThermochemistry
{
    dHf_298   -374710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-119940.0
}
