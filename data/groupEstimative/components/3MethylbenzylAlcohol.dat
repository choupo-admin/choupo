/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-Methylbenzyl alcohol  (C8H10O, CAS 587-03-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethylbenzylAlcohol;
formula     C8H10O;
CAS         587-03-1;
InChIKey    JJCKHVUTVOPLBV-UHFFFAOYSA-N;
MW          122.167;      // g/mol [origin=calculated method=formula-sum]
Tc          705.20;      // K   [origin=predictive method=joback]
Pc          40.159;      // bar [origin=predictive method=joback]
omega       0.7569;      // -   [origin=predictive method=lee-kesler]
Tb          506.48;      // K   [origin=predictive method=joback]
HvapTb      53019.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.699 0.65942 -0.00040596 9.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-methylphenyl)methanol" "3-methylbenzenemethanol" "benzenemethanol, 3-methyl-" "benzyl alcohol, m-methyl-" "m-methylbenzyl alcohol" "m-tolualcohol" "m-tolylmethanol" "m-tolyl carbinol" "3-methylbenzylalcohol" "m-methyl benzyl alcohol" "3-methyl-benzenemethanol" "ai3-21575" );
gibbsFormation
{
    dHf_298   -135620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17560.0
    phase     gas;
}
