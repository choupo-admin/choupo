/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-butanediamine  (C4H12N2, CAS 590-88-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Butanediamine;
formula     C4H12N2;
CAS         590-88-5;
InChIKey    RGTXVXDNHPWPHH-UHFFFAOYSA-N;
MW          88.154;      // g/mol [origin=calculated method=formula-sum]
Tc          637.85;      // K   [origin=predictive method=joback]
Pc          45.654;      // bar [origin=predictive method=joback]
omega       0.5206;      // -   [origin=predictive method=lee-kesler]
Tb          435.74;      // K   [origin=predictive method=joback]
HvapTb      45392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.552 0.51352 -0.0002838 5.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2NH2; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,3-diamine" "1,3-diaminobutane" "1-methyltrimethylenediamine" );
gibbsFormation
{
    dHf_298   -63590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113260.0
    phase     gas;
}
