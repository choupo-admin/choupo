/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzal glyceryl acetal  (C10H12O3, CAS 1708-39-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzalGlycerylAcetal;
formula     C10H12O3;
CAS         1708-39-0;
InChIKey    AUDDNHGBAJNKEH-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          828.63;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.9290;      // -   [origin=predictive method=lee-kesler]
Tb          611.77;      // K   [origin=predictive method=joback]
HvapTb      65777.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.719 1.0081 -0.000626 1.37e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-phenyl-1,3-dioxolan-4-yl)methanol" "1,2-benzylideneglycerol" "benzylidene glycerol" "4-(hydroxymethyl)-2-phenyldioxolane" "2-phenyl-m-dioxan-5-ol" "glycerol, 1,2-o-benzylidene-" "benzaldehyde, cyclic (hydroxymethyl)ethylene acetal" "2-phenyl-1,3-dioxolane-4-methanol" "1,3-dioxolane-4-methanol, 2-phenyl-" "glycerol,2-o-benzylidene-" );
gibbsFormation
{
    dHf_298   -389290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     294.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-134490.0
    phase     gas;
}
