/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-octenoic acid,3-oxo-, methyl ester  (C9H14O3, CAS 110874-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6OctenoicAcid3OxoMethylEster;
formula     C9H14O3;
CAS         110874-83-4;
InChIKey    KEFBZRDCTCSBIN-UHFFFAOYSA-N;
MW          170.208;      // g/mol [origin=calculated method=formula-sum]
Tc          709.72;      // K   [origin=predictive method=joback]
Pc          25.978;      // bar [origin=predictive method=joback]
omega       0.6950;      // -   [origin=predictive method=lee-kesler]
Tb          521.77;      // K   [origin=predictive method=joback]
HvapTb      49739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.293 0.79604 -0.0004363 7.716e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH; count 2; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-oxidanylideneoct-6-enoate" "methyl 3-oxooct-6-enoate" "methyl3-oxo-6-octenoate" "agn-pc-00maxa" "methyl 3-oxo-6-octenoate" "6-octenoic acid, 3-oxo-, methyl ester" "6-octenoic acid, 3-oxo-, methyl ester, (z)-" "6-octenoic acid, 3-oxo-, methyl ester, (6e)-" );
standardThermochemistry
{
    dHf_298   -541730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-334170.0
}
