/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7-dithiaoctane  (C6H14S2, CAS 15394-33-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        27Dithiaoctane;
formula     C6H14S2;
CAS         15394-33-9;
InChIKey    JTFIKVWEZAEFMN-UHFFFAOYSA-N;
MW          150.298;      // g/mol [origin=calculated method=formula-sum]
Tc          686.75;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       0.4365;      // -   [origin=predictive method=lee-kesler]
Tb          474.44;      // K   [origin=predictive method=joback]
HvapTb      42584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.634 0.56262 -0.0002222 5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(methylsulfanyl)butane" "butane, 1,4-bis(methylthio)-" "butane,4-bis(methylthio)-" "butane,1,4-bis(methylthio)-" );
gibbsFormation
{
    dHf_298   -83430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65880.0
    phase     gas;
}
