/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-hydroxyhexanoate  (C8H16O3, CAS 2305-25-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Hydroxyhexanoate;
formula     C8H16O3;
CAS         2305-25-1;
InChIKey    LYRIITRHDCNUHV-UHFFFAOYSA-N;
MW          160.213;      // g/mol [origin=calculated method=formula-sum]
Tc          701.57;      // K   [origin=predictive method=joback]
Pc          28.263;      // bar [origin=predictive method=joback]
omega       0.9972;      // -   [origin=predictive method=lee-kesler]
Tb          532.60;      // K   [origin=predictive method=joback]
HvapTb      57100.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.634 0.74894 -0.0003504 3.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-oxidanylhexanoate" "hexanoic acid, 3-hydroxy-, ethyl ester" "3-hydroxyhexanoic acid ethyl ester" "hexanoic acid,3-hydroxy-, ethyl ester, (3s)-" "ethyl 3-hydroxy-hexanoate" "ethyl beta-hydroxycaproate" "3-hydroxy-hexanoic acid ethyl ester" "s581" "we(2:0/6:0(3oh))" );
standardThermochemistry
{
    dHf_298   -683240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-433150.0
}
