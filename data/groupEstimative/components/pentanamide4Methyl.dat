/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentanamide, 4-methyl-  (C6H13NO, CAS 1119-29-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentanamide4Methyl;
formula     C6H13NO;
CAS         1119-29-5;
InChIKey    ACMPWZQOUILVFB-UHFFFAOYSA-N;
MW          115.176;      // g/mol [origin=calculated method=formula-sum]
Tc          658.66;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       0.5723;      // -   [origin=predictive method=lee-kesler]
Tb          462.84;      // K   [origin=predictive method=joback]
HvapTb      45949.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.602 0.61364 -0.0003305 6.166e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylpentanamide" "valeramide, 4-methyl-" "isohexanamide" "4-methylvaleramide" ".gamma.-methylvaleramide" "agn-pc-0d8b4m" );
standardThermochemistry
{
    dHf_298   -251240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-65270.0
}
