/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-(+)-5-oxotetrahydrofuran-2-carboxylic acid  (C5H6O4, CAS 21461-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s5Oxotetrahydrofuran2CarboxylicAcid;
formula     C5H6O4;
CAS         21461-84-7;
InChIKey    QVADRSWDTZDDGR-VKHMYHEASA-N;
MW          130.099;      // g/mol [origin=calculated method=formula-sum]
Tc          736.19;      // K   [origin=predictive method=joback]
Pc          46.026;      // bar [origin=predictive method=joback]
omega       0.7675;      // -   [origin=predictive method=lee-kesler]
Tb          524.47;      // K   [origin=predictive method=joback]
HvapTb      51208.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.89 0.6257 -0.0004464 1.185e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH2COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-5-oxidanylideneoxolane-2-carboxylic acid" "(s)-5-oxotetrahydrofuran-2-carboxylic acid" "(2s)-5-oxooxolane-2-carboxylic acid" "(s)-gamma-carboxy-gamma-butyrolactone" "(s)-5-oxo-tetrahydrofuran-2-carboxylic acid" "(s)-(+)-5-oxotetrahydrofuran-2-carboxylicacid" "(s)-(+)-5-oxo-2-tetrahydrofuroic acid" "5-oxo-tetrahydro-furan-2-carboxylic acid" "2-furancarboxylic acid, tetrahydro-5-oxo-" "(2s)-(+)-2-carboxy-5-oxotetrahydrofuran" "(s)-(+)-gamma-carboxy-gamma-butyrolactone" "(s)-5-oxotetrahydro-2-furancarboxylic acid" );
gibbsFormation
{
    dHf_298   -741280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-602310.0
    phase     gas;
}
