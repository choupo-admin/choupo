/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2,4,6-trimethylphenyl-carbamoyl-methyl)-imino-diacetic acid  (C15H20N2O5, CAS 65717-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n246TrimethylphenylCarbamoylMethylIminoDiaceticAcid;
formula     C15H20N2O5;
CAS         65717-98-8;
InChIKey    FXVKXNAXJZIDLF-UHFFFAOYSA-N;
MW          308.334;      // g/mol [origin=calculated method=formula-sum]
Tc          1249.83;      // K   [origin=predictive method=joback]
Pc          23.383;      // bar [origin=predictive method=joback]
omega       1.6333;      // -   [origin=predictive method=lee-kesler]
Tb          1013.84;      // K   [origin=predictive method=joback]
HvapTb      106616.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.922 1.43676 -0.00090798 2.1296e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 2; } { group ACCH3; count 3; } { group ACCH; count 1; } { group CH2N; count 1; } { group COOH; count 2; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group CdO; count 1; } { group COOH; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[2-azanyl-2-oxidanylidene-1-(2,4,6-trimethylphenyl)ethyl]-(2-hydroxy-2-oxoethyl)amino]ethanoic acid" "agn-pc-02n3hg" "2-[[2-amino-2-oxo-1-(2,4,6-trimethylphenyl)ethyl]-(carboxymethyl)amino]acetic acid" );
standardThermochemistry
{
    dHf_298   -867890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     806.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-483010.0
}
