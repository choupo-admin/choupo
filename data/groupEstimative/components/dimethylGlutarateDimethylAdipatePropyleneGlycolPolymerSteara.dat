/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl glutarate, dimethyl adipate, propylene glycol polymer, stearate  (C36H68O11, CAS 70892-19-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylGlutarateDimethylAdipatePropyleneGlycolPolymerSteara;
formula     C36H68O11;
CAS         70892-19-2;
InChIKey    VWWMFUPWXMEDQT-UHFFFAOYSA-N;
MW          676.929;      // g/mol [origin=calculated method=formula-sum]
Tc          2111.47;      // K   [origin=predictive method=joback]
Pc          4.479;      // bar [origin=predictive method=joback]
omega       -0.4285;      // -   [origin=predictive method=lee-kesler]
Tb          1408.92;      // K   [origin=predictive method=joback]
HvapTb      149644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (182.454 2.77742 -0.0006656 -2.934e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 19; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 24; } { group CH; count 1; } { group OH; count 1; } { group COO; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl hexanedioate;dimethyl pentanedioate;2-oxidanylpropyl octadecanoate" "hexanedioic acid, 1,6-dimethyl ester, polymer with 1,5-dimethyl pentanedioate and 1,2-propanediol, octadecanoate" "hexanedioic acid, dimethyl ester, polymer with dimethyl pentanedioate and 1,2-propanediol, octadecanoate" );
standardThermochemistry
{
    dHf_298   -2753520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     2071.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1648390.0
}
