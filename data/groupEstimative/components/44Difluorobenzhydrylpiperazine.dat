/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-difluorobenzhydrylpiperazine  (C17H18F2N2, CAS 27469-60-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Difluorobenzhydrylpiperazine;
formula     C17H18F2N2;
CAS         27469-60-9;
InChIKey    TTXIFFYPVGWLSE-UHFFFAOYSA-N;
MW          288.341;      // g/mol [origin=calculated method=formula-sum]
Tc          969.77;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.8229;      // -   [origin=predictive method=lee-kesler]
Tb          730.92;      // K   [origin=predictive method=joback]
HvapTb      66657.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.47 1.6402 -0.00110012 2.752e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 2; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[bis(4-fluorophenyl)methyl]piperazine" "1-(4,4'-difluorobenzhydryl)piperazine" "1-(bis(4-fluorophenyl)methyl)piperazine" "1-bis(4-fluorophenyl)methyl piperazine" "1 [bis(4-fluorophenyl)methyl]-piperazine" "[bis(4-fluorophenyl)methyl]piperazine" "1-bis(4-fluorophenyl)methylpiperazine" "1-[bis(4-fluorophenyl)methylpiperazine" "n-(bis(4-fluorophenyl)methyl)piperazine" "1-[bis(4-fluorophenzyl)methyl]piperazine" "1-[bis-(4-fluorophenyl)methyl]piperazine" "o224" );
standardThermochemistry
{
    dHf_298   -155430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=148510.0
}
