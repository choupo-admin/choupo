/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-(ethylthio)-3-methyl-  (C9H12S, CAS 34786-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1Ethylthio3Methyl;
formula     C9H12S;
CAS         34786-24-8;
InChIKey    HYWRFKLTGRADFO-UHFFFAOYSA-N;
MW          152.255;      // g/mol [origin=calculated method=formula-sum]
Tc          737.88;      // K   [origin=predictive method=joback]
Pc          32.690;      // bar [origin=predictive method=joback]
omega       0.4059;      // -   [origin=predictive method=lee-kesler]
Tb          505.96;      // K   [origin=predictive method=joback]
HvapTb      45383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.299 0.71483 -0.00038976 6.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethylsulfanyl-3-methyl-benzene" "ethyl m-tolyl sulfide" "1-ethylsulfanyl-3-methylbenzene" "1-(ethylsulfanyl)-3-methylbenzene" );
gibbsFormation
{
    dHf_298   37840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160800.0
    phase     gas;
}
