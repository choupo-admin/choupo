/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethylocta-2,6-dienyl 2-ethylbutyrate  (C16H28O2, CAS 85136-39-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethylocta26Dienyl2Ethylbutyrate;
formula     C16H28O2;
CAS         85136-39-6;
InChIKey    PFVYLGTZGQUUOT-UHFFFAOYSA-N;
MW          252.398;      // g/mol [origin=calculated method=formula-sum]
Tc          814.60;      // K   [origin=predictive method=joback]
Pc          14.490;      // bar [origin=predictive method=joback]
omega       0.7460;      // -   [origin=predictive method=lee-kesler]
Tb          631.54;      // K   [origin=predictive method=joback]
HvapTb      58305.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.675 1.5148 -0.0009274 2.2e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 1; } { group CH=C; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 1; } { group dCH; count 2; } { group dC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethylocta-2,6-dienyl 2-ethylbutanoate" "(e)-3,7-dimethylocta-2,6-dienyl 2-ethylbutyrate" );
standardThermochemistry
{
    dHf_298   -481270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     799.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85630.0
}
