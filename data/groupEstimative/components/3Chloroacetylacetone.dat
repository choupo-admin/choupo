/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloroacetylacetone  (C5H7ClO2, CAS 1694-29-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloroacetylacetone;
formula     C5H7ClO2;
CAS         1694-29-7;
InChIKey    VLRGXXKFHVJQOL-UHFFFAOYSA-N;
MW          134.559;      // g/mol [origin=calculated method=formula-sum]
Tc          661.64;      // K   [origin=predictive method=joback]
Pc          39.014;      // bar [origin=predictive method=joback]
omega       0.5332;      // -   [origin=predictive method=lee-kesler]
Tb          458.73;      // K   [origin=predictive method=joback]
HvapTb      44213.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.27 0.43554 -0.0002344 3.872e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 2; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group Cl; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylpentane-2,4-dione" "3-chloropentane-2,4-dione" "3-chloro-2,4-pentanedione" "3-chloro.2,4-pentanedione" "2,4-pentanedione, 3-chloro-" "3-cl-acac" "2,4-pentanedione,3-chloro-" "1-acetyl-1-chloroacetone;3-chloro-2,4-dioxopentane; 3-chloro-2,4-pentadione; 3-chloro-2,4-pentanedione;3-chloroacetylacetone; 3-chloropentan-2,4-dione; a-chloroacetylacetone" );
standardThermochemistry
{
    dHf_298   -392710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-280990.0
}
