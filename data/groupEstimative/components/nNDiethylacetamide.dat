/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethylacetamide  (C6H13NO, CAS 685-91-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethylacetamide;
formula     C6H13NO;
CAS         685-91-6;
InChIKey    AJFDBNQQDYLMJN-UHFFFAOYSA-N;
MW          115.176;      // g/mol [origin=calculated method=formula-sum]
Tc          579.25;      // K   [origin=predictive method=joback]
Pc          33.297;      // bar [origin=predictive method=joback]
omega       0.4870;      // -   [origin=predictive method=lee-kesler]
Tb          403.19;      // K   [origin=predictive method=joback]
HvapTb      37739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.898 0.66976 -0.0003965 8.856e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethylethanamide" "diethylacetamide" "acetamide, n,n-diethyl-" "n-acetyldiethylamine" "n,n-diaethylacetamid [german]" "acetic acid, amide, n,n-diethyl" "n,n-diaethylacetamid" "n,n-diethylacetoamide" "n,n-diethyl acetamide" "n,n-diethyl-acetamide" "acetic acid diethylamide" "p948" );
standardThermochemistry
{
    dHf_298   -212220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18500.0
}
