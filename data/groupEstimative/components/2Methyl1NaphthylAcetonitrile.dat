/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-methyl-1-naphthyl)acetonitrile  (C13H11N, CAS 69815-53-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1NaphthylAcetonitrile;
formula     C13H11N;
CAS         69815-53-8;
InChIKey    WRJGSBPPDFYVSY-UHFFFAOYSA-N;
MW          181.238;      // g/mol [origin=calculated method=formula-sum]
Tc          896.09;      // K   [origin=predictive method=joback]
Pc          26.434;      // bar [origin=predictive method=joback]
omega       0.6625;      // -   [origin=predictive method=lee-kesler]
Tb          654.74;      // K   [origin=predictive method=joback]
HvapTb      60250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.679 0.97202 -0.00068624 1.94e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACCH3; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methylnaphthalen-1-yl)ethanenitrile" "(2-methyl-naphthalen-1-yl)acetonitrile" "2-methyl-1-naphthaleneacetonitrile" "1-naphthaleneacetonitrile, 2-methyl-" "2-(2-methylnaphthalen-1-yl)acetonitrile" );
gibbsFormation
{
    dHf_298   257890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=391560.0
    phase     gas;
}
