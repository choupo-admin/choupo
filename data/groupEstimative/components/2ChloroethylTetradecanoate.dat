/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloroethyl tetradecanoate  (C16H31ClO2, CAS 51479-36-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroethylTetradecanoate;
formula     C16H31ClO2;
CAS         51479-36-8;
InChIKey    MPNMNLLETRXDEX-UHFFFAOYSA-N;
MW          290.872;      // g/mol [origin=calculated method=formula-sum]
Tc          831.11;      // K   [origin=predictive method=joback]
Pc          12.884;      // bar [origin=predictive method=joback]
omega       0.8994;      // -   [origin=predictive method=lee-kesler]
Tb          661.33;      // K   [origin=predictive method=joback]
HvapTb      63002.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.644 1.47582 -0.0007724 1.311e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH2COO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloroethyl myristate" "tetradecanoic acid, 2-chloroethyl ester" "mpnmnlletrxdex-uhfffaoysa-" "tetradecanoic acid,2-chloroethyl ester" "myristic acid 2-chloroethyl ester" );
gibbsFormation
{
    dHf_298   -706590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     863.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-238460.0
    phase     gas;
}
