/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl itaconate  (C7H10O4, CAS 617-52-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylItaconate;
formula     C7H10O4;
CAS         617-52-7;
InChIKey    ZWWQRMFIZFPUAA-UHFFFAOYSA-N;
MW          158.153;      // g/mol [origin=calculated method=formula-sum]
Tc          659.52;      // K   [origin=predictive method=joback]
Pc          29.763;      // bar [origin=predictive method=joback]
omega       0.6006;      // -   [origin=predictive method=lee-kesler]
Tb          472.76;      // K   [origin=predictive method=joback]
HvapTb      45400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.661 0.53914 -0.000193 -2.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=C; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-methylidenebutanedioate" "dimethylitaconate" "itaconic acid dimethyl ester" "itaconic acid, dimethyl ester" "dimethyl 2-methylenesuccinate" "butanedioic acid, methylene-, dimethyl ester" "succinic acid, methylene-, dimethyl ester" "dimethyl 2-methylenebutane-1,4-dioate" "itaconic acid, dimethylester" "methylenesuccinic acid, dimethyl ester" "1,4-dimethyl 2-methylidenebutanedioate" "2-methylene-succinic acid dimethyl ester" );
gibbsFormation
{
    dHf_298   -706730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-533390.0
    phase     gas;
}
