/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromoethane-d3  (C2HD3Br2, CAS 117164-17-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C2HD3Br2 (delta D+3H-3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        12DibromoethaneD3;
formula     C2HD3Br2;
CAS         117164-17-7;
InChIKey    PAAZPARNPHGIKF-APAIHEESSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          190.88;      // g/mol [origin=calculated method=formula-sum]
Tc          588.29;      // K   [origin=predictive method=joback]
Pc          61.805;      // bar [origin=predictive method=joback]
omega       0.3534;      // -   [origin=predictive method=lee-kesler]
Tb          377.68;      // K   [origin=predictive method=joback]
HvapTb      32916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.452 0.2702 -0.0002278 8.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)-1,1,2-trideuterio-ethane" "ethylene-d3 dibromide" "1,2-dibromo-1,1,2-trideuterioethane" );
standardThermochemistry
{
    dHf_298   -31950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     335.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5400.0
}
