/*--------------------------------*- Choupo -*-----------------------*\
  Component: nicodicodine  (C24H26N2O4, CAS 808-24-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nicodicodine;
formula     C24H26N2O4;
CAS         808-24-2;
InChIKey    GTGRMWCOZHEYRL-MJFIPZRTSA-N;
MW          406.482;      // g/mol [origin=calculated method=formula-sum]
Tc          1261.62;      // K   [origin=predictive method=joback]
Pc          17.075;      // bar [origin=predictive method=joback]
omega       1.1792;      // -   [origin=predictive method=lee-kesler]
Tb          1009.01;      // K   [origin=predictive method=joback]
HvapTb      96156.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-216.14 2.8628 -0.00244984 8.662e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group C; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 1; } { group CH-O; count 1; } { group CH3N; count 1; } { group C5H4N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 5; } { group O; count 1; } { group O_ring; count 1; } { group COO; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(4r,4ar,7s,7ar,12bs)-9-methoxy-3-methyl-2,4,4a,5,6,7,7a,13-octahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-7-yl] pyridine-3-carboxylate" "nicodicodina" "nicodicodinum" "nicodicodina [dcit]" "6-nicotinoyl dihydrocodeine" "nicodicodinum [inn-latin]" "nicodicodine [inn:ban:dcf]" "dihydrocodein-nicotinat (ester)" "4,5alpha-epoxy-3-methoxy-17-methyl-6alpha-morphinanylnicotinat" "nicotinsaeure-(4,5-epoxy-3-methoxy-17-methyl-morphinan-6-yl)-ester" );
standardThermochemistry
{
    dHf_298   -288960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=275370.0
}
