/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxythiophene  (C5H6OS, CAS 16839-97-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxythiophene;
formula     C5H6OS;
CAS         16839-97-7;
InChIKey    OKEHURCMYKPVFW-UHFFFAOYSA-N;
MW          114.162;      // g/mol [origin=calculated method=formula-sum]
Tc          628.81;      // K   [origin=predictive method=joback]
Pc          47.497;      // bar [origin=predictive method=joback]
omega       0.3049;      // -   [origin=predictive method=lee-kesler]
Tb          407.50;      // K   [origin=predictive method=joback]
HvapTb      36758.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.1 0.41673 -0.00024622 5.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3O; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group O; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thiophene, 2-methoxy-" "2-methoxy-thiophene" "s815" );
gibbsFormation
{
    dHf_298   -48580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20630.0
    phase     gas;
}
