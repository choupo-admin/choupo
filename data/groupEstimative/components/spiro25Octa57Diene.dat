/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[2.5]octa-5,7-diene  (C8H10, CAS 53143-64-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro25Octa57Diene;
formula     C8H10;
CAS         53143-64-9;
InChIKey    LNHLZGKIMCRSGT-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          633.21;      // K   [origin=predictive method=joback]
Pc          42.943;      // bar [origin=predictive method=joback]
omega       0.2507;      // -   [origin=predictive method=lee-kesler]
Tb          407.89;      // K   [origin=predictive method=joback]
HvapTb      33314.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-155.48 1.2528 -0.00132156 5.574e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro(2.5)octa-4,6-diene" "spiro[2.5]octa-4,6-diene" );
standardThermochemistry
{
    dHf_298   75970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175920.0
}
