/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3326829  (C23H18, CAS 16757-92-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3326829;
formula     C23H18;
CAS         16757-92-9;
InChIKey    BZBLXOWOIQZQPM-UHFFFAOYSA-N;
MW          294.397;      // g/mol [origin=calculated method=formula-sum]
Tc          1100.30;      // K   [origin=predictive method=joback]
Pc          19.052;      // bar [origin=predictive method=joback]
omega       0.9075;      // -   [origin=predictive method=lee-kesler]
Tb          850.62;      // K   [origin=predictive method=joback]
HvapTb      78964.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.44 1.81336 -0.00150876 5.186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 8; } { group ACCH3; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 11; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,6-trimethylbenzo[a]pyrene" "benzo(a)pyrene, 1,3,6-trimethyl-" );
standardThermochemistry
{
    dHf_298   368480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=618250.0
}
