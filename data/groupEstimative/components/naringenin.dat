/*--------------------------------*- Choupo -*-----------------------*\
  Component: naringenin  (C15H12O5, CAS 480-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naringenin;
formula     C15H12O5;
CAS         480-41-1;
InChIKey    FTVWIRXFELQLPI-ZDUSSCGKSA-N;
MW          272.256;      // g/mol [origin=calculated method=formula-sum]
Tc          1231.32;      // K   [origin=predictive method=joback]
Pc          52.282;      // bar [origin=predictive method=joback]
omega       1.5488;      // -   [origin=predictive method=lee-kesler]
Tb          948.78;      // K   [origin=predictive method=joback]
HvapTb      102082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.63 1.6453 -0.00147254 5.404e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACOH; count 3; } { group CH2CO; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 3; } { group O_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-(4-hydroxyphenyl)-5,7-bis(oxidanyl)-2,3-dihydrochromen-4-one" "naringetol" "pelargidanon" "salipurpol" "salipurol" "asahina" "naringenine" "(s)-naringenin" "yso1" "(-)-(2s)-naringenin" "(-)-naringenin" "4',5,7-trihydroxyflavanone" );
gibbsFormation
{
    dHf_298   -626330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-333310.0
    phase     gas;
}
