/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene, 4-(1,5-dimethylhexyl)-1-methyl-, didehydro deriv.  (C15H28, CAS 108797-87-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene415Dimethylhexyl1MethylDidehydroDeriv;
formula     C15H28;
CAS         108797-87-1;
InChIKey    OKLFZUUDPLLEOZ-UHFFFAOYSA-N;
MW          208.389;      // g/mol [origin=calculated method=formula-sum]
Tc          761.38;      // K   [origin=predictive method=joback]
Pc          17.132;      // bar [origin=predictive method=joback]
omega       0.5368;      // -   [origin=predictive method=lee-kesler]
Tb          565.61;      // K   [origin=predictive method=joback]
HvapTb      49591.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.637 1.44728 -0.00079984 1.552e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 3; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-(6-methylheptan-2-yl)cyclohexene" );
gibbsFormation
{
    dHf_298   -262860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=115320.0
    phase     gas;
}
