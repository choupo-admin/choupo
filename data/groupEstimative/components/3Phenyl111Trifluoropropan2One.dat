/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenyl-1,1,1-trifluoropropan-2-one  (C9H7F3O, CAS 350-92-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenyl111Trifluoropropan2One;
formula     C9H7F3O;
CAS         350-92-5;
InChIKey    IAJKTOIWQHTZOS-UHFFFAOYSA-N;
MW          188.148;      // g/mol [origin=calculated method=formula-sum]
Tc          679.16;      // K   [origin=predictive method=joback]
Pc          30.727;      // bar [origin=predictive method=joback]
omega       0.5410;      // -   [origin=predictive method=lee-kesler]
Tb          480.65;      // K   [origin=predictive method=joback]
HvapTb      40903.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.039 0.9131 -0.0006993 2.0106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group F; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(fluoranyl)-3-phenyl-propan-2-one" "1,1,1-trifluoro-3-phenylacetone" "1,1,1-trifluoro-3-phenylpropan-2-one" "1,1,1-trifluoro-3-phenyl-2-propanone" );
standardThermochemistry
{
    dHf_298   -702220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-573200.0
}
