/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-trimethylsilyl-n-butyl-n',n'-diethylurea  (C12H28N2OSi, CAS 18388-99-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H28N2OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nTrimethylsilylNButylNNDiethylurea;
formula     C12H28N2OSi;
CAS         18388-99-3;
InChIKey    UJPXKMUARILIQY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          244.454;      // g/mol [origin=calculated method=formula-sum]
Tc          726.33;      // K   [origin=predictive method=joback]
Pc          16.921;      // bar [origin=predictive method=joback]
omega       0.7204;      // -   [origin=predictive method=lee-kesler]
Tb          554.31;      // K   [origin=predictive method=joback]
HvapTb      53432.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.775 1.15752 -0.0004207 -1.984e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH2N; count 1; } { group Si; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 5; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butyl-3,3-diethyl-1-trimethylsilyl-urea" "1-butyl-3,3-diethyl-1-(trimethylsilyl)urea" "urea, n-butyl-n',n'-diethyl-n-(trimethylsilyl)-" "urea,n'-diethyl-n-(trimethylsilyl)-" "1-butyl-3,3-diethyl-1-trimethylsilylurea" );
standardThermochemistry
{
    dHf_298   -380150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     808.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38040.0
}
