/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropane, 1-ethynyl-1-ethenyl-  (C7H8, CAS 105961-74-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropane1Ethynyl1Ethenyl;
formula     C7H8;
CAS         105961-74-8;
InChIKey    TYVGPCXTPUBRCP-UHFFFAOYSA-N;
MW          92.141;      // g/mol [origin=calculated method=formula-sum]
Tc          559.03;      // K   [origin=predictive method=joback]
Pc          42.999;      // bar [origin=predictive method=joback]
omega       0.1899;      // -   [origin=predictive method=lee-kesler]
Tb          353.54;      // K   [origin=predictive method=joback]
HvapTb      29126.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.92 0.9977 -0.00112863 5.0519e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenyl-1-ethynyl-cyclopropane" "1-ethenyl-1-ethynylcyclopropane" );
standardThermochemistry
{
    dHf_298   317560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=374230.0
}
