/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl 4-bromophenyl ketone  (C14H11BrO, CAS 2001-29-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzyl4BromophenylKetone;
formula     C14H11BrO;
CAS         2001-29-8;
InChIKey    MOSIKPSTRPODHQ-UHFFFAOYSA-N;
MW          275.145;      // g/mol [origin=calculated method=formula-sum]
Tc          957.31;      // K   [origin=predictive method=joback]
Pc          31.456;      // bar [origin=predictive method=joback]
omega       0.7410;      // -   [origin=predictive method=lee-kesler]
Tb          698.29;      // K   [origin=predictive method=joback]
HvapTb      65153.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.799 1.1267 -0.00078586 2.0656e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group CH2CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Br; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-bromophenyl)-2-phenyl-ethanone" "1-(4-bromophenyl)-2-phenylethanone" "4-bromodesoxybenzoin" "4'-bromo-2-phenylacetophenone" "1-(4-bromophenyl)-2-phenylethan-1-one" "benzyl 4-brornophenyl ketone" "ethanone,1-(4-bromophenyl)-2-phenyl-" "u330" "brd-k64462698-001-01-5" "acetophenone,4'-bromo-2-phenyl- (7ci,8ci); 1-(4-bromophenyl)-2-phenylethanone;4-bromodeoxybenzoin; 4-bromodesoxybenzoin; 4-bromophenyl benzyl ketone;4'-bromo-2-phenylacetophenone; benzyl 4-bromophenyl ketone; p-bromophenylbenzyl ketone" );
gibbsFormation
{
    dHf_298   43050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=167590.0
    phase     gas;
}
