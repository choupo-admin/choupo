/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6,10,14-tetramethyloctadecane  (C22H46, CAS 54964-82-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        261014Tetramethyloctadecane;
formula     C22H46;
CAS         54964-82-8;
InChIKey    PUTSHCSOTBWQAI-UHFFFAOYSA-N;
MW          310.61;      // g/mol [origin=calculated method=formula-sum]
Tc          870.33;      // K   [origin=predictive method=joback]
Pc          9.194;      // bar [origin=predictive method=joback]
omega       0.7487;      // -   [origin=predictive method=lee-kesler]
Tb          701.20;      // K   [origin=predictive method=joback]
HvapTb      63014.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.838 2.11752 -0.0011858 2.486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 12; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 12; } { group CH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecane, 2,6,10,14-tetramethyl-" "octadecane,2,6,10,14-tetramethyl-" );
gibbsFormation
{
    dHf_298   -518530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     974.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124600.0
    phase     gas;
}
