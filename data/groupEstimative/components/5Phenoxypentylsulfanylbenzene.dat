/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-phenoxypentylsulfanylbenzene  (C17H20OS, CAS 59950-12-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Phenoxypentylsulfanylbenzene;
formula     C17H20OS;
CAS         59950-12-8;
InChIKey    XJRKBEYACQXERP-UHFFFAOYSA-N;
MW          272.406;      // g/mol [origin=calculated method=formula-sum]
Tc          971.08;      // K   [origin=predictive method=joback]
Pc          20.888;      // bar [origin=predictive method=joback]
omega       0.7660;      // -   [origin=predictive method=lee-kesler]
Tb          733.12;      // K   [origin=predictive method=joback]
HvapTb      67215.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.275 1.39219 -0.0008122 1.597e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene,[(5-phenoxypentyl)thio]-" "[(5-phenoxypentyl)sulfanyl]benzene" "benzene, ((5-phenoxypentyl)thio)-" );
standardThermochemistry
{
    dHf_298   -11500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     678.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=245200.0
}
