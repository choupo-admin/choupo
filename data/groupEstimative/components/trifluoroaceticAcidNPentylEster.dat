/*--------------------------------*- Choupo -*-----------------------*\
  Component: trifluoroacetic acid, n-pentyl ester  (C7H11F3O2, CAS 327-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trifluoroaceticAcidNPentylEster;
formula     C7H11F3O2;
CAS         327-70-8;
InChIKey    XJVUVRKPEBTMEC-UHFFFAOYSA-N;
MW          184.157;      // g/mol [origin=calculated method=formula-sum]
Tc          569.86;      // K   [origin=predictive method=joback]
Pc          24.975;      // bar [origin=predictive method=joback]
omega       0.5750;      // -   [origin=predictive method=lee-kesler]
Tb          412.56;      // K   [origin=predictive method=joback]
HvapTb      34836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.734 0.77522 -0.0004834 1.037e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group F; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentyl 2,2,2-tris(fluoranyl)ethanoate" "acetic acid, trifluoro-, pentyl ester" "pentyl 2,2,2-trifluoroacetate" );
gibbsFormation
{
    dHf_298   -1102170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-883900.0
    phase     gas;
}
