/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-ethanoanthracene, 1,4-dihydro-9,10-dimethoxy-  (C18H18O2, CAS 75102-20-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Ethanoanthracene14Dihydro910Dimethoxy;
formula     C18H18O2;
CAS         75102-20-4;
InChIKey    FNGUELPQSYASAA-UHFFFAOYSA-N;
MW          266.34;      // g/mol [origin=calculated method=formula-sum]
Tc          968.26;      // K   [origin=predictive method=joback]
Pc          21.276;      // bar [origin=predictive method=joback]
omega       0.8154;      // -   [origin=predictive method=lee-kesler]
Tb          734.50;      // K   [origin=predictive method=joback]
HvapTb      67164.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.33 1.51264 -0.00106084 3.032e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 4; } { group ACCH; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -94190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222680.0
}
