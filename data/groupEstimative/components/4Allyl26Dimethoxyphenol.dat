/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-allyl-2,6-dimethoxyphenol  (C11H14O3, CAS 6627-88-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Allyl26Dimethoxyphenol;
formula     C11H14O3;
CAS         6627-88-9;
InChIKey    FWMPKHMKIJDEMJ-UHFFFAOYSA-N;
MW          194.23;      // g/mol [origin=calculated method=formula-sum]
Tc          826.18;      // K   [origin=predictive method=joback]
Pc          30.323;      // bar [origin=predictive method=joback]
omega       0.8099;      // -   [origin=predictive method=lee-kesler]
Tb          610.06;      // K   [origin=predictive method=joback]
HvapTb      60844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.671 0.85914 -0.00052898 1.363e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethoxy-4-prop-2-enyl-phenol" "methoxyeugenol" "2,6-dimethoxy-4-prop-2-enylphenol" "phenol, 4-allyl-2,6-dimethoxy-" "phenol, 2,6-dimethoxy-4-(2-propenyl)-" "phenol,6-dimethoxy-" "2,6-dimethoxy-4-allylphenol" "4-hydroxy-3,5-dimethoxyallylbenzene" "phenol,6-dimethoxy-4-(2-propenyl)-" "2,6-dimethoxychavicol" "phenol, 4-allyl-2,6-dimethoxy- (8ci)" "2,6-dimethoxy-4-(prop-2-en-1-yl)phenol" );
gibbsFormation
{
    dHf_298   -373100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-141890.0
    phase     gas;
}
