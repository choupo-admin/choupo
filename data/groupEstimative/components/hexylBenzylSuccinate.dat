/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexyl benzyl succinate  (C17H24O4, CAS 119450-14-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexylBenzylSuccinate;
formula     C17H24O4;
CAS         119450-14-5;
InChIKey    IROBBPAWTAUBOK-UHFFFAOYSA-N;
MW          292.375;      // g/mol [origin=calculated method=formula-sum]
Tc          926.94;      // K   [origin=predictive method=joback]
Pc          15.885;      // bar [origin=predictive method=joback]
omega       0.9788;      // -   [origin=predictive method=lee-kesler]
Tb          731.68;      // K   [origin=predictive method=joback]
HvapTb      70526.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.348 1.43032 -0.000743 1.024e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-hexyl o4-(phenylmethyl) butanedioate" "1-benzyl 4-hexyl succinate" "butanedioic acid, hexyl phenylmethyl ester" "4-o-benzyl 1-o-hexyl butanedioate" );
standardThermochemistry
{
    dHf_298   -792240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     814.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-416070.0
}
