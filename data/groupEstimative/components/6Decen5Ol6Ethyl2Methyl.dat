/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-decen-5-ol, 6-ethyl-2-methyl-  (C13H26O, CAS 67800-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Decen5Ol6Ethyl2Methyl;
formula     C13H26O;
CAS         67800-83-3;
InChIKey    IDAMESLCQFKSKF-UHFFFAOYSA-N;
MW          198.35;      // g/mol [origin=calculated method=formula-sum]
Tc          762.62;      // K   [origin=predictive method=joback]
Pc          18.887;      // bar [origin=predictive method=joback]
omega       0.9457;      // -   [origin=predictive method=lee-kesler]
Tb          592.38;      // K   [origin=predictive method=joback]
HvapTb      60473.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.875 1.30458 -0.0008063 2.015e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-ethyl-2-methyl-dec-6-en-5-ol" );
standardThermochemistry
{
    dHf_298   -367010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     683.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11450.0
}
