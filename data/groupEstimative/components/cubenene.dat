/*--------------------------------*- Choupo -*-----------------------*\
  Component: cubenene  (C8H4, CAS 29837-12-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cubenene;
formula     C8H4;
CAS         29837-12-5;
InChIKey    KWFAQPWLROZBAY-UHFFFAOYSA-N;
MW          100.12;      // g/mol [origin=calculated method=formula-sum]
Tc          606.41;      // K   [origin=predictive method=joback]
Pc          46.530;      // bar [origin=predictive method=joback]
omega       0.4696;      // -   [origin=predictive method=lee-kesler]
Tb          409.36;      // K   [origin=predictive method=joback]
HvapTb      35304.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-152.93 1.262 -0.001599 7.268e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 4; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 4; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   288690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     -180.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=434040.0
    phase     gas;
}
