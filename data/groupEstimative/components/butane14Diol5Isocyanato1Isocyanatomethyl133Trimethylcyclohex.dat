\*---------------------------------------------------------------------------*/

name        butane14Diol5Isocyanato1Isocyanatomethyl133Trimethylcyclohex;
formula     C16H28N2O4;
CAS         67599-30-8;
InChIKey    GKQQCRVAAZQJCC-UHFFFAOYSA-N;
MW          312.41;      // g/mol [origin=calculated method=formula-sum]
Tc          1101.51;      // K   [origin=predictive method=joback]
Pc          19.220;      // bar [origin=predictive method=joback]
omega       1.4930;      // -   [origin=predictive method=lee-kesler]
Tb          895.47;      // K   [origin=predictive method=joback]
HvapTb      101435.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group C; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group dCd; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group OH; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,4-diol;5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethyl-cyclohexane" "1,4-butanediol, 5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethylcyclohexane copolymer" "1,4-butanediol, polymer with 5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethylcyclohexane" "butane-1,4-diol; 5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethyl-cyclohexane" );
