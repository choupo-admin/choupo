/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl prop-2-enoate; prop-1-en-2-ylbenzene; styrene  (C21H24O2, CAS 67846-23-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylProp2EnoateProp1En2YlbenzeneStyrene;
formula     C21H24O2;
CAS         67846-23-5;
InChIKey    YGTYPJGYNQOEFM-UHFFFAOYSA-N;
MW          308.421;      // g/mol [origin=calculated method=formula-sum]
Tc          1023.27;      // K   [origin=predictive method=joback]
Pc          14.657;      // bar [origin=predictive method=joback]
omega       0.6626;      // -   [origin=predictive method=lee-kesler]
Tb          784.38;      // K   [origin=predictive method=joback]
HvapTb      72957.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.37 1.31374 -0.0003278 -1.478e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenylbenzene;methyl prop-2-enoate;prop-1-en-2-ylbenzene" "2-propenoic acid, methyl ester, polymer with ethenylbenzene and (1-methylethenyl)benzene" );
gibbsFormation
{
    dHf_298   -177730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1009.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85840.0
    phase     gas;
}
