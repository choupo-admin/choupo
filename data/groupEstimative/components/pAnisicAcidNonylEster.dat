/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-anisic acid, nonyl ester  (C17H26O3, CAS 55469-25-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pAnisicAcidNonylEster;
formula     C17H26O3;
CAS         55469-25-5;
InChIKey    VJHRENOBIICHMY-UHFFFAOYSA-N;
MW          278.392;      // g/mol [origin=calculated method=formula-sum]
Tc          892.19;      // K   [origin=predictive method=joback]
Pc          15.427;      // bar [origin=predictive method=joback]
omega       0.9091;      // -   [origin=predictive method=lee-kesler]
Tb          700.86;      // K   [origin=predictive method=joback]
HvapTb      66191.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.738 1.36244 -0.00065956 7.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonyl 4-methoxybenzoate" "benzoic acid, 4-methoxy-, nonyl ester" );
standardThermochemistry
{
    dHf_298   -618650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     768.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-220330.0
}
