/*--------------------------------*- Choupo -*-----------------------*\
  Component: nefopam  (C17H19NO, CAS 13669-70-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nefopam;
formula     C17H19NO;
CAS         13669-70-0;
InChIKey    RGPDEAGGEXEMMM-UHFFFAOYSA-N;
MW          253.345;      // g/mol [origin=calculated method=formula-sum]
Tc          952.15;      // K   [origin=predictive method=joback]
Pc          24.171;      // bar [origin=predictive method=joback]
omega       0.6718;      // -   [origin=predictive method=lee-kesler]
Tb          701.57;      // K   [origin=predictive method=joback]
HvapTb      65460.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.93 1.65412 -0.00112246 2.854e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group FCH2O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-1-phenyl-1,3,4,6-tetrahydro-2,5-benzoxazocine" "fenazoxine" "5-methyl-1-phenyl-3,4,5,6-tetrahydro-1h-benzo[f][1,4]oxazocine" "sinalgico" "nefopam [inn:ban]" "nefopamum [inn-latin]" "1h-2,5-benzoxazocine, 3,4,5,6-tetrahydro-5-methyl-1-phenyl-" "3,4,5,6-tetrahydro-5-methyl-1-phenyl-1h-2,5-benzoxazocin" "1h-2,5-benzoxazocine, 3,4,5,6-tetrahydro-5-methyl-1-phenyl- (8ci,9ci)" "nefopamum" "nefopam (inn)" "1h-2,5-benzoxazocine,3,4,5,6-tetrahydro-5-methyl-1-phenyl-, (1s)-" );
gibbsFormation
{
    dHf_298   63390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=368660.0
    phase     gas;
}
