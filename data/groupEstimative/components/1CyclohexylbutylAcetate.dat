/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexylbutyl acetate  (C12H22O2, CAS 63573-84-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1CyclohexylbutylAcetate;
formula     C12H22O2;
CAS         63573-84-2;
InChIKey    VEDJYUOPZNJAGT-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          752.56;      // K   [origin=predictive method=joback]
Pc          21.593;      // bar [origin=predictive method=joback]
omega       0.5758;      // -   [origin=predictive method=lee-kesler]
Tb          551.49;      // K   [origin=predictive method=joback]
HvapTb      49754.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.898 1.21704 -0.0006186 8.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexylbutyl ethanoate" "alpha-propylcyclohexylmethyl acetate" "agn-pc-0db72h" "[(1s)-1-cyclohexylbutyl] acetate" "cyclohexanemethanol, a-propyl-, 1-acetate" "cyclohexanemethanol, alpha-propyl-, acetate" "cyclohexanemethanol, .alpha.-propyl-, acetate" "cyclohexanemethanol, alpha-propyl-, 1-acetate" "cyclohexanemethanol, .alpha.-propyl-, 1-acetate" "cyclohexanemethanol,a-propyl-, acetate (9ci);1-cyclohexyl-1-butyl acetate" );
standardThermochemistry
{
    dHf_298   -559250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     634.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-238200.0
}
