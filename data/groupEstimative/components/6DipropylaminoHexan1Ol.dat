/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-(dipropylamino)hexan-1-ol  (C12H27NO, CAS 43010-05-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6DipropylaminoHexan1Ol;
formula     C12H27NO;
CAS         43010-05-5;
InChIKey    NGLYVCQIAOHIJE-UHFFFAOYSA-N;
MW          201.354;      // g/mol [origin=calculated method=formula-sum]
Tc          735.96;      // K   [origin=predictive method=joback]
Pc          19.237;      // bar [origin=predictive method=joback]
omega       1.0827;      // -   [origin=predictive method=lee-kesler]
Tb          578.78;      // K   [origin=predictive method=joback]
HvapTb      61028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.42 1.30174 -0.000772 1.788e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-hexanol, 6-dipropylamino-" "1-hexanol, 6-dipropylamino-," );
standardThermochemistry
{
    dHf_298   -375710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     690.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24120.0
}
