/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-(bromomethyl)benzoate  (C9H9BrO2, CAS 1129-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3BromomethylBenzoate;
formula     C9H9BrO2;
CAS         1129-28-8;
InChIKey    YUHSMQQNPRLEEJ-UHFFFAOYSA-N;
MW          229.073;      // g/mol [origin=calculated method=formula-sum]
Tc          790.85;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.6189;      // -   [origin=predictive method=lee-kesler]
Tb          561.56;      // K   [origin=predictive method=joback]
HvapTb      52408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.701 0.70382 -0.00040676 7.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-bromomethylbenzoate" "m-carbomethoxybenzyl bromide" "3-(bromomethyl)benzoic acid methyl ester" "methyl-3-(bromomethyl)benzoate" "methyl alpha-bromo-m-toluate" "methyl3-(bromomethyl)benzoate" "3-carbomethoxybenzyl bromide" "alpha-bromo-m-toluic acid methyl ester" "methyl alpha-bromo-m-toluate;alpha-bromo-m-toluic acid methyl ester" "m-toluicacid, a-bromo-, methyl ester(6ci,7ci,8ci);3-(bromomethyl)benzoic acid methyl ester;3-carbomethoxybenzyl bromide;3-methoxycarbonylbenzyl bromide;methylm-(bromomethyl)benzoate;methyl a-bromo-m-toluate;m-(bromomethyl)benzoic acid methyl ester;m-(methoxycarbonyl)benzyl bromide;m-carbomethoxybenzyl bromide;3-(bromomethyl)phenylacetic acid;" );
gibbsFormation
{
    dHf_298   -294980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-168370.0
    phase     gas;
}
