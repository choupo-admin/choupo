/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-pyridinedicarboxaldehyde  (C7H5NO2, CAS 5431-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H5NO2 (delta C+2H+2O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        26Pyridinedicarboxaldehyde;
formula     C7H5NO2;
CAS         5431-44-7;
InChIKey    PMWXGSWIOOVHEQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          135.122;      // g/mol [origin=calculated method=formula-sum]
Tc          622.07;      // K   [origin=predictive method=joback]
Pc          45.347;      // bar [origin=predictive method=joback]
omega       0.2439;      // -   [origin=predictive method=lee-kesler]
Tb          397.96;      // K   [origin=predictive method=joback]
HvapTb      35578.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.02 0.58036 -0.00063642 2.679e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHO; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyridine-2,6-dicarbaldehyde" "2,6-diformylpyridine" "2,6-pyridine dialdehyde" "2,6-pyridinedicarbaldehyde" "2,6-pyridinedicarboxadehyde" "wt671" "5431-44-7               2,6-pyridinedicarboxaldehyde" );
gibbsFormation
{
    dHf_298   222940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=275810.0
    phase     gas;
}
