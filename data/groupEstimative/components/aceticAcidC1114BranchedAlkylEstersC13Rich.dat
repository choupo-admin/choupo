/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetic acid, c11-14-branched alkyl esters, c13-rich  (C15H30O2, CAS 108419-35-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aceticAcidC1114BranchedAlkylEstersC13Rich;
formula     C15H30O2;
CAS         108419-35-8;
InChIKey    UCXBDUCHMOVNPF-UHFFFAOYSA-N;
MW          242.403;      // g/mol [origin=calculated method=formula-sum]
Tc          772.53;      // K   [origin=predictive method=joback]
Pc          14.468;      // bar [origin=predictive method=joback]
omega       0.7560;      // -   [origin=predictive method=lee-kesler]
Tb          599.70;      // K   [origin=predictive method=joback]
HvapTb      55227.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.616 1.3918 -0.0007072 1.087e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 3; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 6; } { group CH; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3,4-diethyl-6-methyl-octyl) ethanoate" "agn-pc-03vch6" "(3,4-diethyl-6-methyloctyl) acetate" );
standardThermochemistry
{
    dHf_298   -686050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     762.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-242270.0
}
