/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,11,11-tetramethyl-3,10-dioxa-2,11-disiladodecane  (C12H30O2Si2, CAS 6222-22-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H30O2Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        221111Tetramethyl310Dioxa211Disiladodecane;
formula     C12H30O2Si2;
CAS         6222-22-6;
InChIKey    SMGWFAZNSMLUHZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          262.54;      // g/mol [origin=calculated method=formula-sum]
Tc          692.18;      // K   [origin=predictive method=joback]
Pc          14.305;      // bar [origin=predictive method=joback]
omega       0.5281;      // -   [origin=predictive method=lee-kesler]
Tb          521.80;      // K   [origin=predictive method=joback]
HvapTb      47714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (124.616 0.60512 0.0004226 -4.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 4; } { group CH2O; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(6-trimethylsilyloxyhexoxy)silane" "3,10-dioxa-2,11-disiladodecane, 2,2,11,11-tetramethyl-" "1,6-bis(trimethylsiloxy)hexane" "trimethyl-(6-trimethylsilyloxyhexoxy)silane" "3,10-dioxa-2,11-disiladodecane,2,2,11,11-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -778690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     898.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-369360.0
}
