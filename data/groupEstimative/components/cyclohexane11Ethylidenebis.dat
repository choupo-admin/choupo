/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane, 1,1'-ethylidenebis-  (C14H26, CAS 2319-61-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexane11Ethylidenebis;
formula     C14H26;
CAS         2319-61-1;
InChIKey    FUZBYNWONHYNOB-UHFFFAOYSA-N;
MW          194.362;      // g/mol [origin=calculated method=formula-sum]
Tc          787.30;      // K   [origin=predictive method=joback]
Pc          21.755;      // bar [origin=predictive method=joback]
omega       0.3967;      // -   [origin=predictive method=lee-kesler]
Tb          558.58;      // K   [origin=predictive method=joback]
HvapTb      47228.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.73 1.58392 -0.000903 1.741e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexylethylcyclohexane" "ethane, 1,1-dicyclohexyl-" "1,1-dicyclohexylethane" "ethane,1-dicyclohexyl-" "cyclohexane,1'-ethylidenebis-" "cyclohexane,1,1'-ethylidenebis-" );
standardThermochemistry
{
    dHf_298   -228930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113460.0
}
