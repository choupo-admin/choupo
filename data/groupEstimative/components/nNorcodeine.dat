/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-norcodeine  (C17H19NO3, CAS 467-15-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNorcodeine;
formula     C17H19NO3;
CAS         467-15-2;
InChIKey    HKOIXWVRNLGFOR-YANNOFPNSA-N;
MW          285.343;      // g/mol [origin=calculated method=formula-sum]
Tc          1074.23;      // K   [origin=predictive method=joback]
Pc          27.556;      // bar [origin=predictive method=joback]
omega       1.3080;      // -   [origin=predictive method=lee-kesler]
Tb          841.97;      // K   [origin=predictive method=joback]
HvapTb      86539.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-175.78 2.12882 -0.00192126 7.265e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3O; count 1; } { group CH-O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 1; } { group O_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,12bs)-9-methoxy-1,2,3,4,4a,7,7a,13-octahydro-4,12-methanobenzofuro[3,2-e]isoquinoline-7-ol" "n-demethylcodeine" "n-desmethylcodeine" "norcodeine" "norcodeine [inn:ban]" "norcodeinum [inn-latin]" "normorphine 3-methyl ether" "7,8-didehydro-4,5-alpha-epoxy-3-methoxymorphinan-6-alpha-ol" "morphinan-6-alpha-ol, 7,8-didehydro-4,5-alpha-epoxy-3-methoxy-" "norcodeina" "norcodeinum" "morphinan-6-ol, 7,8-didehydro-4,5-epoxy-3-methoxy-, (5-alpha,6-alpha)-" );
gibbsFormation
{
    dHf_298   -226850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     326.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195310.0
    phase     gas;
}
