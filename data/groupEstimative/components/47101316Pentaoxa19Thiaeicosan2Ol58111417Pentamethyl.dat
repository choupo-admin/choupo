/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7,10,13,16-pentaoxa-19-thiaeicosan-2-ol, 5,8,11,14,17-pentamethyl-  (C19H40O6S, CAS 72187-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        47101316Pentaoxa19Thiaeicosan2Ol58111417Pentamethyl;
formula     C19H40O6S;
CAS         72187-30-5;
InChIKey    CDCOZVHLCQGWRP-UHFFFAOYSA-N;
MW          396.583;      // g/mol [origin=calculated method=formula-sum]
Tc          1107.66;      // K   [origin=predictive method=joback]
Pc          11.337;      // bar [origin=predictive method=joback]
omega       1.0825;      // -   [origin=predictive method=lee-kesler]
Tb          904.74;      // K   [origin=predictive method=joback]
HvapTb      91106.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (127.916 1.55673 -0.0004642 -7.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 5; } { group CH2O; count 4; } { group C2H4O2; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 6; } { group CH; count 6; } { group OH; count 1; } { group O; count 5; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[1-[1-[1-[1-(1-methylsulfanylpropan-2-yloxy)propan-2-yloxy]propan-2-yloxy]propan-2-yloxy]propan-2-yloxy]propan-2-ol" "5,8,11,14,17-pentaoxa-2-thiaeicosan-19-ol, 4,7,10,13,16-pentamethyl-" );
gibbsFormation
{
    dHf_298   -1238630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1007.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-534240.0
    phase     gas;
}
