/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclooctylamine  (C8H17N, CAS 5452-37-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclooctylamine;
formula     C8H17N;
CAS         5452-37-9;
InChIKey    HSOHBWMXECKEKV-UHFFFAOYSA-N;
MW          127.231;      // g/mol [origin=calculated method=formula-sum]
Tc          715.48;      // K   [origin=predictive method=joback]
Pc          35.685;      // bar [origin=predictive method=joback]
omega       0.3720;      // -   [origin=predictive method=lee-kesler]
Tb          483.26;      // K   [origin=predictive method=joback]
HvapTb      44816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.74 0.9286 -0.000443 4.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclooctanamine" "aminocyclooctane" "cyclooctanamine; cyclooctylamine" "hsohbwmxeckekv-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -132660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83180.0
    phase     gas;
}
