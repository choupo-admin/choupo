/*--------------------------------*- Choupo -*-----------------------*\
  Component: morpholine, 4-methyl-, acetate  (C7H15NO3, CAS 144505-55-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        morpholine4MethylAcetate;
formula     C7H15NO3;
CAS         144505-55-5;
InChIKey    MUTXDFGBERJZBX-UHFFFAOYSA-N;
MW          161.201;      // g/mol [origin=calculated method=formula-sum]
Tc          784.34;      // K   [origin=predictive method=joback]
Pc          35.137;      // bar [origin=predictive method=joback]
omega       0.7237;      // -   [origin=predictive method=lee-kesler]
Tb          566.01;      // K   [origin=predictive method=joback]
HvapTb      55753.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.85 0.79254 -0.0002963 -2.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group FCH2O; count 1; } { group CH3N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanoic acid;4-methylmorpholine" "morpholine, 4-methyl-, acetate (1:1)" "agn-pc-00asiu" );
gibbsFormation
{
    dHf_298   -633350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-371690.0
    phase     gas;
}
