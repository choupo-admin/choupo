/*--------------------------------*- Choupo -*-----------------------*\
  Component: decamethyl-[5]pericyclyne  (C25H30, CAS 88057-40-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decamethyl5Pericyclyne;
formula     C25H30;
CAS         88057-40-3;
InChIKey    QOIXDYKIHPKUIQ-UHFFFAOYSA-N;
MW          330.515;      // g/mol [origin=calculated method=formula-sum]
Tc          1120.98;      // K   [origin=predictive method=joback]
Pc          15.439;      // bar [origin=predictive method=joback]
omega       0.3528;      // -   [origin=predictive method=lee-kesler]
Tb          814.40;      // K   [origin=predictive method=joback]
HvapTb      75270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-218.73 3.1152 -0.0034443 1.5979e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group C; count 5; } { group C_C; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group tC; count 10; } { group C_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,6,6,9,9,12,12,15,15-decamethylcyclopentadeca-1,4,7,10,13-pentayne" "decamethyl-(5)pericyclyne" );
standardThermochemistry
{
    dHf_298   857490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1116.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1151880.0
}
