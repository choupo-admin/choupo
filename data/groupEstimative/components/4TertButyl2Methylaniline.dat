/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butyl-2-methylaniline  (C11H17N, CAS 2909-82-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButyl2Methylaniline;
formula     C11H17N;
CAS         2909-82-2;
InChIKey    ZPWRNXCIWFCXOL-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          785.39;      // K   [origin=predictive method=joback]
Pc          27.789;      // bar [origin=predictive method=joback]
omega       0.5090;      // -   [origin=predictive method=lee-kesler]
Tb          557.22;      // K   [origin=predictive method=joback]
HvapTb      53025.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.4 1.03868 -0.00068692 1.783e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-tert-butyl-2-methyl-aniline" "4-tert-butyl-o-toluidine" "4-(tert-butyl)-2-methylaniline" "aniline, 4-tert-butyl-2-methyl-" "4-(tert-butyl)-2-methylphenylamine" );
gibbsFormation
{
    dHf_298   -31740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=204180.0
    phase     gas;
}
