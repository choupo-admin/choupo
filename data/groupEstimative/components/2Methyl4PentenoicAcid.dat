/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-4-pentenoic acid  (C6H10O2, CAS 1575-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl4PentenoicAcid;
formula     C6H10O2;
CAS         1575-74-2;
InChIKey    HVRZYSHVZOELOH-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          675.99;      // K   [origin=predictive method=joback]
Pc          36.509;      // bar [origin=predictive method=joback]
omega       0.6220;      // -   [origin=predictive method=lee-kesler]
Tb          478.63;      // K   [origin=predictive method=joback]
HvapTb      45056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.639 0.61052 -0.0004013 1.051e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpent-4-enoic acid" "4-pentenoic acid, 2-methyl-" "2-methyl-pent-4-enoic acid" "2-methylpent-4-en-1-oic acid" "hvrzyshvzoeloh-uhfffaoysa-" "2-methylpent-4-en-1-oic acid;" );
gibbsFormation
{
    dHf_298   -397290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-258870.0
    phase     gas;
}
