/*--------------------------------*- Choupo -*-----------------------*\
  Component: (-)-3-methoxy-17-phenethylmorphinan tartrate  (C29H37NO7, CAS 1109-85-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxy17PhenethylmorphinanTartrate;
formula     C29H37NO7;
CAS         1109-85-9;
InChIKey    GIZKPGCNANMOKF-CZPWWGKQSA-N;
MW          511.615;      // g/mol [origin=calculated method=formula-sum]
Tc          1850.52;      // K   [origin=predictive method=joback]
Pc          14.359;      // bar [origin=predictive method=joback]
omega       0.9110;      // -   [origin=predictive method=lee-kesler]
Tb          1461.93;      // K   [origin=predictive method=joback]
HvapTb      156441.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-196.478 3.25292 -0.00242812 7.411e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 4; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group OH; count 2; } { group CH3O; count 1; } { group CH2N; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } { group O; count 1; } { group COOH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "morphinan, 3-methoxy-17-phenethyl-, tartrate, (-)-" );
gibbsFormation
{
    dHf_298   -1156160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1203.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-501800.0
    phase     gas;
}
