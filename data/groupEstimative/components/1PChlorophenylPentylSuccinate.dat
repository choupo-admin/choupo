/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-p-chlorophenyl pentyl succinate  (C15H19ClO4, CAS 3818-90-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PChlorophenylPentylSuccinate;
formula     C15H19ClO4;
CAS         3818-90-4;
InChIKey    LCPXTPZKKXGDAK-UHFFFAOYSA-N;
MW          298.763;      // g/mol [origin=calculated method=formula-sum]
Tc          1027.26;      // K   [origin=predictive method=joback]
Pc          19.153;      // bar [origin=predictive method=joback]
omega       1.1850;      // -   [origin=predictive method=lee-kesler]
Tb          815.62;      // K   [origin=predictive method=joback]
HvapTb      80878.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.547 1.2932 -0.00075476 1.478e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 4; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[5-(4-chlorophenyl)pentoxy]-4-oxidanylidene-butanoic acid" "alpha-butyl-p-chlorobenzyl ester of succinic acid" "succinic acid, alpha-butyl-p-chlorobenzyl ester" "succinato acido di 1-p-clorofenilpentile" "4-[5-(4-chlorophenyl)pentoxy]-4-oxobutanoic acid" );
gibbsFormation
{
    dHf_298   -811160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     765.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-488010.0
    phase     gas;
}
