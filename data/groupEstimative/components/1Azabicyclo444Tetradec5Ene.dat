/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-azabicyclo[4.4.4]tetradec-5-ene  (C13H23N, CAS 84509-55-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Azabicyclo444Tetradec5Ene;
formula     C13H23N;
CAS         84509-55-7;
InChIKey    GXYPTOSENXHNPT-UHFFFAOYSA-N;
MW          193.334;      // g/mol [origin=calculated method=formula-sum]
Tc          802.34;      // K   [origin=predictive method=joback]
Pc          26.407;      // bar [origin=predictive method=joback]
omega       0.4583;      // -   [origin=predictive method=lee-kesler]
Tb          566.33;      // K   [origin=predictive method=joback]
HvapTb      49177.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-145.75 1.5348 -0.00094264 2.059e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH=C; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 11; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azabicyclo(4.4.4)tetradec-5-ene" );
gibbsFormation
{
    dHf_298   -54650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     678.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=241910.0
    phase     gas;
}
