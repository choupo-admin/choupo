/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl octanoate  (C12H24O2, CAS 5457-66-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertButylOctanoate;
formula     C12H24O2;
CAS         5457-66-9;
InChIKey    BRHAUGJKIFZHDU-UHFFFAOYSA-N;
MW          200.322;      // g/mol [origin=calculated method=formula-sum]
Tc          705.26;      // K   [origin=predictive method=joback]
Pc          18.170;      // bar [origin=predictive method=joback]
omega       0.6372;      // -   [origin=predictive method=lee-kesler]
Tb          529.15;      // K   [origin=predictive method=joback]
HvapTb      48417.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.084 1.21488 -0.0007062 1.464e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octanoic acid, 1,1-dimethylethyl ester" "octanoic acid-tert butyl ester" "octanoic acid, tert-butyl ester" "octanoic acid tert-butyl ester" "octanoic acid,1-dimethylethyl ester" "octanoic acid,1,1-dimethylethyl ester" );
gibbsFormation
{
    dHf_298   -617040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-257370.0
    phase     gas;
}
