/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-5-methylaniline  (C8H11NO, CAS 120-71-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy5Methylaniline;
formula     C8H11NO;
CAS         120-71-8;
InChIKey    WXWCDTXEKCVRRO-UHFFFAOYSA-N;
MW          137.182;      // g/mol [origin=calculated method=formula-sum]
Tc          737.46;      // K   [origin=predictive method=joback]
Pc          36.955;      // bar [origin=predictive method=joback]
omega       0.5409;      // -   [origin=predictive method=lee-kesler]
Tb          514.23;      // K   [origin=predictive method=joback]
HvapTb      50053.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.3 0.56464 -0.00024092 1.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group CH3O; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-5-methyl-aniline" "p-cresidine" "5-methyl-o-anisidine" "cresidine" "benzenamine, 2-methoxy-5-methyl-" "para-cresidine" "6-methoxy-m-toluidine" "3-amino-4-methoxytoluene" "krezidin" "4-methoxy-m-toluidine" "1-amino-2-methoxy-5-methylbenzene" "2-amino-4-methylanisole" );
standardThermochemistry
{
    dHf_298   -93290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71080.0
}
