/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-trimethylsilyloxynonane  (C12H28OSi, CAS 18388-84-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H28OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Trimethylsilyloxynonane;
formula     C12H28OSi;
CAS         18388-84-6;
InChIKey    WZNQZZJRYURJIJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          216.44;      // g/mol [origin=calculated method=formula-sum]
Tc          663.80;      // K   [origin=predictive method=joback]
Pc          15.911;      // bar [origin=predictive method=joback]
omega       0.5586;      // -   [origin=predictive method=lee-kesler]
Tb          497.98;      // K   [origin=predictive method=joback]
HvapTb      45010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.298 0.87448 -0.0001032 -1.404e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(nonoxy)silane" "silane, trimethyl(nonyloxy)-" );
standardThermochemistry
{
    dHf_298   -534850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     761.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-159600.0
}
