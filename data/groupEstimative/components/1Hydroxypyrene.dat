/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hydroxypyrene  (C16H10O, CAS 5315-79-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hydroxypyrene;
formula     C16H10O;
CAS         5315-79-7;
InChIKey    BIJNHUAPTJVVNQ-UHFFFAOYSA-N;
MW          218.255;      // g/mol [origin=calculated method=formula-sum]
Tc          995.07;      // K   [origin=predictive method=joback]
Pc          36.509;      // bar [origin=predictive method=joback]
omega       0.8833;      // -   [origin=predictive method=lee-kesler]
Tb          732.18;      // K   [origin=predictive method=joback]
HvapTb      72108.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.75 1.5446 -0.00151576 5.869e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 6; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 9; } { group dC_ring; count 7; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyren-1-ol" "1-pyrenol" "3-hydroxypyrene" "pyrenol" "3-pyrenol" "1-pyrenol (8ci)" "agn-pc-00kc7z" "1-pyrenol (8ci)(9ci)" "pyren-1-ol;1-hydroxypyrene1-pyrenol" );
standardThermochemistry
{
    dHf_298   190460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=336560.0
}
