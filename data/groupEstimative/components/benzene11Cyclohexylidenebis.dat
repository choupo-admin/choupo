/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,1'-cyclohexylidenebis-  (C18H20, CAS 21113-55-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene11Cyclohexylidenebis;
formula     C18H20;
CAS         21113-55-3;
InChIKey    WLHJCCUFRCTNRZ-UHFFFAOYSA-N;
MW          236.358;      // g/mol [origin=calculated method=formula-sum]
Tc          956.30;      // K   [origin=predictive method=joback]
Pc          24.171;      // bar [origin=predictive method=joback]
omega       0.4935;      // -   [origin=predictive method=lee-kesler]
Tb          684.59;      // K   [origin=predictive method=joback]
HvapTb      59492.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-196.88 1.97 -0.0016314 5.616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-phenylcyclohexyl)benzene" "cyclohexane, 1,1-diphenyl-" "benzene, 1,1'-cyclohexanediylbis-" "1,1'-(cyclohexane-1,1-diyl)bisbenzene" );
gibbsFormation
{
    dHf_298   127770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     683.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=344460.0
    phase     gas;
}
