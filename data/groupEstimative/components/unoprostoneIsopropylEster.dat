/*--------------------------------*- Choupo -*-----------------------*\
  Component: unoprostone isopropyl ester  (C25H44O5, CAS 120373-24-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        unoprostoneIsopropylEster;
formula     C25H44O5;
CAS         120373-24-2;
InChIKey    XXUPXHKCPIKWLR-JLLPCOHGSA-N;
MW          424.622;      // g/mol [origin=calculated method=formula-sum]
Tc          1338.04;      // K   [origin=predictive method=joback]
Pc          9.615;      // bar [origin=predictive method=joback]
omega       0.7411;      // -   [origin=predictive method=lee-kesler]
Tb          1073.04;      // K   [origin=predictive method=joback]
HvapTb      117655.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.018 2.44216 -0.0013319 2.4156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 5; } { group CH=CH; count 1; } { group OH; count 2; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group OH; count 2; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl 7-[(1r,2r,3r,5s)-3,5-bis(oxidanyl)-2-(3-oxidanylidenedecyl)cyclopentyl]hept-5-enoate" );
gibbsFormation
{
    dHf_298   -1182250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1115.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-462110.0
    phase     gas;
}
