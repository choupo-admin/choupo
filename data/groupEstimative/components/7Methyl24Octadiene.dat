/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-methyl-2,4-octadiene  (C9H16, CAS 2216-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Methyl24Octadiene;
formula     C9H16;
CAS         2216-70-8;
InChIKey    LLCIDQNOIXWXCW-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          597.41;      // K   [origin=predictive method=joback]
Pc          25.767;      // bar [origin=predictive method=joback]
omega       0.3510;      // -   [origin=predictive method=lee-kesler]
Tb          413.40;      // K   [origin=predictive method=joback]
HvapTb      35156.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.339 0.90476 -0.0006366 1.902e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methylocta-2,4-diene" );
gibbsFormation
{
    dHf_298   70.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=182900.0
    phase     gas;
}
