/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-benzenediol, 2,?-didodecyl-, branched  (C30H54O2, CAS 72207-58-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Benzenediol2DidodecylBranched;
formula     C30H54O2;
CAS         72207-58-0;
InChIKey    DDNGITSTKRVQGM-CLJLJLNGSA-N;
MW          446.76;      // g/mol [origin=calculated method=formula-sum]
Tc          1327.42;      // K   [origin=predictive method=joback]
Pc          8.315;      // bar [origin=predictive method=joback]
omega       0.7408;      // -   [origin=predictive method=lee-kesler]
Tb          1078.02;      // K   [origin=predictive method=joback]
HvapTb      110564.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.192 3.03648 -0.00209148 6.116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 16; } { group CH; count 2; } { group ACH; count 2; } { group ACCH2; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 18; } { group CH; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis[(3r)-3-butyloctyl]benzene-1,4-diol" );
standardThermochemistry
{
    dHf_298   -802650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1245.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9620.0
}
