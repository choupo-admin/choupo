/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-fluorobenzal chloride  (C7H5Cl2F, CAS 402-64-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3FluorobenzalChloride;
formula     C7H5Cl2F;
CAS         402-64-2;
InChIKey    MVRCPAOYPLZMLB-UHFFFAOYSA-N;
MW          179.015;      // g/mol [origin=calculated method=formula-sum]
Tc          686.03;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.3836;      // -   [origin=predictive method=lee-kesler]
Tb          465.11;      // K   [origin=predictive method=joback]
HvapTb      41679.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.11 0.5617 -0.00038156 9.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CHCl2; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[bis(chloranyl)methyl]-3-fluoranyl-benzene" "1-(dichloromethyl)-3-fluorobenzene" "m-fluorobenzalchloride" "3-fluorobenzal chloride 98%" "toluene,.alpha.-dichloro-m-fluoro-" "benzene,1-(dichloromethyl)-3-fluoro-" "benzene, 1-(dichloromethyl)-3-fluoro-" );
gibbsFormation
{
    dHf_298   -195620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-110270.0
    phase     gas;
}
