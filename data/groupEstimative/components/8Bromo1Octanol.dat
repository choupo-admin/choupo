/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-bromo-1-octanol  (C8H17BrO, CAS 50816-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Bromo1Octanol;
formula     C8H17BrO;
CAS         50816-19-8;
InChIKey    GMXIEASXPUEOTG-UHFFFAOYSA-N;
MW          209.127;      // g/mol [origin=calculated method=formula-sum]
Tc          714.34;      // K   [origin=predictive method=joback]
Pc          30.024;      // bar [origin=predictive method=joback]
omega       1.0125;      // -   [origin=predictive method=lee-kesler]
Tb          540.98;      // K   [origin=predictive method=joback]
HvapTb      56516.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.098 0.836 -0.0005132 1.279e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-bromanyloctan-1-ol" "1-octanol, 8-bromo-" "8-bromooctan-1-ol" "8-bromooctanol" "octamethylene bromohydrin" );
gibbsFormation
{
    dHf_298   -334350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-106020.0
    phase     gas;
}
