/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisphenol a diacetate  (C19H20O4, CAS 10192-62-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisphenolADiacetate;
formula     C19H20O4;
CAS         10192-62-8;
InChIKey    NSNHONPMCQYMNT-UHFFFAOYSA-N;
MW          312.365;      // g/mol [origin=calculated method=formula-sum]
Tc          1044.04;      // K   [origin=predictive method=joback]
Pc          17.639;      // bar [origin=predictive method=joback]
omega       0.8970;      // -   [origin=predictive method=lee-kesler]
Tb          810.85;      // K   [origin=predictive method=joback]
HvapTb      77282.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.25 1.54828 -0.00092072 1.738e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[2-(4-acetyloxyphenyl)propan-2-yl]phenyl] ethanoate" "2,2-bis(4-acetoxyphenyl)propane" "phenol, 4,4'-(1-methylethylidene)bis-, diacetate" "4,4'-isopropylidenediphenol diacetate" "propane-2,2-diyldi-4,1-phenylene diacetate" "[4-[2-(4-acetyloxyphenyl)propan-2-yl]phenyl] acetate" "phenol, 4,4'-(1-methylethylidene)bis-, 1,1'-diacetate" "4-[1-(4-acetyloxyphenyl)-isopropyl]phenyl acetate" "4,4'-isopropylidenediphenyl diacetate" "nsnhonpmcqymnt-uhfffaoysa-" "2,2'-bis(p-acetoxyphenyl)propane" "propane-2,2-diyldibenzene-4,1-diyl diacetate" );
standardThermochemistry
{
    dHf_298   -628680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     734.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-303240.0
}
