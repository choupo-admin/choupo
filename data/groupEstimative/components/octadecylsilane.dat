/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecylsilane  (C18H37Si, CAS 18623-11-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C18H37Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        octadecylsilane;
formula     C18H37Si;
CAS         18623-11-5;
InChIKey    FUESFIVIIFEDFI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          281.579;      // g/mol [origin=calculated method=formula-sum]
Tc          768.06;      // K   [origin=predictive method=joback]
Pc          11.617;      // bar [origin=predictive method=joback]
omega       0.8115;      // -   [origin=predictive method=lee-kesler]
Tb          610.74;      // K   [origin=predictive method=joback]
HvapTb      55515.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.883 1.81692 -0.0011628 3.116e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 1; } { group CH2; count 17; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecylsilicon" "silane, octadecyl-" "u - 2,3-dichlorophenol" );
standardThermochemistry
{
    dHf_298   -359040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     822.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=153060.0
}
