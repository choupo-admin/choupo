/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dichloro-6-phenylphenol  (C12H8Cl2O, CAS 5335-24-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dichloro6Phenylphenol;
formula     C12H8Cl2O;
CAS         5335-24-0;
InChIKey    AFXPPGXJWHJULD-UHFFFAOYSA-N;
MW          239.095;      // g/mol [origin=calculated method=formula-sum]
Tc          960.35;      // K   [origin=predictive method=joback]
Pc          36.159;      // bar [origin=predictive method=joback]
omega       0.7372;      // -   [origin=predictive method=lee-kesler]
Tb          692.96;      // K   [origin=predictive method=joback]
HvapTb      69966.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.37 1.0352 -0.00085448 2.839e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 2; } { group ACOH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 7; } { group dC_ring; count 5; } { group Cl; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(chloranyl)-6-phenyl-phenol" "3,5-dichloro-2-biphenylol" "4,6-dichloro-2-phenylphenol" "2-biphenylol, 3,5-dichloro-" "2-hydroxy-3,5-dichlorobiphenyl" "4,6-dichloro-o-phenylphenol" "[1,1'-biphenyl]-2-ol, 3,5-dichloro-" "3,5-dichloro-(1,1'-biphenyl)-2-ol" "(1,1'-biphenyl)-2-ol, 3,5-dichloro-" "[1, 3,5-dichloro-" "3,1'-biphenyl)-2-ol" "2-biphenylol,5-dichloro-" );
standardThermochemistry
{
    dHf_298   -49680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77240.0
}
