/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-01you5  (C11H18O2, CAS 91069-39-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc01you5;
formula     C11H18O2;
CAS         91069-39-5;
InChIKey    GITDWIBIPJFPDK-UHFFFAOYSA-N;
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          747.71;      // K   [origin=predictive method=joback]
Pc          27.297;      // bar [origin=predictive method=joback]
omega       0.5140;      // -   [origin=predictive method=lee-kesler]
Tb          531.76;      // K   [origin=predictive method=joback]
HvapTb      46506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.419 1.56852 -0.0013602 4.994e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-ethyl-1-oxaspiro[4.5]decan-2-one" "1-oxaspiro(4.5)decan-2-one, 8-ethyl-, cis-" "1-oxaspiro(4.5)decan-2-one, 8-ethyl-, trans-" );
standardThermochemistry
{
    dHf_298   -439130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-176820.0
}
