/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dibromoundecane  (C11H22Br2, CAS 62168-28-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dibromoundecane;
formula     C11H22Br2;
CAS         62168-28-9;
InChIKey    MJKNZSCOSMZCDR-UHFFFAOYSA-N;
MW          314.105;      // g/mol [origin=calculated method=formula-sum]
Tc          775.86;      // K   [origin=predictive method=joback]
Pc          22.083;      // bar [origin=predictive method=joback]
omega       0.7649;      // -   [origin=predictive method=lee-kesler]
Tb          583.16;      // K   [origin=predictive method=joback]
HvapTb      52562.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.589 1.13112 -0.0007206 1.874e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(bromanyl)undecane" "undecane, 1,1-dibromo-" "agn-pc-00k3wz" );
gibbsFormation
{
    dHf_298   -222990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     677.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=67940.0
    phase     gas;
}
