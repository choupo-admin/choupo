/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dimethoxybenzene  (C8H10O2, CAS 150-78-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dimethoxybenzene;
formula     C8H10O2;
CAS         150-78-7;
InChIKey    OHBQPCCCRFSCAX-UHFFFAOYSA-N;
MW          138.166;      // g/mol [origin=calculated method=formula-sum]
Tc          667.64;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       0.4408;      // -   [origin=predictive method=lee-kesler]
Tb          459.14;      // K   [origin=predictive method=joback]
HvapTb      41160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.01 0.49904 -0.00015356 -2.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-dimethoxybenzene" "hydroquinone dimethyl ether" "p-methoxyanisole" "benzene, 1,4-dimethoxy-" "benzene, p-dimethoxy-" "quinol dimethyl ether" "dimethylhydroquinone ether" "dimethyl ether hydroquinone" "usaf an-9" "dimethyl hydroquinone" "1,4-dimethoxybenzol" "anisole, p-methoxy-" );
standardThermochemistry
{
    dHf_298   -247830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90740.0
}
