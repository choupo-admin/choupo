/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethyl-2-methylenecyclopropane  (C6H10, CAS 4372-94-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dimethyl2Methylenecyclopropane;
formula     C6H10;
CAS         4372-94-5;
InChIKey    JLXPBJLFVFPFOJ-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          531.82;      // K   [origin=predictive method=joback]
Pc          39.062;      // bar [origin=predictive method=joback]
omega       0.2250;      // -   [origin=predictive method=lee-kesler]
Tb          343.02;      // K   [origin=predictive method=joback]
HvapTb      27871.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.51 0.89914 -0.000963 4.284e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group CH2_ring; count 1; } { group C_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethyl-2-methylidene-cyclopropane" "cyclopropane, 1,1-dimethyl-2-methylene-" "1,1-dimethyl-2-methylidenecyclopropane" );
gibbsFormation
{
    dHf_298   5110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107980.0
    phase     gas;
}
