/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(ethenyl)benzene; 1-ethenyl-2-ethylbenzene; 5-ethenyl-2-methylpyridine  (C28H31N, CAS 63690-51-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12BisEthenylBenzene1Ethenyl2Ethylbenzene5Ethenyl2Methylpyrid;
formula     C28H31N;
CAS         63690-51-7;
InChIKey    KGULURQQMWVHMD-UHFFFAOYSA-N;
MW          381.563;      // g/mol [origin=calculated method=formula-sum]
Tc          1233.75;      // K   [origin=predictive method=joback]
Pc          11.375;      // bar [origin=predictive method=joback]
omega       0.7701;      // -   [origin=predictive method=lee-kesler]
Tb          978.44;      // K   [origin=predictive method=joback]
HvapTb      90854.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.649 1.79 -0.00066314 -3.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 4; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 4; } { group dCH; count 4; } { group dCH_ring; count 11; } { group dC_ring; count 6; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(ethenyl)benzene;1-ethenyl-2-ethyl-benzene;5-ethenyl-2-methyl-pyridine" "pyridine, 5-ethenyl-2-methyl-, polymer with diethenylbenzene and ethenylethylbenzene" );
gibbsFormation
{
    dHf_298   365200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1118.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=712110.0
    phase     gas;
}
