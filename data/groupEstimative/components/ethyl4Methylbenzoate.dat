/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 4-methylbenzoate  (C10H12O2, CAS 94-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl4Methylbenzoate;
formula     C10H12O2;
CAS         94-08-6;
InChIKey    NWPWRAWAUYIELB-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          729.36;      // K   [origin=predictive method=joback]
Pc          28.999;      // bar [origin=predictive method=joback]
omega       0.5374;      // -   [origin=predictive method=lee-kesler]
Tb          518.28;      // K   [origin=predictive method=joback]
HvapTb      48199.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.399 0.76064 -0.00038976 5.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl p-toluate" "ethyl p-methylbenzoate" "4-methylbenzoic acid ethyl ester" "p-toluic acid ethyl ester" "benzoic acid, 4-methyl-, ethyl ester" "ethyl-p-toluate" "ethyl p-methyl benzoate" "agn-pc-0cqhgo" "p-toluic acid, ethyl ester" "nwpwrawauyielb-uhfffaoysa-" "4-methyl-benzoic acid ethyl ester" );
standardThermochemistry
{
    dHf_298   -341950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-174270.0
}
