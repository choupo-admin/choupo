/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxy-2-methylmalonic acid  (C4H6O5, CAS 595-98-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxy2MethylmalonicAcid;
formula     C4H6O5;
CAS         595-98-2;
InChIKey    LNRVTEQEGXVMEF-UHFFFAOYSA-N;
MW          134.087;      // g/mol [origin=calculated method=formula-sum]
Tc          878.18;      // K   [origin=predictive method=joback]
Pc          58.006;      // bar [origin=predictive method=joback]
omega       1.5173;      // -   [origin=predictive method=lee-kesler]
Tb          671.09;      // K   [origin=predictive method=joback]
HvapTb      74209.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.73 0.64522 -0.0005412 1.741e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group OH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group OH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-2-oxidanyl-propanedioic acid" "dl-methyltartronic acid" "methyl tartronic acid" "hydroxy(methyl)propanedioic acid" );
standardThermochemistry
{
    dHf_298   -987410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-839000.0
}
