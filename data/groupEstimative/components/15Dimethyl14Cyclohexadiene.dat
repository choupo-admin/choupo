/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-dimethyl-1,4-cyclohexadiene  (C8H12, CAS 4190-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Dimethyl14Cyclohexadiene;
formula     C8H12;
CAS         4190-06-1;
InChIKey    TYMUFQXLPNZKGZ-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          624.03;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       0.2951;      // -   [origin=predictive method=lee-kesler]
Tb          415.14;      // K   [origin=predictive method=joback]
HvapTb      36048.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.77 0.68144 -0.00038828 8.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-dimethylcyclohexa-1,4-diene" "tymufqxlpnzkgz-uhfffaoysa-" "1,4-cyclohexadiene,1,5-dimethyl-" );
standardThermochemistry
{
    dHf_298   -41170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89300.0
}
