/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methoxy-7-methyltetraphene  (C20H16O, CAS 966-48-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methoxy7Methyltetraphene;
formula     C20H16O;
CAS         966-48-3;
InChIKey    PRLOOJMAUMLKMS-UHFFFAOYSA-N;
MW          272.347;      // g/mol [origin=calculated method=formula-sum]
Tc          1032.27;      // K   [origin=predictive method=joback]
Pc          21.653;      // bar [origin=predictive method=joback]
omega       0.8272;      // -   [origin=predictive method=lee-kesler]
Tb          783.16;      // K   [origin=predictive method=joback]
HvapTb      72368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.83 1.51264 -0.0011264 3.412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 7; } { group ACCH3; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methoxy-7-methyl-benzo[a]anthracene" "5-methoxy-7-methylbenz(a)anthracene" "benz(a)anthracene, 5-methoxy-7-methyl-" "3-methoxy-10-methyl-1,2-benzanthracene" "5-methoxy-7-methylbenzo[a]anthracene" );
gibbsFormation
{
    dHf_298   175510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=406360.0
    phase     gas;
}
