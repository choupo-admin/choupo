/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-bis(2-(dimethylamino)ethoxy)pyridine  (C13H23N3O2, CAS 29449-91-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Bis2DimethylaminoEthoxyPyridine;
formula     C13H23N3O2;
CAS         29449-91-0;
InChIKey    RGIHODWAEHCRBV-UHFFFAOYSA-N;
MW          253.346;      // g/mol [origin=calculated method=formula-sum]
Tc          849.35;      // K   [origin=predictive method=joback]
Pc          20.908;      // bar [origin=predictive method=joback]
omega       0.9072;      // -   [origin=predictive method=lee-kesler]
Tb          652.12;      // K   [origin=predictive method=joback]
HvapTb      62586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.144 1.25564 -0.00066002 1.111e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2O; count 2; } { group CH3N; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group O; count 2; } { group N; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[6-[2-(dimethylamino)ethoxy]pyridin-2-yl]oxy-n,n-dimethyl-ethanamine" "2,6-bis[2-(dimethylamino)ethoxy]pyridine" "[2-({6-[2-(dimethylamino)ethoxy]pyridin-2-yl}oxy)ethyl]dimethylamine" "2-[6-(2-dimethylaminoethyloxy)pyridin-2-yl]oxy-n,n-dimethylethanamine" "2-((6-(2-(dimethylamino)ethoxy)-2-pyridinyl)oxy)-n,n-dimethylethanamine; n-(2-((6-(2-(dimethylamino)ethoxy)-2-pyridinyl)oxy)ethyl)-n,n-dimethylamine" );
gibbsFormation
{
    dHf_298   -183180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     617.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=249970.0
    phase     gas;
}
