/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluorobenzamide  (C7H6FNO, CAS 824-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Fluorobenzamide;
formula     C7H6FNO;
CAS         824-75-9;
InChIKey    VNDHYTGVCGVETQ-UHFFFAOYSA-N;
MW          139.129;      // g/mol [origin=calculated method=formula-sum]
Tc          743.04;      // K   [origin=predictive method=joback]
Pc          44.504;      // bar [origin=predictive method=joback]
omega       0.6090;      // -   [origin=predictive method=lee-kesler]
Tb          517.09;      // K   [origin=predictive method=joback]
HvapTb      50684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.14 0.5761 -0.00036226 8.026e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACF; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-fluoranylbenzamide" "p-fluorobenzamide" "benzamide, 4-fluoro-" "benzamide, p-fluoro-" "p-fluorobenzoic acid amide" "agn-pc-00dur8" );
standardThermochemistry
{
    dHf_298   -237650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-146440.0
}
