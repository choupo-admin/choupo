/*--------------------------------*- Choupo -*-----------------------*\
  Component: coumarin 334  (C17H17NO3, CAS 55804-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coumarin334;
formula     C17H17NO3;
CAS         55804-67-6;
InChIKey    JBPCDMSEJVCNGV-UHFFFAOYSA-N;
MW          283.327;      // g/mol [origin=calculated method=formula-sum]
Tc          1023.56;      // K   [origin=predictive method=joback]
Pc          24.314;      // bar [origin=predictive method=joback]
omega       1.1039;      // -   [origin=predictive method=lee-kesler]
Tb          793.79;      // K   [origin=predictive method=joback]
HvapTb      76004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.54 1.76932 -0.00145678 4.7996e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=C; count 1; } { group ACH; count 1; } { group AC; count 3; } { group ACCH2; count 2; } { group CH3CO; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group dCH_ring; count 2; } { group dC_ring; count 6; } { group CdO; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-acetyl-2,3,5,6-tetrahydro-1h,4h-11-oxa-3a-aza-benzo[de]anthracen-10-one" "10-acetyl-2,3,6,7-tetrahydro-1h,5h,11h-pyrano[2,3-f]pyrido[3,2,1-ij]quinolin-11-one" "1h,5h,11h-(1)benzopyrano(6,7,8-ij)quinolizin-11-one, 10-acetyl-2,3,6,7-tetrahydro-" "1h,5h,11h-[1]benzopyrano[6,7,8-ij]quinolizin-11-one, 10-acetyl-2,3,6,7-tetrahydro-" "10-acetyl-2,3,6,7-tetrahydro-1h,5h,11h-(1)benzopyrano(6,7,8-ij)quinolizin-11-one" "10-acetyl-2,3,6,7-tetrahydro-1h-pyrano[2,3-f]pyrido[3,2,1-ij]quinolin-11(5h)-one" "1h,5h,11h-[1]benzopyrano[6,7,8-ij]quinolizin-11-one,10-acetyl-2,3,6,7-tetrahydro-" "5-acetyl-3-oxa-13-azatetracyclo[7.7.1.0^{2,7}.0^{13,17}]heptadeca-1,5,7,9(17)-tetraen-4-one" );
gibbsFormation
{
    dHf_298   -234000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75450.0
    phase     gas;
}
