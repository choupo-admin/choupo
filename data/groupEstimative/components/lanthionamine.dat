/*--------------------------------*- Choupo -*-----------------------*\
  Component: lanthionamine  (C4H12N2S, CAS 871-76-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lanthionamine;
formula     C4H12N2S;
CAS         871-76-1;
InChIKey    JONTXEXBTWSUKE-UHFFFAOYSA-N;
MW          120.214;      // g/mol [origin=calculated method=formula-sum]
Tc          724.67;      // K   [origin=predictive method=joback]
Pc          46.214;      // bar [origin=predictive method=joback]
omega       0.6325;      // -   [origin=predictive method=lee-kesler]
Tb          504.96;      // K   [origin=predictive method=joback]
HvapTb      52597.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.834 0.50199 -0.0002404 3.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2NH2; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group NH2; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-azanylethylsulfanyl)ethanamine" "2,2'-thiobis(ethylamine)" "3-thiacadaverine" "bis(2-aminoethyl) sulfide" "monoethanolamine sulfide" "2,2'-thiodiethylamine" "2,2'-thiobisethylamine" "1,7-diaza-4-thiaheptane" "1,5-diamino-3-thiapentane" "ethanamine, 2,2'-thiobis-" "2-(2-aminoethylsulfanyl)ethanamine" "2,2'-thiobis[ethylamine]" );
gibbsFormation
{
    dHf_298   -16440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=148820.0
    phase     gas;
}
