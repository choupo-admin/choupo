/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-ethylhexyl ester, polymer with ethenyl acetate and 2-propenamide  (C18H31NO5, CAS 60164-05-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2EthylhexylEsterPolymerWithEthenylAcetateAnd2P;
formula     C18H31NO5;
CAS         60164-05-8;
InChIKey    AHLZICFMKIUANV-UHFFFAOYSA-N;
MW          341.448;      // g/mol [origin=calculated method=formula-sum]
Tc          1048.96;      // K   [origin=predictive method=joback]
Pc          12.243;      // bar [origin=predictive method=joback]
omega       1.0101;      // -   [origin=predictive method=lee-kesler]
Tb          846.68;      // K   [origin=predictive method=joback]
HvapTb      86053.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (122.175 1.17166 -3.32e-05 -2.9194e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 3; } { group CH3COO; count 1; } { group COO; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 3; } { group dCH; count 3; } { group CdO; count 1; } { group COO; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl ethanoate;2-ethylhexyl prop-2-enoate;prop-2-enamide" "vinyl acetate, 2-ethylhexyl acrylate, acrylamide polymer" "ethenyl acetate; 2-ethylhexyl prop-2-enoate; prop-2-enamide" );
gibbsFormation
{
    dHf_298   -980430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1230.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-530970.0
    phase     gas;
}
