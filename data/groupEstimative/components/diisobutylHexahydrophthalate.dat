/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisobutyl hexahydrophthalate  (C16H28O4, CAS 70969-58-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisobutylHexahydrophthalate;
formula     C16H28O4;
CAS         70969-58-3;
InChIKey    QUKHPBOCBWDYMW-UHFFFAOYSA-N;
MW          284.396;      // g/mol [origin=calculated method=formula-sum]
Tc          893.81;      // K   [origin=predictive method=joback]
Pc          15.307;      // bar [origin=predictive method=joback]
omega       0.8236;      // -   [origin=predictive method=lee-kesler]
Tb          696.12;      // K   [origin=predictive method=joback]
HvapTb      65368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.868 1.52168 -0.0006894 4.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-methylpropyl) cyclohexane-1,2-dicarboxylate" "diisobutyl cyclohexane-1,2-dicarboxylate" "1,2-cyclohexanedicarboxylic acid, bis(2-methylpropyl) ester" "1,2-cyclohexanedicarboxylic acid, 1,2-bis(2-methylpropyl) ester" );
standardThermochemistry
{
    dHf_298   -984710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     789.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-525040.0
}
