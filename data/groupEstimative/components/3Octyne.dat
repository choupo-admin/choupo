/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-octyne  (C8H14, CAS 15232-76-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Octyne;
formula     C8H14;
CAS         15232-76-5;
InChIKey    UDEISTCPVNLKRJ-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          579.00;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       0.3123;      // -   [origin=predictive method=lee-kesler]
Tb          391.64;      // K   [origin=predictive method=joback]
HvapTb      35554.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.174 0.61404 -0.00031926 6.298e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oct-3-yne" "butylethylacetylene" "3-octyne, homopolymer" "udeistcpvnlkrj-uhfffaoysa-" "1-ethyl-2-butylacetylene;butylethylacetylene; ethylbutyl acetylene" "3h-indolium, 2-(((4-methoxyphenyl)methylhydrazono)methyl)-1,3,3-trimethyl-, formate" "3h-indolium, 2-((2-(4-methoxyphenyl)-2-methylhydrazinylidene)methyl)-1,3,3-trimethyl-, formate (1:1)" );
standardThermochemistry
{
    dHf_298   63850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=219280.0
}
