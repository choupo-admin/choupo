/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-acetylamino-p-terphenyl  (C20H17NO, CAS 64058-92-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4AcetylaminoPTerphenyl;
formula     C20H17NO;
CAS         64058-92-0;
InChIKey    GPIMZPOFPAUOTJ-UHFFFAOYSA-N;
MW          287.362;      // g/mol [origin=calculated method=formula-sum]
Tc          1139.00;      // K   [origin=predictive method=joback]
Pc          23.680;      // bar [origin=predictive method=joback]
omega       0.9788;      // -   [origin=predictive method=lee-kesler]
Tb          873.60;      // K   [origin=predictive method=joback]
HvapTb      85653.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.559 1.582 -0.00104842 2.5546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 13; } { group AC; count 4; } { group ACCH2; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(4-phenylphenyl)phenyl]ethanamide" "p-terphenyl-4-ylacetamide" "acetamide, p-terphenyl-4-yl-" "4-acetylamino-p-diphenylbenzene" "2-[4-(4-phenylphenyl)phenyl]acetamide" "2-(1,1':4',1''-terphenyl-4-yl)acetamide" );
gibbsFormation
{
    dHf_298   151730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     681.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=373020.0
    phase     gas;
}
