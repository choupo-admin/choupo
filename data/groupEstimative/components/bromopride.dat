/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromopride  (C14H22BrN3O2, CAS 4093-35-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromopride;
formula     C14H22BrN3O2;
CAS         4093-35-0;
InChIKey    GIYAQDDTCWHPPL-UHFFFAOYSA-N;
MW          344.253;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.32;      // K   [origin=predictive method=joback]
Pc          22.828;      // bar [origin=predictive method=joback]
omega       1.3161;      // -   [origin=predictive method=lee-kesler]
Tb          839.13;      // K   [origin=predictive method=joback]
HvapTb      85731.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.794 1.28546 -0.00071418 1.3536e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 2; } { group AC; count 3; } { group CH3O; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } { group Br; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group O; count 1; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanyl-5-bromanyl-n-[2-(diethylamino)ethyl]-2-methoxy-benzamide" "artomey" "valopride" "viaben" "bromopridum [inn-latin]" "emepride" "emoril" "viadil" "4-amino-5-bromo-n-(2-(diethylamino)ethyl)-o-anisamide" "n-(diethylaminoethyl)-2-methoxy-4-amino-5-bromobenzamide" "benzamide, 4-amino-5-bromo-n-[2-(diethylamino)ethyl]-2-methoxy-" "o-anisamide, 4-amino-5-bromo-n-(2-(diethylamino)ethyl)-" );
gibbsFormation
{
    dHf_298   -193850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     773.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197540.0
    phase     gas;
}
