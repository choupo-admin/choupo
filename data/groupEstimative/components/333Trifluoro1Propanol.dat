/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,3-trifluoro-1-propanol  (C3H5F3O, CAS 2240-88-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333Trifluoro1Propanol;
formula     C3H5F3O;
CAS         2240-88-2;
InChIKey    HDBGBTNNPRCVND-UHFFFAOYSA-N;
MW          114.066;      // g/mol [origin=calculated method=formula-sum]
Tc          501.76;      // K   [origin=predictive method=joback]
Pc          42.719;      // bar [origin=predictive method=joback]
omega       0.6889;      // -   [origin=predictive method=lee-kesler]
Tb          355.00;      // K   [origin=predictive method=joback]
HvapTb      35204.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.748 0.484 -0.0003908 1.23e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group F; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,3-tris(fluoranyl)propan-1-ol" "3,3,3-trifluoropropan-1-ol" "3,3,3-trifluoropropanol" "perfluoroalkyl alcohol" "2-(trifluoromethyl)ethanol;" "3,3,3-trifluoropropanol-1" "2-(trifluoromethyl)ethan-1-ol" "3-hydroxy-1,1,1-trifluoropropane" "poly(difluoromethylene), alpha-fluoro-omega-(2-hydroxyethyl)-" );
gibbsFormation
{
    dHf_298   -854560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-744030.0
    phase     gas;
}
