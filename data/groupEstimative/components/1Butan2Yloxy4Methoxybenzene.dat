/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butan-2-yloxy-4-methoxybenzene  (C11H16O2, CAS 51241-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butan2Yloxy4Methoxybenzene;
formula     C11H16O2;
CAS         51241-49-7;
InChIKey    SHKYHYJVCZVAEJ-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          731.64;      // K   [origin=predictive method=joback]
Pc          25.405;      // bar [origin=predictive method=joback]
omega       0.5568;      // -   [origin=predictive method=lee-kesler]
Tb          527.34;      // K   [origin=predictive method=joback]
HvapTb      47450.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.601 0.78996 -0.00031996 1.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butan-2-yloxy-4-methoxy-benzene" "benzene, 1-methoxy-4-(1-methylpropoxy)-" "1-(butan-2-yloxy)-4-methoxybenzene" "benzene,1-methoxy-4-(1-methylpropoxy)-" );
gibbsFormation
{
    dHf_298   -315030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-67920.0
    phase     gas;
}
