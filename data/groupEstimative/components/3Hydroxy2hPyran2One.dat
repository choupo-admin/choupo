/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxy-2h-pyran-2-one  (C5H4O3, CAS 496-64-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hydroxy2hPyran2One;
formula     C5H4O3;
CAS         496-64-0;
InChIKey    LIPRKYKMVQPYPG-UHFFFAOYSA-N;
MW          112.084;      // g/mol [origin=calculated method=formula-sum]
Tc          687.75;      // K   [origin=predictive method=joback]
Pc          60.655;      // bar [origin=predictive method=joback]
omega       0.5983;      // -   [origin=predictive method=lee-kesler]
Tb          466.84;      // K   [origin=predictive method=joback]
HvapTb      48123.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.91 0.6344 -0.00061372 2.303e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 1; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanylpyran-2-one" "3-hydroxy-2-pyrone" "3-hydroxy-2-pyranone" "3-hydroxypyrone" "3-hydroxypyran-2-one" "2h-pyran-2-one,3-hydroxy-" "2h-pyran-2-one, 3-hydroxy-" "2h-pyran-4-one, 3-hydroxy-" "2,4-pentadienoicacid, 2,5-dihydroxy-, d-lactone (6ci,7ci);3-hydroxy-2-pyrone;3-hydroxy-2h-pyran-2-one;3-hydroxy-a-pyrone;3-hydroxypyran-2-one;" );
gibbsFormation
{
    dHf_298   -438580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     325.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-357490.0
    phase     gas;
}
