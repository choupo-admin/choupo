/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethyl-1-naphthylamine  (C14H17N, CAS 84-95-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethyl1Naphthylamine;
formula     C14H17N;
CAS         84-95-7;
InChIKey    XLEMRIJDZGESRG-UHFFFAOYSA-N;
MW          199.297;      // g/mol [origin=calculated method=formula-sum]
Tc          801.68;      // K   [origin=predictive method=joback]
Pc          24.925;      // bar [origin=predictive method=joback]
omega       0.6018;      // -   [origin=predictive method=lee-kesler]
Tb          583.00;      // K   [origin=predictive method=joback]
HvapTb      53379.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.578 1.31564 -0.00095128 2.745e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 7; } { group AC; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethylnaphthalen-1-amine" "1-(diethylamino)naphthalene" "diethyl-.alpha.-naphthylamine" "n,n-diethyl-1-aminonaphthalene" "1-naphthalenamine, n,n-diethyl-" "diethyl-alpha-naphthylamine" "1-naphthylamine,n-diethyl-" "1-naphthalenamine,n-diethyl-" "n,n-diethyl-alpha-naphthylamine" "n,n-diethyl-.alpha.-naphthylamine" "1-naphthylamine, n,n-diethyl- (8ci)" );
gibbsFormation
{
    dHf_298   151370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=387210.0
    phase     gas;
}
