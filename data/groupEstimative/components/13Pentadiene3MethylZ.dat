/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-pentadiene, 3-methyl-, (z)-  (C6H10, CAS 2787-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Pentadiene3MethylZ;
formula     C6H10;
CAS         2787-45-3;
InChIKey    BOGRNZQRTNVZCZ-WAYWQWQTSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          517.49;      // K   [origin=predictive method=joback]
Pc          34.807;      // bar [origin=predictive method=joback]
omega       0.2269;      // -   [origin=predictive method=lee-kesler]
Tb          337.60;      // K   [origin=predictive method=joback]
HvapTb      28318.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.43 0.57374 -0.0004116 1.268e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3z)-3-methylpenta-1,3-diene" "(z)-3-methyl-1,3-pentadiene" "cis-3-methyl-1,3-pentadiene" );
gibbsFormation
{
    dHf_298   65690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=159150.0
    phase     gas;
}
