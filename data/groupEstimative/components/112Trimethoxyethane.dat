/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2-trimethoxyethane  (C5H12O3, CAS 24332-20-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112Trimethoxyethane;
formula     C5H12O3;
CAS         24332-20-5;
InChIKey    DYOZNCVZPFIXLU-UHFFFAOYSA-N;
MW          120.148;      // g/mol [origin=calculated method=formula-sum]
Tc          551.01;      // K   [origin=predictive method=joback]
Pc          32.992;      // bar [origin=predictive method=joback]
omega       0.4475;      // -   [origin=predictive method=lee-kesler]
Tb          380.82;      // K   [origin=predictive method=joback]
HvapTb      33566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.161 0.29516 8.16e-05 -1.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methoxyacetaldehyde dimethyl acetal" "ethane, 1,1,2-trimethoxy-" "methoxyacetaldehyde dimethylacetal" "methoxy acetaldehyde dimethyl acetal" "methoxy acetaldehyde dimethylacetal" );
gibbsFormation
{
    dHf_298   -548470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-326220.0
    phase     gas;
}
