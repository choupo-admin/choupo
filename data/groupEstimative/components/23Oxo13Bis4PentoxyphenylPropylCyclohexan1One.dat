/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[3-oxo-1,3-bis(4-pentoxyphenyl)propyl]cyclohexan-1-one  (C31H42O4, CAS 71205-34-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Oxo13Bis4PentoxyphenylPropylCyclohexan1One;
formula     C31H42O4;
CAS         71205-34-0;
InChIKey    UWKVEVMUNSLHHZ-UHFFFAOYSA-N;
MW          478.673;      // g/mol [origin=calculated method=formula-sum]
Tc          1417.61;      // K   [origin=predictive method=joback]
Pc          9.267;      // bar [origin=predictive method=joback]
omega       0.8983;      // -   [origin=predictive method=lee-kesler]
Tb          1157.84;      // K   [origin=predictive method=joback]
HvapTb      106330.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.001 2.47734 -0.00119042 1.3636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group CH2CO; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } { group CdO; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[3-oxidanylidene-1,3-bis(4-pentoxyphenyl)propyl]cyclohexan-1-one" "2-{3-oxo-1,3-bis[4-(pentyloxy)phenyl]propyl}cyclohexanone" "2-[3-oxo-1,3-bis[4-(pentyloxy)phenyl]propyl]cyclohexanone" "cyclohexanone, 2-(3-oxo-1,3-bis(4-(pentyloxy)phenyl)propyl)-" "cyclohexanone, 2-[3-oxo-1,3-bis[4-(pentyloxy)phenyl]propyl]-" "1,3-bis(4-(pentyloxy)phenyl)-3-(2-oxocyclohexyl)-1-propanone" );
standardThermochemistry
{
    dHf_298   -698730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1068.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23800.0
}
