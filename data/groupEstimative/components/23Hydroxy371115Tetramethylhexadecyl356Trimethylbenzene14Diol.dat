/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-hydroxy-3,7,11,15-tetramethylhexadecyl)-3,5,6-trimethylbenzene-1,4-diol  (C29H52O3, CAS 14721-75-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Hydroxy371115Tetramethylhexadecyl356Trimethylbenzene14Diol;
formula     C29H52O3;
CAS         14721-75-6;
InChIKey    JOURHZSBLWSODQ-UHFFFAOYSA-N;
MW          448.732;      // g/mol [origin=calculated method=formula-sum]
Tc          1430.56;      // K   [origin=predictive method=joback]
Pc          9.278;      // bar [origin=predictive method=joback]
omega       0.7652;      // -   [origin=predictive method=lee-kesler]
Tb          1153.61;      // K   [origin=predictive method=joback]
HvapTb      124657.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.549 2.98826 -0.0021084 6.311e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 10; } { group CH; count 3; } { group C; count 1; } { group ACCH3; count 3; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 11; } { group CH; count 3; } { group C; count 1; } { group dC_ring; count 6; } { group OH; count 1; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,5-trimethyl-6-(3,7,11,15-tetramethyl-3-oxidanyl-hexadecyl)benzene-1,4-diol" "alpha-tocopherol quinol" "1,4-benzenediol, 2-((3r,7r,11r)-3-hydroxy-3,7,11,15-tetramethylhexadecyl)-3,5,6-trimethyl-" "1,4-benzenediol, 2-[(3r,7r,11r)-3-hydroxy-3,7,11,15-tetramethylhexadecyl]-3,5,6-trimethyl-" "1,4-benzenediol, 2-(3-hydroxy-3,7,11,15-tetramethylhexadecyl)-3,5,6-trimethyl-" "2-(3-hydroxy-3,7,11,15-tetramethylhexadecyl)-3,5,6-trimethyl-1,4-benzenediol (3r-(3r*,7r*,11r*))-" );
gibbsFormation
{
    dHf_298   -971210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1197.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-173720.0
    phase     gas;
}
