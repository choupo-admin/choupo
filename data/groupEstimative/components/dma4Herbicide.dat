/*--------------------------------*- Choupo -*-----------------------*\
  Component: dma-4 herbicide  (C10H13Cl2NO3, CAS 2008-39-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dma4Herbicide;
formula     C10H13Cl2NO3;
CAS         2008-39-1;
InChIKey    IUQJDHJVPLLKFL-UHFFFAOYSA-N;
MW          266.118;      // g/mol [origin=calculated method=formula-sum]
Tc          989.13;      // K   [origin=predictive method=joback]
Pc          26.191;      // bar [origin=predictive method=joback]
omega       1.0538;      // -   [origin=predictive method=lee-kesler]
Tb          759.40;      // K   [origin=predictive method=joback]
HvapTb      76528.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (83.981 0.62714 -5.352e-05 -1.32e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CH2O; count 1; } { group CH3NH; count 1; } { group COOH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group O; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4-bis(chloranyl)phenoxy]ethanoic acid;n-methylmethanamine" "spraygraze" "amicide" "herbitex" "morselect" "phordene" "aminol" "amisol" "demise" "hormin" "spritz-hormin" "dikamin d" );
gibbsFormation
{
    dHf_298   -608260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     706.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-361670.0
    phase     gas;
}
