/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-aminoethyl)pyridine  (C7H10N2, CAS 2706-56-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22AminoethylPyridine;
formula     C7H10N2;
CAS         2706-56-1;
InChIKey    XPQIPUZPSLAZDV-UHFFFAOYSA-N;
MW          122.171;      // g/mol [origin=calculated method=formula-sum]
Tc          749.82;      // K   [origin=predictive method=joback]
Pc          44.385;      // bar [origin=predictive method=joback]
omega       0.5137;      // -   [origin=predictive method=lee-kesler]
Tb          512.67;      // K   [origin=predictive method=joback]
HvapTb      50303.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.828 0.68556 -0.00044086 1.104e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2NH2; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group NH2; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pyridin-2-ylethanamine" "2-pyridineethanamine" "2-pyridylethylamine" "2-(2-pyridyl)ethylamine" "2-(pyridin-2-yl)ethanamine" "demethylbetahistine" "alpha-pyridylethylamine" "2-(pyridin-2-yl)ethan-1-amine" "pyridine, 2-(2-aminoethyl)-" ".alpha.-pyridylethylamine" "2-(2-pyridyl)ethanamine" "2-aminoethylpyridine" );
standardThermochemistry
{
    dHf_298   115300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=263970.0
}
