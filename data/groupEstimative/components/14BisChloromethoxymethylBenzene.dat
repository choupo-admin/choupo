/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-bis(chloromethoxymethyl)benzene  (C10H12Cl2O2, CAS 56894-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BisChloromethoxymethylBenzene;
formula     C10H12Cl2O2;
CAS         56894-91-8;
InChIKey    BXIVHTWXKYBJEM-UHFFFAOYSA-N;
MW          235.104;      // g/mol [origin=calculated method=formula-sum]
Tc          791.82;      // K   [origin=predictive method=joback]
Pc          25.767;      // bar [origin=predictive method=joback]
omega       0.6630;      // -   [origin=predictive method=lee-kesler]
Tb          579.76;      // K   [origin=predictive method=joback]
HvapTb      54382.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.974 0.7026 -0.00030316 1.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 2; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(chloromethyloxymethyl)benzene" "bis-1,4-(chloromethoxy)-p-xylene" "benzene, 1,4-bis(chloromethoxymethyl)-" "1,4-bis{[(chloromethyl)oxy]methyl}benzene" "1,4-bis(chloromethoxy)-p-xylene" "1,4-bis[(chloromethoxy)methyl]benzene" );
gibbsFormation
{
    dHf_298   -320590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-97760.0
    phase     gas;
}
