/*--------------------------------*- Choupo -*-----------------------*\
  Component: dl-mevalonic acid lactone  (C6H10O3, CAS 674-26-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dlMevalonicAcidLactone;
formula     C6H10O3;
CAS         674-26-0;
InChIKey    JYVXNLLUYHCIIH-UHFFFAOYSA-N;
MW          130.143;      // g/mol [origin=calculated method=formula-sum]
Tc          692.92;      // K   [origin=predictive method=joback]
Pc          44.623;      // bar [origin=predictive method=joback]
omega       0.8200;      // -   [origin=predictive method=lee-kesler]
Tb          498.53;      // K   [origin=predictive method=joback]
HvapTb      51970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.22 0.98622 -0.0009448 3.803e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-4-oxidanyl-oxan-2-one" "dl-mevalonolactone" "mevalonolactone" "dl-mevalolactone" "mevalonic lactone" "(+/-)-mevalonolactone" "4-hydroxy-4-methyloxan-2-one" "2h-pyran-2-one, tetrahydro-4-hydroxy-4-methyl-" "4-hydroxy-4-methyltetrahydro-2h-pyran-2-on" "4-hydroxy-4-methyltetrahydro-2h-pyran-2-one" "divalonic acid" "2h-pyran-2-one, tetrahydro-4-hydroxy-4-methyl-, (.+/-.)-" );
standardThermochemistry
{
    dHf_298   -554800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-404390.0
}
