/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r,2s)-(-)-trans-2-(1-methyl-1-phenylethyl)cyclohexanol  (C15H22O, CAS 109527-43-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2sTrans21Methyl1PhenylethylCyclohexanol;
formula     C15H22O;
CAS         109527-43-7;
InChIKey    CTYOSJAXQPHWCK-ZIAGYGMSSA-N;
MW          218.34;      // g/mol [origin=calculated method=formula-sum]
Tc          894.89;      // K   [origin=predictive method=joback]
Pc          23.935;      // bar [origin=predictive method=joback]
omega       0.8205;      // -   [origin=predictive method=lee-kesler]
Tb          673.31;      // K   [origin=predictive method=joback]
HvapTb      66763.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.5 1.60534 -0.0010512 2.559e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2s)-2-(2-phenylpropan-2-yl)cyclohexan-1-ol" );
gibbsFormation
{
    dHf_298   -243400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70590.0
    phase     gas;
}
