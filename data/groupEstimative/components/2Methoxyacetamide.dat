/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxyacetamide  (C3H7NO2, CAS 16332-06-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxyacetamide;
formula     C3H7NO2;
CAS         16332-06-2;
InChIKey    MTEZLAATISORQK-UHFFFAOYSA-N;
MW          89.094;      // g/mol [origin=calculated method=formula-sum]
Tc          613.68;      // K   [origin=predictive method=joback]
Pc          50.802;      // bar [origin=predictive method=joback]
omega       0.5361;      // -   [origin=predictive method=lee-kesler]
Tb          417.06;      // K   [origin=predictive method=joback]
HvapTb      42069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.511 0.25952 -5.31e-05 -2.834e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3O; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group O; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxyethanamide" "acetamide, 2-methoxy-" "2-methoxy-acetamide" );
standardThermochemistry
{
    dHf_298   -316260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-193090.0
}
