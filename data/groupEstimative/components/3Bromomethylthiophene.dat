/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromomethylthiophene  (C5H5BrS, CAS 34846-44-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromomethylthiophene;
formula     C5H5BrS;
CAS         34846-44-1;
InChIKey    KBWHYRUAHXHHFO-UHFFFAOYSA-N;
MW          177.059;      // g/mol [origin=calculated method=formula-sum]
Tc          695.16;      // K   [origin=predictive method=joback]
Pc          53.670;      // bar [origin=predictive method=joback]
omega       0.3510;      // -   [origin=predictive method=lee-kesler]
Tb          451.24;      // K   [origin=predictive method=joback]
HvapTb      40783.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.209 0.51811 -0.00042862 1.424e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group Br; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group Br; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(bromomethyl)thiophene" "3-bromomethyl-thiophene" "3-thienylmethyl bromide" "3-(bromomethyl)-thiophene" "u739" "3-(bromomethyl)thiophene;3-thenyl bromide;3-thienylmethyl bromide;" );
standardThermochemistry
{
    dHf_298   109970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=139950.0
}
