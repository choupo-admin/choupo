/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetracyclo[5.3.0.02,6.03,10]deca-4,8-diene  (C10H10, CAS 34324-40-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetracyclo5300260310Deca48Diene;
formula     C10H10;
CAS         34324-40-8;
InChIKey    JWORPRNWDWIHCA-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          645.58;      // K   [origin=predictive method=joback]
Pc          34.521;      // bar [origin=predictive method=joback]
omega       0.3571;      // -   [origin=predictive method=lee-kesler]
Tb          435.80;      // K   [origin=predictive method=joback]
HvapTb      37128.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-169.49 1.4116 -0.00135756 5.168e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 6; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 6; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetracyclo[4.2.1.1(2,5).0(9,10)]deca-3,7-diene" "tetracyclo(5.3.0.02,6.03,10)deca-4,8-diene" "tetracyclo[5.3.0.0<2,6>.0<3,10>]deca-4,8-diene" );
standardThermochemistry
{
    dHf_298   128670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     -14.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=345020.0
}
