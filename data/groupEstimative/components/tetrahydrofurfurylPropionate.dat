/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydrofurfuryl propionate  (C8H14O3, CAS 637-65-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydrofurfurylPropionate;
formula     C8H14O3;
CAS         637-65-0;
InChIKey    FMKCDSXOYLTWBR-UHFFFAOYSA-N;
MW          158.197;      // g/mol [origin=calculated method=formula-sum]
Tc          682.74;      // K   [origin=predictive method=joback]
Pc          30.524;      // bar [origin=predictive method=joback]
omega       0.5369;      // -   [origin=predictive method=lee-kesler]
Tb          483.09;      // K   [origin=predictive method=joback]
HvapTb      45576.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.138 0.83772 -0.0004303 5.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2COO; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxolan-2-ylmethyl propanoate" "2-furanmethanol, tetrahydro-, propanoate" "(tetrahydrofuran-2-yl)methyl propionate" "dl-tetrahydrofurfuryl propionate" "(+/-)-tetrahydrofurfuryl propionate" "n-butyric acid tetrahydrofurfuryl ester" "n-propionic acid tetrahydrofurfuryl ester" "2-furanmethanol, tetrahydro-, 2-propanoate" "tetrahydrofurfuryl propanoate" "2-tetrahydrofurylmethyl propionate" "tetrahydro-2-furanmethyl propanoate" "propanoic acid 2-oxolanylmethyl ester" );
standardThermochemistry
{
    dHf_298   -597250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-343460.0
}
