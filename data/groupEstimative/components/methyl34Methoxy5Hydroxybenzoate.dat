/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3,4-methoxy-5-hydroxybenzoate  (C10H12O5, CAS 83011-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl34Methoxy5Hydroxybenzoate;
formula     C10H12O5;
CAS         83011-43-2;
InChIKey    LCIFXEQPXQVBGL-UHFFFAOYSA-N;
MW          212.201;      // g/mol [origin=calculated method=formula-sum]
Tc          866.42;      // K   [origin=predictive method=joback]
Pc          32.393;      // bar [origin=predictive method=joback]
omega       0.9579;      // -   [origin=predictive method=lee-kesler]
Tb          648.72;      // K   [origin=predictive method=joback]
HvapTb      66695.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.98 0.72936 -0.00035708 4.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group CH3O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3,4-dimethoxy-5-oxidanyl-benzoate" "methyl 3-hydroxy-4,5-dimethoxybenzoate" "methyl 4,5-dimethoxy-3-hydroxybenzoate" "3,4-dimethoxy-5-hydroxybenzoic acid methyl ester" "methyl 3,4-dimethoxy-5-hydroxybenzoate" "methyl 5-hydroxy-3,4-dimethoxybenzoate" "methyl 3,4-dimehtoxy-5-hydroxybenzoate" "i259" );
standardThermochemistry
{
    dHf_298   -795170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-548520.0
}
