/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-dimethylamino-1-phenylethane  (C10H15N, CAS 2449-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Dimethylamino1Phenylethane;
formula     C10H15N;
CAS         2449-49-2;
InChIKey    BVURNMLGDQYNAF-UHFFFAOYSA-N;
MW          149.237;      // g/mol [origin=calculated method=formula-sum]
Tc          673.82;      // K   [origin=predictive method=joback]
Pc          29.505;      // bar [origin=predictive method=joback]
omega       0.4155;      // -   [origin=predictive method=lee-kesler]
Tb          467.08;      // K   [origin=predictive method=joback]
HvapTb      41785.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.48 1.00476 -0.0006672 1.702e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-1-phenyl-ethanamine" "n,n-dimethyl-1-phenylethylamine" "alpha-methylbenzyldimethylamine" "n,n,alpha-trimethylbenzylamine" "(alpha-methylbenzyl)dimethylamine" "benzylamine, n,n,alpha-trimethyl-" "(.alpha.-methylbenzyl)dimethylamine" "n,n-dimethyl-alpha-phenylethylamine" "n,n-dimethyl-alpha-methylbenzylamine" "benzenemethanamine, n,n,alpha-trimethyl-" "n,n-dimethyl-1-phenylethanamine" "(s)-(-)-alpha-methyl-n,n-dimethylbenzylamine" );
gibbsFormation
{
    dHf_298   49050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=254070.0
    phase     gas;
}
