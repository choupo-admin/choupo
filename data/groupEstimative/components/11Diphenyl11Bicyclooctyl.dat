/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-diphenyl-1,1'-bicyclooctyl  (C28H38, CAS 59358-73-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diphenyl11Bicyclooctyl;
formula     C28H38;
CAS         59358-73-5;
InChIKey    SKPRQLZOAQUBAG-UHFFFAOYSA-N;
MW          374.612;      // g/mol [origin=calculated method=formula-sum]
Tc          1239.17;      // K   [origin=predictive method=joback]
Pc          14.305;      // bar [origin=predictive method=joback]
omega       0.6500;      // -   [origin=predictive method=lee-kesler]
Tb          950.26;      // K   [origin=predictive method=joback]
HvapTb      81718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-342.05 3.2956 -0.0026034 8.686e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 14; } { group C; count 2; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 14; } { group C_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl-1-(1-phenylcyclooctyl)cyclooctane" );
gibbsFormation
{
    dHf_298   -33710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1191.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=399220.0
    phase     gas;
}
