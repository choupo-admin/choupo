/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dichloro-2-methylpropane  (C4H8Cl2, CAS 594-37-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dichloro2Methylpropane;
formula     C4H8Cl2;
CAS         594-37-6;
InChIKey    OQPNDCHKFIHPBY-UHFFFAOYSA-N;
MW          127.008;      // g/mol [origin=calculated method=formula-sum]
Tc          557.57;      // K   [origin=predictive method=joback]
Pc          36.421;      // bar [origin=predictive method=joback]
omega       0.2322;      // -   [origin=predictive method=lee-kesler]
Tb          362.75;      // K   [origin=predictive method=joback]
HvapTb      31972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.561 0.52324 -0.0004064 1.263e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)-2-methyl-propane" "1,2-dichloroisobutane" "dichloroisobutane" "dichloro-2-methylpropane" "propane, dichloro-2-methyl-" "propane,2-dichloro-2-methyl-" "propane,1,2-dichloro-2-methyl-" );
gibbsFormation
{
    dHf_298   -166120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     339.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-38220.0
    phase     gas;
}
