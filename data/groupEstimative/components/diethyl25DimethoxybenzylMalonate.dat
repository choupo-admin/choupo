/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl(2,5-dimethoxybenzyl)malonate  (C16H22O6, CAS 20452-51-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl25DimethoxybenzylMalonate;
formula     C16H22O6;
CAS         20452-51-1;
InChIKey    HJUFGOPKAMIEDJ-UHFFFAOYSA-N;
MW          310.346;      // g/mol [origin=calculated method=formula-sum]
Tc          962.90;      // K   [origin=predictive method=joback]
Pc          16.404;      // bar [origin=predictive method=joback]
omega       1.0457;      // -   [origin=predictive method=lee-kesler]
Tb          763.16;      // K   [origin=predictive method=joback]
HvapTb      74056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (83.173 1.09588 -0.00033572 -6.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-[(2,5-dimethoxyphenyl)methyl]propanedioate" "propanedioic acid, ((2,5-dimethoxyphenyl)methyl)-, diethyl ester" "propanedioic acid, [(2,5-dimethoxyphenyl)methyl]-, diethyl ester" "propanedioic acid, 2-((2,5-dimethoxyphenyl)methyl)-, 1,3-diethyl ester" "propanedioic acid, 2-[(2,5-dimethoxyphenyl)methyl]-, 1,3-diethyl ester" "diethyl (2,5-dimethoxybenzyl)malonate" );
standardThermochemistry
{
    dHf_298   -1064260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     776.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-656190.0
}
