/*--------------------------------*- Choupo -*-----------------------*\
  Component: pinol  (C10H16O, CAS 2437-97-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pinol;
formula     C10H16O;
CAS         2437-97-0;
InChIKey    SKBXVAOMEVOTGJ-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          693.72;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.3769;      // -   [origin=predictive method=lee-kesler]
Tb          477.08;      // K   [origin=predictive method=joback]
HvapTb      42028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.58 1.38336 -0.00125134 4.87e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7,7-trimethyl-6-oxabicyclo[3.2.1]oct-3-ene" "6,8-epoxymenth-1-ene (pinol)" "6-oxabicyclo[3.2.1]oct-3-ene, 4,7,7-trimethyl-" "4,7,7-trimethyl-6-oxabicyclo(3.2.1)oct-3-ene" "6-oxabicyclo(3.2.1)oct-3-ene, 4,7,7-trimethyl-" "agn-pc-00dkix" "p-menth-1-ene,8-epoxy-" "p-menth-1-ene, 6,8-epoxy- (8ci)" "6-oxabicyclo[3.2.1]oct-3-ene,7,7-trimethyl-" "dl-4,7,7-trimethyl-6-oxabicyclo(3.2.1)oct-3-ene" );
standardThermochemistry
{
    dHf_298   -207240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     337.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=51630.0
}
