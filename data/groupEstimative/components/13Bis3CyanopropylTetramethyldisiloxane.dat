name        13Bis3CyanopropylTetramethyldisiloxane;
formula     C12H24N2OSi2;
CAS         18027-80-0;
InChIKey    WDWQNNPLLMFDRG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          268.507;      // g/mol [origin=calculated method=formula-sum]
Tc          904.16;      // K   [origin=predictive method=joback]
Pc          13.954;      // bar [origin=predictive method=joback]
omega       0.7509;      // -   [origin=predictive method=lee-kesler]
Tb          703.54;      // K   [origin=predictive method=joback]
HvapTb      66260.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (133.116 0.53788 0.0003736 -3.702e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH2CN; count 2; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group O; count 1; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[3-cyanopropyl(dimethyl)silyl]oxy-dimethyl-silyl]butanenitrile" "wdwqnnpllmfdrg-uhfffaoysa-" "butanenitrile, 4,4'-(1,1,3,3-tetramethyl-1,3-disiloxanediyl)bis-" "4-[(3-cyanopropyl-dimethylsilyl)oxy-dimethylsilyl]butanenitrile" "4-[[3-cyanopropyl(dimethyl)silyl]oxy-dimethylsilyl]butanenitrile" "butanenitrile,4,4'-(1,1,3,3-tetramethyl-1,3-disiloxanediyl)bis-" "6-oxa-5,7-disilaundecanedinitrile,5,5,7,7-tetramethyl- (6ci,7ci);butyronitrile, 4,4'-(1,1,3,3-tetramethyldisiloxanylene)di-(8ci);1,3-bis(3-cyanopropyl)-1,1,3,3-tetramethyldisiloxane;" );
standardThermochemistry
{
    dHf_298   -316710.0;      // J/mol ideal-gas [origin=predictive method=joback]
