/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropate  (C20H38O2, CAS 54460-46-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropate;
formula     C20H38O2;
CAS         54460-46-7;
InChIKey    NSCKKHGFMYTPBG-UHFFFAOYSA-N;
MW          310.522;      // g/mol [origin=calculated method=formula-sum]
Tc          896.13;      // K   [origin=predictive method=joback]
Pc          11.089;      // bar [origin=predictive method=joback]
omega       0.9087;      // -   [origin=predictive method=lee-kesler]
Tb          722.16;      // K   [origin=predictive method=joback]
HvapTb      67434.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.125 1.99992 -0.0011898 2.69e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecyl cyclopropanecarboxylate" "cycloprate" "zardex" "cyclopropanecarboxylic acid, hexadecyl ester" "cyclopropanecarboxylicacid, hexadecyl ester" "cycloprate;hexadecyl cyclopropanecarboxylate; zr 856; zardex" );
standardThermochemistry
{
    dHf_298   -700610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     896.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-132100.0
}
