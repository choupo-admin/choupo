/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-isopropoxy-1-propanol  (C6H14O2, CAS 110-48-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Isopropoxy1Propanol;
formula     C6H14O2;
CAS         110-48-5;
InChIKey    GBSGXZBOFKJGMG-UHFFFAOYSA-N;
MW          118.176;      // g/mol [origin=calculated method=formula-sum]
Tc          615.73;      // K   [origin=predictive method=joback]
Pc          34.159;      // bar [origin=predictive method=joback]
omega       0.8143;      // -   [origin=predictive method=lee-kesler]
Tb          451.04;      // K   [origin=predictive method=joback]
HvapTb      47651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.543 0.55054 -0.0002252 1.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-propan-2-yloxypropan-1-ol" "dowanol pip" "propylene glycol isopropyl ether" "1-propanol, 3-isopropoxy-" "propylene glycol monoisopropyl ether" "1-propanol, 3-(1-methylethoxy)-" "3-isopropoxypropan-1-ol" "3-(methylethoxy)propan-1-ol" "3-(propan-2-yloxy)propan-1-ol" "1-propanol, 3-(1-methylethoxy)- (9ci)" );
standardThermochemistry
{
    dHf_298   -456900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-244620.0
}
