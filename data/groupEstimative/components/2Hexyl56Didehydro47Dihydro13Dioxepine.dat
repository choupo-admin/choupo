/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexyl-5,6-didehydro-4,7-dihydro-1,3-dioxepine  (C11H18O2, CAS 68797-69-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexyl56Didehydro47Dihydro13Dioxepine;
formula     C11H18O2;
CAS         68797-69-3;
InChIKey    OTEIBXNTZPRYOA-UHFFFAOYSA-N;
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          739.86;      // K   [origin=predictive method=joback]
Pc          26.245;      // bar [origin=predictive method=joback]
omega       0.5307;      // -   [origin=predictive method=lee-kesler]
Tb          529.46;      // K   [origin=predictive method=joback]
HvapTb      51509.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.395 1.02472 -0.00058206 1.2078e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group FCH2O; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group tC; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexyl-1,3-dioxacyclohept-5-yne" "1,3-dioxepin, 5,6-didehydro-2-hexyl-4,7-dihydro-" "heptanal, butyne-1,4-acetal" "5,6-didehydro-2-hexyl-4,7-dihydro-1,3-dioxepin" );
standardThermochemistry
{
    dHf_298   -201590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108850.0
}
