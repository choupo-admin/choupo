/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl benzene-1,4-dicarboxylate;2,2-dimethylhexanedioic acid;ethane-1,2-diol  (C20H30O10, CAS 42342-18-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylBenzene14Dicarboxylate22DimethylhexanedioicAcidEthan;
formula     C20H30O10;
CAS         42342-18-7;
InChIKey    VGWQTCARXYLDOB-UHFFFAOYSA-N;
MW          430.45;      // g/mol [origin=calculated method=formula-sum]
Tc          1605.41;      // K   [origin=predictive method=joback]
Pc          14.714;      // bar [origin=predictive method=joback]
omega       1.0271;      // -   [origin=predictive method=lee-kesler]
Tb          1280.25;      // K   [origin=predictive method=joback]
HvapTb      144844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (92.865 1.53888 -0.00038736 -1.737e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 2; } { group _CH2OH_2; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl benzene-1,4-dicarboxylate; 2,2-dimethylhexanedioic acid; ethane-1,2-diol" "1,4-benzenedicarboxylic acid, 1,4-dimethyl ester, polymer with 1,6-dimethyl hexanedioate and 1,2-ethanediol" "1,4-benzenedicarboxylic acid, dimethyl ester, polymer with dimethyl hexanedioate and 1,2-ethanediol" );
gibbsFormation
{
    dHf_298   -2102620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1309.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1568580.0
    phase     gas;
}
