/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutyl trifluoroacetate  (C6H9F3O2, CAS 17355-83-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutylTrifluoroacetate;
formula     C6H9F3O2;
CAS         17355-83-8;
InChIKey    JNDIDDMPBOLGER-UHFFFAOYSA-N;
MW          170.13;      // g/mol [origin=calculated method=formula-sum]
Tc          550.31;      // K   [origin=predictive method=joback]
Pc          27.789;      // bar [origin=predictive method=joback]
omega       0.4923;      // -   [origin=predictive method=lee-kesler]
Tb          389.24;      // K   [origin=predictive method=joback]
HvapTb      32222.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.961 0.68614 -0.0004322 9.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group F; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropyl 2,2,2-tris(fluoranyl)ethanoate" "trifluoroacetic acid, 2-methylpropyl ester" "2-methylpropyl 2,2,2-trifluoroacetate" "acetic acid, trifluoro-, 2-methylpropyl ester" );
standardThermochemistry
{
    dHf_298   -1086810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-894760.0
}
