MW          274.507;      // g/mol [origin=calculated method=formula-sum]
Tc          736.28;      // K   [origin=predictive method=joback]
Pc          15.082;      // bar [origin=predictive method=joback]
omega       0.5489;      // -   [origin=predictive method=lee-kesler]
