/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,3-dihydroxypropoxy)-1-oxopropan-2-yl hexadecanoate  (C22H42O6, CAS 1335-49-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Dihydroxypropoxy1Oxopropan2YlHexadecanoate;
formula     C22H42O6;
CAS         1335-49-5;
InChIKey    DCOCIAQCXDPXPG-UHFFFAOYSA-N;
MW          402.572;      // g/mol [origin=calculated method=formula-sum]
Tc          1251.87;      // K   [origin=predictive method=joback]
Pc          10.273;      // bar [origin=predictive method=joback]
omega       0.7851;      // -   [origin=predictive method=lee-kesler]
Tb          1002.88;      // K   [origin=predictive method=joback]
HvapTb      111962.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.926 2.06404 -0.001051 1.55e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 2; } { group OH; count 2; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group CH; count 2; } { group OH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[1-[2,3-bis(oxidanyl)propoxy]-1-oxidanylidene-propan-2-yl] hexadecanoate" "hexadecanoic acid, 1-carboxyethyl ester, monoester with 1,2,3-propanetriol" "2-(hexadecanoyloxy)propionic acid, monoester with glycerol" "[1-(2,3-dihydroxypropoxy)-1-oxopropan-2-yl] hexadecanoate" );
gibbsFormation
{
    dHf_298   -1446990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1198.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-764900.0
    phase     gas;
}
