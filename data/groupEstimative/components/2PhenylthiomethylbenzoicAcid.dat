/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenylthiomethylbenzoic acid  (C14H12O2S, CAS 1699-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PhenylthiomethylbenzoicAcid;
formula     C14H12O2S;
CAS         1699-03-2;
InChIKey    QXPRAGVOCILNHG-UHFFFAOYSA-N;
MW          244.308;      // g/mol [origin=calculated method=formula-sum]
Tc          1054.87;      // K   [origin=predictive method=joback]
Pc          30.558;      // bar [origin=predictive method=joback]
omega       0.9531;      // -   [origin=predictive method=lee-kesler]
Tb          792.55;      // K   [origin=predictive method=joback]
HvapTb      75953.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.149 1.16169 -0.00076556 1.819e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(phenylsulfanylmethyl)benzoic acid" "benzoic acid, 2-[(phenylthio)methyl]-" "2-(phenylthiomethyl)benzoic acid" "2-phenylmercaptomethylbenzoic acid" "2-((phenylthio)methyl)benzoic acid" "2-[(phenylsulfanyl)methyl]benzoic acid" "2-[(phenylsulfanyl)methyl]benzenecarboxylic acid" );
gibbsFormation
{
    dHf_298   -179100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28600.0
    phase     gas;
}
