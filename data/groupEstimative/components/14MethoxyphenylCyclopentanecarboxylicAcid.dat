/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-methoxyphenyl)cyclopentanecarboxylic acid  (C13H16O3, CAS 43050-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14MethoxyphenylCyclopentanecarboxylicAcid;
formula     C13H16O3;
CAS         43050-28-8;
InChIKey    OMMROWIAJMZSLF-UHFFFAOYSA-N;
MW          220.268;      // g/mol [origin=calculated method=formula-sum]
Tc          955.17;      // K   [origin=predictive method=joback]
Pc          29.124;      // bar [origin=predictive method=joback]
omega       0.8620;      // -   [origin=predictive method=lee-kesler]
Tb          712.15;      // K   [origin=predictive method=joback]
HvapTb      66150.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.91 1.51162 -0.00126916 4.548e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methoxyphenyl)cyclopentane-1-carboxylic acid" "1-(4-methoxyphenyl)-1-cyclopentanecarboxylic acid" "cyclopentanecarboxylic acid, 1-(4-methoxyphenyl)-" "cyclopentanecarboxylicacid, 1-(4-methoxyphenyl)-" );
gibbsFormation
{
    dHf_298   -493360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-256490.0
    phase     gas;
}
