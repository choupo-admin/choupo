/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-3-ethyl-3-pentene  (C8H16, CAS 19780-68-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl3Ethyl3Pentene;
formula     C8H16;
CAS         19780-68-8;
InChIKey    DSTFDBMUTNIZGD-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          565.75;      // K   [origin=predictive method=joback]
Pc          27.099;      // bar [origin=predictive method=joback]
omega       0.3120;      // -   [origin=predictive method=lee-kesler]
Tb          386.24;      // K   [origin=predictive method=joback]
HvapTb      33052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.939 0.78968 -0.0005007 1.327e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-4-methyl-pent-2-ene" "2-pentene,3-ethyl-4-methyl-" );
standardThermochemistry
{
    dHf_298   -106300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85710.0
}
