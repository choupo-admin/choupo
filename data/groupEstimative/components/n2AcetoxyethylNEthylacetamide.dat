/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-acetoxyethyl)-n-ethylacetamide  (C8H15NO3, CAS 15568-57-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2AcetoxyethylNEthylacetamide;
formula     C8H15NO3;
CAS         15568-57-7;
InChIKey    GIBNFOXKSVQBOP-UHFFFAOYSA-N;
MW          173.212;      // g/mol [origin=calculated method=formula-sum]
Tc          687.10;      // K   [origin=predictive method=joback]
Pc          27.127;      // bar [origin=predictive method=joback]
omega       0.7465;      // -   [origin=predictive method=lee-kesler]
Tb          507.17;      // K   [origin=predictive method=joback]
HvapTb      49598.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.693 0.80496 -0.0004107 5.526e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH3COO; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CdO; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[ethanoyl(ethyl)amino]ethyl ethanoate" "acetamide, n-(2-acetoxyethyl)-n-ethyl-" "acetamide, n-(2-(acetyloxy)ethyl)-n-ethyl-" "acetamide, n-[2-(acetyloxy)ethyl]-n-ethyl-" "acetic acid, [2-(n-ethylacetamido)ethyl] ester" "acetamide, acetate (ester)" "n(2-acetoxyethyl)-n-ethylacetamide" "2-[acetyl(ethyl)amino]ethyl acetate" "n-[(2-acetoxyethyl)-n-ethyl]acetamide" "acetamide, n-[(2-acetoxyethyl)-n-ethyl]-" "acetamide, n-ethyl-n-(2-hydroxyethyl)-, acetate (ester)" "acetamide, n-ethyl-n-(2-hydroxyethyl)-, acetate (ester) (8ci)" );
standardThermochemistry
{
    dHf_298   -570780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-312030.0
}
