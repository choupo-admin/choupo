/*--------------------------------*- Choupo -*-----------------------*\
  Component: prop-2-enylsilane  (C3H8Si, CAS 18191-59-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C3H8Si (delta H+3Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        prop2Enylsilane;
formula     C3H8Si;
CAS         18191-59-8;
InChIKey    DNAJDTIOMGISDS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          72.182;      // g/mol [origin=calculated method=formula-sum]
Tc          423.61;      // K   [origin=predictive method=joback]
Pc          41.731;      // bar [origin=predictive method=joback]
omega       0.1392;      // -   [origin=predictive method=lee-kesler]
Tb          264.22;      // K   [origin=predictive method=joback]
HvapTb      21455.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.239 0.3719 -0.0003697 1.505e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group SiH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   75990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114600.0
}
