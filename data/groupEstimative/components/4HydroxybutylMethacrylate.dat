/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxybutyl methacrylate  (C8H14O3, CAS 997-46-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HydroxybutylMethacrylate;
formula     C8H14O3;
CAS         997-46-6;
InChIKey    YKXAYLPDMSGWEV-UHFFFAOYSA-N;
MW          158.197;      // g/mol [origin=calculated method=formula-sum]
Tc          700.99;      // K   [origin=predictive method=joback]
Pc          29.473;      // bar [origin=predictive method=joback]
omega       0.9797;      // -   [origin=predictive method=lee-kesler]
Tb          529.60;      // K   [origin=predictive method=joback]
HvapTb      56898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.634 0.72292 -0.0003724 5.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2=C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylbutyl 2-methylprop-2-enoate" "4-hydroxybutyl 2-methylprop-2-enoate" );
standardThermochemistry
{
    dHf_298   -562320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-351420.0
}
