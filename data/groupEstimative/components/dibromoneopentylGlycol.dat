/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibromoneopentyl glycol  (C5H10Br2O2, CAS 3296-90-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibromoneopentylGlycol;
formula     C5H10Br2O2;
CAS         3296-90-0;
InChIKey    CHUGKEQJSLOLHL-UHFFFAOYSA-N;
MW          261.941;      // g/mol [origin=calculated method=formula-sum]
Tc          819.12;      // K   [origin=predictive method=joback]
Pc          54.305;      // bar [origin=predictive method=joback]
omega       1.5029;      // -   [origin=predictive method=lee-kesler]
Tb          627.45;      // K   [origin=predictive method=joback]
HvapTb      71656.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.834 0.749 -0.0006236 2.08e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group OH; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group C; count 1; } { group Br; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(bromomethyl)propane-1,3-diol" "2,2-bis(bromomethyl)-1,3-propanediol" "pentaerythritol dibromide" "dibromopentaerythritol" "1,3-propanediol, 2,2-bis(bromomethyl)-" "pentaerythritol dibromohydrin" "1,3-dibromo-2,2-dimethylolpropane" "2,2-dibromomethyl-1,3-propanediol" "2,2-bis(2-bromomethyl)-1,3-propanediol" "1,3-propanediol, 2,2-bis(2-bromomethyl)-" "2,2-bis(bromomethyl)-1,3-propanediol, technical grade" "1,2-dimethylolpropane" );
standardThermochemistry
{
    dHf_298   -407080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-250940.0
}
