/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxybenzylideneacetone  (C10H10O2, CAS 3160-35-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxybenzylideneacetone;
formula     C10H10O2;
CAS         3160-35-8;
InChIKey    OCNIKEFATSKIBE-UHFFFAOYSA-N;
MW          162.188;      // g/mol [origin=calculated method=formula-sum]
Tc          830.49;      // K   [origin=predictive method=joback]
Pc          39.906;      // bar [origin=predictive method=joback]
omega       0.7235;      // -   [origin=predictive method=lee-kesler]
Tb          593.73;      // K   [origin=predictive method=joback]
HvapTb      59848.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.85 1.02152 -0.00087286 3.0476e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-hydroxyphenyl)but-3-en-2-one" "4-hydroxybenzilidene acetone" "3-buten-2-one,4-(4-hydroxyphenyl)-, (3e)-" "3-buten-2-one,4-(4-hydroxyphenyl)-, (e)-;3-buten-2-one, 4-(p-hydroxyphenyl)-, (e)- (8ci);(e)-4-(4-hydroxyphenyl)-3-buten-2-one;4-(4-hydroxyphenyl)-(3e)-buten-2-one;" );
gibbsFormation
{
    dHf_298   -185870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57590.0
    phase     gas;
}
