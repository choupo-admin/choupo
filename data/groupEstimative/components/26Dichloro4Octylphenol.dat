/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dichloro-4-octylphenol-  (C14H20Cl2O, CAS 73986-52-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dichloro4Octylphenol;
formula     C14H20Cl2O;
CAS         73986-52-4;
InChIKey    PJUWJQDQGVXGEI-UHFFFAOYSA-N;
MW          275.213;      // g/mol [origin=calculated method=formula-sum]
Tc          925.33;      // K   [origin=predictive method=joback]
Pc          20.927;      // bar [origin=predictive method=joback]
omega       0.9278;      // -   [origin=predictive method=lee-kesler]
Tb          712.04;      // K   [origin=predictive method=joback]
HvapTb      72142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.717 1.30412 -0.00093208 2.822e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis(chloranyl)-4-octyl-phenol" "2,6-dichloro-4-octylphenol" "phenol, 2,6-dichloro-4-octyl-" "phenol,6-dichloro-4-octyl-" "phenol,2,6-dichloro-4-octyl-" );
gibbsFormation
{
    dHf_298   -327490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     675.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18330.0
    phase     gas;
}
