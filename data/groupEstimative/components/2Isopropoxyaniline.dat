/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropoxyaniline  (C9H13NO, CAS 29026-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropoxyaniline;
formula     C9H13NO;
CAS         29026-74-2;
InChIKey    PZOZYLSYQJYXBI-UHFFFAOYSA-N;
MW          151.209;      // g/mol [origin=calculated method=formula-sum]
Tc          754.91;      // K   [origin=predictive method=joback]
Pc          33.881;      // bar [origin=predictive method=joback]
omega       0.5580;      // -   [origin=predictive method=lee-kesler]
Tb          531.69;      // K   [origin=predictive method=joback]
HvapTb      51229.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.41 0.72504 -0.00036556 5.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group CH-O; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-yloxyaniline" "o-ipa" "o-isopropoxyaniline" "o-izopropoksyanilina [polish]" "aniline, o-isopropoxy-" "2-(1-methylethoxy)benzenamine" "benzenamine, 2-(1-methylethoxy)-" "2-(methylethoxy)phenylamine" "2-(propan-2-yloxy)aniline" "o-izopropoksyanilina" "2-isopropoxy-phenylamine" "(2-isopropoxyphenyl)amine" );
gibbsFormation
{
    dHf_298   -107740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86690.0
    phase     gas;
}
