/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene, 1,2-dimethyl-  (C8H14, CAS 1674-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene12Dimethyl;
formula     C8H14;
CAS         1674-10-8;
InChIKey    TXNWMICHNKMOBR-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          622.69;      // K   [origin=predictive method=joback]
Pc          32.954;      // bar [origin=predictive method=joback]
omega       0.2967;      // -   [origin=predictive method=lee-kesler]
Tb          415.98;      // K   [origin=predictive method=joback]
HvapTb      35756.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.55 0.73744 -0.000401 7.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dimethylcyclohexene" "1,2-dimethyl-1-cyclohexene" "cyclohexene,2-dimethyl-" "1,2-dimethyl-cyclohexene" "1,2-dimethyl cyclohexene" "1,2-dimethyl cyclohexene, 99%" "cyclohexene, 1,2-dimethyl- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -98950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=59340.0
}
