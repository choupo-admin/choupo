/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxybenzaldehyde  (C7H6O2, CAS 100-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H6O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Hydroxybenzaldehyde;
formula     C7H6O2;
CAS         100-83-4;
InChIKey    IAVREABSGIHHMO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          122.123;      // g/mol [origin=calculated method=formula-sum]
Tc          672.84;      // K   [origin=predictive method=joback]
Pc          53.592;      // bar [origin=predictive method=joback]
omega       0.4131;      // -   [origin=predictive method=lee-kesler]
Tb          443.48;      // K   [origin=predictive method=joback]
HvapTb      44093.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.8 0.7526 -0.00079756 3.274e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanylbenzaldehyde" "m-formylphenol" "m-hydroxybenzaldehyde" "benzaldehyde, 3-hydroxy-" "3-formylphenol" "meta-hydroxybenzaldehyde" "benzaldehyde, m-hydroxy-" "3-hydroxy-benzaldehyde" "3-hydroxybenzaldehyd" "3-oh-benzaldehyde" "agn-pc-0cv47p" "meta-hydroxybenzaldehyde;benzaldehyde, 3-hydroxy-;m-formylphenol;3-formylphenol;3-hydroxybenzaldehyde;m-hydroxybenzaldehyde;m-hydroxybenzaldehyde;benzaldehyde, m-hydroxy-;" );
gibbsFormation
{
    dHf_298   -52140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9810.0
    phase     gas;
}
