/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(6-chlorohexyloxy)tetrahydro-2h-pyran  (C11H21ClO2, CAS 2009-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26ChlorohexyloxyTetrahydro2hPyran;
formula     C11H21ClO2;
CAS         2009-84-9;
InChIKey    XOLOZSPDGPUSFV-UHFFFAOYSA-N;
MW          220.737;      // g/mol [origin=calculated method=formula-sum]
Tc          755.07;      // K   [origin=predictive method=joback]
Pc          22.000;      // bar [origin=predictive method=joback]
omega       0.6363;      // -   [origin=predictive method=lee-kesler]
Tb          557.63;      // K   [origin=predictive method=joback]
HvapTb      51814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.004 1.1115 -0.0005511 7.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Cl; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(6-chloranylhexoxy)oxane" "2h-pyran, 2-[(6-chlorohexyl)oxy]tetrahydro-" "2-(6-chlorohexoxy)oxane" "agn-pc-0cri4g" "2-[(6-chlorohexyl)oxy]tetrahydro-2h-pyran" "2h-pyran,2-[(6-chlorohexyl)oxy]tetrahydro-" );
standardThermochemistry
{
    dHf_298   -496010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-136860.0
}
