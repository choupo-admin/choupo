/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl-1-propyne  (C9H8, CAS 673-32-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyl1Propyne;
formula     C9H8;
CAS         673-32-5;
InChIKey    GHUURDQYRGVEHX-UHFFFAOYSA-N;
MW          116.163;      // g/mol [origin=calculated method=formula-sum]
Tc          679.35;      // K   [origin=predictive method=joback]
Pc          39.506;      // bar [origin=predictive method=joback]
omega       0.2527;      // -   [origin=predictive method=lee-kesler]
Tb          441.20;      // K   [origin=predictive method=joback]
HvapTb      40056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.64 0.63012 -0.00040486 1.0038e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group AC; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-1-ynylbenzene" "methylphenylacetylene" "benzene, 1-propynyl-" "benzene, propynyl-" "1-phenylpropyne-1" "prop-1-ynyl-benzene" "prop-1-yn-1-ylbenzene" "1-methyl-2-phenylacetylene" "ghl.pd_mitscher_leg0.471" "propine, 1-phenyl- (3ci);1-phenyl-1-propyne;1-propynylbenzene;3-phenyl-2-propyne;methylphenylacetylene;phenylmethylacetylene;" );
gibbsFormation
{
    dHf_298   279740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     371.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=340110.0
    phase     gas;
}
