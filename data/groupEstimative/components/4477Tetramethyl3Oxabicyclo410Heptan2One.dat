/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4,7,7-tetramethyl-3-oxabicyclo[4.1.0]heptan-2-one  (C10H16O2, CAS 14087-71-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4477Tetramethyl3Oxabicyclo410Heptan2One;
formula     C10H16O2;
CAS         14087-71-9;
InChIKey    XAKBEOUVVTWXNF-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          691.28;      // K   [origin=predictive method=joback]
Pc          27.297;      // bar [origin=predictive method=joback]
omega       0.4628;      // -   [origin=predictive method=lee-kesler]
Tb          486.97;      // K   [origin=predictive method=joback]
HvapTb      41995.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-164.26 1.74128 -0.0018668 8.188e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group C; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group C_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,7,7-tetramethyl-4-oxabicyclo[4.1.0]heptan-5-one" "3-oxabicyclo[4.1.0]heptan-2-one, 4,4,7,7-tetramethyl-" "(1r)-chrysanthemolactone" "agn-pc-01lrlc" "(-)-dihydrochrysanthemolactone" "(1s)-chrysanthemolactone" "3-oxabicyclo(4.1.0)heptan-2-one, 4,4,7,7-tetramethyl-, (+-)-" "4,4,7,7-tetramethyl-3-oxabicyclo(4.1.0)heptan-2-one (1s-cis)-" "3-oxabicyclo(4.1.0)heptan-2-one, 4,4,7,7-tetramethyl-, (1s-cis)-" "3-oxabicyclo[4.1.0]heptan-2-one,4,4,7,7-tetramethyl-, (1s-cis)- (9ci)" );
standardThermochemistry
{
    dHf_298   -425450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-169850.0
}
