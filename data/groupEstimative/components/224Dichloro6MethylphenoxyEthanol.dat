/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2,4-dichloro-6-methylphenoxy)ethanol  (C9H10Cl2O2, CAS 56949-53-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224Dichloro6MethylphenoxyEthanol;
formula     C9H10Cl2O2;
CAS         56949-53-2;
InChIKey    AUUYPDQHDJQJKO-UHFFFAOYSA-N;
MW          221.077;      // g/mol [origin=calculated method=formula-sum]
Tc          841.25;      // K   [origin=predictive method=joback]
Pc          31.036;      // bar [origin=predictive method=joback]
omega       1.0257;      // -   [origin=predictive method=lee-kesler]
Tb          636.60;      // K   [origin=predictive method=joback]
HvapTb      67749.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.272 0.58582 -0.00025608 1.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCl; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4-bis(chloranyl)-6-methyl-phenoxy]ethanol" "ethanol, 2-(4,6-dichloro-o-tolyl)-" "ethanol, 2-(4,6-dichloro-o-tolyl)-," );
standardThermochemistry
{
    dHf_298   -342900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-157260.0
}
