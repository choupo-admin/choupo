/*--------------------------------*- Choupo -*-----------------------*\
  Component: octanedial  (C8H14O2, CAS 638-54-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octanedial;
formula     C8H14O2;
CAS         638-54-0;
InChIKey    OADYBSJSJUFUBR-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          656.78;      // K   [origin=predictive method=joback]
Pc          29.601;      // bar [origin=predictive method=joback]
omega       0.7224;      // -   [origin=predictive method=lee-kesler]
Tb          479.96;      // K   [origin=predictive method=joback]
HvapTb      46842.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.416 0.7128 -0.0003974 7.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CHO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group OdCH_al; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "suberaldehyde(6ci,7ci,8ci);1,8-octanedial;1,8-octanedialdehyde;suberic aldehyde;subericdialdehyde;" );
gibbsFormation
{
    dHf_298   -379610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-182560.0
    phase     gas;
}
