/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-octen-2-one, (5e)-  (C8H14O, CAS 19093-20-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Octen2One5e;
formula     C8H14O;
CAS         19093-20-0;
InChIKey    NBFKNCBRFJKDDR-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          624.72;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.4901;      // -   [origin=predictive method=lee-kesler]
Tb          440.67;      // K   [origin=predictive method=joback]
HvapTb      40106.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.207 0.75584 -0.0004765 1.2236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oct-5-en-2-one" );
standardThermochemistry
{
    dHf_298   -203810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32220.0
}
