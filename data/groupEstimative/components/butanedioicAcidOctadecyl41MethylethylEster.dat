/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanedioic acid, octadecyl-, 4-(1-methylethyl) ester  (C25H48O4, CAS 72906-44-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanedioicAcidOctadecyl41MethylethylEster;
formula     C25H48O4;
CAS         72906-44-6;
InChIKey    BHJSOOCNNVUETA-UHFFFAOYSA-N;
MW          412.655;      // g/mol [origin=calculated method=formula-sum]
Tc          1087.99;      // K   [origin=predictive method=joback]
Pc          7.716;      // bar [origin=predictive method=joback]
omega       0.7200;      // -   [origin=predictive method=lee-kesler]
Tb          887.60;      // K   [origin=predictive method=joback]
HvapTb      85670.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.299 2.27516 -0.0011502 1.716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 17; } { group CH; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 19; } { group CH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-octadecyl o4-propan-2-yl butanedioate" "butanedioic acid, 2-octadecyl-, 4-(1-methylethyl) ester" "monoisopropyl octadecylsuccinate" "1-o-octadecyl 4-o-propan-2-yl butanedioate" );
gibbsFormation
{
    dHf_298   -1199170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1222.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-463560.0
    phase     gas;
}
