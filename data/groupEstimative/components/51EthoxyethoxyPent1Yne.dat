/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-(1-ethoxyethoxy)pent-1-yne  (C9H16O2, CAS 144271-37-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        51EthoxyethoxyPent1Yne;
formula     C9H16O2;
CAS         144271-37-4;
InChIKey    NLFPIKUDKBJDMY-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          618.18;      // K   [origin=predictive method=joback]
Pc          26.031;      // bar [origin=predictive method=joback]
omega       0.4970;      // -   [origin=predictive method=lee-kesler]
Tb          440.04;      // K   [origin=predictive method=joback]
HvapTb      39918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.804 0.64444 -0.00024293 4.19e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2O; count 2; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group tCH; count 1; } { group tC; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pentyne, 5-(1-ethoxyethoxy)-" "5-(1-ethoxyethoxy)-1-pentyne" );
standardThermochemistry
{
    dHf_298   -206910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35530.0
}
