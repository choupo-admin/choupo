/*--------------------------------*- Choupo -*-----------------------*\
  Component: methoxychlor  (C16H15Cl3O2, CAS 72-43-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methoxychlor;
formula     C16H15Cl3O2;
CAS         72-43-5;
InChIKey    IAKOZHOLGAGEJT-UHFFFAOYSA-N;
MW          345.644;      // g/mol [origin=calculated method=formula-sum]
Tc          1032.80;      // K   [origin=predictive method=joback]
Pc          19.930;      // bar [origin=predictive method=joback]
omega       0.7650;      // -   [origin=predictive method=lee-kesler]
Tb          782.46;      // K   [origin=predictive method=joback]
HvapTb      73377.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.65 1.27274 -0.00078912 1.692e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group CH3O; count 2; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-4-[2,2,2-tris(chloranyl)-1-(4-methoxyphenyl)ethyl]benzene" "p,p'-methoxychlor" "dmdt" "dimethoxy-ddt" "methoxy-ddt" "methoxcide" "metox" "maralate" "marlate" "moxie" "dianisyl trichloroethane" "higalmetox" );
gibbsFormation
{
    dHf_298   -249140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     628.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=44010.0
    phase     gas;
}
