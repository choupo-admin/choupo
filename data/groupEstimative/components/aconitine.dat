/*--------------------------------*- Choupo -*-----------------------*\
  Component: aconitine  (C34H47NO11, CAS 302-27-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aconitine;
formula     C34H47NO11;
CAS         302-27-2;
InChIKey    XFSBVAOIAHNAPC-UHFFFAOYSA-N;
MW          645.746;      // g/mol [origin=calculated method=formula-sum]
Tc          2027.76;      // K   [origin=predictive method=joback]
Pc          9.341;      // bar [origin=predictive method=joback]
omega       0.1731;      // -   [origin=predictive method=lee-kesler]
Tb          1498.67;      // K   [origin=predictive method=joback]
HvapTb      162181.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-351.888 4.85302 -0.0043806 1.6863e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 11; } { group C; count 4; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 3; } { group CH3COO; count 1; } { group CH3O; count 4; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 11; } { group C_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 3; } { group O; count 4; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "acetyl benzoyl aconine" "agn-pc-00iylk" "(3alpha,6alpha,14alpha,15alpha,16beta)-8-(acetyloxy)-20-ethyl-3,13,15-trihydroxy-1,6,16-trimethoxy-4-(methoxymethyl)aconitan-14-yl benzoate" "(9xi,13xi)-8-(acetyloxy)-20-ethyl-3,13,15-trihydroxy-1,6,16-trimethoxy-4-(methoxymethyl)aconitan-14-yl benzoate" "8-(acetyloxy)-20-ethyl-3,13,15-trihydroxy-1,6,16-trimethoxy-4-(methoxymethyl)aconitan-14-yl benzoate" "aconitane-3,8,13,14,15-pentol, 20-ethyl-1,6,16-trimethoxy-4-(methoxymethyl)-, 8-acetate 14-benzoate, (1.alpha.,3.alpha.,6.alpha.,14.alpha.,15.alpha.,16.beta.)-" );
standardThermochemistry
{
    dHf_298   -1746460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1045.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-719460.0
}
