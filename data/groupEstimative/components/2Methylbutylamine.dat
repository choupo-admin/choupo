/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylbutylamine  (C5H13N, CAS 96-15-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylbutylamine;
formula     C5H13N;
CAS         96-15-1;
InChIKey    VJROPLWGFCORRM-UHFFFAOYSA-N;
MW          87.166;      // g/mol [origin=calculated method=formula-sum]
Tc          571.49;      // K   [origin=predictive method=joback]
Pc          37.500;      // bar [origin=predictive method=joback]
omega       0.3917;      // -   [origin=predictive method=lee-kesler]
Tb          386.09;      // K   [origin=predictive method=joback]
HvapTb      36977.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.152 0.54664 -0.0002948 5.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbutan-1-amine" "1-amino-2-methylbutane" "1-butanamine, 2-methyl-" "1-aminoisopentane" "(2-methylbutyl)amine" "butylamine, 2-methyl-" "2-methyl-butylamine" "2-methyl-1-butanamine" "1-amino-2-methyl-butane" "2-methyl-butan-1-amine" "s-(-)-2-methylbutylamine" "(+/-)-1-amino-2-methylbutane" );
gibbsFormation
{
    dHf_298   -118020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55230.0
    phase     gas;
}
