/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-propyldiethanolamine  (C7H17NO2, CAS 6735-35-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nPropyldiethanolamine;
formula     C7H17NO2;
CAS         6735-35-9;
InChIKey    OZICRFXCUVKDRG-UHFFFAOYSA-N;
MW          147.218;      // g/mol [origin=calculated method=formula-sum]
Tc          712.86;      // K   [origin=predictive method=joback]
Pc          34.279;      // bar [origin=predictive method=joback]
omega       1.4184;      // -   [origin=predictive method=lee-kesler]
Tb          556.56;      // K   [origin=predictive method=joback]
HvapTb      66577.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.584 0.86072 -0.0005304 1.291e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-hydroxyethyl(propyl)amino]ethanol" "2,2'-(propylimino)bisethanol" "ethanol, 2,2'-(propylimino)bis-" "2,2'-(propylimino)diethanol" "2-[(2-hydroxyethyl)propylamino]ethan-1-ol" "propyldiethanolamine" "diethanol(propyl)amine" "propylbis(2-hydroxyethyl)amine" "n,n-bis(2-hydroxyethyl)propylamine" );
gibbsFormation
{
    dHf_298   -424740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154800.0
    phase     gas;
}
