/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylidenecyclooctane  (C10H18, CAS 19780-51-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylidenecyclooctane;
formula     C10H18;
CAS         19780-51-9;
InChIKey    WSOKCFIRHYCWJE-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          688.94;      // K   [origin=predictive method=joback]
Pc          28.874;      // bar [origin=predictive method=joback]
omega       0.3138;      // -   [origin=predictive method=lee-kesler]
Tb          467.80;      // K   [origin=predictive method=joback]
HvapTb      39723.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.89 1.00572 -0.0005323 8.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group CH2_ring; count 7; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -111360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86740.0
    phase     gas;
}
