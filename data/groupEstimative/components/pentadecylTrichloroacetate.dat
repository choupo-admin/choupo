/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentadecyl trichloroacetate  (C17H31Cl3O2, CAS 74339-53-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentadecylTrichloroacetate;
formula     C17H31Cl3O2;
CAS         74339-53-0;
InChIKey    NKIOTTYRINVYJZ-UHFFFAOYSA-N;
MW          373.783;      // g/mol [origin=calculated method=formula-sum]
Tc          941.27;      // K   [origin=predictive method=joback]
Pc          11.593;      // bar [origin=predictive method=joback]
omega       0.9081;      // -   [origin=predictive method=lee-kesler]
Tb          755.84;      // K   [origin=predictive method=joback]
HvapTb      72702.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.044 1.71022 -0.0010394 2.329e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CCl3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group C; count 1; } { group Cl; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadecyl 2,2,2-tris(chloranyl)ethanoate" "trichloroacetic acid, pentadecyl ester" "pentadecyl 2,2,2-trichloroacetate" );
standardThermochemistry
{
    dHf_298   -767460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     930.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-251060.0
}
