/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-Dimethylphenol  (C8H10O, CAS 105-67-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dimethylphenol;
formula     C8H10O;
CAS         105-67-9;
InChIKey    KUFFULVDNCHOFZ-UHFFFAOYSA-N;
MW          122.167;      // g/mol [origin=calculated method=formula-sum]
Tc          722.32;      // K   [origin=predictive method=joback]
Pc          43.226;      // bar [origin=predictive method=joback]
omega       0.5140;      // -   [origin=predictive method=lee-kesler]
Tb          494.92;      // K   [origin=predictive method=joback]
HvapTb      49354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.91 0.78004 -0.00063192 2.177e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-hydroxy-2,4-dimethylbenzene" "2,4-dmp" "2,4-xylenol" "4,6-dimethylphenol" "4-hydroxy-1,3-dimethylbenzene" "phenol, 2,4-dimethyl-" "m-xylenol" "gallex" "rcra waste number u101" "caswell no. 907a" "lysol brand disinfectant" "2,4-dimethyl phenol" );
gibbsFormation
{
    dHf_298   -160700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-35360.0
    phase     gas;
}
