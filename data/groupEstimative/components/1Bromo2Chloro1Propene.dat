/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2-chloro-1-propene  (C3H4BrCl, CAS 67939-55-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo2Chloro1Propene;
formula     C3H4BrCl;
CAS         67939-55-3;
InChIKey    LEUMKYBSYBFZEU-UHFFFAOYSA-N;
MW          155.419;      // g/mol [origin=calculated method=formula-sum]
Tc          586.92;      // K   [origin=predictive method=joback]
Pc          49.804;      // bar [origin=predictive method=joback]
omega       0.2767;      // -   [origin=predictive method=lee-kesler]
Tb          375.87;      // K   [origin=predictive method=joback]
HvapTb      33130.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.37 0.35372 -0.0003173 1.168e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group Br; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-chloranyl-prop-1-ene" "1-bromo-2-chloropropene" "1-propene, 1-bromo-2-chloro-" "1-bromo-2-chloroprop-1-ene" );
standardThermochemistry
{
    dHf_298   12770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48440.0
}
