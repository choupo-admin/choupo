/*--------------------------------*- Choupo -*-----------------------*\
  Component: carbitol acrylate  (C9H16O4, CAS 7328-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carbitolAcrylate;
formula     C9H16O4;
CAS         7328-17-8;
InChIKey    FTALTLPZDVFJSS-UHFFFAOYSA-N;
MW          188.223;      // g/mol [origin=calculated method=formula-sum]
Tc          678.22;      // K   [origin=predictive method=joback]
Pc          23.360;      // bar [origin=predictive method=joback]
omega       0.7308;      // -   [origin=predictive method=lee-kesler]
Tb          505.26;      // K   [origin=predictive method=joback]
HvapTb      47185.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.125 0.65762 -0.0001721 -5.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH2O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-ethoxyethoxy)ethyl prop-2-enoate" "2-(2-ethoxyethoxy)ethyl acrylate" "2-propenoic acid, 2-(2-ethoxyethoxy)ethyl ester" "di(ethylene glycol) ethyl ether acrylate" "2-(2-ethoxyethoxy)ethylacrylate" "ftaltlpzdvfjss-uhfffaoysa-" "p538" "diethylene glycol monoethyl ether acrylate" "acrylic acid 2-(2-ethoxyethoxy)ethyl ester" "2-propenoic acid 2-(2-ethoxyethoxy)ethyl ester" "2-propenoic acid,2-(2-ethoxyethoxy)ethyl ester" "acrylicacid, 2-(2-ethoxyethoxy)ethyl ester (7ci,8ci);ethanol, 2-(2-ethoxyethoxy)-,acrylate (8ci);2-(2-ethoxyethoxy)ethyl acrylate;carbitol acrylate;diethyleneglycol ethyl ether acrylate;ethylcarbitol acrylate;irr 184;light acrylateec-a;light ester eca;miramer 170;miramer m 170;r 672;rc 20;reactomer rc20;sr 256;sr 2564;sartomer 256;sartomer sr 256;v 190;viscoat 190;" );
standardThermochemistry
{
    dHf_298   -685380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-407630.0
}
