/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(1,1-dibutoxypropoxy)butane  (C15H32O3, CAS 62042-45-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111DibutoxypropoxyButane;
formula     C15H32O3;
CAS         62042-45-9;
InChIKey    BQIKKNNMJKMBEQ-UHFFFAOYSA-N;
MW          260.418;      // g/mol [origin=calculated method=formula-sum]
Tc          773.62;      // K   [origin=predictive method=joback]
Pc          13.820;      // bar [origin=predictive method=joback]
omega       0.8151;      // -   [origin=predictive method=lee-kesler]
Tb          606.83;      // K   [origin=predictive method=joback]
HvapTb      54918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.28 1.36508 -0.000631 7.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group C; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 10; } { group C; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tributyl orthopropionate" "butane, 1,1',1''-(propylidynetris(oxy))tris-" "butane, 1,1',1''-[propylidynetris(oxy)]tris-" "tributyl ortho propionate" "1,1',1''-(propylidynetris(oxy))tributane" );
standardThermochemistry
{
    dHf_298   -758340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     735.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-236740.0
}
