/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propanone, 1-(2-piperidinyl)-  (C8H15NO, CAS 97073-23-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propanone12Piperidinyl;
formula     C8H15NO;
CAS         97073-23-9;
InChIKey    FDOBDBWYWMTMKT-UHFFFAOYSA-N;
MW          141.214;      // g/mol [origin=calculated method=formula-sum]
Tc          724.10;      // K   [origin=predictive method=joback]
Pc          34.889;      // bar [origin=predictive method=joback]
omega       0.5131;      // -   [origin=predictive method=lee-kesler]
Tb          504.61;      // K   [origin=predictive method=joback]
HvapTb      47335.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.709 0.84452 -0.0004131 5.166e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2CO; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-piperidin-2-ylpropan-1-one" );
gibbsFormation
{
    dHf_298   -228900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-280.0
    phase     gas;
}
