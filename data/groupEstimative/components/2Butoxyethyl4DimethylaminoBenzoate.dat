/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butoxyethyl 4-(dimethylamino)benzoate  (C15H23NO3, CAS 67362-76-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butoxyethyl4DimethylaminoBenzoate;
formula     C15H23NO3;
CAS         67362-76-9;
InChIKey    PAAVDLDRAZEFGW-UHFFFAOYSA-N;
MW          265.353;      // g/mol [origin=calculated method=formula-sum]
Tc          860.45;      // K   [origin=predictive method=joback]
Pc          18.016;      // bar [origin=predictive method=joback]
omega       0.9015;      // -   [origin=predictive method=lee-kesler]
Tb          667.54;      // K   [origin=predictive method=joback]
HvapTb      63782.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.865 1.29636 -0.00066336 9.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, 4-(dimethylamino)-, 2-butoxyethyl ester" "4-(dimethylamino)benzoic acid 2-butoxyethyl ester" "ethylene glycol monobutyl ether 4-(dimethylamino)benzoate" );
standardThermochemistry
{
    dHf_298   -509840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     706.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-126390.0
}
