/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-n,n-dimethylaniline  (C8H10BrN, CAS 16518-62-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3BromoNNDimethylaniline;
formula     C8H10BrN;
CAS         16518-62-0;
InChIKey    USEXQPWLCGBYNT-UHFFFAOYSA-N;
MW          200.079;      // g/mol [origin=calculated method=formula-sum]
Tc          719.29;      // K   [origin=predictive method=joback]
Pc          38.916;      // bar [origin=predictive method=joback]
omega       0.4726;      // -   [origin=predictive method=lee-kesler]
Tb          492.90;      // K   [origin=predictive method=joback]
HvapTb      44818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.49 0.78754 -0.00055956 1.561e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-n,n-dimethyl-aniline" "(3-bromophenyl)dimethylamine" "benzenamine, 3-bromo-n,n-dimethyl-" "n,n-dimethyl-3-bromoaniline" "m-bromodimethyl aniline" "n,n-dimethyl 3-bromoaniline," "n652" "n-(3-bromophenyl)dimethylamine;n,n-dimethyl-3-bromoaniline;aniline,m-bromo-n,n-dimethyl- (6ci,7ci,8ci);(3-bromophenyl)dimethylamine;m-bromo-n,n-dimethylaniline;" );
gibbsFormation
{
    dHf_298   110470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=244360.0
    phase     gas;
}
