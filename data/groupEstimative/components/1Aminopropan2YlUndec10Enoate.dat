/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-aminopropan-2-yl undec-10-enoate  (C14H27NO2, CAS 68052-40-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Aminopropan2YlUndec10Enoate;
formula     C14H27NO2;
CAS         68052-40-4;
InChIKey    VJHCSIJGIDREPD-UHFFFAOYSA-N;
MW          241.375;      // g/mol [origin=calculated method=formula-sum]
Tc          826.75;      // K   [origin=predictive method=joback]
Pc          16.660;      // bar [origin=predictive method=joback]
omega       0.9270;      // -   [origin=predictive method=lee-kesler]
Tb          646.91;      // K   [origin=predictive method=joback]
HvapTb      63748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.389 1.32682 -0.0007127 1.262e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2COO; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azanylpropan-2-yl undec-10-enoate" "10-undecenoic acid, 2-amino-1-methylethyl ester" );
standardThermochemistry
{
    dHf_298   -495630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     790.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-91520.0
}
