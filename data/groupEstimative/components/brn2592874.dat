/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2592874  (C19H16O2, CAS 24684-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2592874;
formula     C19H16O2;
CAS         24684-49-9;
InChIKey    CGCLWKCCKCGADM-UHFFFAOYSA-N;
MW          276.335;      // g/mol [origin=calculated method=formula-sum]
Tc          1077.75;      // K   [origin=predictive method=joback]
Pc          22.355;      // bar [origin=predictive method=joback]
omega       0.9293;      // -   [origin=predictive method=lee-kesler]
Tb          825.51;      // K   [origin=predictive method=joback]
HvapTb      73633.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.93 1.37094 -0.00089984 2.378e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 6; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH2CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 8; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methoxy-11-methyl-15,16-dihydrocyclopenta[a]phenanthren-17-one" "17h-cyclopenta(a)phenanthren-17-one, 15,16-dihydro-11-methyl-6-methoxy-" "17h-cyclopenta(a)phenanthren-17-one, 15,16-dihydro-6-methoxy-11-methyl-" "6-methoxy-11-methyl-15,16-dihydro-17h-cyclopenta(a)phenanthren-17-one" );
standardThermochemistry
{
    dHf_298   -50950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=227530.0
}
