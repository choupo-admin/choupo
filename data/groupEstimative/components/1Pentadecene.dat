/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentadecene  (C15H30, CAS 13360-61-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pentadecene;
formula     C15H30;
CAS         13360-61-7;
InChIKey    PJLHTVIBELQURV-UHFFFAOYSA-N;
MW          210.405;      // g/mol [origin=calculated method=formula-sum]
Tc          701.04;      // K   [origin=predictive method=joback]
Pc          14.613;      // bar [origin=predictive method=joback]
omega       0.6911;      // -   [origin=predictive method=lee-kesler]
Tb          539.48;      // K   [origin=predictive method=joback]
HvapTb      48314.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.738 1.40882 -0.0008151 1.847e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadec-1-ene" "pentadecene,1-" "pentadecene" );
gibbsFormation
{
    dHf_298   -227500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     735.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=163260.0
    phase     gas;
}
