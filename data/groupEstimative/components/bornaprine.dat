/*--------------------------------*- Choupo -*-----------------------*\
  Component: bornaprine  (C21H31NO2, CAS 20448-86-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bornaprine;
formula     C21H31NO2;
CAS         20448-86-6;
InChIKey    BDNMABJZSXTKAQ-UHFFFAOYSA-N;
MW          329.484;      // g/mol [origin=calculated method=formula-sum]
Tc          1003.99;      // K   [origin=predictive method=joback]
Pc          14.759;      // bar [origin=predictive method=joback]
omega       0.9017;      // -   [origin=predictive method=lee-kesler]
Tb          790.74;      // K   [origin=predictive method=joback]
HvapTb      72604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-185.045 2.54664 -0.002039 6.83e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(diethylamino)propyl 3-phenylbicyclo[2.2.1]heptane-3-carboxylate" "kr 339 [german]" "bornaprinum [inn-latin]" "2-phenylbicyclo(2.2.1)heptane-2-carboxylic acid, 3-(diethylamino)propyl ester" "sormodren" "2-norbornanecarboxylic acid, 2-phenyl-, 3-(diethylamino)propyl ester" "2-phenyl-2-(gamma-diethylaminocarbopropoxy)-bicyclo(2.2.1)heptane" "2-phenylbicyclo(2.2.1)heptan-2-carbonsaeure-(gamma-diaethylaminopropyl) ester [german]" "bornaprino" "bornaprinum" "bornaprine (inn)" "bornaprine [ban:inn]" );
standardThermochemistry
{
    dHf_298   -355650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=134960.0
}
