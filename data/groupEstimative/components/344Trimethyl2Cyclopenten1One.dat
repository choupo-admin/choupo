/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4,4-trimethyl-2-cyclopenten-1-one  (C8H12O, CAS 30434-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        344Trimethyl2Cyclopenten1One;
formula     C8H12O;
CAS         30434-65-2;
InChIKey    BDINBSUUIUWFNH-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          695.33;      // K   [origin=predictive method=joback]
Pc          34.399;      // bar [origin=predictive method=joback]
omega       0.3625;      // -   [origin=predictive method=lee-kesler]
Tb          470.12;      // K   [origin=predictive method=joback]
HvapTb      37709.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.35 0.90366 -0.00074764 2.878e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4,4-trimethylcyclopent-2-en-1-one" "2-cyclopenten-1-one, 3,4,4-trimethyl-" "3,4,4-trimethylcyclopent-2-enone" "3,4,4-trimethyl-cyclopent-2-en-1-one" );
gibbsFormation
{
    dHf_298   -224120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-54720.0
    phase     gas;
}
