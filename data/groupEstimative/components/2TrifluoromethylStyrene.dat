/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(trifluoromethyl)styrene  (C9H7F3, CAS 395-45-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TrifluoromethylStyrene;
formula     C9H7F3;
CAS         395-45-9;
InChIKey    VGWWQZSCLBZOGK-UHFFFAOYSA-N;
MW          172.149;      // g/mol [origin=calculated method=formula-sum]
Tc          621.44;      // K   [origin=predictive method=joback]
Pc          29.537;      // bar [origin=predictive method=joback]
omega       0.3902;      // -   [origin=predictive method=lee-kesler]
Tb          428.44;      // K   [origin=predictive method=joback]
HvapTb      34149.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.09 0.8616 -0.00067386 2.026e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenyl-2-(trifluoromethyl)benzene" "2-trifluoromethylstyrene" "1-(trifluoromethyl)-2-vinylbenzene" "2-vinylbenzotrifluoride" "o-(trifluoromethyl)styrene" "benzene,1-ethenyl-2-(trifluoromethyl)-" "styrene,o-(trifluoromethyl)- (8ci);2-(trifluoromethyl)styrene;o-trifluoromethylstyrene;" "o-(trifluoromethyl)styrene;1-ethenyl-2-(trifluoromethyl)benzene;1-vinyl-2-(trifluoromethyl)benzene" );
gibbsFormation
{
    dHf_298   -475680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-366070.0
    phase     gas;
}
