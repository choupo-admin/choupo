/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5,7,9-pentathiecane  (C5H10S5, CAS 2372-99-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13579Pentathiecane;
formula     C5H10S5;
CAS         2372-99-8;
InChIKey    OORAADWLEVSLPL-UHFFFAOYSA-N;
MW          230.435;      // g/mol [origin=calculated method=formula-sum]
Tc          931.92;      // K   [origin=predictive method=joback]
Pc          51.757;      // bar [origin=predictive method=joback]
omega       0.2746;      // -   [origin=predictive method=lee-kesler]
Tb          594.45;      // K   [origin=predictive method=joback]
HvapTb      57210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.42 0.66105 -0.0002925 1.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2S; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group S_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5,7,9-pentathiacyclodecane" "1,3,5,7,9-pentathiecane(7ci,8ci,9ci)" );
gibbsFormation
{
    dHf_298   129790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     693.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=174280.0
    phase     gas;
}
