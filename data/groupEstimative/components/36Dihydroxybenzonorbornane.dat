/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-dihydroxybenzonorbornane  (C11H12O2, CAS 16144-91-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Dihydroxybenzonorbornane;
formula     C11H12O2;
CAS         16144-91-5;
InChIKey    JYHNNCBQCSLFQM-UHFFFAOYSA-N;
MW          176.215;      // g/mol [origin=calculated method=formula-sum]
Tc          903.89;      // K   [origin=predictive method=joback]
Pc          49.246;      // bar [origin=predictive method=joback]
omega       0.9026;      // -   [origin=predictive method=lee-kesler]
Tb          653.39;      // K   [origin=predictive method=joback]
HvapTb      68700.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-139.92 1.531 -0.00153828 6.15e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 2; } { group ACCH; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-methanonaphthalene-5,8-diol, 1,2,3,4-tetrahydro-" "1,2,3,4-tetrahydro-1,4-methanonaphthalene-5,8-diol" "tricyclo[6.2.1.02,7]undeca-2,4,6-triene-3,6-diol" "benzonorbornene-3,6-diol" "agn-pc-00hmqv" "tricyclo[6.2.1.0<2,7>]undeca-2(7),3,5-triene-3,6-diol" "tricyclo[6.2.1.0^{2,7}]undeca-2(7),3,5-triene-3,6-diol" );
standardThermochemistry
{
    dHf_298   -248170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     324.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31120.0
}
