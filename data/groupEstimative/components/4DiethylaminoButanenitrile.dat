/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(diethylamino)butanenitrile  (C8H16N2, CAS 5336-75-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4DiethylaminoButanenitrile;
formula     C8H16N2;
CAS         5336-75-4;
InChIKey    NUVVGLXJJPTXRJ-UHFFFAOYSA-N;
MW          140.23;      // g/mol [origin=calculated method=formula-sum]
Tc          680.31;      // K   [origin=predictive method=joback]
Pc          24.678;      // bar [origin=predictive method=joback]
omega       0.6278;      // -   [origin=predictive method=lee-kesler]
Tb          497.16;      // K   [origin=predictive method=joback]
HvapTb      45923.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.925 0.82254 -0.000493 1.151e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-diethylaminobutyronitrile" "gamma-diethylaminobutyronitrile" "butanenitrile,4-(diethylamino)-" "butanenitrile, 4-(diethylamino)-" "4-(diethylamino)butyronitrile" );
standardThermochemistry
{
    dHf_298   23960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=260440.0
}
