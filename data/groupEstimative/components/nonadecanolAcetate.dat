/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonadecanol, acetate  (C21H44O3, CAS 53939-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonadecanolAcetate;
formula     C21H44O3;
CAS         53939-51-8;
InChIKey    ICCWFPLRMGHRIP-UHFFFAOYSA-N;
MW          344.58;      // g/mol [origin=calculated method=formula-sum]
Tc          1127.43;      // K   [origin=predictive method=joback]
Pc          10.136;      // bar [origin=predictive method=joback]
omega       0.9589;      // -   [origin=predictive method=lee-kesler]
Tb          919.17;      // K   [origin=predictive method=joback]
HvapTb      96477.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.508 1.87744 -0.0008068 5.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 18; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanoic acid;nonadecan-1-ol" );
gibbsFormation
{
    dHf_298   -1090890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1185.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-459550.0
    phase     gas;
}
