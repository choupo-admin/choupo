/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,9,14,18-tetramethyl-20-(2,6,6-trimethylcyclohexen-1-yl)icosa-3,5,7,9,11,13,15,17,19-nonaen-2-one  (C33H44O, CAS 3604-90-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        591418Tetramethyl20266Trimethylcyclohexen1YlIcosa35791113151;
formula     C33H44O;
CAS         3604-90-8;
InChIKey    PRDJTOVRIHGKNU-UHFFFAOYSA-N;
MW          456.714;      // g/mol [origin=calculated method=formula-sum]
Tc          1318.12;      // K   [origin=predictive method=joback]
Pc          7.807;      // bar [origin=predictive method=joback]
omega       0.7215;      // -   [origin=predictive method=lee-kesler]
Tb          1074.38;      // K   [origin=predictive method=joback]
HvapTb      96634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-225.37 3.52956 -0.0029829 1.06826e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 3; } { group C; count 1; } { group CH=CH; count 5; } { group CH=C; count 4; } { group CH3CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group dCH; count 14; } { group dC; count 4; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5,7,9,11,13,15,17,19-eicosanonaen-2-one, 5,9,14,18-tetramethyl-20-(2,6,6-trimethyl-1-cyclohexen-1-yl)-, (3e,5e,7e,9e,11e,13e,15e,17e,19e)-" );
standardThermochemistry
{
    dHf_298   283190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1381.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=815500.0
}
