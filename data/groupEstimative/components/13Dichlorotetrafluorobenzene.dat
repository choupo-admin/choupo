/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dichlorotetrafluorobenzene  (C6Cl2F4, CAS 1198-61-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dichlorotetrafluorobenzene;
formula     C6Cl2F4;
CAS         1198-61-4;
InChIKey    LFIJIYWQWRQWQC-UHFFFAOYSA-N;
MW          218.958;      // g/mol [origin=calculated method=formula-sum]
Tc          651.16;      // K   [origin=predictive method=joback]
Pc          31.140;      // bar [origin=predictive method=joback]
omega       0.5418;      // -   [origin=predictive method=lee-kesler]
Tb          460.40;      // K   [origin=predictive method=joback]
HvapTb      40038.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (85.17 0.2582 -0.000105 1.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACCl; count 2; } { group ACF; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group F; count 4; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)-2,4,5,6-tetrakis(fluoranyl)benzene" "benzene, 1,3-dichlorotetrafluoro-" "1,3-dichloro-2,4,5,6-tetrafluorobenzene" "benzene, 1,3-dichloro-2,4,5,6-tetrafluoro-" "k877" "benzene,1,3-dichloro-2,4,5,6-tetrafluoro-" "benzene,1,3-dichlorotetrafluoro- (7ci,8ci); 1,3-dichloro-2,4,5,6-tetrafluorobenzene;1,3-dichlorotetrafluorobenzene; 2,4,5,6-tetrafluoro-1,3-dichlorobenzene;m-dichlorotetrafluorobenzene" );
gibbsFormation
{
    dHf_298   -803910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-739200.0
    phase     gas;
}
