/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorodibromomethane  (CHBr2Cl, CAS 124-48-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorodibromomethane;
formula     CHBr2Cl;
CAS         124-48-1;
InChIKey    GATVIKZLVQHOMN-UHFFFAOYSA-N;
MW          208.277;      // g/mol [origin=calculated method=formula-sum]
Tc          619.17;      // K   [origin=predictive method=joback]
Pc          68.869;      // bar [origin=predictive method=joback]
omega       0.3323;      // -   [origin=predictive method=lee-kesler]
Tb          391.79;      // K   [origin=predictive method=joback]
HvapTb      34687.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.57 0.1879 -0.000197 7.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group Cl; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(bromanyl)-chloranyl-methane" "dibromochloromethane" "methane, dibromochloro-" "dibromo(chloro)methane" "monochlorodibromomethane" "cdbm" "methane, chlorodibromo-" "dibromo-chloro-methane" "agn-pc-00g7v3" "ls-77" "dibromochloromethane;dibromomonochloromethane;monochlorodibromomethane;" );
standardThermochemistry
{
    dHf_298   -32330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     320.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28190.0
}
