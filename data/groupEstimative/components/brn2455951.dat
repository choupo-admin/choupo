/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2455951  (C12H16ClNO2, CAS 13791-92-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2455951;
formula     C12H16ClNO2;
CAS         13791-92-9;
InChIKey    OKCMWDCQCIAGAQ-UHFFFAOYSA-N;
MW          241.715;      // g/mol [origin=calculated method=formula-sum]
Tc          849.59;      // K   [origin=predictive method=joback]
Pc          23.703;      // bar [origin=predictive method=joback]
omega       0.7816;      // -   [origin=predictive method=lee-kesler]
Tb          636.52;      // K   [origin=predictive method=joback]
HvapTb      61102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.05 0.99138 -0.00053262 8.936e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group CH-O; count 1; } { group ACCl; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chloranyl-2-methyl-phenoxy)-n,n-dimethyl-propanamide" "2-(4-chloro-2-methylphenoxy)-n,n-dimethylpropanamide" "2-(4-chloro-2-methylphenoxy)-n,n-dimethylpropionamide" "propionamide, 2-(4-chloro-2-methylphenoxy)-n,n-dimethyl-" "2-(4-chloro-2-methylphenoxy)-n,n-dimethyl-propionamide" );
gibbsFormation
{
    dHf_298   -275710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5800.0
    phase     gas;
}
