/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl ferulate  (C12H14O4, CAS 4046-02-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylFerulate;
formula     C12H14O4;
CAS         4046-02-0;
InChIKey    ATJVZXXHKSYELS-FNORWQNLSA-N;
MW          222.24;      // g/mol [origin=calculated method=formula-sum]
Tc          891.78;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.9326;      // -   [origin=predictive method=lee-kesler]
Tb          671.24;      // K   [origin=predictive method=joback]
HvapTb      68033.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.181 1.06204 -0.00072772 2.008e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (e)-3-(3-methoxy-4-oxidanyl-phenyl)prop-2-enoate" "ethyl 3-(4-hydroxy-3-methoxyphenyl)acrylate" "ferulic acid ethyl ester" "ethyl 4-hydroxy-3-methoxycinnamate" "ethyl 4'-hydroxy-3'-methoxycinnamate" "ethyl (2e)-3-(4-hydroxy-3-methoxyphenyl)prop-2-enoate" "ferulic acid ethylester" "ferulic acid, ethyl ester" "ethyl 3-(4-hydroxy-3-methoxyphenyl)prop-2-enoate" "(e)-3-(4-hydroxy-3-methoxy-phenyl)-" "ethyl-3-(4-hydroxy-3-methoxyphenyl)prop-2-enoate" "ethyl (2e)-3-(4-hydroxy-3-methoxyphenyl)-2-propenoate" );
gibbsFormation
{
    dHf_298   -575540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-336830.0
    phase     gas;
}
