/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2879160  (C16H23Cl2NO2, CAS 66232-25-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2879160;
formula     C16H23Cl2NO2;
CAS         66232-25-5;
InChIKey    BAKGUOSIFRQDLJ-UHFFFAOYSA-N;
MW          332.265;      // g/mol [origin=calculated method=formula-sum]
Tc          942.75;      // K   [origin=predictive method=joback]
Pc          15.885;      // bar [origin=predictive method=joback]
omega       0.9611;      // -   [origin=predictive method=lee-kesler]
Tb          742.86;      // K   [origin=predictive method=joback]
HvapTb      72368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.238 1.46812 -0.00086956 1.781e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH2COO; count 1; } { group CH2N; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 2-[4-[bis(2-chloroethyl)amino]phenyl]ethanoate" "butyl {4-[bis(2-chloroethyl)amino]phenyl}acetate" "butyl 2-[4-[bis(2-chloroethyl)amino]phenyl]acetate" );
standardThermochemistry
{
    dHf_298   -429740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     800.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-36830.0
}
