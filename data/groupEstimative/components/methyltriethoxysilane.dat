/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyltriethoxysilane  (C7H18O3Si, CAS 2031-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H18O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methyltriethoxysilane;
formula     C7H18O3Si;
CAS         2031-67-6;
InChIKey    CPUDPFPXCZDNGI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          178.303;      // g/mol [origin=calculated method=formula-sum]
Tc          599.15;      // K   [origin=predictive method=joback]
Pc          23.542;      // bar [origin=predictive method=joback]
omega       0.4746;      // -   [origin=predictive method=lee-kesler]
Tb          428.42;      // K   [origin=predictive method=joback]
HvapTb      38700.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (113.843 0.27308 0.0003908 -3.095e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethoxy(methyl)silane" "triethoxymethylsilane" "silane, triethoxymethyl-" "triethoxysilylmethane" "methyl triethoxysilane" "silane, methyltriethoxy-" "methaneorthosiliconic acid, triethyl ester" "silane,methyl,triethoxy" "triethoxy(methyl)silane; methaneorthosiliconic acid, triethyl ester" );
gibbsFormation
{
    dHf_298   -696090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-411700.0
    phase     gas;
}
