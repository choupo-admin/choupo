/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,3,4,4-pentamethyl-3-ethylpentane  (C12H26, CAS 66576-21-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22344Pentamethyl3Ethylpentane;
formula     C12H26;
CAS         66576-21-4;
InChIKey    IZNAUALMSCRPBS-UHFFFAOYSA-N;
MW          170.34;      // g/mol [origin=calculated method=formula-sum]
Tc          656.55;      // K   [origin=predictive method=joback]
Pc          18.692;      // bar [origin=predictive method=joback]
omega       0.3136;      // -   [origin=predictive method=lee-kesler]
Tb          464.47;      // K   [origin=predictive method=joback]
HvapTb      38418.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.439 1.52136 -0.0011444 3.473e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 1; } { group C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 1; } { group C; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-2,2,3,4,4-pentamethyl-pentane" "agn-pc-02y3uk" "3-ethyl-2,2,3,4,4-pentamethylpentane" );
gibbsFormation
{
    dHf_298   -317260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58680.0
    phase     gas;
}
