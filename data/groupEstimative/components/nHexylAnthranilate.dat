/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-hexyl anthranilate  (C13H19NO2, CAS 18189-05-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nHexylAnthranilate;
formula     C13H19NO2;
CAS         18189-05-4;
InChIKey    YMQOKTHPONOAKK-UHFFFAOYSA-N;
MW          221.3;      // g/mol [origin=calculated method=formula-sum]
Tc          868.66;      // K   [origin=predictive method=joback]
Pc          22.937;      // bar [origin=predictive method=joback]
omega       0.8681;      // -   [origin=predictive method=lee-kesler]
Tb          659.45;      // K   [origin=predictive method=joback]
HvapTb      65518.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.365 1.10752 -0.00059636 9.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexyl 2-azanylbenzoate" "hexyl 2-aminobenzoate" "anthranilic acid, hexyl ester" "n-hexyl o-aminobenzoate" "benzoic acid, 2-amino-, hexyl ester" "hexyl anthranilate" "anthranilic acid, hexyl ester (8ci)" );
standardThermochemistry
{
    dHf_298   -370080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     652.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-82560.0
}
