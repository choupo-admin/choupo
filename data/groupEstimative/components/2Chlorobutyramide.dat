/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorobutyramide  (C4H8ClNO, CAS 7462-73-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorobutyramide;
formula     C4H8ClNO;
CAS         7462-73-9;
InChIKey    VJIOSCMTZVXQQU-UHFFFAOYSA-N;
MW          121.564;      // g/mol [origin=calculated method=formula-sum]
Tc          661.60;      // K   [origin=predictive method=joback]
Pc          43.800;      // bar [origin=predictive method=joback]
omega       0.5328;      // -   [origin=predictive method=lee-kesler]
Tb          454.51;      // K   [origin=predictive method=joback]
HvapTb      45882.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.311 0.43042 -0.0002421 4.686e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CHCl; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group Cl; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylbutanamide" "2-chlorobutanamide" );
gibbsFormation
{
    dHf_298   -225700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94040.0
    phase     gas;
}
