/*--------------------------------*- Choupo -*-----------------------*\
  Component: carbocysteine  (C5H9NO4S, CAS 2387-59-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carbocysteine;
formula     C5H9NO4S;
CAS         2387-59-9;
InChIKey    GBFLZEXEOZUWRN-UHFFFAOYSA-N;
MW          179.19;      // g/mol [origin=calculated method=formula-sum]
Tc          978.73;      // K   [origin=predictive method=joback]
Pc          48.360;      // bar [origin=predictive method=joback]
omega       1.3710;      // -   [origin=predictive method=lee-kesler]
Tb          745.89;      // K   [origin=predictive method=joback]
HvapTb      78122.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.952 0.64259 -0.0003998 8.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CHNH2; count 1; } { group COOH; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group COOH; count 2; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-3-(2-hydroxy-2-oxoethylsulfanyl)propanoic acid" "thiodril" "s-carboxymethylcysteine" "s-(carboxymethyl)cysteine" "3-(carboxymethylthio)alanine" "cysteine, s-(carboxymethyl)-" "broncodeterge" "fluifort" "loviscol" "mucocis" "reomucil" "rinatiol" );
standardThermochemistry
{
    dHf_298   -776690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-599470.0
}
