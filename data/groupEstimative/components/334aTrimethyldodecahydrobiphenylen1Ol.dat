/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,4a-trimethyldodecahydrobiphenylen-1-ol  (C15H26O, CAS 64394-19-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        334aTrimethyldodecahydrobiphenylen1Ol;
formula     C15H26O;
CAS         64394-19-0;
InChIKey    DGSPVRDUQBYTCW-UHFFFAOYSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          867.03;      // K   [origin=predictive method=joback]
Pc          22.461;      // bar [origin=predictive method=joback]
omega       0.8087;      // -   [origin=predictive method=lee-kesler]
Tb          654.48;      // K   [origin=predictive method=joback]
HvapTb      62689.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-253.71 2.39106 -0.002243 8.967e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 4; } { group C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4a-trimethyl-1,2,4,4b,5,6,7,8,8a,8b-decahydrobiphenylen-1-ol" "1-biphenylenol, dodecahydro-3,3,4a-trimethyl-" "5,5,7-trimethyltricyclo(6.4.0.02,7)dodecan-3-ol" "tricyclo(6.4.0.02,7)dodecan-3-ol, 5,5,7-trimethyl-" );
standardThermochemistry
{
    dHf_298   -335780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50440.0
}
