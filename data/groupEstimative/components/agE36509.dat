/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-e-36509  (C22H20Si, CAS 18753-19-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C22H20Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        agE36509;
formula     C22H20Si;
CAS         18753-19-0;
InChIKey    SHCZBMYTPGCRGJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          312.487;      // g/mol [origin=calculated method=formula-sum]
Tc          1070.70;      // K   [origin=predictive method=joback]
Pc          18.452;      // bar [origin=predictive method=joback]
omega       0.6667;      // -   [origin=predictive method=lee-kesler]
Tb          805.64;      // K   [origin=predictive method=joback]
HvapTb      74016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.39 1.60344 -0.00095996 1.968e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 14; } { group AC; count 6; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 14; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl(dinaphthalen-1-yl)silane" "dimethyl-dinaphthalen-1-yl-silane" "silane,dimethyl-di-1-naphthalenyl-" "silane, dimethyl-di-1-naphthalenyl-" "silane,dimethyldi-1-naphthalenyl- (9ci)" "silane,dimethyldi-1-naphthyl- (6ci,8ci)" );
gibbsFormation
{
    dHf_298   223230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     696.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=448460.0
    phase     gas;
}
