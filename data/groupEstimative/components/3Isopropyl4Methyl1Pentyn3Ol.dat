/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-isopropyl-4-methyl-1-pentyn-3-ol  (C9H16O, CAS 5333-87-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Isopropyl4Methyl1Pentyn3Ol;
formula     C9H16O;
CAS         5333-87-9;
InChIKey    DIFXCBNNWBBNCA-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          669.90;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.6598;      // -   [origin=predictive method=lee-kesler]
Tb          483.71;      // K   [origin=predictive method=joback]
HvapTb      50093.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.06 0.93658 -0.00067033 1.9499e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-3-propan-2-yl-pent-1-yn-3-ol" "4-methyl-3-propan-2-ylpent-1-yn-3-ol" "1-pentyn-3-ol,4-methyl-3-(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -108730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109110.0
    phase     gas;
}
