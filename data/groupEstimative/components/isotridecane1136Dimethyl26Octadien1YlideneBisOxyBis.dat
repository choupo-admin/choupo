/*--------------------------------*- Choupo -*-----------------------*\
  Component: isotridecane, 1,1'-[(3,6-dimethyl-2,6-octadien-1-ylidene)bis(oxy)]bis-  (C36H70O2, CAS 67923-86-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isotridecane1136Dimethyl26Octadien1YlideneBisOxyBis;
formula     C36H70O2;
CAS         67923-86-8;
InChIKey    ACMRDVFLNVZDCX-UHFFFAOYSA-N;
MW          534.954;      // g/mol [origin=calculated method=formula-sum]
Tc          1360.76;      // K   [origin=predictive method=joback]
Pc          4.788;      // bar [origin=predictive method=joback]
omega       0.0809;      // -   [origin=predictive method=lee-kesler]
Tb          1074.88;      // K   [origin=predictive method=joback]
HvapTb      99462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.628 3.35504 -0.0018944 4.045e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 20; } { group CH; count 3; } { group CH=C; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 22; } { group CH; count 3; } { group dCH; count 2; } { group dC; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[3,6-dimethyl-1-(11-methyldodecoxy)octa-3,6-dienoxy]-11-methyl-dodecane" "isotridecane, 1,1'-[(3,6-dimethyl-2,6-octadienylidene)bis(oxy)]bis-" );
gibbsFormation
{
    dHf_298   -851790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1530.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=178260.0
    phase     gas;
}
