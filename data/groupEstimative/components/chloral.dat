/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloral  (C2HCl3O, CAS 75-87-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloral;
formula     C2HCl3O;
CAS         75-87-6;
InChIKey    HFFLGKNGCAIQMO-UHFFFAOYSA-N;
MW          147.379;      // g/mol [origin=calculated method=formula-sum]
Tc          618.56;      // K   [origin=predictive method=joback]
Pc          49.039;      // bar [origin=predictive method=joback]
omega       0.3365;      // -   [origin=predictive method=lee-kesler]
Tb          403.08;      // K   [origin=predictive method=joback]
HvapTb      38625.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.67 0.3145 -0.000311 1.094e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHO; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group Cl; count 3; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(chloranyl)ethanal" "trichloroacetaldehyde" "acetaldehyde, trichloro-" "2,2,2-trichloroacetaldehyde" "grasex" "trichloroethanal" "anhydrous chloral" "chloral (iupac)" "tri-chloro-acetaldehyde" "acetaldehyde, 2,2,2-trichloro-" "cloralio" "trichloro-acetaldehyde" );
gibbsFormation
{
    dHf_298   -226160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     313.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-166510.0
    phase     gas;
}
