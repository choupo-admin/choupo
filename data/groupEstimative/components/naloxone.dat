/*--------------------------------*- Choupo -*-----------------------*\
  Component: naloxone  (C19H21NO4, CAS 465-65-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naloxone;
formula     C19H21NO4;
CAS         465-65-6;
InChIKey    UZHSEJADLWPNLE-GRGSLBFTSA-N;
MW          327.38;      // g/mol [origin=calculated method=formula-sum]
Tc          1213.59;      // K   [origin=predictive method=joback]
Pc          29.250;      // bar [origin=predictive method=joback]
omega       1.6169;      // -   [origin=predictive method=lee-kesler]
Tb          970.82;      // K   [origin=predictive method=joback]
HvapTb      98489.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-279.079 2.9291 -0.00306368 1.2897e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group CH2=CH; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } { group CH-O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 1; } { group O_ring; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,4as,7ar,12bs)-4a,9-bis(oxidanyl)-3-prop-2-enyl-2,4,5,6,7a,13-hexahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-7-one" "l-naloxone" "n-allylnoroxymorphone" "naloxona" "naloxonum" "narcanti" "nalone" "narcan" "en 1530 base" "nalossone [dcit]" "(-)-naloxone" "nalossone" );
gibbsFormation
{
    dHf_298   -300340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=144840.0
    phase     gas;
}
