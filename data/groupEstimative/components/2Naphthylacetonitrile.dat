/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-naphthylacetonitrile  (C12H9N, CAS 7498-57-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Naphthylacetonitrile;
formula     C12H9N;
CAS         7498-57-9;
InChIKey    LPCWDVLDJVZIHA-UHFFFAOYSA-N;
MW          167.211;      // g/mol [origin=calculated method=formula-sum]
Tc          872.61;      // K   [origin=predictive method=joback]
Pc          29.730;      // bar [origin=predictive method=joback]
omega       0.6134;      // -   [origin=predictive method=lee-kesler]
Tb          626.88;      // K   [origin=predictive method=joback]
HvapTb      57362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.069 0.9365 -0.00069888 2.07e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-naphthalen-2-ylethanenitrile" "2-naphthyl acetonitrile" "2-naphthaleneacetonitrile" "2-(naphthalen-2-yl)acetonitrile" "2-naphthalen-2-ylacetonitrile" "2-(2-naphthyl)ethanenitrile" "2-naphthylmethylcyanide" ".beta.-naphthyleneacetonitrile" );
gibbsFormation
{
    dHf_298   290000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=392770.0
    phase     gas;
}
