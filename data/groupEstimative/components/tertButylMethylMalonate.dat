/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl methyl malonate  (C8H14O4, CAS 42726-73-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertButylMethylMalonate;
formula     C8H14O4;
CAS         42726-73-8;
InChIKey    XPSYZCWYRWHVCC-UHFFFAOYSA-N;
MW          174.196;      // g/mol [origin=calculated method=formula-sum]
Tc          684.68;      // K   [origin=predictive method=joback]
Pc          26.111;      // bar [origin=predictive method=joback]
omega       0.5993;      // -   [origin=predictive method=lee-kesler]
Tb          495.85;      // K   [origin=predictive method=joback]
HvapTb      46920.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.961 0.78008 -0.000394 4.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o3-tert-butyl o1-methyl propanedioate" "1-tert-butyl 3-methyl propanedioate" "3-o-tert-butyl 1-o-methyl propanedioate" "propanedioic acid o3-tert-butyl ester o1-methyl ester" "malonicacid, tert-butyl methyl ester (6ci);propanedioic acid, 1,1-dimethylethylmethyl ester (9ci);malonic acid methyl tert-butyl ester;methyl tert-butylmalonate;tert-butyl methyl malonate;" );
standardThermochemistry
{
    dHf_298   -851760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-601420.0
}
