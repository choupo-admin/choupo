/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dichlorophenylacetonitrile  (C8H5Cl2N, CAS 6306-60-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dichlorophenylacetonitrile;
formula     C8H5Cl2N;
CAS         6306-60-1;
InChIKey    VJARIBGMDPJLCL-UHFFFAOYSA-N;
MW          186.035;      // g/mol [origin=calculated method=formula-sum]
Tc          838.74;      // K   [origin=predictive method=joback]
Pc          31.420;      // bar [origin=predictive method=joback]
omega       0.5765;      // -   [origin=predictive method=lee-kesler]
Tb          596.22;      // K   [origin=predictive method=joback]
HvapTb      56250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.091 0.5143 -0.00031832 7.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CH2CN; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,4-dichlorophenyl)ethanenitrile" "2,4-dichlorobenzyl cyanide" "2-(2,4-dichlorophenyl)acetonitrile" "benzeneacetonitrile, 2,4-dichloro-" "(2,4-dichlorphenyl)acetonitril" "(2,4-dichlorophenyl)acetonitrile" "acetonitrile, (2,4-dichlorophenyl)-" "2,4-dccn" "2,4-dichlorobenzeneacetonitrile" "benzeneacetonitrile,4-dichloro-" "acetonitrile,4-dichlorophenyl)-" "vjaribgmdpjlcl-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   138540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=218950.0
    phase     gas;
}
