/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2r,4r)-pentanediol  (C5H12O2, CAS 42075-32-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2r4rPentanediol;
formula     C5H12O2;
CAS         42075-32-1;
InChIKey    GTCCGKPBSJZVRZ-RFZPGFLSSA-N;
MW          104.149;      // g/mol [origin=calculated method=formula-sum]
Tc          661.47;      // K   [origin=predictive method=joback]
Pc          44.563;      // bar [origin=predictive method=joback]
omega       1.1852;      // -   [origin=predictive method=lee-kesler]
Tb          497.48;      // K   [origin=predictive method=joback]
HvapTb      59306.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.561 0.55864 -0.0003154 6.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,4r)-pentane-2,4-diol" "(r,r)-(-)-2,4-pentanediol" "(2r,4r)-(-)-2,4-pentanediol" "(2r,4r)-(-)-2,4-dihydroxypentane" "2,4-pentanediol,(r*,r*)-; (r*,r*)-2,4-pentanediol; (?a'a a'a currency)-2,4-pentanediol; dl-2,4-pentanediol;dl-2,4-pentanediol; rac-2,4-pentanediol" );
gibbsFormation
{
    dHf_298   -461550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-287300.0
    phase     gas;
}
