/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-diaminoanthracene-9,10-diol  (C14H12N2O2, CAS 5327-72-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Diaminoanthracene910Diol;
formula     C14H12N2O2;
CAS         5327-72-0;
InChIKey    WGOXABJBDOYQFK-UHFFFAOYSA-N;
MW          240.262;      // g/mol [origin=calculated method=formula-sum]
Tc          1180.37;      // K   [origin=predictive method=joback]
Pc          52.970;      // bar [origin=predictive method=joback]
omega       1.5081;      // -   [origin=predictive method=lee-kesler]
Tb          905.80;      // K   [origin=predictive method=joback]
HvapTb      101610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.59 1.502 -0.00144084 5.566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } { group ACOH; count 2; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 8; } { group OH_phenol; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(azanyl)anthracene-9,10-diol" "leuco-1,4-diaminoanthraquinone" "9,10-anthracenediol, 1,4-diamino-" "leuko-1,4-diaminoanthrachinon" "1,4-diamino-9,10-anthracenediol" "1,4-diamino-9,10-dihydroxyanthraquinone" "anthraquinone, 1,4-diamino-9,10-dihydroxy-" "1,10-dihydroxyanthracen" "anthracene-9, 1,4-diamino-" "1,4-diamino-9,10-dihydroxyanthracen" "1,4-diamino-9,10-dihydroxyanthrachinon" );
standardThermochemistry
{
    dHf_298   -35070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=187480.0
}
