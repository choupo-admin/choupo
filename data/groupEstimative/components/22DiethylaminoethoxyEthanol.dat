/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-diethylaminoethoxy)ethanol  (C8H19NO2, CAS 140-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DiethylaminoethoxyEthanol;
formula     C8H19NO2;
CAS         140-82-9;
InChIKey    VKBVRNHODPFVHK-UHFFFAOYSA-N;
MW          161.245;      // g/mol [origin=calculated method=formula-sum]
Tc          668.46;      // K   [origin=predictive method=joback]
Pc          27.326;      // bar [origin=predictive method=joback]
omega       1.0159;      // -   [origin=predictive method=lee-kesler]
Tb          509.68;      // K   [origin=predictive method=joback]
HvapTb      54534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.716 0.85854 -0.0004434 7.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH2N; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group OH; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(diethylamino)ethoxy]ethanol" "diethylaminoethoxyethanol" "2-(2-diethylaminoethoxy)-ethanol" "6-ethyl-3-oxa-6-azaoctanol" "diethylamine, ethoxylated" "n,n-diethylethoxyethanolamine" "2-(2-(diethylamino)ethoxy)ethanol" "2-(2-n,n-diethylaminoethoxy)ethanol" "2-(beta-(diethylamino)ethoxy)ethanol" "polyoxyethylene-n,n-diethylethanolamine" "2-[2-(diethylamino)ethoxy]ethan-1-ol" "ethanol, 2-(2-(diethylamino)ethoxy)-" );
gibbsFormation
{
    dHf_298   -425370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114560.0
    phase     gas;
}
