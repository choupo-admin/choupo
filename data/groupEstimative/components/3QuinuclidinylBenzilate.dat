/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-quinuclidinyl benzilate  (C21H23NO3, CAS 6581-06-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3QuinuclidinylBenzilate;
formula     C21H23NO3;
CAS         6581-06-2;
InChIKey    HGMITUYOCPPQLE-UHFFFAOYSA-N;
MW          337.419;      // g/mol [origin=calculated method=formula-sum]
Tc          1147.40;      // K   [origin=predictive method=joback]
Pc          21.178;      // bar [origin=predictive method=joback]
omega       1.2603;      // -   [origin=predictive method=lee-kesler]
Tb          910.80;      // K   [origin=predictive method=joback]
HvapTb      91723.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-194.08 2.3621 -0.0017952 5.204e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azabicyclo[2.2.2]octan-3-yl 2-oxidanyl-2,2-diphenyl-ethanoate" "bz [anticholinergic]" "3-chinuclidylbenzilate" "3-quinuclidyl benzilate" "3-quinuclidinol benzilate" "benzilic acid, 3-quinuclidinyl ester" "bz" "qnb" "benzeneacetic acid, alpha-hydroxy-alpha-phenyl-, 1-azabicyclo(2.2.2)oct-3-yl ester" "3-(2,2-diphenyl-2-hydroxyethanoyloxy)-quinuclidine" "[3h]qnb" "1-azabicyclo[2.2.2]octan-3-yl 2-hydroxy-2,2-diphenylacetate" );
standardThermochemistry
{
    dHf_298   -275000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     679.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=126590.0
}
