/*--------------------------------*- Choupo -*-----------------------*\
  Component: dropropizine  (C13H20N2O2, CAS 17692-31-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dropropizine;
formula     C13H20N2O2;
CAS         17692-31-8;
InChIKey    PTVWPYVOOKLBCG-UHFFFAOYSA-N;
MW          236.315;      // g/mol [origin=calculated method=formula-sum]
Tc          942.31;      // K   [origin=predictive method=joback]
Pc          32.320;      // bar [origin=predictive method=joback]
omega       1.5914;      // -   [origin=predictive method=lee-kesler]
Tb          748.20;      // K   [origin=predictive method=joback]
HvapTb      84258.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.618 1.6494 -0.001233 3.605e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-phenylpiperazin-1-yl)propane-1,2-diol" "dipropizine" "catabex" "ditustat" "larylin" "tussilex" "katril" "ribex" "(+-)-dropropizine" "dropropizine (r,s)" "dropropizinum [inn-latin]" "(+/-)-dropropizine" );
standardThermochemistry
{
    dHf_298   -162820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     652.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172830.0
}
