/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 0591268  (C30H46N2O2, CAS 10140-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn0591268;
formula     C30H46N2O2;
CAS         10140-08-6;
InChIKey    LKAFZYPMWORKEH-UHFFFAOYSA-N;
MW          466.71;      // g/mol [origin=calculated method=formula-sum]
Tc          1278.45;      // K   [origin=predictive method=joback]
Pc          8.975;      // bar [origin=predictive method=joback]
omega       0.8699;      // -   [origin=predictive method=lee-kesler]
Tb          1044.24;      // K   [origin=predictive method=joback]
HvapTb      98486.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.362 2.7532 -0.00163804 3.595e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group ACH; count 6; } { group AC; count 1; } { group ACCH2; count 4; } { group ACCH; count 1; } { group CH2O; count 2; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 8; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-[2-[bis(2,6-diethylphenyl)methoxy]ethoxy]ethyl]-4-methyl-piperazine" "1-(2-(2-(2,6-diethyl-alpha-(2,6-diethylphenyl)benzyloxy)ethoxy)ethyl)-4-methylpiperazine" "piperazine, 1-(2-(2-(2,6-diethyl-alpha-(2,6-diethylphenyl)benzyloxy)ethoxy)ethyl)-4-methyl-" "1-[2-[2-[bis(2,6-diethylphenyl)methoxy]ethoxy]ethyl]-4-methylpiperazine" );
gibbsFormation
{
    dHf_298   -283030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1104.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=453500.0
    phase     gas;
}
