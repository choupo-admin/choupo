/*--------------------------------*- Choupo -*-----------------------*\
  Component: ang-steranthrene  (C23H18, CAS 517-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        angSteranthrene;
formula     C23H18;
CAS         517-85-1;
InChIKey    BIEKLVSBEXWOTC-UHFFFAOYSA-N;
MW          294.397;      // g/mol [origin=calculated method=formula-sum]
Tc          1108.94;      // K   [origin=predictive method=joback]
Pc          21.295;      // bar [origin=predictive method=joback]
omega       0.8860;      // -   [origin=predictive method=lee-kesler]
Tb          848.24;      // K   [origin=predictive method=joback]
HvapTb      77261.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-176.06 2.1392 -0.00187576 6.635e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 9; } { group AC; count 6; } { group ACCH2; count 2; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ang.-steranthren [german]" "4h-dibenz(fg,j)aceanthrylene, 5,5a,6,7-tetrahydro-" "ang.-steranthren" );
standardThermochemistry
{
    dHf_298   406440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=668300.0
}
