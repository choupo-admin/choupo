/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propylaniline  (C9H13N, CAS 1821-39-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propylaniline;
formula     C9H13N;
CAS         1821-39-2;
InChIKey    WKURVXXDGMYSDP-UHFFFAOYSA-N;
MW          135.21;      // g/mol [origin=calculated method=formula-sum]
Tc          730.40;      // K   [origin=predictive method=joback]
Pc          34.239;      // bar [origin=predictive method=joback]
omega       0.5124;      // -   [origin=predictive method=lee-kesler]
Tb          509.71;      // K   [origin=predictive method=joback]
HvapTb      49207.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.408 0.78232 -0.00047336 1.075e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzenamine, 2-propyl-" "2-propyl-aniline" "o-propylaniline" "2-propylbenzenamine" "o-aminopropylbenzene" "aniline, o-propyl-" "1-amino-2-propylbenzene" "aniline, 2-propyl-" "2-propylphenylamine" "pry" "2-n-propylaniline" "benzenamine, 2-propyl- (9ci)" );
standardThermochemistry
{
    dHf_298   29760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=194130.0
}
