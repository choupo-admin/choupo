/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-dicyclohexylhexane  (C18H34, CAS 1610-23-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Dicyclohexylhexane;
formula     C18H34;
CAS         1610-23-7;
InChIKey    VBQJFJRTZSWYPK-UHFFFAOYSA-N;
MW          250.47;      // g/mol [origin=calculated method=formula-sum]
Tc          859.45;      // K   [origin=predictive method=joback]
Pc          15.549;      // bar [origin=predictive method=joback]
omega       0.6065;      // -   [origin=predictive method=lee-kesler]
Tb          650.54;      // K   [origin=predictive method=joback]
HvapTb      56520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.684 1.958 -0.0011174 2.222e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 16; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH2_ring; count 10; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-cyclohexylhexylcyclohexane" "hexane, 1,6-dicyclohexyl-" "cyclohexane, 1,1'-(1,6-hexanediyl)bis-" "1,1'-hexane-1,6-diyldicyclohexane" );
gibbsFormation
{
    dHf_298   -306210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     796.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=149580.0
    phase     gas;
}
