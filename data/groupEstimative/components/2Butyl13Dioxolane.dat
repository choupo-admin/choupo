/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butyl-1,3-dioxolane  (C7H14O2, CAS 4360-76-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butyl13Dioxolane;
formula     C7H14O2;
CAS         4360-76-3;
InChIKey    KODJTPVSRWYRDF-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          624.11;      // K   [origin=predictive method=joback]
Pc          33.490;      // bar [origin=predictive method=joback]
omega       0.4265;      // -   [origin=predictive method=lee-kesler]
Tb          428.94;      // K   [origin=predictive method=joback]
HvapTb      40453.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.317 0.79452 -0.0004566 9.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 2-butyl-" );
standardThermochemistry
{
    dHf_298   -391330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     275.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-127630.0
}
