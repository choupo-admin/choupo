/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-tetrahydroquinoxaline  (C8H10N2, CAS 3476-89-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234Tetrahydroquinoxaline;
formula     C8H10N2;
CAS         3476-89-9;
InChIKey    HORKYAIEVBUXGM-UHFFFAOYSA-N;
MW          134.182;      // g/mol [origin=calculated method=formula-sum]
Tc          779.58;      // K   [origin=predictive method=joback]
Pc          48.766;      // bar [origin=predictive method=joback]
omega       0.4948;      // -   [origin=predictive method=lee-kesler]
Tb          527.08;      // K   [origin=predictive method=joback]
HvapTb      50250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.45 0.7664 -0.00048356 1.164e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetrahydro-quinoxaline" "tetrahydroquinoxaline" "quinoxaline, 1,2,3,4-tetrahydro-" "1,3,4-tetrahydroquinoxaline" "quinoxaline,2,3,4-tetrahydro-" "1,2,3,4-tetrahydro quinoxaline" );
standardThermochemistry
{
    dHf_298   179210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     314.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=351040.0
}
