/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenyl-3-pentanol  (C11H16O, CAS 1565-71-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenyl3Pentanol;
formula     C11H16O;
CAS         1565-71-5;
InChIKey    XXCPOPNECJIJIH-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          767.98;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       0.7981;      // -   [origin=predictive method=lee-kesler]
Tb          566.91;      // K   [origin=predictive method=joback]
HvapTb      57739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.198 1.12974 -0.000808 2.269e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylpentan-3-ol" "benzenemethanol, .alpha.,.alpha.-diethyl-" "benzenemethanol, a,a-diethyl-" );
gibbsFormation
{
    dHf_298   -194820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20170.0
    phase     gas;
}
