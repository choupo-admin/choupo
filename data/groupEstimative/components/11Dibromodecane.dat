/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dibromodecane  (C10H20Br2, CAS 36182-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dibromodecane;
formula     C10H20Br2;
CAS         36182-49-7;
InChIKey    HFVIYAZBVIGNAN-UHFFFAOYSA-N;
MW          300.078;      // g/mol [origin=calculated method=formula-sum]
Tc          755.48;      // K   [origin=predictive method=joback]
Pc          24.219;      // bar [origin=predictive method=joback]
omega       0.7182;      // -   [origin=predictive method=lee-kesler]
Tb          560.28;      // K   [origin=predictive method=joback]
HvapTb      50336.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.498 1.03612 -0.0006662 1.755e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(bromanyl)decane" "decane, dibromo-" );
gibbsFormation
{
    dHf_298   -202350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=59520.0
    phase     gas;
}
