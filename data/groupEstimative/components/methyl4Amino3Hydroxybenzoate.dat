/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-amino-3-hydroxybenzoate  (C8H9NO3, CAS 63435-16-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4Amino3Hydroxybenzoate;
formula     C8H9NO3;
CAS         63435-16-5;
InChIKey    OCZXDVNSNDITBS-UHFFFAOYSA-N;
MW          167.164;      // g/mol [origin=calculated method=formula-sum]
Tc          864.08;      // K   [origin=predictive method=joback]
Pc          46.977;      // bar [origin=predictive method=joback]
omega       0.8917;      // -   [origin=predictive method=lee-kesler]
Tb          625.67;      // K   [origin=predictive method=joback]
HvapTb      67402.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.01 0.78712 -0.00058072 1.716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-azanyl-3-oxidanyl-benzoate" "methyl-4-amino-3-hydroxybenzoate" "r465" "methyl 4-amino-3-hydroxybenzenecarboxylate" "3-hydroxy-4-aminobenzoic acid, methyl ester" "2-hydroxy-4-methoxycarbonylaniline;4-amino-3-hydroxybenzoic acid methyl ester;methyl 3-hydroxy-4-aminobenzoate;" );
standardThermochemistry
{
    dHf_298   -444190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-279280.0
}
