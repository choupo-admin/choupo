/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanoxytriphetol  (C27H33NO3, CAS 67-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanoxytriphetol;
formula     C27H33NO3;
CAS         67-98-1;
InChIKey    KDYQVUUCWUPJGE-UHFFFAOYSA-N;
MW          419.565;      // g/mol [origin=calculated method=formula-sum]
Tc          1291.97;      // K   [origin=predictive method=joback]
Pc          13.014;      // bar [origin=predictive method=joback]
omega       1.1873;      // -   [origin=predictive method=lee-kesler]
Tb          1053.59;      // K   [origin=predictive method=joback]
HvapTb      106094.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.645 2.37046 -0.00149732 3.463e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 13; } { group AC; count 4; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group C; count 1; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group OH; count 1; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-[2-(diethylamino)ethoxy]phenyl]-2-(4-methoxyphenyl)-1-phenyl-ethanol" "ethamoxytriphetol" "mer 25" "mer-25" "1-[4-(2-diethylaminoethoxy)phenyl]-1-phenyl-2-(p-anisyl)ethanol" "(p-2-diethylaminoethoxyphenyl)-1-phenyl-2-p-anisylethanol" "1-(p-2-diethylaminoethoxyphenyl)-1-phenyl-2-p-anisylethanol" "1-(4-(2-diethylaminoethoxy)phenyl)-1-phenyl-2-(p-anisyl)ethanol" "1-(p-(2-(diethylamino)ethoxy)phenyl)-1-phenyl-2-(p-methoxyphenyl)ethanol" "1-{4-[2-(diethylamino)ethoxy]phenyl}-2-(4-methoxyphenyl)-1-phenylethanol" "ethanol, 1-(p-(2-(diethylamino)ethoxy)phenyl)-2-(p-methoxyphenyl)-1-phenyl-" "1-(4-{[2-(diethylamino)ethyl]oxy}phenyl)-2-[4-(methyloxy)phenyl]-1-phenylethanol" );
standardThermochemistry
{
    dHf_298   -271850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     926.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=261230.0
}
