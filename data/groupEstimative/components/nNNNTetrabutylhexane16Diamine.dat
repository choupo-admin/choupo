/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,n',n'-tetrabutylhexane-1,6-diamine  (C22H48N2, CAS 27090-63-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNNNTetrabutylhexane16Diamine;
formula     C22H48N2;
CAS         27090-63-7;
InChIKey    UPPIBFVZIFKMFO-UHFFFAOYSA-N;
MW          340.64;      // g/mol [origin=calculated method=formula-sum]
Tc          894.05;      // K   [origin=predictive method=joback]
Pc          8.996;      // bar [origin=predictive method=joback]
omega       0.8359;      // -   [origin=predictive method=lee-kesler]
Tb          727.84;      // K   [origin=predictive method=joback]
HvapTb      68652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.492 2.34168 -0.0013982 3.254e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 16; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 18; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6-hexanediamine, n,n,n',n'-tetrabutyl-" "n,n,n',n'-tetrabutyl-1,6-hexanediamine" "1,6-hexanediamine, n1,n1,n6,n6-tetrabutyl-" "1,6-hexanediamine,n1,n1,n6,n6-tetrabutyl-" "n,n,n inverted exclamation marka,n inverted exclamation marka-tetrabutyl-1,6-hexanediamine" "1,6-hexanediamine,n,n,n',n'-tetrabutyl- (8ci,9ci); n,n,n',n'-tetrabutyl-1,6-hexanediamine;n,n,n',n'-tetrabutylhexamethylenediamine" );
standardThermochemistry
{
    dHf_298   -362350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1045.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=355920.0
}
