/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,5,6-tetrafluoro-4-(trifluoromethyl)phenol  (C7HF7O, CAS 2787-79-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2356Tetrafluoro4TrifluoromethylPhenol;
formula     C7HF7O;
CAS         2787-79-3;
InChIKey    HZQGKHUTYHEFBT-UHFFFAOYSA-N;
MW          234.07;      // g/mol [origin=calculated method=formula-sum]
Tc          652.37;      // K   [origin=predictive method=joback]
Pc          32.064;      // bar [origin=predictive method=joback]
omega       0.7925;      // -   [origin=predictive method=lee-kesler]
Tb          478.64;      // K   [origin=predictive method=joback]
HvapTb      42099.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.06 0.7149 -0.000663 2.422e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group ACOH; count 1; } { group ACF; count 4; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dC_ring; count 6; } { group F; count 7; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,5,6-tetrakis(fluoranyl)-4-(trifluoromethyl)phenol" "4-hydroxy-2,3,5,6-tetrafluorobenzotrifluoride" "perfluoro-p-cresol" "2,3,5,6-tetrafluoro-4-hydroxybenzotrifluoride" "alpha,alpha,alpha,2,3,5,6-heptafluoro-p-cresol" "phenol,2,3,5,6-tetrafluoro-4-(trifluoromethyl)-" "p-cresol, a,a,a,2,3,5,6-heptafluoro- (8ci);p-cresol,heptafluoro- (7ci);2,3,5,6-tetrafluoro-4-(trifluoromethyl)phenol;4-hydroxy-2,3,5,6-tetrafluorobenzotrifluoride;4-trifluoromethyl-2,3,5,6-tetrafluorophenol;heptafluoro-p-cresol;" );
standardThermochemistry
{
    dHf_298   -1555990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1433500.0
}
