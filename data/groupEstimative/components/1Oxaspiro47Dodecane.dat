/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-oxaspiro[4.7]dodecane  (C11H20O, CAS 62079-29-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Oxaspiro47Dodecane;
formula     C11H20O;
CAS         62079-29-2;
InChIKey    LDUJSEBWLVYVGC-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          766.86;      // K   [origin=predictive method=joback]
Pc          31.036;      // bar [origin=predictive method=joback]
omega       0.3544;      // -   [origin=predictive method=lee-kesler]
Tb          522.24;      // K   [origin=predictive method=joback]
HvapTb      44606.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-176.93 1.6084 -0.0013107 4.564e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group C; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group C_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-oxaspiro(4.7)dodecane" "4-oxaspiro[4.7]dodecane" );
gibbsFormation
{
    dHf_298   -258150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6740.0
    phase     gas;
}
