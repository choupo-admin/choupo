/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-1-butene  (C5H10, CAS 563-45-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl1Butene;
formula     C5H10;
CAS         563-45-1;
InChIKey    YHQXBTXEYZIYOV-UHFFFAOYSA-N;
MW          70.135;      // g/mol [origin=calculated method=formula-sum]
Tc          480.50;      // K   [origin=predictive method=joback]
Pc          36.820;      // bar [origin=predictive method=joback]
omega       0.2096;      // -   [origin=predictive method=lee-kesler]
Tb          310.24;      // K   [origin=predictive method=joback]
HvapTb      25666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.33 0.46474 -0.0002743 6.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbut-1-ene" "1-butene, 3-methyl-" "isopropylethylene" "isopentene" "vinylisopropyl" "alpha-isoamylene" "2-methyl-3-butene" "2-methyl-3-butene;3,3-dimethylpropene; 3-methyl-1-butene; isopropylethene; isopropylethylene; a-isoamylene" );
standardThermochemistry
{
    dHf_298   -26380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     336.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76620.0
}
