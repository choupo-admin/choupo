/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropoxy  (C3H7O, CAS 3958-66-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        isopropoxy;
formula     C3H7O;
CAS         3958-66-5;
InChIKey    ZOAMZFNAPHWBEN-UHFFFAOYSA-N;
role        radical;
MW          59.088;      // g/mol [origin=calculated method=formula-sum]
Tc          402.59;      // K   [origin=predictive method=joback]
Pc          52.132;      // bar [origin=predictive method=joback]
omega       0.2740;      // -   [origin=predictive method=lee-kesler]
Tb          256.60;      // K   [origin=predictive method=joback]
HvapTb      27646.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.11 0.41744 -0.0003373 1.148e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dO_oth; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-$l^{1}-oxidanylpropane" "i-propoxy" "1-methylethoxy" "1-methylethyloxy" "1-methyl ethoxy radical" "ethoxy, 1-methyl-" "i-c3h7o" );
standardThermochemistry
{
    dHf_298   -302330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     322.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-226510.0
}
