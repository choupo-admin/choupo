/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-cyclohexadecenone  (C16H28O, CAS 3100-36-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Cyclohexadecenone;
formula     C16H28O;
CAS         3100-36-5;
InChIKey    ZGEHHVDYDNXYMW-UHFFFAOYSA-N;
MW          236.399;      // g/mol [origin=calculated method=formula-sum]
Tc          968.78;      // K   [origin=predictive method=joback]
Pc          20.755;      // bar [origin=predictive method=joback]
omega       0.4682;      // -   [origin=predictive method=lee-kesler]
Tb          699.58;      // K   [origin=predictive method=joback]
HvapTb      58207.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.2 1.3521 -0.00026228 -1.908e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 13; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexadec-8-en-1-one" "8-cyclohexadecen-1-one" "8-cyclohexadecen-1-on;" "8-cyclohexadecen-1-one, (8e)-" );
gibbsFormation
{
    dHf_298   -440430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     874.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-97630.0
    phase     gas;
}
