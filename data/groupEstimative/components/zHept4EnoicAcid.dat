/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-hept-4-enoic acid  (C7H12O2, CAS 35194-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        zHept4EnoicAcid;
formula     C7H12O2;
CAS         35194-37-7;
InChIKey    KFXPOIKSDYRVKS-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          704.92;      // K   [origin=predictive method=joback]
Pc          32.690;      // bar [origin=predictive method=joback]
omega       0.6976;      // -   [origin=predictive method=lee-kesler]
Tb          509.43;      // K   [origin=predictive method=joback]
HvapTb      48298.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.057 0.73962 -0.0005134 1.475e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hept-4-enoic acid" "4-heptenoic acid" "4-heptenoic acid, (4e)-" "4(e)-hept-4-enoic acid;(e)-hept-4-enoic acid;(z)-hept-4-enoic acid;4-heptenoic acid, (z)-;" );
standardThermochemistry
{
    dHf_298   -420860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255630.0
}
