/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentafluorostyrene  (C8H3F5, CAS 653-34-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentafluorostyrene;
formula     C8H3F5;
CAS         653-34-9;
InChIKey    LVJZCPNIJXVIAT-UHFFFAOYSA-N;
MW          194.102;      // g/mol [origin=calculated method=formula-sum]
Tc          596.45;      // K   [origin=predictive method=joback]
Pc          27.326;      // bar [origin=predictive method=joback]
omega       0.5555;      // -   [origin=predictive method=lee-kesler]
Tb          427.25;      // K   [origin=predictive method=joback]
HvapTb      34233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.67 0.4264 -0.0002123 3.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group AC; count 1; } { group ACF; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group dC_ring; count 6; } { group F; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenyl-2,3,4,5,6-pentakis(fluoranyl)benzene" "2,3,4,5,6-pentafluorostyrene" "benzene, ethenylpentafluoro-" "2',3',4',5',6'-pentafluorostyrene" "1-ethenyl-2,3,4,5,6-pentafluorobenzene" "2,3,4,5,6-pentafluorovinylbenzene" "1,2,3,4,5-pentafluoro-6-vinyl-benzene" "2-(2,3,4,5,6-pentafluorophenyl)ethyl" "1,2,3,4,5-pentafluoro-6-vinylbenzene" "1,2,3,5,6-pentafluoro-4-vinylbenzene" );
standardThermochemistry
{
    dHf_298   -884390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-805470.0
}
