/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-methoxyphenoxy)ethanol  (C9H12O3, CAS 5394-57-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24MethoxyphenoxyEthanol;
formula     C9H12O3;
CAS         5394-57-0;
InChIKey    OOWGFJQYZCXHEY-UHFFFAOYSA-N;
MW          168.192;      // g/mol [origin=calculated method=formula-sum]
Tc          767.21;      // K   [origin=predictive method=joback]
Pc          34.279;      // bar [origin=predictive method=joback]
omega       0.9871;      // -   [origin=predictive method=lee-kesler]
Tb          574.20;      // K   [origin=predictive method=joback]
HvapTb      60065.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.392 0.62802 -0.00023836 -3.3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4'-methoxyphenoxy)ethanol" "2-(4-methoxyphenoxy)ethan-1-ol" "4-(2-hydroxyethoxy)anisole" "methoxyphenoxyethanol" "ethanol,2-(4-methoxyphenoxy)-" "1-(2-hydroxyethoxy)-4-methoxybenzene" );
standardThermochemistry
{
    dHf_298   -420700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-219140.0
}
