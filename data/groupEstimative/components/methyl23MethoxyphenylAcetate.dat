/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-(3-methoxyphenyl)acetate  (C10H12O3, CAS 18927-05-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl23MethoxyphenylAcetate;
formula     C10H12O3;
CAS         18927-05-4;
InChIKey    BSVIOYCZTJRBDB-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          749.66;      // K   [origin=predictive method=joback]
Pc          28.475;      // bar [origin=predictive method=joback]
omega       0.6169;      // -   [origin=predictive method=lee-kesler]
Tb          540.70;      // K   [origin=predictive method=joback]
HvapTb      50609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.101 0.69744 -0.00027876 -3.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-(3-methoxyphenyl)ethanoate" "methyl 3-methoxyphenylacetate" "benzeneacetic acid, 3-methoxy-, methyl ester" "acetic acid, (m-methoxyphenyl)-, methyl ester" "sdccgmls-0065871.p001" "3-methoxyphenylacetic acid methyl ester" "2-(3-methoxyphenyl)acetic acid methyl ester" "benzeneacetic acid,3-methoxy-, methyl ester" );
standardThermochemistry
{
    dHf_298   -474170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-279270.0
}
