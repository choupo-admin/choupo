/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dichloroadamantane  (C10H14Cl2, CAS 16104-50-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dichloroadamantane;
formula     C10H14Cl2;
CAS         16104-50-0;
InChIKey    DZLCQHWJVJXVES-UHFFFAOYSA-N;
MW          205.122;      // g/mol [origin=calculated method=formula-sum]
Tc          768.96;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.3600;      // -   [origin=predictive method=lee-kesler]
Tb          523.56;      // K   [origin=predictive method=joback]
HvapTb      43924.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-230.31 1.9678 -0.002185 9.616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group C_ring; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)adamantane" "adamantane, 1,3-dichloro" "ambscl01/020" "ambap16104-50-0" "adamantane,1,3-dichloro- (7ci,8ci);" );
standardThermochemistry
{
    dHf_298   -58830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160920.0
}
