/*--------------------------------*- Choupo -*-----------------------*\
  Component: s 1688  (C18H23N5O, CAS 30194-63-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s1688;
formula     C18H23N5O;
CAS         30194-63-9;
InChIKey    XAMHDWYQQBLUBL-UHFFFAOYSA-N;
MW          325.416;      // g/mol [origin=calculated method=formula-sum]
Tc          1189.85;      // K   [origin=predictive method=joback]
Pc          25.482;      // bar [origin=predictive method=joback]
omega       1.3523;      // -   [origin=predictive method=lee-kesler]
Tb          940.61;      // K   [origin=predictive method=joback]
HvapTb      95389.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.968 2.05596 -0.00148772 4.1576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group CH2N; count 2; } { group ACNH2; count 1; } { group C5H4N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 1; } { group N; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanyl-n-[2-(4-pyridin-2-ylpiperazin-1-yl)ethyl]benzamide" "4-amino-n-(2-(4-(2-pyridinyl)-1-piperazinyl)ethyl)benzamide" "benzamide, 4-amino-n-(2-(4-(2-pyridinyl)-1-piperazinyl)ethyl)-" "4-amino-n-[2-(4-pyridin-2-ylpiperazin-1-yl)ethyl]benzamide" );
gibbsFormation
{
    dHf_298   276250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     773.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=697760.0
    phase     gas;
}
