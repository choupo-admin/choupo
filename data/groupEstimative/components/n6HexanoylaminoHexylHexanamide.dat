/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-[6-(hexanoylamino)hexyl]hexanamide  (C18H36N2O2, CAS 21150-81-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n6HexanoylaminoHexylHexanamide;
formula     C18H36N2O2;
CAS         21150-81-2;
InChIKey    FEEWLVLWKFQOFB-UHFFFAOYSA-N;
MW          312.498;      // g/mol [origin=calculated method=formula-sum]
Tc          1007.01;      // K   [origin=predictive method=joback]
Pc          12.810;      // bar [origin=predictive method=joback]
omega       1.1471;      // -   [origin=predictive method=lee-kesler]
Tb          819.52;      // K   [origin=predictive method=joback]
HvapTb      82026.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.176 1.81024 -0.0010152 2.0592e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CONHCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group CdO; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanamide, n,n'-1,6-hexanediylbis-" );
gibbsFormation
{
    dHf_298   -533070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     991.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21620.0
    phase     gas;
}
