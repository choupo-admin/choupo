/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-nonadien-1-ol, 3,7-dimethyl-  (C11H20O, CAS 41865-30-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Nonadien1Ol37Dimethyl;
formula     C11H20O;
CAS         41865-30-9;
InChIKey    ZEUWCZMRCKECEG-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          727.07;      // K   [origin=predictive method=joback]
Pc          23.383;      // bar [origin=predictive method=joback]
omega       0.8736;      // -   [origin=predictive method=lee-kesler]
Tb          551.54;      // K   [origin=predictive method=joback]
HvapTb      56835.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.566 1.12266 -0.0007772 2.279e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH; count 2; } { group dC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethylnona-2,6-dien-1-ol" "2,6-nonadien-1-ol, 3,7-dimethyl-, (e,z)-" );
standardThermochemistry
{
    dHf_298   -207740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48260.0
}
