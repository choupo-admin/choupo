/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyl salicylate  (C10H12O3, CAS 607-85-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylSalicylate;
formula     C10H12O3;
CAS         607-85-2;
InChIKey    YEULQIJMIOWCHB-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          819.56;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.7484;      // -   [origin=predictive method=lee-kesler]
Tb          593.48;      // K   [origin=predictive method=joback]
HvapTb      60163.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.3 0.98064 -0.00071636 2.088e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl 2-oxidanylbenzoate" "isopropyl 2-hydroxybenzoate" "salicylic acid isopropyl ester" "salicylic acid, isopropyl ester" "propan-2-yl 2-hydroxybenzoate" "iso-propyl salicylate" "benzoic acid, 2-hydroxy-, 1-methylethyl ester" "isopropyl o-hydroxybenzoate" "1-methylethyl 2-hydroxybenzoate" "methylethyl 2-hydroxybenzoate" "opropyl salicylate" "2-hydroxybenzoic acid isopropyl ester" );
gibbsFormation
{
    dHf_298   -513070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-321700.0
    phase     gas;
}
