/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-nonen-2-one  (C9H16O, CAS 14309-57-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Nonen2One;
formula     C9H16O;
CAS         14309-57-0;
InChIKey    HDKLIZDXVUCLHQ-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          645.93;      // K   [origin=predictive method=joback]
Pc          25.846;      // bar [origin=predictive method=joback]
omega       0.5396;      // -   [origin=predictive method=lee-kesler]
Tb          463.55;      // K   [origin=predictive method=joback]
HvapTb      42332.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.116 0.85084 -0.0005309 1.3426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "non-3-en-2-one" "non-3-en-2-one;" "3-nonen-2-one, (3e)-" "(3e)-3-nonen-2-one;non-3-en-2-one" );
standardThermochemistry
{
    dHf_298   -224450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23800.0
}
