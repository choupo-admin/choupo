/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 12-acetyloxyoctadec-9-enoate  (C24H44O4, CAS 140-04-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl12Acetyloxyoctadec9Enoate;
formula     C24H44O4;
CAS         140-04-5;
InChIKey    BEWFIPLBFJGWSR-UHFFFAOYSA-N;
MW          396.612;      // g/mol [origin=calculated method=formula-sum]
Tc          1063.75;      // K   [origin=predictive method=joback]
Pc          8.392;      // bar [origin=predictive method=joback]
omega       0.8088;      // -   [origin=predictive method=lee-kesler]
Tb          868.88;      // K   [origin=predictive method=joback]
HvapTb      83402.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.026 2.20016 -0.0011796 2.071e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 1; } { group CH=CH; count 1; } { group CH3COO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 16; } { group CH; count 1; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-octadecenoic acid, 12-(acetyloxy)-, butyl ester, (9z,12r)-" "9-octadecenoic acid,12-(acetyloxy)-, butyl ester, (9z,12r)-" "9-octadecenoicacid, 12-(acetyloxy)-, butyl ester, [r-(z)]-;ricinoleic acid, butyl ester,acetate (6ci,7ci,8ci);bakers p 6;baryl;butyl acetyl ricinoleate;flexricin p6;" );
gibbsFormation
{
    dHf_298   -1061310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1177.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-391760.0
    phase     gas;
}
