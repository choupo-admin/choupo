/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(trimethylsilyloxy)propane  (C9H24O2Si2, CAS 17887-80-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H24O2Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13BisTrimethylsilyloxyPropane;
formula     C9H24O2Si2;
CAS         17887-80-8;
InChIKey    DWHYMKOUICVFHL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          220.459;      // g/mol [origin=calculated method=formula-sum]
Tc          627.48;      // K   [origin=predictive method=joback]
Pc          18.016;      // bar [origin=predictive method=joback]
omega       0.3987;      // -   [origin=predictive method=lee-kesler]
Tb          453.16;      // K   [origin=predictive method=joback]
HvapTb      41036.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (127.343 0.32012 0.0005858 -4.481e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group CH2O; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(3-trimethylsilyloxypropoxy)silane" "1,3 propanediol di-tms" "3,7-dioxa-2,8-disilanonane, 2,2,8,8-tetramethyl-" );
gibbsFormation
{
    dHf_298   -716770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     782.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-394620.0
    phase     gas;
}
