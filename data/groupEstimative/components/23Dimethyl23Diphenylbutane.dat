/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethyl-2,3-diphenylbutane  (C18H22, CAS 1889-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethyl23Diphenylbutane;
formula     C18H22;
CAS         1889-67-4;
InChIKey    HGTUJZTUQFXBIH-UHFFFAOYSA-N;
MW          238.374;      // g/mol [origin=calculated method=formula-sum]
Tc          907.38;      // K   [origin=predictive method=joback]
Pc          19.824;      // bar [origin=predictive method=joback]
omega       0.4719;      // -   [origin=predictive method=lee-kesler]
Tb          658.34;      // K   [origin=predictive method=joback]
HvapTb      57622.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-130.23 1.80768 -0.0013614 3.978e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,3-dimethyl-3-phenyl-butan-2-yl)benzene" "dicumene" "butane, 2,3-dimethyl-2,3-diphenyl-" "benzene, 1,1'-(1,1,2,2-tetramethyl-1,2-ethanediyl)bis-" "(2,3-dimethyl-3-phenylbutan-2-yl)benzene" "bibenzyl, .alpha.,.alpha.,.alpha.',.alpha.'-tetramethyl-" "alpha,alpha'-dicumyl" ".alpha.,.alpha.'-dicumyl" "butane,3-dimethyl-2,3-diphenyl-" "(2,3-dimethylbutane-2,3-diyl)dibenzene" "p320" "(1,1,2-trimethyl-2-phenylpropyl)benzene" );
gibbsFormation
{
    dHf_298   40710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=331180.0
    phase     gas;
}
