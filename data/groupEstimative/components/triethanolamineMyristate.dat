/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethanolamine myristate  (C20H43NO5, CAS 41669-40-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triethanolamineMyristate;
formula     C20H43NO5;
CAS         41669-40-3;
InChIKey    IHUMNXSBUOIDQI-UHFFFAOYSA-N;
MW          377.566;      // g/mol [origin=calculated method=formula-sum]
Tc          1400.20;      // K   [origin=predictive method=joback]
Pc          12.200;      // bar [origin=predictive method=joback]
omega       0.6839;      // -   [origin=predictive method=lee-kesler]
Tb          1093.09;      // K   [origin=predictive method=joback]
HvapTb      129652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.308 1.97432 -0.0009258 1.044e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group OH; count 3; } { group CH2N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group OH; count 3; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2-hydroxyethyl)amino]ethanol;tetradecanoic acid" "tea-myristate" "myristic acid, triethanolamine salt" "tris(2-hydroxyethyl)ammonium myristate" "tetradecanoic acid, compd. with 2,2',2''-nitrilotris(ethanol)" "tetradecanoic acid, compd. with 2,2',2''-nitrilotris(ethanol) (1:1)" "2-[bis(2-hydroxyethyl)amino]ethanol; tetradecanoic acid" );
gibbsFormation
{
    dHf_298   -1307180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1264.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-630830.0
    phase     gas;
}
