/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylsalicylic acid  (C8H8O3, CAS 83-40-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethylsalicylicAcid;
formula     C8H8O3;
CAS         83-40-9;
InChIKey    WHSXTWFYRGOBGO-UHFFFAOYSA-N;
MW          152.149;      // g/mol [origin=calculated method=formula-sum]
Tc          879.56;      // K   [origin=predictive method=joback]
Pc          48.766;      // bar [origin=predictive method=joback]
omega       0.9531;      // -   [origin=predictive method=lee-kesler]
Tb          640.43;      // K   [origin=predictive method=joback]
HvapTb      66518.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.31 0.83082 -0.00070452 2.457e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-2-oxidanyl-benzoic acid" "hydroxytoluic acid" "2-hydroxy-3-methylbenzoic acid" "o-cresotic acid" "o-cresotinic acid" "2-hydroxy-m-toluic acid" "o-homosalicylic acid" "cresotic acid" "2,3-cresotinic acid" "benzoic acid, 2-hydroxy-3-methyl-" "2,3-cresotic acid" "cresotinic acid" );
gibbsFormation
{
    dHf_298   -510970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-379270.0
    phase     gas;
}
