/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-2-pentyne  (C6H10, CAS 21020-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl2Pentyne;
formula     C6H10;
CAS         21020-27-9;
InChIKey    SLMFWJQZLPEDDU-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          539.27;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.1918;      // -   [origin=predictive method=lee-kesler]
Tb          345.44;      // K   [origin=predictive method=joback]
HvapTb      30714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.31 0.42996 -0.00021366 3.868e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylpent-2-yne" "2-pentyne, 4-methyl-" "isopropylmethylacetylene" "1-methyl-2-isopropylacetylene;2-methyl-3-pentyne; 4-methyl-2-pentyne; isopropylmethylacetylene;methyl(isopropyl)acetylene" );
standardThermochemistry
{
    dHf_298   99850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=200000.0
}
