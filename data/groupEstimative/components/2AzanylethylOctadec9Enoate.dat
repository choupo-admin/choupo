/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-azanylethyl octadec-9-enoate  (C20H39NO2, CAS 3282-75-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AzanylethylOctadec9Enoate;
formula     C20H39NO2;
CAS         3282-75-5;
InChIKey    VPHOSDZKGZRSAI-UHFFFAOYSA-N;
MW          325.537;      // g/mol [origin=calculated method=formula-sum]
Tc          975.25;      // K   [origin=predictive method=joback]
Pc          10.935;      // bar [origin=predictive method=joback]
omega       0.9833;      // -   [origin=predictive method=lee-kesler]
Tb          792.11;      // K   [origin=predictive method=joback]
HvapTb      78120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.426 1.93092 -0.0010968 2.281e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH=CH; count 1; } { group CH2COO; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group dCH; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "monoethanolamine oleate;9-octadecenoic acid (9z)-, compd. with 2-aminoethanol (1:1);oleic acid, 2-aminoethanol salt (6ci);9-octadecenoic acid (z)-, compd. with 2-aminoethanol;cis-9-octadecenoic acid, ethanolamine salt;oleic acid, ethanolamine salt" );
gibbsFormation
{
    dHf_298   -622400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1031.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-46180.0
    phase     gas;
}
