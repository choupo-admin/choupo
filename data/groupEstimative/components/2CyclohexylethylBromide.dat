/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexylethyl bromide  (C8H15Br, CAS 1647-26-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2CyclohexylethylBromide;
formula     C8H15Br;
CAS         1647-26-3;
InChIKey    JRQAAYVLPPGEHT-UHFFFAOYSA-N;
MW          191.112;      // g/mol [origin=calculated method=formula-sum]
Tc          688.25;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.3879;      // -   [origin=predictive method=lee-kesler]
Tb          468.35;      // K   [origin=predictive method=joback]
HvapTb      40266.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.798 0.9241 -0.0005638 1.277e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromoethylcyclohexane" "(2-bromoethyl)cyclohexane" "cyclohexane, (2-bromoethyl)-" "1-bromo-2-cyclohexylethane" "1-bromo-4-ethylbenzene;4-ethyl-1-bromobenzene;4-ethylphenylbromide;p-ethylbromobenzene;benzene,1-bromo-4-ethyl-;" );
standardThermochemistry
{
    dHf_298   -127800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55250.0
}
