/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 3-(methylthio)-, ethyl ester, (e)-  (C6H10O2S, CAS 136115-65-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid3MethylthioEthylEsterE;
formula     C6H10O2S;
CAS         136115-65-6;
InChIKey    DNNJFSSUXIAKAI-UHFFFAOYSA-N;
MW          146.204;      // g/mol [origin=calculated method=formula-sum]
Tc          673.84;      // K   [origin=predictive method=joback]
Pc          33.802;      // bar [origin=predictive method=joback]
omega       0.4825;      // -   [origin=predictive method=lee-kesler]
Tb          468.04;      // K   [origin=predictive method=joback]
HvapTb      43132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.261 0.53343 -0.0002516 2.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group COO; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 2; } { group COO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-methylsulfanylprop-2-enoate" );
standardThermochemistry
{
    dHf_298   -325360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197390.0
}
