/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyltris(trimethylsiloxy)silane  (C11H30O3Si4, CAS 5356-84-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H30O3Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        vinyltrisTrimethylsiloxySilane;
formula     C11H30O3Si4;
CAS         5356-84-3;
InChIKey    CHEFFAKKAFRMHG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          322.698;      // g/mol [origin=calculated method=formula-sum]
Tc          705.87;      // K   [origin=predictive method=joback]
Pc          13.099;      // bar [origin=predictive method=joback]
omega       0.3489;      // -   [origin=predictive method=lee-kesler]
Tb          520.82;      // K   [origin=predictive method=joback]
HvapTb      47816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (229.67 0.01458 0.0013947 -8.961e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 9; } { group CH2=CH; count 1; } { group Si; count 1; } { group SiO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl-tris(trimethylsilyloxy)silane" "vinyl tris(trimethylsiloxy)silane" "tris(trimethylsiloxy)(vinyl)silane" "1,1,1,5,5,5-hexamethyl-3-((trimethylsilyl)oxy)-3-vinyltrisiloxane" "[tris(trimethylsiloxy)silyl]ethylene" "vinyl tris(trimethylsiloxy) silane" "trisiloxane, 3-ethenyl-1,1,1,5,5,5-hexamethyl-3-((trimethylsilyl)oxy)-" "trisiloxane, 3-ethenyl-1,1,1,5,5,5-hexamethyl-3-[(trimethylsilyl)oxy]-" "trisiloxane,3-ethenyl-1,1,1,5,5,5-hexamethyl-3-[(trimethylsilyl)oxy]-" );
gibbsFormation
{
    dHf_298   -988080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1119.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-604460.0
    phase     gas;
}
