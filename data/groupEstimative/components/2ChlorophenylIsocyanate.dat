/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorophenyl isocyanate  (C7H4ClNO, CAS 3320-83-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChlorophenylIsocyanate;
formula     C7H4ClNO;
CAS         3320-83-0;
InChIKey    NOHQUGRVHSJYMR-UHFFFAOYSA-N;
MW          153.565;      // g/mol [origin=calculated method=formula-sum]
Tc          727.38;      // K   [origin=predictive method=joback]
Pc          42.330;      // bar [origin=predictive method=joback]
omega       0.4770;      // -   [origin=predictive method=lee-kesler]
Tb          495.52;      // K   [origin=predictive method=joback]
HvapTb      48031.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-isocyanato-benzene" "o-chlorophenyl isocyanate" "benzene, 1-chloro-2-isocyanato-" "isocyanic acid, o-chlorophenyl ester" "chlorophenyl isocyanate" "2-chlorophenylisocyanate" "1-chloro-2-isocyanatobenzene" "1-chloro-2-isocyanato-benzene" "isocyanic acid 2-chlorophenyl ester" "2-chlorobenzenisocyanate" "chloroisocyanatobenzene" "nohqugrvhsjymr-uhfffaoysa-" );
