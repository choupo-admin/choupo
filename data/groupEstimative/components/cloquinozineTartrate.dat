/*--------------------------------*- Choupo -*-----------------------*\
  Component: cloquinozine tartrate  (C20H28ClNO6, CAS 34255-03-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cloquinozineTartrate;
formula     C20H28ClNO6;
CAS         34255-03-3;
InChIKey    UASAQZSNMBGOSS-LREBCSMRSA-N;
MW          413.895;      // g/mol [origin=calculated method=formula-sum]
Tc          1525.69;      // K   [origin=predictive method=joback]
Pc          20.001;      // bar [origin=predictive method=joback]
omega       1.5355;      // -   [origin=predictive method=lee-kesler]
Tb          1240.92;      // K   [origin=predictive method=joback]
HvapTb      137026.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.309 2.1443 -0.00126016 2.401e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 4; } { group ACH; count 4; } { group ACCH2; count 1; } { group OH; count 2; } { group CH2N; count 1; } { group COOH; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 2; } { group COOH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3r)-2,3-bis(oxidanyl)butanedioic acid;3-[(4-chlorophenyl)methyl]-2,3,4,6,7,8,9,9a-octahydro-1h-quinolizine" "qb 1" "3-(p-chlorobenzyl)quinolizidine tartrate" "quinolizine, 3-(p-chlorobenzyl)octahydro-, tartrate (1:1)" "3-(4-chlorobenzyl)octahydro-2h-quinolizine 2,3-dihydroxybutanedioate(1:1)" "2h-quinolizine, 3-((4-chlorophenyl)methyl)octahydro-, (r-(r*,r*))-2,3-dihydroxybutanedioate (1:1)" "3-[(4-chlorophenyl)methyl]-2,3,4,6,7,8,9,9a-octahydro-1h-quinolizine; (2r,3r)-2,3-dihydroxybutanedioic acid" );
gibbsFormation
{
    dHf_298   -1179340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1047.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-666750.0
    phase     gas;
}
