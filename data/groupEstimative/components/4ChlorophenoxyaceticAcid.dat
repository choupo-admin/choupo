/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorophenoxyacetic acid  (C8H7ClO3, CAS 122-88-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorophenoxyaceticAcid;
formula     C8H7ClO3;
CAS         122-88-3;
InChIKey    SODPIMGUZLOIPE-UHFFFAOYSA-N;
MW          186.591;      // g/mol [origin=calculated method=formula-sum]
Tc          849.65;      // K   [origin=predictive method=joback]
Pc          37.408;      // bar [origin=predictive method=joback]
omega       0.8292;      // -   [origin=predictive method=lee-kesler]
Tb          619.66;      // K   [origin=predictive method=joback]
HvapTb      60299.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.001 0.6198 -0.00035756 6.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chloranylphenoxy)ethanoic acid" "4-cpa" "(4-chlorophenoxy)acetic acid" "tomatotone" "sure-set" "tomato fix" "p-chlorophenoxyacetic acid" "acetic acid, (p-chlorophenoxy)-" "acetic acid, (4-chlorophenoxy)-" "tomato hold" "4-chlorophenoxyacetate" "(p-chlorophenoxy)acetic acid" );
gibbsFormation
{
    dHf_298   -481620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-341580.0
    phase     gas;
}
