/*--------------------------------*- Choupo -*-----------------------*\
  Component: valdetamide  (C9H17NO, CAS 512-48-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        valdetamide;
formula     C9H17NO;
CAS         512-48-1;
InChIKey    LOMDVEFCNVDZMZ-UHFFFAOYSA-N;
MW          155.241;      // g/mol [origin=calculated method=formula-sum]
Tc          725.50;      // K   [origin=predictive method=joback]
Pc          27.672;      // bar [origin=predictive method=joback]
omega       0.6278;      // -   [origin=predictive method=lee-kesler]
Tb          525.37;      // K   [origin=predictive method=joback]
HvapTb      51049.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.907 0.99854 -0.0006852 1.8716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group CH2=CH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-diethylpent-4-enamide" "epinoval" "novonal" "4-pentenamide, 2,2-diethyl-" "2,2-diethyl-4-pentenamide" "diethylallylacetamide" "valdetamidum [latin]" "diaethylallylacetamide [german]" "valdetamida" "valdetamidum" "valdetamide [inn]" "diaethylallylacetamide" );
standardThermochemistry
{
    dHf_298   -191200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53110.0
}
