/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-methoxyethyl) phthalate  (C14H18O6, CAS 117-82-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2MethoxyethylPhthalate;
formula     C14H18O6;
CAS         117-82-8;
InChIKey    HSUIVCLOAAJSRE-UHFFFAOYSA-N;
MW          282.292;      // g/mol [origin=calculated method=formula-sum]
Tc          911.99;      // K   [origin=predictive method=joback]
Pc          19.407;      // bar [origin=predictive method=joback]
omega       1.0260;      // -   [origin=predictive method=lee-kesler]
Tb          712.86;      // K   [origin=predictive method=joback]
HvapTb      69330.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (72.374 0.95944 -0.00029076 -6.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-methoxyethyl) benzene-1,2-dicarboxylate" "kesscoflex mcp" "dimethylglycol phthalate" "di(2-methoxyethyl)phthalate" "methyl glycol phthalate" "dimethoxyethyl phthalate" "methox" "2-methoxyethyl phthalate" "dimethoxy ethyl phthalate" "bis(methoxyethyl) phthalate" "di(2-methoxyethyl) phthalate" "phthalic acid, di(methoxyethyl) ester" );
standardThermochemistry
{
    dHf_298   -1006230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     713.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-660960.0
}
