/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-2,5,5-trimethyl-thiazolidine-4-carboxylic acid  (C7H13NO2S, CAS 212755-85-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s255TrimethylThiazolidine4CarboxylicAcid;
formula     C7H13NO2S;
CAS         212755-85-6;
InChIKey    MQQSPQRNCBFBSG-AKGZTFGVSA-N;
MW          175.246;      // g/mol [origin=calculated method=formula-sum]
Tc          849.00;      // K   [origin=predictive method=joback]
Pc          37.963;      // bar [origin=predictive method=joback]
omega       0.7090;      // -   [origin=predictive method=lee-kesler]
Tb          607.83;      // K   [origin=predictive method=joback]
HvapTb      59398.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.73 1.09127 -0.0009369 3.571e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CHNH; count 1; } { group COOH; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group COOH; count 1; } { group NH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4s)-2,5,5-trimethyl-1,3-thiazolidine-4-carboxylic acid" "4-thiazolidinecarboxylicacid, 2,5,5-trimethyl-, (4s)-" "(4s,2rs)-2,5,5-trimethylthiazolidine-4-carboxylic acid" );
gibbsFormation
{
    dHf_298   -419970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-192640.0
    phase     gas;
}
