/*--------------------------------*- Choupo -*-----------------------*\
  Component: ecabapide  (C20H25N3O4, CAS 104775-36-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ecabapide;
formula     C20H25N3O4;
CAS         104775-36-2;
InChIKey    JTAGHJPZEDNHHA-UHFFFAOYSA-N;
MW          371.437;      // g/mol [origin=calculated method=formula-sum]
Tc          1264.22;      // K   [origin=predictive method=joback]
Pc          17.507;      // bar [origin=predictive method=joback]
omega       1.4218;      // -   [origin=predictive method=lee-kesler]
Tb          1028.59;      // K   [origin=predictive method=joback]
HvapTb      104272.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.883 1.61376 -0.00081188 1.0692e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 4; } { group ACCH2; count 1; } { group CH3O; count 2; } { group CH2NH; count 1; } { group CONHCH3; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group O; count 2; } { group CdO; count 2; } { group NH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[[2-[2-(3,4-dimethoxyphenyl)ethylamino]-2-oxidanylidene-ethyl]amino]-n-methyl-benzamide" "m-((((3,4-dimethoxyphenethyl)carbamoyl)methyl)amino)-n-methylbenzamide" "3-((2-((2-(3,4-dimethoxyphenyl)ethyl)amino)-2-oxoethyl)amino)-n-methylbenzamide" "benzamide, 3-((2-((2-(3,4-dimethoxyphenyl)ethyl)amino)-2-oxoethyl)amino)-n-methyl-" "ecabamide" "muralis" "m-[[[(3,4-dimethoxyphenethyl)carbamoyl]methyl]amino]-n-methylbenzamide" "ecabapide [inn]" "3-2-2-(3,4-dimethoxyphenyl)ethylamino-2-oxoethylamino-n-methylbenzamide" "3-[[2-[2-(3,4-dimethoxyphenyl)ethylamino]-2-oxoethyl]amino]-n-methylbenzamide" );
standardThermochemistry
{
    dHf_298   -346670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     901.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113780.0
}
