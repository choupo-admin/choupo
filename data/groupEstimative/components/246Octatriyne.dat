/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-octatriyne  (C8H6, CAS 1072-20-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Octatriyne;
formula     C8H6;
CAS         1072-20-4;
InChIKey    JINAOWUNDFEJHT-UHFFFAOYSA-N;
MW          102.136;      // g/mol [origin=calculated method=formula-sum]
Tc          659.46;      // K   [origin=predictive method=joback]
Pc          44.091;      // bar [origin=predictive method=joback]
omega       0.1429;      // -   [origin=predictive method=lee-kesler]
Tb          409.64;      // K   [origin=predictive method=joback]
HvapTb      39858.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.29 0.31444 -0.00013498 2.094e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C_C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group tC; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octa-2,4,6-triyne" "agn-pc-0ckkhm" );
gibbsFormation
{
    dHf_298   608450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=624880.0
    phase     gas;
}
