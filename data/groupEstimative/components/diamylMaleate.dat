/*--------------------------------*- Choupo -*-----------------------*\
  Component: diamyl maleate  (C14H24O4, CAS 10099-71-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diamylMaleate;
formula     C14H24O4;
CAS         10099-71-5;
InChIKey    NFCMRHDORQSGIS-UHFFFAOYSA-N;
MW          256.342;      // g/mol [origin=calculated method=formula-sum]
Tc          816.98;      // K   [origin=predictive method=joback]
Pc          16.000;      // bar [origin=predictive method=joback]
omega       0.9168;      // -   [origin=predictive method=lee-kesler]
Tb          640.52;      // K   [origin=predictive method=joback]
HvapTb      61530.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.798 1.24424 -0.0006324 8.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipentyl but-2-enedioate" "2-butenedioic acid (2z)-, 1,4-dipentyl ester" "2-butenedioic acid(2z)-, 1,4-dipentyl ester" "2-butenedioicacid (2z)-, dipentyl ester (9ci); 2-butenedioic acid (z)-, dipentyl ester;maleic acid, dipentyl ester (6ci,7ci,8ci); di-n-pentyl maleate; diamyl maleate;dipentyl maleate" );
gibbsFormation
{
    dHf_298   -849630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     797.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-473520.0
    phase     gas;
}
