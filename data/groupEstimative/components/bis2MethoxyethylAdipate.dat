/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-methoxyethyl) adipate  (C12H22O6, CAS 106-00-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2MethoxyethylAdipate;
formula     C12H22O6;
CAS         106-00-3;
InChIKey    GVRNUDCCYWKHMV-UHFFFAOYSA-N;
MW          262.302;      // g/mol [origin=calculated method=formula-sum]
Tc          807.65;      // K   [origin=predictive method=joback]
Pc          17.448;      // bar [origin=predictive method=joback]
omega       1.0153;      // -   [origin=predictive method=lee-kesler]
Tb          635.44;      // K   [origin=predictive method=joback]
HvapTb      61940.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (93.798 0.90784 -0.0002178 -9.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2COO; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-methoxyethyl) hexanedioate" "hexanedioic acid, bis(2-methoxyethyl) ester" "di[2-methoxyethyl] adipate" "adipic acid, bis(2-methoxyethyl) ester" "bis(2-methoxyethyl)adipate" "adipic acid bis(2-methoxyethyl) ester" "hexanedioic acid, 1,6-bis(2-methoxyethyl) ester" "gvrnudccywkhmv-uhfffaoysa-" "1,6-bis(2-methoxyethyl) hexanedioate" "adipic acid, bis(2-methoxyethyl) ester (8ci)" "hexanedioic acid,1,6-bis(2-methoxyethyl) ester" );
gibbsFormation
{
    dHf_298   -1190010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     748.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-780580.0
    phase     gas;
}
