/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dichloro-4,4-dimethylpentane  (C7H14Cl2, CAS 6065-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dichloro44Dimethylpentane;
formula     C7H14Cl2;
CAS         6065-90-3;
InChIKey    RJTBLHMOHNHTTP-UHFFFAOYSA-N;
MW          169.089;      // g/mol [origin=calculated method=formula-sum]
Tc          625.99;      // K   [origin=predictive method=joback]
Pc          26.653;      // bar [origin=predictive method=joback]
omega       0.3417;      // -   [origin=predictive method=lee-kesler]
Tb          430.95;      // K   [origin=predictive method=joback]
HvapTb      38262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.848 0.81416 -0.0005728 1.615e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)-4,4-dimethyl-pentane" "pentane, 1,2-dichloro-4,4-dimethyl-" );
standardThermochemistry
{
    dHf_298   -233320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15400.0
}
