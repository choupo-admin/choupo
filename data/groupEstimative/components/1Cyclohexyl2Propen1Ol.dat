/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexyl-2-propen-1-ol  (C9H16O, CAS 4352-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexyl2Propen1Ol;
formula     C9H16O;
CAS         4352-44-7;
InChIKey    BRZYZVXYQQVYNT-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          709.81;      // K   [origin=predictive method=joback]
Pc          33.220;      // bar [origin=predictive method=joback]
omega       0.7124;      // -   [origin=predictive method=lee-kesler]
Tb          513.49;      // K   [origin=predictive method=joback]
HvapTb      51678.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.28 1.0008 -0.0006033 1.322e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexylprop-2-en-1-ol" );
gibbsFormation
{
    dHf_298   -206850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2070.0
    phase     gas;
}
