/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-benzylacetoacetate  (C13H16O3, CAS 620-79-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Benzylacetoacetate;
formula     C13H16O3;
CAS         620-79-1;
InChIKey    XDWQYMXQMNUWID-UHFFFAOYSA-N;
MW          220.268;      // g/mol [origin=calculated method=formula-sum]
Tc          847.29;      // K   [origin=predictive method=joback]
Pc          23.588;      // bar [origin=predictive method=joback]
omega       0.7857;      // -   [origin=predictive method=lee-kesler]
Tb          635.37;      // K   [origin=predictive method=joback]
HvapTb      60573.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.748 1.08304 -0.0006045 1.0236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-oxidanylidene-2-(phenylmethyl)butanoate" "ethyl 2-benzyl-3-oxobutanoate" "ethyl .alpha.-benzylacetoacetate" "ethyl 2-acetyl-3-phenylpropionate" "ethyl benzyl acetoacetate" "2-acetyl-3-phenylpropionic acid ethyl ester" "2-benzylacetoacetic acid ethyl ester" "ethyl-2-benzylacetoacetate" "ethyl alpha-benzylacetoacetate" "ethyl .alpha.-acetylhydrocinnamate" );
gibbsFormation
{
    dHf_298   -510260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-270740.0
    phase     gas;
}
