/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-aminotridecane  (C13H29N, CAS 13205-57-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Aminotridecane;
formula     C13H29N;
CAS         13205-57-7;
InChIKey    WCLHZVGJULAEJH-UHFFFAOYSA-N;
MW          199.382;      // g/mol [origin=calculated method=formula-sum]
Tc          742.64;      // K   [origin=predictive method=joback]
Pc          17.347;      // bar [origin=predictive method=joback]
omega       0.7699;      // -   [origin=predictive method=lee-kesler]
Tb          569.13;      // K   [origin=predictive method=joback]
HvapTb      54785.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.12 1.30664 -0.00073 1.54e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridecan-2-amine" "2-tridecanamine" "1-methyldodecylamine" "dodecylamine,1-methyl- (6ci,7ci,8ci); 1-methyldodecylamine; 2-aminotridecane; tridecamin;tridekamin" );
gibbsFormation
{
    dHf_298   -283140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122590.0
    phase     gas;
}
