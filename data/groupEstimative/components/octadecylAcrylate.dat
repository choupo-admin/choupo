/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecyl acrylate  (C21H40O2, CAS 4813-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecylAcrylate;
formula     C21H40O2;
CAS         4813-57-4;
InChIKey    FSAJWMJJORKPKS-UHFFFAOYSA-N;
MW          324.549;      // g/mol [origin=calculated method=formula-sum]
Tc          906.03;      // K   [origin=predictive method=joback]
Pc          9.845;      // bar [origin=predictive method=joback]
omega       0.8775;      // -   [origin=predictive method=lee-kesler]
Tb          734.98;      // K   [origin=predictive method=joback]
HvapTb      69077.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.217 1.92402 -0.0010469 1.99e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CH2=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecyl prop-2-enoate" "stearyl acrylate" "2-propenoic acid, octadecyl ester" "n-octadecyl acrylate" "octadecyl 2-propenoate" "acrylic acid stearyl ester" "acrylic acid octadecyl ester" "2-propenoic acid octadecyl ester" "p540" "1-octadecanol,acrylate (5ci);acrylic acid, octadecyl ester (6ci,7ci,8ci);blemmer sa;exceparl s;light acrylate s-a;sr 257;stearyl acrylate;n-octadecyl acrylate;" );
gibbsFormation
{
    dHf_298   -668620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1020.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96590.0
    phase     gas;
}
