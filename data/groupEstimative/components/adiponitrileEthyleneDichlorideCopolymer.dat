/*--------------------------------*- Choupo -*-----------------------*\
  Component: adiponitrile, ethylene dichloride copolymer  (C8H12Cl2N2, CAS 67924-06-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        adiponitrileEthyleneDichlorideCopolymer;
formula     C8H12Cl2N2;
CAS         67924-06-5;
InChIKey    NGWOVTHRJLHVDG-UHFFFAOYSA-N;
MW          207.098;      // g/mol [origin=calculated method=formula-sum]
Tc          878.39;      // K   [origin=predictive method=joback]
Pc          20.699;      // bar [origin=predictive method=joback]
omega       0.7595;      // -   [origin=predictive method=lee-kesler]
Tb          663.06;      // K   [origin=predictive method=joback]
HvapTb      63422.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (96.216 0.4408 2.46e-05 -1.278e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2CN; count 2; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group Cl; count 2; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)ethane;hexanedinitrile" "hexanedinitrile, polymer with 1,2-dichloroethane" "1,2-dichloroethane; hexanedinitrile" );
gibbsFormation
{
    dHf_298   -21790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     654.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=154220.0
    phase     gas;
}
