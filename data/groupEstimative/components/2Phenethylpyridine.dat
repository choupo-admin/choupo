/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenethylpyridine  (C13H13N, CAS 2116-62-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenethylpyridine;
formula     C13H13N;
CAS         2116-62-3;
InChIKey    NIJWAAUHTPDGOM-UHFFFAOYSA-N;
MW          183.254;      // g/mol [origin=calculated method=formula-sum]
Tc          856.41;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       0.5233;      // -   [origin=predictive method=lee-kesler]
Tb          604.10;      // K   [origin=predictive method=joback]
HvapTb      55294.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.678 1.11476 -0.00075506 1.963e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-phenylethyl)pyridine" "pyridine, 2-(2-phenylethyl)-" "pyridine, 2-phenethyl-" "phenethyl pyridine" "2-phenethyl-pyridine" "2-picoline, alpha-benzyl-" "2-picoline, .alpha.-benzyl-" );
standardThermochemistry
{
    dHf_298   194200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=360450.0
}
