/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-undecanone  (C11H22O, CAS 112-12-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Undecanone;
formula     C11H22O;
CAS         112-12-9;
InChIKey    KYWIYKKSMDLRDC-UHFFFAOYSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          676.67;      // K   [origin=predictive method=joback]
Pc          20.456;      // bar [origin=predictive method=joback]
omega       0.6702;      // -   [origin=predictive method=lee-kesler]
Tb          505.15;      // K   [origin=predictive method=joback]
HvapTb      46826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.248 1.02084 -0.0005559 1.1066e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undecan-2-one" "methyl nonyl ketone" "ketone, methyl nonyl" "2-hendecanone" "2-oxoundecane" "nonyl methyl ketone" "methyl n-nonyl ketone" "methylnonylketone" "rue ketone" "2-undecanon" "2-undecanone (natural)" "mgk dog and cat repellent" );
standardThermochemistry
{
    dHf_298   -382950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     611.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87180.0
}
