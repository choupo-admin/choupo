/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-3-ethylpentane  (C7H15Cl, CAS 994-25-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro3Ethylpentane;
formula     C7H15Cl;
CAS         994-25-2;
InChIKey    ZOUXTTNTFFBAQN-UHFFFAOYSA-N;
MW          134.647;      // g/mol [origin=calculated method=formula-sum]
Tc          577.12;      // K   [origin=predictive method=joback]
Pc          27.469;      // bar [origin=predictive method=joback]
omega       0.3169;      // -   [origin=predictive method=lee-kesler]
Tb          393.96;      // K   [origin=predictive method=joback]
HvapTb      34265.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.057 0.80146 -0.0005492 1.53e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-3-ethyl-pentane" "pentane, 3-chloro-3-ethyl-" );
gibbsFormation
{
    dHf_298   -212300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1030.0
    phase     gas;
}
