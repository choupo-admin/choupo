/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-chloroethyl)-4-methoxybenzene  (C9H11ClO, CAS 18217-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Chloroethyl4Methoxybenzene;
formula     C9H11ClO;
CAS         18217-00-0;
InChIKey    PMIAMRAWHYEPNH-UHFFFAOYSA-N;
MW          170.636;      // g/mol [origin=calculated method=formula-sum]
Tc          710.13;      // K   [origin=predictive method=joback]
Pc          30.190;      // bar [origin=predictive method=joback]
omega       0.4735;      // -   [origin=predictive method=lee-kesler]
Tb          497.03;      // K   [origin=predictive method=joback]
HvapTb      45361.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.492 0.66402 -0.00033936 5.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-chloroethyl)-4-methoxy-benzene" "4-(2-chloroethyl)anisole" "p-(2-chloro)ethyl anisole" "2-(4-methoxyphenyl)ethylchloride" "4-methoxy-2-phenylethyl chloride" "2-(4-methoxyphenyl)-ethylchloride" "4-(2-chloroethyl)phenyl methyl ether" "benzene, 1-(2-chloroethyl)-4-methoxy-" "n069" "anisole,p-(2-chloroethyl)- (6ci,8ci);1-(2-chloroethyl)-4-methoxybenzene;1-chloro-2-(4-methoxyphenyl)ethane;2-(4-methoxyphenyl)ethylchloride;4-(2-chloroethyl)anisole;4-methoxyphenethyl chloride;p-(2-chloroethyl)anisole;p-methoxyphenethyl chloride;" );
gibbsFormation
{
    dHf_298   -151990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10750.0
    phase     gas;
}
