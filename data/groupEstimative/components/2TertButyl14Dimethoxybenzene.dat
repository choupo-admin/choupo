/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tert-butyl-1,4-dimethoxybenzene  (C12H18O2, CAS 21112-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TertButyl14Dimethoxybenzene;
formula     C12H18O2;
CAS         21112-37-8;
InChIKey    ALVJDUNBMKMTDC-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          762.71;      // K   [origin=predictive method=joback]
Pc          23.025;      // bar [origin=predictive method=joback]
omega       0.5369;      // -   [origin=predictive method=lee-kesler]
Tb          552.41;      // K   [origin=predictive method=joback]
HvapTb      49430.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.2 0.9454 -0.00047592 6.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tert-butyl-1,4-dimethoxy-benzene" "benzene, 2-tert-butyl-1,4-dimethoxy-" "benzene, 2-(1,1-dimethylethyl)-1,4-dimethoxy-" "dimethoxy-1,4-tert-butyl-2-benzene" "2-t-butyl-1,4-dimethoxybenzene" "benzene,2-(1,1-dimethylethyl)-1,4-dimethoxy-" "benzene,2-tert-butyl-1,4-dimethoxy- (6ci,8ci); 1,4-dimethoxy-2-tert-butylbenzene;2-tert-butyl-1,4-dimethoxybenzene; compound 77b; mono-tert-butylhydroquinonedimethyl ether" );
gibbsFormation
{
    dHf_298   -350610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-63850.0
    phase     gas;
}
