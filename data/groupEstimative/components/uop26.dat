/*--------------------------------*- Choupo -*-----------------------*\
  Component: uop 26  (C18H28N2, CAS 4175-38-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        uop26;
formula     C18H28N2;
CAS         4175-38-6;
InChIKey    AIMXDOGPMWDCDF-UHFFFAOYSA-N;
MW          272.436;      // g/mol [origin=calculated method=formula-sum]
Tc          1029.24;      // K   [origin=predictive method=joback]
Pc          20.774;      // bar [origin=predictive method=joback]
omega       0.8192;      // -   [origin=predictive method=lee-kesler]
Tb          782.54;      // K   [origin=predictive method=joback]
HvapTb      72330.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-166.71 1.972 -0.00117876 2.438e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group ACH; count 4; } { group AC; count 2; } { group CHNH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n4-dicyclohexylbenzene-1,4-diamine" "1,4-benzenediamine, n,n'-dicyclohexyl-" "n,n'-dicyclohexyl-p-phenylenediamine" "n,n'-dicyclohexyl-4-phenylenediamine" "p-phenylenediamine, n,n'-dicyclohexyl-" "1,4-benzenediamine, n1,n4-dicyclohexyl-" "1-n,4-n-dicyclohexylbenzene-1,4-diamine" );
standardThermochemistry
{
    dHf_298   25790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     764.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=431140.0
}
