/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tert-butyl-4-fluorobenzene  (C10H13F, CAS 701-30-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButyl4Fluorobenzene;
formula     C10H13F;
CAS         701-30-4;
InChIKey    ISXPXFQBHNIYCU-UHFFFAOYSA-N;
MW          152.212;      // g/mol [origin=calculated method=formula-sum]
Tc          664.40;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       0.3498;      // -   [origin=predictive method=lee-kesler]
Tb          456.10;      // K   [origin=predictive method=joback]
HvapTb      38679.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.19 0.95306 -0.00067256 1.859e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-4-fluoranyl-benzene" "4-tert-butylfluorobenzene" "4-butylfluorobenzene" "4-t-butylfluorobenzene" "1-tert-butyl-4-fluorobenzene," "1-(tert-butyl)-4-fluorobenzene" );
gibbsFormation
{
    dHf_298   -229530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55870.0
    phase     gas;
}
