/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butene-1, n,n,n',n'-tetraethyl-, (e)-  (C12H26N2, CAS 105-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butene1NNNNTetraethylE;
formula     C12H26N2;
CAS         105-17-9;
InChIKey    GTSWSDCAOQCBEH-MDZDMXLPSA-N;
MW          198.354;      // g/mol [origin=calculated method=formula-sum]
Tc          668.49;      // K   [origin=predictive method=joback]
Pc          18.547;      // bar [origin=predictive method=joback]
omega       0.6727;      // -   [origin=predictive method=lee-kesler]
Tb          503.20;      // K   [origin=predictive method=joback]
HvapTb      46350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.584 1.41168 -0.000938 2.538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH=CH; count 1; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group dCH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-n,n,n',n'-tetraethylbut-2-ene-1,4-diamine" "(e)-n,n,n',n'-tetraethyl-2-butene-1,4-diamine" "2-butene-1,4-diamine, n,n,n',n'-tetraethyl-, (2e)-" "2-butene-1,4-diamine, n1,n1,n4,n4-tetraethyl-, (2e)-" "[(e)-4-diethylaminobut-2-enyl]-diethyl-amine" "2-butene-1,4-diamine, n,n,n',n'-tetraethyl-, (e)- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -38730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     649.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=351940.0
}
