/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(trifluoromethyl)benzyl bromide  (C8H6BrF3, CAS 402-49-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TrifluoromethylBenzylBromide;
formula     C8H6BrF3;
CAS         402-49-3;
InChIKey    IKSNDOVDVVPSMA-UHFFFAOYSA-N;
MW          239.034;      // g/mol [origin=calculated method=formula-sum]
Tc          683.44;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.4876;      // -   [origin=predictive method=lee-kesler]
Tb          475.04;      // K   [origin=predictive method=joback]
HvapTb      39028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.999 0.8248 -0.00066796 2.074e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group Br; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(bromomethyl)-4-(trifluoromethyl)benzene" "4-trifluoromethylbenzyl bromide" "4-(bromomethyl)benzotrifluoride" "p-trifluoromethylbenzyl bromide" "4-(trifluoromethyl)benzylbromide" "fxffr d1e" "p-(trifluoromethyl)benzyl bromide" "alpha'-bromo-alpha,alpha,alpha-trifluoro-p-xylene" "4-trifluoromethylbenzylbromide" "benzene, 1-(bromomethyl)-4-(trifluoromethyl)-" "wt188" "4-(trifluoromethyl) benzyl bromide" );
gibbsFormation
{
    dHf_298   -554140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-448010.0
    phase     gas;
}
