/*--------------------------------*- Choupo -*-----------------------*\
  Component: anilinephthalein  (C20H16N2O2, CAS 509-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anilinephthalein;
formula     C20H16N2O2;
CAS         509-77-3;
InChIKey    PLYHMRQAXIKUIV-UHFFFAOYSA-N;
MW          316.36;      // g/mol [origin=calculated method=formula-sum]
Tc          1226.35;      // K   [origin=predictive method=joback]
Pc          26.407;      // bar [origin=predictive method=joback]
omega       1.1924;      // -   [origin=predictive method=lee-kesler]
Tb          953.90;      // K   [origin=predictive method=joback]
HvapTb      96035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-125.71 2.0196 -0.00179448 6.506e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 12; } { group AC; count 4; } { group ACNH2; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group COO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(4-aminophenyl)-2-benzofuran-1-one" "1(3h)-isobenzofuranone, 3,3-bis(4-aminophenyl)-" "3,3-bis(4-aminophenyl)-2-benzofuran-1(3h)-one" "3,3-bis-(4-amino-phenyl)-3h-isobenzofuran-1-one" "3,3-bis(4-aminophenyl)phthalide" "3,3-bis(4-aminophenyl)-3-hydroisobenzofuran-1-one" );
standardThermochemistry
{
    dHf_298   69710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     691.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=327850.0
}
