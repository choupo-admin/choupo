/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropane, 1,1-diethynyl-  (C7H6, CAS 72323-66-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropane11Diethynyl;
formula     C7H6;
CAS         72323-66-1;
InChIKey    NYLVKOBKPNQZTK-UHFFFAOYSA-N;
MW          90.125;      // g/mol [origin=calculated method=formula-sum]
Tc          563.92;      // K   [origin=predictive method=joback]
Pc          49.663;      // bar [origin=predictive method=joback]
omega       0.1485;      // -   [origin=predictive method=lee-kesler]
Tb          346.98;      // K   [origin=predictive method=joback]
HvapTb      29654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.15 0.9238 -0.00110166 5.0618e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 2; } { group tC; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diethynylcyclopropane" );
gibbsFormation
{
    dHf_298   484030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=509460.0
    phase     gas;
}
