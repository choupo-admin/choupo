/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrakis(bis(2-hydroxyethyl)ammonium) ethylenediaminetetraacetate  (C14H27N3O10, CAS 60816-64-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrakisBis2HydroxyethylAmmoniumEthylenediaminetetraacetate;
formula     C14H27N3O10;
CAS         60816-64-0;
InChIKey    HFYFQWAWAXTQMX-UHFFFAOYSA-N;
MW          397.381;      // g/mol [origin=calculated method=formula-sum]
Tc          1788.73;      // K   [origin=predictive method=joback]
Pc          22.654;      // bar [origin=predictive method=joback]
omega       0.8906;      // -   [origin=predictive method=lee-kesler]
Tb          1362.77;      // K   [origin=predictive method=joback]
HvapTb      159588.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.37 1.7228 -0.000948 1.551e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group OH; count 2; } { group CH2NH; count 1; } { group CH2N; count 2; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group OH; count 2; } { group COOH; count 4; } { group NH; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[bis(2-hydroxy-2-oxoethyl)amino]ethyl-(2-hydroxy-2-oxoethyl)amino]ethanoic acid;2-(2-hydroxyethylamino)ethanol" "2,2',2'',2'''-(ethane-1,2-diyldinitrilo)tetraacetic acid - 2,2'-iminodiethanol (1:1)" "n,n'-1,2-ethanediylbis(n-carboxymethylglycine), 2,2'-iminobis(ethanol) salt (1:4)" "2-[2-[bis(carboxymethyl)amino]ethyl-(carboxymethyl)amino]acetic acid; 2-(2-hydroxyethylamino)ethanol" "glycine, n,n'-1,2-ethanediylbis(n-(carboxymethyl)-, compd. with 2,2'-iminobis(ethanol) (1:4)" );
standardThermochemistry
{
    dHf_298   -1960920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1196.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1376090.0
}
