/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1757471  (C5H7F5O2, CAS 337-28-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1757471;
formula     C5H7F5O2;
CAS         337-28-0;
InChIKey    CPCMQYHVJRQUGX-UHFFFAOYSA-N;
MW          194.099;      // g/mol [origin=calculated method=formula-sum]
Tc          563.32;      // K   [origin=predictive method=joback]
Pc          30.796;      // bar [origin=predictive method=joback]
omega       0.8568;      // -   [origin=predictive method=lee-kesler]
Tb          418.05;      // K   [origin=predictive method=joback]
HvapTb      38748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.961 0.76612 -0.0005964 1.746e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2O; count 1; } { group CF3; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group C; count 2; } { group F; count 5; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxy-2,2,3,3,3-pentakis(fluoranyl)propan-1-ol" "1-ethoxy-2,2,3,3,3-pentafluoropropan-1-ol" "1-propanol, 1-ethoxy-2,2,3,3,3-pentafluoro-" "1-ethoxy-2,2,3,3,3-pentafluoro-1-propanol" "1-propanol,1-ethoxy-2,2,3,3,3-pentafluoro-" "pentafluoropropionaldehyde ethyl hemiacetal;1-ethoxy-2,2,3,3,3-pentafluoro-1-propanol;1-ethoxy-2,2,3,3,3-pentafluoropropan-1-ol" );
gibbsFormation
{
    dHf_298   -1434310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1221410.0
    phase     gas;
}
