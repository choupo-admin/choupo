/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,8-dimethylnona-3,7-dien-2-ol  (C11H20O, CAS 67845-50-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        48Dimethylnona37Dien2Ol;
formula     C11H20O;
CAS         67845-50-5;
InChIKey    NYPOJSCNHYUZRG-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          729.93;      // K   [origin=predictive method=joback]
Pc          23.565;      // bar [origin=predictive method=joback]
omega       0.8391;      // -   [origin=predictive method=lee-kesler]
Tb          551.10;      // K   [origin=predictive method=joback]
HvapTb      56447.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.248 1.12858 -0.0007804 2.274e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } { group dC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-nonadien-2-ol, 4,8-dimethyl-, (e)-" "3,7-nonadien-2-ol, 4,8-dimethyl-, (z)-" );
standardThermochemistry
{
    dHf_298   -213020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     604.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45820.0
}
