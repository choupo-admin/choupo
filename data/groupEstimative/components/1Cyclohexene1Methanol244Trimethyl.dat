/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexene-1-methanol, 2,4,4-trimethyl-  (C10H18O, CAS 103985-40-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexene1Methanol244Trimethyl;
formula     C10H18O;
CAS         103985-40-6;
InChIKey    BIZXZBCIHICFGV-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          746.67;      // K   [origin=predictive method=joback]
Pc          29.861;      // bar [origin=predictive method=joback]
omega       0.7767;      // -   [origin=predictive method=lee-kesler]
Tb          549.49;      // K   [origin=predictive method=joback]
HvapTb      55427.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.129 1.22686 -0.0010174 3.796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group OH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,4,4-trimethylcyclohexen-1-yl)methanol" );
gibbsFormation
{
    dHf_298   -297560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-73840.0
    phase     gas;
}
