/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,4,5-tetrakis(bromomethyl)benzene  (C10H10Br4, CAS 15442-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1245TetrakisBromomethylBenzene;
formula     C10H10Br4;
CAS         15442-91-8;
InChIKey    UTXIKCCNBUIWPT-UHFFFAOYSA-N;
MW          449.806;      // g/mol [origin=calculated method=formula-sum]
Tc          995.00;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.9363;      // -   [origin=predictive method=lee-kesler]
Tb          734.66;      // K   [origin=predictive method=joback]
HvapTb      67856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.554 0.8492 -0.00063588 1.95e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH2; count 4; } { group Br; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4,5-tetra(bromomethyl)benzene" "benzene, 1,2,4,5-tetrakis(bromomethyl)-" "alpha,alpha',alpha'',alpha'''-tetrabromodurene" "tetrabromodurene;benzene,1,2,4,5-tetrakis(bromomethyl)-;" "a," "a inverted exclamation marka," "a inverted exclamation marka inverted exclamation marka," "a inverted exclamation marka inverted exclamation marka inverted exclamation marka-tetrabromodurene" );
standardThermochemistry
{
    dHf_298   57710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=174120.0
}
