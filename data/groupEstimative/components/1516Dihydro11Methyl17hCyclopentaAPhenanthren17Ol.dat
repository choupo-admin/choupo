/*--------------------------------*- Choupo -*-----------------------*\
  Component: 15,16-dihydro-11-methyl-17h-cyclopenta(a)phenanthren-17-ol  (C18H16O, CAS 40951-13-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1516Dihydro11Methyl17hCyclopentaAPhenanthren17Ol;
formula     C18H16O;
CAS         40951-13-1;
InChIKey    CMGSCNRFRLIEPI-UHFFFAOYSA-N;
MW          248.325;      // g/mol [origin=calculated method=formula-sum]
Tc          1025.78;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       1.1410;      // -   [origin=predictive method=lee-kesler]
Tb          794.92;      // K   [origin=predictive method=joback]
HvapTb      80458.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.02 1.57442 -0.00124248 4.002e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 7; } { group AC; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 7; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-methyl-16,17-dihydro-15h-cyclopenta[a]phenanthren-17-ol" );
standardThermochemistry
{
    dHf_298   78510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=311800.0
}
