/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,2,6-tetramethylaniline,4-fluoro  (C10H14FN, CAS 14994-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nN26Tetramethylaniline4Fluoro;
formula     C10H14FN;
CAS         14994-35-5;
InChIKey    JRZLRKWQJXPFTG-UHFFFAOYSA-N;
MW          167.227;      // g/mol [origin=calculated method=formula-sum]
Tc          677.06;      // K   [origin=predictive method=joback]
Pc          26.598;      // bar [origin=predictive method=joback]
omega       0.5045;      // -   [origin=predictive method=lee-kesler]
Tb          481.73;      // K   [origin=predictive method=joback]
HvapTb      43342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.81 0.83218 -0.00047928 1.016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 2; } { group CH3N; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-fluoranyl-n,n,2,6-tetramethyl-aniline" "4-fluoro-n,n,2,6-tetramethylaniline" "n,n,2,6-tetramethylaniline, 4-fluoro-" );
gibbsFormation
{
    dHf_298   -176190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32810.0
    phase     gas;
}
