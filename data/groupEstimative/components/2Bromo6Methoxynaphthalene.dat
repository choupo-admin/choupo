/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-6-methoxynaphthalene  (C11H9BrO, CAS 5111-65-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo6Methoxynaphthalene;
formula     C11H9BrO;
CAS         5111-65-9;
InChIKey    AYFJBMBVXWNYLT-UHFFFAOYSA-N;
MW          237.096;      // g/mol [origin=calculated method=formula-sum]
Tc          842.68;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.5991;      // -   [origin=predictive method=lee-kesler]
Tb          595.48;      // K   [origin=predictive method=joback]
HvapTb      54165.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.17 0.82222 -0.00056884 1.558e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } { group CH3O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-6-methoxy-naphthalene" "6-methoxy-2-bromonaphthalene" "naphthalene, 2-bromo-6-methoxy-" "2-bromo-6-methoxynapthalene" "6-bromo-2-methoxynaphthalene" "2-bromo-6-methoxy-naphthalene" "bromo(2-)-6-methoxy naphthalene" "(6-brom-2-naphthyl)-methyl ether" "2-bromo-6-methoxy napthalene" "6-bromo-2-naphthylmethylether" "2-bromo-6-methoxy naphthalene" "6-bromo-2-methoxy naphthalene" );
standardThermochemistry
{
    dHf_298   28400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=150860.0
}
