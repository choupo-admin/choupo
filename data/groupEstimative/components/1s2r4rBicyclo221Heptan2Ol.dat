/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1s,2r,4r)-bicyclo[2.2.1]heptan-2-ol  (C7H12O, CAS 61277-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1s2r4rBicyclo221Heptan2Ol;
formula     C7H12O;
CAS         61277-90-5;
InChIKey    ZQTYQMYDIHMKQB-DSYKOEDSSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          658.00;      // K   [origin=predictive method=joback]
Pc          41.839;      // bar [origin=predictive method=joback]
omega       0.6725;      // -   [origin=predictive method=lee-kesler]
Tb          465.02;      // K   [origin=predictive method=joback]
HvapTb      47544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.85 0.9685 -0.000726 2.224e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,3r,4s)-bicyclo[2.2.1]heptan-3-ol" "(+)-endo-2-norborneol" );
standardThermochemistry
{
    dHf_298   -220940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     276.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-27070.0
}
