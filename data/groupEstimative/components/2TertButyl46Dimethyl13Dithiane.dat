/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tert-butyl-4,6-dimethyl-1,3-dithiane  (C10H20S2, CAS 22425-92-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TertButyl46Dimethyl13Dithiane;
formula     C10H20S2;
CAS         22425-92-9;
InChIKey    MFVZIKOLBGYKSR-UHFFFAOYSA-N;
MW          204.39;      // g/mol [origin=calculated method=formula-sum]
Tc          768.67;      // K   [origin=predictive method=joback]
Pc          24.219;      // bar [origin=predictive method=joback]
omega       0.3180;      // -   [origin=predictive method=lee-kesler]
Tb          531.04;      // K   [origin=predictive method=joback]
HvapTb      47993.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.76 1.17762 -0.0006996 1.505e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CHS; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group C; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tert-butyl,cis-4,cis-6-dimethyl-1,3-dithiane" "2-tert-butyl-cis-4,cis-6-dimethyl-1,3-dithiane" "(4r,6s)-2-tert-butyl-4,6-dimethyl-1,3-dithiane" );
standardThermochemistry
{
    dHf_298   -154320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124910.0
}
