/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-bis(ethylcyclohexyl)ethane  (C18H34, CAS 98803-07-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11BisEthylcyclohexylEthane;
formula     C18H34;
CAS         98803-07-7;
InChIKey    HXBDGYWGALHERR-UHFFFAOYSA-N;
MW          250.47;      // g/mol [origin=calculated method=formula-sum]
Tc          879.47;      // K   [origin=predictive method=joback]
Pc          16.824;      // bar [origin=predictive method=joback]
omega       0.5003;      // -   [origin=predictive method=lee-kesler]
Tb          650.58;      // K   [origin=predictive method=joback]
HvapTb      53830.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-246.348 2.54776 -0.0021858 8.177e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 10; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-1-[1-(1-ethylcyclohexyl)ethyl]cyclohexane" "1,1'-ethane-1,1-diylbis(1-ethylcyclohexane)" );
standardThermochemistry
{
    dHf_298   -281010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     925.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136160.0
}
