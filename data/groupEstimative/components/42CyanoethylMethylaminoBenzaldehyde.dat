/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[(2-cyanoethyl)methylamino]benzaldehyde  (C11H12N2O, CAS 94-21-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H12N2O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        42CyanoethylMethylaminoBenzaldehyde;
formula     C11H12N2O;
CAS         94-21-3;
InChIKey    DNRTTXXWWAKULZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          188.23;      // g/mol [origin=calculated method=formula-sum]
Tc          791.36;      // K   [origin=predictive method=joback]
Pc          26.543;      // bar [origin=predictive method=joback]
omega       0.6159;      // -   [origin=predictive method=lee-kesler]
Tb          573.88;      // K   [origin=predictive method=joback]
HvapTb      53166.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.908 0.97722 -0.00077336 2.481e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH3N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(4-methanoylphenyl)-methyl-amino]propanenitrile" "4-((2-cyanoethyl)methylamino)benzaldehyde" "3-[(4-formylphenyl)(methyl)amino]propanenitrile" "propanenitrile, 3-[(4-formylphenyl)methylamino]-" "3-[(4-formylphenyl)methylamino]propanenitrile" "3-((4-formylphenyl)(methyl)amino)propanenitrile" "propanenitrile, 3-((4-formylphenyl)methylamino)-" "i651" "n-methyl-n-cyanoethyl-p-amino benzaldehyde" "3-(4-formyl-n-methylanilino)propanenitrile" "3-((4-formylphenyl)methylamino)propiononitrile" "p-in-(2-cyanoethyl)-methylamino)-benzaldehyde" );
standardThermochemistry
{
    dHf_298   263550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=432440.0
}
