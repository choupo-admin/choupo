/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 1-methylpipecolinate  (C9H17NO2, CAS 30727-18-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl1Methylpipecolinate;
formula     C9H17NO2;
CAS         30727-18-5;
InChIKey    ZICBNHLULHJETL-UHFFFAOYSA-N;
MW          171.24;      // g/mol [origin=calculated method=formula-sum]
Tc          686.82;      // K   [origin=predictive method=joback]
Pc          27.730;      // bar [origin=predictive method=joback]
omega       0.5563;      // -   [origin=predictive method=lee-kesler]
Tb          491.46;      // K   [origin=predictive method=joback]
HvapTb      45335.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.059 1.05964 -0.0006112 1.157e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 1-methylpiperidine-2-carboxylate" "ethyl n-methylpipecolinate" "ethyl 1-methyl-2-piperidinecarboxylate" "ethyl 1-methylpipecolate" "zicbnhlulhjetl-uhfffaoysa-" "1-methylpipecolic acid ethyl ester" "1-methylpipecolinic acid ethyl ester" "methyl 1-methyl piperidine-2-carboxylate" "s939" "1-methyl-2-piperidinecarboxylic acid ethyl ester" "2-piperidinecarboxylic acid, 1-methyl-, ethyl ester" "pipecolicacid, 1-methyl-, ethyl ester (6ci,7ci,8ci);ethyl 1-methylpipecolate;" );
standardThermochemistry
{
    dHf_298   -418360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-138140.0
}
