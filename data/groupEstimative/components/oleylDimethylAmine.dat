/*--------------------------------*- Choupo -*-----------------------*\
  Component: oleyl dimethyl amine  (C20H41N, CAS 14727-68-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oleylDimethylAmine;
formula     C20H41N;
CAS         14727-68-5;
InChIKey    DCNHQNGFLVPROM-UHFFFAOYSA-N;
MW          295.555;      // g/mol [origin=calculated method=formula-sum]
Tc          838.26;      // K   [origin=predictive method=joback]
Pc          10.487;      // bar [origin=predictive method=joback]
omega       0.8355;      // -   [origin=predictive method=lee-kesler]
Tb          673.80;      // K   [origin=predictive method=joback]
HvapTb      62115.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.165 2.04776 -0.0012606 3.116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH=CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 15; } { group dCH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyloctadec-9-en-1-amine" "9-octadecen-1-amine, n,n-dimethyl-, (9z)-" "octadecen-1-amine,n,n-dimethyl-" "octadecenylamine,n,n-dimethyl- (7ci,8ci);" );
gibbsFormation
{
    dHf_298   -271380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     944.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=308520.0
    phase     gas;
}
