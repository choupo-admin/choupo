/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(6-methyl-3-cyclohexenemethyl) adipate  (C22H34O4, CAS 68555-34-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis6Methyl3CyclohexenemethylAdipate;
formula     C22H34O4;
CAS         68555-34-0;
InChIKey    FVBFUZKTISMNMG-UHFFFAOYSA-N;
MW          362.51;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.17;      // K   [origin=predictive method=joback]
Pc          11.858;      // bar [origin=predictive method=joback]
omega       0.9091;      // -   [origin=predictive method=lee-kesler]
Tb          847.48;      // K   [origin=predictive method=joback]
HvapTb      80204.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.064 2.06344 -0.00100956 1.076e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 4; } { group CH=CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH2_ring; count 4; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[(6-methylcyclohex-3-en-1-yl)methyl] hexanedioate" "bis((6-methylcyclohex-3-enyl)methyl) adipate" "adipic acid, 6-methyl-3-cyclohexenyl-methanol diester" "adipic acid, diester with 6-methyl-3-cyclohexene-1-methanol" "hexanedioic acid bis[(6-methyl-3-cyclohexen-1-yl)methyl] ester" "hexanedioic acid, bis((6-methyl-3-cyclohexen-1-yl)methyl) ester" "hexanedioic acid, bis[(6-methyl-3-cyclohexen-1-yl)methyl] ester" "hexanedioic acid, 1,6-bis((6-methyl-3-cyclohexen-1-yl)methyl) ester" "hexanedioic acid, 1,6-bis[(6-methyl-3-cyclohexen-1-yl)methyl] ester" );
standardThermochemistry
{
    dHf_298   -948450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     895.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-392980.0
}
