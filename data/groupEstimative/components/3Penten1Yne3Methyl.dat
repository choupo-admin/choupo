/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-penten-1-yne, 3-methyl-  (C6H8, CAS 1574-33-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Penten1Yne3Methyl;
formula     C6H8;
CAS         1574-33-0;
InChIKey    GRGVQLWQXHFRHO-UHFFFAOYSA-N;
MW          80.13;      // g/mol [origin=calculated method=formula-sum]
Tc          520.35;      // K   [origin=predictive method=joback]
Pc          39.605;      // bar [origin=predictive method=joback]
omega       0.1839;      // -   [origin=predictive method=lee-kesler]
Tb          331.04;      // K   [origin=predictive method=joback]
HvapTb      28846.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.66 0.49984 -0.00038463 1.2779e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylpent-3-en-1-yne" );
standardThermochemistry
{
    dHf_298   232160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=294380.0
}
