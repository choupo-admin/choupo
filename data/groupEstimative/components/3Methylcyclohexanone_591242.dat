/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylcyclohexanone  (C7H12O, CAS 591-24-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylcyclohexanone;
formula     C7H12O;
CAS         591-24-2;
InChIKey    UJBOOUHRTQVGRU-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          670.95;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       0.3261;      // -   [origin=predictive method=lee-kesler]
Tb          447.13;      // K   [origin=predictive method=joback]
HvapTb      35852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.65 0.62262 -0.000194 -3.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylcyclohexan-1-one" "cyclohexanone, 3-methyl-" "3-methyl cyclohexanone" "(+)-(3r)-3-methylcyclohexanone" "cyclohexanone, 3-methyl-, (r)-" "cyclohexanone, 3-methyl-, (s)-" "methyl-3 cyclohexanone-1 [french]" "tetrahydro-m-cresol" "methyl-3 cyclohexanone-1" "agn-pc-00ejpi" "m-methylcyclohexanone" "3-methyl-cyclohexan-1-one" );
gibbsFormation
{
    dHf_298   -271190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     319.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90080.0
    phase     gas;
}
