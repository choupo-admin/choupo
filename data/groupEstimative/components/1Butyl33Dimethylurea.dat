/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butyl-3,3-dimethylurea  (C7H16N2O, CAS 52696-91-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butyl33Dimethylurea;
formula     C7H16N2O;
CAS         52696-91-0;
InChIKey    XJQKHXXRLQIHMS-UHFFFAOYSA-N;
MW          144.218;      // g/mol [origin=calculated method=formula-sum]
Tc          654.76;      // K   [origin=predictive method=joback]
Pc          30.323;      // bar [origin=predictive method=joback]
omega       0.7027;      // -   [origin=predictive method=lee-kesler]
Tb          476.24;      // K   [origin=predictive method=joback]
HvapTb      46401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.017 0.84096 -0.0004995 1.1096e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2NH; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-butyl-1,1-dimethyl-urea" "3-butyl-1,1-dimethylurea" "1-butyl-3,3-dimethyl urea" "(dimethylamino)-n-butylcarboxamide" "1-(n-butyl)-3,3-dimethyl urea" );
standardThermochemistry
{
    dHf_298   -179390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79310.0
}
