/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dichloro-1-propene  (C3H4Cl2, CAS 78-88-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dichloro1Propene;
formula     C3H4Cl2;
CAS         78-88-6;
InChIKey    FALCMQXTWHPRIH-UHFFFAOYSA-N;
MW          110.965;      // g/mol [origin=calculated method=formula-sum]
Tc          530.10;      // K   [origin=predictive method=joback]
Pc          42.552;      // bar [origin=predictive method=joback]
omega       0.2295;      // -   [origin=predictive method=lee-kesler]
Tb          339.66;      // K   [origin=predictive method=joback]
HvapTb      30452.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.261 0.2823 -0.0002054 6.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group CH2Cl; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(chloranyl)prop-1-ene" "2,3-dichloropropene" "2,3-dichloropropylene" "2-chloroallyl chloride" "2,3-dichloroprop-1-ene" "1-propene, 2,3-dichloro-" "propene, 2,3-dichloro-" "propylene, 2,3-dichloro" "1,2-dichloro-2-propene" "2,3-dichloro-propene" "2-hydroxy-2-(trifluoromethyl)butanoic acid;" );
gibbsFormation
{
    dHf_298   -21090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29810.0
    phase     gas;
}
