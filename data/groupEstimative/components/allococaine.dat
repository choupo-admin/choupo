/*--------------------------------*- Choupo -*-----------------------*\
  Component: allococaine  (C17H21NO4, CAS 50-36-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allococaine;
formula     C17H21NO4;
CAS         50-36-2;
InChIKey    ZPUCINDJVBIVPJ-UHFFFAOYSA-N;
MW          303.358;      // g/mol [origin=calculated method=formula-sum]
Tc          972.37;      // K   [origin=predictive method=joback]
Pc          19.036;      // bar [origin=predictive method=joback]
omega       0.9167;      // -   [origin=predictive method=lee-kesler]
Tb          752.53;      // K   [origin=predictive method=joback]
HvapTb      71949.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.07 1.79344 -0.0011388 2.521e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 4; } { group ACH; count 5; } { group AC; count 1; } { group CH3N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 8-methyl-3-(phenylcarbonyloxy)-8-azabicyclo[3.2.1]octane-4-carboxylate" "cocaine" "methyl 3-(benzoyloxy)-8-methyl-8-azabicyclo[3.2.1]octane-2-carboxylate" "pseudococaine" "allopseudococaine" "pseudoallococaine" "(-)-cocaine base" "agn-pc-00g043" "[1r-(2-endo-3-exo)]-3-(benzolyloxy)-8-methyl-8-azabicyclo[3.2.1]octane-2-carboxylic acid methyl ester" "1.alpha.h,5.alpha.h-tropane-2.beta.-carboxylic acid, 3.beta.-hydroxy-, methyl ester, benzoate (ester)" "8-azabicyclo(3.2.1)octane-2-carboxylic acid, 3-(benzoyloxy)-8-methyl-, methyl ester, (1r-(exo,exo))-" "8-azabicyclo[3.2.1]octane-2-carboxylic acid, 3-(benzoyloxy)-8-methyl-, methyl ester, [1r-(exo,exo)]-" );
standardThermochemistry
{
    dHf_298   -625950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-211310.0
}
