/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene-1,3-dicarboxylic acid; [3-hydroxy-2-(hydroxymethyl)-2-methylpropyl] octadecanoate  (C31H52O8, CAS 68186-77-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene13DicarboxylicAcid3Hydroxy2Hydroxymethyl2Methylpropyl;
formula     C31H52O8;
CAS         68186-77-6;
InChIKey    WJXAVMDGJCYWPZ-UHFFFAOYSA-N;
MW          552.749;      // g/mol [origin=calculated method=formula-sum]
Tc          2074.80;      // K   [origin=predictive method=joback]
Pc          7.803;      // bar [origin=predictive method=joback]
omega       -0.0731;      // -   [origin=predictive method=lee-kesler]
Tb          1472.31;      // K   [origin=predictive method=joback]
HvapTb      161629.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.639 2.84484 -0.00149516 2.315e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 18; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 2; } { group CH2COO; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 19; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group COOH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid;[2-(hydroxymethyl)-2-methyl-3-oxidanyl-propyl] octadecanoate" );
gibbsFormation
{
    dHf_298   -1900760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1579.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1060830.0
    phase     gas;
}
