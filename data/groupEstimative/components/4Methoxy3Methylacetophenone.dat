/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxy-3-methylacetophenone  (C10H12O2, CAS 10024-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxy3Methylacetophenone;
formula     C10H12O2;
CAS         10024-90-5;
InChIKey    SRPCRBVBOIYYHS-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          756.32;      // K   [origin=predictive method=joback]
Pc          29.828;      // bar [origin=predictive method=joback]
omega       0.5926;      // -   [origin=predictive method=lee-kesler]
Tb          541.33;      // K   [origin=predictive method=joback]
HvapTb      50610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.35 0.66476 -0.00028762 1.966e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CH3CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methoxy-3-methyl-phenyl)ethanone" "1-(4-methoxy-3-methylphenyl)ethanone" "ethanone, 1-(4-methoxy-3-methylphenyl)-" "3'-methyl-4'-methoxyacetophenone" );
standardThermochemistry
{
    dHf_298   -280940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-107450.0
}
