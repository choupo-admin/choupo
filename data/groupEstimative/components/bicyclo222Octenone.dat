/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.2]octenone  (C8H10O, CAS 2220-40-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo222Octenone;
formula     C8H10O;
CAS         2220-40-8;
InChIKey    UJVGEBBKXJLFPB-UHFFFAOYSA-N;
MW          122.167;      // g/mol [origin=calculated method=formula-sum]
Tc          704.06;      // K   [origin=predictive method=joback]
Pc          38.819;      // bar [origin=predictive method=joback]
omega       0.3677;      // -   [origin=predictive method=lee-kesler]
Tb          471.64;      // K   [origin=predictive method=joback]
HvapTb      38111.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.9 0.8221 -0.00050228 1.14e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.2]oct-2-en-5-one" "bicyclo[2.2.2]oct-5-en-2-one" "bicyclo(2.2.2)oct-5-en-2-one" "bicyclo[2.2.2]oct-7-en-6-one" );
standardThermochemistry
{
    dHf_298   -155090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     210.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21150.0
}
