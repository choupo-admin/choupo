/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-pyran, tetrahydro-4-methylene-2-(2-methyl-1-propenyl)-  (C10H16O, CAS 60857-05-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hPyranTetrahydro4Methylene22Methyl1Propenyl;
formula     C10H16O;
CAS         60857-05-8;
InChIKey    JRIATCFPZFOVNP-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          690.07;      // K   [origin=predictive method=joback]
Pc          27.527;      // bar [origin=predictive method=joback]
omega       0.3841;      // -   [origin=predictive method=lee-kesler]
Tb          478.10;      // K   [origin=predictive method=joback]
HvapTb      42990.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.07 0.97534 -0.000581 1.288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dC_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylidene-2-(2-methylprop-1-enyl)oxane" "2h-pyran, tetrahydro-4-methylene-2-(2-methyl-1-propen-1-yl)-" "agn-pc-00ejqa" "tetrahydro-4-methylene-2-(2-methyl-1-propenyl)-2h-pyran" "4-methylidene-2-(2-methylprop-1-en-1-yl)tetrahydro-2h-pyran" );
standardThermochemistry
{
    dHf_298   -135740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=96400.0
}
