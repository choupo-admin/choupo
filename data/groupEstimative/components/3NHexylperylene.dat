/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-n-hexylperylene  (C26H24, CAS 7350-91-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3NHexylperylene;
formula     C26H24;
CAS         7350-91-6;
InChIKey    TZZMLMCAAVPEBH-UHFFFAOYSA-N;
MW          336.478;      // g/mol [origin=calculated method=formula-sum]
Tc          1146.97;      // K   [origin=predictive method=joback]
Pc          15.391;      // bar [origin=predictive method=joback]
omega       0.9995;      // -   [origin=predictive method=lee-kesler]
Tb          909.30;      // K   [origin=predictive method=joback]
HvapTb      84318.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.765 2.21732 -0.00180604 6.041e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 11; } { group AC; count 8; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 11; } { group dC_ring; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-hexylperylene" "perylene, 3-hexyl-" );
gibbsFormation
{
    dHf_298   329500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=662770.0
    phase     gas;
}
