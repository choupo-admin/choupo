/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenylacetylene  (C14H10, CAS 501-65-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diphenylacetylene;
formula     C14H10;
CAS         501-65-5;
InChIKey    JRXXLCKWQFKACW-UHFFFAOYSA-N;
MW          178.234;      // g/mol [origin=calculated method=formula-sum]
Tc          854.46;      // K   [origin=predictive method=joback]
Pc          33.029;      // bar [origin=predictive method=joback]
omega       0.3816;      // -   [origin=predictive method=lee-kesler]
Tb          582.28;      // K   [origin=predictive method=joback]
HvapTb      53462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.09 1.0262 -0.00070806 1.8538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylethynylbenzene" "diphenylethyne" "tolan" "tolane" "1,2-diphenylacetylene" "benzene, 1,1'-(1,2-ethynediyl)bis-" "ethyne, diphenyl-" "1,2-diphenylethyne" "1,2-diphenyl ethyne" "1,1'-ethyne-1,2-diyldibenzene" "(2-phenylethynyl)benzene" "biphenylacetylene" );
gibbsFormation
{
    dHf_298   413070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=494620.0
    phase     gas;
}
