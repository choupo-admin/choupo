/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyl 1-hydroxy-2-naphthoate  (C17H12O3, CAS 132-54-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenyl1Hydroxy2Naphthoate;
formula     C17H12O3;
CAS         132-54-7;
InChIKey    QHDYIMWKSCJTIM-UHFFFAOYSA-N;
MW          264.28;      // g/mol [origin=calculated method=formula-sum]
Tc          1065.92;      // K   [origin=predictive method=joback]
Pc          30.727;      // bar [origin=predictive method=joback]
omega       0.9985;      // -   [origin=predictive method=lee-kesler]
Tb          804.72;      // K   [origin=predictive method=joback]
HvapTb      80711.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.03 1.4976 -0.00119484 3.743e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 4; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 11; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenyl 1-oxidanylnaphthalene-2-carboxylate" "1-hydroxy-2-naphthoic acid phenyl ester" "phenyl 1-hydroxynaphthalene-2-carboxylate" "phenyl 1-hydroxy-2-naphthalenecarboxylate" "2-naphthalenecarboxylic acid, 1-hydroxy-, phenyl ester" "2-naphthoic acid, phenyl ester" "qhdyimwkscjtim-uhfffaoysa-" "m820" "1-hydroxy-2-naphthalenecarboxylic acid phenyl ester" "2-naphthoic acid, 1-hydroxy-, phenyl ester (8ci)" );
gibbsFormation
{
    dHf_298   -236140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-50890.0
    phase     gas;
}
