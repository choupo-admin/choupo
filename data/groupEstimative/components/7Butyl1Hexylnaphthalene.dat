/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-butyl-1-hexylnaphthalene  (C20H28, CAS 55000-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Butyl1Hexylnaphthalene;
formula     C20H28;
CAS         55000-55-0;
InChIKey    LPEFBGSLSJQKAH-UHFFFAOYSA-N;
MW          268.444;      // g/mol [origin=calculated method=formula-sum]
Tc          916.09;      // K   [origin=predictive method=joback]
Pc          14.884;      // bar [origin=predictive method=joback]
omega       0.7960;      // -   [origin=predictive method=lee-kesler]
Tb          712.82;      // K   [origin=predictive method=joback]
HvapTb      65354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.042 1.70224 -0.00109804 2.836e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group ACH; count 6; } { group AC; count 2; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH_ring; count 6; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-butyl-1-hexyl-naphthalene" "naphthalene, 7-butyl-1-hexyl-" );
gibbsFormation
{
    dHf_298   -51470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     707.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=317320.0
    phase     gas;
}
