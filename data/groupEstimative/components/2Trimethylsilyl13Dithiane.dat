/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-trimethylsilyl-1,3-dithiane  (C7H16S2Si, CAS 13411-42-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H16S2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Trimethylsilyl13Dithiane;
formula     C7H16S2Si;
CAS         13411-42-2;
InChIKey    BTTUMVHWIAXYPJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          192.41;      // g/mol [origin=calculated method=formula-sum]
Tc          720.23;      // K   [origin=predictive method=joback]
Pc          30.289;      // bar [origin=predictive method=joback]
omega       0.2287;      // -   [origin=predictive method=lee-kesler]
Tb          476.37;      // K   [origin=predictive method=joback]
HvapTb      43523.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.38 0.61358 -6.06e-05 -1.179e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group Si; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dithian-2-yl(trimethyl)silane" "silane, 1,3-dithian-2-yltrimethyl-" "2-(trimethylsilyl)-1,3-dithiane" "(1,3-dithian-2-yl)trimethylsilane" "1,3-dithian-2-yltrimethylsilane" "1,3-dithiane,2-(trimethylsilyl)-" );
standardThermochemistry
{
    dHf_298   -154590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=7470.0
}
