/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-hydroxy-5-methylbenzoate  (C10H12O3, CAS 34265-58-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Hydroxy5Methylbenzoate;
formula     C10H12O3;
CAS         34265-58-2;
InChIKey    ZGYXABNSOOACGL-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          821.19;      // K   [origin=predictive method=joback]
Pc          34.279;      // bar [origin=predictive method=joback]
omega       0.7842;      // -   [origin=predictive method=lee-kesler]
Tb          598.90;      // K   [origin=predictive method=joback]
HvapTb      61213.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.319 0.91524 -0.00064612 1.844e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 5-methyl-2-oxidanyl-benzoate" "ethyl 5-methylsalicylate" "ethyl 2-hydroxy-5-methyl-benzoate" "benzoic acid, 2-hydroxy-5-methyl-, ethyl ester" );
gibbsFormation
{
    dHf_298   -519260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-328890.0
    phase     gas;
}
