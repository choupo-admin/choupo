/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-acetoxy-2-methylenebutyrate  (C8H12O4, CAS 22787-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3Acetoxy2Methylenebutyrate;
formula     C8H12O4;
CAS         22787-68-4;
InChIKey    RECQPQVWZPJQJO-UHFFFAOYSA-N;
MW          172.18;      // g/mol [origin=calculated method=formula-sum]
Tc          683.95;      // K   [origin=predictive method=joback]
Pc          27.099;      // bar [origin=predictive method=joback]
omega       0.6163;      // -   [origin=predictive method=lee-kesler]
Tb          495.20;      // K   [origin=predictive method=joback]
HvapTb      47238.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.07 0.64006 -0.0002506 -1.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group CH3COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-acetyloxy-2-methylidene-butanoate" "methyl 3-acetyloxy-2-methylidenebutanoate" "butanoic acid, 3-(acetyloxy)-2-methylene-, methyl ester" "butanoic acid,3-(acetyloxy)-2-methylene-, methyl ester" );
gibbsFormation
{
    dHf_298   -732650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-527410.0
    phase     gas;
}
