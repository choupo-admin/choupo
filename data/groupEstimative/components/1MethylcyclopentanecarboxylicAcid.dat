/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylcyclopentanecarboxylic acid  (C7H12O2, CAS 110378-86-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1MethylcyclopentanecarboxylicAcid;
formula     C7H12O2;
CAS         110378-86-4;
InChIKey    MNIBBVOEXUQHFF-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          746.43;      // K   [origin=predictive method=joback]
Pc          40.261;      // bar [origin=predictive method=joback]
omega       0.5808;      // -   [origin=predictive method=lee-kesler]
Tb          520.79;      // K   [origin=predictive method=joback]
HvapTb      47446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.35 1.14322 -0.0010896 4.376e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylcyclopentane-1-carboxylic acid" "cyclopentanecarboxylic acid, 1-methyl-" "cyclopentanecarboxylic acid, methyl- (6ci,9ci)" "1-methyl-1-carboxy-cyclopentane" "1-methyl-cyclopentane-1-carboxylic acid" );
standardThermochemistry
{
    dHf_298   -462360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-304790.0
}
