/*--------------------------------*- Choupo -*-----------------------*\
  Component: decylmalonic acid  (C13H24O4, CAS 4372-29-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decylmalonicAcid;
formula     C13H24O4;
CAS         4372-29-6;
InChIKey    HCUZVMHXDRSBKX-UHFFFAOYSA-N;
MW          244.331;      // g/mol [origin=calculated method=formula-sum]
Tc          982.68;      // K   [origin=predictive method=joback]
Pc          19.237;      // bar [origin=predictive method=joback]
omega       1.3024;      // -   [origin=predictive method=lee-kesler]
Tb          787.62;      // K   [origin=predictive method=joback]
HvapTb      78472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.411 1.34632 -0.0008318 1.99e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-decylpropanedioic acid" "2-decyl-malonic acid" "2-decylmalonic acid" );
gibbsFormation
{
    dHf_298   -1017470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     759.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-631680.0
    phase     gas;
}
