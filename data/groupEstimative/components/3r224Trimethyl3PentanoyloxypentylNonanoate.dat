/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(3r)-2,2,4-trimethyl-3-pentanoyloxypentyl] nonanoate  (C22H42O4, CAS 70693-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3r224Trimethyl3PentanoyloxypentylNonanoate;
formula     C22H42O4;
CAS         70693-41-3;
InChIKey    DDAHZULAHQUUGJ-OAQYLSRUSA-N;
MW          370.574;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.76;      // K   [origin=predictive method=joback]
Pc          9.267;      // bar [origin=predictive method=joback]
omega       0.8592;      // -   [origin=predictive method=lee-kesler]
Tb          815.29;      // K   [origin=predictive method=joback]
HvapTb      77308.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.871 2.12192 -0.001162 2.073e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 9; } { group CH; count 2; } { group C; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 11; } { group CH; count 2; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3r)-2,2,4-trimethyl-3-pentanoyloxy-pentyl] nonanoate" );
standardThermochemistry
{
    dHf_298   -1151280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1057.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-488420.0
}
