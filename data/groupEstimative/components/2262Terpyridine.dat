/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2':6',2''-terpyridine  (C15H11N3, CAS 1148-79-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2262Terpyridine;
formula     C15H11N3;
CAS         1148-79-4;
InChIKey    DRGAZIDRYFYHIJ-UHFFFAOYSA-N;
MW          233.274;      // g/mol [origin=calculated method=formula-sum]
Tc          1094.27;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.7233;      // -   [origin=predictive method=lee-kesler]
Tb          788.92;      // K   [origin=predictive method=joback]
HvapTb      75104.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.98 1.23388 -0.00084654 2.243e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C5H4N; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 11; } { group dC_ring; count 4; } { group Nd_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dipyridin-2-ylpyridine" "tripyridyl" "tripyridine" "2,6-bis(2-pyridyl)pyridine" "2,2',2''-terpyridine" "terpy" "alpha,alpha',alpha''-tripyridyl" "2,2',2''-terpyridyl" "2,2',2''-tripyridine" "2,2',2''-tripyridyl" "2,6-di(2-pyridyl)pyridine" "2,6-di(pyridin-2-yl)pyridine" );
gibbsFormation
{
    dHf_298   443560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=634170.0
    phase     gas;
}
