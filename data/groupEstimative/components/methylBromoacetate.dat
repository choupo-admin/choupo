/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl bromoacetate  (C3H5BrO2, CAS 96-32-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylBromoacetate;
formula     C3H5BrO2;
CAS         96-32-2;
InChIKey    YDCHPLOFQATIDS-UHFFFAOYSA-N;
MW          152.975;      // g/mol [origin=calculated method=formula-sum]
Tc          589.36;      // K   [origin=predictive method=joback]
Pc          48.766;      // bar [origin=predictive method=joback]
omega       0.4264;      // -   [origin=predictive method=lee-kesler]
Tb          392.62;      // K   [origin=predictive method=joback]
HvapTb      36114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.761 0.27222 -0.0001162 1.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2COO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-bromanylethanoate" "methyl 2-bromoacetate" "bromoacetic acid methyl ester" "methyl monobromoacetate" "methyl alpha-bromoacetate" "acetic acid, 2-bromo-, methyl ester" "methyl .alpha.-bromoacetate" "methylester kyseliny bromoctove" "2-bromoacetic acid methyl ester" );
standardThermochemistry
{
    dHf_298   -396200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-321670.0
}
