/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-3-methylidenepent-1-ene  (C7H12, CAS 14145-44-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl3Methylidenepent1Ene;
formula     C7H12;
CAS         14145-44-9;
InChIKey    PJXJBPMWCKMWLS-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          530.51;      // K   [origin=predictive method=joback]
Pc          31.002;      // bar [origin=predictive method=joback]
omega       0.2580;      // -   [origin=predictive method=lee-kesler]
Tb          352.88;      // K   [origin=predictive method=joback]
HvapTb      29996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.839 0.62864 -0.0004074 1.105e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-3-methylidene-pent-1-ene" "ch2=c(ch3)c(c2h5)=ch2" "2-ethyl-3-methyl-1,3-butadiene" "1,3-butadiene, 2-ethyl-3-methyl-" );
standardThermochemistry
{
    dHf_298   43470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=166640.0
}
