/*--------------------------------*- Choupo -*-----------------------*\
  Component: biphenylene  (C12H8, CAS 259-79-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        biphenylene;
formula     C12H8;
CAS         259-79-0;
InChIKey    IFVTZJHWGZSXFD-UHFFFAOYSA-N;
MW          152.196;      // g/mol [origin=calculated method=formula-sum]
Tc          779.84;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       0.4649;      // -   [origin=predictive method=lee-kesler]
Tb          536.08;      // K   [origin=predictive method=joback]
HvapTb      47888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.05 1.0732 -0.00097212 3.5e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diphenylene" "cyclobutadibenzene" "dibenzocyclobutadiene" "1,1'-biphenylene" "biphenylene (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   270730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     290.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=360480.0
}
