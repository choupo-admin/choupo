/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 14-methylpentadecanoate  (C17H34O2, CAS 5129-60-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl14Methylpentadecanoate;
formula     C17H34O2;
CAS         5129-60-2;
InChIKey    WAKCWJNDXBPEBP-UHFFFAOYSA-N;
MW          270.457;      // g/mol [origin=calculated method=formula-sum]
Tc          813.38;      // K   [origin=predictive method=joback]
Pc          12.425;      // bar [origin=predictive method=joback]
omega       0.8575;      // -   [origin=predictive method=lee-kesler]
Tb          646.34;      // K   [origin=predictive method=joback]
HvapTb      60455.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.162 1.56996 -0.0008096 1.335e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadecanoic acid, 14-methyl-, methyl ester" "methyl isopalmitate" "14-methylpentadecanoic acid methyl ester" );
standardThermochemistry
{
    dHf_298   -716770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     859.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-220550.0
}
