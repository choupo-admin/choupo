/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-difluorobenzaldehyde  (C7H4F2O, CAS 437-81-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H4F2O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        26Difluorobenzaldehyde;
formula     C7H4F2O;
CAS         437-81-0;
InChIKey    SOWRUJSGHKNOKN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          142.104;      // g/mol [origin=calculated method=formula-sum]
Tc          560.53;      // K   [origin=predictive method=joback]
Pc          37.408;      // bar [origin=predictive method=joback]
omega       0.3090;      // -   [origin=predictive method=lee-kesler]
Tb          371.36;      // K   [origin=predictive method=joback]
HvapTb      30769.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.1 0.5026 -0.00043992 1.557e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CHO; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis(fluoranyl)benzaldehyde" "2,6-dfad" "2,6-difluorobenzaledehyde" "2,6-difluoro benzaldehyde" "benzaldehyde, 2,6-difluoro-" "l118" "3,4-difluorobenzalehyde;2,6-fluorobenzaldehyde;" );
standardThermochemistry
{
    dHf_298   -289990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-244450.0
}
