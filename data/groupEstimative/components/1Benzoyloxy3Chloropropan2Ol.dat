/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-benzoyloxy-3-chloropropan-2-ol  (C10H11ClO3, CAS 3477-94-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Benzoyloxy3Chloropropan2Ol;
formula     C10H11ClO3;
CAS         3477-94-9;
InChIKey    SOEGKTCFKODFPT-UHFFFAOYSA-N;
MW          214.645;      // g/mol [origin=calculated method=formula-sum]
Tc          846.40;      // K   [origin=predictive method=joback]
Pc          31.597;      // bar [origin=predictive method=joback]
omega       1.0650;      // -   [origin=predictive method=lee-kesler]
Tb          642.47;      // K   [origin=predictive method=joback]
HvapTb      68213.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.802 0.8668 -0.0005108 9.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-chloranyl-2-oxidanyl-propyl) benzoate" "3-chloro-1,2-propanediol 1-benzoate" "3-chloro-1,2-propanediol-1-benzoate" "1,2-propanediol, 3-chloro-, 1-benzoate" "benzoic acid, 3-chloro-2-hydroxypropyl ester" "u 27,574" "(3-chloro-2-hydroxypropyl) benzoate" "1,2-propanediol,3-chloro-, 1-benzoate" "1-benzoyloxy-3-chloropropan-2-ol;3-benzoyloxy-1-chloro-2-propanol; 3-chloro-2-hydroxypropyl benzoate" );
standardThermochemistry
{
    dHf_298   -503730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-315830.0
}
