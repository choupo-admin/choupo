/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-eicosanoxyethanol  (C22H46O2, CAS 2136-73-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Eicosanoxyethanol;
formula     C22H46O2;
CAS         2136-73-4;
InChIKey    WLDSAHIJFBDEMS-UHFFFAOYSA-N;
MW          342.608;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.38;      // K   [origin=predictive method=joback]
Pc          9.438;      // bar [origin=predictive method=joback]
omega       0.9105;      // -   [origin=predictive method=lee-kesler]
Tb          817.56;      // K   [origin=predictive method=joback]
HvapTb      83655.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.681 2.06462 -0.0010924 2.056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 19; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 21; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-icosoxyethanol" "ethanol, 2-(eicosyloxy)-" "2-icosyloxyethanol" );
gibbsFormation
{
    dHf_298   -781860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1075.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-107460.0
    phase     gas;
}
