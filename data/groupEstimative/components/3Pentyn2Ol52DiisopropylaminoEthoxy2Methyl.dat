/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pentyn-2-ol, 5-[2-(diisopropylamino)ethoxy]-2-methyl-  (C14H27NO2, CAS 16488-99-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Pentyn2Ol52DiisopropylaminoEthoxy2Methyl;
formula     C14H27NO2;
CAS         16488-99-6;
InChIKey    OKKYQMHHYGTSQA-UHFFFAOYSA-N;
MW          241.375;      // g/mol [origin=calculated method=formula-sum]
Tc          834.91;      // K   [origin=predictive method=joback]
Pc          19.003;      // bar [origin=predictive method=joback]
omega       0.9995;      // -   [origin=predictive method=lee-kesler]
Tb          651.85;      // K   [origin=predictive method=joback]
HvapTb      67970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.017 1.41642 -0.00085586 1.9768e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group tC; count 2; } { group OH; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-[2-[di(propan-2-yl)amino]ethoxy]-2-methyl-pent-3-yn-2-ol" "5-[2-[di(propan-2-yl)amino]ethoxy]-2-methylpent-3-yn-2-ol" );
standardThermochemistry
{
    dHf_298   -296220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     693.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136720.0
}
