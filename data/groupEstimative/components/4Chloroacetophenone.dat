/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-chloroacetophenone  (C8H7ClO, CAS 99-91-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloroacetophenone;
formula     C8H7ClO;
CAS         99-91-2;
InChIKey    BUZYGTVTZYSBCU-UHFFFAOYSA-N;
MW          154.593;      // g/mol [origin=calculated method=formula-sum]
Tc          734.58;      // K   [origin=predictive method=joback]
Pc          37.000;      // bar [origin=predictive method=joback]
omega       0.4740;      // -   [origin=predictive method=lee-kesler]
Tb          505.60;      // K   [origin=predictive method=joback]
HvapTb      47471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.74 0.60422 -0.00037726 8.456e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH3CO; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-chlorophenyl)ethanone" "4-chloroacetophenone" "p-chloroacetophenone" "ethanone, 1-(4-chlorophenyl)-" "acetophenone, 4'-chloro-" "p-chloracetophenone" "p-acetylchlorobenzene" "4-acetylchlorobenzene" "1-(4-chlorophenyl)-ethanone" "usaf do-1" "methyl p-chlorophenyl ketone" "p-chlorophenyl methyl ketone" );
standardThermochemistry
{
    dHf_298   -111710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-21590.0
}
