/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-mercaptoethyl acetate  (C4H8O2S, CAS 5862-40-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MercaptoethylAcetate;
formula     C4H8O2S;
CAS         5862-40-8;
InChIKey    YDLAHBBJAGGIJZ-UHFFFAOYSA-N;
MW          120.166;      // g/mol [origin=calculated method=formula-sum]
Tc          612.61;      // K   [origin=predictive method=joback]
Pc          42.552;      // bar [origin=predictive method=joback]
omega       0.4211;      // -   [origin=predictive method=lee-kesler]
Tb          412.20;      // K   [origin=predictive method=joback]
HvapTb      38642.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.552 0.35632 -0.0001216 -1.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3COO; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group COO; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-sulfanylethyl ethanoate" "2-sulfanylethyl acetate" "ethanol, 2-mercapto-, 1-acetate" "ethanol, 1-acetate" "acetic acid, 2-mercaptoethyl ester" );
standardThermochemistry
{
    dHf_298   -404690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-298180.0
}
