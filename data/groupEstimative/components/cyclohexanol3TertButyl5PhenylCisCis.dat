/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanol, 3-tert-butyl-5-phenyl-, cis,cis-  (C16H24O, CAS 21152-33-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanol3TertButyl5PhenylCisCis;
formula     C16H24O;
CAS         21152-33-0;
InChIKey    XVJVUBGDOOZBQV-UHFFFAOYSA-N;
MW          232.367;      // g/mol [origin=calculated method=formula-sum]
Tc          909.42;      // K   [origin=predictive method=joback]
Pc          21.178;      // bar [origin=predictive method=joback]
omega       0.8322;      // -   [origin=predictive method=lee-kesler]
Tb          691.52;      // K   [origin=predictive method=joback]
HvapTb      68680.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-118.47 1.67386 -0.0010502 2.396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-tert-butyl-5-phenyl-cyclohexan-1-ol" "3-tert-butyl-5-phenylcyclohexan-1-ol" "3-phenyl-5-tert-butyl-cyclohexan-1-ol" );
gibbsFormation
{
    dHf_298   -284380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71300.0
    phase     gas;
}
