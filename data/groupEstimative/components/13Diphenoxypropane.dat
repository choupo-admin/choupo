/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diphenoxypropane  (C15H16O2, CAS 726-44-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diphenoxypropane;
formula     C15H16O2;
CAS         726-44-3;
InChIKey    HZIVULLSUOJNPX-UHFFFAOYSA-N;
MW          228.291;      // g/mol [origin=calculated method=formula-sum]
Tc          869.14;      // K   [origin=predictive method=joback]
Pc          24.267;      // bar [origin=predictive method=joback]
omega       0.6802;      // -   [origin=predictive method=lee-kesler]
Tb          641.00;      // K   [origin=predictive method=joback]
HvapTb      58356.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.557 1.1446 -0.0006326 1.087e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenoxypropoxybenzene" "benzene, 1,1'-(1,3-propanediylbis(oxy))bis-" "benzene, 1,1'-[1,3-propanediylbis(oxy)]bis-" "(3-phenoxypropoxy)benzene" "1,1'-[propane-1,3-diylbis(oxy)]dibenzene" );
gibbsFormation
{
    dHf_298   -144310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90240.0
    phase     gas;
}
