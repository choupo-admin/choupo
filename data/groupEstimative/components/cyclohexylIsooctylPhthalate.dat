/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexyl isooctyl phthalate  (C22H32O4, CAS 71486-48-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylIsooctylPhthalate;
formula     C22H32O4;
CAS         71486-48-1;
InChIKey    PQDNDGYLGVVELW-UHFFFAOYSA-N;
MW          360.494;      // g/mol [origin=calculated method=formula-sum]
Tc          1085.64;      // K   [origin=predictive method=joback]
Pc          12.838;      // bar [origin=predictive method=joback]
omega       0.9723;      // -   [origin=predictive method=lee-kesler]
Tb          870.17;      // K   [origin=predictive method=joback]
HvapTb      82359.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.185 1.97384 -0.00103216 1.461e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o2-cyclohexyl o1-(6-methylheptyl) benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid, 1-cyclohexyl 2-isooctyl ester" "1,2-benzenedicarboxylic acid, cyclohexyl isooctyl ester" "1,2-benzenedicarboxylicacid, 1-cyclohexyl 2-isooctyl ester" "2-o-cyclohexyl 1-o-(6-methylheptyl) benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylicacid, cyclohexyl isooctyl ester (9ci); cyclohexyl isooctyl phthalate" );
gibbsFormation
{
    dHf_298   -857870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     962.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-361590.0
    phase     gas;
}
