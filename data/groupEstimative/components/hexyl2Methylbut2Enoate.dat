/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexyl 2-methylbut-2-enoate  (C11H20O2, CAS 16930-96-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexyl2Methylbut2Enoate;
formula     C11H20O2;
CAS         16930-96-4;
InChIKey    JTCIUOKKVACNCK-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          691.84;      // K   [origin=predictive method=joback]
Pc          20.438;      // bar [origin=predictive method=joback]
omega       0.6300;      // -   [origin=predictive method=lee-kesler]
Tb          513.54;      // K   [origin=predictive method=joback]
HvapTb      47525.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.425 1.01396 -0.0005661 1.118e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butenoic acid, 2-methyl-, hexyl ester, (2z)-" "agn-pc-03njh5" "hexyl (z)-2-methylbut-2-enoate" );
gibbsFormation
{
    dHf_298   -480220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-196960.0
    phase     gas;
}
