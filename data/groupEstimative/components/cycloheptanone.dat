/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloheptanone  (C7H12O, CAS 502-42-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloheptanone;
formula     C7H12O;
CAS         502-42-1;
InChIKey    CGZZMOTZOONQIA-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          689.46;      // K   [origin=predictive method=joback]
Pc          39.456;      // bar [origin=predictive method=joback]
omega       0.3216;      // -   [origin=predictive method=lee-kesler]
Tb          456.07;      // K   [origin=predictive method=joback]
HvapTb      36333.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.71 0.6395 -0.000203 -3.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "suberone" "suberon" "ketoheptamethylene" "cycloheptanon" "cycloheptyloxy" "cycloheptan-1-one" "1-oxocycloheptane" );
gibbsFormation
{
    dHf_298   -257010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94470.0
    phase     gas;
}
