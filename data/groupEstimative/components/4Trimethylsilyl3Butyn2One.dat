/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(trimethylsilyl)-3-butyn-2-one  (C7H12OSi, CAS 5930-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H12OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Trimethylsilyl3Butyn2One;
formula     C7H12OSi;
CAS         5930-98-3;
InChIKey    NQEZDDPEJMKMOS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          140.257;      // g/mol [origin=calculated method=formula-sum]
Tc          633.57;      // K   [origin=predictive method=joback]
Pc          31.315;      // bar [origin=predictive method=joback]
omega       0.2854;      // -   [origin=predictive method=lee-kesler]
Tb          424.03;      // K   [origin=predictive method=joback]
HvapTb      40368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.26 0.28488 0.00016864 -1.7516e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH3CO; count 1; } { group C_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group tC; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-trimethylsilylbut-3-yn-2-one" "4-trimethylsilyl-3-butyn-2-one" );
standardThermochemistry
{
    dHf_298   -139710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-22820.0
}
