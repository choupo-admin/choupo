/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-allylcyclopentanol  (C8H14O, CAS 36399-21-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Allylcyclopentanol;
formula     C8H14O;
CAS         36399-21-0;
InChIKey    LEWSEJSBOCWBQY-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          682.39;      // K   [origin=predictive method=joback]
Pc          37.777;      // bar [origin=predictive method=joback]
omega       0.6867;      // -   [origin=predictive method=lee-kesler]
Tb          487.02;      // K   [origin=predictive method=joback]
HvapTb      48517.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.559 1.2014 -0.0011247 4.487e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-prop-2-enylcyclopentan-1-ol" "1-allylcyclopentan-1-ol" "cyclopentanol, 1-(2-propenyl)-" "cyclopentanol, 1-(2-propen-1-yl)-" "1-prop-2-enyl-1-cyclopentanol" );
standardThermochemistry
{
    dHf_298   -159530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1440.0
}
