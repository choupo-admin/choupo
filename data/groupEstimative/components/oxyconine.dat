/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxyconine  (C8H17NO, CAS 495-20-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxyconine;
formula     C8H17NO;
CAS         495-20-5;
InChIKey    VCCAAURNBULZRR-UHFFFAOYSA-N;
MW          143.23;      // g/mol [origin=calculated method=formula-sum]
Tc          742.63;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.8279;      // -   [origin=predictive method=lee-kesler]
Tb          542.48;      // K   [origin=predictive method=joback]
HvapTb      56880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.459 0.91242 -0.0004654 7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group OH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-piperidin-2-ylpropan-1-ol" "(+)-conhydrine" "conhydrine" "(r-(r*,s*))-alpha-ethyl-2-piperidinemethanol" "conhydrin" "alpha-conhydrine" "1-((2r)(piperidin-2-yl))(1s)propan-1-ol" "1-(piperidin-2-yl)propan-1-ol" "(1s)-1-[(2r)-piperidin-2-yl]propan-1-ol" "2-piperidinemethanol, alpha-ethyl-, (r-(r*,s*))-" "2-piperidinemethanol, alpha-ethyl-, (r-(r*,s*))- (9ci)" );
standardThermochemistry
{
    dHf_298   -273830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-10620.0
}
