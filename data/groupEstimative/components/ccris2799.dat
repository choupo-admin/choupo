/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 2799  (C22H18O2, CAS 2517-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris2799;
formula     C22H18O2;
CAS         2517-98-8;
InChIKey    QZBZIXDRHVAJSX-UHFFFAOYSA-N;
MW          314.384;      // g/mol [origin=calculated method=formula-sum]
Tc          1108.10;      // K   [origin=predictive method=joback]
Pc          18.595;      // bar [origin=predictive method=joback]
omega       0.9793;      // -   [origin=predictive method=lee-kesler]
Tb          864.72;      // K   [origin=predictive method=joback]
HvapTb      81817.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.739 1.71104 -0.0012516 3.627e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 6; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(12-methylbenzo[a]anthracen-7-yl)methyl ethanoate" "7-acetoxymethyl-12-methylbenz(a)anthracene" "benz(a)anthracene-7-methanol, 12-methyl-, acetate" "12-methylbenz(a)anthracene-7-methanol acetate (ester)" "(12-methylbenzo[a]anthracen-7-yl)methyl acetate" "benz[a]anthracene-7-methanol,12-methyl-, 7-acetate" "benz[a]anthracene-7-methanol,12-methyl-, acetate (7ci,8ci,9ci); 7-acetoxymethyl-12-methylbenz[a]anthracene" );
standardThermochemistry
{
    dHf_298   -50830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     606.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=217830.0
}
