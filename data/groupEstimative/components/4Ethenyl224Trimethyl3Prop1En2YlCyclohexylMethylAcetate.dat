/*--------------------------------*- Choupo -*-----------------------*\
  Component: [4-ethenyl-2,2,4-trimethyl-3-(prop-1-en-2-yl)cyclohexyl]methyl acetate  (C17H28O2, CAS 22601-92-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethenyl224Trimethyl3Prop1En2YlCyclohexylMethylAcetate;
formula     C17H28O2;
CAS         22601-92-9;
InChIKey    WVBWGEUOGUDKGD-UHFFFAOYSA-N;
MW          264.409;      // g/mol [origin=calculated method=formula-sum]
Tc          853.67;      // K   [origin=predictive method=joback]
Pc          15.259;      // bar [origin=predictive method=joback]
omega       0.5936;      // -   [origin=predictive method=lee-kesler]
Tb          646.04;      // K   [origin=predictive method=joback]
HvapTb      56783.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.599 2.1504 -0.0018345 6.916e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group C; count 2; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-ethenyl-2,2,4-trimethyl-3-prop-1-en-2-yl-cyclohexyl)methyl ethanoate" "cyclohexanemethanol, 4-ethenyl-alpha,alpha,4-trimethyl-3-(1-methylethenyl)-, acetate, (1r,3s,4s)-" "(4-ethenyl-2,2,4-trimethyl-3-prop-1-en-2-ylcyclohexyl)methyl acetate" "cyclohexanemethanol, 4-ethenyl-.alpha.,.alpha.,4-trimethyl-3-(1-methylethenyl)-, 1-acetate, (1r,3s,4s)-" "cyclohexanemethanol, 4-ethenyl-.alpha.,.alpha.,4-trimethyl-3-(1-methylethenyl)-, acetate, (1r,3s,4s)-" "cyclohexanemethanol, 4-ethenyl-alpha,alpha,4-trimethyl-3-(1-methylethenyl)-, 1-acetate, (1r,3s,4s)-" );
standardThermochemistry
{
    dHf_298   -446640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     837.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60640.0
}
