/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dichlorobenzotrichloride  (C7H3Cl5, CAS 13014-24-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dichlorobenzotrichloride;
formula     C7H3Cl5;
CAS         13014-24-9;
InChIKey    ATYLRBXENHNROH-UHFFFAOYSA-N;
MW          264.351;      // g/mol [origin=calculated method=formula-sum]
Tc          840.78;      // K   [origin=predictive method=joback]
Pc          32.467;      // bar [origin=predictive method=joback]
omega       0.4343;      // -   [origin=predictive method=lee-kesler]
Tb          580.32;      // K   [origin=predictive method=joback]
HvapTb      55405.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.2 0.6307 -0.00052792 1.647e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CCl3; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)-4-(trichloromethyl)benzene" "1,2-dichloro-4-(trichloromethyl)benzene" "benzene, 1,2-dichloro-4-(trichloromethyl)-" "3,4-dichlorophenyltrichloromethane" "1,2-dichloro-4-trichloromethylbenzene" "a,a,a,3,4-pentachlorotoluene" "alpha,alpha,alpha,3,4-pentachlorotoluene" "3,4-dichlorotrichloromethylbenzene" "3,4,alpha,alpha,alpha-pentachlorotoluene" "toluene, alpha,alpha,alpha,3,4-pentachloro-" "toluene, .alpha.,.alpha.,.alpha.,3,4-pentachloro-" "atylrbxenhnroh-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -61670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=44400.0
    phase     gas;
}
