/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1-naphthylmethyl)-1,2,3,4-tetrahydronaphthalene  (C21H20, CAS 56818-06-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        21Naphthylmethyl1234Tetrahydronaphthalene;
formula     C21H20;
CAS         56818-06-5;
InChIKey    PXYDLIUAIBQLBW-UHFFFAOYSA-N;
MW          272.391;      // g/mol [origin=calculated method=formula-sum]
Tc          1032.06;      // K   [origin=predictive method=joback]
Pc          20.624;      // bar [origin=predictive method=joback]
omega       0.7022;      // -   [origin=predictive method=lee-kesler]
Tb          773.39;      // K   [origin=predictive method=joback]
HvapTb      69941.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.219 1.8596 -0.00135744 3.904e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 11; } { group AC; count 2; } { group ACCH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1,2,3,4-tetrahydronaphthalen-2-ylmethyl)naphthalene" "naphthalene, 1,2,3,4-tetrahydro-2-(1-naphthalenylmethyl)-" "2-(1-naphthylmethyl)-[1,2,3,4-tetrahydronaphthalene]" "1',2',3',4'-tetrahydro-1,2-dinaphthylmethane" );
standardThermochemistry
{
    dHf_298   231060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=486800.0
}
