/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-2-hydroxy-1,2,2-triphenylethyl acetate  (C22H20O3, CAS 95061-51-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s2Hydroxy122TriphenylethylAcetate;
formula     C22H20O3;
CAS         95061-51-1;
InChIKey    GXLZCXZLVDUDHP-NRFANRHFSA-N;
MW          332.399;      // g/mol [origin=calculated method=formula-sum]
Tc          1173.76;      // K   [origin=predictive method=joback]
Pc          20.419;      // bar [origin=predictive method=joback]
omega       1.2070;      // -   [origin=predictive method=lee-kesler]
Tb          929.73;      // K   [origin=predictive method=joback]
HvapTb      93796.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.28 1.96802 -0.0013774 3.512e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 15; } { group AC; count 2; } { group ACCH; count 1; } { group OH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1s)-2-oxidanyl-1,2,2-triphenyl-ethyl] ethanoate" "(1s)-2-hydroxy-1,2,2-triphenylethyl acetate" "(s)-(-)-2-hydroxy-1,2,2-triphenylethyl acetate" "(s)-(-)-1,1,2-triphenyl-1,2-ethanediol 2-acetate" "n800" "[(1s)-2-hydroxy-1,2,2-triphenylethyl] acetate" "(s)-(-)-2-hydroxy-1,2,3-triphenylethyl acetate" );
gibbsFormation
{
    dHf_298   -271360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     747.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24800.0
    phase     gas;
}
