/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,3-trimethylcyclobutanone  (C7H12O, CAS 1449-49-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        223Trimethylcyclobutanone;
formula     C7H12O;
CAS         1449-49-6;
InChIKey    XCNUTNIUANPMKW-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          649.67;      // K   [origin=predictive method=joback]
Pc          35.096;      // bar [origin=predictive method=joback]
omega       0.3209;      // -   [origin=predictive method=lee-kesler]
Tb          434.16;      // K   [origin=predictive method=joback]
HvapTb      34048.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.46 0.90726 -0.000764 2.983e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3-trimethylcyclobutan-1-one" "cyclobutanone, 2,2,3-trimethyl-" "2,2,3-trimethyl cyclobutanone" );
gibbsFormation
{
    dHf_298   -263970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     306.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-79080.0
    phase     gas;
}
