/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6h-benzo[c]chromene  (C13H10O, CAS 229-95-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6hBenzoCChromene;
formula     C13H10O;
CAS         229-95-8;
InChIKey    BEUDCHGZCTUAOG-UHFFFAOYSA-N;
MW          182.222;      // g/mol [origin=calculated method=formula-sum]
Tc          847.67;      // K   [origin=predictive method=joback]
Pc          34.399;      // bar [origin=predictive method=joback]
omega       0.5408;      // -   [origin=predictive method=lee-kesler]
Tb          594.45;      // K   [origin=predictive method=joback]
HvapTb      54968.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.88 1.146 -0.00091982 2.934e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6h-dibenzo(b,d)pyran" "6h-dibenzo[b,d]pyrane" "6h-dibenzo[b,d]-pyran" "6h-dibenzo[b,d]pyran" "6h-benzo[c]isochromene" );
gibbsFormation
{
    dHf_298   105770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     318.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=258580.0
    phase     gas;
}
