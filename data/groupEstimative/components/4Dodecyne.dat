/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-dodecyne  (C12H22, CAS 22058-01-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Dodecyne;
formula     C12H22;
CAS         22058-01-1;
InChIKey    RVIMTVIYJAEION-UHFFFAOYSA-N;
MW          166.308;      // g/mol [origin=calculated method=formula-sum]
Tc          664.28;      // K   [origin=predictive method=joback]
Pc          20.475;      // bar [origin=predictive method=joback]
omega       0.5026;      // -   [origin=predictive method=lee-kesler]
Tb          483.16;      // K   [origin=predictive method=joback]
HvapTb      44458.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.538 0.99404 -0.00053686 1.1058e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodec-4-yne" );
standardThermochemistry
{
    dHf_298   -18710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252960.0
}
