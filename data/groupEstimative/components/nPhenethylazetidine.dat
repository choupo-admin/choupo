/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-phenethylazetidine  (C11H15N, CAS 42525-65-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nPhenethylazetidine;
formula     C11H15N;
CAS         42525-65-5;
InChIKey    VIXGVWUHPTYYAH-UHFFFAOYSA-N;
MW          161.248;      // g/mol [origin=calculated method=formula-sum]
Tc          717.38;      // K   [origin=predictive method=joback]
Pc          31.491;      // bar [origin=predictive method=joback]
omega       0.4887;      // -   [origin=predictive method=lee-kesler]
Tb          501.81;      // K   [origin=predictive method=joback]
HvapTb      44621.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.888 1.2712 -0.000994 3.101e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-phenylethyl)azetidine" "1-phenethylazetidine" );
gibbsFormation
{
    dHf_298   126830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=333390.0
    phase     gas;
}
