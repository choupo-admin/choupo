/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-dimethyloct-6-en-4-yn-3-ol  (C10H16O, CAS 62851-70-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Dimethyloct6En4Yn3Ol;
formula     C10H16O;
CAS         62851-70-1;
InChIKey    XYRKRLCDCBKVGW-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          728.44;      // K   [origin=predictive method=joback]
Pc          29.218;      // bar [origin=predictive method=joback]
omega       0.6909;      // -   [origin=predictive method=lee-kesler]
Tb          530.39;      // K   [origin=predictive method=joback]
HvapTb      55427.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.699 0.98378 -0.00071636 2.1768e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-octen-4-yn-3-ol, 3,6-dimethyl-" "3,6-dimethyl-6-octen-4-yn-3-ol" );
standardThermochemistry
{
    dHf_298   -30980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173810.0
}
