/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentanone, 2-(2-ethylbutylidene)-, (2e)-  (C11H18O, CAS 67860-10-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentanone22Ethylbutylidene2e;
formula     C11H18O;
CAS         67860-10-0;
InChIKey    YVOVHXJNXFEFHZ-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          759.51;      // K   [origin=predictive method=joback]
Pc          25.277;      // bar [origin=predictive method=joback]
omega       0.5309;      // -   [origin=predictive method=lee-kesler]
Tb          545.25;      // K   [origin=predictive method=joback]
HvapTb      45292.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.688 0.96714 -0.0004851 7.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 1; } { group CH2_ring; count 3; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-ethylbutylidene)cyclopentan-1-one" "(2e)-2-(2-ethylbutylidene)cyclopentan-1-one" );
gibbsFormation
{
    dHf_298   -256500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6430.0
    phase     gas;
}
