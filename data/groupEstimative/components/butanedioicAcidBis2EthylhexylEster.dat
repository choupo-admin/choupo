/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanedioic acid, bis(2-ethylhexyl) ester  (C20H38O4, CAS 2915-57-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanedioicAcidBis2EthylhexylEster;
formula     C20H38O4;
CAS         2915-57-3;
InChIKey    WMNULTDOANGXRT-UHFFFAOYSA-N;
MW          342.52;      // g/mol [origin=calculated method=formula-sum]
Tc          951.83;      // K   [origin=predictive method=joback]
Pc          10.326;      // bar [origin=predictive method=joback]
omega       0.9281;      // -   [origin=predictive method=lee-kesler]
Tb          772.76;      // K   [origin=predictive method=joback]
HvapTb      74152.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.162 1.80608 -0.0008814 1.116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-ethylhexyl) butanedioate" "butanedioic acid, 1,4-bis(2-ethylhexyl) ester" "di-2-ethylhexyl succinate" "bis(2-ethylhexyl) succinate" "di(2-ethylhexyl)butanedioate" "di-(2-ethylhexyl) succinate" "succinic acid, bis(2-ethylhexyl) ester" "butanedioic acid, bis(2-ethylhexyl) ester  y" "butanedioic acid,1,4-bis(2-ethylhexyl) ester" "butanedioicacid, bis(2-ethylhexyl) ester (9ci);succinic acid, bis(2-ethylhexyl) ester(6ci,7ci,8ci);bis(2-ethylhexyl) succinate;crodamol osu;di-2-ethylhexylsuccinate;dioctyl succinate;wickenol 159;" );
gibbsFormation
{
    dHf_298   -1101250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1018.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-508100.0
    phase     gas;
}
