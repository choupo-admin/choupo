/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-phenylheptanoic acid  (C13H18O2, CAS 40228-90-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7PhenylheptanoicAcid;
formula     C13H18O2;
CAS         40228-90-8;
InChIKey    ZVSXKFNTWOIGJI-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          878.57;      // K   [origin=predictive method=joback]
Pc          23.888;      // bar [origin=predictive method=joback]
omega       0.9224;      // -   [origin=predictive method=lee-kesler]
Tb          669.23;      // K   [origin=predictive method=joback]
HvapTb      63972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.234 1.2107 -0.0007872 1.97e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 5; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenylheptanoic acid" "benzeneheptanoic acid" "7-phenylheptanoic acid +" "heptanoicacid, 7-phenyl- (6ci,7ci);7-phenylheptanoic acid;" "xxc" );
gibbsFormation
{
    dHf_298   -425390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     609.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-172920.0
    phase     gas;
}
