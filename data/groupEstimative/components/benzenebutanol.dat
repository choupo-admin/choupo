/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenebutanol  (C10H14O, CAS 3360-41-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenebutanol;
formula     C10H14O;
CAS         3360-41-6;
InChIKey    LDZLXQFDGRCELX-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          739.74;      // K   [origin=predictive method=joback]
Pc          32.467;      // bar [origin=predictive method=joback]
omega       0.8616;      // -   [origin=predictive method=lee-kesler]
Tb          547.26;      // K   [origin=predictive method=joback]
HvapTb      56809.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.816 0.9089 -0.0005818 1.431e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenylbutan-1-ol" "4-phenyl-1-butanol" "4-phenylbutanol" "4-phenylbutyl alcohol" "1-butanol, 4-phenyl-" "phenylbutyl alcohol" "4-phenyl butanol-1" "4-phenyl-butan-1-ol" "ldzlxqfdgrcelx-uhfffaoysa-" "1-butanol, 4-phenyl- (8ci)" "-butanol, 4-phenyl-;phenylbutyl alcohol" );
gibbsFormation
{
    dHf_298   -165430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8910.0
    phase     gas;
}
