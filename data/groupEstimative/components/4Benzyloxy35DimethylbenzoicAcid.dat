/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-benzyloxy-3,5-dimethylbenzoic acid  (C16H16O3, CAS 97888-80-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Benzyloxy35DimethylbenzoicAcid;
formula     C16H16O3;
CAS         97888-80-7;
InChIKey    JABUPJCJZZNUFK-UHFFFAOYSA-N;
MW          256.301;      // g/mol [origin=calculated method=formula-sum]
Tc          1038.13;      // K   [origin=predictive method=joback]
Pc          23.451;      // bar [origin=predictive method=joback]
omega       1.0398;      // -   [origin=predictive method=lee-kesler]
Tb          801.91;      // K   [origin=predictive method=joback]
HvapTb      77322.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.469 1.17514 -0.00066948 1.287e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group ACCH3; count 2; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-dimethyl-4-phenylmethoxy-benzoic acid" "3,5-dimethyl-4-(phenylmethoxy)benzoic acid" "4-benzyloxy-3,5-dimethyl-benzoate" "3,5-dimethyl-4-phenylmethoxybenzoic acid" "l648" );
standardThermochemistry
{
    dHf_298   -417410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-169140.0
}
