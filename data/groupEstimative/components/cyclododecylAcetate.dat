/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclododecyl acetate  (C14H26O2, CAS 6221-92-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclododecylAcetate;
formula     C14H26O2;
CAS         6221-92-7;
InChIKey    AWJATTSJDXARCL-UHFFFAOYSA-N;
MW          226.36;      // g/mol [origin=calculated method=formula-sum]
Tc          856.26;      // K   [origin=predictive method=joback]
Pc          20.624;      // bar [origin=predictive method=joback]
omega       0.5112;      // -   [origin=predictive method=lee-kesler]
Tb          623.31;      // K   [origin=predictive method=joback]
HvapTb      55626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.76 1.34352 -0.0004458 -7.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 11; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclododecyl ethanoate" "cyclododecanol, acetate" "cyclododecanol, 1-acetate" );
gibbsFormation
{
    dHf_298   -632210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     841.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-291520.0
    phase     gas;
}
