/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorfenac  (C8H5Cl3O2, CAS 85-34-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorfenac;
formula     C8H5Cl3O2;
CAS         85-34-7;
InChIKey    QZXCCPZJCKEPSA-UHFFFAOYSA-N;
MW          239.476;      // g/mol [origin=calculated method=formula-sum]
Tc          923.27;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       0.8713;      // -   [origin=predictive method=lee-kesler]
Tb          682.06;      // K   [origin=predictive method=joback]
HvapTb      67983.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.881 0.5776 -0.00037528 8.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH2; count 1; } { group COOH; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,3,6-tris(chloranyl)phenyl]ethanoic acid" "fenac" "kanepar" "trifene" "fenae" "tri-fen" "tcpa" "benzeneacetic acid, 2,3,6-trichloro-" "tri fene" "2,3,6-trichlorophenylacetic acid" "chlorfenac [bsi:iso]" "2,3,6-trichlorobenzeneacetic acid" );
standardThermochemistry
{
    dHf_298   -403820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-279700.0
}
