/*--------------------------------*- Choupo -*-----------------------*\
  Component: octanedinitrile  (C8H12N2, CAS 629-40-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octanedinitrile;
formula     C8H12N2;
CAS         629-40-3;
InChIKey    BTNXBLUGMAMSSH-UHFFFAOYSA-N;
MW          136.198;      // g/mol [origin=calculated method=formula-sum]
Tc          788.75;      // K   [origin=predictive method=joback]
Pc          24.124;      // bar [origin=predictive method=joback]
omega       0.7389;      // -   [origin=predictive method=lee-kesler]
Tb          586.80;      // K   [origin=predictive method=joback]
HvapTb      54358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.616 0.6334 -0.0003494 7.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6-dicyanohexane" "suberonitrile" "suberic acid dinitrile" "hexamethylene dicyanide" "hexamethylene di-isocyanide" "hexane-1,6-dicarbonitrile" "korksaeuredinitril [german]" "hexamethylenediisocyanic acid" "hexa-1,6-diyl diisocyanide" "isocyanic acid, hexamethylenedi-" "hexane, 1,6-dicyanato-" "suberodinitrile" );
standardThermochemistry
{
    dHf_298   121310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=282840.0
}
