/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4,5,6,7-heptachloronaphthalene  (C10HCl7, CAS 32241-08-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234567Heptachloronaphthalene;
formula     C10HCl7;
CAS         32241-08-0;
InChIKey    NDZIBNJHNBUHKW-UHFFFAOYSA-N;
MW          369.268;      // g/mol [origin=calculated method=formula-sum]
Tc          1037.92;      // K   [origin=predictive method=joback]
Pc          25.872;      // bar [origin=predictive method=joback]
omega       0.7663;      // -   [origin=predictive method=lee-kesler]
Tb          770.93;      // K   [origin=predictive method=joback]
HvapTb      77099.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (118.78 0.5023 -0.00036164 1.031e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 2; } { group ACCl; count 7; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 1; } { group dC_ring; count 9; } { group Cl; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5,6,7-heptakis(chloranyl)naphthalene" "naphthalene, 1,2,3,4,5,6,7-heptachloro" "1h-heptachloronaphthalene" "naphthalene,heptachloro-" "naphthalene, 1,2,3,4,5,6,7-heptachloro-" );
gibbsFormation
{
    dHf_298   -12600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=101460.0
    phase     gas;
}
