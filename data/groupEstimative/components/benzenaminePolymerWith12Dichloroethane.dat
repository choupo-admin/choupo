/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenamine, polymer with 1,2-dichloroethane  (C8H11Cl2N, CAS 68016-17-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenaminePolymerWith12Dichloroethane;
formula     C8H11Cl2N;
CAS         68016-17-1;
InChIKey    BFGOKKIOPFKCOI-UHFFFAOYSA-N;
MW          192.083;      // g/mol [origin=calculated method=formula-sum]
Tc          799.12;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       0.4913;      // -   [origin=predictive method=lee-kesler]
Tb          558.11;      // K   [origin=predictive method=joback]
HvapTb      55383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.802 0.5542 -0.000112 -7.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACNH2; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aniline;1,2-bis(chloranyl)ethane" "aniline; 1,2-dichloroethane" "aniline, ethylene dichloride polymer" );
gibbsFormation
{
    dHf_298   -81230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66720.0
    phase     gas;
}
