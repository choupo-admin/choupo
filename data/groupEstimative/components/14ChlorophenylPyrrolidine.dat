/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-chlorophenyl)pyrrolidine  (C10H12ClN, CAS 4280-30-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14ChlorophenylPyrrolidine;
formula     C10H12ClN;
CAS         4280-30-2;
InChIKey    DPQIAEJLCJLSJK-UHFFFAOYSA-N;
MW          181.663;      // g/mol [origin=calculated method=formula-sum]
Tc          759.88;      // K   [origin=predictive method=joback]
Pc          34.079;      // bar [origin=predictive method=joback]
omega       0.4649;      // -   [origin=predictive method=lee-kesler]
Tb          525.61;      // K   [origin=predictive method=joback]
HvapTb      47614.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.91 1.1139 -0.00084656 2.524e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-chlorophenyl)-pyrrolidine" "pyrrolidine, 1-(4-chlorophenyl)" "pyrrolidine, 1-(4-chlorophenyl)-" "1-(4-chloro-phenyl)-pyrrolidine" );
gibbsFormation
{
    dHf_298   114100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=291310.0
    phase     gas;
}
