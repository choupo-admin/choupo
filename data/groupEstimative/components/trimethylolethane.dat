/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolethane  (C5H12O3, CAS 77-85-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolethane;
formula     C5H12O3;
CAS         77-85-0;
InChIKey    QXJQHYBHAIHNGG-UHFFFAOYSA-N;
MW          120.148;      // g/mol [origin=calculated method=formula-sum]
Tc          749.67;      // K   [origin=predictive method=joback]
Pc          50.802;      // bar [origin=predictive method=joback]
omega       1.7448;      // -   [origin=predictive method=lee-kesler]
Tb          587.31;      // K   [origin=predictive method=joback]
HvapTb      75465.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.257 0.70662 -0.0005112 1.496e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(hydroxymethyl)-2-methyl-propane-1,3-diol" "1,1,1-tris(hydroxymethyl)ethane" "pentaglycerol" "methriol" "metriol" "trimet" "pentaglycerine" "methyltrimethanolmethane" "methyltrimethylolmethane" "tris(hydroxymethyl)ethane" "1,3-propanediol, 2-(hydroxymethyl)-2-methyl-" "ethane, 1,1,1-tris(hydroxymethyl)-" );
gibbsFormation
{
    dHf_298   -611970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-416400.0
    phase     gas;
}
