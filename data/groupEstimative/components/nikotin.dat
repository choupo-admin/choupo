/*--------------------------------*- Choupo -*-----------------------*\
  Component: nikotin  (C10H14N2, CAS 22083-74-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nikotin;
formula     C10H14N2;
CAS         22083-74-5;
InChIKey    SNICXCGAKADSCV-UHFFFAOYSA-N;
MW          162.236;      // g/mol [origin=calculated method=formula-sum]
Tc          769.45;      // K   [origin=predictive method=joback]
Pc          34.889;      // bar [origin=predictive method=joback]
omega       0.4747;      // -   [origin=predictive method=lee-kesler]
Tb          532.23;      // K   [origin=predictive method=joback]
HvapTb      48468.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.1 1.17388 -0.00084706 2.419e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH3N; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(1-methylpyrrolidin-2-yl)pyridine" "(r,s)-nicotine" "black leaf" "nicocide" "tendust" "nico-dust" "emo-nik" "nico-fume" "nicotine alkaloid" "mach-nic" "(-)-nicotine" "nic-sal" );
gibbsFormation
{
    dHf_298   153760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=382210.0
    phase     gas;
}
