/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-acetoxymethylbenzo(a)pyrene  (C23H16O2, CAS 42978-43-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6AcetoxymethylbenzoAPyrene;
formula     C23H16O2;
CAS         42978-43-8;
InChIKey    AIXMKWLMVGVTGG-UHFFFAOYSA-N;
MW          324.379;      // g/mol [origin=calculated method=formula-sum]
Tc          1147.26;      // K   [origin=predictive method=joback]
Pc          19.648;      // bar [origin=predictive method=joback]
omega       1.0591;      // -   [origin=predictive method=lee-kesler]
Tb          898.88;      // K   [origin=predictive method=joback]
HvapTb      85047.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.629 1.87752 -0.00154824 5.113e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 8; } { group ACCH2; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 9; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzo[b]pyren-6-ylmethyl ethanoate" "6-acetyloxymethylbenzo(a)pyrene" "benzo(a)pyrene, 6-acetoxymethyl-" "benzo(a)pyrene-6-methanol, acetate (ester)" "benzo[b]pyren-6-ylmethyl acetate" );
standardThermochemistry
{
    dHf_298   74140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=327140.0
}
