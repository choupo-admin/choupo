/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyisobutyric acid  (C4H8O3, CAS 594-61-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyisobutyricAcid;
formula     C4H8O3;
CAS         594-61-6;
InChIKey    BWLBGMIXKSTLSX-UHFFFAOYSA-N;
MW          104.105;      // g/mol [origin=calculated method=formula-sum]
Tc          719.84;      // K   [origin=predictive method=joback]
Pc          50.875;      // bar [origin=predictive method=joback]
omega       0.9968;      // -   [origin=predictive method=lee-kesler]
Tb          525.58;      // K   [origin=predictive method=joback]
HvapTb      57045.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.33 0.59444 -0.0004686 1.461e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-2-oxidanyl-propanoic acid" "2-methyllactic acid" "2-hydroxy-2-methylpropanoic acid" "acetonic acid" "alpha-hydroxyisobutyric acid" "2-hydroxy-2-methylpropionic acid" "hydroxydimethylacetic acid" "propanoic acid, 2-hydroxy-2-methyl-" "acetonate" "alpha-hydroxyisobutanoic acid" "hiba" "alpha-hydroxy-alpha-methylpropanoic acid" );
gibbsFormation
{
    dHf_298   -637140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-495090.0
    phase     gas;
}
