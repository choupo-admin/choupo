/*--------------------------------*- Choupo -*-----------------------*\
  Component: propionitrile, 3-(n-ethyl-m-toluidino)-  (C12H16N2, CAS 148-69-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propionitrile3NEthylMToluidino;
formula     C12H16N2;
CAS         148-69-6;
InChIKey    NPCCPMHHNIOSHL-UHFFFAOYSA-N;
MW          188.274;      // g/mol [origin=calculated method=formula-sum]
Tc          833.71;      // K   [origin=predictive method=joback]
Pc          23.092;      // bar [origin=predictive method=joback]
omega       0.7153;      // -   [origin=predictive method=lee-kesler]
Tb          620.34;      // K   [origin=predictive method=joback]
HvapTb      57765.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.317 1.06414 -0.00067476 1.633e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[ethyl-(3-methylphenyl)amino]propanenitrile" "n-(2-cyanoethyl)-n-ethyl-m-toluidine" "3-(n-ethyl-m-toluidino)propiononitrile" "n-ethyl-n-cyanoethyl-m-toluidine" "m-toluidine, n-cyanoethyl-n-ethyl-" "3-(n-ethyl-m-toluidino)propionitrite" "3-(ethyl(m-tolyl)amino)propanenitrile" "n-ethylcyano-n-ethyl-m-toluidine" "propanenitrile, 3-[ethyl(3-methylphenyl)amino]-" "3-(ethyl(3-methylphenyl)amino)propanenitrile" "propanenitrile, 3-(ethyl(3-methylphenyl)amino)-" "3-(ethyl-m-tolyl-amino)-propionitrile" );
standardThermochemistry
{
    dHf_298   166460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=396900.0
}
