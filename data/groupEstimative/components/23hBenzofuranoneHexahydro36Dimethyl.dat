/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2(3h)-benzofuranone, hexahydro-3,6-dimethyl-  (C10H16O2, CAS 92015-65-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23hBenzofuranoneHexahydro36Dimethyl;
formula     C10H16O2;
CAS         92015-65-1;
InChIKey    FGDINYRLQOKVQS-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          697.60;      // K   [origin=predictive method=joback]
Pc          26.191;      // bar [origin=predictive method=joback]
omega       0.4829;      // -   [origin=predictive method=lee-kesler]
Tb          495.03;      // K   [origin=predictive method=joback]
HvapTb      44641.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.52 1.13824 -0.0007088 1.63e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 4; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-dimethyl-3a,4,5,6,7,7a-hexahydro-3h-1-benzofuran-2-one" "dihydromintlactone" );
gibbsFormation
{
    dHf_298   -468250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183070.0
    phase     gas;
}
