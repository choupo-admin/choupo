/*--------------------------------*- Choupo -*-----------------------*\
  Component: propene-d6  (C3D6, CAS 1517-52-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C3D6 (delta D+6H-6; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        propeneD6;
formula     C3D6;
CAS         1517-52-8;
InChIKey    QQONPFPTGQHPMA-QNYGJALNSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          48.117;      // g/mol [origin=calculated method=formula-sum]
Tc          427.64;      // K   [origin=predictive method=joback]
Pc          46.657;      // bar [origin=predictive method=joback]
omega       0.1508;      // -   [origin=predictive method=lee-kesler]
Tb          264.92;      // K   [origin=predictive method=joback]
HvapTb      21602.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.83 0.26882 -0.0001623 4.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,3,3,3-hexadeuterioprop-1-ene" "propylene-d6" "(2h6)prop-1-ene" "cd3cd=cd2" );
standardThermochemistry
{
    dHf_298   20180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     268.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62220.0
}
