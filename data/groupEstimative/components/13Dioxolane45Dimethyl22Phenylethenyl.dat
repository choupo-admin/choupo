/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxolane, 4,5-dimethyl-2-(2-phenylethenyl)-  (C13H16O2, CAS 6413-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxolane45Dimethyl22Phenylethenyl;
formula     C13H16O2;
CAS         6413-97-4;
InChIKey    VDWXISSGYHXTDT-UHFFFAOYSA-N;
MW          204.269;      // g/mol [origin=calculated method=formula-sum]
Tc          820.47;      // K   [origin=predictive method=joback]
Pc          25.328;      // bar [origin=predictive method=joback]
omega       0.5193;      // -   [origin=predictive method=lee-kesler]
Tb          587.72;      // K   [origin=predictive method=joback]
HvapTb      55425.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.98 1.25264 -0.0007872 1.821e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH-O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,5-dimethyl-2-(2-phenylethenyl)-1,3-dioxolane" );
standardThermochemistry
{
    dHf_298   -202100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     311.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100100.0
}
