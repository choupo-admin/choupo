/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-aminopropan-2-ol; 4-tert-butylbenzoic acid  (C14H23NO3, CAS 67859-80-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Aminopropan2Ol4TertButylbenzoicAcid;
formula     C14H23NO3;
CAS         67859-80-7;
InChIKey    DTUPQRXSFPBPHI-UHFFFAOYSA-N;
MW          253.342;      // g/mol [origin=calculated method=formula-sum]
Tc          1080.19;      // K   [origin=predictive method=joback]
Pc          23.360;      // bar [origin=predictive method=joback]
omega       1.3666;      // -   [origin=predictive method=lee-kesler]
Tb          859.53;      // K   [origin=predictive method=joback]
HvapTb      92790.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.601 1.26768 -0.00060856 5.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azanylpropan-2-ol;4-tert-butylbenzoic acid" "benzoic acid, 4-(1,1-dimethylethyl)-, compd. with 1-amino-2-propanol (1:1)" "p-tert-butylbenzoic acid, isopropanolamine salt" "p-tert-butylbenzoic acid, monoisopropanolamine salt" "4-tert-butylbenzoic acid - 1-aminopropan-2-ol (1:1)" "p-tert-butylbenzoic acid, compound with 1-aminopropan-2-ol (1:1)" );
standardThermochemistry
{
    dHf_298   -701590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     803.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-348860.0
}
