/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethylindan  (C11H14, CAS 4912-92-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dimethylindan;
formula     C11H14;
CAS         4912-92-9;
InChIKey    UTTMVTDJCFSOFF-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          719.55;      // K   [origin=predictive method=joback]
Pc          31.456;      // bar [origin=predictive method=joback]
omega       0.3587;      // -   [origin=predictive method=lee-kesler]
Tb          489.92;      // K   [origin=predictive method=joback]
HvapTb      41780.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.95 1.35324 -0.00129156 5.176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethyl-1,2-dihydroindene" "1,1-dimethylindane" "1h-indene, 2,3-dihydro-1,1-dimethyl-" "indan, 1,1-dimethyl-" "indan,1-dimethyl-" "indan, 1,1-dimethyl- (8ci)" "3,3-dimethyl-1,2-dihydro-indene" "1,1-dimethyl-(2,3-dihydroindene)" "1h-indene,3-dihydro-1,1-dimethyl-" "1h-indene, 2,3-dihydro-1,1-dimethyl- (9ci)" );
gibbsFormation
{
    dHf_298   42730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=199780.0
    phase     gas;
}
