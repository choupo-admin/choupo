/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-3,5-dichlorobenzotrifluoride  (C7H4Cl2F3N, CAS 62593-17-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino35Dichlorobenzotrifluoride;
formula     C7H4Cl2F3N;
CAS         62593-17-3;
InChIKey    OCJPQZFOBGQYEA-UHFFFAOYSA-N;
MW          230.01;      // g/mol [origin=calculated method=formula-sum]
Tc          763.04;      // K   [origin=predictive method=joback]
Pc          33.144;      // bar [origin=predictive method=joback]
omega       0.6115;      // -   [origin=predictive method=lee-kesler]
Tb          543.35;      // K   [origin=predictive method=joback]
HvapTb      51102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.59 0.6481 -0.00049228 1.406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACNH2; count 1; } { group ACCl; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 3; } { group Cl; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(chloranyl)-6-(trifluoromethyl)aniline" "2,4-dichloro-6-(trifluoromethyl)aniline" "3,5-dichloro-2-aminobenzotrifluoride" "2,4-dichloro-6-(trifluoromethyl)phenylamine" "u310" "2,4-dichloro-6-(trifluoromethyl)benzenamine" "2,4-dichloro-6-(trifluoromethyl)aniline 97%" "benzenamine,2,4-dichloro-6-(trifluoromethyl)-" "2,4-dichloro-6-(trifluoromethyl)aniline;2-amino-3,5-dichlorobenzotrifluoride" );
standardThermochemistry
{
    dHf_298   -580460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-447420.0
}
