/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl isocyanate  (C3H5NO, CAS 109-90-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylIsocyanate;
formula     C3H5NO;
CAS         109-90-0;
InChIKey    WUDNUHPRLBTKOJ-UHFFFAOYSA-N;
MW          71.079;      // g/mol [origin=calculated method=formula-sum]
Tc          514.39;      // K   [origin=predictive method=joback]
Pc          48.766;      // bar [origin=predictive method=joback]
omega       0.3313;      // -   [origin=predictive method=lee-kesler]
Tb          334.91;      // K   [origin=predictive method=joback]
HvapTb      31804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCd; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "isocyanatoethane" "ethane, isocyanato-" "ethylisocyanate" "isocyanic acid, ethyl ester" "isocyanic acid ethyl ester" "ethane, isocyanato" "agn-pc-02zz28" );
