/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-ethylhexyl)aniline  (C14H23N, CAS 10137-80-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2EthylhexylAniline;
formula     C14H23N;
CAS         10137-80-1;
InChIKey    GXFHZISVUPJOCI-UHFFFAOYSA-N;
MW          205.345;      // g/mol [origin=calculated method=formula-sum]
Tc          795.18;      // K   [origin=predictive method=joback]
Pc          20.475;      // bar [origin=predictive method=joback]
omega       0.7036;      // -   [origin=predictive method=lee-kesler]
Tb          596.33;      // K   [origin=predictive method=joback]
HvapTb      55082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.635 1.33704 -0.0008208 1.909e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aniline, n-(2-ethylhexyl)-" "benzenamine, n-(2-ethylhexyl)-" "n-2-(ethylhexyl)aniline" "n-(2-ethylhexyl)benzenamine" "hexylamine, 2-ethyl-n-phenyl-" "benzenamine, n-(2-ethylhexyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   -47570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     626.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=266360.0
}
