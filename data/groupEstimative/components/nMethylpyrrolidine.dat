/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylpyrrolidine  (C5H11N, CAS 120-94-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylpyrrolidine;
formula     C5H11N;
CAS         120-94-5;
InChIKey    AVFZOVWCLRSYKC-UHFFFAOYSA-N;
MW          85.15;      // g/mol [origin=calculated method=formula-sum]
Tc          528.39;      // K   [origin=predictive method=joback]
Pc          43.742;      // bar [origin=predictive method=joback]
omega       0.2749;      // -   [origin=predictive method=lee-kesler]
Tb          342.12;      // K   [origin=predictive method=joback]
HvapTb      29161.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.65 0.77052 -0.00059 1.833e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylpyrrolidine" "pyrrolidine, 1-methyl-" "n-methyltetrahydropyrrole" "methylpyrrolidine" "n-methyl pyrrolidine" "pyrrolidine, n-methyl-" "methyl pyrrolidone" "1-methyl-pyrrolidine" "2-pyrrolidone, 1-methyl" "pyrrolidine, n-methyl" "51368-35-5 (hydrobromide)" "36520-42-0 (hydrochloride)" );
gibbsFormation
{
    dHf_298   7980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     338.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158360.0
    phase     gas;
}
