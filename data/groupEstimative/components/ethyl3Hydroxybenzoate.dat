/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-hydroxybenzoate  (C9H10O3, CAS 7781-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Hydroxybenzoate;
formula     C9H10O3;
CAS         7781-98-8;
InChIKey    MWSMNBYIEBRXAL-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          796.48;      // K   [origin=predictive method=joback]
Pc          39.209;      // bar [origin=predictive method=joback]
omega       0.7337;      // -   [origin=predictive method=lee-kesler]
Tb          571.04;      // K   [origin=predictive method=joback]
HvapTb      58325.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.709 0.87972 -0.00065876 1.974e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-oxidanylbenzoate" "ethyl m-hydroxybenzoate" "3-hydroxybenzoic acid ethyl ester" "m-ethoxycarbonylphenol" "ethyl-3-hydroxybenzoate" "benzoic acid, 3-hydroxy-, ethyl ester" "k368" );
gibbsFormation
{
    dHf_298   -487150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-327680.0
    phase     gas;
}
