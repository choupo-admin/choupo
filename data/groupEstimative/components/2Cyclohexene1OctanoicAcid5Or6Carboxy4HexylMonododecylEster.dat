/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexene-1-octanoic acid, 5(or 6)-carboxy-4-hexyl-, monododecyl ester  (C33H60O4, CAS 72258-29-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexene1OctanoicAcid5Or6Carboxy4HexylMonododecylEster;
formula     C33H60O4;
CAS         72258-29-8;
InChIKey    IUGCSZUKBPGZQE-OLUZHXLYSA-N;
MW          520.839;      // g/mol [origin=calculated method=formula-sum]
Tc          1482.46;      // K   [origin=predictive method=joback]
Pc          5.900;      // bar [origin=predictive method=joback]
omega       0.2211;      // -   [origin=predictive method=lee-kesler]
Tb          1167.74;      // K   [origin=predictive method=joback]
HvapTb      113726.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.047 3.14794 -0.00170688 3.098e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 24; } { group CH; count 3; } { group CH=CH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 23; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-[(1s,4r,5s)-5-dodecoxycarbonyl-4-hexyl-cyclohex-2-en-1-yl]octanoic acid" "8-[(1s,4r,5s)-5-dodecoxycarbonyl-4-hexylcyclohex-2-en-1-yl]octanoic acid" );
standardThermochemistry
{
    dHf_298   -1320580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1393.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-388310.0
}
