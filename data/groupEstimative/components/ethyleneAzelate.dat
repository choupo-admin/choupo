/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylene azelate  (C11H18O4, CAS 4471-27-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyleneAzelate;
formula     C11H18O4;
CAS         4471-27-6;
InChIKey    QABJRPWOBYCMBO-UHFFFAOYSA-N;
MW          214.261;      // g/mol [origin=calculated method=formula-sum]
Tc          829.55;      // K   [origin=predictive method=joback]
Pc          26.272;      // bar [origin=predictive method=joback]
omega       0.6444;      // -   [origin=predictive method=lee-kesler]
Tb          604.75;      // K   [origin=predictive method=joback]
HvapTb      56148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.2 1.059 -0.0003826 -4.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dioxacyclotridecane-5,13-dione" "azelaic acid, cyclic ethylene ester" );
standardThermochemistry
{
    dHf_298   -848750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     758.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-583140.0
}
