/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 2(or 4)-sec-hexacosyl-  (C32H58O, CAS 234446-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol2Or4SecHexacosyl;
formula     C32H58O;
CAS         234446-37-8;
InChIKey    UBJVGCQWESUVTF-UHFFFAOYSA-N;
MW          458.815;      // g/mol [origin=calculated method=formula-sum]
Tc          1282.17;      // K   [origin=predictive method=joback]
Pc          6.918;      // bar [origin=predictive method=joback]
omega       0.5562;      // -   [origin=predictive method=lee-kesler]
Tb          1038.62;      // K   [origin=predictive method=joback]
HvapTb      101728.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.707 3.12544 -0.00200776 5.277e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 23; } { group ACH; count 4; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 23; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-hexacosan-2-ylphenol" );
gibbsFormation
{
    dHf_298   -649870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1313.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173910.0
    phase     gas;
}
