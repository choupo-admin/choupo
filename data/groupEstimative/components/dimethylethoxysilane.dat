/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylethoxysilane  (C4H11OSi, CAS 14857-34-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H11OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dimethylethoxysilane;
formula     C4H11OSi;
CAS         14857-34-2;
InChIKey    DRUOQOFQRYFQGB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          103.216;      // g/mol [origin=calculated method=formula-sum]
Tc          481.09;      // K   [origin=predictive method=joback]
Pc          34.807;      // bar [origin=predictive method=joback]
omega       0.2313;      // -   [origin=predictive method=lee-kesler]
Tb          314.24;      // K   [origin=predictive method=joback]
HvapTb      27055.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.161 0.21756 0.0001246 -1.27e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethoxy(dimethyl)silicon" "silane, ethoxydimethyl-" "ethoxydimethylsilane" "ethoxydimethyl-silane" "dimethyl ethoxysilane" "sgqhhgcihcup@" "dimethylethoxysilane, ammonia-free" );
standardThermochemistry
{
    dHf_298   -313920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-174580.0
}
