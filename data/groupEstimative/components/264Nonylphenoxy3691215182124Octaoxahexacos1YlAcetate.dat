/*--------------------------------*- Choupo -*-----------------------*\
  Component: 26-(4-nonylphenoxy)-3,6,9,12,15,18,21,24-octaoxahexacos-1-yl acetate  (C35H62O11, CAS 67845-40-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        264Nonylphenoxy3691215182124Octaoxahexacos1YlAcetate;
formula     C35H62O11;
CAS         67845-40-3;
InChIKey    WSRIFSCIMSMXJL-UHFFFAOYSA-N;
MW          658.87;      // g/mol [origin=calculated method=formula-sum]
Tc          1774.51;      // K   [origin=predictive method=joback]
Pc          5.142;      // bar [origin=predictive method=joback]
omega       -0.1983;      // -   [origin=predictive method=lee-kesler]
Tb          1292.06;      // K   [origin=predictive method=joback]
HvapTb      125539.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (206.376 2.56684 -0.00075076 -1.444e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3COO; count 1; } { group CH2O; count 9; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 26; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 9; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-[2-[2-[2-[2-[2-(4-nonylphenoxy)ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethyl ethanoate" "3,6,9,12,15,18,21,24-octaoxahexacosan-1-ol, 26-(4-nonylphenoxy)-, 1-acetate" "3,6,9,12,15,18,21,24-octaoxahexacosan-1-ol, 26-(4-nonylphenoxy)-, acetate" "26-(4-nonylphenoxy)-3,6,9,12,15,18,21,24-octaoxahexacosan-1-yl acetate" "2-[2-[2-[2-[2-[2-[2-[2-[2-(4-nonylphenoxy)ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethyl acetate" );
gibbsFormation
{
    dHf_298   -2047930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1559.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-908770.0
    phase     gas;
}
