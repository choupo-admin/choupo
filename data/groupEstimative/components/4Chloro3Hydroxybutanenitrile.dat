/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-3-hydroxybutanenitrile  (C4H6ClNO, CAS 105-33-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro3Hydroxybutanenitrile;
formula     C4H6ClNO;
CAS         105-33-9;
InChIKey    LHBPNZDUNCZWFL-UHFFFAOYSA-N;
MW          119.548;      // g/mol [origin=calculated method=formula-sum]
Tc          715.27;      // K   [origin=predictive method=joback]
Pc          40.881;      // bar [origin=predictive method=joback]
omega       0.8854;      // -   [origin=predictive method=lee-kesler]
Tb          522.37;      // K   [origin=predictive method=joback]
HvapTb      55652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.752 0.3653 -0.0002168 4.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group OH; count 1; } { group CH2CN; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group Cl; count 1; } { group OH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-3-oxidanyl-butanenitrile" "4-chloro-3-hydroxybutyronitrile" "4-chloro-3-hydroxy butyronitrile" "butanenitrile, 4-chloro-3-hydroxy-" "4-chloro-3-hydroxy-butyronitrile" "gamma-chloro-beta-hydroxybutyronitrile" "3-hydroxy-4-chlorobutyronitrile; " "a-chloro-" "a-hydroxybutyronitrile" );
gibbsFormation
{
    dHf_298   -134260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-35210.0
    phase     gas;
}
