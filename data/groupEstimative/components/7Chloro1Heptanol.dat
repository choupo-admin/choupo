/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-chloro-1-heptanol  (C7H15ClO, CAS 55944-70-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Chloro1Heptanol;
formula     C7H15ClO;
CAS         55944-70-2;
InChIKey    DPNLUCKAZIFDLB-UHFFFAOYSA-N;
MW          150.646;      // g/mol [origin=calculated method=formula-sum]
Tc          655.76;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.8805;      // -   [origin=predictive method=lee-kesler]
Tb          489.37;      // K   [origin=predictive method=joback]
HvapTb      52240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.707 0.7096 -0.0004078 9.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group OH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-chloranylheptan-1-ol" "1-heptanol, 7-chloro-" "7-chloroheptan-1-ol" "7-chloro-1-heptanol;heptamethylene chlorohydrin;" );
standardThermochemistry
{
    dHf_298   -355780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-140690.0
}
