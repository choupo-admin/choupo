/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,1-dichloro-2-methylbutan-2-yl)benzene  (C11H14Cl2, CAS 36318-77-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichloro2Methylbutan2YlBenzene;
formula     C11H14Cl2;
CAS         36318-77-1;
InChIKey    HZWWIJSYUMVUTJ-UHFFFAOYSA-N;
MW          217.133;      // g/mol [origin=calculated method=formula-sum]
Tc          780.14;      // K   [origin=predictive method=joback]
Pc          25.252;      // bar [origin=predictive method=joback]
omega       0.4242;      // -   [origin=predictive method=lee-kesler]
Tb          549.15;      // K   [origin=predictive method=joback]
HvapTb      49442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.389 1.11524 -0.0008216 2.346e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[1,1-bis(chloranyl)-2-methyl-butan-2-yl]benzene" "1,1-dichloro-2-methyl-2-phenylbutane" "benzene, (1-(dichloromethyl)-1-methylpropyl)-" "benzene, [1-(dichloromethyl)-1-methylpropyl]-" "1,1-dichloro-2-methyl-2-phenylpropane" "(1-(dichloromethyl)-1-methylpropyl)benzene" );
gibbsFormation
{
    dHf_298   -79350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130690.0
    phase     gas;
}
