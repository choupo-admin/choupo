/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentadecyl 3-sulfanylpropanoate  (C18H36O2S, CAS 70942-41-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentadecyl3Sulfanylpropanoate;
formula     C18H36O2S;
CAS         70942-41-5;
InChIKey    WZVOSGCKRGEQOD-UHFFFAOYSA-N;
MW          316.544;      // g/mol [origin=calculated method=formula-sum]
Tc          911.52;      // K   [origin=predictive method=joback]
Pc          12.081;      // bar [origin=predictive method=joback]
omega       0.9506;      // -   [origin=predictive method=lee-kesler]
Tb          732.52;      // K   [origin=predictive method=joback]
HvapTb      69806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.826 1.68632 -0.0008832 1.515e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH2COO; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group COO; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadecyl 3-mercaptopropionate" "propanoic acid, 3-mercapto-, pentadecyl ester" "3-mercaptopropanoic acid, pentadecyl ester" );
gibbsFormation
{
    dHf_298   -693650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     970.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180300.0
    phase     gas;
}
