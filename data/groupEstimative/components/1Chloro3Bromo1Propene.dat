/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-3-bromo-1-propene  (C3H4BrCl, CAS 3737-00-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro3Bromo1Propene;
formula     C3H4BrCl;
CAS         3737-00-6;
InChIKey    AHUWMUAVZFJTOC-UHFFFAOYSA-N;
MW          155.419;      // g/mol [origin=calculated method=formula-sum]
Tc          582.56;      // K   [origin=predictive method=joback]
Pc          49.454;      // bar [origin=predictive method=joback]
omega       0.3027;      // -   [origin=predictive method=lee-kesler]
Tb          375.99;      // K   [origin=predictive method=joback]
HvapTb      33050.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.061 0.3538 -0.000315 1.15e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group Br; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 2; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-1-chloranyl-prop-1-ene" "(e)-3-bromo-1-chloro-prop-1-ene" "1-propene,3-bromo-1-chloro- (9ci)" "1-propene, 3-bromo-1-chloro-, (z)-" "propene,3-bromo-1-chloro- (6ci,7ci,8ci); 1-chloro-3-bromo-1-propene;3-bromo-1-chloro-1-propene; 3-bromo-1-chloropropene-1; cbp; cbp 55" );
standardThermochemistry
{
    dHf_298   22560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56990.0
}
