/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-pyridylacetate  (C9H11NO2, CAS 39931-77-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Pyridylacetate;
formula     C9H11NO2;
CAS         39931-77-6;
InChIKey    RPWXYCRIAGBAGY-UHFFFAOYSA-N;
MW          165.192;      // g/mol [origin=calculated method=formula-sum]
Tc          766.43;      // K   [origin=predictive method=joback]
Pc          32.840;      // bar [origin=predictive method=joback]
omega       0.5894;      // -   [origin=predictive method=lee-kesler]
Tb          544.12;      // K   [origin=predictive method=joback]
HvapTb      51521.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.728 0.75888 -0.00041166 6.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2COO; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-pyridin-3-ylethanoate" "3-pyridineacetic acid, ethyl ester" "ethyl 3-pyridineacetate" "ethyl 2-(pyridin-3-yl)acetate" "acetic acid, 2-(3-pyridyl)-, ethyl ester" "ethyl 2-(3-pyridyl)acetate" "ethyl 2-pyridin-3-ylacetate" "3-pyridylacetic acid ethyl ester" "3-pyridineacetic acid ethyl ester" "pyridine-3-acetic acid ethyl ester" "r733" );
standardThermochemistry
{
    dHf_298   -277050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96010.0
}
