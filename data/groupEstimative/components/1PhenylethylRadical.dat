/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylethyl radical  (C8H9, CAS 2348-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        1PhenylethylRadical;
formula     C8H9;
CAS         2348-51-8;
InChIKey    OGOPVNZBIWLOIJ-UHFFFAOYSA-N;
role        radical;
MW          105.16;      // g/mol [origin=calculated method=formula-sum]
Tc          626.52;      // K   [origin=predictive method=joback]
Pc          37.684;      // bar [origin=predictive method=joback]
omega       0.2773;      // -   [origin=predictive method=lee-kesler]
Tb          411.40;      // K   [origin=predictive method=joback]
HvapTb      35657.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.38 0.69492 -0.0004845 1.332e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethylbenzene" "1-phenylethyl" "1-phenyl-ethyl" "1-(phenyl)ethyl" );
gibbsFormation
{
    dHf_298   86690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=169000.0
    phase     gas;
}
