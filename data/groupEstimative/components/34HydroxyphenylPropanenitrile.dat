/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4-hydroxyphenyl)propanenitrile  (C9H9NO, CAS 17362-17-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34HydroxyphenylPropanenitrile;
formula     C9H9NO;
CAS         17362-17-3;
InChIKey    KDMJGLYRWRHKJS-UHFFFAOYSA-N;
MW          147.177;      // g/mol [origin=calculated method=formula-sum]
Tc          852.97;      // K   [origin=predictive method=joback]
Pc          37.777;      // bar [origin=predictive method=joback]
omega       0.7524;      // -   [origin=predictive method=lee-kesler]
Tb          614.90;      // K   [origin=predictive method=joback]
HvapTb      61396.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.118 0.8693 -0.00072236 2.482e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-hydroxyphenyl)propionitrile" ".beta.-(4-hydroxyphenyl)propionitrile" "4-hydroxyhydrocinnamonitrile" "4-hydroxyphenylpropionitrile" "benzenepropanenitrile,4-hydroxy-" "3-(p-hydroxyphenyl) propionitrile" "3-(4-hydroxyphenyl) propionitrile" "3-(p-hydroxyphenyl)propiononitrile" "3-(4-hydroxy-phenyl)-propionitrile" );
standardThermochemistry
{
    dHf_298   -4990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=115870.0
}
