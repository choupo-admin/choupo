/*--------------------------------*- Choupo -*-----------------------*\
  Component: a-nor-5-alpha-androstane-2-beta,17-beta-diol, 2-alpha-ethynyl-  (C20H30O2, CAS 1038-19-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aNor5AlphaAndrostane2Beta17BetaDiol2AlphaEthynyl;
formula     C20H30O2;
CAS         1038-19-3;
InChIKey    KSJJQCZCDJYYDJ-RZOQUZGISA-N;
MW          302.458;      // g/mol [origin=calculated method=formula-sum]
Tc          1079.00;      // K   [origin=predictive method=joback]
Pc          20.984;      // bar [origin=predictive method=joback]
omega       1.2708;      // -   [origin=predictive method=lee-kesler]
Tb          857.76;      // K   [origin=predictive method=joback]
HvapTb      88981.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-338.6 3.21284 -0.00319233 1.32359e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 5; } { group C; count 3; } { group OH; count 2; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 3; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,6s)-2-ethynyl-3a,5a-dimethyl-3,3b,4,5,6,7,8,8a,8b,9,10,10a-dodecahydro-1h-indeno[5,4-e]indene-2,6-diol" "2-beta,17-beta-dihydroxy-2-alpha-ethinyl-a-nor(5-alpha)androstane" );
standardThermochemistry
{
    dHf_298   -237770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     764.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=214240.0
}
