/*--------------------------------*- Choupo -*-----------------------*\
  Component: tonalid  (C18H26O, CAS 21145-77-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tonalid;
formula     C18H26O;
CAS         21145-77-7;
InChIKey    DNRJTBAOUJJKDY-UHFFFAOYSA-N;
MW          258.405;      // g/mol [origin=calculated method=formula-sum]
Tc          934.92;      // K   [origin=predictive method=joback]
Pc          17.104;      // bar [origin=predictive method=joback]
omega       0.6794;      // -   [origin=predictive method=lee-kesler]
Tb          709.08;      // K   [origin=predictive method=joback]
HvapTb      63835.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.59 2.10064 -0.00189498 7.5376e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group C; count 2; } { group ACH; count 2; } { group AC; count 3; } { group ACCH3; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3,5,5,6,8,8-hexamethyl-6,7-dihydronaphthalen-2-yl)ethanone" "tonalide" "tentarome" "tetralide" "musk tonalid" "6-acetyl-1,1,2,4,4,7-hexamethyltetralin" "1-(3,5,5,6,8,8-hexamethyl-5,6,7,8-tetrahydronaphthalen-2-yl)ethanone" "ahmt (perfume)" "ahmt" "ahtn" "acetyl hexamethyl tetralin" "ethanone, 1-(5,6,7,8-tetrahydro-3,5,5,6,8,8-hexamethyl-2-naphthalenyl)-" );
standardThermochemistry
{
    dHf_298   -268870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     742.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77530.0
}
