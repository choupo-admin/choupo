/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-octanedithiol  (C8H18S2, CAS 1191-62-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Octanedithiol;
formula     C8H18S2;
CAS         1191-62-4;
InChIKey    PGTWZHXOSWQKCY-UHFFFAOYSA-N;
MW          178.352;      // g/mol [origin=calculated method=formula-sum]
Tc          714.88;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.5410;      // -   [origin=predictive method=lee-kesler]
Tb          508.36;      // K   [origin=predictive method=joback]
HvapTb      46876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.398 0.8184 -0.0004562 9.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2SH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group SH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octane-1,8-dithiol" "1,8-dimercaptooctane" "octamethylene dimercaptan" "1,8-octamethylenedithiol" "1,8-dioctyl mercaptan" "nanothinks(tm) thio8" "1,8-octamethylenedithiol;" "1,8-octanedithiol solution" );
standardThermochemistry
{
    dHf_298   -131490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75260.0
}
