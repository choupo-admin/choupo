/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloropropyl isocyanate  (C4H6ClNO, CAS 13010-19-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ChloropropylIsocyanate;
formula     C4H6ClNO;
CAS         13010-19-0;
InChIKey    RQAVSDINDRNIKL-UHFFFAOYSA-N;
MW          119.548;      // g/mol [origin=calculated method=formula-sum]
Tc          583.13;      // K   [origin=predictive method=joback]
Pc          40.829;      // bar [origin=predictive method=joback]
omega       0.4387;      // -   [origin=predictive method=lee-kesler]
Tb          395.22;      // K   [origin=predictive method=joback]
HvapTb      38415.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH2; count 3; } { group dCd; count 1; } { group Cl; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-isocyanato-propane" "3-chloropropylisocyanate" "1-chloro-3-isocyanatopropane" "3-chloropropanisocyanate" "1-chloro-3-isocyanato-propane" "propane, 1-chloro-3-isocyanato-" "isocyanicacid, 3-chloropropyl ester (6ci,7ci,8ci);1-chloro-3-isocyanatopropane;" );
