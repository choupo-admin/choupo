/*--------------------------------*- Choupo -*-----------------------*\
  Component: flavan  (C15H14O, CAS 494-12-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        flavan;
formula     C15H14O;
CAS         494-12-2;
InChIKey    QOLIPNRNLBQTAU-UHFFFAOYSA-N;
MW          210.276;      // g/mol [origin=calculated method=formula-sum]
Tc          897.66;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.5443;      // -   [origin=predictive method=lee-kesler]
Tb          639.10;      // K   [origin=predictive method=joback]
HvapTb      58793.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.3 1.3498 -0.00094746 2.541e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenyl-3,4-dihydro-2h-chromene" "2-phenylchromane" "2h-1-benzopyran, 3,4-dihydro-2-phenyl-" "3,4-dihydro-2-phenyl-2h-1-benzopyran" "2-phenylchroman" "flavane" );
standardThermochemistry
{
    dHf_298   43300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=253140.0
}
