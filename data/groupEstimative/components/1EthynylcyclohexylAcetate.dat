/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethynylcyclohexyl acetate  (C10H14O2, CAS 5240-32-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1EthynylcyclohexylAcetate;
formula     C10H14O2;
CAS         5240-32-4;
InChIKey    YASSLXHVJQGNOK-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          723.60;      // K   [origin=predictive method=joback]
Pc          31.740;      // bar [origin=predictive method=joback]
omega       0.3975;      // -   [origin=predictive method=lee-kesler]
Tb          496.53;      // K   [origin=predictive method=joback]
HvapTb      44397.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.61 1.21912 -0.00103513 3.7669e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group CH3COO; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-ethynylcyclohexyl) ethanoate" "cyclohexanol, 1-ethynyl-, acetate" "1-ethynylcyclohexanol acetate" "1-acetoxy-1-ethynylcyclohexane" "(1-ethynylcyclohexyl) acetate" "cyclohexanol, 1-ethynyl-, 1-acetate" "acetic acid 1-ethynyl-cyclohexyl ester" );
gibbsFormation
{
    dHf_298   -205550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-35020.0
    phase     gas;
}
