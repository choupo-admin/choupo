/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2,2-dimethyl-3-(3,5-di-tert-butyl-4-hydroxyphenyl)propyl) 2,9-dimethyl-4,7-dithiadecanedioate  (C48H78O6S2, CAS 62546-75-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis22Dimethyl335DiTertButyl4HydroxyphenylPropyl29Dimethyl47D;
formula     C48H78O6S2;
CAS         62546-75-2;
InChIKey    ZZZJYMQEUKEZGV-UHFFFAOYSA-N;
MW          815.266;      // g/mol [origin=calculated method=formula-sum]
Tc          2451.99;      // K   [origin=predictive method=joback]
Pc          4.428;      // bar [origin=predictive method=joback]
omega       -0.3008;      // -   [origin=predictive method=lee-kesler]
Tb          1766.10;      // K   [origin=predictive method=joback]
HvapTb      175566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-129.382 5.12334 -0.00366196 1.0386e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 18; } { group CH2; count 4; } { group CH; count 2; } { group C; count 6; } { group ACH; count 4; } { group AC; count 4; } { group ACCH2; count 2; } { group ACOH; count 2; } { group COO; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 18; } { group CH2; count 8; } { group CH; count 2; } { group C; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } { group COO; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-(3,5-ditert-butyl-4-oxidanyl-phenyl)-2,2-dimethyl-propyl] 3-[2-[3-[3-(3,5-ditert-butyl-4-oxidanyl-phenyl)-2,2-dimethyl-propoxy]-2-methyl-3-oxidanylidene-propyl]sulfanylethylsulfanyl]-2-methyl-propanoate" "bis(3,5-di-tert-butyl-4-hydroxyphenyl)-2,2-dimethylpropyl) 3,3'-(1,2-ethanedylbis(thio)bis(2-methylpropionate)" "bis[3,5-di-tert-butyl-4-hydroxyphenyl]-2,2-dimethylpropyl] 3,3'-[1,2-ethanedylbis(thio)bis[2-methylpropionate]" "propanoic acid, 3,3'-(1,2-ethanediylbis(thio))bis(2-methyl-, 1,1'-bis(3-(3,5-bis(1,1-dimethylethyl)-4-hydroxyphenyl)-2,2-dimethylpropyl) ester" "propanoic acid, 3,3'-[1,2-ethanediylbis(thio)]bis[2-methyl-, 1,1'-bis[3-[3,5-bis(1,1-dimethylethyl)-4-hydroxyphenyl]-2,2-dimethylpropyl] ester" "[3-(3,5-ditert-butyl-4-hydroxyphenyl)-2,2-dimethylpropyl] 3-[2-[3-[3-(3,5-ditert-butyl-4-hydroxyphenyl)-2,2-dimethylpropoxy]-2-methyl-3-oxopropyl]sulfanylethylsulfanyl]-2-methylpropanoate" "propanoic acid, 3,3'-(1,2-ethanediylbis(thio))bis(2-methyl-, bis(3-(3,5-bis(1,1-dimethylethyl)-4-hydroxyphenyl)-2,2-dimethylpropyl) ester" );
standardThermochemistry
{
    dHf_298   -1575370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1814.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-312000.0
}
