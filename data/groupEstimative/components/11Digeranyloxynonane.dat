/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-digeranyloxynonane  (C29H52O2, CAS 67785-73-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Digeranyloxynonane;
formula     C29H52O2;
CAS         67785-73-3;
InChIKey    FOZNRVHWZWWCPV-UHFFFAOYSA-N;
MW          432.733;      // g/mol [origin=calculated method=formula-sum]
Tc          1130.99;      // K   [origin=predictive method=joback]
Pc          6.925;      // bar [origin=predictive method=joback]
omega       0.6327;      // -   [origin=predictive method=lee-kesler]
Tb          923.68;      // K   [origin=predictive method=joback]
HvapTb      84732.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.647 2.71804 -0.0016794 4.206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 11; } { group CH; count 1; } { group CH=C; count 4; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 13; } { group CH; count 1; } { group dCH; count 4; } { group dC; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[1-(3,7-dimethylocta-2,6-dienoxy)nonoxy]-3,7-dimethyl-octa-2,6-diene" "nonane, 1,1-bis[(3,7-dimethyl-2,6-octadienyl)oxy]-" "nonane, 1,1-bis[(3,7-dimethyl-2,6-octadien-1-yl)oxy]-" "nonane,1,1-bis[(3,7-dimethyl-2,6-octadienyl)oxy]- (9ci);1,1-bis{[(2e)-3,7-dimethylocta-2,6-dien-1-yl]oxy}nonane;nonane,1,1-bis[(3,7-dimethyl-2,6-octadien-1-yl)oxy]-;(2e)-1-[1-[(2e)-3,7-dimethylocta-2,6-dienoxy]nonoxy]-3,7-dimethylocta-2,;" );
gibbsFormation
{
    dHf_298   -481890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1255.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=267540.0
    phase     gas;
}
