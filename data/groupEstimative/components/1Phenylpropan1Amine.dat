/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylpropan-1-amine  (C9H13N, CAS 2941-20-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenylpropan1Amine;
formula     C9H13N;
CAS         2941-20-0;
InChIKey    AQFLVLHRZFLDDV-UHFFFAOYSA-N;
MW          135.21;      // g/mol [origin=calculated method=formula-sum]
Tc          728.91;      // K   [origin=predictive method=joback]
Pc          35.179;      // bar [origin=predictive method=joback]
omega       0.4791;      // -   [origin=predictive method=lee-kesler]
Tb          504.29;      // K   [origin=predictive method=joback]
HvapTb      48157.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.389 0.84772 -0.0005436 1.319e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "alpha-ethylbenzylamine" "1-phenylpropylamine" "a-ethylbenzylamine" "alpha-phenylpropylamine" "alpha-ethylbenzenemethanamine" "benzylamine, alpha-ethyl-" "benzenemethanamine, .alpha.-ethyl" "1-phenyl-1-propanamine" "(s)-1-phenylpropylamine" "1-phenyl-propyl-amine" "1-propanamine, phenyl-" );
standardThermochemistry
{
    dHf_298   35950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=201320.0
}
