/*--------------------------------*- Choupo -*-----------------------*\
  Component: sabatine  (C29H47NO8, CAS 124-80-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sabatine;
formula     C29H47NO8;
CAS         124-80-1;
InChIKey    IJZIXCZIZHENJV-ONCBQHFTSA-N;
MW          537.694;      // g/mol [origin=calculated method=formula-sum]
Tc          2112.42;      // K   [origin=predictive method=joback]
Pc          15.307;      // bar [origin=predictive method=joback]
omega       0.2901;      // -   [origin=predictive method=lee-kesler]
Tb          1516.76;      // K   [origin=predictive method=joback]
HvapTb      181955.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-511.63 5.12728 -0.0050168 2.0538e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 9; } { group C; count 5; } { group OH; count 6; } { group CH3COO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 10; } { group CH_ring; count 9; } { group C_ring; count 5; } { group OH; count 6; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "sabadine" "cevane-3,4,12,14,16,17,20-heptol, 3-acetate, (3beta,4alpha,16-beta)-" );
standardThermochemistry
{
    dHf_298   -1491700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1245.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-624440.0
}
