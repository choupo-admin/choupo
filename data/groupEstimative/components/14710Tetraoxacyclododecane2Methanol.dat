/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,7,10-tetraoxacyclododecane-2-methanol  (C9H18O5, CAS 75507-26-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14710Tetraoxacyclododecane2Methanol;
formula     C9H18O5;
CAS         75507-26-5;
InChIKey    NJIPEIQHUNDGPY-UHFFFAOYSA-N;
MW          206.238;      // g/mol [origin=calculated method=formula-sum]
Tc          873.47;      // K   [origin=predictive method=joback]
Pc          35.814;      // bar [origin=predictive method=joback]
omega       0.9723;      // -   [origin=predictive method=lee-kesler]
Tb          650.67;      // K   [origin=predictive method=joback]
HvapTb      71808.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.049 0.9453 -0.0002432 -9.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group FCH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 1; } { group OH; count 1; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,7,10-tetraoxacyclododec-2-ylmethanol" "1,4,7,10-tetraoxacyclododecan-2-methanol" "(12-crown-4)-2-methanol" "2-hydroxymethyl-12-crown-4" "2-(hydroxymethyl)-12-crown 4-ether" "2-(hydroxymethyl)-12-crown-4-ether" "1,4,7,10-tetraoxacyclododecan-2-ylmethanol" "(2,5,8,11-tetraoxacyclododecyl)methan-1-ol" );
standardThermochemistry
{
    dHf_298   -891960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-504550.0
}
