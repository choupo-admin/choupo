/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butanamine, 3,3-dimethyl-  (C6H15N, CAS 3850-30-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butanamine33Dimethyl;
formula     C6H15N;
CAS         3850-30-4;
InChIKey    DXSUORGKJZADET-UHFFFAOYSA-N;
MW          101.193;      // g/mol [origin=calculated method=formula-sum]
Tc          602.53;      // K   [origin=predictive method=joback]
Pc          34.199;      // bar [origin=predictive method=joback]
omega       0.3430;      // -   [origin=predictive method=lee-kesler]
Tb          405.74;      // K   [origin=predictive method=joback]
HvapTb      37907.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.23 0.76748 -0.000521 1.426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group C; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylbutan-2-amine" "1,2,2-trimethylpropylamine" "2-amino-3,3-dimethylbutane" "3,3-dimethyl-2-butylamine" "3,3-dimethyl-2-aminobutane" "propylamine, 1,2,2-trimethyl-" "3,3-dimethylbut-2-ylamine" "1,2,2-trimethyl-propylamine" "3,3-dimethyl-2-butyl amine" "3,3-dimethyl-butan-2-amine" "propylamine,1,2,2-trimethyl- (6ci,7ci,8ci);(?a'a a'a currency)-2-amino-3,3-dimethylbutane;(?a'a a'a currency)-3,3-dimethyl-2-butanamine;1,2,2-trimethylpropanamine;1,2,2-trimethylpropylamine;2-amino-3,3-dimethylbutane;3,3-dimethyl-2-aminobutane;3,3-dimethyl-2-butanamine;3,3-dimethylbut-2-ylamine;3-amino-2,2-dimethylbutane;dl-3,3-dimethyl-2-aminobutane;" );
standardThermochemistry
{
    dHf_298   -147410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66490.0
}
