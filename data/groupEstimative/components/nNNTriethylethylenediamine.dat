/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,n'-triethylethylenediamine  (C8H20N2, CAS 105-04-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNNTriethylethylenediamine;
formula     C8H20N2;
CAS         105-04-4;
InChIKey    HDCAZTXEZQWTIJ-UHFFFAOYSA-N;
MW          144.262;      // g/mol [origin=calculated method=formula-sum]
Tc          612.26;      // K   [origin=predictive method=joback]
Pc          25.637;      // bar [origin=predictive method=joback]
omega       0.6161;      // -   [origin=predictive method=lee-kesler]
Tb          445.25;      // K   [origin=predictive method=joback]
HvapTb      41881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.285 0.96396 -0.0005726 1.319e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n',n'-triethylethane-1,2-diamine" "1,2-ethanediamine, n,n,n'-triethyl-" "triethylethylenediamine" "n,n,n'-triethylethane-1,2-diamine" "n1,n1,n2-triethyl-1,2-ethanediamine" "ethylenediamine, n,n,n'-triethyl-" "[2-(diethylamino)ethyl](ethyl)amine" "1,2-ethanediamine, n1,n1,n2-triethyl-" "n,n,n-triethylenediamine" "1, n,n,n'-triethyl-" "n,n'-triethylethylenediamine" "diethyl(2-ethylaminoethyl)amine" );
gibbsFormation
{
    dHf_298   -87450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=216650.0
    phase     gas;
}
