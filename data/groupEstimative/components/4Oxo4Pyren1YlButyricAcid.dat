/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-oxo-4-pyren-1-yl-butyric acid  (C20H14O3, CAS 7499-60-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Oxo4Pyren1YlButyricAcid;
formula     C20H14O3;
CAS         7499-60-7;
InChIKey    AAJQTWWVKREOQP-UHFFFAOYSA-N;
MW          302.329;      // g/mol [origin=calculated method=formula-sum]
Tc          1194.48;      // K   [origin=predictive method=joback]
Pc          23.772;      // bar [origin=predictive method=joback]
omega       1.3403;      // -   [origin=predictive method=lee-kesler]
Tb          947.44;      // K   [origin=predictive method=joback]
HvapTb      92570.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.208 1.7333 -0.00146386 4.9546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 9; } { group AC; count 7; } { group CH2CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 7; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylidene-4-pyren-1-yl-butanoic acid" "1-pyrenebutanoic acid, .gamma.-oxo-" "1-pyrenebutanoic acid, " "a-oxo-" "4-oxo-4-pyren-1-yl-butyricacid" "4-oxo-4-pyren-1-ylbutanoic acid" "4-oxo-4-(pyren-1-yl)butanoic acid" "4-oxo-4-pyrenylbutanoic acid" "a-oxo-1-pyrenebutyric acid" "gamma-oxo-1-pyrenebutyric acid" "gamma-oxopyrene-1-butyric acid" "1-pyrenebutanoic acid, g-oxo-" "aajqtwwvkreoqp-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -189110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42400.0
    phase     gas;
}
