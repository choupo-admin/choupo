/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloropentafluoroethane  (C2ClF5, CAS 76-15-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloropentafluoroethane;
formula     C2ClF5;
CAS         76-15-3;
InChIKey    RFCAUADVODFSLZ-UHFFFAOYSA-N;
MW          154.462;      // g/mol [origin=calculated method=formula-sum]
Tc          416.74;      // K   [origin=predictive method=joback]
Pc          37.454;      // bar [origin=predictive method=joback]
omega       0.2621;      // -   [origin=predictive method=lee-kesler]
Tb          272.68;      // K   [origin=predictive method=joback]
HvapTb      17754.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.53 0.5112 -0.000531 1.934e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CF3; count 1; } { group CClF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group F; count 5; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-1,1,2,2,2-pentakis(fluoranyl)ethane" "ethane, chloropentafluoro-" "pentafluoroethyl chloride" "1-chloro-1,1,2,2,2-pentafluoroethane" "chloroperfluoroethane" "pentafluorochloroethane" "perfluoroethyl chloride" "monochloropentafluoroethane" "(mono)chloropentafluoroethane" "chloropentafluorethane [french]" "ethane, 1-chloro-1,1,2,2,2-pentafluoro-" "chloropentafluoretano" );
gibbsFormation
{
    dHf_298   -1098400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1014340.0
    phase     gas;
}
