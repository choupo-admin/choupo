/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-4-chloronaphthalene  (C10H6BrCl, CAS 53220-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo4Chloronaphthalene;
formula     C10H6BrCl;
CAS         53220-82-9;
InChIKey    WUGJECZACFHDFE-UHFFFAOYSA-N;
MW          241.512;      // g/mol [origin=calculated method=formula-sum]
Tc          848.30;      // K   [origin=predictive method=joback]
Pc          39.062;      // bar [origin=predictive method=joback]
omega       0.5289;      // -   [origin=predictive method=lee-kesler]
Tb          587.61;      // K   [origin=predictive method=joback]
HvapTb      53914.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.87 0.7972 -0.00064584 2.077e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACCl; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 4; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-chloranyl-naphthalene" "naphthalene, 1-bromo-4-chloro-" );
gibbsFormation
{
    dHf_298   165520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=235510.0
    phase     gas;
}
