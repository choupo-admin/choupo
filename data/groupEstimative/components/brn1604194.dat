/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1604194  (C25H34N2O4, CAS 17766-62-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1604194;
formula     C25H34N2O4;
CAS         17766-62-0;
InChIKey    SNMTWROJPBGTIB-UHFFFAOYSA-N;
MW          426.557;      // g/mol [origin=calculated method=formula-sum]
Tc          1236.91;      // K   [origin=predictive method=joback]
Pc          12.746;      // bar [origin=predictive method=joback]
omega       1.1026;      // -   [origin=predictive method=lee-kesler]
Tb          1003.34;      // K   [origin=predictive method=joback]
HvapTb      95604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.749 2.30692 -0.00140494 3.0856e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 6; } { group AC; count 5; } { group ACCH2; count 1; } { group CH3O; count 3; } { group CH2N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 3; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[(4-tert-butylphenyl)methyl]piperazin-1-yl]-(3,4,5-trimethoxyphenyl)methanone" "4-(p-tert-butylbenzyl)piperazinyl 3,4,5-trimethoxyphenyl ketone" "piperazine, 1-(p-tert-butylbenzyl)-4-(3,4,5-trimethoxybenzoyl)-" "ketone, 4-(p-tert-butylbenzyl)piperazinyl 3,4,5-trimethoxyphenyl" "[4-(4-tert-butylbenzyl)piperazin-1-yl](3,4,5-trimethoxyphenyl)methanone" );
gibbsFormation
{
    dHf_298   -428100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     918.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=182760.0
    phase     gas;
}
