/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-4-phenyl-1,3-dioxolane  (C10H12O2, CAS 33941-99-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl4Phenyl13Dioxolane;
formula     C10H12O2;
CAS         33941-99-0;
InChIKey    YPPGSWWESBCSCT-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          755.38;      // K   [origin=predictive method=joback]
Pc          33.881;      // bar [origin=predictive method=joback]
omega       0.4352;      // -   [origin=predictive method=lee-kesler]
Tb          519.59;      // K   [origin=predictive method=joback]
HvapTb      49098.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.01 0.97412 -0.0005956 1.272e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 2-methyl-4-phenyl-" "acetaldehyde styleneglycol acetal 1" "agn-pc-00gt9h" "acetaldehyde styleneglycol acetal 2" );
standardThermochemistry
{
    dHf_298   -237060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     243.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=2330.0
}
