/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethyl-2-hexylcyclopropane  (C11H22, CAS 41845-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dimethyl2Hexylcyclopropane;
formula     C11H22;
CAS         41845-49-2;
InChIKey    UQECZADINQGSLE-UHFFFAOYSA-N;
MW          154.297;      // g/mol [origin=calculated method=formula-sum]
Tc          634.52;      // K   [origin=predictive method=joback]
Pc          22.000;      // bar [origin=predictive method=joback]
omega       0.4411;      // -   [origin=predictive method=lee-kesler]
Tb          453.59;      // K   [origin=predictive method=joback]
HvapTb      38533.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.405 1.46516 -0.001272 4.888e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexyl-1,1-dimethyl-cyclopropane" "2-hexyl-1,1-dimethylcyclopropane" "1,1-dimethyl-2-hexyl-cyclopropane" );
standardThermochemistry
{
    dHf_298   -202670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89290.0
}
