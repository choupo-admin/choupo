/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-3,4-dimethyl-2-pentene  (C7H14, CAS 4914-91-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis34Dimethyl2Pentene;
formula     C7H14;
CAS         4914-91-4;
InChIKey    PPBWEVVDSRKEIK-ALCCZGGFSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          543.54;      // K   [origin=predictive method=joback]
Pc          30.024;      // bar [origin=predictive method=joback]
omega       0.2656;      // -   [origin=predictive method=lee-kesler]
Tb          363.36;      // K   [origin=predictive method=joback]
HvapTb      30826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.03 0.69468 -0.0004463 1.208e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-3,4-dimethylpent-2-ene" "(z)-3,4-dimethyl-2-pentene" "2-pentene, 3,4-dimethyl-, (z)-" "3,4-dimethyl-cis-2-pentene" "(2z)-3,4-dimethylpent-2-ene" "2-pentene, 3,4-dimethyl-, (2z)-" );
standardThermochemistry
{
    dHf_298   -85660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77290.0
}
