/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyl stearate  (C21H42O2, CAS 112-10-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylStearate;
formula     C21H42O2;
CAS         112-10-7;
InChIKey    ZPWFUIUNWDIYCJ-UHFFFAOYSA-N;
MW          326.565;      // g/mol [origin=calculated method=formula-sum]
Tc          909.33;      // K   [origin=predictive method=joback]
Pc          9.639;      // bar [origin=predictive method=joback]
omega       0.8619;      // -   [origin=predictive method=lee-kesler]
Tb          737.86;      // K   [origin=predictive method=joback]
HvapTb      69359.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.526 1.94996 -0.0010272 1.811e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 15; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 16; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl octadecanoate" "octadecanoic acid, 1-methylethyl ester" "1-methylethyl octadecanoate" "stearic acid, isopropyl ester" "octadecanoic acid,1-methylethyl ester" "stearicacid, isopropyl ester (6ci,7ci,8ci);emerest 2310;isopropyl octadecanoate;isopropyl stearate;kessco ips;wickenol 127;" );
gibbsFormation
{
    dHf_298   -799330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1015.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-186870.0
    phase     gas;
}
