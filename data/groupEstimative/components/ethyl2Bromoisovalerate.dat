/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-bromoisovalerate  (C7H13BrO2, CAS 609-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Bromoisovalerate;
formula     C7H13BrO2;
CAS         609-12-1;
InChIKey    WNFUWONOILPKNX-UHFFFAOYSA-N;
MW          209.083;      // g/mol [origin=calculated method=formula-sum]
Tc          680.83;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.5598;      // -   [origin=predictive method=lee-kesler]
Tb          483.26;      // K   [origin=predictive method=joback]
HvapTb      44242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.761 0.66406 -0.0003402 4.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-bromanyl-3-methyl-butanoate" "ethyl 2-bromo-3-methylbutanoate" "ethyl 2-bromo-3-methylbutyrate" "ethyl .alpha.-bromoisovalerate" "ethyl " "a-bromoisovalerate" "butanoic acid, 2-bromo-3-methyl-, ethyl ester" "ethyl 2-bromo isovalerate" "alpha-bromoisovaleric acid ethyl ester" "butanoic acid, 2-bromo-3-methyl-, ethyl ester, (s)-" "ethyl alpha-bromoisovalerate" "2-bromoisovaleric acid ethyl ester" ".alpha.-bromoisovaleric acid ethyl ester" );
standardThermochemistry
{
    dHf_298   -489320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-292870.0
}
