/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenedicarboxylic acid, polymer with 2-ethyl-2-(hydroxymethyl)-1,3-propanediol, benzoate (9z,12z)-9,12-octadecadienoate  (C39H54O9, CAS 69070-57-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BenzenedicarboxylicAcidPolymerWith2Ethyl2Hydroxymethyl13Pr;
formula     C39H54O9;
CAS         69070-57-1;
InChIKey    OXSKATZFRCPIBN-NNNYMDSFSA-N;
MW          666.852;      // g/mol [origin=calculated method=formula-sum]
Tc          2389.54;      // K   [origin=predictive method=joback]
Pc          6.250;      // bar [origin=predictive method=joback]
omega       -0.2328;      // -   [origin=predictive method=lee-kesler]
Tb          1656.39;      // K   [origin=predictive method=joback]
HvapTb      172357.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.784 3.47714 -0.00200416 3.801e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group C; count 1; } { group CH=CH; count 2; } { group ACH; count 9; } { group AC; count 3; } { group OH; count 1; } { group CH2COO; count 1; } { group COOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group C; count 1; } { group dCH; count 4; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group OH; count 1; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid;[2-(hydroxymethyl)-2-[[(9e,12e)-octadeca-9,12-dienoyl]oxymethyl]butyl] benzoate" );
gibbsFormation
{
    dHf_298   -1759960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1771.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-894170.0
    phase     gas;
}
