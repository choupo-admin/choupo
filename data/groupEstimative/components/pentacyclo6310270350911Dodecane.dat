/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentacyclo(6.3.1.0(2,7).0(3,5).0(9,11))dodecane  (C12H16, CAS 82110-70-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentacyclo6310270350911Dodecane;
formula     C12H16;
CAS         82110-70-1;
InChIKey    CUEVXBHHOPVSBW-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          689.32;      // K   [origin=predictive method=joback]
Pc          27.877;      // bar [origin=predictive method=joback]
omega       0.4242;      // -   [origin=predictive method=lee-kesler]
Tb          481.04;      // K   [origin=predictive method=joback]
HvapTb      40428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-226.05 1.8476 -0.001703 6.332e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentacyclo[6.3.1.0(2,7).0(3,5).0(9,11)]dodecane" "decahydro-1h-2,4-methanodicyclopropa[a,f]indene" );
standardThermochemistry
{
    dHf_298   30450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     -14.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=367080.0
}
