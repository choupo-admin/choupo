/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(dimethylamino)-2-methoxybenzaldehyde  (C10H13NO2, CAS 84562-48-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H13NO2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Dimethylamino2Methoxybenzaldehyde;
formula     C10H13NO2;
CAS         84562-48-1;
InChIKey    HGDRXADJVGVGBC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          179.219;      // g/mol [origin=calculated method=formula-sum]
Tc          678.63;      // K   [origin=predictive method=joback]
Pc          29.155;      // bar [origin=predictive method=joback]
omega       0.4729;      // -   [origin=predictive method=lee-kesler]
Tb          476.32;      // K   [origin=predictive method=joback]
HvapTb      43534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.2 0.82476 -0.00057192 1.628e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CHO; count 1; } { group CH3O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(dimethylamino)-2-methoxy-benzaldehyde" "4-dimethylamino-2-methoxybenzaldehyde" "benzaldehyde,4-(dimethylamino)-2-methoxy-" );
standardThermochemistry
{
    dHf_298   -24380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176210.0
}
