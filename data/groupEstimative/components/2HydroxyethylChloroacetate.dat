/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyethyl chloroacetate  (C4H7ClO3, CAS 35280-53-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyethylChloroacetate;
formula     C4H7ClO3;
CAS         35280-53-6;
InChIKey    JUHXSFLHDUCNCZ-UHFFFAOYSA-N;
MW          138.547;      // g/mol [origin=calculated method=formula-sum]
Tc          655.29;      // K   [origin=predictive method=joback]
Pc          42.056;      // bar [origin=predictive method=joback]
omega       0.9063;      // -   [origin=predictive method=lee-kesler]
Tb          478.95;      // K   [origin=predictive method=joback]
HvapTb      52969.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.843 0.3698 -0.00015 -1.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 1; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group Cl; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hydroxyethyl 2-chloranylethanoate" "2-hydroxyethyl 2-chloroacetate" );
gibbsFormation
{
    dHf_298   -611140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-476320.0
    phase     gas;
}
