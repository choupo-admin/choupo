/*--------------------------------*- Choupo -*-----------------------*\
  Component: arotinoid ethyl ester  (C26H32O2, CAS 71441-09-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        arotinoidEthylEster;
formula     C26H32O2;
CAS         71441-09-3;
InChIKey    NULUAKSYPPSJCO-FBMGVBCBSA-N;
MW          376.54;      // g/mol [origin=calculated method=formula-sum]
Tc          1172.73;      // K   [origin=predictive method=joback]
Pc          12.548;      // bar [origin=predictive method=joback]
omega       0.8648;      // -   [origin=predictive method=lee-kesler]
Tb          931.86;      // K   [origin=predictive method=joback]
HvapTb      84927.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-183.529 2.80132 -0.00242698 9.038e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 3; } { group C; count 2; } { group CH=C; count 1; } { group ACH; count 7; } { group AC; count 5; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 4-[(e)-2-(5,5,8,8-tetramethyl-6,7-dihydronaphthalen-2-yl)prop-1-enyl]benzoate" "ethyl-p-((e)-2-(5,6,7,8-tetrahydro-5,5,8,8-tetramethyl-2-naphthyl)-1-propenyl)benzoate" "benzoic acid, p-((e)-2-(5,6,7,8-tetrahydro-5,5,8,8-tetramethyl-2-naphthyl)-1-propenyl)-, ethyl ester" "ethyl-p-((e)-2-(5,6,7,8-tetrahydro-5,5,8,8-tetramethyl-2-naphthyl)-1-propenyl)benzoic acid" "ethyl-p-(2-(5,6,7,8-tetrahydro-5,5,8,8-tetramethyl-2-naphthyl)-1-propenyl)benzoate" "benzoic acid, p-((e)-2-(5,6,7,8-tetrahydro-5,5,8,8-tetramethyl-2-naphthyl)-1-propenyl)-,ethyl ester" );
gibbsFormation
{
    dHf_298   -274390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1004.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=155230.0
    phase     gas;
}
