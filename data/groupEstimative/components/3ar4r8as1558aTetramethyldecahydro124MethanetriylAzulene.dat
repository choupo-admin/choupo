/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3ar,4r,8as)-1,5,5,8a-tetramethyldecahydro-1,2,4-(methanetriyl)azulene  (C15H24, CAS 115440-60-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ar4r8as1558aTetramethyldecahydro124MethanetriylAzulene;
formula     C15H24;
CAS         115440-60-3;
InChIKey    WCEIQUQVIOGRBF-ZYBGGCANSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          776.24;      // K   [origin=predictive method=joback]
Pc          22.104;      // bar [origin=predictive method=joback]
omega       0.4177;      // -   [origin=predictive method=lee-kesler]
Tb          552.20;      // K   [origin=predictive method=joback]
HvapTb      44084.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-338.75 2.83828 -0.003151 1.4038e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 4; } { group C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 4; } { group C_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4-methenoazulene, decahydro-1,5,5,8a-tetramethyl-, (1s,2r,3ar,4r,8ar,9s)-" "(1s-(1alpha,2alpha,3abeta,4alpha,8abeta,9r*))-decahydro-1,5,5,8a-tetramethyl-1,2,4-methenoazulene" );
gibbsFormation
{
    dHf_298   -70870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=290920.0
    phase     gas;
}
