/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-xylylene sulfide  (C8H8S, CAS 2471-92-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oXylyleneSulfide;
formula     C8H8S;
CAS         2471-92-3;
InChIKey    KVRZARWOKBNZMM-UHFFFAOYSA-N;
MW          136.212;      // g/mol [origin=calculated method=formula-sum]
Tc          720.27;      // K   [origin=predictive method=joback]
Pc          43.684;      // bar [origin=predictive method=joback]
omega       0.3324;      // -   [origin=predictive method=lee-kesler]
Tb          473.54;      // K   [origin=predictive method=joback]
HvapTb      42374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.35 0.81721 -0.00066986 2.209e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dihydro-2-benzothiophene" "1,3-dihydrobenzo[c]thiophene" "benzo[c]thiophene, 1,3-dihydro-" "dihydroisobenzothiophene" "benzo(c)thiophene, 1,3-dihydro-" "1,3-dihydro-benzo[c]thiophene" );
gibbsFormation
{
    dHf_298   155010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=227580.0
    phase     gas;
}
