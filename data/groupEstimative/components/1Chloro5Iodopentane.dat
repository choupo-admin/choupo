/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-5-iodopentane  (C5H10ClI, CAS 60274-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro5Iodopentane;
formula     C5H10ClI;
CAS         60274-60-4;
InChIKey    GUUHKOCYWBEGGX-UHFFFAOYSA-N;
MW          232.485;      // g/mol [origin=calculated method=formula-sum]
Tc          654.37;      // K   [origin=predictive method=joback]
Pc          32.393;      // bar [origin=predictive method=joback]
omega       0.3606;      // -   [origin=predictive method=lee-kesler]
Tb          444.57;      // K   [origin=predictive method=joback]
HvapTb      40482.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.925 0.5246 -0.00035 9.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2Cl; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group Cl; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-5-iodanyl-pentane" "pentamethylene chloroiodide" "pentane, 1-chloro-5-iodo-" "5-chloropentyl iodide" "5-iodopentyl chloride" "pentane,1-chloro-5-iodo-" "1-chloro-5-iodopentane;1-iodo-5-chloropentane; 5-chloro-1-iodopentane" );
standardThermochemistry
{
    dHf_298   -85400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37410.0
}
