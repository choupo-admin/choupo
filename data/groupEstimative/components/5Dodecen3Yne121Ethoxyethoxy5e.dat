/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-dodecen-3-yne, 12-(1-ethoxyethoxy)-, (5e)-  (C16H28O2, CAS 58763-67-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Dodecen3Yne121Ethoxyethoxy5e;
formula     C16H28O2;
CAS         58763-67-0;
InChIKey    AFFLAKUHPBBSGC-UHFFFAOYSA-N;
MW          252.398;      // g/mol [origin=calculated method=formula-sum]
Tc          806.22;      // K   [origin=predictive method=joback]
Pc          15.164;      // bar [origin=predictive method=joback]
omega       0.7528;      // -   [origin=predictive method=lee-kesler]
Tb          623.24;      // K   [origin=predictive method=joback]
HvapTb      57752.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.038 1.27356 -0.00061946 9.548e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2O; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group dCH; count 2; } { group tC; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "12-(1-ethoxyethoxy)dodec-5-en-3-yne" );
gibbsFormation
{
    dHf_298   -253770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     757.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=154420.0
    phase     gas;
}
