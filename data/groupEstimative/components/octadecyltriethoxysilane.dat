/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecyltriethoxysilane  (C24H52O3Si, CAS 7399-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C24H52O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        octadecyltriethoxysilane;
formula     C24H52O3Si;
CAS         7399-00-0;
InChIKey    FZMJEGJVKFTGMU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          416.762;      // g/mol [origin=calculated method=formula-sum]
Tc          1000.71;      // K   [origin=predictive method=joback]
Pc          7.332;      // bar [origin=predictive method=joback]
omega       0.6858;      // -   [origin=predictive method=lee-kesler]
Tb          817.38;      // K   [origin=predictive method=joback]
HvapTb      76542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (98.39 1.88808 -0.000534 -1.072e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 17; } { group CH2O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 20; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethoxy(octadecyl)silane" "triethoxyoctadecylsilane" "n-octadecyltriethoxysilane" "triethoxystearylsilane" "octadecyl triethoxysilane" );
standardThermochemistry
{
    dHf_298   -1046970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1251.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-268560.0
}
