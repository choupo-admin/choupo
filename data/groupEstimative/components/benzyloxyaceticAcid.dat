/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyloxyacetic acid  (C9H10O3, CAS 30379-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzyloxyaceticAcid;
formula     C9H10O3;
CAS         30379-55-6;
InChIKey    GRZHHTYDZVRPIC-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          821.35;      // K   [origin=predictive method=joback]
Pc          35.473;      // bar [origin=predictive method=joback]
omega       0.8153;      // -   [origin=predictive method=lee-kesler]
Tb          600.13;      // K   [origin=predictive method=joback]
HvapTb      57478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.098 0.7675 -0.0004586 9.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylmethoxyethanoic acid" "(benzyloxy)acetic acid" "acetic acid, (phenylmethoxy)-" "2-(benzyloxy)acetic acid" "phenylmethoxyacetic acid" "2-(phenylmethoxy)acetic acid" "phenylmethoxyaceticacid" "(benzyloxy)-acetic acid" "2-phenylmethoxyacetic acid" "2-(benzyl-oxy)acetic acid" "m040" );
standardThermochemistry
{
    dHf_298   -475050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-311600.0
}
