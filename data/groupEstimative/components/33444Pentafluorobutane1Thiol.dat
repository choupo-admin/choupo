/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,4,4,4-pentafluorobutane-1-thiol  (C4H5F5S, CAS 68140-18-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33444Pentafluorobutane1Thiol;
formula     C4H5F5S;
CAS         68140-18-1;
InChIKey    WEILNYJKAUGBAU-UHFFFAOYSA-N;
MW          180.134;      // g/mol [origin=calculated method=formula-sum]
Tc          507.26;      // K   [origin=predictive method=joback]
Pc          33.606;      // bar [origin=predictive method=joback]
omega       0.3651;      // -   [origin=predictive method=lee-kesler]
Tb          343.87;      // K   [origin=predictive method=joback]
HvapTb      24558.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.348 0.7217 -0.0006418 2.138e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2SH; count 1; } { group CF3; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 2; } { group F; count 5; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,4-pentakis(fluoranyl)butane-1-thiol" "perfluoroalkyl (c2-c8)ethyl mercaptan" "thiols, c4-10, gamma-omega-perfluoro" "thiols, c4-20, gamma-omega-perfluoro" "1,1,2,2-tetrahydroperfluoroalkyl (c4-c20) mercaptan" );
gibbsFormation
{
    dHf_298   -1085460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-956180.0
    phase     gas;
}
