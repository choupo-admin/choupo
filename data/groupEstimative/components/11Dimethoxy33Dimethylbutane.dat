/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethoxy-3,3-dimethylbutane  (C8H18O2, CAS 78263-32-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dimethoxy33Dimethylbutane;
formula     C8H18O2;
CAS         78263-32-8;
InChIKey    XQXASMBOOKNENN-UHFFFAOYSA-N;
MW          146.23;      // g/mol [origin=calculated method=formula-sum]
Tc          602.31;      // K   [origin=predictive method=joback]
Pc          25.176;      // bar [origin=predictive method=joback]
omega       0.4210;      // -   [origin=predictive method=lee-kesler]
Tb          423.81;      // K   [origin=predictive method=joback]
HvapTb      36538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.461 0.7692 -0.0003644 4.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethoxy-3,3-dimethyl-butane" );
standardThermochemistry
{
    dHf_298   -486920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-193120.0
}
