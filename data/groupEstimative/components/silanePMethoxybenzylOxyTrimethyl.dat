/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, [(p-methoxybenzyl)oxy]trimethyl-  (C11H18O2Si, CAS 14629-56-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H18O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silanePMethoxybenzylOxyTrimethyl;
formula     C11H18O2Si;
CAS         14629-56-2;
InChIKey    IFOZSFFJSXAKEY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          210.348;      // g/mol [origin=calculated method=formula-sum]
Tc          735.65;      // K   [origin=predictive method=joback]
Pc          22.419;      // bar [origin=predictive method=joback]
omega       0.4843;      // -   [origin=predictive method=lee-kesler]
Tb          529.18;      // K   [origin=predictive method=joback]
HvapTb      48132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (65.101 0.57788 9.804e-05 -2.065e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methoxyphenyl)methoxy-trimethyl-silane" "silane, [(4-methoxyphenyl)methoxy]trimethyl-" "(4-methoxyphenyl)methoxy-trimethylsilane" );
gibbsFormation
{
    dHf_298   -421370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-170240.0
    phase     gas;
}
