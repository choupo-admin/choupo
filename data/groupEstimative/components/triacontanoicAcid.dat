/*--------------------------------*- Choupo -*-----------------------*\
  Component: triacontanoic acid  (C30H60O2, CAS 506-50-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triacontanoicAcid;
formula     C30H60O2;
CAS         506-50-3;
InChIKey    VHOCUJPBKOZGJD-UHFFFAOYSA-N;
MW          452.808;      // g/mol [origin=calculated method=formula-sum]
Tc          1293.86;      // K   [origin=predictive method=joback]
Pc          6.222;      // bar [origin=predictive method=joback]
omega       0.3414;      // -   [origin=predictive method=lee-kesler]
Tb          1031.51;      // K   [origin=predictive method=joback]
HvapTb      99538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.782 2.90462 -0.0016808 3.738e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 28; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 28; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "melissic acid" "n-triacontanoic acid" "1-triacontanoic acid" "myricic acid" "triacontansaeure" "mellisic acid" "triacontoic acid" "eye(r)ieea" "melissic acid,synthetic" "ch3-[ch2]28-cooh" "c30:0" );
standardThermochemistry
{
    dHf_298   -1012800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1377.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-142190.0
}
