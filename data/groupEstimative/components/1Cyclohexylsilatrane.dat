/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexylsilatrane  (C12H23NO3Si, CAS 31865-49-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H23NO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Cyclohexylsilatrane;
formula     C12H23NO3Si;
CAS         31865-49-3;
InChIKey    MVTYGOLWLNDFRD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          257.405;      // g/mol [origin=calculated method=formula-sum]
Tc          868.87;      // K   [origin=predictive method=joback]
Pc          27.326;      // bar [origin=predictive method=joback]
omega       0.5711;      // -   [origin=predictive method=lee-kesler]
Tb          624.03;      // K   [origin=predictive method=joback]
HvapTb      59562.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.26 1.5006 -0.0007781 1.006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group CH2O; count 3; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 11; } { group CH_ring; count 1; } { group O_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-cyclohexyl-4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecane" "1-cyclohexyl-2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane" "1-cyclohexyl-2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane, 1-cyclohexyl-" "2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane,1-cyclohexyl-" );
standardThermochemistry
{
    dHf_298   -508980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77110.0
}
