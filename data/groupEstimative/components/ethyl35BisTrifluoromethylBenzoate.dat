/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3,5-bis(trifluoromethyl)benzoate  (C11H8F6O2, CAS 96617-71-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl35BisTrifluoromethylBenzoate;
formula     C11H8F6O2;
CAS         96617-71-9;
InChIKey    NBWZJMOEFTYMOF-UHFFFAOYSA-N;
MW          286.171;      // g/mol [origin=calculated method=formula-sum]
Tc          711.51;      // K   [origin=predictive method=joback]
Pc          20.661;      // bar [origin=predictive method=joback]
omega       0.7328;      // -   [origin=predictive method=lee-kesler]
Tb          535.30;      // K   [origin=predictive method=joback]
HvapTb      43593.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.591 1.11852 -0.00081912 2.157e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CF3; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 6; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-bis(trifluoromethyl)benzoic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -1568220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     629.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1338660.0
    phase     gas;
}
