/*--------------------------------*- Choupo -*-----------------------*\
  Component: surecn5678601  (C11H16O, CAS 58275-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        surecn5678601;
formula     C11H16O;
CAS         58275-58-4;
InChIKey    MUARYPDSOOLBNJ-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          728.55;      // K   [origin=predictive method=joback]
Pc          28.084;      // bar [origin=predictive method=joback]
omega       0.5047;      // -   [origin=predictive method=lee-kesler]
Tb          516.03;      // K   [origin=predictive method=joback]
HvapTb      45947.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.6 1.42052 -0.0011057 3.5216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 5; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 5; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -205230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     255.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79650.0
}
