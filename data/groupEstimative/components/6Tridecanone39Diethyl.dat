/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-tridecanone, 3,9-diethyl-  (C17H34O, CAS 99148-55-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Tridecanone39Diethyl;
formula     C17H34O;
CAS         99148-55-7;
InChIKey    LJIUTOLEBSNPSS-UHFFFAOYSA-N;
MW          254.458;      // g/mol [origin=calculated method=formula-sum]
Tc          812.96;      // K   [origin=predictive method=joback]
Pc          13.023;      // bar [origin=predictive method=joback]
omega       0.8270;      // -   [origin=predictive method=lee-kesler]
Tb          641.55;      // K   [origin=predictive method=joback]
HvapTb      59406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.57 1.60268 -0.0008887 1.8106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 9; } { group CH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,9-diethyltridecan-6-one" );
standardThermochemistry
{
    dHf_298   -517350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     825.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41540.0
}
