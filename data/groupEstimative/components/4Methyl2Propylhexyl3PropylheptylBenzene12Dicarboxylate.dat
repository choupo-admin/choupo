/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-2-propylhexyl 3-propylheptyl benzene-1,2-dicarboxylate  (C28H46O4, CAS 68515-54-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl2Propylhexyl3PropylheptylBenzene12Dicarboxylate;
formula     C28H46O4;
CAS         68515-54-8;
InChIKey    SGQFNMXWBSKZLQ-UHFFFAOYSA-N;
MW          446.672;      // g/mol [origin=calculated method=formula-sum]
Tc          1209.08;      // K   [origin=predictive method=joback]
Pc          7.908;      // bar [origin=predictive method=joback]
omega       0.7488;      // -   [origin=predictive method=lee-kesler]
Tb          987.02;      // K   [origin=predictive method=joback]
HvapTb      94510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.602 2.4336 -0.00128396 2.069e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 12; } { group CH; count 3; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 12; } { group CH; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o2-(4-methyl-2-propyl-hexyl) o1-(3-propylheptyl) benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid, mono-c9-11-branched alkyl esters, c10-rich" "2-o-(4-methyl-2-propylhexyl) 1-o-(3-propylheptyl) benzene-1,2-dicarboxylate" );
standardThermochemistry
{
    dHf_298   -1046590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1208.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-340400.0
}
