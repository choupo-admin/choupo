/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutane, perfluoro-  (C4HF9, CAS 382-24-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutanePerfluoro;
formula     C4HF9;
CAS         382-24-1;
InChIKey    IMRLDNHHTCXOOR-UHFFFAOYSA-N;
MW          220.034;      // g/mol [origin=calculated method=formula-sum]
Tc          393.70;      // K   [origin=predictive method=joback]
Pc          26.516;      // bar [origin=predictive method=joback]
omega       0.3970;      // -   [origin=predictive method=lee-kesler]
Tb          274.42;      // K   [origin=predictive method=joback]
HvapTb      12869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.03 0.8733 -0.00086 3.02e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CF3; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 3; } { group F; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,3,3,3-hexakis(fluoranyl)-2-(trifluoromethyl)propane" "1,1,1,3,3,3-hexafluoro-2-(trifluoromethyl)propane" "2-(trifluoromethyl)-1,1,1,3,3,3-hexafluoropropane" "propane, 1,1,1,3,3,3-hexafluoro-2-trifluoromethyl-" "tris(trifluoromethyl)methane" );
standardThermochemistry
{
    dHf_298   -1922410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1764410.0
}
