/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(ethylthio)butric acid  (C6H12O2S, CAS 71057-15-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4EthylthioButricAcid;
formula     C6H12O2S;
CAS         71057-15-3;
InChIKey    DBNZPPFTPCELJG-UHFFFAOYSA-N;
MW          148.22;      // g/mol [origin=calculated method=formula-sum]
Tc          759.48;      // K   [origin=predictive method=joback]
Pc          35.096;      // bar [origin=predictive method=joback]
omega       0.7616;      // -   [origin=predictive method=lee-kesler]
Tb          551.17;      // K   [origin=predictive method=joback]
HvapTb      52931.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.634 0.61901 -0.000335 6.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethylsulfanylbutanoic acid" "4-(ethylthio)butanoic acid" "butyric acid, 4-ethylthio-" "4-(ethylsulfanyl)butanoic acid" );
standardThermochemistry
{
    dHf_298   -475570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-311150.0
}
