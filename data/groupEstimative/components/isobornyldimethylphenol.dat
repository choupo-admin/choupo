/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobornyldimethylphenol  (C18H26O, CAS 72968-53-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobornyldimethylphenol;
formula     C18H26O;
CAS         72968-53-7;
InChIKey    PFQAEXWCTNWZTN-RKVPGOIHSA-N;
MW          258.405;      // g/mol [origin=calculated method=formula-sum]
Tc          978.88;      // K   [origin=predictive method=joback]
Pc          20.908;      // bar [origin=predictive method=joback]
omega       0.7516;      // -   [origin=predictive method=lee-kesler]
Tb          737.59;      // K   [origin=predictive method=joback]
HvapTb      69354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-221.41 2.4936 -0.00245728 1.0201e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group ACH; count 2; } { group ACCH3; count 2; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-dimethyl-6-[(1r,2s,4s)-4,7,7-trimethyl-2-bicyclo[2.2.1]heptanyl]phenol" "phenol, dimethyl(1,7,7-trimethylbicyclo(2.2.1)hept-2-yl)-" "2,4-dimethyl-6-[(1r,2s,4s)-4,7,7-trimethylnorbornan-2-yl]phenol" );
gibbsFormation
{
    dHf_298   -249330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     658.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122210.0
    phase     gas;
}
