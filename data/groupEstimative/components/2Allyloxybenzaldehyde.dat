/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-allyloxybenzaldehyde  (C10H10O2, CAS 28752-82-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H10O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Allyloxybenzaldehyde;
formula     C10H10O2;
CAS         28752-82-1;
InChIKey    BXCJDECTRRMSCV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          162.188;      // g/mol [origin=calculated method=formula-sum]
Tc          663.78;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.3904;      // -   [origin=predictive method=lee-kesler]
Tb          455.58;      // K   [origin=predictive method=joback]
HvapTb      40159.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.799 0.7403 -0.00054926 1.677e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-prop-2-enoxybenzaldehyde" "2-(allyloxy)benzaldehyde" "benzaldehyde, 2-(2-propenyloxy)-" "benzaldehyde, o-(allyloxy)-" "o-allyloxybenzaldehyde" "o-(allyloxy)benzaldehyde" "2-(prop-2-en-1-yloxy)benzaldehyde" "2-prop-2-enyloxybenzaldehyde" "vhr bo2u1" "allyloxybenzenecarbaldehyde" "salicylaldehyde allyl ether" );
gibbsFormation
{
    dHf_298   44990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162900.0
    phase     gas;
}
