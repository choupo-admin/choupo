/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-hexadecanediol  (C16H34O2, CAS 6920-24-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Hexadecanediol;
formula     C16H34O2;
CAS         6920-24-7;
InChIKey    BTOOAFQCTJZDRC-UHFFFAOYSA-N;
MW          258.446;      // g/mol [origin=calculated method=formula-sum]
Tc          919.45;      // K   [origin=predictive method=joback]
Pc          15.235;      // bar [origin=predictive method=joback]
omega       1.3257;      // -   [origin=predictive method=lee-kesler]
Tb          749.60;      // K   [origin=predictive method=joback]
HvapTb      84180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.756 1.59772 -0.0009106 1.983e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group CH; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecane-1,2-diol" "cetyl glycol" "1,2-palmityl diol" "1,2-hexadecyl diol" "hexadecan-1,2-diol" "1,2-dihydroxyhexadecane" "1,2-hexadecanediol (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   -683310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     871.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-192240.0
    phase     gas;
}
