/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(p-chlorobenzyl) ether  (C14H12Cl2O, CAS 56428-00-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisPChlorobenzylEther;
formula     C14H12Cl2O;
CAS         56428-00-3;
InChIKey    REXQTRHCVRPOMB-UHFFFAOYSA-N;
MW          267.149;      // g/mol [origin=calculated method=formula-sum]
Tc          924.50;      // K   [origin=predictive method=joback]
Pc          24.483;      // bar [origin=predictive method=joback]
omega       0.6718;      // -   [origin=predictive method=lee-kesler]
Tb          680.52;      // K   [origin=predictive method=joback]
HvapTb      63814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.232 1.0074 -0.00059592 1.198e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2O; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-[(4-chlorophenyl)methoxymethyl]benzene" "1,1'-[oxybis(methylene)]bis(4-chlorobenzene)" "benzene, (chloromethyl)phenoxy-, mono(chloromethyl) deriv." "1,1'-(oxybis(methylene))bis(4-chlorobenzene)" "bis(alpha-chlorotolyl) ether" "ether, bis(alpha-chlorotolyl)" "bis(.alpha.-chlorotolyl) ether" "1-chloro-4-[(4-chlorophenyl)methoxymethyl]benzene" "benzene, 1,1'-(oxybis(methylene))bis(4-chloro-" "benzene, 1,1'-oxybis-, bis(chloromethyl) deriv." );
gibbsFormation
{
    dHf_298   -45870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143700.0
    phase     gas;
}
