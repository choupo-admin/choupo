/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 7058  (C6H6O3, CAS 88973-46-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris7058;
formula     C6H6O3;
CAS         88973-46-0;
InChIKey    MGCBXZGOSMSZBJ-ZPUQHVIOSA-N;
MW          126.111;      // g/mol [origin=calculated method=formula-sum]
Tc          750.93;      // K   [origin=predictive method=joback]
Pc          42.887;      // bar [origin=predictive method=joback]
omega       0.7893;      // -   [origin=predictive method=lee-kesler]
Tb          539.37;      // K   [origin=predictive method=joback]
HvapTb      52750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.93 0.6391 -0.0005358 1.809e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group CHO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 4; } { group OdCH_al; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2e,4e)-6-oxidanylidenehexa-2,4-dienoic acid" "6-oxo-2,4-hexadienoic acid (e,e)-" "6-oxo-trans,trans-2,4-hexadienoic acid" "2,4-hexadienoic acid, 6-oxo-, (e,e)-" "(2e,4e)-6-oxohexa-2,4-dienoic acid" );
gibbsFormation
{
    dHf_298   -368580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-283350.0
    phase     gas;
}
