/*--------------------------------*- Choupo -*-----------------------*\
  Component: trityl chloride  (C19H15Cl, CAS 76-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tritylChloride;
formula     C19H15Cl;
CAS         76-83-5;
InChIKey    JBWKIWSBJXDJDT-UHFFFAOYSA-N;
MW          278.779;      // g/mol [origin=calculated method=formula-sum]
Tc          1029.42;      // K   [origin=predictive method=joback]
Pc          23.406;      // bar [origin=predictive method=joback]
omega       0.5693;      // -   [origin=predictive method=lee-kesler]
Tb          748.56;      // K   [origin=predictive method=joback]
HvapTb      67805.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.68 1.7047 -0.0012956 3.723e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 15; } { group AC; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group C; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[chloranyl(diphenyl)methyl]benzene" "triphenylmethyl chloride" "triphenylchloromethane" "chlorotriphenylmethane" "methane, chlorotriphenyl-" "(chloromethanetriyl)tribenzene" "triphenyl chloromethane" "1,1',1''-(chloromethylidyne)trisbenzene" "[chloro(diphenyl)methyl]benzene" "benzene, 1,1',1''-(chloromethylidyne)tris-" "1,1',1''-(chloromethanetriyl)tribenzene" "(chlorodiphenylmethyl)benzene" );
gibbsFormation
{
    dHf_298   249610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=437240.0
    phase     gas;
}
