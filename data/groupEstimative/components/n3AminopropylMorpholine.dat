/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(3-aminopropyl)morpholine  (C7H16N2O, CAS 123-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3AminopropylMorpholine;
formula     C7H16N2O;
CAS         123-00-2;
InChIKey    UIKUBYKUYUSRSM-UHFFFAOYSA-N;
MW          144.218;      // g/mol [origin=calculated method=formula-sum]
Tc          697.63;      // K   [origin=predictive method=joback]
Pc          37.592;      // bar [origin=predictive method=joback]
omega       0.6076;      // -   [origin=predictive method=lee-kesler]
Tb          491.63;      // K   [origin=predictive method=joback]
HvapTb      48936.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.777 1.0098 -0.0006819 1.795e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group FCH2O; count 1; } { group CH2NH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-morpholin-4-ylpropan-1-amine" "3-morpholinopropylamine" "n-aminopropylmorpholine" "4-(3-aminopropyl)morpholine" "morpholine, 4-(3-aminopropyl)-" "4-aminopropylmorpholine" "4-morpholinepropylamine" "(3-aminopropyl)morpholine" "morpholine, 4-aminopropyl-" "morpholine, n-aminopropyl-" "1-amino-3-morpholinopropane" "3-morpholinopropanamine" );
gibbsFormation
{
    dHf_298   -137670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143430.0
    phase     gas;
}
