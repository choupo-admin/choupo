/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluorobenzanthracene  (C18H11F, CAS 388-72-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Fluorobenzanthracene;
formula     C18H11F;
CAS         388-72-7;
InChIKey    NHEMFXZWMPLBQU-UHFFFAOYSA-N;
MW          246.284;      // g/mol [origin=calculated method=formula-sum]
Tc          961.35;      // K   [origin=predictive method=joback]
Pc          25.767;      // bar [origin=predictive method=joback]
omega       0.7154;      // -   [origin=predictive method=lee-kesler]
Tb          709.27;      // K   [origin=predictive method=joback]
HvapTb      64027.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.72 1.4571 -0.00121204 4.027e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 6; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 11; } { group dC_ring; count 7; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-fluoranylbenzo[a]anthracene" "4-fluorobenz(a)anthracene" "benz(a)anthracene, 4-fluoro-" "4'-fluoro-1,2-benzanthracene" "4-fluorobenzo[a]anthracene" );
gibbsFormation
{
    dHf_298   164370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=309340.0
    phase     gas;
}
