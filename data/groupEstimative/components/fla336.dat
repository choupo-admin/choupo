/*--------------------------------*- Choupo -*-----------------------*\
  Component: fla 336  (C12H20N2, CAS 9004-64-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fla336;
formula     C12H20N2;
CAS         9004-64-2;
InChIKey    RRHXDYJWVYFMKV-UHFFFAOYSA-N;
MW          192.306;      // g/mol [origin=calculated method=formula-sum]
Tc          807.53;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.6904;      // -   [origin=predictive method=lee-kesler]
Tb          595.33;      // K   [origin=predictive method=joback]
HvapTb      58202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.209 1.13768 -0.00068532 1.552e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CHNH2; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(1-azanylpropyl)-n,n,3-trimethyl-aniline" "4-(dimethylamino)-alpha,2-dimethylphenethylamine" "benzeneethanamine, 4-(dimethylamino)-alpha,2-dimethyl-" "amiflamin" "55875-51-9 (di-hydrochloride)" "4-dimethylamino-alpha,2-dimethylphenethylamine" );
gibbsFormation
{
    dHf_298   18620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=318100.0
    phase     gas;
}
