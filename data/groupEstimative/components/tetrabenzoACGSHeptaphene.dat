/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrabenzo(a,c,g,s)heptaphene  (C46H26, CAS 62662-49-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrabenzoACGSHeptaphene;
formula     C46H26;
CAS         62662-49-1;
InChIKey    DRXGDYLSMFVWTB-UHFFFAOYSA-N;
MW          578.714;      // g/mol [origin=calculated method=formula-sum]
Tc          1853.43;      // K   [origin=predictive method=joback]
Pc          11.201;      // bar [origin=predictive method=joback]
omega       1.0674;      // -   [origin=predictive method=lee-kesler]
Tb          1513.38;      // K   [origin=predictive method=joback]
HvapTb      142624.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-258.57 3.7224 -0.00327364 1.1486e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 26; } { group AC; count 20; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 26; } { group dC_ring; count 20; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrabenzo[a,c,g,s]heptaphene" "tetrabenzo[a,c,q,s]heptaphene" );
standardThermochemistry
{
    dHf_298   1051230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     696.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1428680.0
}
