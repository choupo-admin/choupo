/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2044508  (C10H10O, CAS 1075-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2044508;
formula     C10H10O;
CAS         1075-30-5;
InChIKey    HRBWEKNHUNICAM-UHFFFAOYSA-N;
MW          146.189;      // g/mol [origin=calculated method=formula-sum]
Tc          741.38;      // K   [origin=predictive method=joback]
Pc          34.848;      // bar [origin=predictive method=joback]
omega       0.5100;      // -   [origin=predictive method=lee-kesler]
Tb          516.40;      // K   [origin=predictive method=joback]
HvapTb      47279.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.57 0.94792 -0.00073226 2.2856e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(7-bicyclo[4.2.0]octa-1,3,5-trienyl)ethanone" "bicyclo(4.2.0)octa-1,3,5-trien-7-yl methyl ketone" "ketone, bicyclo(4.2.0)octa-1,3,5-trien-7-yl methyl" );
gibbsFormation
{
    dHf_298   -58290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80030.0
    phase     gas;
}
