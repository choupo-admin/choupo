/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentaerythritol diheptanoate  (C19H36O6, CAS 67763-19-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentaerythritolDiheptanoate;
formula     C19H36O6;
CAS         67763-19-3;
InChIKey    OMAIADOUFDGXKC-UHFFFAOYSA-N;
MW          360.491;      // g/mol [origin=calculated method=formula-sum]
Tc          1146.18;      // K   [origin=predictive method=joback]
Pc          12.495;      // bar [origin=predictive method=joback]
omega       1.1131;      // -   [origin=predictive method=lee-kesler]
Tb          931.89;      // K   [origin=predictive method=joback]
HvapTb      104764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.544 1.89304 -0.0010532 1.922e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group C; count 1; } { group OH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group C; count 1; } { group OH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(heptanoyloxymethyl)-2-(hydroxymethyl)-3-oxidanyl-propyl] heptanoate" "2,2-bis(hydroxymethyl)propane-1,3-diyl diheptanoate" "2,2-bis(hydroxymethyl)propane-1,3-diyl bisheptanoate" "heptanoic acid, 1,1'-(2,2-bis(hydroxymethyl)-1,3-propanediyl) ester" "heptanoic acid, 1,1'-[2,2-bis(hydroxymethyl)-1,3-propanediyl] ester" "heptanoic acid, 2,2-bis(hydroxymethyl)-1,3-propanediyl ester" "[2-(heptanoyloxymethyl)-3-hydroxy-2-(hydroxymethyl)propyl] heptanoate" );
gibbsFormation
{
    dHf_298   -1383260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1061.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-782440.0
    phase     gas;
}
