/*--------------------------------*- Choupo -*-----------------------*\
  Component: methoxyethane  (C3H8O, CAS 540-67-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methoxyethane;
formula     C3H8O;
CAS         540-67-0;
InChIKey    XOBKSJJDNFUZPF-UHFFFAOYSA-N;
MW          60.096;      // g/mol [origin=calculated method=formula-sum]
Tc          453.04;      // K   [origin=predictive method=joback]
Pc          43.112;      // bar [origin=predictive method=joback]
omega       0.2380;      // -   [origin=predictive method=lee-kesler]
Tb          290.66;      // K   [origin=predictive method=joback]
HvapTb      24682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.661 0.22564 -2.84e-05 -3.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl methyl ether" "ethane, methoxy-" "methyl ethyl ether" "ether, ethyl methyl" "methane, ethoxy" "ethane, methoxy- (9ci)" "2me" "methoxyethan" "alcohols, c1-2, ethoxylated" "1-methoxyethane" "aethylmethylaether" "methylaethylaether" );
standardThermochemistry
{
    dHf_298   -237470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     284.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130620.0
}
