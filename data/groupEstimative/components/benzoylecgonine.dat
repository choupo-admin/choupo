/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoylecgonine  (C16H19NO4, CAS 519-09-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoylecgonine;
formula     C16H19NO4;
CAS         519-09-5;
InChIKey    GVGYEFKIHJTNQZ-UHFFFAOYSA-N;
MW          289.331;      // g/mol [origin=calculated method=formula-sum]
Tc          1046.51;      // K   [origin=predictive method=joback]
Pc          22.419;      // bar [origin=predictive method=joback]
omega       1.1153;      // -   [origin=predictive method=lee-kesler]
Tb          816.94;      // K   [origin=predictive method=joback]
HvapTb      79480.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.97 1.80402 -0.0012516 3.253e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 4; } { group ACH; count 5; } { group AC; count 1; } { group CH3N; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-methyl-3-(phenylcarbonyloxy)-8-azabicyclo[3.2.1]octane-4-carboxylic acid" "8-azabicyclo[3.2.1]octane-2-carboxylic acid, 3-(benzoyloxy)-8-methyl-, [1r-(exo,exo)]-" "3-benzoyloxy-8-methyl-8-azabicyclo[3.2.1]octane-4-carboxylic acid" "8-azabicyclo[3.2.1]octane-2-carboxylic acid, 3-(benzoyloxy)-8-methyl-" );
standardThermochemistry
{
    dHf_298   -638300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-253270.0
}
