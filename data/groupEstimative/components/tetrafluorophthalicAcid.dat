/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrafluorophthalic acid  (C8H2F4O4, CAS 652-03-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrafluorophthalicAcid;
formula     C8H2F4O4;
CAS         652-03-9;
InChIKey    YJLVXRPNNDKMMO-UHFFFAOYSA-N;
MW          238.092;      // g/mol [origin=calculated method=formula-sum]
Tc          927.08;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       1.3741;      // -   [origin=predictive method=lee-kesler]
Tb          722.32;      // K   [origin=predictive method=joback]
HvapTb      70048.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (66.77 0.5362 -0.0003182 6.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 2; } { group COOH; count 2; } { group ACF; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group F; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4,5,6-tetrakis(fluoranyl)phthalic acid" "3,4,5,6-tetrafluorophthalic acid" "3,4,5,6-tetrafluorophthalic" "3,4,5,6-tetrafluorobenzene-1,2-dicarboxylic acid" "2,3,4,5-tetrafluoro-phthalic acid" "3,4,5,6-tetrafluoro-phthalic acid" "1,2-benzenedicarboxylic acid, 3,4,5,6-tetrafluoro-" "tetrafluorobenzene-1,2-dicarboxylic acid" "1,2-benzenedicarboxylicacid, 3,4,5,6-tetrafluoro-" "3,4,5,6-tetrafluoro-1,2-benzenedicarboxylic acid" "phthalicacid, tetrafluoro- (6ci,7ci,8ci);3,4,5,6-tetrafluorophthalic acid;" );
standardThermochemistry
{
    dHf_298   -1514250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1386320.0
}
