/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl anthranilate  (C10H11NO2, CAS 7493-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylAnthranilate;
formula     C10H11NO2;
CAS         7493-63-2;
InChIKey    UCANFCXAKYMFGA-UHFFFAOYSA-N;
MW          177.203;      // g/mol [origin=calculated method=formula-sum]
Tc          812.11;      // K   [origin=predictive method=joback]
Pc          32.357;      // bar [origin=predictive method=joback]
omega       0.6992;      // -   [origin=predictive method=lee-kesler]
Tb          587.49;      // K   [origin=predictive method=joback]
HvapTb      58170.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.101 0.8025 -0.00045606 7.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl 2-azanylbenzoate" "anthranilic acid, allyl ester" "allyl 2-aminobenzoate" "benzoic acid, 2-amino-, 2-propenyl ester" "allyl o-aminobenzoate" "vinyl carbinyl anthranilate" "2-propenyl 2-aminobenzoate" "2-propen-1-yl anthranilate" "2-propen-1-yl 2-aminobenzoate" "prop-2-enyl 2-aminobenzoate" "prop-2-en-1-yl 2-aminobenzoate" "anthranilic acid, allyl ester (8ci)" );
gibbsFormation
{
    dHf_298   -182730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19980.0
    phase     gas;
}
