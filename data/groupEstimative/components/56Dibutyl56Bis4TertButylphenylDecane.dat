/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,6-dibutyl-5,6-bis(4-tert-butylphenyl)decane  (C38H62, CAS 85668-76-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        56Dibutyl56Bis4TertButylphenylDecane;
formula     C38H62;
CAS         85668-76-4;
InChIKey    DMHYTJAITPRFFD-UHFFFAOYSA-N;
MW          518.914;      // g/mol [origin=calculated method=formula-sum]
Tc          1372.56;      // K   [origin=predictive method=joback]
Pc          5.784;      // bar [origin=predictive method=joback]
omega       0.4571;      // -   [origin=predictive method=lee-kesler]
Tb          1119.44;      // K   [origin=predictive method=joback]
HvapTb      100874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-168.758 3.8404 -0.00265892 7.298e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group CH2; count 12; } { group C; count 4; } { group ACH; count 8; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group CH2; count 12; } { group C; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-4-[5,6-dibutyl-6-(4-tert-butylphenyl)decan-5-yl]benzene" "benzene, 1,1'-(1,1,2,2-tetrabutyl-1,2-ethanediyl)bis(4-(1,1-dimethylethyl)-" );
standardThermochemistry
{
    dHf_298   -412530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1255.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=486000.0
}
