/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(8.2.2.24,7)hexadeca-4,6,10,12,13,15-hexaene, 2,2,3,3,8,8,9,9,-octafluoro-  (C16H8F8, CAS 3345-29-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo822247Hexadeca4610121315Hexaene22338899Octafluoro;
formula     C16H8F8;
CAS         3345-29-7;
InChIKey    KCKIWSAAWFKXMA-UHFFFAOYSA-N;
MW          352.224;      // g/mol [origin=calculated method=formula-sum]
Tc          825.69;      // K   [origin=predictive method=joback]
Pc          19.824;      // bar [origin=predictive method=joback]
omega       0.7073;      // -   [origin=predictive method=lee-kesler]
Tb          621.12;      // K   [origin=predictive method=joback]
HvapTb      45104.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-239.65 2.5708 -0.00304412 1.402e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group CF2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,3,8,8,9,9- octafluorotricyclo[8.2.2.2;{4,7}]hexadeca- 1(12),4,6,10,13,15-hexaene" );
standardThermochemistry
{
    dHf_298   -1425750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     888.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1265520.0
}
