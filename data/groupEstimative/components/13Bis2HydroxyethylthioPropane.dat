/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(2-hydroxyethylthio)propane  (C7H16O2S2, CAS 16260-48-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Bis2HydroxyethylthioPropane;
formula     C7H16O2S2;
CAS         16260-48-3;
InChIKey    JIJWGPUMOGBVMQ-UHFFFAOYSA-N;
MW          196.323;      // g/mol [origin=calculated method=formula-sum]
Tc          868.33;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       1.5175;      // -   [origin=predictive method=lee-kesler]
Tb          681.68;      // K   [origin=predictive method=joback]
HvapTb      78168.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.307 0.72558 -0.0003374 3.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group OH; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group OH; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[3-(2-hydroxyethylsulfanyl)propylsulfanyl]ethanol" "3,7-dithia-1,9-nonanediol" "2-((3-[(2-hydroxyethyl)sulfanyl]propyl)sulfanyl)ethanol" "2-[3-(2-hydroxyethylthio)propylthio]ethan-1-ol" "2,2'-(trimethylenedithio)diethanol" "ethanol,2,2'-[1,3-propanediylbis(thio)]bis-" "2-((3-((2-hydroxyethyl)thio)propyl)thio)ethanol" "2,2'-(propane-1,3-diylbis(sulfanediyl))diethanol" );
gibbsFormation
{
    dHf_298   -408530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     653.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199340.0
    phase     gas;
}
