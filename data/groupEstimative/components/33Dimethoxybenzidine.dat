/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3'-dimethoxybenzidine  (C14H16N2O2, CAS 119-90-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethoxybenzidine;
formula     C14H16N2O2;
CAS         119-90-4;
InChIKey    JRBJSXQPQWSCCF-UHFFFAOYSA-N;
MW          244.294;      // g/mol [origin=calculated method=formula-sum]
Tc          1029.60;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       1.0150;      // -   [origin=predictive method=lee-kesler]
Tb          783.10;      // K   [origin=predictive method=joback]
HvapTb      80060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.53 0.93544 -0.00039684 1.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } { group CH3O; count 2; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-azanyl-3-methoxy-phenyl)-2-methoxy-aniline" "o-dianisidine" "dianisidine" "3,3'-dimethoxybiphenyl-4,4'-diamine" "cellitazol b" "ortho-dianisidine" "neutrosel navy bn" "diacel navy dc" "fast blue b" "disperse black 6" "blue base nb" "blue bn base" );
standardThermochemistry
{
    dHf_298   -101970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     589.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176200.0
}
