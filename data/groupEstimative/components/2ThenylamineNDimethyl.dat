/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-thenylamine,n-dimethyl-  (C7H11NS, CAS 26019-17-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ThenylamineNDimethyl;
formula     C7H11NS;
CAS         26019-17-0;
InChIKey    DJQUVKALZASWTJ-UHFFFAOYSA-N;
MW          141.232;      // g/mol [origin=calculated method=formula-sum]
Tc          657.54;      // K   [origin=predictive method=joback]
Pc          37.730;      // bar [origin=predictive method=joback]
omega       0.3847;      // -   [origin=predictive method=lee-kesler]
Tb          443.28;      // K   [origin=predictive method=joback]
HvapTb      40843.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.909 0.79385 -0.00057862 1.695e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH3N; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group N; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-1-thiophen-2-yl-methanamine" "2-(dimethylaminomethyl)thiophene" "2-thenylamine, n,n-dimethyl-" "n,n-dimethyl(2-thienylmethyl)amine" "n,n-dimethyl-1-(thiophen-2-yl)methanamine" "n,n-dimethyl(2-thienyl)methanamine" "2-thiophenemethanamine,n,n-dimethyl-" "n,n-dimethyl-1-thiophen-2-ylmethanamine" );
standardThermochemistry
{
    dHf_298   109890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=253250.0
}
