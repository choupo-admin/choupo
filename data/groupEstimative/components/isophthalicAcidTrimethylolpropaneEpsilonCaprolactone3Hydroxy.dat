/*--------------------------------*- Choupo -*-----------------------*\
  Component: isophthalic acid, trimethylolpropane, epsilon-caprolactone, 3-hydroxy-2,2-dimethylpropyl 3-hydroxy-2,2-dimethylpropanoate polymer  (C30H50O13, CAS 41238-51-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isophthalicAcidTrimethylolpropaneEpsilonCaprolactone3Hydroxy;
formula     C30H50O13;
CAS         41238-51-1;
InChIKey    FDBIWTXWMSXZBH-UHFFFAOYSA-N;
MW          618.717;      // g/mol [origin=calculated method=formula-sum]
Tc          3053.92;      // K   [origin=predictive method=joback]
Pc          10.220;      // bar [origin=predictive method=joback]
omega       -0.3351;      // -   [origin=predictive method=lee-kesler]
Tb          1800.48;      // K   [origin=predictive method=joback]
HvapTb      215409.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.097 2.7945 -0.00113416 -3.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 11; } { group C; count 3; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 5; } { group CH2COO; count 1; } { group COOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 7; } { group C; count 3; } { group CH2_ring; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 5; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid;(2,2-dimethyl-3-oxidanyl-propyl) 2,2-dimethyl-3-oxidanyl-propanoate;2-ethyl-2-(hydroxymethyl)propane-1,3-diol;oxepan-2-one" "benzene-1,3-dicarboxylic acid; 2-ethyl-2-(hydroxymethyl)propane-1,3-diol; (3-hydroxy-2,2-dimethylpropyl) 3-hydroxy-2,2-dimethylpropanoate; oxepan-2-one" );
gibbsFormation
{
    dHf_298   -2814010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1873.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1949660.0
    phase     gas;
}
