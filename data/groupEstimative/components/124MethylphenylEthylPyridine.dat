/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[2-(4-methylphenyl)ethyl]pyridine  (C14H17N, CAS 118177-93-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        124MethylphenylEthylPyridine;
formula     C14H17N;
CAS         118177-93-8;
InChIKey    PSMKMSUAIGECAI-UHFFFAOYSA-N;
MW          199.297;      // g/mol [origin=calculated method=formula-sum]
Tc          807.60;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       0.5693;      // -   [origin=predictive method=lee-kesler]
Tb          582.29;      // K   [origin=predictive method=joback]
HvapTb      52889.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.998 1.36552 -0.00097192 2.695e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 2; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-(4-methylphenyl)ethyl]-2h-pyridine" "pyridinium,1-[2-(4-methylphenyl)ethyl]-" );
standardThermochemistry
{
    dHf_298   156680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=384740.0
}
