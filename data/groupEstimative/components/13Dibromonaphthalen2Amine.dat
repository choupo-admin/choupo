/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dibromonaphthalen-2-amine  (C10H7Br2N, CAS 54288-95-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dibromonaphthalen2Amine;
formula     C10H7Br2N;
CAS         54288-95-8;
InChIKey    QXQLGCVWRCXDKS-UHFFFAOYSA-N;
MW          300.981;      // g/mol [origin=calculated method=formula-sum]
Tc          970.44;      // K   [origin=predictive method=joback]
Pc          47.431;      // bar [origin=predictive method=joback]
omega       0.8059;      // -   [origin=predictive method=lee-kesler]
Tb          693.85;      // K   [origin=predictive method=joback]
HvapTb      67267.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.78 0.831 -0.0006732 2.189e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 4; } { group ACNH2; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 5; } { group dC_ring; count 5; } { group Br; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(bromanyl)naphthalen-2-amine" "2-naphthalenamine, 1,3-dibromo-" "1,3-dibromo-2-naphthalenamine" );
gibbsFormation
{
    dHf_298   229910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=318580.0
    phase     gas;
}
