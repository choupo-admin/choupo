/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(diethylamino)ethyl oleate  (C24H47NO2, CAS 45296-12-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DiethylaminoEthylOleate;
formula     C24H47NO2;
CAS         45296-12-6;
InChIKey    VWTYZZXUXJVLIO-UHFFFAOYSA-N;
MW          381.645;      // g/mol [origin=calculated method=formula-sum]
Tc          1008.35;      // K   [origin=predictive method=joback]
Pc          8.319;      // bar [origin=predictive method=joback]
omega       0.7998;      // -   [origin=predictive method=lee-kesler]
Tb          823.54;      // K   [origin=predictive method=joback]
HvapTb      78426.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.392 2.37296 -0.0013836 3.021e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 16; } { group CH=CH; count 1; } { group CH2COO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 18; } { group dCH; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethyl octadec-9-enoate" "9-octadecenoic acid (9z)-, 2-(diethylamino)ethyl ester" );
standardThermochemistry
{
    dHf_298   -671220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1151.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31830.0
}
