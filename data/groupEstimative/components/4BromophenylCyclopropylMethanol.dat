/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-bromophenyl)(cyclopropyl)methanol  (C10H11BrO, CAS 70289-39-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BromophenylCyclopropylMethanol;
formula     C10H11BrO;
CAS         70289-39-3;
InChIKey    PLVQKMYLBFYJHT-UHFFFAOYSA-N;
MW          227.101;      // g/mol [origin=calculated method=formula-sum]
Tc          849.33;      // K   [origin=predictive method=joback]
Pc          40.934;      // bar [origin=predictive method=joback]
omega       0.9415;      // -   [origin=predictive method=lee-kesler]
Tb          624.70;      // K   [origin=predictive method=joback]
HvapTb      63431.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.25 1.0444 -0.00080956 2.511e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-bromophenyl)-cyclopropyl-methanol" "(4-bromophenyl)-cyclopropylmethanol" "benzenemethanol,4-bromo-a-cyclopropyl-" "p-bromo-alpha-cyclopropylbenzyl alcohol" "benzylalcohol, p-bromo-a-cyclopropyl-(7ci)" "benzenemethanol, 4-bromo-.alpha.-cyclopropyl-" );
standardThermochemistry
{
    dHf_298   -83050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71910.0
}
