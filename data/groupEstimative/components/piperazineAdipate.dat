/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperazine adipate  (C10H20N2O4, CAS 142-88-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperazineAdipate;
formula     C10H20N2O4;
CAS         142-88-1;
InChIKey    BVEGEKOBSPXUJS-UHFFFAOYSA-N;
MW          232.28;      // g/mol [origin=calculated method=formula-sum]
Tc          1074.94;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       1.3846;      // -   [origin=predictive method=lee-kesler]
Tb          842.14;      // K   [origin=predictive method=joback]
HvapTb      86730.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.114 0.971 -0.0002658 -8.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2NH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 4; } { group COOH; count 2; } { group NH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanedioic acid;piperazine" "vermicompren" "adiprazina" "adiprazine" "arduvermin" "dietelmin" "divermex" "helmirazin" "nometan" "oxurasin" "oxypaat" "pipadox" );
gibbsFormation
{
    dHf_298   -911610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     758.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-551680.0
    phase     gas;
}
