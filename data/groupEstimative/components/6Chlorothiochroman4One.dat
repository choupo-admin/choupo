/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-chlorothiochroman-4-one  (C9H7ClOS, CAS 13735-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Chlorothiochroman4One;
formula     C9H7ClOS;
CAS         13735-12-1;
InChIKey    OKHUUKHZUNKSQA-UHFFFAOYSA-N;
MW          198.664;      // g/mol [origin=calculated method=formula-sum]
Tc          883.66;      // K   [origin=predictive method=joback]
Pc          39.014;      // bar [origin=predictive method=joback]
omega       0.5183;      // -   [origin=predictive method=lee-kesler]
Tb          610.92;      // K   [origin=predictive method=joback]
HvapTb      54066.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.76 0.68161 -0.00038722 7.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH2CO; count 1; } { group ACCl; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group CdO_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-chloranyl-2,3-dihydrothiochromen-4-one" "6-chloro-2,3-dihydro-4h-thiochromen-4-one" "6-chloro-2h,3h-benzo[e]thiin-4-one" "6-chloro-thiochroman-4-one" "6-chloro-2,3-dihydrothiochromen-4-one" "6-chloro-2,3-dihydro-1-benzothiopyran-4-one" "4h-1-benzothiopyran-4-one,6-chloro-2,3-dihydro-" );
gibbsFormation
{
    dHf_298   -36700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79750.0
    phase     gas;
}
