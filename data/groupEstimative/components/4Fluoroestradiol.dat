/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluoroestradiol  (C18H23FO2, CAS 1881-37-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Fluoroestradiol;
formula     C18H23FO2;
CAS         1881-37-4;
InChIKey    QZFXMXJXAUMHQR-AWMRIXHMSA-N;
MW          290.378;      // g/mol [origin=calculated method=formula-sum]
Tc          1067.08;      // K   [origin=predictive method=joback]
Pc          24.267;      // bar [origin=predictive method=joback]
omega       1.2626;      // -   [origin=predictive method=lee-kesler]
Tb          839.81;      // K   [origin=predictive method=joback]
HvapTb      86452.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-215.4 2.38872 -0.00214528 8.069e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group ACH; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 1; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(17s)-4-fluoranyl-13-methyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthrene-3,17-diol" "4-fluoroestra-1,3,5-(10)-triene-3,17-beta-diol" "(17-beta)-4-fluoroestra-1,3,5(10)-triene-3,17-diol" "estra-1,3,5(10)-triene-3,17-beta-diol, 4-fluoro-" "(17s)-4-fluoro-13-methyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthrene-3,17-diol" );
gibbsFormation
{
    dHf_298   -546270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-155280.0
    phase     gas;
}
