/*--------------------------------*- Choupo -*-----------------------*\
  Component: (methylthio)acetic acid  (C3H6O2S, CAS 2444-37-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylthioAceticAcid;
formula     C3H6O2S;
CAS         2444-37-3;
InChIKey    HGTBAIVLETUVCG-UHFFFAOYSA-N;
MW          106.139;      // g/mol [origin=calculated method=formula-sum]
Tc          701.06;      // K   [origin=predictive method=joback]
Pc          51.020;      // bar [origin=predictive method=joback]
omega       0.6045;      // -   [origin=predictive method=lee-kesler]
Tb          482.53;      // K   [origin=predictive method=joback]
HvapTb      46253.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.361 0.33401 -0.0001718 2.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group COOH; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylsulfanylethanoic acid" "2-methylthioacetic acid" "2-(methylthio)acetic acid" "acetic acid,(methylthio)-" "acetic acid, (methylthio)-" "methylmercaptoacetic acid" "methylsulfenylacetic acid" "mtg" "2-methylsulfanylacetic acid" "(methylmercapto)acetic acid" "2-(methylsulfanyl)acetic acid" );
standardThermochemistry
{
    dHf_298   -413650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-336410.0
}
