/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2s,3s)-2,3-dimethylthiirane  (C4H8S, CAS 5955-98-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2s3s23Dimethylthiirane;
formula     C4H8S;
CAS         5955-98-6;
InChIKey    ZMJBHCIEMIVIFZ-IMJSIDKUSA-N;
MW          88.168;      // g/mol [origin=calculated method=formula-sum]
Tc          538.21;      // K   [origin=predictive method=joback]
Pc          43.800;      // bar [origin=predictive method=joback]
omega       0.2014;      // -   [origin=predictive method=lee-kesler]
Tb          341.02;      // K   [origin=predictive method=joback]
HvapTb      29914.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.23 0.52265 -0.0003773 1.163e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thiirane, 2,3-dimethyl-, trans-" "thiirane, 2,3-dimethyl-, (2r,3r)-rel-" "trans-2,3-dimethylthiirane" );
standardThermochemistry
{
    dHf_298   -28170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     229.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75700.0
}
