/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanol, 1-(tetrahydro-4-pyranyl)-  (C11H20O2, CAS 27070-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanol1Tetrahydro4Pyranyl;
formula     C11H20O2;
CAS         27070-20-8;
InChIKey    GSFRPJXSGHYFIY-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          833.65;      // K   [origin=predictive method=joback]
Pc          33.182;      // bar [origin=predictive method=joback]
omega       0.7881;      // -   [origin=predictive method=lee-kesler]
Tb          609.75;      // K   [origin=predictive method=joback]
HvapTb      60976.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-165.7 1.6159 -0.0012857 4.38e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(oxan-4-yl)cyclohexan-1-ol" );
gibbsFormation
{
    dHf_298   -430720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-137790.0
    phase     gas;
}
