/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexane, 2,2,3,3,4,4,5,5-octamethyl-  (C14H30, CAS 65149-84-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexane22334455Octamethyl;
formula     C14H30;
CAS         65149-84-0;
InChIKey    MSNGVRWOQUIZAH-UHFFFAOYSA-N;
MW          198.394;      // g/mol [origin=calculated method=formula-sum]
Tc          706.35;      // K   [origin=predictive method=joback]
Pc          16.181;      // bar [origin=predictive method=joback]
omega       0.3152;      // -   [origin=predictive method=lee-kesler]
Tb          507.00;      // K   [origin=predictive method=joback]
HvapTb      41574.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.73 1.8372 -0.001425 4.43e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group C; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group C; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,3,4,4,5,5-octamethylhexane" "agn-pc-02kvxm" );
gibbsFormation
{
    dHf_298   -367290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78360.0
    phase     gas;
}
