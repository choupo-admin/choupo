/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,6,7,8,9,10-hexahydrobenzocyclooctene  (C12H16, CAS 1076-69-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5678910Hexahydrobenzocyclooctene;
formula     C12H16;
CAS         1076-69-3;
InChIKey    ADKYNRATSQVVPJ-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          772.19;      // K   [origin=predictive method=joback]
Pc          30.323;      // bar [origin=predictive method=joback]
omega       0.3806;      // -   [origin=predictive method=lee-kesler]
Tb          530.04;      // K   [origin=predictive method=joback]
HvapTb      45982.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.17 1.154 -0.00072956 1.7e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,6,7,8,9,10-hexahydrobenzo[8]annulene" "benzocyclooctene,5,6,7,8,9,10-hexahydro-" "benzocyclooctene, 5,6,7,8,9,10-hexahydro-" "bicyclo[6.4.0]dodeca-8,10,12-triene" "5,6,7,8,9,10-hexahydrobenzocyclooctene;benzocyclooctane" );
gibbsFormation
{
    dHf_298   8710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185100.0
    phase     gas;
}
