/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-isopropyl-3-methylcyclohex-2-en-1-yl formate  (C11H18O2, CAS 68516-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H18O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        6Isopropyl3Methylcyclohex2En1YlFormate;
formula     C11H18O2;
CAS         68516-71-2;
InChIKey    DGUJSWWZSWEZCR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          647.32;      // K   [origin=predictive method=joback]
Pc          23.542;      // bar [origin=predictive method=joback]
omega       0.2974;      // -   [origin=predictive method=lee-kesler]
Tb          446.28;      // K   [origin=predictive method=joback]
HvapTb      38393.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.88 1.04296 -0.00067664 1.766e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } { group CH=C; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-methyl-6-propan-2-yl-cyclohex-2-en-1-yl) methanoate" "6-(isopropyl)-3-methylcyclohex-2-en-1-yl formate" "2-cyclohexen-1-ol, 3-methyl-6-(1-methylethyl)-, formate" "2-cyclohexen-1-ol, 3-methyl-6-(1-methylethyl)-, 1-formate" "(3-methyl-6-propan-2-ylcyclohex-2-en-1-yl) formate" );
gibbsFormation
{
    dHf_298   -118910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120330.0
    phase     gas;
}
