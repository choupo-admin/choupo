/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-epoxy-1,4-dihydronaphthalene  (C10H8O, CAS 573-57-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Epoxy14Dihydronaphthalene;
formula     C10H8O;
CAS         573-57-9;
InChIKey    JWCGDNHAPBZVHD-UHFFFAOYSA-N;
MW          144.173;      // g/mol [origin=calculated method=formula-sum]
Tc          729.00;      // K   [origin=predictive method=joback]
Pc          39.062;      // bar [origin=predictive method=joback]
omega       0.4339;      // -   [origin=predictive method=lee-kesler]
Tb          495.38;      // K   [origin=predictive method=joback]
HvapTb      45248.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.07 1.0678 -0.00094454 3.324e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dihydro-1,4-epoxynaphthalene" "1,4-epoxynaphthalene, 1,4-dihydro-" "1,4-dihydro-1,4-expoxynaphthalene" "1,4-epoxynaphthalene,1,4-dihydro-" "1,4-expoxynaphthalene, 1,4-dihydro-" "11-oxatricyclo[6.2.1.0<2,7>]undeca-2,4,6,9-tetraene" "1,4-dihydronaphthalene-1,4-endo-oxide;(1s)-1?,4?-epoxy-1,4-dihydronaphthalene" );
standardThermochemistry
{
    dHf_298   52870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     143.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213540.0
}
