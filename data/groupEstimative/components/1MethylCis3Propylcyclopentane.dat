/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-cis-3-propylcyclopentane  (C9H18, CAS 2443-04-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1MethylCis3Propylcyclopentane;
formula     C9H18;
CAS         2443-04-1;
InChIKey    HRSBIYASWAILIF-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          606.88;      // K   [origin=predictive method=joback]
Pc          26.708;      // bar [origin=predictive method=joback]
omega       0.3250;      // -   [origin=predictive method=lee-kesler]
Tb          416.13;      // K   [origin=predictive method=joback]
HvapTb      35576.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.838 0.96404 -0.0005378 1.072e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3-propyl-cyclopentane" "1-methyl-3-propylcyclopentane" "cyclopentane, 1-methyl-3-propyl-" );
standardThermochemistry
{
    dHf_298   -188950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53740.0
}
