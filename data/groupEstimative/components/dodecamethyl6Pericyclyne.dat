/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecamethyl-[6]pericyclyne  (C30H36, CAS 98127-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecamethyl6Pericyclyne;
formula     C30H36;
CAS         98127-90-3;
InChIKey    BRJNVSWZHFRAQA-UHFFFAOYSA-N;
MW          396.618;      // g/mol [origin=calculated method=formula-sum]
Tc          1255.11;      // K   [origin=predictive method=joback]
Pc          12.504;      // bar [origin=predictive method=joback]
omega       0.3928;      // -   [origin=predictive method=lee-kesler]
Tb          937.64;      // K   [origin=predictive method=joback]
HvapTb      87264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-254.89 3.69624 -0.00405496 1.87628e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group C; count 6; } { group C_C; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group tC; count 12; } { group C_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,6,6,9,9,12,12,15,15,18,18-dodecamethylcyclooctadeca-1,4,7,10,13,16-hexayne" "dodecamethyl-(6)pericyclyne" );
gibbsFormation
{
    dHf_298   1015330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1329.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1371480.0
    phase     gas;
}
