/*--------------------------------*- Choupo -*-----------------------*\
  Component: lenamycin  (C4H4N2O2, CAS 543-21-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lenamycin;
formula     C4H4N2O2;
CAS         543-21-5;
InChIKey    JBTGHKUTYAMZEZ-UHFFFAOYSA-N;
MW          112.088;      // g/mol [origin=calculated method=formula-sum]
Tc          799.52;      // K   [origin=predictive method=joback]
Pc          69.214;      // bar [origin=predictive method=joback]
omega       0.7572;      // -   [origin=predictive method=lee-kesler]
Tb          552.92;      // K   [origin=predictive method=joback]
HvapTb      61424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.51 0.3018 -0.00015106 1.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C_C; count 1; } { group CONH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group CdO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-2-ynediamide" "2-butynediamide" "aquamycin" "cellocidin" "acetylene dicarboxamide" "acetylenedicarboxylic acid diamide" "renamycin" "acetylendicarbonsaeureamid" "acetylendicarbonsaeureamid [german]" "acetylene diamide" "73663-83-9 (hemihydrate)" );
standardThermochemistry
{
    dHf_298   -11170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60660.0
}
