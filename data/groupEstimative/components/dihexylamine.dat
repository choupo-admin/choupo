/*--------------------------------*- Choupo -*-----------------------*\
  Component: dihexylamine  (C12H27N, CAS 143-16-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dihexylamine;
formula     C12H27N;
CAS         143-16-8;
InChIKey    PXSXRABJBXYMFT-UHFFFAOYSA-N;
MW          185.355;      // g/mol [origin=calculated method=formula-sum]
Tc          688.82;      // K   [origin=predictive method=joback]
Pc          18.000;      // bar [origin=predictive method=joback]
omega       0.7392;      // -   [origin=predictive method=lee-kesler]
Tb          524.33;      // K   [origin=predictive method=joback]
HvapTb      48742.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.23 1.22004 -0.0006776 1.421e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-hexylhexan-1-amine" "di-n-hexylamine" "1-hexanamine, n-hexyl-" "n-hexylhexanamine" "n,n-dihexylamine" "di-n-hexylamine, pract" );
standardThermochemistry
{
    dHf_298   -237540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     664.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=139550.0
}
