/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,5-tetrafluorobenzene  (C6H2F4, CAS 2367-82-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1235Tetrafluorobenzene;
formula     C6H2F4;
CAS         2367-82-0;
InChIKey    UHHYOKRQTQBKSB-UHFFFAOYSA-N;
MW          150.074;      // g/mol [origin=calculated method=formula-sum]
Tc          549.14;      // K   [origin=predictive method=joback]
Pc          35.096;      // bar [origin=predictive method=joback]
omega       0.4223;      // -   [origin=predictive method=lee-kesler]
Tb          375.58;      // K   [origin=predictive method=joback]
HvapTb      29944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.79 0.3636 -0.00019828 3.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACF; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,5-tetrakis(fluoranyl)benzene" "benzene, 1,2,3,5-tetrafluoro-" "benzene,1,2,3,5-tetrafluoro-" "t145" "1,2,4,6-tetrafluorobenzene;1,3,4,5-tetrafluorobenzene;m-tetrafluorobenzene;" );
gibbsFormation
{
    dHf_298   -749490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-696080.0
    phase     gas;
}
