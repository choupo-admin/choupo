/*--------------------------------*- Choupo -*-----------------------*\
  Component: methamphetamine  (C10H15N, CAS 537-46-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methamphetamine;
formula     C10H15N;
CAS         537-46-2;
InChIKey    MYWUZJCMWCOHBA-VIFPVBQESA-N;
MW          149.237;      // g/mol [origin=calculated method=formula-sum]
Tc          715.92;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       0.5099;      // -   [origin=predictive method=lee-kesler]
Tb          504.81;      // K   [origin=predictive method=joback]
HvapTb      46178.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.999 0.95704 -0.0006032 1.433e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-n-methyl-1-phenyl-propan-2-amine" "metamfetamine" "d-deoxyephedrine" "d-desoxyephedrine" "d-n-methylamphetamine" "metamphetamine" "d-phenylisopropylmethylamine" "methylamphetamine" "d-methamphetamine" "l-methamphetamine" "d-methylamphetamine" "metamfetaminum" );
standardThermochemistry
{
    dHf_298   34990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=232680.0
}
