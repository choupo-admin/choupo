/*--------------------------------*- Choupo -*-----------------------*\
  Component: (chloropropylphenyl)pyridine  (C14H14ClN, CAS 73559-40-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloropropylphenylPyridine;
formula     C14H14ClN;
CAS         73559-40-7;
InChIKey    JJTJVLGXANAXBB-NSHDSACASA-N;
MW          231.723;      // g/mol [origin=calculated method=formula-sum]
Tc          924.71;      // K   [origin=predictive method=joback]
Pc          26.488;      // bar [origin=predictive method=joback]
omega       0.5996;      // -   [origin=predictive method=lee-kesler]
Tb          668.95;      // K   [origin=predictive method=joback]
HvapTb      62179.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.079 1.16298 -0.00076602 1.918e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group C5H4N; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group Cl; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-[(2s)-2-chloranylpropyl]phenyl]pyridine" "pyridine, (chloropropylphenyl)-" "4-[2-[(2s)-2-chloropropyl]phenyl]pyridine" );
standardThermochemistry
{
    dHf_298   141070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=344870.0
}
