/*--------------------------------*- Choupo -*-----------------------*\
  Component: β-Terpineol  (C10H18O, CAS 138-87-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        terpineol;
formula     C10H18O;
CAS         138-87-4;
InChIKey    RUJPNZNXGCHGID-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          732.81;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       0.6900;      // -   [origin=predictive method=lee-kesler]
Tb          532.26;      // K   [origin=predictive method=joback]
HvapTb      52912.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.25 1.35524 -0.001134 4.162e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-prop-1-en-2-ylcyclohexan-1-ol" "1-Methyl-4-(1-methylethenyl)cyclohexanol" "1-methyl-4-(prop-1-en-2-yl)cyclohexan-1-ol" "4-(1-Methylethenyl)-1-methyl-cyclohexanol" "Cyclohexanol, 1-methyl-4-(1-methylethenyl)-" "p-menth-8-en-1-ol" "beta-terpineol" "cis-beta-terpineol" "trans-beta-terpineol" "trans-" "a-terpineol" "cis-.beta.-terpineol" "trans-.beta.-terpineol" );
standardThermochemistry
{
    dHf_298   -237100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12960.0
}
