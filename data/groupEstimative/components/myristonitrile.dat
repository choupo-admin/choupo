/*--------------------------------*- Choupo -*-----------------------*\
  Component: myristonitrile  (C14H27N, CAS 629-63-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        myristonitrile;
formula     C14H27N;
CAS         629-63-0;
InChIKey    MLRCLPRHEOPXLL-UHFFFAOYSA-N;
MW          209.377;      // g/mol [origin=calculated method=formula-sum]
Tc          797.49;      // K   [origin=predictive method=joback]
Pc          14.942;      // bar [origin=predictive method=joback]
omega       0.8195;      // -   [origin=predictive method=lee-kesler]
Tb          622.00;      // K   [origin=predictive method=joback]
HvapTb      57236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.162 1.26862 -0.0007068 1.491e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecanenitrile" "tetradecanonitrile" "1-cyanotridecane" "c14-18 nitriles" "myristyl nitrile" "myrystyl nitrile" "tridecyl cyanide" "n-tridecyl cyanide" "(c14-c18)alkylnitrile" );
standardThermochemistry
{
    dHf_298   -167410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     707.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=200180.0
}
