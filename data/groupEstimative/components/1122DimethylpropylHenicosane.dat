/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11-(2,2-dimethylpropyl)henicosane  (C26H54, CAS 55282-10-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1122DimethylpropylHenicosane;
formula     C26H54;
CAS         55282-10-5;
InChIKey    JOPYPDXSWNGCTB-UHFFFAOYSA-N;
MW          366.718;      // g/mol [origin=calculated method=formula-sum]
Tc          969.23;      // K   [origin=predictive method=joback]
Pc          7.356;      // bar [origin=predictive method=joback]
omega       0.6781;      // -   [origin=predictive method=lee-kesler]
Tb          790.81;      // K   [origin=predictive method=joback]
HvapTb      71786.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.901 2.6056 -0.0015656 3.696e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 19; } { group CH; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 19; } { group CH; count 1; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-(2',2'-dimethylpropyl)heneicosane" "heneicosane, 11-(2,2-dimethylpropyl)-" "heneicosane,2-dimethylpropyl)-" );
gibbsFormation
{
    dHf_298   -594000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1120.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=168440.0
    phase     gas;
}
