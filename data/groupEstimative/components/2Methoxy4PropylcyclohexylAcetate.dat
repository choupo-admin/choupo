/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-4-propylcyclohexyl acetate  (C12H22O3, CAS 67845-58-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy4PropylcyclohexylAcetate;
formula     C12H22O3;
CAS         67845-58-3;
InChIKey    DCHIIKAIQRAGHB-UHFFFAOYSA-N;
MW          214.305;      // g/mol [origin=calculated method=formula-sum]
Tc          760.02;      // K   [origin=predictive method=joback]
Pc          19.877;      // bar [origin=predictive method=joback]
omega       0.6249;      // -   [origin=predictive method=lee-kesler]
Tb          565.01;      // K   [origin=predictive method=joback]
HvapTb      51934.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.838 1.09496 -0.0003936 -2.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 3; } { group CH3COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methoxy-4-propyl-cyclohexyl) ethanoate" "cyclohexanol, 2-methoxy-4-propyl-, acetate" "cyclohexanol, 2-methoxy-4-propyl-, 1-acetate" "octahydroeugenyl acetate" "(2-methoxy-4-propylcyclohexyl) acetate" );
gibbsFormation
{
    dHf_298   -726870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-356180.0
    phase     gas;
}
