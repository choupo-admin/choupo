/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptadec-8-ene  (C17H34, CAS 16369-12-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptadec8Ene;
formula     C17H34;
CAS         16369-12-3;
InChIKey    BIQKRILZMDQPHI-UHFFFAOYSA-N;
MW          238.459;      // g/mol [origin=calculated method=formula-sum]
Tc          756.61;      // K   [origin=predictive method=joback]
Pc          12.773;      // bar [origin=predictive method=joback]
omega       0.7464;      // -   [origin=predictive method=lee-kesler]
Tb          592.72;      // K   [origin=predictive method=joback]
HvapTb      53394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.747 1.63884 -0.0009848 2.385e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-heptadecene, (e)-" "8-heptadecene, (8z)-" );
standardThermochemistry
{
    dHf_298   -276990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     811.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172480.0
}
