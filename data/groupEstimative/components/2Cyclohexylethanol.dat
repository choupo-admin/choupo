/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexylethanol  (C8H16O, CAS 4442-79-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexylethanol;
formula     C8H16O;
CAS         4442-79-9;
InChIKey    QJQZRLXDLORINA-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          685.01;      // K   [origin=predictive method=joback]
Pc          35.054;      // bar [origin=predictive method=joback]
omega       0.7231;      // -   [origin=predictive method=lee-kesler]
Tb          494.37;      // K   [origin=predictive method=joback]
HvapTb      50510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.698 0.9199 -0.0005228 1.034e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexaneethanol" "cyclohexylethyl alcohol" "ethanol, 2-cyclohexyl-" "cyclohexylethanol" "hexahydrophenylethyl alcohol" ".beta.-cyclohexylethyl alcohol" "(2-hydroxyethyl)cyclohexane" "cyclohexane-ethanol" "2-cyclohexyl-ethanol" "2-cyclohexylethan-1-ol" "qjqzrlxdlorina-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -306360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-95890.0
    phase     gas;
}
