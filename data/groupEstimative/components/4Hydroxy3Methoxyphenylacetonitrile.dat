/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxy-3-methoxyphenylacetonitrile  (C9H9NO2, CAS 4468-59-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxy3Methoxyphenylacetonitrile;
formula     C9H9NO2;
CAS         4468-59-1;
InChIKey    SDVYWMWQCJEYTC-UHFFFAOYSA-N;
MW          163.176;      // g/mol [origin=calculated method=formula-sum]
Tc          877.73;      // K   [origin=predictive method=joback]
Pc          36.334;      // bar [origin=predictive method=joback]
omega       0.8390;      // -   [origin=predictive method=lee-kesler]
Tb          642.30;      // K   [origin=predictive method=joback]
HvapTb      64468.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.681 0.74662 -0.00054432 1.685e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-methoxy-4-oxidanyl-phenyl)ethanenitrile" "2-(4-hydroxy-3-methoxyphenyl)acetonitrile" "(4-hydroxy-3-methoxyphenyl)acetonitrile" "homovanillonitrile" "sdvywmwqcjeytc-uhfffaoysa-" "benzeneacetonitrile,4-hydroxy-3-methoxy-" "benzeneacetonitrile, 4-hydroxy-3-methoxy-" "2-(4-hydroxy-3-methoxyphenyl)ethanenitrile" "acetonitrile,(4-hydroxy-3-methoxyphenyl)- (6ci,8ci);(4-hydroxy-3-methoxyphenyl)acetonitrile;2-methoxy-4-(cyanomethyl)phenol;homovanillonitrile;" );
gibbsFormation
{
    dHf_298   -148680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1240.0
    phase     gas;
}
