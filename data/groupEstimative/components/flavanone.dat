/*--------------------------------*- Choupo -*-----------------------*\
  Component: flavanone  (C15H12O2, CAS 487-26-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        flavanone;
formula     C15H12O2;
CAS         487-26-3;
InChIKey    ZONYXWQDUYMKFB-UHFFFAOYSA-N;
MW          224.259;      // g/mol [origin=calculated method=formula-sum]
Tc          977.03;      // K   [origin=predictive method=joback]
Pc          29.861;      // bar [origin=predictive method=joback]
omega       0.6604;      // -   [origin=predictive method=lee-kesler]
Tb          706.92;      // K   [origin=predictive method=joback]
HvapTb      63040.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.87 1.1815 -0.00070346 1.411e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group CH2CO; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenyl-2,3-dihydrochromen-4-one" "2,3-dihydroflavone" "2-phenyl-4-chromanone" "2-phenylchroman-4-one" "4-flavanone" "4h-1-benzopyran-4-one, 2,3-dihydro-2-phenyl-" "2,3-dihydro-2-phenyl-4h-1-benzopyran-4-one" "2-phenyl-chroman-4-one" "2-phenyl-2,3-dihydro-4h-chromen-4-one" "2,3-dihydro-2-phenyl-4h-benzopyran-4-one" "2-phenyl-3,4-dihydro-2h-1-benzopyran-4-one" "2-phenylchromanone" );
standardThermochemistry
{
    dHf_298   -94400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     320.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130550.0
}
