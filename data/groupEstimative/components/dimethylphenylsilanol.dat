/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylphenylsilanol  (C8H12OSi, CAS 5272-18-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H12OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dimethylphenylsilanol;
formula     C8H12OSi;
CAS         5272-18-4;
InChIKey    FDTBETCIPGWBHK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          152.268;      // g/mol [origin=calculated method=formula-sum]
Tc          707.07;      // K   [origin=predictive method=joback]
Pc          35.305;      // bar [origin=predictive method=joback]
omega       0.6338;      // -   [origin=predictive method=lee-kesler]
Tb          502.90;      // K   [origin=predictive method=joback]
HvapTb      52651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.82 0.51274 -5.82e-05 -9.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl-oxidanyl-phenyl-silane" "phenyldimethylsilanol" "silanol, dimethylphenyl-" "silanol, 1,1-dimethyl-1-phenyl-" "phenyldimethylsilanol;" "hydroxy-dimethyl-phenylsilane" "silanol,1,1-dimethyl-1-phenyl-" );
standardThermochemistry
{
    dHf_298   -235770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-112690.0
}
