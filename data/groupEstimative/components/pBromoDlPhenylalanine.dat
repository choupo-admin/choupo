/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-bromo-dl-phenylalanine  (C9H10BrNO2, CAS 14091-15-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pBromoDlPhenylalanine;
formula     C9H10BrNO2;
CAS         14091-15-7;
InChIKey    PEMUHKUIQHFMTH-UHFFFAOYSA-N;
MW          244.088;      // g/mol [origin=calculated method=formula-sum]
Tc          968.50;      // K   [origin=predictive method=joback]
Pc          42.002;      // bar [origin=predictive method=joback]
omega       1.0562;      // -   [origin=predictive method=lee-kesler]
Tb          720.94;      // K   [origin=predictive method=joback]
HvapTb      72418.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.299 0.8772 -0.00062056 1.691e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-3-(4-bromophenyl)propanoic acid" "4-bromophenylalanine" "2-amino-3-(4-bromophenyl)propanoic acid" "4-bromo-dl-phenylalanine" "4-bromo-phenylalanine" "phenylalanine, 4-bromo-" "p-br-phenylalanine" "p-br-phe" "para-bromophenylalanine" "dl-4-bromophenylalanine" "dl-4-br-phe-oh" "2-amino-3-(4-bromo-phenyl)-propionic acid" );
gibbsFormation
{
    dHf_298   -299460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-137900.0
    phase     gas;
}
