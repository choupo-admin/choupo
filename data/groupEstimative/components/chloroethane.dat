/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloroethane  (C2H5Cl, CAS 75-00-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloroethane;
formula     C2H5Cl;
CAS         75-00-3;
InChIKey    HRYZWHHZPQKTII-UHFFFAOYSA-N;
MW          64.512;      // g/mol [origin=calculated method=formula-sum]
Tc          453.13;      // K   [origin=predictive method=joback]
Pc          47.760;      // bar [origin=predictive method=joback]
omega       0.1793;      // -   [origin=predictive method=lee-kesler]
Tb          282.79;      // K   [origin=predictive method=joback]
HvapTb      24431.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.961 0.20062 -0.0001054 2.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranylethane" "ethyl chloride" "ethane, chloro-" "chlorene" "anodynon" "chlorethyl" "cloretilo" "dublofix" "chelen" "chloryl" "monochloroethane" "ether chloratus" );
gibbsFormation
{
    dHf_298   -100350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     267.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-45970.0
    phase     gas;
}
