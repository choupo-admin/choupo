/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-oxabicyclo[3.2.1]octan-2-one, 5,8,8-trimethyl-  (C10H16O2, CAS 90820-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Oxabicyclo321Octan2One588Trimethyl;
formula     C10H16O2;
CAS         90820-47-6;
InChIKey    DBRCQDHKXZLHJE-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          708.26;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       0.4585;      // -   [origin=predictive method=lee-kesler]
Tb          495.91;      // K   [origin=predictive method=joback]
HvapTb      42476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-175.32 1.75816 -0.0018758 8.171e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,8,8-trimethyl-3-oxabicyclo[3.2.1]octan-2-one" );
standardThermochemistry
{
    dHf_298   -411270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-174240.0
}
