/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutane,1,1,2,2-tetramethyl-3,4-bis(1-methylethylidene)-  (C14H24, CAS 1133-23-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobutane1122Tetramethyl34Bis1Methylethylidene;
formula     C14H24;
CAS         1133-23-9;
InChIKey    PUOXTFSPIXYJTJ-UHFFFAOYSA-N;
MW          192.346;      // g/mol [origin=calculated method=formula-sum]
Tc          748.51;      // K   [origin=predictive method=joback]
Pc          19.203;      // bar [origin=predictive method=joback]
omega       0.4224;      // -   [origin=predictive method=lee-kesler]
Tb          539.78;      // K   [origin=predictive method=joback]
HvapTb      45966.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.43 1.87736 -0.001863 7.98e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group C; count 2; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group dC; count 2; } { group C_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetramethyl-3,4-di(propan-2-ylidene)cyclobutane" );
gibbsFormation
{
    dHf_298   -123030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     663.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=170780.0
    phase     gas;
}
