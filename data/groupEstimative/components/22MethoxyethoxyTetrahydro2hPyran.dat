/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-methoxyethoxy)-tetrahydro-2h-pyran  (C8H16O3, CAS 4819-82-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22MethoxyethoxyTetrahydro2hPyran;
formula     C8H16O3;
CAS         4819-82-3;
InChIKey    CENLRESKVLHEPM-UHFFFAOYSA-N;
MW          160.213;      // g/mol [origin=calculated method=formula-sum]
Tc          672.71;      // K   [origin=predictive method=joback]
Pc          30.057;      // bar [origin=predictive method=joback]
omega       0.5067;      // -   [origin=predictive method=lee-kesler]
Tb          473.98;      // K   [origin=predictive method=joback]
HvapTb      43161.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.668 0.75652 -0.0002565 -2.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methoxyethoxy)oxane" "agn-pc-0cza21" "2h-pyran, tetrahydro-2-(2-methoxyethoxy)-" );
standardThermochemistry
{
    dHf_298   -550570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255190.0
}
