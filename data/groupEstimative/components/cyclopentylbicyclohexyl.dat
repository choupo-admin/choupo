/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentylbicyclohexyl  (C17H30, CAS 26447-22-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentylbicyclohexyl;
formula     C17H30;
CAS         26447-22-3;
InChIKey    UQHBCYMBCJNVRK-UHFFFAOYSA-N;
MW          234.427;      // g/mol [origin=calculated method=formula-sum]
Tc          895.45;      // K   [origin=predictive method=joback]
Pc          20.382;      // bar [origin=predictive method=joback]
omega       0.4301;      // -   [origin=predictive method=lee-kesler]
Tb          643.18;      // K   [origin=predictive method=joback]
HvapTb      53400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-254.25 2.2866 -0.001723 5.478e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 14; } { group CH; count 2; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 14; } { group CH_ring; count 2; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexyl-1-cyclopentyl-cyclohexane" "agn-pc-03et64" "1-cyclohexyl-1-cyclopentylcyclohexane" );
standardThermochemistry
{
    dHf_298   -209850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     776.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172220.0
}
