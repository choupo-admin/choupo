/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-formyl-1-methyl-4-(4-methyl-4-pentenyl)-3-cyclohexene  (C14H22O, CAS 67746-28-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Formyl1Methyl44Methyl4Pentenyl3Cyclohexene;
formula     C14H22O;
CAS         67746-28-5;
InChIKey    BNUNNHANDKGXBY-UHFFFAOYSA-N;
MW          206.329;      // g/mol [origin=calculated method=formula-sum]
Tc          797.76;      // K   [origin=predictive method=joback]
Pc          21.236;      // bar [origin=predictive method=joback]
omega       0.6160;      // -   [origin=predictive method=lee-kesler]
Tb          589.07;      // K   [origin=predictive method=joback]
HvapTb      53120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.637 1.58674 -0.00128984 4.594e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-(4-methylpent-4-enyl)cyclohex-3-ene-1-carbaldehyde" "3-cyclohexene-1-carboxaldehyde, 1-methyl-4-(4-methyl-4-pentenyl)-" "3-cyclohexene-1-carboxaldehyde, 1-methyl-4-(4-methyl-4-penten-1-yl)-" "1-methyl-4-(4-methylpent-4-enyl)-1-cyclohex-3-enecarboxaldehyde" );
standardThermochemistry
{
    dHf_298   -186360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     706.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86060.0
}
