/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-dimethylundecane  (C13H28, CAS 17312-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dimethylundecane;
formula     C13H28;
CAS         17312-68-4;
InChIKey    BXVZPIGCIFJGEI-UHFFFAOYSA-N;
MW          184.367;      // g/mol [origin=calculated method=formula-sum]
Tc          662.94;      // K   [origin=predictive method=joback]
Pc          16.701;      // bar [origin=predictive method=joback]
omega       0.5397;      // -   [origin=predictive method=lee-kesler]
Tb          493.81;      // K   [origin=predictive method=joback]
HvapTb      43236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.402 1.36468 -0.0008552 2.154e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undecane, 4,4-dimethyl-" );
gibbsFormation
{
    dHf_298   -320400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61420.0
    phase     gas;
}
