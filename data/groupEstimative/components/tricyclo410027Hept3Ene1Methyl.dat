/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[4.1.0.02,7]hept-3-ene,1-methyl-  (C8H10, CAS 61772-33-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo410027Hept3Ene1Methyl;
formula     C8H10;
CAS         61772-33-6;
InChIKey    FMQJRWFOLVXBPH-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          593.20;      // K   [origin=predictive method=joback]
Pc          39.160;      // bar [origin=predictive method=joback]
omega       0.2858;      // -   [origin=predictive method=lee-kesler]
Tb          389.05;      // K   [origin=predictive method=joback]
HvapTb      31629.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-181.14 1.44512 -0.00162928 7.157e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 3; } { group C; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo(4.1.0.02,7)hept-3-ene, 1-methyl-" );
gibbsFormation
{
    dHf_298   74950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     146.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=239690.0
    phase     gas;
}
