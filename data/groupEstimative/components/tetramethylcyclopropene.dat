/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetramethylcyclopropene  (C7H12, CAS 26385-95-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetramethylcyclopropene;
formula     C7H12;
CAS         26385-95-5;
InChIKey    ONAPRVZODHCPOU-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          567.66;      // K   [origin=predictive method=joback]
Pc          34.239;      // bar [origin=predictive method=joback]
omega       0.2756;      // -   [origin=predictive method=lee-kesler]
Tb          375.86;      // K   [origin=predictive method=joback]
HvapTb      31554.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.33 0.93668 -0.000963 4.238e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C_ring; count 1; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,3-tetramethylcyclopropene" "cyclopropene,tetramethyl" "cyclopropene,1,2,3,3-tetramethyl-" "cyclopropene,1,2,3,3-tetramethyl- (6ci); cyclopropene, tetramethyl- (7ci,8ci,9ci);tetramethylcyclopropene" );
gibbsFormation
{
    dHf_298   -64930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74020.0
    phase     gas;
}
