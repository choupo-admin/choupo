/*--------------------------------*- Choupo -*-----------------------*\
  Component: estradiol, diacetate  (C22H28O4, CAS 3434-88-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        estradiolDiacetate;
formula     C22H28O4;
CAS         3434-88-6;
InChIKey    VQHQLBARMFAKSV-UHFFFAOYSA-N;
MW          356.462;      // g/mol [origin=calculated method=formula-sum]
Tc          1108.38;      // K   [origin=predictive method=joback]
Pc          14.793;      // bar [origin=predictive method=joback]
omega       0.9343;      // -   [origin=predictive method=lee-kesler]
Tb          875.70;      // K   [origin=predictive method=joback]
HvapTb      81294.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-170.68 2.45876 -0.00187052 5.918e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-acetyloxy-13-methyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-17-yl) ethanoate" "estra-1,3,5(10)-triene-3,17-diyl diacetate" "estradiol diacetate" "estra-1,3,5(10)-triene-3,17-diol (17.beta.)-, diacetate" "estradiol-3,17-diacetate" "beta-estradiol diacetate" ".beta.-estradiol diacetate" ".alpha.-estradiol diacetate" "17.beta.-estradiol diacetate" "17.alpha.-estradiol diacetate" "estradiol-3,17.beta.-diacetate" "(17beta)-estra-1,3,5(10)-triene-3,17-diyl diacetate" );
gibbsFormation
{
    dHf_298   -737740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     750.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-256090.0
    phase     gas;
}
