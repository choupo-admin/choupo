/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexahydro-1,3,5-tris(2-hydroxypropyl)-s-triazine  (C12H27N3O3, CAS 25254-50-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexahydro135Tris2HydroxypropylSTriazine;
formula     C12H27N3O3;
CAS         25254-50-6;
InChIKey    QUGSRMKLRLHUHU-UHFFFAOYSA-N;
MW          261.366;      // g/mol [origin=calculated method=formula-sum]
Tc          978.28;      // K   [origin=predictive method=joback]
Pc          27.326;      // bar [origin=predictive method=joback]
omega       1.8631;      // -   [origin=predictive method=lee-kesler]
Tb          798.11;      // K   [origin=predictive method=joback]
HvapTb      97530.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.447 1.81266 -0.0013432 3.992e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 3; } { group OH; count 3; } { group CH2N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 3; } { group CH2_ring; count 3; } { group OH; count 3; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[3,5-bis(2-oxidanylpropyl)-1,3,5-triazinan-1-yl]propan-2-ol" "1,3,5-tris(beta-hydroxypropyl)hexahydrotriazine" "1,1',1''-(1,3,5-triazinane-1,3,5-triyl)tripropan-2-ol" "1-[3,5-bis(2-hydroxypropyl)-1,3,5-triazinan-1-yl]propan-2-ol" "(2s)-1-[3,5-bis[(2s)-2-hydroxypropyl]-1,3,5-triazinan-1-yl]propan-2-ol" "1,3,5-triazine-1,3,5(2h,4h,6h)-triethanol, .alpha.1,.alpha.3,.alpha.5-trimethyl-" "1,3,5-triazine-1,3,5(2h,4h,6h)-triethanol, alpha,alpha',alpha''-trimethyl-" "1,3,5-triazine-1,3,5(2h,4h,6h)-triethanol, alpha1,alpha3,alpha5-trimethyl-" "alpha,alpha',alpha''-trimethyl-1,3,5-triazine-1,3,5(2h,4h,6h)-triethanol" );
standardThermochemistry
{
    dHf_298   -467810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     747.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=33180.0
}
