/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxyphthalic acid  (C8H6O5, CAS 610-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HydroxyphthalicAcid;
formula     C8H6O5;
CAS         610-35-5;
InChIKey    MWRVRCAFWBBXTL-UHFFFAOYSA-N;
MW          182.131;      // g/mol [origin=calculated method=formula-sum]
Tc          1030.59;      // K   [origin=predictive method=joback]
Pc          55.443;      // bar [origin=predictive method=joback]
omega       1.4648;      // -   [origin=predictive method=lee-kesler]
Tb          785.94;      // K   [origin=predictive method=joback]
HvapTb      83682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.71 0.8816 -0.00077712 2.737e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylphthalic acid" "4-hydroxybenzene-1,2-dicarboxylic acid" "1,2-benzenedicarboxylic acid, 4-hydroxy-" "4-hydroxy-1,2-benzenedicarboxylic acid" "3,4-dicarboxyphenol" "1,2-benzenedicarboxylicacid, 4-hydroxy-" "phthalicacid, 4-hydroxy- (6ci,7ci,8ci);4-hydroxy-1,2-benzenedicarboxylic acid;4-hydroxyphthalic acid;" );
gibbsFormation
{
    dHf_298   -861240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-723180.0
    phase     gas;
}
