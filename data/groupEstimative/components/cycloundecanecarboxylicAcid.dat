/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloundecanecarboxylic acid  (C12H22O2, CAS 831-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloundecanecarboxylicAcid;
formula     C12H22O2;
CAS         831-67-4;
InChIKey    BHECNPOVJVTHKS-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          902.41;      // K   [origin=predictive method=joback]
Pc          26.272;      // bar [origin=predictive method=joback]
omega       0.6716;      // -   [origin=predictive method=lee-kesler]
Tb          660.57;      // K   [origin=predictive method=joback]
HvapTb      60759.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.63 1.2687 -0.0005506 1.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CH_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloundecanecarboxylicacid" "cycloundecancarbons&#xe4;ure" );
gibbsFormation
{
    dHf_298   -617760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     745.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-329800.0
    phase     gas;
}
