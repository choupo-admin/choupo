/*--------------------------------*- Choupo -*-----------------------*\
  Component: isovalerylphenylacetylene  (C13H14O, CAS 23566-47-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isovalerylphenylacetylene;
formula     C13H14O;
CAS         23566-47-4;
InChIKey    YSNUZHGXXPVDOQ-UHFFFAOYSA-N;
MW          186.254;      // g/mol [origin=calculated method=formula-sum]
Tc          821.73;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       0.5358;      // -   [origin=predictive method=lee-kesler]
Tb          586.15;      // K   [origin=predictive method=joback]
HvapTb      55318.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.599 0.98804 -0.00060696 1.3844e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-1-phenyl-hex-1-yn-3-one" "5-methyl-1-phenylhex-1-yn-3-one" );
standardThermochemistry
{
    dHf_298   79320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=242430.0
}
