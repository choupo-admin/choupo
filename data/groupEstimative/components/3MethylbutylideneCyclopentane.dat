/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-methylbutylidene)cyclopentane  (C10H18, CAS 53366-51-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethylbutylideneCyclopentane;
formula     C10H18;
CAS         53366-51-1;
InChIKey    IUEAAJZOPXGHPO-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          655.88;      // K   [origin=predictive method=joback]
Pc          26.902;      // bar [origin=predictive method=joback]
omega       0.3760;      // -   [origin=predictive method=lee-kesler]
Tb          454.55;      // K   [origin=predictive method=joback]
HvapTb      38819.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.209 1.04044 -0.0006747 1.759e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 1; } { group CH2_ring; count 4; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutylidenecyclopentane" "cyclopentane, (3-methylbutylidene)-" );
standardThermochemistry
{
    dHf_298   -98160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120600.0
}
