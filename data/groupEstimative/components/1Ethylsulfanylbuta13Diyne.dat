/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethylsulfanylbuta-1,3-diyne  (C6H6S, CAS 1609-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethylsulfanylbuta13Diyne;
formula     C6H6S;
CAS         1609-42-3;
InChIKey    DAXGDBXXWICARU-UHFFFAOYSA-N;
MW          110.174;      // g/mol [origin=calculated method=formula-sum]
Tc          639.61;      // K   [origin=predictive method=joback]
Pc          46.340;      // bar [origin=predictive method=joback]
omega       0.2144;      // -   [origin=predictive method=lee-kesler]
Tb          404.78;      // K   [origin=predictive method=joback]
HvapTb      37777.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.371 0.32451 -0.00016619 2.997e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH_C; count 1; } { group C_C; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group tCH; count 1; } { group tC; count 3; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(ethylsulfanyl)buta-1,3-diyne" );
standardThermochemistry
{
    dHf_298   438900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=458630.0
}
