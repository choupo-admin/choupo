/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylethylisopropylamine  (C6H15N, CAS 39198-07-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylethylisopropylamine;
formula     C6H15N;
CAS         39198-07-7;
InChIKey    UTLDDSNRFHWERZ-UHFFFAOYSA-N;
MW          101.193;      // g/mol [origin=calculated method=formula-sum]
Tc          515.33;      // K   [origin=predictive method=joback]
Pc          31.280;      // bar [origin=predictive method=joback]
omega       0.3320;      // -   [origin=predictive method=lee-kesler]
Tb          348.88;      // K   [origin=predictive method=joback]
HvapTb      30605.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.939 0.70368 -0.0004184 9.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-n-methyl-propan-2-amine" "agn-pc-02sger" "2-propanamine, n-ethyl-n-methyl-" );
standardThermochemistry
{
    dHf_298   -104920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107980.0
}
