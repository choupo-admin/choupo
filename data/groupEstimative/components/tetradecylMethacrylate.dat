/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecyl methacrylate  (C18H34O2, CAS 2549-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecylMethacrylate;
formula     C18H34O2;
CAS         2549-53-3;
InChIKey    ATZHWSYYKQKSSY-UHFFFAOYSA-N;
MW          282.468;      // g/mol [origin=calculated method=formula-sum]
Tc          834.97;      // K   [origin=predictive method=joback]
Pc          11.940;      // bar [origin=predictive method=joback]
omega       0.8667;      // -   [origin=predictive method=lee-kesler]
Tb          666.22;      // K   [origin=predictive method=joback]
HvapTb      62479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.253 1.63894 -0.000886 1.651e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, tetradecyl ester" "myristyl methacrylate" "methacrylic acid, tetradecyl ester" "2-propenoic acid, 2-methyl-, tetradecyl ester, homopolymer" "tetradecyl 2-methyl-2-propenoate" "tetradecyl 2-methyl-2-propenoate, polymer" "2-propenoic acid,2-methyl-, tetradecyl ester" "methacrylicacid, tetradecyl ester (7ci,8ci);1-tetradecanol, methacrylate (8ci);myristylmethacrylate;tetradecyl methacrylate;" );
gibbsFormation
{
    dHf_298   -616490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     899.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130400.0
    phase     gas;
}
