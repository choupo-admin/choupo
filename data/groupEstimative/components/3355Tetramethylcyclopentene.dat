/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,5,5-tetramethylcyclopentene  (C9H16, CAS 38667-10-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3355Tetramethylcyclopentene;
formula     C9H16;
CAS         38667-10-6;
InChIKey    FCJMCOVEXBZEMH-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          626.45;      // K   [origin=predictive method=joback]
Pc          30.558;      // bar [origin=predictive method=joback]
omega       0.2445;      // -   [origin=predictive method=lee-kesler]
Tb          415.77;      // K   [origin=predictive method=joback]
HvapTb      33566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-152.04 1.49188 -0.00159028 7.074e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,5,5-tetramethyl-1-cyclopentene" "3,3,5,5-tetramethyl cyclopentene" "3,.3,5,5-tetramethylcyclopentene" );
standardThermochemistry
{
    dHf_298   -100690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72720.0
}
