/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dihydromorphol  (C14H12O2, CAS 20057-09-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dihydromorphol;
formula     C14H12O2;
CAS         20057-09-4;
InChIKey    FOTICWSJABVKPW-UHFFFAOYSA-N;
MW          212.248;      // g/mol [origin=calculated method=formula-sum]
Tc          979.02;      // K   [origin=predictive method=joback]
Pc          35.685;      // bar [origin=predictive method=joback]
omega       1.4636;      // -   [origin=predictive method=lee-kesler]
Tb          765.40;      // K   [origin=predictive method=joback]
HvapTb      85424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.65 1.259 -0.00093812 2.772e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 6; } { group AC; count 3; } { group ACCH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dihydrophenanthrene-3,4-diol" "phenanthrene-3,4-dihydrodiol" "3,4-dihydro-3,4-phenanthrenediol" "3,4-phenanthrenediol, 3,4-dihydro-" );
gibbsFormation
{
    dHf_298   -128010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64060.0
    phase     gas;
}
