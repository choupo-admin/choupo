/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-dichloro-2-hydroxybenzoic acid  (C7H4Cl2O3, CAS 3401-80-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Dichloro2HydroxybenzoicAcid;
formula     C7H4Cl2O3;
CAS         3401-80-7;
InChIKey    FKIKPQHMWFZFEB-UHFFFAOYSA-N;
MW          207.006;      // g/mol [origin=calculated method=formula-sum]
Tc          947.93;      // K   [origin=predictive method=joback]
Pc          49.246;      // bar [origin=predictive method=joback]
omega       1.0424;      // -   [origin=predictive method=lee-kesler]
Tb          697.39;      // K   [origin=predictive method=joback]
HvapTb      73724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.68 0.6899 -0.00062388 2.269e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 1; } { group COOH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-bis(chloranyl)-2-oxidanyl-benzoic acid" "3,6-dichlorosalicylic acid" "3,6-dichloro-2-hydroxy-benzoic acid" "benzoic acid, 3,6-dichloro-2-hydroxy-" "salicylic acid, 3,6-dichloro-" "2-oxy-3,6-dichlorobenzoic acid" "2-hydroxy-3,6-dichlorobenzoic acid" "hxx" "3,6-dichloro-2-hydroxy benzoic acid" "68938-80-7 (di-potassium salt)" "benzoic acid,3,6-dichloro-2-hydroxy-" "68938-79-4 (potassium.hydrochloride salt)" );
gibbsFormation
{
    dHf_298   -533280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-421180.0
    phase     gas;
}
