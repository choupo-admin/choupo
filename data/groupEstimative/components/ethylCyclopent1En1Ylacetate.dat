/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl cyclopent-1-en-1-ylacetate  (C9H14O2, CAS 57647-92-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylCyclopent1En1Ylacetate;
formula     C9H14O2;
CAS         57647-92-4;
InChIKey    BQAQPTBVFWRVPE-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          689.12;      // K   [origin=predictive method=joback]
Pc          29.441;      // bar [origin=predictive method=joback]
omega       0.5231;      // -   [origin=predictive method=lee-kesler]
Tb          487.83;      // K   [origin=predictive method=joback]
HvapTb      44555.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.228 0.84672 -0.00047424 8.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-(cyclopenten-1-yl)ethanoate" "ethyl cyclopent-1-ene-1-acetate" "ethyl 2-(1-cyclopentenyl)acetate" "ethyl 2-(cyclopenten-1-yl)acetate" "ethylcyclopent-1-enylmethanecarboxylate" "1-cyclopentene-1-aceticacid, ethyl ester" "1-cyclopentene-1-acetic acid, ethyl ester" );
standardThermochemistry
{
    dHf_298   -419240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-220880.0
}
