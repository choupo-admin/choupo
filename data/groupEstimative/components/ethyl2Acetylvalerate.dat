/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-acetylvalerate  (C9H16O3, CAS 1540-28-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Acetylvalerate;
formula     C9H16O3;
CAS         1540-28-9;
InChIKey    VHOACUZAQKMOEQ-UHFFFAOYSA-N;
MW          172.224;      // g/mol [origin=calculated method=formula-sum]
Tc          700.92;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.6963;      // -   [origin=predictive method=lee-kesler]
Tb          517.17;      // K   [origin=predictive method=joback]
HvapTb      49393.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.793 0.78196 -0.0003557 2.926e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-ethanoylpentanoate" "ethyl 2-acetylpentanoate" "ethyl 2-propylacetoacetate" "ethyl propylacetoacetate" "pentanoic acid, 2-acetyl-, ethyl ester" "2-acetyl-pentanoic acid ethyl ester" "ethyl .alpha.-propylacetoacetate" "n-amyl acetoacetate" "ethyl alpha-propylacetoacetate" "ethyl n-propylacetoacetate" "valeric acid, 2-acetyl-, ethyl ester" );
gibbsFormation
{
    dHf_298   -664230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-416830.0
    phase     gas;
}
