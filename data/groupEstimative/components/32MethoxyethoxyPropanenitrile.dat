/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-methoxyethoxy)propanenitrile  (C6H11NO2, CAS 35633-50-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32MethoxyethoxyPropanenitrile;
formula     C6H11NO2;
CAS         35633-50-2;
InChIKey    ZAGOKQGYDCMNPT-UHFFFAOYSA-N;
MW          129.159;      // g/mol [origin=calculated method=formula-sum]
Tc          671.06;      // K   [origin=predictive method=joback]
Pc          29.124;      // bar [origin=predictive method=joback]
omega       0.6253;      // -   [origin=predictive method=lee-kesler]
Tb          483.80;      // K   [origin=predictive method=joback]
HvapTb      44248.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (65.434 0.38222 -4.96e-05 -5.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3O; count 1; } { group CH2O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group O; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propanenitrile, 3-(2-methoxyethoxy)-" "methoxyethoxypropionitrile" );
gibbsFormation
{
    dHf_298   -266730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77180.0
    phase     gas;
}
