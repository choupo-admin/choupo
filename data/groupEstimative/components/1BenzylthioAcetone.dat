/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(benzylthio)acetone  (C10H12OS, CAS 10230-69-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1BenzylthioAcetone;
formula     C10H12OS;
CAS         10230-69-0;
InChIKey    OIEDQMIEPJIRFT-UHFFFAOYSA-N;
MW          180.265;      // g/mol [origin=calculated method=formula-sum]
Tc          812.65;      // K   [origin=predictive method=joback]
Pc          32.028;      // bar [origin=predictive method=joback]
omega       0.5859;      // -   [origin=predictive method=lee-kesler]
Tb          577.73;      // K   [origin=predictive method=joback]
HvapTb      53693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.148 0.84131 -0.0004925 9.666e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group CH3CO; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(phenylmethylsulfanyl)propan-2-one" "1-(benzylsulfanyl)acetone" ".alpha.-(benzylthio)acetone" "1-(benzylthio)-2-propanone" "1-(phenylmethylthio)acetone" "alpha-(benzylthio)acetone" "1-benzylsulfanylpropan-2-one" "1-(benzylsulfanyl)propan-2-one" "2-propanone,1-[(phenylmethyl)thio]-" "2-propanone,(benzylthio)- (7ci);2-propanone, 1-(benzylthio)- (8ci);(benzylthio)acetone;1-(benzylthio)-2-propanone;1-(benzylthio)acetone;benzylthio-2-propanone;" );
standardThermochemistry
{
    dHf_298   -83910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49930.0
}
