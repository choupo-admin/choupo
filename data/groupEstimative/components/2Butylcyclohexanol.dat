/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butylcyclohexanol  (C10H20O, CAS 36159-49-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butylcyclohexanol;
formula     C10H20O;
CAS         36159-49-6;
InChIKey    LVDALGYBEFALAP-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          721.48;      // K   [origin=predictive method=joback]
Pc          27.297;      // bar [origin=predictive method=joback]
omega       0.7902;      // -   [origin=predictive method=lee-kesler]
Tb          535.46;      // K   [origin=predictive method=joback]
HvapTb      54653.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.577 1.08342 -0.0005762 9.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butylcyclohexan-1-ol" "cyclohexanol, 2-butyl-," "cyclohexanol, 2-butyl-" "2-n-butyl-1-cyclohexanol" );
gibbsFormation
{
    dHf_298   -367980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-86760.0
    phase     gas;
}
