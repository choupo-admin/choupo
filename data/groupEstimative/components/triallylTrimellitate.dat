/*--------------------------------*- Choupo -*-----------------------*\
  Component: triallyl trimellitate  (C18H18O6, CAS 2694-54-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triallylTrimellitate;
formula     C18H18O6;
CAS         2694-54-4;
InChIKey    GRPURDFRFHUDSP-UHFFFAOYSA-N;
MW          330.336;      // g/mol [origin=calculated method=formula-sum]
Tc          1020.04;      // K   [origin=predictive method=joback]
Pc          15.949;      // bar [origin=predictive method=joback]
omega       1.0821;      // -   [origin=predictive method=lee-kesler]
Tb          812.78;      // K   [origin=predictive method=joback]
HvapTb      79473.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.473 1.2915 -0.00063742 5.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 3; } { group ACH; count 3; } { group AC; count 3; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 3; } { group dCH; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(prop-2-enyl) benzene-1,2,4-tricarboxylate" "triallyl benzene-1,2,4-tricarboxylate" "trimellitic acid triallyl ester" "1,2,4-triallyl trimellitate" "1,2,4-benzenetricarboxylic acid, tri-2-propenyl ester" "tri-2-propenyl 1,2,4-benzenetricarboxylate" "triprop-2-en-1-yl benzene-1,2,4-tricarboxylate" "1,2,4-benzenetricarboxylic acid, triallyl ester (7ci,8ci)" "1,2,4-benzenetricarboxylic acid, 1,2,4-tri-2-propen-1-yl ester" "triallyl 1,2,4-benzenetricarboxylate" "1,2,4-benzenetricarboxylicacid, 1,2,4-tri-2-propen-1-yl ester" "1,2,4-benzenetricarboxylicacid, tri-2-propenyl ester (9ci);1,2,4-benzenetricarboxylic acid, triallylester (7ci,8ci);1,2,4-triallyl trimellitate;triam 705;triam 750;triallyl1,2,4-benzenetricarboxylate;triallyl trimellitate;trimellitic acid triallylester;" );
gibbsFormation
{
    dHf_298   -776810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     878.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-473760.0
    phase     gas;
}
