/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,3-trimethoxypropene  (C6H12O3, CAS 17576-35-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        133Trimethoxypropene;
formula     C6H12O3;
CAS         17576-35-1;
InChIKey    JGVSIZVWGGQMPY-UHFFFAOYSA-N;
MW          132.159;      // g/mol [origin=calculated method=formula-sum]
Tc          586.02;      // K   [origin=predictive method=joback]
Pc          31.385;      // bar [origin=predictive method=joback]
omega       0.4614;      // -   [origin=predictive method=lee-kesler]
Tb          407.86;      // K   [origin=predictive method=joback]
HvapTb      35750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.07 0.41016 -5.66e-05 -5.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,3-trimethoxyprop-1-ene" "1-propene, 1,3,3-trimethoxy-" "agn-pc-02mp6e" "1-propene,1,3,3-trimethoxy-" "acrolein,3-methoxy-, dimethyl acetal (6ci,8ci); propene, 1,3,3-trimethoxy- (8ci);1,3,3-trimethoxy-1-propene; 1,3,3-trimethoxypropene" );
gibbsFormation
{
    dHf_298   -451890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-237580.0
    phase     gas;
}
