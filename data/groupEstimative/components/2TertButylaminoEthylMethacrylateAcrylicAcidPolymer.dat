/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(tert-butylamino)ethyl methacrylate, acrylic acid polymer  (C13H23NO4, CAS 70788-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TertButylaminoEthylMethacrylateAcrylicAcidPolymer;
formula     C13H23NO4;
CAS         70788-45-3;
InChIKey    CQGCWIKFSBDDLW-UHFFFAOYSA-N;
MW          257.33;      // g/mol [origin=calculated method=formula-sum]
Tc          945.39;      // K   [origin=predictive method=joback]
Pc          18.278;      // bar [origin=predictive method=joback]
omega       1.0293;      // -   [origin=predictive method=lee-kesler]
Tb          742.35;      // K   [origin=predictive method=joback]
HvapTb      73277.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.542 1.19058 -0.0005151 1.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group COOH; count 1; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(tert-butylamino)ethyl 2-methylprop-2-enoate;prop-2-enoic acid" "2-propenoic acid, 2-methyl-, 2-((1,1-dimethylethyl)amino)ethyl ester, polymer with 2-propenoic acid" );
standardThermochemistry
{
    dHf_298   -805030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     862.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-441100.0
}
