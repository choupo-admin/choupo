/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethylidenebicyclo[2.2.2]octane  (C10H14, CAS 36439-79-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethylidenebicyclo222Octane;
formula     C10H14;
CAS         36439-79-9;
InChIKey    WEOIMVGRKQBCKD-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          657.79;      // K   [origin=predictive method=joback]
Pc          29.861;      // bar [origin=predictive method=joback]
omega       0.3469;      // -   [origin=predictive method=lee-kesler]
Tb          448.74;      // K   [origin=predictive method=joback]
HvapTb      38342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.35 1.0014 -0.000683 1.884e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.2]octane,2,3-bis(methylene)-" "bicyclo(2.2.2)octane, 2,3-bis(methylene)-" );
gibbsFormation
{
    dHf_298   52030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=236780.0
    phase     gas;
}
