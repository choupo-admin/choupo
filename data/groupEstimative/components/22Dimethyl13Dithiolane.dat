/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-1,3-dithiolane  (C5H10S2, CAS 6008-78-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl13Dithiolane;
formula     C5H10S2;
CAS         6008-78-2;
InChIKey    HEDYXMHGMMWNBO-UHFFFAOYSA-N;
MW          134.255;      // g/mol [origin=calculated method=formula-sum]
Tc          669.50;      // K   [origin=predictive method=joback]
Pc          45.347;      // bar [origin=predictive method=joback]
omega       0.2193;      // -   [origin=predictive method=lee-kesler]
Tb          425.18;      // K   [origin=predictive method=joback]
HvapTb      37454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.49 0.93126 -0.0009456 4.034e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dithiolane, 2,2-dimethyl-" );
gibbsFormation
{
    dHf_298   19710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102000.0
    phase     gas;
}
