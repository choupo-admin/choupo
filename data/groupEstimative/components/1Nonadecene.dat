/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-nonadecene  (C19H38, CAS 18435-45-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Nonadecene;
formula     C19H38;
CAS         18435-45-5;
InChIKey    NHLUYCJZUXOUBX-UHFFFAOYSA-N;
MW          266.513;      // g/mol [origin=calculated method=formula-sum]
Tc          792.02;      // K   [origin=predictive method=joback]
Pc          11.111;      // bar [origin=predictive method=joback]
omega       0.7949;      // -   [origin=predictive method=lee-kesler]
Tb          631.00;      // K   [origin=predictive method=joback]
HvapTb      57218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.374 1.78882 -0.0010327 2.323e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonadec-1-ene" "nonadecene" );
gibbsFormation
{
    dHf_298   -310060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     891.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196940.0
    phase     gas;
}
