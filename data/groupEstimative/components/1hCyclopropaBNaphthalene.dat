/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-cyclopropa[b]naphthalene  (C11H8, CAS 286-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1hCyclopropaBNaphthalene;
formula     C11H8;
CAS         286-85-1;
InChIKey    SHKRKDNBUOUWRB-UHFFFAOYSA-N;
MW          140.185;      // g/mol [origin=calculated method=formula-sum]
Tc          746.61;      // K   [origin=predictive method=joback]
Pc          38.340;      // bar [origin=predictive method=joback]
omega       0.4491;      // -   [origin=predictive method=lee-kesler]
Tb          509.77;      // K   [origin=predictive method=joback]
HvapTb      45198.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.8 1.0438 -0.00097684 3.638e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h-cyclopropa(b)naphthalene" );
standardThermochemistry
{
    dHf_298   239750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     269.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=334200.0
}
