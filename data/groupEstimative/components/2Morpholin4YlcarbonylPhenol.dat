/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(morpholin-4-ylcarbonyl)phenol  (C11H13NO3, CAS 3202-84-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Morpholin4YlcarbonylPhenol;
formula     C11H13NO3;
CAS         3202-84-4;
InChIKey    TUFGIGGYNZUDAL-UHFFFAOYSA-N;
MW          207.229;      // g/mol [origin=calculated method=formula-sum]
Tc          918.61;      // K   [origin=predictive method=joback]
Pc          42.775;      // bar [origin=predictive method=joback]
omega       0.9194;      // -   [origin=predictive method=lee-kesler]
Tb          671.79;      // K   [origin=predictive method=joback]
HvapTb      69235.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.37 1.3756 -0.00112496 3.6566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group FCH2O; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group O_ring; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-hydroxyphenyl)-morpholin-4-yl-methanone" "4-salicyloylmorpholine" "morpholine, 4-salicyloyl-" "n-salicyloyl morpholine" "morpholine, 4-(2-hydroxybenzoyl)-" "2-hydroxyphenyl morpholin-4-yl ketone" "(2-hydroxyphenyl)-morpholin-4-ylmethanone" "(2-hydroxyphenyl)(morpholin-4-yl)methanone" "(2-hydroxy-phenyl)-morpholin-4-yl-methanone" );
standardThermochemistry
{
    dHf_298   -307380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60470.0
}
