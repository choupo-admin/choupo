/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethylanisole  (C9H12O, CAS 4685-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dimethylanisole;
formula     C9H12O;
CAS         4685-47-6;
InChIKey    LVUBSVWMOWKPDJ-UHFFFAOYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          673.17;      // K   [origin=predictive method=joback]
Pc          30.933;      // bar [origin=predictive method=joback]
omega       0.4140;      // -   [origin=predictive method=lee-kesler]
Tb          464.58;      // K   [origin=predictive method=joback]
HvapTb      41638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.9 0.59776 -0.00025192 1.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxy-1,2-dimethyl-benzene" "4-methoxy-1,2-dimethylbenzene" "4-methoxy-o-xylene" "benzene, 4-methoxy-1,2-dimethyl-" "1,2-dimethyl-4-methoxybenzene" "3,4-dimethylphenyl methyl ether" "lvubsvwmowkpdj-uhfffaoysa-" "anisole,3,4-dimethyl- (6ci,7ci,8ci);1,2-dimethyl-4-methoxybenzene;1-methoxy-3,4-dimethylbenzene;2-methyl-4-methoxytoluene;3,4-dimethylanisole;3,4-dimethylphenol methyl ether;4-methoxy-1,2-dimethylbenzene;4-methoxy-o-xylene;" );
gibbsFormation
{
    dHf_298   -147720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13050.0
    phase     gas;
}
