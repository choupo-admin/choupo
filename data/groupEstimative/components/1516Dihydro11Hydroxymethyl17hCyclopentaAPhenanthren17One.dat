/*--------------------------------*- Choupo -*-----------------------*\
  Component: 15,16-dihydro-11-hydroxymethyl-17h-cyclopenta(a)phenanthren-17-one  (C18H14O2, CAS 55651-36-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1516Dihydro11Hydroxymethyl17hCyclopentaAPhenanthren17One;
formula     C18H14O2;
CAS         55651-36-0;
InChIKey    KMMASHMZJFVOOO-UHFFFAOYSA-N;
MW          262.308;      // g/mol [origin=calculated method=formula-sum]
Tc          1107.67;      // K   [origin=predictive method=joback]
Pc          27.847;      // bar [origin=predictive method=joback]
omega       1.3053;      // -   [origin=predictive method=lee-kesler]
Tb          867.41;      // K   [origin=predictive method=joback]
HvapTb      85014.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.529 1.4326 -0.00105388 3.154e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 5; } { group ACCH2; count 2; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 7; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-(hydroxymethyl)-15,16-dihydrocyclopenta[a]phenanthren-17-one" "17h-cyclopenta(a)phenanthren-17-one, 15,16-dihydro-11-hydroxymethyl-" "11-(hydroxymethyl)gona-1(10),2,4,6,8,11,13-heptaen-17-one" );
gibbsFormation
{
    dHf_298   -38850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196920.0
    phase     gas;
}
