/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzylacetoacetamide  (C11H13NO2, CAS 882-36-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzylacetoacetamide;
formula     C11H13NO2;
CAS         882-36-0;
InChIKey    KOHNUEXAOQRRPI-UHFFFAOYSA-N;
MW          191.23;      // g/mol [origin=calculated method=formula-sum]
Tc          854.65;      // K   [origin=predictive method=joback]
Pc          30.727;      // bar [origin=predictive method=joback]
omega       0.8757;      // -   [origin=predictive method=lee-kesler]
Tb          635.87;      // K   [origin=predictive method=joback]
HvapTb      62284.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.508 0.99012 -0.000617 1.3762e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3CO; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanylidene-n-(phenylmethyl)butanamide" "acetoacetbenzylamide" "n-benzyl-3-oxobutanamide" "n-acetoacetylbenzylamine" "acetoacetobenzylamide" "butanamide, 3-oxo-n-(phenylmethyl)-" "3-oxo-n-benzylbutanamide" "n-acetoacetabenzylamine" "acetoacetamide, n-benzyl-" "acetoacetamide, n-benzyl- (8ci)" );
gibbsFormation
{
    dHf_298   -205530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14300.0
    phase     gas;
}
