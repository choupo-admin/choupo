/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromohexacosane  (C26H53Br, CAS 4276-51-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromohexacosane;
formula     C26H53Br;
CAS         4276-51-1;
InChIKey    CCSZHMUGOPQUDX-UHFFFAOYSA-N;
MW          445.614;      // g/mol [origin=calculated method=formula-sum]
Tc          1054.06;      // K   [origin=predictive method=joback]
Pc          7.527;      // bar [origin=predictive method=joback]
omega       0.7060;      // -   [origin=predictive method=lee-kesler]
Tb          860.64;      // K   [origin=predictive method=joback]
HvapTb      79905.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.555 2.51202 -0.001462 3.323e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 25; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 25; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylhexacosane" "hexacosane, 1-bromo-" "bromohexacosane" );
gibbsFormation
{
    dHf_298   -553640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1219.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=182360.0
    phase     gas;
}
