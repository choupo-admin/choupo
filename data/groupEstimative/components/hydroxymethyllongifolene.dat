/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydroxymethyllongifolene  (C16H26O, CAS 5989-05-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydroxymethyllongifolene;
formula     C16H26O;
CAS         5989-05-9;
InChIKey    XUMDBSUTEGMQRC-VTQLKFFXSA-N;
MW          234.383;      // g/mol [origin=calculated method=formula-sum]
Tc          893.26;      // K   [origin=predictive method=joback]
Pc          21.256;      // bar [origin=predictive method=joback]
omega       0.8993;      // -   [origin=predictive method=lee-kesler]
Tb          684.40;      // K   [origin=predictive method=joback]
HvapTb      65839.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-244.339 2.44466 -0.0023677 9.676e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 3; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanol, 2-((1s,3ar,4s,8ar)-decahydro-4,8,8-trimethyl-1,4-methanoazulen-9-ylidene)-" "(1s-(1alpha,3abeta,4alpha,8abeta))-2-(decahydro-4,8,8-trimethyl-1,4-methanoazulen-9-ylidene)ethanol" );
standardThermochemistry
{
    dHf_298   -253890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124130.0
}
