/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,7,10,13-pentaoxacyclopentadecane-2-methanol  (C11H22O6, CAS 75507-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1471013Pentaoxacyclopentadecane2Methanol;
formula     C11H22O6;
CAS         75507-25-4;
InChIKey    YHIQMMGCRYKJLB-UHFFFAOYSA-N;
MW          250.291;      // g/mol [origin=calculated method=formula-sum]
Tc          968.65;      // K   [origin=predictive method=joback]
Pc          30.967;      // bar [origin=predictive method=joback]
omega       1.0643;      // -   [origin=predictive method=lee-kesler]
Tb          736.19;      // K   [origin=predictive method=joback]
HvapTb      81286.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.909 1.1035 -0.0001989 -1.735e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } { group FCH2O; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 1; } { group OH; count 1; } { group O_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,7,10,13-pentaoxacyclopentadec-2-ylmethanol" "2-hydroxymethyl-15-crown-5" "2-hydroxymethyl-15-crown-5;" "2-(hydroxymethyl)-15-crown 5-ether" "2-(hydroxymethyl)-15-crown-5-ether" "(2,5,8,11,14-pentaoxacyclopentadecyl)methan-1-ol" "1,4,7,10,13-pentaoxacyclopentadec-2-yl-methanol" "1,4,7,10,13-pentaoxacyclopentadecan-2-ylmethanol" );
standardThermochemistry
{
    dHf_298   -1083720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-610130.0
}
