/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptanolactone  (C7H12O2, CAS 539-87-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptanolactone;
formula     C7H12O2;
CAS         539-87-7;
InChIKey    BTLSLHNLDQCWKS-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          653.53;      // K   [origin=predictive method=joback]
Pc          36.865;      // bar [origin=predictive method=joback]
omega       0.3922;      // -   [origin=predictive method=lee-kesler]
Tb          442.20;      // K   [origin=predictive method=joback]
HvapTb      39321.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.61 0.7626 -0.0003988 5.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxocan-2-one" );
gibbsFormation
{
    dHf_298   -430430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-270150.0
    phase     gas;
}
