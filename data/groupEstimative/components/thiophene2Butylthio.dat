/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiophene, 2-(butylthio)-  (C8H12S2, CAS 3988-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiophene2Butylthio;
formula     C8H12S2;
CAS         3988-71-4;
InChIKey    PTTSDBWFNLNXII-UHFFFAOYSA-N;
MW          172.304;      // g/mol [origin=calculated method=formula-sum]
Tc          759.53;      // K   [origin=predictive method=joback]
Pc          34.399;      // bar [origin=predictive method=joback]
omega       0.4419;      // -   [origin=predictive method=lee-kesler]
Tb          522.50;      // K   [origin=predictive method=joback]
HvapTb      47843.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.473 0.75932 -0.00048022 1.164e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2S; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group S; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butylsulfanylthiophene" "2-(butylsulfanyl)thiophene" "2-butylsulfanyl-thiophene" );
standardThermochemistry
{
    dHf_298   63590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184010.0
}
