/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 2-oxoglutarate  (C7H10O5, CAS 13192-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl2Oxoglutarate;
formula     C7H10O5;
CAS         13192-04-6;
InChIKey    TXIXSLPEABAEHP-UHFFFAOYSA-N;
MW          174.152;      // g/mol [origin=calculated method=formula-sum]
Tc          719.12;      // K   [origin=predictive method=joback]
Pc          30.289;      // bar [origin=predictive method=joback]
omega       0.7962;      // -   [origin=predictive method=lee-kesler]
Tb          530.07;      // K   [origin=predictive method=joback]
HvapTb      52736.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.702 0.53124 -0.0001491 -5.114e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2CO; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CdO; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-oxidanylidenepentanedioate" "dimethyl " "a-ketoglutarate" "dimethyl 2-oxopentanedioate" "dimethyl 2-ketoglutarate" "2-oxopentanedioic acid, dimethyl ether" "dimethyl-alpha-ketoglutarate" "2-oxoglutaric acid dimethyl ester" "2-ketoglutaric acid dimethyl ester" "2-oxopentanedioic acid dimethyl ester" "glutaric acid, 2-oxo-, dimethyl ester" "pentanedioic acid, 2-oxo-, dimethyl ester" "pentanedioic acid,2-oxo-, 1,5-dimethyl ester" );
standardThermochemistry
{
    dHf_298   -934950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-741600.0
}
