/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 4-dimethylaminobenzoate  (C11H15NO2, CAS 10287-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl4Dimethylaminobenzoate;
formula     C11H15NO2;
CAS         10287-53-3;
InChIKey    FZUGPQWGEGAKET-UHFFFAOYSA-N;
MW          193.246;      // g/mol [origin=calculated method=formula-sum]
Tc          758.52;      // K   [origin=predictive method=joback]
Pc          26.164;      // bar [origin=predictive method=joback]
omega       0.6497;      // -   [origin=predictive method=lee-kesler]
Tb          553.60;      // K   [origin=predictive method=joback]
HvapTb      52468.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.999 0.97956 -0.00055676 1.006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 4-(dimethylamino)benzoate" "parbenate" "benzoic acid, 4-(dimethylamino)-, ethyl ester" "ethyl-p-dimethylaminobenzoate" "ethyl-4-dimethylaminobenzoate" "ethyl p-dimethylaminobenzoate" "m401" "4-(dimethylamino)benzoic acid ethyl ester" "4-(n,n-dimethylamino)benzoic acid ethyl ester" "benzoic acid, p-(dimethylamino)-, ethyl ester" );
gibbsFormation
{
    dHf_298   -295060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55070.0
    phase     gas;
}
