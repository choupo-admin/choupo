/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-2-methylpiperidine  (C6H13N, CAS 3197-42-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s2Methylpiperidine;
formula     C6H13N;
CAS         3197-42-0;
InChIKey    NNWUEBIEOFQMSS-LURJTMIESA-N;
MW          99.177;      // g/mol [origin=calculated method=formula-sum]
Tc          619.01;      // K   [origin=predictive method=joback]
Pc          40.881;      // bar [origin=predictive method=joback]
omega       0.2910;      // -   [origin=predictive method=lee-kesler]
Tb          404.98;      // K   [origin=predictive method=joback]
HvapTb      36137.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.25 0.68252 -0.000323 3.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-methylpiperidine" "(s)-(+)-2-methylpiperidine" "piperidin, 2e-methyl" "s-2-methyl-piperidinedihydrochloride" "piperidine, 2-methyl-,(2s)-" "n117" );
gibbsFormation
{
    dHf_298   -75040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     353.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=111800.0
    phase     gas;
}
