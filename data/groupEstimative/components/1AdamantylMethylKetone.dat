/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-adamantyl methyl ketone  (C12H18O, CAS 1660-04-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1AdamantylMethylKetone;
formula     C12H18O;
CAS         1660-04-4;
InChIKey    DACIGVIOAFXPHW-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          773.95;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       0.5071;      // -   [origin=predictive method=lee-kesler]
Tb          548.09;      // K   [origin=predictive method=joback]
HvapTb      47503.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-200.56 1.82432 -0.0017017 6.6036e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-adamantyl)ethanone" "1-acetyladamantane" "acetyladamantane" "ethanone, 1-tricyclo[3.3.1.1(3,7)-]dec-1-yl-" "1-(tricyclo[3.3.1.1~3,7~]dec-1-yl)ethanone" "methyl 1-adamantyl ketone" "1-(adamantan-1-yl)ethanone" "ambap1660-04-4" "dacigvioafxphw-uhfffaoysa-" "1-((3r,5r,7r)-adamantan-1-yl)ethanone" "ethanone, 1-tricyclo(3.3.1.13,7)dec-1-yl-" "methyl tricyclo(3.3.1.13,7)dec-1-yl ketone" );
gibbsFormation
{
    dHf_298   -196450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78190.0
    phase     gas;
}
