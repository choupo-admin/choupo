/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-([bis(2-hydroxyethyl)amino]methyl)-4-tert-butylphenol  (C15H25NO3, CAS 69470-50-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bis2HydroxyethylAminoMethyl4TertButylphenol;
formula     C15H25NO3;
CAS         69470-50-4;
InChIKey    KUSJOXZZOOOPOD-UHFFFAOYSA-N;
MW          267.369;      // g/mol [origin=calculated method=formula-sum]
Tc          1047.69;      // K   [origin=predictive method=joback]
Pc          25.201;      // bar [origin=predictive method=joback]
omega       1.6766;      // -   [origin=predictive method=lee-kesler]
Tb          848.65;      // K   [origin=predictive method=joback]
HvapTb      99041.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.855 1.76276 -0.00135792 4.299e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 2; } { group ACOH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 2; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[bis(2-hydroxyethyl)amino]methyl]-4-tert-butyl-phenol" "2-[[bis(2-hydroxyethyl)amino]methyl]-4-tert-butylphenol" "ethanol,2'-(5-tert-butyl-2-hydroxybenzyl-amino)bis-" );
gibbsFormation
{
    dHf_298   -550860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     733.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-136440.0
    phase     gas;
}
