/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-1-methylcyclohexane  (C7H13Br, CAS 931-77-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo1Methylcyclohexane;
formula     C7H13Br;
CAS         931-77-1;
InChIKey    VSGXTQWTJYAQHO-UHFFFAOYSA-N;
MW          177.085;      // g/mol [origin=calculated method=formula-sum]
Tc          679.35;      // K   [origin=predictive method=joback]
Pc          40.518;      // bar [origin=predictive method=joback]
omega       0.2987;      // -   [origin=predictive method=lee-kesler]
Tb          445.71;      // K   [origin=predictive method=joback]
HvapTb      36889.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.88 1.12102 -0.001042 4.138e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-1-methyl-cyclohexane" "1-bromo-1-methyl-cyclohexane" "cyclohexane, 1-bromo-1-methyl-" );
gibbsFormation
{
    dHf_298   -91920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41340.0
    phase     gas;
}
