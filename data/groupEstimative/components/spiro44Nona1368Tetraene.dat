/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[4.4]nona-1,3,6,8-tetraene  (C9H8, CAS 14867-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro44Nona1368Tetraene;
formula     C9H8;
CAS         14867-83-5;
InChIKey    CLZMRBFGNUYTSN-UHFFFAOYSA-N;
MW          116.163;      // g/mol [origin=calculated method=formula-sum]
Tc          670.33;      // K   [origin=predictive method=joback]
Pc          42.999;      // bar [origin=predictive method=joback]
omega       0.2639;      // -   [origin=predictive method=lee-kesler]
Tb          433.36;      // K   [origin=predictive method=joback]
HvapTb      36296.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-145.95 1.2262 -0.00130412 5.478e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group CH=CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dCH_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro(4.4)nona-1,3,6,8-tetraene" "spiro[4.4]nonatetraene" );
gibbsFormation
{
    dHf_298   164730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=232160.0
    phase     gas;
}
