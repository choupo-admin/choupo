/*--------------------------------*- Choupo -*-----------------------*\
  Component: pregnane-3,20-diol  (C21H36O2, CAS 4479-11-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pregnane320Diol;
formula     C21H36O2;
CAS         4479-11-2;
InChIKey    YWYQTGBBEZQBGO-UHFFFAOYSA-N;
MW          320.517;      // g/mol [origin=calculated method=formula-sum]
Tc          1109.33;      // K   [origin=predictive method=joback]
Pc          16.810;      // bar [origin=predictive method=joback]
omega       1.2610;      // -   [origin=predictive method=lee-kesler]
Tb          894.11;      // K   [origin=predictive method=joback]
HvapTb      92284.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-310.1 3.10616 -0.002675 9.887e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 7; } { group C; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 6; } { group C_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "17-(1-hydroxyethyl)-10,13-dimethyl-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthren-3-ol" "5.beta.-pregnan-3.alpha.,20.alpha.-diol" "pregnanediol" "5beta-pregnane-3alpha,20alpha-diol" "diol (6ci,7ci)" "pregnane-3alpha,20alpha-diol" "3alpha,20alpha-dihydroxy-5beta-pregnane" "5-beta-pregnane-3-alpha,20-alpha-diol" "5-beta-pregnane-3-alpha, 20-alpha-diol" "pregnandiol [jan]" "5beta-pregnane, 3alpha,20alpha-dihydroxy-" "allopregnandiol" );
standardThermochemistry
{
    dHf_298   -576990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     774.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9460.0
}
