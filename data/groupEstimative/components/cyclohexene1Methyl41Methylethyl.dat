/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene, 1-methyl-4-(1-methylethyl)-  (C10H18, CAS 5502-88-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene1Methyl41Methylethyl;
formula     C10H18;
CAS         5502-88-5;
InChIKey    FAMJUFMHYAFYNU-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          656.61;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.3350;      // -   [origin=predictive method=lee-kesler]
Tb          451.65;      // K   [origin=predictive method=joback]
HvapTb      38849.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.41 0.96636 -0.00052464 9.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-propan-2-yl-cyclohexene" "1-p-menthene" "p-menth-1-ene" ".delta.(sup1)-p-menthene" "menthene" "1-methyl-4-isopropylcyclohexene" "p-menth-1-ene, (r)-(+)-" "1-methyl-4-isopropyl-1-cyclohexene" "carvomenthene" "1-methyl-4-propan-2-ylcyclohexene" "cyclohexene, 1-methyl-4-(1-methylethyl)-, (r)-" "cyclohexane, 1-methyl-4-(1-methylethyl)-, didehydro deriv." );
gibbsFormation
{
    dHf_298   -154380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75660.0
    phase     gas;
}
