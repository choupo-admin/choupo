/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene,1-propyl-  (C9H16, CAS 2539-75-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene1Propyl;
formula     C9H16;
CAS         2539-75-5;
InChIKey    WCPWJMLXSZIWOP-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          636.83;      // K   [origin=predictive method=joback]
Pc          30.090;      // bar [origin=predictive method=joback]
omega       0.3443;      // -   [origin=predictive method=lee-kesler]
Tb          433.88;      // K   [origin=predictive method=joback]
HvapTb      37320.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.758 0.89192 -0.00052244 1.13e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propylcyclohexene" "1-propyl-1-cyclohexene" "cyclohexene, propyl-" "cyclohexene, 1-propyl-" );
standardThermochemistry
{
    dHf_298   -108120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77390.0
}
