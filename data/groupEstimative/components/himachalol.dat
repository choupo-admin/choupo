/*--------------------------------*- Choupo -*-----------------------*\
  Component: himachalol  (C15H26O, CAS 1891-45-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        himachalol;
formula     C15H26O;
CAS         1891-45-8;
InChIKey    BBAMLNIPVMLTSQ-VNHYZAJKSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          879.81;      // K   [origin=predictive method=joback]
Pc          21.918;      // bar [origin=predictive method=joback]
omega       0.8054;      // -   [origin=predictive method=lee-kesler]
Tb          665.09;      // K   [origin=predictive method=joback]
HvapTb      64383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-197.57 2.13198 -0.00190564 7.451e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4ar,5r,9as)-2,5,9,9-tetramethyl-4,4a,6,7,8,9a-hexahydro-3h-benzo[7]annulen-5-ol" "2,4a,5,6,7,8,9,9a-octahydro-3,5,5,9-tetramethyl-1h-benzocyclohepten-9-ol" "(4as,9r,9ar)-3,5,5,9-tetramethyl-2,4a,5,6,7,8,9,9a-octahydro-1h-benzo[7]annulen-9-ol" "1h-benzocyclohepten-9-ol, 2,4a-beta,5,6,7,8,9,9a-beta-octahydro-3,5,5,9-beta-tetramethyl-" "2,4a-beta,5,6,7,8,9,9a-beta-octahydro-3,5,5,9-beta-tetramethyl-1h-benzocyclohepten-9-ol" "(+)-2-himachalen-7-ol" );
gibbsFormation
{
    dHf_298   -354250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6470.0
    phase     gas;
}
