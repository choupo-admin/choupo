/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-chloranyl-5-methyl-hex-1-en-3-yne  (C7H9Cl, CAS 819-44-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Chloranyl5MethylHex1En3Yne;
formula     C7H9Cl;
CAS         819-44-3;
InChIKey    MCXPOGYVVMJKMP-UHFFFAOYSA-N;
MW          128.599;      // g/mol [origin=calculated method=formula-sum]
Tc          615.20;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       0.2079;      // -   [origin=predictive method=lee-kesler]
Tb          399.64;      // K   [origin=predictive method=joback]
HvapTb      35747.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.49 0.63164 -0.00047996 1.4938e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group tC; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   185430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=289610.0
}
