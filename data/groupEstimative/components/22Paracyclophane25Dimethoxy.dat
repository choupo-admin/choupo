/*--------------------------------*- Choupo -*-----------------------*\
  Component: [2.2]-paracyclophane, 2,5-dimethoxy-  (C18H20O2, CAS 65317-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Paracyclophane25Dimethoxy;
formula     C18H20O2;
CAS         65317-00-2;
InChIKey    CLFMRMYRIJJZAH-UHFFFAOYSA-N;
MW          268.356;      // g/mol [origin=calculated method=formula-sum]
Tc          985.20;      // K   [origin=predictive method=joback]
Pc          20.850;      // bar [origin=predictive method=joback]
omega       0.7803;      // -   [origin=predictive method=lee-kesler]
Tb          745.24;      // K   [origin=predictive method=joback]
HvapTb      68076.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.39 1.35944 -0.00075684 1.424e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACCH2; count 4; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2.2)-paracyclophane, 2,5-dimethoxy-" "5,15-dimethoxytricyclo[8.2.2.24,7]hexadeca-1(12),4,6,10,13,15-hexaene" );
gibbsFormation
{
    dHf_298   -165130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     614.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133340.0
    phase     gas;
}
