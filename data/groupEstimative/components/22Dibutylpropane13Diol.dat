/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dibutylpropane-1,3-diol  (C11H24O2, CAS 24765-57-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dibutylpropane13Diol;
formula     C11H24O2;
CAS         24765-57-9;
InChIKey    OJMJOSRCBAXSAQ-UHFFFAOYSA-N;
MW          188.311;      // g/mol [origin=calculated method=formula-sum]
Tc          795.64;      // K   [origin=predictive method=joback]
Pc          23.315;      // bar [origin=predictive method=joback]
omega       1.3512;      // -   [origin=predictive method=lee-kesler]
Tb          632.41;      // K   [origin=predictive method=joback]
HvapTb      72142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.002 1.24264 -0.0008072 2.112e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group C; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dibutyl-1,3-propanediol" "2,2,-dibutylpropane-1,3-diol" "2,2-di-n-butyl-1,3-propanediol" );
gibbsFormation
{
    dHf_298   -583580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-229060.0
    phase     gas;
}
