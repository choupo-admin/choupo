/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methylidenebicyclo[2.2.0]hex-2-ene  (C7H8, CAS 67254-49-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methylidenebicyclo220Hex2Ene;
formula     C7H8;
CAS         67254-49-3;
InChIKey    QPKRDQSHPVHXQQ-UHFFFAOYSA-N;
MW          92.141;      // g/mol [origin=calculated method=formula-sum]
Tc          569.97;      // K   [origin=predictive method=joback]
Pc          40.312;      // bar [origin=predictive method=joback]
omega       0.2730;      // -   [origin=predictive method=lee-kesler]
Tb          371.56;      // K   [origin=predictive method=joback]
HvapTb      31453.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.89 0.7971 -0.00069228 2.458e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.0]hex-2-ene,5-methylene" "bicyclo(2.2.0)hex-2-ene, 5-methylene-" );
standardThermochemistry
{
    dHf_298   99810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     184.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212600.0
}
