/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,3-trimethylcyclopent-3-enecarboxylic acid  (C9H14O2, CAS 6709-22-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        223Trimethylcyclopent3EnecarboxylicAcid;
formula     C9H14O2;
CAS         6709-22-4;
InChIKey    ZRVJUIDXQSYDBJ-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          786.86;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.6505;      // -   [origin=predictive method=lee-kesler]
Tb          566.02;      // K   [origin=predictive method=joback]
HvapTb      52543.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.15 1.19126 -0.00106324 4.125e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3-trimethylcyclopent-3-ene-1-carboxylic acid" "a-campholytic acid" "3-cyclopentene-1-carboxylicacid, 2,2,3-trimethyl- (8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -477670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-275330.0
}
