/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,n'-triethyl-n'-methylethane-1,2-diamine  (C9H22N2, CAS 104-99-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNNTriethylNMethylethane12Diamine;
formula     C9H22N2;
CAS         104-99-4;
InChIKey    IHFOKWPYAWVPAK-UHFFFAOYSA-N;
MW          158.289;      // g/mol [origin=calculated method=formula-sum]
Tc          591.11;      // K   [origin=predictive method=joback]
Pc          22.981;      // bar [origin=predictive method=joback]
omega       0.5680;      // -   [origin=predictive method=lee-kesler]
Tb          430.40;      // K   [origin=predictive method=joback]
HvapTb      39714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.675 1.10668 -0.000691 1.707e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n',n'-triethyl-n-methyl-ethane-1,2-diamine" "1,2-ethanediamine, n,n,n'-triethyl-n'-methyl-" "1,2-ethanediamine, n1,n1,n2-triethyl-n2-methyl-" "n,n',n'-triethyl-n-methylethane-1,2-diamine" "n-methyl-n,n',n'-triethylethylenediamine" "n-methyl-n,n`,n`-triethylethylenediamine" );
gibbsFormation
{
    dHf_298   -94030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=246460.0
    phase     gas;
}
