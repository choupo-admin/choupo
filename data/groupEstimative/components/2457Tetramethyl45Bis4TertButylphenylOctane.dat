/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,5,7-tetramethyl-4,5-bis(4-tert-butylphenyl)octane  (C32H50, CAS 85668-75-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2457Tetramethyl45Bis4TertButylphenylOctane;
formula     C32H50;
CAS         85668-75-3;
InChIKey    MFHJPQMOWKNBEO-UHFFFAOYSA-N;
MW          434.752;      // g/mol [origin=calculated method=formula-sum]
Tc          1214.25;      // K   [origin=predictive method=joback]
Pc          7.864;      // bar [origin=predictive method=joback]
omega       0.6451;      // -   [origin=predictive method=lee-kesler]
Tb          981.28;      // K   [origin=predictive method=joback]
HvapTb      86742.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-166.668 3.28224 -0.00233892 6.574e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group CH2; count 2; } { group CH; count 2; } { group C; count 4; } { group ACH; count 8; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group CH2; count 2; } { group CH; count 2; } { group C; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-4-[5-(4-tert-butylphenyl)-2,4,5,7-tetramethyl-octan-4-yl]benzene" "1-tert-butyl-4-[5-(4-tert-butylphenyl)-2,4,5,7-tetramethyloctan-4-yl]benzene" );
gibbsFormation
{
    dHf_298   -299250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1002.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=430600.0
    phase     gas;
}
