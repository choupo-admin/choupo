/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-cyclobuta(cd)pentalene, 1a,3a,5a,5b-tetrahydro-1-methylene-  (C10H10, CAS 64096-73-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1hCyclobutaCdPentalene1a3a5a5bTetrahydro1Methylene;
formula     C10H10;
CAS         64096-73-7;
InChIKey    CGWXPLQCZGXXTQ-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          653.05;      // K   [origin=predictive method=joback]
Pc          33.412;      // bar [origin=predictive method=joback]
omega       0.3505;      // -   [origin=predictive method=lee-kesler]
Tb          441.43;      // K   [origin=predictive method=joback]
HvapTb      38027.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.14 1.1505 -0.00100756 3.568e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 4; } { group CH=CH; count 2; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   148130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     131.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=320860.0
    phase     gas;
}
