/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-amino-5-(4-amino-3-methoxybenzyl)benzoate  (C17H20N2O3, CAS 68003-13-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Amino54Amino3MethoxybenzylBenzoate;
formula     C17H20N2O3;
CAS         68003-13-4;
InChIKey    XOXDJJHGWFPFGE-UHFFFAOYSA-N;
MW          300.358;      // g/mol [origin=calculated method=formula-sum]
Tc          1125.49;      // K   [origin=predictive method=joback]
Pc          21.714;      // bar [origin=predictive method=joback]
omega       1.2027;      // -   [origin=predictive method=lee-kesler]
Tb          887.54;      // K   [origin=predictive method=joback]
HvapTb      91735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.712 1.22884 -0.00057644 5.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 1; } { group ACNH2; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 1; } { group COO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-azanyl-5-[(4-azanyl-3-methoxy-phenyl)methyl]benzoate" "benzoic acid, 2-amino-5-((4-amino-3-methoxyphenyl)methyl)-, ethyl ester" "benzoic acid, 2-amino-5-[(4-amino-3-methoxyphenyl)methyl]-, ethyl ester" "ethyl 2-amino-5-[(4-amino-3-methoxyphenyl)methyl]benzoate" );
standardThermochemistry
{
    dHf_298   -348950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     746.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3910.0
}
