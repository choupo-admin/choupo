/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7,7,8,8-tetramethyloctahydro-2,3b-methanocyclopenta[1,3]cyclopropa[1,2]benzene-4-carbaldehyde  (C16H24O, CAS 59056-66-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7788Tetramethyloctahydro23bMethanocyclopenta13Cyclopropa12Be;
formula     C16H24O;
CAS         59056-66-5;
InChIKey    DHERDKJNYUNHCB-UHFFFAOYSA-N;
MW          232.367;      // g/mol [origin=calculated method=formula-sum]
Tc          854.89;      // K   [origin=predictive method=joback]
Pc          22.590;      // bar [origin=predictive method=joback]
omega       0.5743;      // -   [origin=predictive method=lee-kesler]
Tb          623.98;      // K   [origin=predictive method=joback]
HvapTb      51879.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-378.25 3.19968 -0.003731 1.7116e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 3; } { group C; count 4; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group C_ring; count 4; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3b-methano-3bh-cyclopenta(1,3)cyclopropa(1,2)benzene-4-carboxaldehyde, octahydro-7,7,8,8-tetramethyl-" "2,3b-methano-3bh-cyclopenta(1,3)cyclopropa(1,2)benzene-7-carboxaldehyde, octahydro-1,1,4,4-tetramethyl-" "2,3b-methano-3bh-cyclopenta[1,3]cyclopropa[1,2]benzene-4-carboxaldehyde, octahydro-7,7,8,8-tetramethyl-" "2,3b-methano-3bh-cyclopenta[1,3]cyclopropa[1,2]benzene-7-carboxaldehyde, octahydro-1,1,4,4-tetramethyl-" "octahydro-7,7,8,8-tetramethyl-2,3b-methano-3bh-cyclopenta(1,3)cyclopropa(1,2)benzene-4-carbaldehyde" "octahydro-7,7,8,8-tetramethyl-2,3b-methano-3bh-cyclopenta(1,3)cyclopropa(1,2)benzene-4-carboxaldehyde" );
gibbsFormation
{
    dHf_298   -161850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=194330.0
    phase     gas;
}
