/*--------------------------------*- Choupo -*-----------------------*\
  Component: sabinene hydrate  (C10H18O, CAS 546-79-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sabineneHydrate;
formula     C10H18O;
CAS         546-79-2;
InChIKey    KXSDPILWMGFJMM-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          727.89;      // K   [origin=predictive method=joback]
Pc          32.246;      // bar [origin=predictive method=joback]
omega       0.7340;      // -   [origin=predictive method=lee-kesler]
Tb          529.43;      // K   [origin=predictive method=joback]
HvapTb      51360.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-197.12 1.85286 -0.002004 8.835e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-1-propan-2-yl-bicyclo[3.1.0]hexan-4-ol" "cis-sabinenehydrate" "4-thujanol" "5-isopropyl-2-methylbicyclo[3.1.0]hexan-2-ol" "bicyclo[3.1.0]hexan-2-ol, 2-methyl-5-(1-methylethyl)-" "bicyclo(3.1.0)hexan-2-ol, 2-methyl-5-(1-methylethyl)-" "sabinenehydrate" "(z)-sabinene hydrate" "4-thujanol (natural)" "2-methyl-5-propan-2-ylbicyclo[3.1.0]hexan-2-ol" "2-methyl-5-(1-methylethyl)bicyclo(3.1.0)hexan-2-ol" "(1alpha,2alpha,5alpha)-2-methyl-5-(1-methylethyl)bicyclo(3.1.0)hexan-2-ol" );
gibbsFormation
{
    dHf_298   -251500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3130.0
    phase     gas;
}
