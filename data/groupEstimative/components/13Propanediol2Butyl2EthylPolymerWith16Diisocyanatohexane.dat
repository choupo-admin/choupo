/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-propanediol, 2-butyl-2-ethyl-, polymer with 1,6-diisocyanatohexane  (C17H32N2O4, CAS 169196-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Propanediol2Butyl2EthylPolymerWith16Diisocyanatohexane;
formula     C17H32N2O4;
CAS         169196-93-4;
InChIKey    CDCUAODLDXJEAT-UHFFFAOYSA-N;
MW          328.453;      // g/mol [origin=calculated method=formula-sum]
Tc          1107.48;      // K   [origin=predictive method=joback]
Pc          14.942;      // bar [origin=predictive method=joback]
omega       1.3314;      // -   [origin=predictive method=lee-kesler]
Tb          904.43;      // K   [origin=predictive method=joback]
HvapTb      104856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group C; count 1; } { group dCd; count 2; } { group OH; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butyl-2-ethyl-propane-1,3-diol;1,6-diisocyanatohexane" );
