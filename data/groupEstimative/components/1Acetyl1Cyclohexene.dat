/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-acetyl-1-cyclohexene  (C8H12O, CAS 932-66-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Acetyl1Cyclohexene;
formula     C8H12O;
CAS         932-66-1;
InChIKey    LTYLUDGDHUEBGX-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          682.17;      // K   [origin=predictive method=joback]
Pc          36.115;      // bar [origin=predictive method=joback]
omega       0.4165;      // -   [origin=predictive method=lee-kesler]
Tb          464.87;      // K   [origin=predictive method=joback]
HvapTb      41840.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.49 0.76892 -0.00044934 9.206e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(cyclohexen-1-yl)ethanone" "ethanone, 1-(1-cyclohexen-1-yl)-" "ketone, 1-cyclohexen-1-yl methyl" "1-(cyclohex-1-en-1-yl)ethanone" "methyl 1-cyclohexenyl ketone" "1-acetylcyclohexene" "cyclohex-1-enylmethylketone" "1-(1-cyclohexenyl)ethanone" "1-(1-cyclohexenyl)-ethanone" "ethanone, 1-(cyclohexenyl)-" "1-cyclohex-1-en-1-ylethanone" "1-cyclohexen-1-yl methyl ketone" );
gibbsFormation
{
    dHf_298   -200060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-59950.0
    phase     gas;
}
