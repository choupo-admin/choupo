/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(3-oxobutyl)phenyl butyrate  (C14H18O3, CAS 72727-70-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        43OxobutylPhenylButyrate;
formula     C14H18O3;
CAS         72727-70-9;
InChIKey    HFHMAFJEDGPVNB-UHFFFAOYSA-N;
MW          234.295;      // g/mol [origin=calculated method=formula-sum]
Tc          869.41;      // K   [origin=predictive method=joback]
Pc          21.081;      // bar [origin=predictive method=joback]
omega       0.8619;      // -   [origin=predictive method=lee-kesler]
Tb          663.67;      // K   [origin=predictive method=joback]
HvapTb      63849.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.324 1.11264 -0.00058866 8.986e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(3-oxidanylidenebutyl)phenyl] butanoate" "butanoic acid, 4-(3-oxobutyl)phenyl ester" "[4-(3-oxobutyl)phenyl] butanoate" "4-(4-(butyryloxy)phenyl)-2-butanone" "butanoic acid,4-(3-oxobutyl)phenyl ester" );
gibbsFormation
{
    dHf_298   -537090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     666.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-269510.0
    phase     gas;
}
