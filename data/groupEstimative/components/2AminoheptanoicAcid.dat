/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-aminoheptanoic acid  (C7H15NO2, CAS 1115-90-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AminoheptanoicAcid;
formula     C7H15NO2;
CAS         1115-90-8;
InChIKey    RDFMDVXONNIGBC-UHFFFAOYSA-N;
MW          145.202;      // g/mol [origin=calculated method=formula-sum]
Tc          777.82;      // K   [origin=predictive method=joback]
Pc          33.182;      // bar [origin=predictive method=joback]
omega       0.9001;      // -   [origin=predictive method=lee-kesler]
Tb          577.36;      // K   [origin=predictive method=joback]
HvapTb      58593.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.934 0.78742 -0.0004762 1.106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanylheptanoic acid" "2-aminoenanthic acid" "(+/-)-2-aminoheptanedioic acid" "2-amino-heptanoic acid" "n-amylglycine" "dl-homonorleucine" "alpha-aminoenanthic acid" "heptanoic acid, amino-" "(1)-2-aminoheptanoic acid" "alpha-dl-aminoheptanoic acid" "heptanoic acid, 2-amino-, dl-" "heptanoic acid, 2-amino-, (1)-" );
gibbsFormation
{
    dHf_298   -509570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-271840.0
    phase     gas;
}
