/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 6974  (C20H30O7, CAS 154869-43-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris6974;
formula     C20H30O7;
CAS         154869-43-9;
InChIKey    CZRTWOKSRMXXSJ-ROUUACIJSA-N;
MW          382.453;      // g/mol [origin=calculated method=formula-sum]
Tc          1227.15;      // K   [origin=predictive method=joback]
Pc          14.294;      // bar [origin=predictive method=joback]
omega       1.1319;      // -   [origin=predictive method=lee-kesler]
Tb          989.70;      // K   [origin=predictive method=joback]
HvapTb      93819.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.718 1.60794 -0.0003408 -2.1648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 2; } { group CH3CO; count 2; } { group CH2CO; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 9; } { group CH_ring; count 2; } { group CdO; count 2; } { group CdO_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,16s)-8,16-bis(2-oxidanylidenepropyl)-1,9-dioxacyclohexadecane-2,5,10-trione" "1,9-dioxacyclohexadecane-2,5,10-trione, 8,16-bis(2-oxopropyl)-, (8s-(8r*,16r*))-" "(8s,16s)-8,16-bis(2-oxopropyl)-1,9-dioxacyclohexadecane-2,5,10-trione" );
gibbsFormation
{
    dHf_298   -1456530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1058.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-939510.0
    phase     gas;
}
