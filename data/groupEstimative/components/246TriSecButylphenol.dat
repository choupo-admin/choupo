/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-tri-sec-butylphenol  (C18H30O, CAS 5892-47-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246TriSecButylphenol;
formula     C18H30O;
CAS         5892-47-7;
InChIKey    LAVMWOGIDKQCDK-UHFFFAOYSA-N;
MW          262.437;      // g/mol [origin=calculated method=formula-sum]
Tc          933.72;      // K   [origin=predictive method=joback]
Pc          16.365;      // bar [origin=predictive method=joback]
omega       0.8727;      // -   [origin=predictive method=lee-kesler]
Tb          727.38;      // K   [origin=predictive method=joback]
HvapTb      71112.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.747 1.68832 -0.00111848 3.103e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 3; } { group ACH; count 2; } { group ACCH; count 3; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-tri(butan-2-yl)phenol" "phenol, 2,4,6-tris(1-methylpropyl)-" );
standardThermochemistry
{
    dHf_298   -394410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     736.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31890.0
}
