/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethyloctyl acetate  (C12H24O2, CAS 20780-49-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37DimethyloctylAcetate;
formula     C12H24O2;
CAS         20780-49-8;
InChIKey    XFPXWDJICXBWRU-UHFFFAOYSA-N;
MW          200.322;      // g/mol [origin=calculated method=formula-sum]
Tc          704.95;      // K   [origin=predictive method=joback]
Pc          18.123;      // bar [origin=predictive method=joback]
omega       0.6707;      // -   [origin=predictive method=lee-kesler]
Tb          531.50;      // K   [origin=predictive method=joback]
HvapTb      48937.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.025 1.10088 -0.0005408 7.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyloctyl ethanoate" "1-octanol, 3,7-dimethyl-, acetate" "tetrahydrogeranyl acetate" "3,7-dimethyl-1-octanyl acetate" "dihydrocitronellyl acetate" "3,7-dimethyloctanyl acetate" "3,7-dimethyl-1-octyl acetate" "3,7-dimethyloctanyl-1-acetate" "3,7-dimethyl-1-octanol, acetate" "1-octanol, 3,7-dimethyl-, 1-acetate" );
standardThermochemistry
{
    dHf_298   -618850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     655.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-265090.0
}
