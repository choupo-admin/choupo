/*--------------------------------*- Choupo -*-----------------------*\
  Component: 15-carboxy-13-isopropylatis-13-ene-17,18-dioic acid  (C24H34O6, CAS 125-66-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Carboxy13Isopropylatis13Ene1718DioicAcid;
formula     C24H34O6;
CAS         125-66-6;
InChIKey    PXYRCOIAFZBLBN-UHFFFAOYSA-N;
MW          418.53;      // g/mol [origin=calculated method=formula-sum]
Tc          1488.02;      // K   [origin=predictive method=joback]
Pc          14.759;      // bar [origin=predictive method=joback]
omega       1.3182;      // -   [origin=predictive method=lee-kesler]
Tb          1215.03;      // K   [origin=predictive method=joback]
HvapTb      116727.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-332.4 3.66158 -0.00349444 1.396e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 6; } { group C; count 3; } { group CH=C; count 1; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 5; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COOH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(9beta,10alpha,15beta)-15-carboxy-13-(propan-2-yl)atis-13-ene-17,18-dioic acid" "17,19-dinoratis-15-ene-4,13,14-tricarboxylic acid, 16-(1-methylethyl)-, (4.alpha.,8.alpha.,12.alpha.,13r,14s)-" );
standardThermochemistry
{
    dHf_298   -1317550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     954.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-715350.0
}
