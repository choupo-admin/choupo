/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3'-bicylopropenyl  (C6H6, CAS 62595-44-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Bicylopropenyl;
formula     C6H6;
CAS         62595-44-2;
InChIKey    HVWGZGIZCKXHJV-UHFFFAOYSA-N;
MW          78.114;      // g/mol [origin=calculated method=formula-sum]
Tc          548.30;      // K   [origin=predictive method=joback]
Pc          46.785;      // bar [origin=predictive method=joback]
omega       0.2332;      // -   [origin=predictive method=lee-kesler]
Tb          348.68;      // K   [origin=predictive method=joback]
HvapTb      29360.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.49 0.7636 -0.00071756 2.672e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cycloprop-2-en-1-ylcyclopropene" );
standardThermochemistry
{
    dHf_298   93990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     134.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=181060.0
}
