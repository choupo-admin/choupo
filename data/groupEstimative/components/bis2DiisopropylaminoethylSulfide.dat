/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-diisopropylaminoethyl) sulfide  (C16H36N2S, CAS 110501-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2DiisopropylaminoethylSulfide;
formula     C16H36N2S;
CAS         110501-56-9;
InChIKey    VRSFIFVYZVUBLG-UHFFFAOYSA-N;
MW          288.538;      // g/mol [origin=calculated method=formula-sum]
Tc          839.40;      // K   [origin=predictive method=joback]
Pc          13.626;      // bar [origin=predictive method=joback]
omega       0.7932;      // -   [origin=predictive method=lee-kesler]
Tb          657.58;      // K   [origin=predictive method=joback]
HvapTb      60561.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.166 1.78975 -0.0010444 2.244e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 1; } { group CH; count 4; } { group CH2N; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 4; } { group CH; count 4; } { group N; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[2-[2-[di(propan-2-yl)amino]ethylsulfanyl]ethyl]-n-propan-2-yl-propan-2-amine" "sulfane, bis(2-diisopropylaminoethyl)-" "2-propanamine,n,n'-(thiodi-2,1-ethanediyl)bis[n-(1-methylethyl)- (9ci)" "bis[2-(diisopropylamino)ethyl]sulfide" "n-[2-[2-[di(propan-2-yl)amino]ethylsulfanyl]ethyl]-n-propan-2-ylpropan-2-amine" );
gibbsFormation
{
    dHf_298   -217760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     834.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=328760.0
    phase     gas;
}
