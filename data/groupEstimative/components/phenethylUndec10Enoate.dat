/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenethyl undec-10-enoate  (C19H28O2, CAS 72727-63-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenethylUndec10Enoate;
formula     C19H28O2;
CAS         72727-63-0;
InChIKey    BXLGKICTKQVKQF-UHFFFAOYSA-N;
MW          288.431;      // g/mol [origin=calculated method=formula-sum]
Tc          907.03;      // K   [origin=predictive method=joback]
Pc          14.091;      // bar [origin=predictive method=joback]
omega       0.8878;      // -   [origin=predictive method=lee-kesler]
Tb          715.90;      // K   [origin=predictive method=joback]
HvapTb      66901.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.87 1.6551 -0.0009693 2.007e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2=CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylethyl undec-10-enoate" "10-undecenoic acid, 2-phenylethyl ester" "10-undecenoic acid,2-phenylethyl ester" "10-undecenoicacid, phenethyl ester (6ci)" );
gibbsFormation
{
    dHf_298   -390810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     836.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1020.0
    phase     gas;
}
