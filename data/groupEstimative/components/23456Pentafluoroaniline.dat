/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,5,6-pentafluoroaniline  (C6H2F5N, CAS 771-60-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23456Pentafluoroaniline;
formula     C6H2F5N;
CAS         771-60-8;
InChIKey    NOXLGCOSAFGMDV-UHFFFAOYSA-N;
MW          183.079;      // g/mol [origin=calculated method=formula-sum]
Tc          638.40;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       0.6654;      // -   [origin=predictive method=lee-kesler]
Tb          457.34;      // K   [origin=predictive method=joback]
HvapTb      41092.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.97 0.3183 -0.000124 2e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACNH2; count 1; } { group ACF; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group F; count 5; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5,6-pentakis(fluoranyl)aniline" "pentafluoroaniline" "pentafluorophenylamine" "benzenamine, 2,3,4,5,6-pentafluoro-" "2,3,4,5,6-pentafluorobenzenamine" "aminopentafluorobenzene" "aniline, 2,3,4,5,6-pentafluoro-" "2,3,4,5,6-pentafluorophenylamine" "perfluoroaniline" "pentafluoroaniline 99%" "2,4,5,6-pentafluoroaniline" "aniline,3,4,5,6-pentafluoro-" );
gibbsFormation
{
    dHf_298   -934750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-843700.0
    phase     gas;
}
