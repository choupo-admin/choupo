/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyltrifluoroacetamide  (C3H4F3NO, CAS 815-06-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethyltrifluoroacetamide;
formula     C3H4F3NO;
CAS         815-06-5;
InChIKey    IQNHBUQSOSYAJU-UHFFFAOYSA-N;
MW          127.065;      // g/mol [origin=calculated method=formula-sum]
Tc          534.35;      // K   [origin=predictive method=joback]
Pc          41.839;      // bar [origin=predictive method=joback]
omega       0.5111;      // -   [origin=predictive method=lee-kesler]
Tb          366.86;      // K   [origin=predictive method=joback]
HvapTb      31707.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.11 0.49822 -0.0003903 1.1466e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CF3; count 1; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group F; count 3; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(fluoranyl)-n-methyl-ethanamide" "2,2,2-trifluoro-n-methylacetamide" "n-methyl-2,2,2-trifluoroacetamide" "2,2,2-trifluoro-n-methyl-acetamide" "acetamide, 2,2,2-trifluoro-n-methyl-" "acetamide,2,2,2-trifluoro-n-methyl-" "n-methyl-2,2,2-trifluoroacetamide 98%" "n-methyltrifluoroacetamide;2,2,2-trifluoro-n-methylacetamide;" );
standardThermochemistry
{
    dHf_298   -761440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-646740.0
}
