/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-thiacyclopentane  (C6H12S, CAS 5161-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DimethylThiacyclopentane;
formula     C6H12S;
CAS         5161-75-1;
InChIKey    XUZUHHOTUSNHDJ-UHFFFAOYSA-N;
MW          116.222;      // g/mol [origin=calculated method=formula-sum]
Tc          623.49;      // K   [origin=predictive method=joback]
Pc          40.312;      // bar [origin=predictive method=joback]
omega       0.2187;      // -   [origin=predictive method=lee-kesler]
Tb          400.23;      // K   [origin=predictive method=joback]
HvapTb      33868.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.22 1.01185 -0.0009813 4.065e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylthiolane" "thiophene, tetrahydro-2,2-dimethyl-" );
gibbsFormation
{
    dHf_298   -46190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70560.0
    phase     gas;
}
