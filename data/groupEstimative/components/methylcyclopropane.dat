/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylcyclopropane  (C4H8, CAS 594-11-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylcyclopropane;
formula     C4H8;
CAS         594-11-6;
InChIKey    VNXBKJFUJUWOCW-UHFFFAOYSA-N;
MW          56.108;      // g/mol [origin=calculated method=formula-sum]
Tc          475.41;      // K   [origin=predictive method=joback]
Pc          46.151;      // bar [origin=predictive method=joback]
omega       0.1815;      // -   [origin=predictive method=lee-kesler]
Tb          297.86;      // K   [origin=predictive method=joback]
HvapTb      24411.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.99 0.53472 -0.000414 1.357e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropane, methyl-" "1-methylcyclopropane" "cyclopropylmethane;methylcyclopropane" );
standardThermochemistry
{
    dHf_298   -53090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     221.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=43550.0
}
