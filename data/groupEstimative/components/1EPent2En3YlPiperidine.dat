/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[(e)-pent-2-en-3-yl]piperidine  (C10H19N, CAS 21086-43-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1EPent2En3YlPiperidine;
formula     C10H19N;
CAS         21086-43-1;
InChIKey    CGFVAIHRGVVSOS-UHFFFAOYSA-N;
MW          153.269;      // g/mol [origin=calculated method=formula-sum]
Tc          665.43;      // K   [origin=predictive method=joback]
Pc          27.412;      // bar [origin=predictive method=joback]
omega       0.4218;      // -   [origin=predictive method=lee-kesler]
Tb          464.83;      // K   [origin=predictive method=joback]
HvapTb      40501.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.189 1.25584 -0.0009017 2.621e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH=C; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pent-2-en-3-ylpiperidine" );
standardThermochemistry
{
    dHf_298   6050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     542.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=260030.0
}
