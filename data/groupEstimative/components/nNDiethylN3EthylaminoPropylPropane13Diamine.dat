/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-diethyl-n-(3-(ethylamino)propyl)propane-1,3-diamine  (C12H29N3, CAS 67952-95-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethylN3EthylaminoPropylPropane13Diamine;
formula     C12H29N3;
CAS         67952-95-8;
InChIKey    WGMLAJNLNAEBAH-UHFFFAOYSA-N;
MW          215.385;      // g/mol [origin=calculated method=formula-sum]
Tc          753.36;      // K   [origin=predictive method=joback]
Pc          18.170;      // bar [origin=predictive method=joback]
omega       0.9472;      // -   [origin=predictive method=lee-kesler]
Tb          586.94;      // K   [origin=predictive method=joback]
HvapTb      57221.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.131 1.42016 -0.0008388 1.9e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH2NH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group NH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-diethyl-n'-[3-(ethylamino)propyl]propane-1,3-diamine" "n,n'-diethyl-n-[3-(ethylamino)propyl]propane-1,3-diamine" "1,3-propanediamine, n,n'-diethyl-n-(3-(ethylamino)propyl)-" "1,3-propanediamine, n,n'-diethyl-n-[3-(ethylamino)propyl]-" "1,3-propanediamine, n1,n3-diethyl-n1-(3-(ethylamino)propyl)-" "1,3-propanediamine, n1,n3-diethyl-n1-[3-(ethylamino)propyl]-" );
gibbsFormation
{
    dHf_298   -116540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     720.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=339720.0
    phase     gas;
}
