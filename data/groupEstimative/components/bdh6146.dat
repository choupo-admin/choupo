name        bdh6146;
formula     C21H23F3O2;
CAS         2061-56-5;
InChIKey    SZQHIOPVLPMIPS-ZWQJFZRQSA-N;
MW          364.407;      // g/mol [origin=calculated method=formula-sum]
Tc          1144.82;      // K   [origin=predictive method=joback]
Pc          21.256;      // bar [origin=predictive method=joback]
omega       1.2535;      // -   [origin=predictive method=lee-kesler]
Tb          908.02;      // K   [origin=predictive method=joback]
HvapTb      90539.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-277.15 3.02472 -0.00302058 1.22758e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 2; } { group C; count 2; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group C_C; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group tC; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 3; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(17s)-13-methyl-17-[3,3,3-tris(fluoranyl)prop-1-ynyl]-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthrene-3,17-diol" "estra-1,3,5(10)-triene-3,17-beta-diol, 17-(3,3,3-trifluoro-1-propynyl)-" "estra-1,3,5(10)-trien-3,17-diol, 3-methoxy-17-(3,3,3-trifluoro-1-propynyl)-, (17-beta)-" "(17s)-13-methyl-17-(3,3,3-trifluoroprop-1-ynyl)-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthrene-3,17-diol" );
