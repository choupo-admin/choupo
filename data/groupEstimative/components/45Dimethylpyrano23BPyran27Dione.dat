/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,5-dimethylpyrano[2,3-b]pyran-2,7-dione  (C10H8O4, CAS 37831-60-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        45Dimethylpyrano23BPyran27Dione;
formula     C10H8O4;
CAS         37831-60-0;
InChIKey    HJFMTEKPRKTJLL-UHFFFAOYSA-N;
MW          192.17;      // g/mol [origin=calculated method=formula-sum]
Tc          795.06;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.7975;      // -   [origin=predictive method=lee-kesler]
Tb          585.06;      // K   [origin=predictive method=joback]
HvapTb      56636.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.79 0.79304 -0.00057588 1.616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 2; } { group C=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,5-dimethyl-2h,7h-pyrano-[2,3-b]-pyran-2,7-dione" );
gibbsFormation
{
    dHf_298   -570550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-399140.0
    phase     gas;
}
