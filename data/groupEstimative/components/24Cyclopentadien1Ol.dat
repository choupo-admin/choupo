/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-cyclopentadien-1-ol  (C5H6O, CAS 80156-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Cyclopentadien1Ol;
formula     C5H6O;
CAS         80156-16-7;
InChIKey    GRZIHXUWTOPZRY-UHFFFAOYSA-N;
MW          82.102;      // g/mol [origin=calculated method=formula-sum]
Tc          613.04;      // K   [origin=predictive method=joback]
Pc          54.546;      // bar [origin=predictive method=joback]
omega       0.6034;      // -   [origin=predictive method=lee-kesler]
Tb          419.78;      // K   [origin=predictive method=joback]
HvapTb      44244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.29 0.5325 -0.00038056 1.06e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group dCH_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopenta-2,4-dien-1-ol" );
standardThermochemistry
{
    dHf_298   -122720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     276.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49130.0
}
