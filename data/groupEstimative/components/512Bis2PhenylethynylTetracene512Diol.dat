/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,12-bis(2-phenylethynyl)tetracene-5,12-diol  (C34H22O2, CAS 31559-43-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        512Bis2PhenylethynylTetracene512Diol;
formula     C34H22O2;
CAS         31559-43-0;
InChIKey    YMKQDNKFEZLLTK-UHFFFAOYSA-N;
MW          462.548;      // g/mol [origin=calculated method=formula-sum]
Tc          1617.67;      // K   [origin=predictive method=joback]
Pc          19.036;      // bar [origin=predictive method=joback]
omega       1.5257;      // -   [origin=predictive method=lee-kesler]
Tb          1318.80;      // K   [origin=predictive method=joback]
HvapTb      138800.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-245.65 3.2222 -0.00303912 1.17636e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 2; } { group ACH; count 20; } { group AC; count 8; } { group OH; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 4; } { group C_ring; count 2; } { group dCH_ring; count 20; } { group dC_ring; count 8; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,12-bis(phenylethynyl)-5,12-dihydrotetracene-5,12-diol" "5,12-naphthacenediol, 5,12-dihydro-5,12-bis(2-phenylethynyl)-" "5,12-naphthacenediol, 5,12-dihydro-5,12-bis(phenylethynyl)-" "5,12-dihydro-5,12-bis(phenylethynyl)naphthacene-5,12-diol" "5,12-naphthacenediol,5,12-dihydro-5,12-bis(2-phenylethynyl)-" "5,12-naphthacenediol,5,12-dihydro-5,12-bis(phenylethynyl)- (8ci,9ci); 5,12-dihydroxy-5,12-bis(phenylethynyl)-5,12-dihydronaphthacene" );
gibbsFormation
{
    dHf_298   686930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     959.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=948920.0
    phase     gas;
}
