/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenethylamine, n,n-dibutyl-  (C16H27N, CAS 5779-51-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenethylamineNNDibutyl;
formula     C16H27N;
CAS         5779-51-1;
InChIKey    LEHSOUZQZPUDEC-UHFFFAOYSA-N;
MW          233.399;      // g/mol [origin=calculated method=formula-sum]
Tc          792.15;      // K   [origin=predictive method=joback]
Pc          17.005;      // bar [origin=predictive method=joback]
omega       0.7269;      // -   [origin=predictive method=lee-kesler]
Tb          604.80;      // K   [origin=predictive method=joback]
HvapTb      55529.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.252 1.56884 -0.0009904 2.421e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-butyl-n-(2-phenylethyl)butan-1-amine" "n,n-dibutylphenethylamine" "dibutyl-phenethyl-amine" "benzeneethanamine,n,n-dibutyl-" "n-butyl-n-phenethylbutan-1-amine" "2-phenylethylamine, n,n-dibutyl-" );
standardThermochemistry
{
    dHf_298   -69510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     688.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=307030.0
}
