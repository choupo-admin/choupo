/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl prop-2-enoate;2-methylidenebutanedioic acid;methyl prop-2-enoate;2-methylprop-2-enoic acid  (C18H26O10, CAS 67785-35-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylProp2Enoate2MethylidenebutanedioicAcidMethylProp2Enoate;
formula     C18H26O10;
CAS         67785-35-7;
InChIKey    LJJLDOJWMWOADC-UHFFFAOYSA-N;
MW          402.396;      // g/mol [origin=calculated method=formula-sum]
Tc          1415.28;      // K   [origin=predictive method=joback]
Pc          13.175;      // bar [origin=predictive method=joback]
omega       1.2090;      // -   [origin=predictive method=lee-kesler]
Tb          1155.09;      // K   [origin=predictive method=joback]
HvapTb      120330.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (162.252 1.05786 0.0001642 -4.056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH2=CH; count 2; } { group CH2=C; count 2; } { group COOH; count 3; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH2; count 4; } { group dCH; count 2; } { group dC; count 2; } { group COOH; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanedioic acid, 2-methylene-, polymer with ethyl 2-propenoate, methyl 2-propenoate and 2-methyl-2-propenoic acid" "butanedioic acid, methylene-, polymer with ethyl 2-propenoate, methyl 2-propenoate and 2-methyl-2-propenoic acid" "ethyl prop-2-enoate; 2-methylidenebutanedioic acid; methyl prop-2-enoate; 2-methylprop-2-enoic acid" );
standardThermochemistry
{
    dHf_298   -1952940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1415.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1531810.0
}
