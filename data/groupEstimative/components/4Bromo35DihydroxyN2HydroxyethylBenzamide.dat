/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-3,5-dihydroxy-n-(2-hydroxyethyl)benzamide  (C9H10BrNO4, CAS 46427-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo35DihydroxyN2HydroxyethylBenzamide;
formula     C9H10BrNO4;
CAS         46427-20-7;
InChIKey    HLMLWNJLJRZNGJ-UHFFFAOYSA-N;
MW          276.086;      // g/mol [origin=calculated method=formula-sum]
Tc          1091.67;      // K   [origin=predictive method=joback]
Pc          65.991;      // bar [origin=predictive method=joback]
omega       2.0328;      // -   [origin=predictive method=lee-kesler]
Tb          860.80;      // K   [origin=predictive method=joback]
HvapTb      100890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.108 1.15 -0.00107438 4.0806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 2; } { group AC; count 2; } { group OH; count 1; } { group ACOH; count 2; } { group Br; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group OH; count 1; } { group OH_phenol; count 2; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-n-(2-hydroxyethyl)-3,5-bis(oxidanyl)benzamide" "benzamide, 4-bromo-3,5-dihydroxy-n-(2-hydroxyethyl)-" "benzamide,4-bromo-3,5-dihydroxy-n-(2-hydroxyethyl)-" );
gibbsFormation
{
    dHf_298   -543660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     616.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-343590.0
    phase     gas;
}
