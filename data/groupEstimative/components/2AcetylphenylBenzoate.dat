/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetylphenyl benzoate  (C15H12O3, CAS 4010-33-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AcetylphenylBenzoate;
formula     C15H12O3;
CAS         4010-33-7;
InChIKey    UEVPPUDQJRWOLT-UHFFFAOYSA-N;
MW          240.258;      // g/mol [origin=calculated method=formula-sum]
Tc          955.74;      // K   [origin=predictive method=joback]
Pc          26.488;      // bar [origin=predictive method=joback]
omega       0.8152;      // -   [origin=predictive method=lee-kesler]
Tb          713.23;      // K   [origin=predictive method=joback]
HvapTb      68351.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.49 1.12872 -0.00067426 1.2726e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-ethanoylphenyl) benzoate" "o-(benzoyloxy)acetophenone" "(2-acetylphenyl) benzoate" "ethanone, 1-[2-(benzoyloxy)phenyl]-" "ethanone, 1-(2-(benzoyloxy)phenyl)-" "o-acetylphenyl benzoate" "o-benzoyloxyacetophenone" );
gibbsFormation
{
    dHf_298   -321200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-148680.0
    phase     gas;
}
