/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1-cyclohexylundecan-5-yl)butanedioic acid  (C21H38O4, CAS 67816-12-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        21Cyclohexylundecan5YlButanedioicAcid;
formula     C21H38O4;
CAS         67816-12-0;
InChIKey    WYMULJWSHAGNEH-UHFFFAOYSA-N;
MW          354.531;      // g/mol [origin=calculated method=formula-sum]
Tc          1212.78;      // K   [origin=predictive method=joback]
Pc          12.442;      // bar [origin=predictive method=joback]
omega       1.1565;      // -   [origin=predictive method=lee-kesler]
Tb          989.77;      // K   [origin=predictive method=joback]
HvapTb      96321.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.97 2.23432 -0.0013512 3.033e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 3; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2(or 3)-carboxy-4-hexylcyclohexaneoctanoic acid" "cyclohexaneoctanoic acid, 2(or 3)-carboxy-4-hexyl-" "5(6)-carboxy-4-hexylcyclohexane-1-octanoic acid" );
gibbsFormation
{
    dHf_298   -1133550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1030.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-542310.0
    phase     gas;
}
