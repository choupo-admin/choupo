/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-benzylidene-2,4-pentanedione  (C12H12O2, CAS 4335-90-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Benzylidene24Pentanedione;
formula     C12H12O2;
CAS         4335-90-4;
InChIKey    NYRGMNMVISROGJ-UHFFFAOYSA-N;
MW          188.226;      // g/mol [origin=calculated method=formula-sum]
Tc          841.78;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       0.6843;      // -   [origin=predictive method=lee-kesler]
Tb          612.62;      // K   [origin=predictive method=joback]
HvapTb      58112.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.08 1.02884 -0.0007089 1.8822e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(phenylmethylidene)pentane-2,4-dione" "benzylidene acetylacetone" "benzalacetylacetone" "3-benzylideneacetylacetone" "2,4-pentanedione, 3-(phenylmethylene)-" "1,1-diacetyl-2-phenylethylene" "1vyv1&u1r" "2-acetyl-1-phenyl but-1-en-3-one" "3-(phenylmethylene)pentane-2,4-dione" "3-benzylidene acetylacetone" "(2,2-diacetylvinyl)benzene" "2,4-pentanedione, 3-benzylidene-" );
gibbsFormation
{
    dHf_298   -172210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23600.0
    phase     gas;
}
