/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butylcyclohexanone  (C10H18O, CAS 1126-18-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butylcyclohexanone;
formula     C10H18O;
CAS         1126-18-7;
InChIKey    POYYYXPQBFPUKS-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          729.33;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.4720;      // -   [origin=predictive method=lee-kesler]
Tb          515.77;      // K   [origin=predictive method=joback]
HvapTb      42530.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.377 0.90762 -0.0003572 4.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butylcyclohexan-1-one" "cyclohexanone, 2-butyl-" "2-n-butylcyclohexanone" "2-butyl-cyclohexan-1-one" );
standardThermochemistry
{
    dHf_298   -333110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64820.0
}
