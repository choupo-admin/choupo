/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diiodo-2,2-dimethylpropane  (C5H10I2, CAS 2443-89-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diiodo22Dimethylpropane;
formula     C5H10I2;
CAS         2443-89-2;
InChIKey    WETJKCOBPFKLBI-UHFFFAOYSA-N;
MW          323.935;      // g/mol [origin=calculated method=formula-sum]
Tc          759.35;      // K   [origin=predictive method=joback]
Pc          33.999;      // bar [origin=predictive method=joback]
omega       0.2278;      // -   [origin=predictive method=lee-kesler]
Tb          496.61;      // K   [origin=predictive method=joback]
HvapTb      43786.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.43 0.68856 -0.000586 1.995e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(iodanyl)-2,2-dimethyl-propane" "propane,1,1-diiodo-2,2-dimethyl-" );
gibbsFormation
{
    dHf_298   -6820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107860.0
    phase     gas;
}
