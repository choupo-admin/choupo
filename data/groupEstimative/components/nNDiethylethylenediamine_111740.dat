/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-diethylethylenediamine  (C6H16N2, CAS 111-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethylethylenediamine;
formula     C6H16N2;
CAS         111-74-0;
InChIKey    CJKRXEBLWJVYJD-UHFFFAOYSA-N;
MW          116.208;      // g/mol [origin=calculated method=formula-sum]
Tc          611.84;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.6161;      // -   [origin=predictive method=lee-kesler]
Tb          437.22;      // K   [origin=predictive method=joback]
HvapTb      41822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.986 0.72624 -0.0003998 8.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-diethylethane-1,2-diamine" "1,2-ethanediamine, n,n'-diethyl-" "1,2-bis(ethylamino)ethane" "n,n'-diethylethan-1,2-diamin" "ethylenediamine, n,n'-diethyl-" "1,2-ethanediamine, n1,n2-diethyl-" "ethyl[2-(ethylamino)ethyl]amine" "n,n'-ethylenediethyldiamine" "1,2-ethanediamine,n1,n2-diethyl-" "1,2-ethanediamine,n,n'-diethyl- (9ci);ethylenediamine, n,n'-diethyl- (6ci,7ci,8ci);n,n'-diethyl-1,2-diaminoethane;n,n'-diethyl-1,2-ethanediamine;n,n'-diethyldiaminoethane;n,n'-diethylethylenediamine;" );
gibbsFormation
{
    dHf_298   -60230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=178420.0
    phase     gas;
}
