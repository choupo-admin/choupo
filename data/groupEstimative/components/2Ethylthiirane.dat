/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylthiirane  (C4H8S, CAS 3195-86-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethylthiirane;
formula     C4H8S;
CAS         3195-86-6;
InChIKey    ZXKFFOMHVCMTEV-UHFFFAOYSA-N;
MW          88.168;      // g/mol [origin=calculated method=formula-sum]
Tc          543.67;      // K   [origin=predictive method=joback]
Pc          45.777;      // bar [origin=predictive method=joback]
omega       0.2262;      // -   [origin=predictive method=lee-kesler]
Tb          345.69;      // K   [origin=predictive method=joback]
HvapTb      30223.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.169 0.54913 -0.0004327 1.445e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thiirane, 2-ethyl-" "butane,1,2-epithio- (7ci,8ci); thiirane, ethyl- (9ci); 1,2-epithiobutane;2-ethylthiirane; ethylthiirane" );
standardThermochemistry
{
    dHf_298   -7830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     271.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83410.0
}
