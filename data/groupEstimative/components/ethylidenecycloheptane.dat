/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylidenecycloheptane  (C9H16, CAS 10494-87-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylidenecycloheptane;
formula     C9H16;
CAS         10494-87-8;
InChIKey    MLFGNFYXTYMGAT-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          656.22;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.2974;      // -   [origin=predictive method=lee-kesler]
Tb          440.65;      // K   [origin=predictive method=joback]
HvapTb      37325.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.86 0.92032 -0.0005243 1.047e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group CH2_ring; count 6; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl idenecycloheptane" "cycloheptane,ethylidene-" );
gibbsFormation
{
    dHf_298   -84560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90420.0
    phase     gas;
}
