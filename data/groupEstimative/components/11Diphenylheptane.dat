/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diphenylheptane  (C19H24, CAS 1530-05-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diphenylheptane;
formula     C19H24;
CAS         1530-05-8;
InChIKey    MZLKNWMNBXHXMA-UHFFFAOYSA-N;
MW          252.401;      // g/mol [origin=calculated method=formula-sum]
Tc          909.23;      // K   [origin=predictive method=joback]
Pc          17.773;      // bar [origin=predictive method=joback]
omega       0.6774;      // -   [origin=predictive method=lee-kesler]
Tb          687.24;      // K   [origin=predictive method=joback]
HvapTb      62052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.875 1.65692 -0.0010754 2.654e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylheptylbenzene" "heptane, 1,1-diphenyl-" "heptane,1-diphenyl-" "benzene,1,1'-heptylidenebis-" );
standardThermochemistry
{
    dHf_298   32290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     673.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=331480.0
}
