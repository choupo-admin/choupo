/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylpyruvic acid  (C9H8O3, CAS 156-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylpyruvicAcid;
formula     C9H8O3;
CAS         156-06-9;
InChIKey    BTNMPGBKDVTSJY-UHFFFAOYSA-N;
MW          164.16;      // g/mol [origin=calculated method=formula-sum]
Tc          862.80;      // K   [origin=predictive method=joback]
Pc          39.111;      // bar [origin=predictive method=joback]
omega       0.8800;      // -   [origin=predictive method=lee-kesler]
Tb          631.58;      // K   [origin=predictive method=joback]
HvapTb      61814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.239 0.8027 -0.0005509 1.4036e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylidene-3-phenyl-propanoic acid" "phenylpyruvate" "3-phenylpyruvic acid" "2-oxo-3-phenylpropanoic acid" "keto-phenylpyruvate" "b-phenylpyruvic acid" "beta-phenylpyruvic acid" "pyruvic acid, phenyl-" "3-phenyl-2-oxopropanoate" "benzenepropanoic acid, .alpha.-oxo-" "alpha-ketohydrocinnamic acid" "3-phenyl-2-oxopropanoic acid" );
standardThermochemistry
{
    dHf_298   -455410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-335520.0
}
