/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrakis(trimethylsiloxy)silane  (C12H36O4Si5, CAS 3555-47-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H36O4Si5 (delta Si+5; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetrakisTrimethylsiloxySilane;
formula     C12H36O4Si5;
CAS         3555-47-3;
InChIKey    VNRWTCZXQWOWIG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          384.841;      // g/mol [origin=calculated method=formula-sum]
Tc          754.84;      // K   [origin=predictive method=joback]
Pc          10.835;      // bar [origin=predictive method=joback]
omega       0.3807;      // -   [origin=predictive method=lee-kesler]
Tb          570.84;      // K   [origin=predictive method=joback]
HvapTb      53416.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (298.07 -0.13976 0.001889 -1.1736e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group Si; count 1; } { group SiO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrakis(trimethylsilyl) silicate" "tetrakis(trimethylsilyloxy)silane" "trisiloxane, 1,1,1,5,5,5-hexamethyl-3,3-bis[(trimethylsilyl)oxy]-" "trisiloxane, 1,1,1,5,5,5-hexamethyl-3,3-bis((trimethylsilyl)oxy)-" "1,1,5,5,5-hexamethyl-3,3-bis((trimethylsilyl)oxy)trisiloxane" "trisiloxane, 1,1,1,5,5,5-hexamethyl-3,3-bis(trimethylsiloxy)-" "trisiloxane,1,1,1,5,5,5-hexamethyl-3,3-bis(trimethylsiloxy)- (6ci,7ci,8ci);silicic acid, tetrakis(trimethylsilyl)ester (6ci);silanol, trimethyl-, tetraester with silicic acid (h4sio4);silicic acid (h4sio4), tetrakis(trimethylsilyl) ester;tetrakis(trimethylsilyl) silicate;silicic acid (h4sio4), tetrakis(trimethylsilyl) ester;tetrakis(trimethylsilyl) orthosilicate;trisiloxane, 1,1,1,5,5,5-hexamethyl-3,3-bis((trimethylsilyl)oxy)-;trisiloxane, 1,1,1,5,5,5-hexamethyl-3,3-bis(trimethylsiloxy)-;" );
gibbsFormation
{
    dHf_298   -1377990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1300.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-893640.0
    phase     gas;
}
