/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzophenone dimethylketal  (C15H16O2, CAS 2235-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzophenoneDimethylketal;
formula     C15H16O2;
CAS         2235-01-0;
InChIKey    NYRVXYOKUZSUDA-UHFFFAOYSA-N;
MW          228.291;      // g/mol [origin=calculated method=formula-sum]
Tc          879.98;      // K   [origin=predictive method=joback]
Pc          24.727;      // bar [origin=predictive method=joback]
omega       0.5767;      // -   [origin=predictive method=lee-kesler]
Tb          637.77;      // K   [origin=predictive method=joback]
HvapTb      57060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.03 1.27044 -0.0008044 1.806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[dimethoxy(phenyl)methyl]benzene" "dimethoxydiphenylmethane" "1,1'-(dimethoxymethylene)dibenzene" "benzophenone dimethyl ketal" "benzene, 1,1'-(dimethoxymethylene)bis-" "1,1'-(dimethoxymethylene)bisbenzene" "benzene,1'-(dimethoxymethylene)bis-" "1,1'-(dimethoxymethanediyl)dibenzene" "1,1'-(dimethoxymethylene)bisbenzene;" "benzene,1,1'-(dimethoxymethylene)bis-" );
gibbsFormation
{
    dHf_298   -153060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93080.0
    phase     gas;
}
