/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanone,2-methyl-5,5-diphenyl-  (C19H20O, CAS 50592-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanone2Methyl55Diphenyl;
formula     C19H20O;
CAS         50592-49-9;
InChIKey    IEEGJJCOUZRVOF-UHFFFAOYSA-N;
MW          264.368;      // g/mol [origin=calculated method=formula-sum]
Tc          1046.02;      // K   [origin=predictive method=joback]
Pc          22.083;      // bar [origin=predictive method=joback]
omega       0.6220;      // -   [origin=predictive method=lee-kesler]
Tb          770.62;      // K   [origin=predictive method=joback]
HvapTb      65656.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-155.42 1.87022 -0.0013864 4.323e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-5,5-diphenyl-cyclohexan-1-one" "2-methyl-5,5-diphenylcyclohexan-1-one" "cyclohexanone, 2-methyl-5,5-diphenyl-" );
gibbsFormation
{
    dHf_298   -50910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222580.0
    phase     gas;
}
