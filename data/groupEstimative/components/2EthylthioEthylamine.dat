/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(ethylthio)ethylamine  (C4H11NS, CAS 36489-03-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylthioEthylamine;
formula     C4H11NS;
CAS         36489-03-9;
InChIKey    HJCTVUWPHAZTLI-UHFFFAOYSA-N;
MW          105.199;      // g/mol [origin=calculated method=formula-sum]
Tc          639.87;      // K   [origin=predictive method=joback]
Pc          42.831;      // bar [origin=predictive method=joback]
omega       0.4435;      // -   [origin=predictive method=lee-kesler]
Tb          432.43;      // K   [origin=predictive method=joback]
HvapTb      41956.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.343 0.44011 -0.000197 1.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2NH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylsulfanylethanamine" "2-[ethylthio]ethylamonium" "2-aminoethylethyl sulfide" "2-ethylthioethylamine" "2-(ethylthio)ethanamine" "2-(ethylsulfanyl)ethanamine" "2-aminoethyl ethyl sulphide" "ethanamine,2-(ethylthio)-" "2-(ethylsulphanyl)ethylamine" "ethanamine, 2-(ethylthio)-" "2-(ethylsulfanyl)ethan-1-amine" "2-(ethylsulfanyl)ethan-1-amine hydrochloride" );
gibbsFormation
{
    dHf_298   -50230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82370.0
    phase     gas;
}
