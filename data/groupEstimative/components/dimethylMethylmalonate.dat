/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl methylmalonate  (C6H10O4, CAS 609-02-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylMethylmalonate;
formula     C6H10O4;
CAS         609-02-9;
InChIKey    LRBPFPZTIZSOGG-UHFFFAOYSA-N;
MW          146.142;      // g/mol [origin=calculated method=formula-sum]
Tc          638.32;      // K   [origin=predictive method=joback]
Pc          31.704;      // bar [origin=predictive method=joback]
omega       0.5695;      // -   [origin=predictive method=lee-kesler]
Tb          452.88;      // K   [origin=predictive method=joback]
HvapTb      43376.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.57 0.47016 -0.0001166 -5.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-methylpropanedioate" "dimethyl 2-methylmalonate" "propanedioic acid, methyl-, dimethyl ester" "malonic acid, methyl-, dimethyl ester" "propanedioic acid, 2-methyl-, 1,3-dimethyl ester" "m322" "malonic acid, methyl-, dimethyl ester (8ci)" );
gibbsFormation
{
    dHf_298   -807010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-623540.0
    phase     gas;
}
