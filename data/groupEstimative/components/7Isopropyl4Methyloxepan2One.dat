/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-isopropyl-4-methyloxepan-2-one  (C10H18O2, CAS 499-54-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Isopropyl4Methyloxepan2One;
formula     C10H18O2;
CAS         499-54-7;
InChIKey    GGAXPLCKKANQED-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          696.20;      // K   [origin=predictive method=joback]
Pc          24.556;      // bar [origin=predictive method=joback]
omega       0.4832;      // -   [origin=predictive method=lee-kesler]
Tb          496.79;      // K   [origin=predictive method=joback]
HvapTb      44821.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.02 1.01016 -0.0005008 6.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-7-propan-2-yl-oxepan-2-one" "menthone lactone" "4-methyl-7-isopropyl-2-oxepanone" "3-methyl-6-isopropyl-6-hexanolide" "3,7-dimethyl-6-octanolide" "4-methyl-7-(1-methylethyl)-2-oxepanone" "6-hydroxy-3,7-dimethyloctanoic acid lactone" "6-hydroxy-3,7-dimethylcaprylic acid epsilon-lactone" "2-oxepanone, 4-methyl-7-(1-methylethyl)-, (4r,7s)-" "4-methyl-7-propan-2-yloxepan-2-one" "4-methyl-7-(propan-2-yl)oxepan-2-one" "4-methyl-7-(1-methylethyl)oxepan-2-one" );
standardThermochemistry
{
    dHf_298   -532150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-250650.0
}
