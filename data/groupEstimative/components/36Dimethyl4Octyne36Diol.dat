/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-dimethyl-4-octyne-3,6-diol  (C10H18O2, CAS 78-66-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Dimethyl4Octyne36Diol;
formula     C10H18O2;
CAS         78-66-0;
InChIKey    NUYADIDKTLPDGG-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          802.00;      // K   [origin=predictive method=joback]
Pc          31.002;      // bar [origin=predictive method=joback]
omega       1.1568;      // -   [origin=predictive method=lee-kesler]
Tb          615.30;      // K   [origin=predictive method=joback]
HvapTb      70772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.008 1.12368 -0.00083246 2.5018e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 2; } { group OH; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 2; } { group tC; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-dimethyloct-4-yne-3,6-diol" "surfynol 82" "3,6-dimethyl-4-octyn-3,6-diol" "surfynol 85" "4-octyne-3,6-diol, 3,6-dimethyl-" "3,6-dihydroxy-3,6-dimethyl-4-octyne" "3,6-diol" "3,6-dimethyl-octin-4-diol-(3,6) [german]" "4-octyne-3, 3,6-dimethyl-" "3,6-dimethyl-octin-4-diol-(3,6)" "k389" );
standardThermochemistry
{
    dHf_298   -299390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31840.0
}
