/*--------------------------------*- Choupo -*-----------------------*\
  Component: epinine  (C9H13NO2, CAS 501-15-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        epinine;
formula     C9H13NO2;
CAS         501-15-5;
InChIKey    NGKZFDYBISXGGS-UHFFFAOYSA-N;
MW          167.208;      // g/mol [origin=calculated method=formula-sum]
Tc          875.38;      // K   [origin=predictive method=joback]
Pc          48.225;      // bar [origin=predictive method=joback]
omega       1.0260;      // -   [origin=predictive method=lee-kesler]
Tb          643.61;      // K   [origin=predictive method=joback]
HvapTb      70368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.248 1.16532 -0.00105832 3.981e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(methylamino)ethyl]benzene-1,2-diol" "n-methyldopamine" "1,2-benzenediol, 4-(2-(methylamino)ethyl)-" "1,2-benzenediol, 4-[2-(methylamino)ethyl]-" "4-(2-methylaminoethyl)pyrocatechol" "4-(2-methylaminoethyl)benzene-1,2-diol" );
gibbsFormation
{
    dHf_298   -293710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-82540.0
    phase     gas;
}
