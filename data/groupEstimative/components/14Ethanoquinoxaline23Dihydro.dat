/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-ethanoquinoxaline, 2,3-dihydro-  (C10H12N2, CAS 7140-45-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Ethanoquinoxaline23Dihydro;
formula     C10H12N2;
CAS         7140-45-6;
InChIKey    OGEXWIXITOCNRZ-UHFFFAOYSA-N;
MW          160.22;      // g/mol [origin=calculated method=formula-sum]
Tc          717.08;      // K   [origin=predictive method=joback]
Pc          39.555;      // bar [origin=predictive method=joback]
omega       0.5612;      // -   [origin=predictive method=lee-kesler]
Tb          499.22;      // K   [origin=predictive method=joback]
HvapTb      44978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-149.31 1.4372 -0.00135356 4.98e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydro-1,4-ethanoquinoxaline" "benzo[b]-1,4-diazabicyclo[2.2.2]octane" "1,4-ethanoquinoxaline,2,3-dihydro-" "1,8-diazatricyclo[6.2.2.0<2,7>]dodeca-2(7),3,5-triene" "2,3-dihydro-1,4-ethanoquinoxaline;benzo[b]-1,4-diazabicyclo[2.2.2]octane;" );
gibbsFormation
{
    dHf_298   308990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     329.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=518780.0
    phase     gas;
}
