/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl (s)-(-)-lactate  (C4H8O3, CAS 27871-49-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylSLactate;
formula     C4H8O3;
CAS         27871-49-4;
InChIKey    LPEKGGXMPWTOCB-VKHMYHEASA-N;
MW          104.105;      // g/mol [origin=calculated method=formula-sum]
Tc          615.05;      // K   [origin=predictive method=joback]
Pc          44.623;      // bar [origin=predictive method=joback]
omega       0.7975;      // -   [origin=predictive method=lee-kesler]
Tb          441.08;      // K   [origin=predictive method=joback]
HvapTb      48196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.27 0.36894 -0.0001328 -1.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (2s)-2-oxidanylpropanoate" "(s)-lactic acid methyl ester" "(-)-methyl l-lactate" "propanoic acid, 2-hydroxy-, methyl ester, (2s)-" "methyl (r)-lactate" "methyl l-lactate" "d-lactate methyl ester" "d-lactic acid methyl ester" "(s)-methyl lactate" "(-)-methyl lactate" "propanoic acid, 2-hydroxy-, methyl ester, (s)-" "methyl l-(-)-lactate" );
standardThermochemistry
{
    dHf_298   -600680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-466830.0
}
