/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-disilacyclobutane, 1,1,3,3-tetramethyl-  (C6H16Si2, CAS 1627-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H16Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13Disilacyclobutane1133Tetramethyl;
formula     C6H16Si2;
CAS         1627-98-1;
InChIKey    JKDNLUGVHCNUTB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          144.364;      // g/mol [origin=calculated method=formula-sum]
Tc          532.02;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.1499;      // -   [origin=predictive method=lee-kesler]
Tb          346.82;      // K   [origin=predictive method=joback]
HvapTb      29588.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.01 0.34848 0.000205 -2.168e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,3,3-tetramethyl-1,3-disiletane" "1,1,3,3-tetramethyl-1,3-disilacyclobutane" "1,1,3,3-tetramethyl-1,3-disilacyclobutane;" "1,3-disilacyclobutane,1,1,3,3-tetramethyl-" );
gibbsFormation
{
    dHf_298   -291110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-129320.0
    phase     gas;
}
