/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-2-penta-1,3-dienyl-1,3-dioxane  (C11H18O2, CAS 72845-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl2Penta13Dienyl13Dioxane;
formula     C11H18O2;
CAS         72845-83-1;
InChIKey    AKVZAXRCLMGZRL-UHFFFAOYSA-N;
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          748.56;      // K   [origin=predictive method=joback]
Pc          25.741;      // bar [origin=predictive method=joback]
omega       0.4493;      // -   [origin=predictive method=lee-kesler]
Tb          528.62;      // K   [origin=predictive method=joback]
HvapTb      47985.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.49 1.47036 -0.0012726 4.765e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxane, 5,5-dimethyl-2-(1,3-pentadienyl)-" "1,3-dioxane, 5,5-dimethyl-2-(1,3-pentadien-1-yl)-" "5,5-dimethyl-2-(1,3-pentadienyl)-1,3-dioxane" );
standardThermochemistry
{
    dHf_298   -250710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41190.0
}
