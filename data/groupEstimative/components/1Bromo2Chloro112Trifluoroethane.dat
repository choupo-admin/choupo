/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2-chloro-1,1,2-trifluoroethane  (C2HBrClF3, CAS 354-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo2Chloro112Trifluoroethane;
formula     C2HBrClF3;
CAS         354-06-3;
InChIKey    KFTODZKBBUMDQB-UHFFFAOYSA-N;
MW          197.378;      // g/mol [origin=calculated method=formula-sum]
Tc          523.83;      // K   [origin=predictive method=joback]
Pc          45.286;      // bar [origin=predictive method=joback]
omega       0.3297;      // -   [origin=predictive method=lee-kesler]
Tb          343.09;      // K   [origin=predictive method=joback]
HvapTb      26731.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.27 0.4059 -0.000401 1.439e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Br; count 1; } { group CF2; count 1; } { group HCClF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group F; count 3; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-chloranyl-1,1,2-tris(fluoranyl)ethane" "isohaloethane" "ethane, 1-bromo-2-chloro-1,1,2-trifluoro-" "1,1,2-trifluoro-1-bromo-2-chloroethane" "1,2-trifluoro-1-bromo-2-chloroethane" "1-bromo-2-chloro-1,2-trifluoroethane" "ethane,1-bromo-2-chloro-1,1,2-trifluoro-" "1-bromo-2-chloro-1,1,2-trifluoroethane ( min)" );
gibbsFormation
{
    dHf_298   -676380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     365.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-615680.0
    phase     gas;
}
