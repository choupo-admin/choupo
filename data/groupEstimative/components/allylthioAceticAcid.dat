/*--------------------------------*- Choupo -*-----------------------*\
  Component: (allylthio)acetic acid  (C5H8O2S, CAS 20600-63-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylthioAceticAcid;
formula     C5H8O2S;
CAS         20600-63-9;
InChIKey    BLSMRHBHPHGMSV-UHFFFAOYSA-N;
MW          132.177;      // g/mol [origin=calculated method=formula-sum]
Tc          741.24;      // K   [origin=predictive method=joback]
Pc          41.623;      // bar [origin=predictive method=joback]
omega       0.6834;      // -   [origin=predictive method=lee-kesler]
Tb          524.97;      // K   [origin=predictive method=joback]
HvapTb      50035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.552 0.50399 -0.0003035 6.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-prop-2-enylsulfanylethanoic acid" "acetic acid, (allylthio)-" "acetic acid, (2-propenylthio)-" "allylsulfanyl-acetic acid" "(prop-2-en-1-ylsulfanyl)acetic acid" "2-(prop-2-en-1-ylsulfanyl)acetic acid" "allylsulfanylacetic acid" "2-prop-2-enylsulfanylacetic acid" );
gibbsFormation
{
    dHf_298   -329500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-231730.0
    phase     gas;
}
