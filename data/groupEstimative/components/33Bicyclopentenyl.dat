/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3'-bicyclopentenyl  (C10H14, CAS 5009-17-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Bicyclopentenyl;
formula     C10H14;
CAS         5009-17-6;
InChIKey    VJEREEILRKZBKE-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          684.19;      // K   [origin=predictive method=joback]
Pc          32.803;      // bar [origin=predictive method=joback]
omega       0.2968;      // -   [origin=predictive method=lee-kesler]
Tb          457.28;      // K   [origin=predictive method=joback]
HvapTb      38952.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.61 1.1052 -0.00074956 1.952e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cyclopent-2-en-1-ylcyclopentene" "di-3,3'-bis(cyclopentenyl)" "dl 3,3'-bis(cyclopentenyl)" );
standardThermochemistry
{
    dHf_298   -13210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=166340.0
}
