/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentyl isocyanate  (C6H11NO, CAS 3954-13-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentylIsocyanate;
formula     C6H11NO;
CAS         3954-13-0;
InChIKey    VRVUKQWNRPNACD-UHFFFAOYSA-N;
MW          113.16;      // g/mol [origin=calculated method=formula-sum]
Tc          581.46;      // K   [origin=predictive method=joback]
Pc          33.802;      // bar [origin=predictive method=joback]
omega       0.4784;      // -   [origin=predictive method=lee-kesler]
Tb          403.55;      // K   [origin=predictive method=joback]
HvapTb      38482.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCd; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanatopentane" "pentane, 1-isocyanato-" "pentylisocyanate" "n-pentyl isocyanate" "1-pentyl isocyanate" "1-isocyanato-pentane" "isocyanicacid, pentyl ester (6ci,7ci,8ci); 1-isocyanatopentane; amyl isocyanate; pentylisocyanate; n-pentyl isocyanate" );
