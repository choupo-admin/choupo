/*--------------------------------*- Choupo -*-----------------------*\
  Component: aminochlorambucil  (C14H20Cl2N2O2, CAS 3688-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aminochlorambucil;
formula     C14H20Cl2N2O2;
CAS         3688-35-5;
InChIKey    WBIFEHLOTPXXKS-UHFFFAOYSA-N;
MW          319.226;      // g/mol [origin=calculated method=formula-sum]
Tc          1078.27;      // K   [origin=predictive method=joback]
Pc          21.276;      // bar [origin=predictive method=joback]
omega       1.2716;      // -   [origin=predictive method=lee-kesler]
Tb          856.48;      // K   [origin=predictive method=joback]
HvapTb      87926.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.944 1.4515 -0.00097456 2.499e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CHNH2; count 1; } { group CH2N; count 1; } { group COOH; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group COOH; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-4-[4-[bis(2-chloroethyl)amino]phenyl]butanoic acid" "2-amino-4-(p-(bis(2-chloroethyl)amino)phenyl)butyric acid" "alpha-amino-gamma-(p-dichloroethylamino)phenylbutyric acid" "alpha-amino-gamma-p-(n,n-di-2-chloroethylamino)phenylbutyric acid" "butyric acid, 2-amino-4-(p-(bis(2-chloroethyl)amino)phenyl)-" "butyric acid, 2-amino-4-[p-[bis(2-chloroethyl)amino]phenyl]-" ".alpha.-amino-.gamma.-(p-dichloroethylamino)phenylbutyric acid" "2-amino-4-[4-[bis(2-chloroethyl)amino]phenyl]butanoic acid" "benzenebutanoic acid, alpha-amino-4-(bis(2-chloroethyl)amino)-" ".alpha.-amino-.gamma.-[[p-(dichloroethyl)amino]phenyl]butyric acid" "benzenebutanoic acid, .alpha.-amino-4-[bis(2-chloroethyl)amino]-" "benzenebutanoic acid, alpha-amino-4-(bis(2-chloroethyl)amino)- (9ci)" );
gibbsFormation
{
    dHf_298   -392940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     766.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23200.0
    phase     gas;
}
