/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopenta(ef)heptalene, 3,5,8,10-tetramethyl-  (C18H18, CAS 17597-70-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentaEfHeptalene35810Tetramethyl;
formula     C18H18;
CAS         17597-70-5;
InChIKey    AINPHPVLIAVCOW-UHFFFAOYSA-N;
MW          234.342;      // g/mol [origin=calculated method=formula-sum]
Tc          937.26;      // K   [origin=predictive method=joback]
Pc          20.661;      // bar [origin=predictive method=joback]
omega       0.6891;      // -   [origin=predictive method=lee-kesler]
Tb          700.98;      // K   [origin=predictive method=joback]
HvapTb      64528.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.77 1.33008 -0.00092484 2.662e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 2; } { group ACH; count 4; } { group AC; count 4; } { group ACCH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   146470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=378240.0
    phase     gas;
}
