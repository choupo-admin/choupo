/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-indenecarboxaldehyde, 2,3,3a,4,5,6-hexahydro-1,3,3-trimethyl-  (C13H20O, CAS 94406-15-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1hIndenecarboxaldehyde233a456Hexahydro133Trimethyl;
formula     C13H20O;
CAS         94406-15-2;
InChIKey    GHHCTCHDGTWLFZ-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          800.01;      // K   [origin=predictive method=joback]
Pc          25.533;      // bar [origin=predictive method=joback]
omega       0.5121;      // -   [origin=predictive method=lee-kesler]
Tb          571.94;      // K   [origin=predictive method=joback]
HvapTb      49937.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-185.34 1.92816 -0.00190764 7.974e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group C; count 2; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,3-trimethyl-3a,4,5,6-tetrahydro-2h-indene-1-carbaldehyde" "3a,4,5,6-tetrahydro-1,3,3-trimethylindancarbaldehyde" );
standardThermochemistry
{
    dHf_298   -213660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45900.0
}
