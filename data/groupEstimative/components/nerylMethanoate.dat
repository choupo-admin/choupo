/*--------------------------------*- Choupo -*-----------------------*\
  Component: neryl methanoate  (C11H18O2, CAS 2142-94-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H18O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nerylMethanoate;
formula     C11H18O2;
CAS         2142-94-1;
InChIKey    OZSGNVIRNJAXJT-XFFZJAGNSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          605.65;      // K   [origin=predictive method=joback]
Pc          21.473;      // bar [origin=predictive method=joback]
omega       0.3746;      // -   [origin=predictive method=lee-kesler]
Tb          428.30;      // K   [origin=predictive method=joback]
HvapTb      37155.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.166 1.05674 -0.0008389 2.848e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2=C; count 1; } { group CH=C; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2z)-3,7-dimethylocta-2,7-dienyl] methanoate" "neryl formate (natural)" "neryl 2-methylpropanoate" "formic acid, neryl ester" "2,6-octadien-1-ol, 3,7-dimethyl-, formate, (z)-" "3,7-dimethyl-2,6-octadienyl formate, (z)-" "cis-3,7-dimethyl-2,6-octadien-1-ol formate" "3,7-dimethyl-2,6-octadien-1-yl formate, cis-" "3,7-dimethyl-2,6-octadien-1-yl methanoate, cis-" "2,6-octadien-1-ol, 3,7-dimethyl-, formate, (2z)-" );
standardThermochemistry
{
    dHf_298   29150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     748.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=236660.0
}
