/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-dibromopentane  (C5H10Br2, CAS 111-24-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Dibromopentane;
formula     C5H10Br2;
CAS         111-24-0;
InChIKey    IBODDUNKEPPBKW-UHFFFAOYSA-N;
MW          229.943;      // g/mol [origin=calculated method=formula-sum]
Tc          650.43;      // K   [origin=predictive method=joback]
Pc          41.091;      // bar [origin=predictive method=joback]
omega       0.5012;      // -   [origin=predictive method=lee-kesler]
Tb          446.32;      // K   [origin=predictive method=joback]
HvapTb      39594.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.725 0.5552 -0.000391 1.165e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-bis(bromanyl)pentane" "pentamethylene bromide" "pentane, 1,5-dibromo-" "pentamethylene dibromide" "pentane,5-dibromo-" "1,5-dibromo-pentane" "pentane,1,5-dibromo-" "pentane-1,5-dibromide" "i855" );
standardThermochemistry
{
    dHf_298   -93870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=19860.0
}
