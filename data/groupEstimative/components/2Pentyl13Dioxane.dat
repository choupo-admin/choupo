/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pentyl-1,3-dioxane  (C9H18O2, CAS 5663-29-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Pentyl13Dioxane;
formula     C9H18O2;
CAS         5663-29-6;
InChIKey    SMUIAOJZCSQUSN-UHFFFAOYSA-N;
MW          158.241;      // g/mol [origin=calculated method=formula-sum]
Tc          677.23;      // K   [origin=predictive method=joback]
Pc          27.847;      // bar [origin=predictive method=joback]
omega       0.4928;      // -   [origin=predictive method=lee-kesler]
Tb          478.97;      // K   [origin=predictive method=joback]
HvapTb      45077.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.256 0.97492 -0.000519 8.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxane, 2-pentyl-" "m-dioxane,2-pentyl- (8ci); 2-pentyl-1,3-dioxane; hexanal, cyclic 1,3-propanediyl acetal" );
standardThermochemistry
{
    dHf_298   -438770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122890.0
}
