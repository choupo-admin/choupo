/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodec-8-yn-1-yl acetate  (C14H24O2, CAS 26906-26-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodec8Yn1YlAcetate;
formula     C14H24O2;
CAS         26906-26-3;
InChIKey    KAOAAXSFXKKFGC-UHFFFAOYSA-N;
MW          224.344;      // g/mol [origin=calculated method=formula-sum]
Tc          769.58;      // K   [origin=predictive method=joback]
Pc          17.405;      // bar [origin=predictive method=joback]
omega       0.7359;      // -   [origin=predictive method=lee-kesler]
Tb          587.14;      // K   [origin=predictive method=joback]
HvapTb      56317.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.129 1.12924 -0.00055106 7.728e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH3COO; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group tC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodec-8-ynyl ethanoate" "8-dodecyn-1-ol, acetate" "8-dodecyn-1-ol, 1-acetate" "dodec-8-ynyl acetate" );
gibbsFormation
{
    dHf_298   -377270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     724.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40570.0
    phase     gas;
}
