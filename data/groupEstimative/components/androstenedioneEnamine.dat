/*--------------------------------*- Choupo -*-----------------------*\
  Component: androstenedione enamine  (C23H33NO, CAS 905-30-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        androstenedioneEnamine;
formula     C23H33NO;
CAS         905-30-6;
InChIKey    RYMKCRPGXRRYQV-CWMMHYCISA-N;
MW          339.523;      // g/mol [origin=calculated method=formula-sum]
Tc          1130.71;      // K   [origin=predictive method=joback]
Pc          16.511;      // bar [origin=predictive method=joback]
omega       0.8112;      // -   [origin=predictive method=lee-kesler]
Tb          874.18;      // K   [origin=predictive method=joback]
HvapTb      73285.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-330.04 3.19414 -0.00282428 1.0586e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 3; } { group C; count 2; } { group CH=C; count 2; } { group CH2CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 11; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s)-10,13-dimethyl-3-pyrrolidin-1-yl-1,2,7,8,9,11,12,14,15,16-decahydrocyclopenta[a]phenanthren-17-one" "3-pyrrolidin-1-ylandrosta-3,5-dien-17-one" "3-(1-pyrrolidinyl)androsta-3,5-dien-17-one" "androsta-3,5-dien-17-one, 3-(1-pyrrolidinyl)-" );
gibbsFormation
{
    dHf_298   -138080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     709.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=391800.0
    phase     gas;
}
