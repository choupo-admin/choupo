/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(1r,2s,5s)-2-amino-5-phenylcyclohexyl]methanol  (C13H19NO, CAS 195190-88-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2s5s2Amino5PhenylcyclohexylMethanol;
formula     C13H19NO;
CAS         195190-88-6;
InChIKey    LUMAPUYZQIKJQG-AVGNSLFASA-N;
MW          205.301;      // g/mol [origin=calculated method=formula-sum]
Tc          922.16;      // K   [origin=predictive method=joback]
Pc          29.313;      // bar [origin=predictive method=joback]
omega       1.0013;      // -   [origin=predictive method=lee-kesler]
Tb          698.64;      // K   [origin=predictive method=joback]
HvapTb      73939.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.779 1.3249 -0.0007586 1.43e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1r,2s,5s)-2-azanyl-5-phenyl-cyclohexyl]methanol" "((2s,5s,1r)-2-amino-5-phenylcyclohexyl)methan-1-ol" );
standardThermochemistry
{
    dHf_298   -179920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     543.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109650.0
}
