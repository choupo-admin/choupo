/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-benzosuberone  (C11H12O, CAS 826-73-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Benzosuberone;
formula     C11H12O;
CAS         826-73-3;
InChIKey    KWHUHTFXMNQHAA-UHFFFAOYSA-N;
MW          160.216;      // g/mol [origin=calculated method=formula-sum]
Tc          824.24;      // K   [origin=predictive method=joback]
Pc          34.199;      // bar [origin=predictive method=joback]
omega       0.4715;      // -   [origin=predictive method=lee-kesler]
Tb          570.71;      // K   [origin=predictive method=joback]
HvapTb      47831.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.71 0.9003 -0.00047756 7.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,7,8,9-tetrahydrobenzo[7]annulen-5-one" "benzsuberone" "1-benzosuberanone" "2,3-benzosuberone" "6,7,8,9-tetrahydro-5h-benzo[7]annulen-5-one" "5-benzocycloheptanone" "6,7,8,9-tetrahydro-5h-benzocyclohepten-5-one" "6,7,8,9-tetrahydrobenzocyclohepten-5-one" "5h-benzocyclohepten-5-one, 6,7,8,9-tetrahydro-" "6,7,8,9-tetrahydro-5-benzocycloheptenone" "benzo(b)cycloheptan-1-one" "benzo[b]cycloheptan-1-one" );
standardThermochemistry
{
    dHf_298   -102190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66190.0
}
