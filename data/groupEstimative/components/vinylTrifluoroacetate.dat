/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl trifluoroacetate  (C4H3F3O2, CAS 433-28-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylTrifluoroacetate;
formula     C4H3F3O2;
CAS         433-28-3;
InChIKey    ZBGRMWIREQJHPK-UHFFFAOYSA-N;
MW          140.06;      // g/mol [origin=calculated method=formula-sum]
Tc          501.06;      // K   [origin=predictive method=joback]
Pc          35.814;      // bar [origin=predictive method=joback]
omega       0.4018;      // -   [origin=predictive method=lee-kesler]
Tb          340.60;      // K   [origin=predictive method=joback]
HvapTb      27488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.47 0.4702 -0.0003431 8.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl 2,2,2-tris(fluoranyl)ethanoate" "ethenyl 2,2,2-trifluoroacetate" "trifluoroacetic acid vinyl ester" "vinyl 2,2,2-trifluoroacetate" "zbgrmwireqjhpk-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -914820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-821320.0
}
