/*--------------------------------*- Choupo -*-----------------------*\
  Component: dabi  (C18H17N, CAS 443-30-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dabi;
formula     C18H17N;
CAS         443-30-1;
InChIKey    HXVZHTQDVDNJMN-UHFFFAOYSA-N;
MW          247.341;      // g/mol [origin=calculated method=formula-sum]
Tc          947.60;      // K   [origin=predictive method=joback]
Pc          22.937;      // bar [origin=predictive method=joback]
omega       0.7047;      // -   [origin=predictive method=lee-kesler]
Tb          704.41;      // K   [origin=predictive method=joback]
HvapTb      64882.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.68 1.60484 -0.0012277 3.742e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(inden-1-ylidenemethyl)-n,n-dimethyl-aniline" "4-(inden-1-ylidenemethyl)-n,n-dimethylaniline" );
gibbsFormation
{
    dHf_298   329750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=560900.0
    phase     gas;
}
