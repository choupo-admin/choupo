/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dibromo-4-isopropylaniline  (C9H11Br2N, CAS 10546-65-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dibromo4Isopropylaniline;
formula     C9H11Br2N;
CAS         10546-65-3;
InChIKey    CJEBZUFROMNDEK-UHFFFAOYSA-N;
MW          293.002;      // g/mol [origin=calculated method=formula-sum]
Tc          906.71;      // K   [origin=predictive method=joback]
Pc          39.407;      // bar [origin=predictive method=joback]
omega       0.7513;      // -   [origin=predictive method=lee-kesler]
Tb          651.55;      // K   [origin=predictive method=joback]
HvapTb      63013.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.89 0.74564 -0.00048528 1.254e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH; count 1; } { group ACNH2; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis(bromanyl)-4-propan-2-yl-aniline" "2,6-dibromo-4-propan-2-ylaniline" "2,6-dibromo-4-(methylethyl)phenylamine" "benzenamine,2,6-dibromo-4-(1-methylethyl)-" "cumidine,2,6-dibromo- (7ci,8ci);2,6-dibromo-4-(1-methylethyl)aniline;2,6-dibromo-4-isopropylaniline;" );
gibbsFormation
{
    dHf_298   54200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=201070.0
    phase     gas;
}
