/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7-dichlorofluorene  (C13H8Cl2, CAS 7012-16-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        27Dichlorofluorene;
formula     C13H8Cl2;
CAS         7012-16-0;
InChIKey    SDPURBHAHVFTGX-UHFFFAOYSA-N;
MW          235.107;      // g/mol [origin=calculated method=formula-sum]
Tc          904.30;      // K   [origin=predictive method=joback]
Pc          30.024;      // bar [origin=predictive method=joback]
omega       0.6032;      // -   [origin=predictive method=lee-kesler]
Tb          648.05;      // K   [origin=predictive method=joback]
HvapTb      60380.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.7 1.0532 -0.00088684 3.002e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,7-bis(chloranyl)-9h-fluorene" "2,7-dichloro-9h-fluorene" "2,7-dichlor-9h-fluoren" "fluorene,7-dichloro-" "9h-fluorene,7-dichloro-" "q305" );
standardThermochemistry
{
    dHf_298   189510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=313680.0
}
