/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-1-(1-chloro-2-(4-ethoxyphenyl)vinyl)-4-octylbenzene  (C24H31ClO, CAS 33468-15-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        z11Chloro24EthoxyphenylVinyl4Octylbenzene;
formula     C24H31ClO;
CAS         33468-15-4;
InChIKey    GSDUCZGRMDRJKE-CLCOLTQESA-N;
MW          370.961;      // g/mol [origin=calculated method=formula-sum]
Tc          1094.48;      // K   [origin=predictive method=joback]
Pc          11.998;      // bar [origin=predictive method=joback]
omega       0.9014;      // -   [origin=predictive method=lee-kesler]
Tb          875.93;      // K   [origin=predictive method=joback]
HvapTb      81727.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.622 1.97054 -0.00120562 2.79e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2O; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(z)-1-chloranyl-2-(4-ethoxyphenyl)ethenyl]-4-octyl-benzene" "1-[(1z)-2-chloro-2-(4-octylphenyl)vinyl]-4-ethoxybenzene" "1-[(z)-1-chloro-2-(4-ethoxyphenyl)ethenyl]-4-octylbenzene" "trans-4-octyl-" "a-chloro-4 inverted exclamation marka-ethoxystilbene" );
standardThermochemistry
{
    dHf_298   -129100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     899.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=311500.0
}
