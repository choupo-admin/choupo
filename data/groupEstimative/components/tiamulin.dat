/*--------------------------------*- Choupo -*-----------------------*\
  Component: tiamulin  (C28H47NO4S, CAS 55297-95-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tiamulin;
formula     C28H47NO4S;
CAS         55297-95-5;
InChIKey    UURAUHCOJAIIRQ-BYPWMRGOSA-N;
MW          493.747;      // g/mol [origin=calculated method=formula-sum]
Tc          1415.39;      // K   [origin=predictive method=joback]
Pc          9.573;      // bar [origin=predictive method=joback]
omega       0.9208;      // -   [origin=predictive method=lee-kesler]
Tb          1155.30;      // K   [origin=predictive method=joback]
HvapTb      110046.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-246.125 3.72101 -0.0030359 1.0903e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 6; } { group CH; count 5; } { group C; count 3; } { group CH2=CH; count 1; } { group OH; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } { group CH2N; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 5; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 5; } { group C_ring; count 3; } { group OH; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } { group N; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thiamutilin" "tiavet p" "tiamuline [inn-french]" "tiamulinum [inn-latin]" "14-deoxy-14-((2-diethylaminoethyl-thio)-acetoxy)mutiline" "tiamutin" "denagard" "((2-(diethylamino)ethyl)thio)acetic acid 8-ester with (3as,4r,5s,6s,8r,9r,9ar,10r)-octahydro-5,8-dihydroxy-4,6,9,10)-tetramethyl-6-vinyl-3a,9-propano-3ah-cyclopentacycloocten-1(4h)-one" "acetic acid, ((2-(diethylamino)ethyl)thio)-, 6-ethenyldecahydro-5-hydroxy-4,6,9,10-tetramethyl-1-oxo-3a,9-propano-3ah-cyclopentacycloocten-8-yl ester (3as-(3aalpha,4beta,5alpha,6alpha,8beta,9alpha,9abeta,10s*))-" "tiamulinum" "tiamulina" "tiamuline" );
standardThermochemistry
{
    dHf_298   -862010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1168.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-86430.0
}
