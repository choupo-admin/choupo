/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-4,6-difluoroaniline  (C6H4ClF2N, CAS 36556-56-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro46Difluoroaniline;
formula     C6H4ClF2N;
CAS         36556-56-6;
InChIKey    DUPRZIYJXCCXQZ-UHFFFAOYSA-N;
MW          163.551;      // g/mol [origin=calculated method=formula-sum]
Tc          702.77;      // K   [origin=predictive method=joback]
Pc          40.159;      // bar [origin=predictive method=joback]
omega       0.5426;      // -   [origin=predictive method=lee-kesler]
Tb          487.00;      // K   [origin=predictive method=joback]
HvapTb      46604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.99 0.4087 -0.00022928 4.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACNH2; count 1; } { group ACCl; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 2; } { group Cl; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-4,6-bis(fluoranyl)aniline" "6-chloro-2,4-difluoroaniline" "4,6-difluoro-2-chloroaniline" "2-amino-3,5-difluorochlorobenzene" "2-chloro-4,6-difluorophenylamine" "2-chloro-4,6-difluoro-phenylamine" "timtec-bb sbb003922;2-chloro-4,6-difluoroaniline;4,6-difluoro-2-chloroaniline;6-chloro-2,4-difluoroaniline;6-chloro-2,4-difluoroaniline 97%;6-fluoro-2,4-difluoroaniline;2-chloro-4,6-difluoro-phenylamine" );
standardThermochemistry
{
    dHf_298   -339220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-251940.0
}
