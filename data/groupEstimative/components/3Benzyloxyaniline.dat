/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-benzyloxyaniline  (C13H13NO, CAS 1484-26-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Benzyloxyaniline;
formula     C13H13NO;
CAS         1484-26-0;
InChIKey    IGPFOKFDBICQMC-UHFFFAOYSA-N;
MW          199.253;      // g/mol [origin=calculated method=formula-sum]
Tc          899.12;      // K   [origin=predictive method=joback]
Pc          31.597;      // bar [origin=predictive method=joback]
omega       0.6863;      // -   [origin=predictive method=lee-kesler]
Tb          650.33;      // K   [origin=predictive method=joback]
HvapTb      62797.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.449 1.0202 -0.00061116 1.258e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group CH2O; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylmethoxyaniline" "3-(benzyloxy)aniline" "benzenamine, 3-(phenylmethoxy)-" "3-[(phenylmethyl)oxy]aniline" "3-(phenylmethoxy)phenylamine" "3-benzyloxy-phenylamine" "3-(benzyloxy)benzenamine" "3-amino-alpha-phenylanisole" "(3-phenylmethoxy-phenyl)-amine" "3-(benzyloxy)phenylamine;3-(phenylmethoxy)aniline;3-aminophenyl benzyl ether;m-(benzyloxy)aniline;m-aminophenyl benzyl ether;" );
gibbsFormation
{
    dHf_298   51510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=235220.0
    phase     gas;
}
