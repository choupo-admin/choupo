/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propyl-2,5,5-trimethyl-1,3-dioxane  (C10H20O2, CAS 5421-99-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propyl255Trimethyl13Dioxane;
formula     C10H20O2;
CAS         5421-99-8;
InChIKey    YVIHJMSLCZGXLX-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          709.93;      // K   [origin=predictive method=joback]
Pc          26.735;      // bar [origin=predictive method=joback]
omega       0.4285;      // -   [origin=predictive method=lee-kesler]
Tb          497.66;      // K   [origin=predictive method=joback]
HvapTb      44692.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.208 1.62728 -0.0015832 6.678e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5,5-trimethyl-2-propyl-1,3-dioxane" "1,3-dioxane, 2,5,5-trimethyl-2-propyl-" "m-dioxane,5,5-trimethyl-2-propyl-" "m-dioxane, 2,5,5-trimethyl-2-propyl- (8ci)" "methylpropyl ketone,2-dimethyl-1,3-propanediol ketal" "methylpropyl ketone, 2,2-dimethyl-1,3-propanediol ketal" );
standardThermochemistry
{
    dHf_298   -449270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133160.0
}
