/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-tetrahydro-1,4-methanonaphthalen-9-amine  (C11H13N, CAS 142-65-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234Tetrahydro14Methanonaphthalen9Amine;
formula     C11H13N;
CAS         142-65-4;
InChIKey    AIGGDKWINIMWNQ-UHFFFAOYSA-N;
MW          159.232;      // g/mol [origin=calculated method=formula-sum]
Tc          798.79;      // K   [origin=predictive method=joback]
Pc          34.643;      // bar [origin=predictive method=joback]
omega       0.5422;      // -   [origin=predictive method=lee-kesler]
Tb          560.01;      // K   [origin=predictive method=joback]
HvapTb      53004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.65 1.2572 -0.00101356 3.316e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group ACCH; count 2; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-aminobenzonorbornene" "1,4-methanonaphthalen-9-amine, 1,2,3,4-tetrahydro-, stereoisomer (van)" );
gibbsFormation
{
    dHf_298   119900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     280.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=336860.0
    phase     gas;
}
