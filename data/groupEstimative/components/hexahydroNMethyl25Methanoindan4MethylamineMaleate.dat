/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexahydro-n-methyl-2,5-methanoindan-4-methylamine maleate  (C16H25NO4, CAS 59177-76-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexahydroNMethyl25Methanoindan4MethylamineMaleate;
formula     C16H25NO4;
CAS         59177-76-3;
InChIKey    ALGSTNZPXIHUIG-UHFFFAOYSA-N;
MW          295.379;      // g/mol [origin=calculated method=formula-sum]
Tc          1157.77;      // K   [origin=predictive method=joback]
Pc          19.753;      // bar [origin=predictive method=joback]
omega       1.3189;      // -   [origin=predictive method=lee-kesler]
Tb          927.58;      // K   [origin=predictive method=joback]
HvapTb      91519.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.999 1.90552 -0.0012128 2.875e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 5; } { group CH=CH; count 1; } { group CH3NH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 5; } { group COOH; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -843480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     691.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-384400.0
}
