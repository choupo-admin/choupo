/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenamine, 4,4'-((2-chlorophenyl)methylene)bis(2-methyl-  (C21H21ClN2, CAS 75673-51-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenamine442ChlorophenylMethyleneBis2Methyl;
formula     C21H21ClN2;
CAS         75673-51-7;
InChIKey    LVTVHAYOZXMKLD-UHFFFAOYSA-N;
MW          336.863;      // g/mol [origin=calculated method=formula-sum]
Tc          1234.24;      // K   [origin=predictive method=joback]
Pc          20.091;      // bar [origin=predictive method=joback]
omega       1.0757;      // -   [origin=predictive method=lee-kesler]
Tb          967.07;      // K   [origin=predictive method=joback]
HvapTb      97757.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.23 1.60114 -0.0009874 2.212e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group ACCH3; count 2; } { group ACCH; count 1; } { group ACNH2; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group Cl; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(4-azanyl-3-methyl-phenyl)-(2-chlorophenyl)methyl]-2-methyl-aniline" );
standardThermochemistry
{
    dHf_298   222030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     750.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=533550.0
}
