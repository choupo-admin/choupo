/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(2-cyanoethyl)formamide  (C7H9N3O, CAS 3445-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H9N3O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nNBis2CyanoethylFormamide;
formula     C7H9N3O;
CAS         3445-84-9;
InChIKey    MYRFNYCEQURXPT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          151.169;      // g/mol [origin=calculated method=formula-sum]
Tc          754.91;      // K   [origin=predictive method=joback]
Pc          27.759;      // bar [origin=predictive method=joback]
omega       0.7026;      // -   [origin=predictive method=lee-kesler]
Tb          552.78;      // K   [origin=predictive method=joback]
HvapTb      51802.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.334 0.6704 -0.0005606 1.936e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2CN; count 2; } { group CONCH3CH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group N; count 1; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(2-cyanoethyl)methanamide" "formamide, n,n-bis(2-cyanoethyl)-" "nn-bis(2-cyanoethyl)formamide" "myrfnycequrxpt-uhfffaoysa-" "3,3'-formyliminodipropiononitrile" "n,n-bis(2-cyanoethyl)carboxamide" "formamide,n,n-bis(2-cyanoethyl)-" "n-formylimino-3,3'-dipropionitrile" "t753" "3,3'-(formylimino)dipropionitrile" "bis(2-cyanoethyl)formamide;glyezin pfd;luprintan;n,n-bis(2-cyanoethyl)formamide;n,n-bis(cyanoethyl)formamide;n,n'-bis(2-cyanoethyl)formamide;" );
gibbsFormation
{
    dHf_298   285930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=429160.0
    phase     gas;
}
