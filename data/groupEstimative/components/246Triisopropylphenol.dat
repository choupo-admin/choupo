/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-triisopropylphenol  (C15H24O, CAS 2934-07-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Triisopropylphenol;
formula     C15H24O;
CAS         2934-07-8;
InChIKey    HVFKKINZIWVNQG-UHFFFAOYSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          873.94;      // K   [origin=predictive method=joback]
Pc          20.965;      // bar [origin=predictive method=joback]
omega       0.7558;      // -   [origin=predictive method=lee-kesler]
Tb          658.74;      // K   [origin=predictive method=joback]
HvapTb      64434.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.02 1.40332 -0.00095528 2.746e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group ACH; count 2; } { group ACCH; count 3; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-tri(propan-2-yl)phenol" "phenol, 2,4,6-tris(1-methylethyl)-" "hvfkkinziwvnqg-uhfffaoysa-" "2,4,6-tris(1-methylethyl)phenol" "phenol,2,4,6-tris(1-methylethyl)-" "phenol,2,4,6-triisopropyl- (6ci,7ci,8ci); 2,4,6-triisopropylphenol" );
standardThermochemistry
{
    dHf_298   -332490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6630.0
}
