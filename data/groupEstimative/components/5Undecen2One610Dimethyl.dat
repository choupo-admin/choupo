/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-undecen-2-one, 6,10-dimethyl-  (C13H24O, CAS 689-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Undecen2One610Dimethyl;
formula     C13H24O;
CAS         689-66-7;
InChIKey    COFFUYZBRGBAQS-UHFFFAOYSA-N;
MW          196.334;      // g/mol [origin=calculated method=formula-sum]
Tc          736.40;      // K   [origin=predictive method=joback]
Pc          18.294;      // bar [origin=predictive method=joback]
omega       0.6670;      // -   [origin=predictive method=lee-kesler]
Tb          554.51;      // K   [origin=predictive method=joback]
HvapTb      50928.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.125 1.23668 -0.000754 1.8316e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,10-dimethylundec-5-en-2-one" "5-undecen-2-one, 6,10-dimethyl-, (5e)-" );
gibbsFormation
{
    dHf_298   -322080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     668.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1110.0
    phase     gas;
}
