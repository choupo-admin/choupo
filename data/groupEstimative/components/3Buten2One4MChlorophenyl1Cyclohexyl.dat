/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-buten-2-one, 4-(m-chlorophenyl)-1-cyclohexyl-,  (C16H19ClO, CAS 1760-62-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Buten2One4MChlorophenyl1Cyclohexyl;
formula     C16H19ClO;
CAS         1760-62-9;
InChIKey    HJUQNTIOFIUETP-MDZDMXLPSA-N;
MW          262.777;      // g/mol [origin=calculated method=formula-sum]
Tc          954.62;      // K   [origin=predictive method=joback]
Pc          21.533;      // bar [origin=predictive method=joback]
omega       0.6964;      // -   [origin=predictive method=lee-kesler]
Tb          712.35;      // K   [origin=predictive method=joback]
HvapTb      65666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.799 1.5063 -0.00097726 2.3676e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-4-(3-chlorophenyl)-1-cyclohexyl-but-3-en-2-one" "(e)-4-(3-chlorophenyl)-1-cyclohexylbut-3-en-2-one" );
gibbsFormation
{
    dHf_298   -105290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=150440.0
    phase     gas;
}
