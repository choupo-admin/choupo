/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluorophenylacetone  (C9H9FO, CAS 459-03-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Fluorophenylacetone;
formula     C9H9FO;
CAS         459-03-0;
InChIKey    ZUEKIIWSVFBTCM-UHFFFAOYSA-N;
MW          152.168;      // g/mol [origin=calculated method=formula-sum]
Tc          698.58;      // K   [origin=predictive method=joback]
Pc          32.728;      // bar [origin=predictive method=joback]
omega       0.5237;      // -   [origin=predictive method=lee-kesler]
Tb          490.32;      // K   [origin=predictive method=joback]
HvapTb      44495.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.449 0.70422 -0.00042766 9.306e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group CH3CO; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-fluorophenyl)propan-2-one" "(4-fluorophenyl)acetone" "1-(4-fluorophenyl)acetone" "2-propanone, 1-(4-fluorophenyl)-" "4'-fluorophenylacetone" "4-fluorophenyl acetone" "(p-fluorophenyl)acetone" "1-acetonyl-4-fluorobenzene" "p-fluoro enzyl methyl ketone" "p-fluoro benzyl methyl ketone" "1-(4-fluorophenyl)-2-propanone" "1-(4-fluoro-phenyl)-propan-2-one" );
standardThermochemistry
{
    dHf_298   -312720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-196050.0
}
