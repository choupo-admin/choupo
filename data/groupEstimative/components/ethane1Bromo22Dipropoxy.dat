/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethane, 1-bromo-2,2-dipropoxy-,  (C8H17BrO2, CAS 61365-93-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethane1Bromo22Dipropoxy;
formula     C8H17BrO2;
CAS         61365-93-3;
InChIKey    YZXXNXIKOGVZPP-UHFFFAOYSA-N;
MW          225.126;      // g/mol [origin=calculated method=formula-sum]
Tc          676.64;      // K   [origin=predictive method=joback]
Pc          26.488;      // bar [origin=predictive method=joback]
omega       0.6476;      // -   [origin=predictive method=lee-kesler]
Tb          493.20;      // K   [origin=predictive method=joback]
HvapTb      44269.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.125 0.68154 -0.000264 8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH2O; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group Br; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-bromanyl-1-propoxy-ethoxy)propane" "1,1'-((2-bromoethylidene)bis(oxy))bispropane" "1,1'-[(2-bromoethylidene)bis(oxy)]bispropane" "1-(2-bromo-1-propoxyethoxy)propane" "propane,1-(2-bromo-1-propoxyethoxy)-" "propane,1,1'-[(2-bromoethylidene)bis(oxy)]bis- (9ci); bromoacetaldehyde dipropyl acetal" );
standardThermochemistry
{
    dHf_298   -451840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-181640.0
}
