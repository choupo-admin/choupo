/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl(trimethylsilylmethyl)amine  (C6H17NSi, CAS 18182-40-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H17NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dimethylTrimethylsilylmethylAmine;
formula     C6H17NSi;
CAS         18182-40-6;
InChIKey    OUSBZHYDUVVKHE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          131.294;      // g/mol [origin=calculated method=formula-sum]
Tc          519.37;      // K   [origin=predictive method=joback]
Pc          27.240;      // bar [origin=predictive method=joback]
omega       0.2691;      // -   [origin=predictive method=lee-kesler]
Tb          350.72;      // K   [origin=predictive method=joback]
HvapTb      31287.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.561 0.4916 -4e-07 -1.196e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH3N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-1-trimethylsilyl-methanamine" "(ch3)2nch2si(ch3)3" "n,n-dimethyl-1-trimethylsilylmethanamine" "n,n-dimethyl-1-(trimethylsilyl)methanamine" );
gibbsFormation
{
    dHf_298   -211260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5660.0
    phase     gas;
}
