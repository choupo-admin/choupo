/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodo-2-(trimethylsilyl)acetylene  (C5H9ISi, CAS 18163-47-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H9ISi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Iodo2TrimethylsilylAcetylene;
formula     C5H9ISi;
CAS         18163-47-8;
InChIKey    HNIRHTRSZDSMOF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          224.112;      // g/mol [origin=calculated method=formula-sum]
Tc          660.22;      // K   [origin=predictive method=joback]
Pc          35.431;      // bar [origin=predictive method=joback]
omega       0.1321;      // -   [origin=predictive method=lee-kesler]
Tb          417.54;      // K   [origin=predictive method=joback]
HvapTb      38543.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.41 0.16186 0.00017734 -1.5002e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group I; count 1; } { group C_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group tC; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-iodanylethynyl(trimethyl)silane" "silane, (iodomethyl)trimethyl-" "2-iodoethynyl(trimethyl)silane" "silane,(iodoethynyl)trimethyl- (7ci,8ci,9ci);(iodoethynyl)trimethylsilane;1-iodo-2-(trimethylsilyl)acetylene;1-iodo-2-(trimethylsilyl)ethyne;iodo(trimethylsilyl)acetylene;" );
standardThermochemistry
{
    dHf_298   91020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147380.0
}
