/*--------------------------------*- Choupo -*-----------------------*\
  Component: flurenol-butyl  (C18H18O3, CAS 2314-09-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        flurenolButyl;
formula     C18H18O3;
CAS         2314-09-2;
InChIKey    PSGPXWYGJGGEEG-UHFFFAOYSA-N;
MW          282.339;      // g/mol [origin=calculated method=formula-sum]
Tc          1042.00;      // K   [origin=predictive method=joback]
Pc          22.849;      // bar [origin=predictive method=joback]
omega       1.2677;      // -   [origin=predictive method=lee-kesler]
Tb          823.60;      // K   [origin=predictive method=joback]
HvapTb      84042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.977 1.87822 -0.00166512 6.14e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 9-oxidanylfluorene-9-carboxylate" "flurenol-n-butyl ester" "butyl 9-hydroxyfluorene-9-carboxylate" "butyl flurenol" "flurenol ester" "butyl morphactin" "flurecol [bsi]" "flurenol-butyl ester" "flurecol-butyl" "9h-fluorene-9-carboxylic acid, 9-hydroxy-, butyl ester" "butyl 9-hydroxy-9h-fluorene-9-carboxylate" "9-hydroxy-9h-fluorene-9-carboxylic acid butyl ester" );
standardThermochemistry
{
    dHf_298   -333880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     673.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-61490.0
}
