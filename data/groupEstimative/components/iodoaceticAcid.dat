/*--------------------------------*- Choupo -*-----------------------*\
  Component: iodoacetic acid  (C2H3IO2, CAS 64-69-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iodoaceticAcid;
formula     C2H3IO2;
CAS         64-69-7;
InChIKey    JDNTWHVOXJZDSN-UHFFFAOYSA-N;
MW          185.944;      // g/mol [origin=calculated method=formula-sum]
Tc          717.96;      // K   [origin=predictive method=joback]
Pc          55.443;      // bar [origin=predictive method=joback]
omega       0.5291;      // -   [origin=predictive method=lee-kesler]
Tb          484.01;      // K   [origin=predictive method=joback]
HvapTb      46583.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.361 0.2836 -0.000239 8.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group COOH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group I; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-iodanylethanoic acid" "iodoacetate" "acetic acid, iodo-" "monoiodoacetic acid" "2-iodoacetic acid" "monoiodoacetate" "monoiodine acetate" "acetic acid, 2-iodo-" "monoiodo acetate" "iodoethanoic acid" "iodoaceticacid" "kyselina jodoctova" );
standardThermochemistry
{
    dHf_298   -358010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-319830.0
}
