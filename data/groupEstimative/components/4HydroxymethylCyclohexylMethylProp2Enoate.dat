/*--------------------------------*- Choupo -*-----------------------*\
  Component: [4-(hydroxymethyl)cyclohexyl]methyl prop-2-enoate  (C11H18O3, CAS 23117-36-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HydroxymethylCyclohexylMethylProp2Enoate;
formula     C11H18O3;
CAS         23117-36-4;
InChIKey    URLYGBGJPQYXBN-UHFFFAOYSA-N;
MW          198.262;      // g/mol [origin=calculated method=formula-sum]
Tc          804.67;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       0.9789;      // -   [origin=predictive method=lee-kesler]
Tb          613.24;      // K   [origin=predictive method=joback]
HvapTb      63616.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.068 1.1036 -0.0005589 7.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group CH2=CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, [4-(hydroxymethyl)cyclohexyl]methyl ester" "2-propenoic acid, (4-(hydroxymethyl)cyclohexyl)methyl ester" "2-propenoic acid,[4-(hydroxymethyl)cyclohexyl]methyl ester" "acrylicacid, [4-(hydroxymethyl)cyclohexyl]methyl ester (8ci);1,4-cyclohexanedimethanol monoacrylate; chdmma" );
standardThermochemistry
{
    dHf_298   -580470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     609.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-300870.0
}
