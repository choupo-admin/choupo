/*--------------------------------*- Choupo -*-----------------------*\
  Component: clofexamide  (C14H21ClN2O2, CAS 1223-36-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        clofexamide;
formula     C14H21ClN2O2;
CAS         1223-36-5;
InChIKey    UORGKWWJEQDTGX-UHFFFAOYSA-N;
MW          284.784;      // g/mol [origin=calculated method=formula-sum]
Tc          930.89;      // K   [origin=predictive method=joback]
Pc          20.181;      // bar [origin=predictive method=joback]
omega       1.0579;      // -   [origin=predictive method=lee-kesler]
Tb          727.91;      // K   [origin=predictive method=joback]
HvapTb      71716.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.405 1.31114 -0.00075386 1.4906e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 1; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chloranylphenoxy)-n-[2-(diethylamino)ethyl]ethanamide" "amichlophene" "chlofexamide" "clofexamidum [inn-latin]" "n-(2-diethylaminoethyl)-4-chlorophenoxyacetamide" "2-(4-chlorophenoxy)-n-(2-diethylaminoethyl)acetamide" "2-(p-chlorophenoxy)-n-(2-(diethylamino)ethyl)acetamide" "acetamide, 2-(p-chlorophenoxy)-n-(2-(diethylamino)ethyl)-" "acetamide, 2-(4-chlorophenoxy)-n-(2-(diethylamino)ethyl)-" "acetamide, 2-(4-chlorophenoxy)-n-[2-(diethylamino)ethyl]-" "clofexamida" "clofexamidum" );
standardThermochemistry
{
    dHf_298   -246770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     716.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124100.0
}
