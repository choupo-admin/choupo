/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropylbenzyl chloride  (C10H13Cl, CAS 2051-18-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4IsopropylbenzylChloride;
formula     C10H13Cl;
CAS         2051-18-5;
InChIKey    CYAKWEQUWJAHLW-UHFFFAOYSA-N;
MW          168.664;      // g/mol [origin=calculated method=formula-sum]
Tc          713.82;      // K   [origin=predictive method=joback]
Pc          27.965;      // bar [origin=predictive method=joback]
omega       0.4148;      // -   [origin=predictive method=lee-kesler]
Tb          497.05;      // K   [origin=predictive method=joback]
HvapTb      44789.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.599 0.82814 -0.00050796 1.169e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(chloromethyl)-4-propan-2-yl-benzene" "p-cymene, 7-chloro-" "p-isopropylbenzyl chloride" "7-chloro-p-cymene" "p-isopropyl benzyl chloride" "benzene, 1-(chloromethyl)-4-(1-methylethyl)-" "1-(chloromethyl)-4-isopropylbenzene" "1-(chloromethyl)-4-(propan-2-yl)benzene" "benzene, 1-(chloromethyl)-4-(methylethyl)-" "4-iso-propylbenzyl chloride" "1-(chloromethyl)-4-propan-2-ylbenzene" "4-(chloromethyl)-1-(methylethyl)benzene" );
standardThermochemistry
{
    dHf_298   -45690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=121730.0
}
