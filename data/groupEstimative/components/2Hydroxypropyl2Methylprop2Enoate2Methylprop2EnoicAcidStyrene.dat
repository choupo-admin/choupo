/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxypropyl 2-methylprop-2-enoate; 2-methylprop-2-enoic acid; styrene  (C19H26O5, CAS 68239-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxypropyl2Methylprop2Enoate2Methylprop2EnoicAcidStyrene;
formula     C19H26O5;
CAS         68239-97-4;
InChIKey    OBENACRUWNHQKS-UHFFFAOYSA-N;
MW          334.412;      // g/mol [origin=calculated method=formula-sum]
Tc          1170.67;      // K   [origin=predictive method=joback]
Pc          15.295;      // bar [origin=predictive method=joback]
omega       1.2546;      // -   [origin=predictive method=lee-kesler]
Tb          949.07;      // K   [origin=predictive method=joback]
HvapTb      99764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.611 1.29326 -0.0002963 -1.58e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenylbenzene;2-methylprop-2-enoic acid;2-oxidanylpropyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, polymer with ethenylbenzene and 2-hydroxypropyl 2-methyl-2-propenoate" "2-propenoic acid, 2-methyl-, polymer with ethenylbenzene and 1,2-propanediol mono(2-methyl-2-propenoate)" );
gibbsFormation
{
    dHf_298   -890550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1128.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-535130.0
    phase     gas;
}
