/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 1-methylpiperidine-4-carboxylate  (C8H15NO2, CAS 1690-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl1Methylpiperidine4Carboxylate;
formula     C8H15NO2;
CAS         1690-75-1;
InChIKey    KYAOKPRJTMFBTQ-UHFFFAOYSA-N;
MW          157.213;      // g/mol [origin=calculated method=formula-sum]
Tc          666.38;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       0.5062;      // -   [origin=predictive method=lee-kesler]
Tb          468.58;      // K   [origin=predictive method=joback]
HvapTb      43109.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.15 0.96464 -0.0005568 1.038e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl n-methyl-4-piperidinecarboxylate" "methyl 1-methyl piperidine-4-carboxylate" "methyl-1-methylpiperidine-4-carboxylate" "methyl n-methyl piperidine-4-carboxylate" "1-methyl-4-piperidinecarboxylic acid methyl ester" "4-piperidinecarboxylicacid, 1-methyl-, methyl ester" "4-piperidinecarboxylic acid, 1-methyl-, methyl ester" "n-methyl-4-piperidinecarboxylic acid methyl ester" "isonipecoticacid, 1-methyl-, methyl ester (6ci,7ci,8ci);methyl1-methylpiperidine-4-carboxylate;methyl n-methylisonipecotinate;" );
gibbsFormation
{
    dHf_298   -397720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-146560.0
    phase     gas;
}
