/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-(4-fluorophenyl)oxolan-2-one  (C10H9FO2, CAS 51787-96-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        54FluorophenylOxolan2One;
formula     C10H9FO2;
CAS         51787-96-3;
InChIKey    RMFNZGXVLAUJHF-UHFFFAOYSA-N;
MW          180.178;      // g/mol [origin=calculated method=formula-sum]
Tc          740.41;      // K   [origin=predictive method=joback]
Pc          31.847;      // bar [origin=predictive method=joback]
omega       0.5604;      // -   [origin=predictive method=lee-kesler]
Tb          524.29;      // K   [origin=predictive method=joback]
HvapTb      47295.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.55 0.9233 -0.00062636 1.562e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group CH2COO; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( ".gamma.-(4-fluorophenyl)-butyrolactone" "4,5-dihydro-5-(4-fluorophenyl)-2(3h)-furanone" "5-(4-fluorophenyl)dihydrofuran-2(3h)-one" ".gamma.-(4-fluorophenyl)-.gamma.-butyrolactone" "5-(4-fluorophenyl)-3,4,5-trihydrofuran-2-one" "gamma-(4-fluorophenyl)-gamma-butyrolactone" "2(3h)-furanone,5-(4-fluorophenyl)dihydro-" "5-(4-fluorophenyl)tetrahydrofuran-2-one;5-(4-fluorophenyl)dihydro-2(3h)-furanone;4-(4-fluorophenyl)butyrolactone;g-(4-fluorophenyl)-g-butyrolactone;gamma-(4-fluorophenyl)-gamma-butyrolactone;ac1l2uza;ac1q4np2;ar-1g5287;" );
standardThermochemistry
{
    dHf_298   -465260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-308330.0
}
