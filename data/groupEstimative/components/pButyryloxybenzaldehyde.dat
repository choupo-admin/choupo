/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-butyryloxybenzaldehyde  (C11H12O3, CAS 50262-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H12O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pButyryloxybenzaldehyde;
formula     C11H12O3;
CAS         50262-49-2;
InChIKey    DAFTVVBQFUITOL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          192.214;      // g/mol [origin=calculated method=formula-sum]
Tc          725.21;      // K   [origin=predictive method=joback]
Pc          27.440;      // bar [origin=predictive method=joback]
omega       0.5364;      // -   [origin=predictive method=lee-kesler]
Tb          517.58;      // K   [origin=predictive method=joback]
HvapTb      48052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.808 0.86372 -0.00059716 1.599e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methanoylphenyl) butanoate" "butanoic acid, 4-formylphenyl ester" "4-formylphenyl butyrate" "4-formylphenyl butanoate" "4-butyryloxybenzaldehyde" "p-butyryl-oxybenzaldehyde" "(4-formylphenyl) butanoate" "p-butyroxybenzaldehyde" "butanoic acid (4-formylphenyl) ester" );
standardThermochemistry
{
    dHf_298   -286140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     604.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-121890.0
}
