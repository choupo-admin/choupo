/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-Carboxyethyl acrylate  (C6H8O4, CAS 24615-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2CarboxyethylAcrylate;
formula     C6H8O4;
CAS         24615-84-7;
InChIKey    CYUZOYPRAQASLN-UHFFFAOYSA-N;
MW          144.126;      // g/mol [origin=calculated method=formula-sum]
Tc          735.23;      // K   [origin=predictive method=joback]
Pc          36.377;      // bar [origin=predictive method=joback]
omega       0.8296;      // -   [origin=predictive method=lee-kesler]
Tb          537.29;      // K   [origin=predictive method=joback]
HvapTb      52851.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.452 0.5498 -0.0003035 4.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-prop-2-enoyloxypropanoic acid" "2-propenoic acid, 2-carboxyethyl ester" "3-(Acryloyloxy)propionic acid" "3-acryloyloxypropanoic acid" "acrylic acid 2-carboxyethyl ester" "acrylic acid dimer" "aronix m 566" "c 800" "c 800 (acrylate)" "hydracrylic acid, acrylate" "miramer cea" "β-(acryloyloxy)propionic acid" );
standardThermochemistry
{
    dHf_298   -709290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-566800.0
}
