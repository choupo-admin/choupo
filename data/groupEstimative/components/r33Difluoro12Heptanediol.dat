/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-(+)-3,3-difluoro-1,2-heptanediol  (C7H14F2O2, CAS 158358-96-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r33Difluoro12Heptanediol;
formula     C7H14F2O2;
CAS         158358-96-4;
InChIKey    NDZCPOSFHWMJGY-ZCFIWIBFSA-N;
MW          168.183;      // g/mol [origin=calculated method=formula-sum]
Tc          693.60;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       1.3142;      // -   [origin=predictive method=lee-kesler]
Tb          538.99;      // K   [origin=predictive method=joback]
HvapTb      61216.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.866 0.89212 -0.0006256 1.743e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 2; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group F; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-3,3-bis(fluoranyl)heptane-1,2-diol" "(r)-3,3-difluoro-1,2-heptanediol" "1,2-heptanediol,3,3-difluoro-, (r)- (9ci)" );
gibbsFormation
{
    dHf_298   -898520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-654800.0
    phase     gas;
}
