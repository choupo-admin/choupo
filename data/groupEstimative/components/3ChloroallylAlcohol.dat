/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloroallyl alcohol  (C3H5ClO, CAS 29560-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ChloroallylAlcohol;
formula     C3H5ClO;
CAS         29560-84-7;
InChIKey    HJGHXDNIPAWLLE-UHFFFAOYSA-N;
MW          92.522;      // g/mol [origin=calculated method=formula-sum]
Tc          580.89;      // K   [origin=predictive method=joback]
Pc          51.093;      // bar [origin=predictive method=joback]
omega       0.6356;      // -   [origin=predictive method=lee-kesler]
Tb          402.01;      // K   [origin=predictive method=joback]
HvapTb      43294.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.161 0.3496 -0.000274 9.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 2; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylprop-2-en-1-ol" "2-propen-1-ol, 3-chloro-" "pi-chloro allyl alcohol" "3-chloro-2-propen-1-ol" "3-chloroallylalcohol" "2-propen-1-ol,3-chloro- (6ci,7ci,8ci,9ci)" );
gibbsFormation
{
    dHf_298   -156000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94150.0
    phase     gas;
}
