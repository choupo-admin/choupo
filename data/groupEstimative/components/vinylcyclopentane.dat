/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinylcyclopentane  (C7H12, CAS 3742-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylcyclopentane;
formula     C7H12;
CAS         3742-34-5;
InChIKey    BEFDCLMNVWHSGT-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          570.22;      // K   [origin=predictive method=joback]
Pc          35.942;      // bar [origin=predictive method=joback]
omega       0.2349;      // -   [origin=predictive method=lee-kesler]
Tb          371.72;      // K   [origin=predictive method=joback]
HvapTb      30763.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.95 0.7805 -0.0005073 1.29e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenylcyclopentane" "cyclopentane, ethenyl-" "cyclopentane, vinyl-" );
standardThermochemistry
{
    dHf_298   -1900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132450.0
}
