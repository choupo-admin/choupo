/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4s,2rs)-2-methylthiazolidine-4-carboxylic acid  (C5H9NO2S, CAS 205985-91-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4s2rs2Methylthiazolidine4CarboxylicAcid;
formula     C5H9NO2S;
CAS         205985-91-7;
InChIKey    FHTPNEYXMGZOSH-SRBOSORUSA-N;
MW          147.192;      // g/mol [origin=calculated method=formula-sum]
Tc          807.89;      // K   [origin=predictive method=joback]
Pc          48.025;      // bar [origin=predictive method=joback]
omega       0.6862;      // -   [origin=predictive method=lee-kesler]
Tb          566.50;      // K   [origin=predictive method=joback]
HvapTb      56406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.86 0.63583 -0.0003509 6.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CHNH; count 1; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group COOH; count 1; } { group NH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4s)-2-methyl-1,3-thiazolidine-4-carboxylic acid" "(4s,2rs)-2-methyl thiazolidine-4-carboxylic acid" );
standardThermochemistry
{
    dHf_298   -373590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-196280.0
}
