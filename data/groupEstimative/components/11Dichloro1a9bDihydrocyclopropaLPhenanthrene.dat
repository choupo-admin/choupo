/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dichloro-1a,9b-dihydrocyclopropa[l]phenanthrene  (C15H10Cl2, CAS 37608-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichloro1a9bDihydrocyclopropaLPhenanthrene;
formula     C15H10Cl2;
CAS         37608-29-0;
InChIKey    HQGMQJUEHLYMOY-UHFFFAOYSA-N;
MW          261.145;      // g/mol [origin=calculated method=formula-sum]
Tc          939.74;      // K   [origin=predictive method=joback]
Pc          27.614;      // bar [origin=predictive method=joback]
omega       0.5966;      // -   [origin=predictive method=lee-kesler]
Tb          677.22;      // K   [origin=predictive method=joback]
HvapTb      61480.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-153.35 1.7616 -0.00181812 7.446e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH; count 2; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)-1a,9b-dihydrocyclopropa[l]phenanthrene" "1h-cyclopropa(l)phenanthrene, 1,1-dichloro-1a,9b-dihydro-" "1h-cyclopropa[l]phenanthrene, 1,1-dichloro-1a,9b-dihydro-" "agn-pc-03d2b7" "1h-cyclopropa[l]phenanthrene,1,1-dichloro-1a,9b-dihydro-" );
standardThermochemistry
{
    dHf_298   224690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=401720.0
}
