/*--------------------------------*- Choupo -*-----------------------*\
  Component: bikhaconitine  (C36H51NO11, CAS 6078-26-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bikhaconitine;
formula     C36H51NO11;
CAS         6078-26-8;
InChIKey    CYIFGHJXUWZGSW-GRXCUHEDSA-N;
MW          673.8;      // g/mol [origin=calculated method=formula-sum]
Tc          1833.61;      // K   [origin=predictive method=joback]
Pc          7.523;      // bar [origin=predictive method=joback]
omega       0.3084;      // -   [origin=predictive method=lee-kesler]
Tb          1424.21;      // K   [origin=predictive method=joback]
HvapTb      140037.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-296.568 4.78266 -0.00418332 1.5875e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 9; } { group C; count 4; } { group ACH; count 3; } { group AC; count 3; } { group OH; count 1; } { group CH3COO; count 1; } { group CH3O; count 6; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 9; } { group C_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 6; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -1729980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1116.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-642820.0
    phase     gas;
}
