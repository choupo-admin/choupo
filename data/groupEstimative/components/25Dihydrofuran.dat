/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dihydrofuran  (C4H6O, CAS 1708-29-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dihydrofuran;
formula     C4H6O;
CAS         1708-29-8;
InChIKey    ARGCQEVBJHPOGB-UHFFFAOYSA-N;
MW          70.091;      // g/mol [origin=calculated method=formula-sum]
Tc          538.24;      // K   [origin=predictive method=joback]
Pc          53.907;      // bar [origin=predictive method=joback]
omega       0.2259;      // -   [origin=predictive method=lee-kesler]
Tb          337.18;      // K   [origin=predictive method=joback]
HvapTb      29866.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.07 0.483 -0.00034998 9.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "furan, 2,5-dihydro-" "3-oxolene" "1-oxa-3-cyclopentene" "furan,5-dihydro-" "2,5-dihydro-furan" );
gibbsFormation
{
    dHf_298   -119290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     215.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29100.0
    phase     gas;
}
