/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylcarbamazine citrate  (C16H29N3O8, CAS 1642-54-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylcarbamazineCitrate;
formula     C16H29N3O8;
CAS         1642-54-2;
InChIKey    PGNKBEARDDELNB-UHFFFAOYSA-N;
MW          391.421;      // g/mol [origin=calculated method=formula-sum]
Tc          1480.69;      // K   [origin=predictive method=joback]
Pc          20.309;      // bar [origin=predictive method=joback]
omega       1.4901;      // -   [origin=predictive method=lee-kesler]
Tb          1199.43;      // K   [origin=predictive method=joback]
HvapTb      131648.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.236 2.14136 -0.0014001 3.2846e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C; count 1; } { group OH; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } { group COOH; count 3; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group CH2_ring; count 4; } { group OH; count 1; } { group CdO; count 1; } { group COOH; count 3; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-4-methyl-piperazine-1-carboxamide;2-oxidanylpropane-1,2,3-tricarboxylic acid" "caritrol" "dicarocide" "eosinopin" "filazine" "franocide" "franozan" "loxuran" "carbam palatabs" "ethodryl citrate" "diro-form" "dec chewable" );
gibbsFormation
{
    dHf_298   -1519990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1105.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-926850.0
    phase     gas;
}
