/*--------------------------------*- Choupo -*-----------------------*\
  Component: formic acid, methyl ester, polymer with n-(3-(dimethoxymethylsilyl)propyl)-1,2-ethanediamine and octamethylcyclotetrasiloxane  (C18H48N2O8Si5, CAS 168811-63-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C18H48N2O8Si5 (delta C+1H+1O+2Si+5; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        formicAcidMethylEsterPolymerWithN3DimethoxymethylsilylPropyl;
formula     C18H48N2O8Si5;
CAS         168811-63-0;
InChIKey    WLWASPVYRQGVLN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          561.013;      // g/mol [origin=calculated method=formula-sum]
Tc          1096.59;      // K   [origin=predictive method=joback]
Pc          8.520;      // bar [origin=predictive method=joback]
omega       0.7207;      // -   [origin=predictive method=lee-kesler]
Tb          886.84;      // K   [origin=predictive method=joback]
HvapTb      94996.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (274.515 0.65832 0.0013336 -1.0293e-06);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 11; } { group CH2; count 5; } { group CH; count 1; } { group O; count 2; } { group O_ring; count 4; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-azanylethylamino)propyl-(dimethoxymethyl)silicon;methyl methanoate;2,2,4,4,6,6,8,8-octamethyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" "formic acid, methyl ester, polymer with n1-(3-(dimethoxymethylsilyl)propyl)-1,2-ethanediamine and 2,2,4,4,6,6,8,8-octamethylcyclotetrasiloxane" );
gibbsFormation
{
    dHf_298   -1631600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1652.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-828640.0
    phase     gas;
}
