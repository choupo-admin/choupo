/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethylbenzene-1,2-diamine  (C8H12N2, CAS 41927-01-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dimethylbenzene12Diamine;
formula     C8H12N2;
CAS         41927-01-9;
InChIKey    MHQULXYNBKWNDF-UHFFFAOYSA-N;
MW          136.198;      // g/mol [origin=calculated method=formula-sum]
Tc          805.81;      // K   [origin=predictive method=joback]
Pc          39.755;      // bar [origin=predictive method=joback]
omega       0.6478;      // -   [origin=predictive method=lee-kesler]
Tb          569.32;      // K   [origin=predictive method=joback]
HvapTb      58946.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.59 0.63024 -0.00032828 5.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 2; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dimethyl-o-phenylenediamine" "2-amino-3,4-dimethylphenylamine" "3,4-dimethyl-benzene-1,2-diamine" "1,2-benzenediamine, 3,4-dimethyl-" "1,2-benzenediamine,3,4-dimethyl-" "o-phenylenediamine,3,4-dimethyl- (7ci);1,2-diamino-3,4-dimethylbenzene;3,4-diamino-o-xylene;3,4-dimethyl-1,2-benzenediamine;3,4-dimethyl-1,2-phenylenediamine;3,4-dimethyl-o-phenylenediamine;" );
standardThermochemistry
{
    dHf_298   61250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=232900.0
}
