/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyltrimethylsilane  (C10H16Si, CAS 770-09-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzyltrimethylsilane;
formula     C10H16Si;
CAS         770-09-2;
InChIKey    MRIWRLGWLMRJIW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          164.323;      // g/mol [origin=calculated method=formula-sum]
Tc          668.49;      // K   [origin=predictive method=joback]
Pc          25.846;      // bar [origin=predictive method=joback]
omega       0.2943;      // -   [origin=predictive method=lee-kesler]
Tb          456.48;      // K   [origin=predictive method=joback]
HvapTb      40424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.711 0.66876 -0.0001366 -8.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-(phenylmethyl)silane" "silane, benzyltrimethyl-" "silane, trimethyl(phenylmethyl)-" "alpha-trimethylsilyltoluene" "trimethylbenzylsilane" "benzyl(trimethyl)silane" "benzene, ((trimethylsilyl)methyl)-" "benzene, [(trimethylsilyl)methyl]-" "silane, benzyltrimethyl- (8ci)" );
standardThermochemistry
{
    dHf_298   -124820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40970.0
}
