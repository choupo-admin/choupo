/*--------------------------------*- Choupo -*-----------------------*\
  Component: allylcyclohexylamine  (C9H17N, CAS 6628-00-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylcyclohexylamine;
formula     C9H17N;
CAS         6628-00-8;
InChIKey    SQGBZKZDUMBTIJ-UHFFFAOYSA-N;
MW          139.242;      // g/mol [origin=calculated method=formula-sum]
Tc          678.13;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       0.4435;      // -   [origin=predictive method=lee-kesler]
Tb          471.92;      // K   [origin=predictive method=joback]
HvapTb      41823.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.099 1.0371 -0.0006183 1.334e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-prop-2-enylcyclohexanamine" "n-allylcyclohexanamine" "cyclohexylprop-2-enylamine" "n-allylcyclohexylamine" "cyclohexanamine, n-2-propenyl-" );
gibbsFormation
{
    dHf_298   4130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=226580.0
    phase     gas;
}
