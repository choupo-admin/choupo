/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-acetylindoline  (C10H11NO, CAS 16078-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Acetylindoline;
formula     C10H11NO;
CAS         16078-34-5;
InChIKey    GYMZRGMAWRJZPV-UHFFFAOYSA-N;
MW          161.204;      // g/mol [origin=calculated method=formula-sum]
Tc          817.65;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.6376;      // -   [origin=predictive method=lee-kesler]
Tb          578.87;      // K   [origin=predictive method=joback]
HvapTb      55180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.41 0.89192 -0.00061362 1.6906e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3CO; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group CdO; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,3-dihydro-1h-indol-5-yl)ethanone" "1-(2,3-dihydro-1h-indol-5-yl)-ethanone" "1-(indolin-5-yl)ethanone" "ethanone,3-dihydro-1h-indol-5-yl)-" "ethanone,1-(2,3-dihydro-1h-indol-5-yl)-" );
gibbsFormation
{
    dHf_298   -17770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=153720.0
    phase     gas;
}
