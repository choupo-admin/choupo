/*--------------------------------*- Choupo -*-----------------------*\
  Component: decyl methyl sulfide  (C11H24S, CAS 22438-39-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decylMethylSulfide;
formula     C11H24S;
CAS         22438-39-7;
InChIKey    HKGUUZAACYBIID-UHFFFAOYSA-N;
MW          188.373;      // g/mol [origin=calculated method=formula-sum]
Tc          700.27;      // K   [origin=predictive method=joback]
Pc          19.631;      // bar [origin=predictive method=joback]
omega       0.6110;      // -   [origin=predictive method=lee-kesler]
Tb          520.06;      // K   [origin=predictive method=joback]
HvapTb      46897.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.489 1.04323 -0.0005344 9.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylsulfanyldecane" "n-decyl methyl sulfide" "decyl methyl sulphide" "1-(methylsulfanyl)decane" "decane, 1-(methylthio)-" "sulfide,decyl methyl (6ci,7ci,8ci); 1-(methylthio)decane; 2-thiadodecane; decyl methylsulfide; methyl decyl sulfide; n-decyl methyl sulfide" );
gibbsFormation
{
    dHf_298   -228500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     645.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74860.0
    phase     gas;
}
