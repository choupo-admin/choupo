/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(methylamino)propanenitrile  (C4H8N2, CAS 693-05-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethylaminoPropanenitrile;
formula     C4H8N2;
CAS         693-05-0;
InChIKey    UNIJBMUBHBAUET-UHFFFAOYSA-N;
MW          84.122;      // g/mol [origin=calculated method=formula-sum]
Tc          639.55;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.5260;      // -   [origin=predictive method=lee-kesler]
Tb          443.37;      // K   [origin=predictive method=joback]
HvapTb      41412.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.042 0.39482 -0.0002114 4.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3NH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylaminopropionitrile" "propanenitrile, 3-(methylamino)-" "3-(methylamino)propionitrile" "(2-cyanoethyl)methyl amine" "propionitrile, 3-(methylamino)-" "(2-cyanoethyl)methylamine" "n-methyl-beta-alaninenitrile" "n-(2-cyanoethyl)methylamine" "beta-(methylamino)propionitrile" "n-(beta-cyanoethyl)methylamine" "3-(methyl amino)-propionitrile" "3-(n-methylamino)propionitrile" );
gibbsFormation
{
    dHf_298   92460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=205370.0
    phase     gas;
}
