/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethyl-2-methyl-1,5-hexadiene  (C9H16, CAS 73398-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethyl2Methyl15Hexadiene;
formula     C9H16;
CAS         73398-15-9;
InChIKey    MROJOHIMEYEXNY-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          575.38;      // K   [origin=predictive method=joback]
Pc          25.379;      // bar [origin=predictive method=joback]
omega       0.3465;      // -   [origin=predictive method=lee-kesler]
Tb          398.32;      // K   [origin=predictive method=joback]
HvapTb      33980.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.648 0.82464 -0.0005171 1.32e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-2-methyl-hexa-1,5-diene" "agn-pc-03cz5i" "3-ethyl-2-methylhexa-1,5-diene" );
standardThermochemistry
{
    dHf_298   6700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=189590.0
}
