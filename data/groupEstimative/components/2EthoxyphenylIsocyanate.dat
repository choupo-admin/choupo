/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethoxyphenyl isocyanate  (C9H9NO2, CAS 5395-71-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthoxyphenylIsocyanate;
formula     C9H9NO2;
CAS         5395-71-1;
InChIKey    BUIQXUQLYZPMLS-UHFFFAOYSA-N;
MW          163.176;      // g/mol [origin=calculated method=formula-sum]
Tc          742.66;      // K   [origin=predictive method=joback]
Pc          34.239;      // bar [origin=predictive method=joback]
omega       0.5977;      // -   [origin=predictive method=lee-kesler]
Tb          526.27;      // K   [origin=predictive method=joback]
HvapTb      50508.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxy-2-isocyanato-benzene" "1-ethoxy-2-isocyanatobenzene" "o-ethoxyphenyl isocyanate" "benzene, 1-ethoxy-2-isocyanato-" "isocyanic acid, o-ethoxyphenyl ester" "2-ethoxybenzenisocyanate" "benzene,1-ethoxy-2-isocyanato-" "o-ethoxyphenyl isocyanate;2-ethoxybenzenisocyanate;" );
