/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,2-trichloro-1-(4-fluorophenyl)ethanol  (C8H6Cl3FO, CAS 394-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222Trichloro14FluorophenylEthanol;
formula     C8H6Cl3FO;
CAS         394-56-9;
InChIKey    NXMVOAIYDICRQK-UHFFFAOYSA-N;
MW          243.483;      // g/mol [origin=calculated method=formula-sum]
Tc          832.84;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       0.8696;      // -   [origin=predictive method=lee-kesler]
Tb          614.37;      // K   [origin=predictive method=joback]
HvapTb      63673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.09 0.8233 -0.00065856 1.984e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group CCl3; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group Cl; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(chloranyl)-1-(4-fluorophenyl)ethanol" "benzyl alcohol, p-fluoro-" "a-(trichloromethyl)-" "benzyl alcohol, p-fluoro-alpha-(trichloromethyl)-" );
gibbsFormation
{
    dHf_298   -392980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-247760.0
    phase     gas;
}
