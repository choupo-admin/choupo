/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,1'-(1,3,5,7,9-decapentaene-1,10-diyl)bis-  (C22H20, CAS 3029-41-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1113579Decapentaene110DiylBis;
formula     C22H20;
CAS         3029-41-2;
InChIKey    NODIXMQDAGGDJQ-GDHZPREYSA-N;
MW          284.402;      // g/mol [origin=calculated method=formula-sum]
Tc          1025.49;      // K   [origin=predictive method=joback]
Pc          17.246;      // bar [origin=predictive method=joback]
omega       0.6783;      // -   [origin=predictive method=lee-kesler]
Tb          777.12;      // K   [origin=predictive method=joback]
HvapTb      68908.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-155.83 2.036 -0.0016544 5.386e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 5; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 10; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1e,3e,5e,7e,9e)-10-phenyldeca-1,3,5,7,9-pentaenyl]benzene" );
gibbsFormation
{
    dHf_298   561750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     767.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=760280.0
    phase     gas;
}
