/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(m-tolyloxy)ethane  (C16H18O2, CAS 54914-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12BisMTolyloxyEthane;
formula     C16H18O2;
CAS         54914-85-1;
InChIKey    OAGNKYSIOSDNIG-UHFFFAOYSA-N;
MW          242.318;      // g/mol [origin=calculated method=formula-sum]
Tc          899.47;      // K   [origin=predictive method=joback]
Pc          21.513;      // bar [origin=predictive method=joback]
omega       0.7247;      // -   [origin=predictive method=lee-kesler]
Tb          673.84;      // K   [origin=predictive method=joback]
HvapTb      61906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.132 1.12064 -0.00055292 7.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3-[2-(3-methylphenoxy)ethoxy]benzene" "1,2-bis(3-methylphenoxy)ethane" "benzene, 1,1'-[1,2-ethanediylbis(oxy)]bis[3-methyl-" "1,1'-[ethane-1,2-diylbis(oxy)]bis(3-methylbenzene)" "benzene, 1,1'-(1,2-ethanediylbis(oxy))bis(3-methyl-" "3-methyl-1-[2-(3-methylphenoxy)ethoxy]benzene" );
gibbsFormation
{
    dHf_298   -187890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79400.0
    phase     gas;
}
