/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenylbutylamine  (C10H15N, CAS 13214-66-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenylbutylamine;
formula     C10H15N;
CAS         13214-66-9;
InChIKey    AGNFWIZBEATIAK-UHFFFAOYSA-N;
MW          149.237;      // g/mol [origin=calculated method=formula-sum]
Tc          743.45;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.5639;      // -   [origin=predictive method=lee-kesler]
Tb          527.61;      // K   [origin=predictive method=joback]
HvapTb      50771.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.616 0.9368 -0.0005948 1.443e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenylbutan-1-amine" "benzenebutanamine" "1-amino-4-phenylbutane" "4-phenylbutylammonium chloride" "4-phenyl-butylamine" "phenylbutylamine, 4-" "4-phenyl-1-butylamine" "agnfwizbeatiak-uhfffaoysa-" "butylamine, 4-phenyl-, hydrochloride" );
gibbsFormation
{
    dHf_298   20590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212180.0
    phase     gas;
}
