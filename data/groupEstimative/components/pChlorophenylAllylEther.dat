/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-chlorophenyl allyl ether  (C9H9ClO, CAS 13997-70-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pChlorophenylAllylEther;
formula     C9H9ClO;
CAS         13997-70-1;
InChIKey    KWXDOKLIYYAHJN-UHFFFAOYSA-N;
MW          168.62;      // g/mol [origin=calculated method=formula-sum]
Tc          711.59;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       0.4491;      // -   [origin=predictive method=lee-kesler]
Tb          493.71;      // K   [origin=predictive method=joback]
HvapTb      44691.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.501 0.644 -0.00036226 6.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-prop-2-enoxy-benzene" "1-allyloxy-4-chlorobenzene" "allyl p-chlorophenyl ether" "benzene, 1-chloro-4-(2-propenyloxy)-" "1-chloro-4-(prop-2-en-1-yloxy)benzene" "ether, allyl p-chlorophenyl" "allyl (4-chlorophenyl) ether" "1-(allyloxy)-4-chlorobenzene" "1-chloro-4-prop-2-enoxybenzene" "benzene, 1-(allyloxy)-4-chloro-" "1-allyloxy-4-chloro benzene" "(4-chlorophenyl) (2-propenyl) ether" );
standardThermochemistry
{
    dHf_298   -26560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98590.0
}
