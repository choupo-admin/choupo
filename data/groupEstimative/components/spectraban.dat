/*--------------------------------*- Choupo -*-----------------------*\
  Component: spectraban  (C14H21NO2, CAS 21245-01-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spectraban;
formula     C14H21NO2;
CAS         21245-01-2;
InChIKey    OFSAUHSCHWRZKM-UHFFFAOYSA-N;
MW          235.327;      // g/mol [origin=calculated method=formula-sum]
Tc          821.90;      // K   [origin=predictive method=joback]
Pc          20.019;      // bar [origin=predictive method=joback]
omega       0.7566;      // -   [origin=predictive method=lee-kesler]
Tb          621.80;      // K   [origin=predictive method=joback]
HvapTb      58758.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.408 1.27048 -0.00072316 1.358e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutyl 4-(dimethylamino)benzoate" "isoamyl 4-(dimethylamino)benzoate" "3-methylbutyl-4-dimethylaminobenzoate" "isoamyl para-n,n-dimethylaminobenzoate" "4-dimethylaminobenzoic acid isoamyl ester" "benzoic acid, 4-(dimethylamino)-, 3-methylbutyl ester" "padimato" "padimatum [inn-latin]" "3-methylbutyl 4-dimethylaminobenzoate" "m796" "4-(dimethylamino)benzoic acid isoamyl ester" "4-(dimethylamino)benzoic acid 3-methylbutyl ester" );
standardThermochemistry
{
    dHf_298   -362260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32250.0
}
