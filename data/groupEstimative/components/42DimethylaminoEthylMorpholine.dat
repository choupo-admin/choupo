/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[2-(dimethylamino)ethyl]morpholine  (C8H18N2O, CAS 4385-05-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        42DimethylaminoEthylMorpholine;
formula     C8H18N2O;
CAS         4385-05-1;
InChIKey    PMHXGHYANBXRSZ-UHFFFAOYSA-N;
MW          158.245;      // g/mol [origin=calculated method=formula-sum]
Tc          643.67;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.5365;      // -   [origin=predictive method=lee-kesler]
Tb          454.42;      // K   [origin=predictive method=joback]
HvapTb      42564.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.868 1.16684 -0.0008055 2.178e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group FCH2O; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-2-morpholin-4-yl-ethanamine" "4-morpholineethanamine, n,n-dimethyl-" "n,n-dimethyl-4-morpholineethanamine" "4-(2-(dimethylamino)ethyl)morpholine" "n-(2-dimethylaminoethyl)morpholine" "n,n-dimethyl-2-morpholinoethanamine" "dimethyl(2-morpholin-4-ylethyl)amine" "r433" "n,n-dimethyl-2-(4-morpholinyl)ethanamine" );
gibbsFormation
{
    dHf_298   -124570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196180.0
    phase     gas;
}
