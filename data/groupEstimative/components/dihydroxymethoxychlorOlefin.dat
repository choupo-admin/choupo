/*--------------------------------*- Choupo -*-----------------------*\
  Component: dihydroxymethoxychlor olefin  (C14H10Cl2O2, CAS 14868-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dihydroxymethoxychlorOlefin;
formula     C14H10Cl2O2;
CAS         14868-03-2;
InChIKey    OWEYKIWAZBBXJK-UHFFFAOYSA-N;
MW          281.132;      // g/mol [origin=calculated method=formula-sum]
Tc          1091.16;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       1.0165;      // -   [origin=predictive method=lee-kesler]
Tb          813.30;      // K   [origin=predictive method=joback]
HvapTb      86226.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.27 1.5186 -0.00144212 5.416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2,2-bis(chloranyl)-1-(4-hydroxyphenyl)ethenyl]phenol" "1,1-dichloro-2,2-bis(4-hydroxyphenyl)ethylene" "4,4'-(2,2-dichloroethene-1,1-diyl)diphenol" "phenol, 4,4'-(dichloroethenylidene)bis-" "phenol, 4,4'-(2,2-dichloroethenylidene)bis-" "4-[2,2-dichloro-1-(4-hydroxyphenyl)ethenyl]phenol" "4,4'-(dichlorovinylidene)diphenol" "4,4'-(dichloroethenylidene)bis[phenol]" "4,4'-(2,2-dichlorovinylidene)bisphenol" "bim-0020410.p001" "1,1-bis(4-hydroxyphenyl)-2,2-dichloroethylene" "1,1-bis-(4-hydroxyphenyl)-2,2-dichloroethylene" );
standardThermochemistry
{
    dHf_298   -147690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21840.0
}
