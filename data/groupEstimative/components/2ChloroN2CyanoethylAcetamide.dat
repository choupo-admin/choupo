/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-n-(2-cyanoethyl)acetamide  (C5H7ClN2O, CAS 17756-81-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroN2CyanoethylAcetamide;
formula     C5H7ClN2O;
CAS         17756-81-9;
InChIKey    WECIKJKLCDCIMY-UHFFFAOYSA-N;
MW          146.574;      // g/mol [origin=calculated method=formula-sum]
Tc          765.99;      // K   [origin=predictive method=joback]
Pc          35.263;      // bar [origin=predictive method=joback]
omega       0.7848;      // -   [origin=predictive method=lee-kesler]
Tb          557.55;      // K   [origin=predictive method=joback]
HvapTb      54769.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.383 0.4686 -0.0002675 5.246e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2CN; count 1; } { group CH2Cl; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group Cl; count 1; } { group CdO; count 1; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n-(2-cyanoethyl)ethanamide" "ceca" "udankor" "udonkor" "nf 21" "acetamide, 2-chloro-n-(2-cyanoethyl)-" "n-(beta-cyanoethyl)chloroacetamide" "n-(beta-cyanoethyl)monochloroacetamide" );
standardThermochemistry
{
    dHf_298   -56500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72940.0
}
