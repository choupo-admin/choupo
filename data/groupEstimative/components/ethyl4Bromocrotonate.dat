/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 4-bromocrotonate  (C6H9BrO2, CAS 37746-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl4Bromocrotonate;
formula     C6H9BrO2;
CAS         37746-78-4;
InChIKey    FHGRPBSDPBRTLS-ONEGZZNKSA-N;
MW          193.04;      // g/mol [origin=calculated method=formula-sum]
Tc          665.95;      // K   [origin=predictive method=joback]
Pc          35.942;      // bar [origin=predictive method=joback]
omega       0.5412;      // -   [origin=predictive method=lee-kesler]
Tb          465.42;      // K   [origin=predictive method=joback]
HvapTb      42750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.852 0.57722 -0.0003632 8.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 2; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (e)-4-bromanylbut-2-enoate" "4-bromocrotonic acid ethyl ester" "(e)-ethyl 4-bromobut-2-enoate" "ethyl (e)-4-bromo-2-butenoate" "ethyl trans-4-bromo-2-butenoate" "2-butenoic acid, 4-bromo-, ethyl ester, (e)-" "ethyl (2e)-4-bromobut-2-enoate" "2-butenoic acid, 4-bromo-, ethyl ester" "(e)-4-bromo-2-butenoic acid ethyl ester" "ethyl 4-bromobut-2-enoate" "ethyl (e)-4-bromobut-2-enoate" "ethyl (2e)-4-bromo-2-butenoate" );
gibbsFormation
{
    dHf_298   -340900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-216190.0
    phase     gas;
}
