/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tetradecoxyaniline  (C20H35NO, CAS 41710-89-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Tetradecoxyaniline;
formula     C20H35NO;
CAS         41710-89-8;
InChIKey    IXZBAJOADDIGIP-UHFFFAOYSA-N;
MW          305.506;      // g/mol [origin=calculated method=formula-sum]
Tc          976.88;      // K   [origin=predictive method=joback]
Pc          12.921;      // bar [origin=predictive method=joback]
omega       0.9889;      // -   [origin=predictive method=lee-kesler]
Tb          783.81;      // K   [origin=predictive method=joback]
HvapTb      76103.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.907 1.76412 -0.00096076 1.836e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tetradecyloxyaniline" "2-(tetradecyloxy)aniline" "benzenamine, 2-(tetradecyloxy)-" );
gibbsFormation
{
    dHf_298   -329500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     885.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=181750.0
    phase     gas;
}
