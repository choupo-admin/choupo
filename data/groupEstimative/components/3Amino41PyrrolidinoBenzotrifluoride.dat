/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-amino-4-(1-pyrrolidino)benzotrifluoride  (C11H13F3N2, CAS 133184-80-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Amino41PyrrolidinoBenzotrifluoride;
formula     C11H13F3N2;
CAS         133184-80-2;
InChIKey    HPDFKXPVMXSXGE-UHFFFAOYSA-N;
MW          230.233;      // g/mol [origin=calculated method=formula-sum]
Tc          798.30;      // K   [origin=predictive method=joback]
Pc          29.345;      // bar [origin=predictive method=joback]
omega       0.7151;      // -   [origin=predictive method=lee-kesler]
Tb          583.15;      // K   [origin=predictive method=joback]
HvapTb      53011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.12 1.3657 -0.00107792 3.301e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 3; } { group AC; count 2; } { group CH2N; count 1; } { group ACNH2; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 3; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pyrrolidin-1-yl-5-(trifluoromethyl)aniline" "2-(1-pyrrolidinyl)-5-(trifluoromethyl)aniline" "2-(pyrrolidin-1-yl)-5-(trifluoromethyl)aniline" "n-[2-amino-4-(trifluoromethyl)phenyl]pyrrolidine" "n-(2-amino-4-trifluoromethylphenyl)pyrrolidine" "2-pyrrolidin-1-yl-5-trifluoromethyl-phenylamine" "2-pyrrolidinyl-5-(trifluoromethyl)phenylamine" "n-[2-amino-4-trifluoromethylphenyl]pyrrolidine" "2-pyrrolidin-1-yl-5-trifluoromethyl-phenylamin e" );
standardThermochemistry
{
    dHf_298   -465560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-213110.0
}
