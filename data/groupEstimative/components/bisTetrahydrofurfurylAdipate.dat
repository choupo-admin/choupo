/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(tetrahydrofurfuryl)adipate  (C16H26O6, CAS 105-02-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisTetrahydrofurfurylAdipate;
formula     C16H26O6;
CAS         105-02-2;
InChIKey    DMNQTEVDCGAATA-UHFFFAOYSA-N;
MW          314.378;      // g/mol [origin=calculated method=formula-sum]
Tc          972.47;      // K   [origin=predictive method=joback]
Pc          17.332;      // bar [origin=predictive method=joback]
omega       1.0301;      // -   [origin=predictive method=lee-kesler]
Tb          766.58;      // K   [origin=predictive method=joback]
HvapTb      75558.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.164 1.6716 -0.0008844 1.266e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 2; } { group CH2COO; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group O_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(oxolan-2-ylmethyl) hexanedioate" "bis(tetrahydrofurfuryl) adipate" "bis(tetrahydrofuran-2-ylmethyl) adipate" "hexanedioic acid, bis[(tetrahydro-2-furanyl)methyl] ester" "hexanedioic acid, bis((tetrahydro-2-furanyl)methyl) ester" "hexanedioic acid, 1,6-bis((tetrahydro-2-furanyl)methyl) ester" "hexanedioic acid, 1,6-bis[(tetrahydro-2-furanyl)methyl] ester" "adipic acid, bis(tetrahydrofurfuryl) ester (8ci)" "adipic acid, bis(tetrahydrofurfuryl) ester" );
standardThermochemistry
{
    dHf_298   -1151170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     678.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-636040.0
}
