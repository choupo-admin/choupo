/*--------------------------------*- Choupo -*-----------------------*\
  Component: dichloromethane-d2  (CD2Cl2, CAS 1665-00-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula CD2Cl2 (delta D+2H-2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dichloromethaneD2;
formula     CD2Cl2;
CAS         1665-00-5;
InChIKey    YMWUJEATGCHHMB-DICFDUPASA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          86.939;      // g/mol [origin=calculated method=formula-sum]
Tc          478.88;      // K   [origin=predictive method=joback]
Pc          51.906;      // bar [origin=predictive method=joback]
omega       0.1874;      // -   [origin=predictive method=lee-kesler]
Tb          297.34;      // K   [origin=predictive method=joback]
HvapTb      26590.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.761 0.1124 -7.14e-05 1.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2Cl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(chloranyl)-dideuterio-methane" "methylene chloride-d2" "dideuteromethylenechloride" "dideuteromethylene chloride" "methane-d2, dichloro-" "dichloro(2h2)methane" "deuterated dichloromethane" "methane-d2-, dichloro-" "dichloro(dideuterio)methane" "dichloromethane, deuterated" "de780" "methylene chloride-d2 >99.95 atom % d" );
gibbsFormation
{
    dHf_298   -95450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     261.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-66320.0
    phase     gas;
}
