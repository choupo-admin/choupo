/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,8-trimethyldecane  (C13H28, CAS 62238-01-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        228Trimethyldecane;
formula     C13H28;
CAS         62238-01-1;
InChIKey    ZXPYELGEJQYCMG-UHFFFAOYSA-N;
MW          184.367;      // g/mol [origin=calculated method=formula-sum]
Tc          665.90;      // K   [origin=predictive method=joback]
Pc          16.810;      // bar [origin=predictive method=joback]
omega       0.5095;      // -   [origin=predictive method=lee-kesler]
Tb          493.37;      // K   [origin=predictive method=joback]
HvapTb      42848.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.084 1.3706 -0.0008584 2.149e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decane, 2,2,8-trimethyl-" );
gibbsFormation
{
    dHf_298   -325680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58980.0
    phase     gas;
}
