/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-carvone  (C10H14O, CAS 2244-16-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dCarvone;
formula     C10H14O;
CAS         2244-16-8;
InChIKey    ULDHMXUKGWMISQ-VIFPVBQESA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          742.52;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       0.4190;      // -   [origin=predictive method=lee-kesler]
Tb          516.47;      // K   [origin=predictive method=joback]
HvapTb      42894.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.98 0.77204 -0.00030264 2.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5s)-2-methyl-5-prop-1-en-2-yl-cyclohex-2-en-1-one" "(s)-(+)-carvone" "(s)-carvone" "(+)-carvone" "(+)-(s)-carvone" "d(+)-carvone" "carvol" "(s)-(+)-p-mentha-6,8-dien-2-one" "d-(+)-carvone" "carvone, (+)-" "(+)-(4s)-carvone" "d-carvone (natural)" );
gibbsFormation
{
    dHf_298   -171160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=34800.0
    phase     gas;
}
