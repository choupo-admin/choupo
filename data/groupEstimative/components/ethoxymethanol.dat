/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethoxymethanol  (C3H8O2, CAS 10171-38-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethoxymethanol;
formula     C3H8O2;
CAS         10171-38-7;
InChIKey    RRLWYLINGKISHN-UHFFFAOYSA-N;
MW          76.095;      // g/mol [origin=calculated method=formula-sum]
Tc          545.81;      // K   [origin=predictive method=joback]
Pc          48.834;      // bar [origin=predictive method=joback]
omega       0.6952;      // -   [origin=predictive method=lee-kesler]
Tb          382.84;      // K   [origin=predictive method=joback]
HvapTb      41361.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.952 0.25962 -5.88e-05 -2.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxy-1-hydroxymethane" "methanol, ethoxy-(7ci,8ci,9ci)" "formaldehyde,ethyl hemiacetal; ethoxymethanol; sapozhok 74" );
gibbsFormation
{
    dHf_298   -389700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     335.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-267440.0
    phase     gas;
}
