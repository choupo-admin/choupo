/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(1-sec-butyl-2-(dimethylamino)ethyl)phenol  (C14H23NO, CAS 69745-66-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        41SecButyl2DimethylaminoEthylPhenol;
formula     C14H23NO;
CAS         69745-66-0;
InChIKey    MTJOZEKFPWZGCS-UHFFFAOYSA-N;
MW          221.344;      // g/mol [origin=calculated method=formula-sum]
Tc          851.02;      // K   [origin=predictive method=joback]
Pc          22.871;      // bar [origin=predictive method=joback]
omega       0.8424;      // -   [origin=predictive method=lee-kesler]
Tb          644.20;      // K   [origin=predictive method=joback]
HvapTb      64365.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.737 1.47988 -0.00107412 3.26e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-butan-2-yl-2-[2-(dimethylamino)ethyl]phenol" "phenol, 4-(1-(sec-butyl)-2-(dimethylamino)ethyl)-" "4-butan-2-yl-2-(2-dimethylaminoethyl)phenol" );
standardThermochemistry
{
    dHf_298   -222290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     621.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=123500.0
}
