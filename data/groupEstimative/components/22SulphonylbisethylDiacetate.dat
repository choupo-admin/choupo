/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-sulphonylbisethyl diacetate  (C8H14O6S, CAS 3763-72-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H14O6S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        22SulphonylbisethylDiacetate;
formula     C8H14O6S;
CAS         3763-72-2;
InChIKey    ZNEZVLKEOCTFHJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          238.254;      // g/mol [origin=calculated method=formula-sum]
Tc          635.46;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       0.9255;      // -   [origin=predictive method=lee-kesler]
Tb          478.08;      // K   [origin=predictive method=joback]
HvapTb      60034.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.074 0.69344 -0.0001968 -6.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3COO; count 2; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group COO; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-acetyloxyethylsulfonyl)ethyl ethanoate" "bis(acetoxyethyl)sulfone" "bis(2-acetoxyethyl)sulfone" "sulfone, bis(2-acetoxyethyl)" "2,2'-sulfonyldiethanol diacetate" "2,2'-sulfonylbisethanol diacetate" "ethanol, 2,2'-sulfonyldi-, diacetate (7ci,8ci)" "sulfonyldiethane-2,1-diyl diacetate" "ethanol, 2,2'-sulfonylbis-, diacetate" "2-(2-acetyloxyethylsulfonyl)ethyl acetate" "ethanol,2,2'-sulfonylbis-, diacetate (9ci)" "ethanol, 2,2'-sulfonylbis-, diacetate (9ci)" );
standardThermochemistry
{
    dHf_298   -1338230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     828.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1105920.0
}
