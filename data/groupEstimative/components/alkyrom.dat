/*--------------------------------*- Choupo -*-----------------------*\
  Component: alkyrom  (C12H15Cl2NO2, CAS 5977-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alkyrom;
formula     C12H15Cl2NO2;
CAS         5977-35-5;
InChIKey    DKROWFJGHDLNFQ-UHFFFAOYSA-N;
MW          276.157;      // g/mol [origin=calculated method=formula-sum]
Tc          961.46;      // K   [origin=predictive method=joback]
Pc          23.657;      // bar [origin=predictive method=joback]
omega       1.0580;      // -   [origin=predictive method=lee-kesler]
Tb          743.61;      // K   [origin=predictive method=joback]
HvapTb      73883.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.364 1.13422 -0.00075212 1.907e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CH2N; count 1; } { group COOH; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[bis(2-chloroethyl)amino]-4-methyl-benzoic acid" "iob 82" "3-bis(2-chloroethyl)amino-p-toluic acid" "p-toluic acid, 3-bis(2-chloroethyl)amino-" "3-bis(2-chloroethyl)amino-4-methylbenzoic acid" "4-methyl-3-bis(2-chloroethyl)aminobenzoic acid" "3-(bis(2-chloroethyl)amino)-4-methylbenzoic acid" "3-[bis(2-chloroethyl)amino]-4-methylbenzoic acid" "benzoic acid, 3-bis(2-chloroethyl)amino-4-methyl-" "benzoic acid, 3-(bis(2-chloroethyl)amino)-4-methyl-" "benzoic acid, 3-[bis(2-chloroethyl)amino]-4-methyl-" "52616-25-8 (hydrochloride salt)" );
gibbsFormation
{
    dHf_298   -391640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113680.0
    phase     gas;
}
