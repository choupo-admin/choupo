/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropylaminoethanol caprate  (C15H33NO3, CAS 64601-15-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylaminoethanolCaprate;
formula     C15H33NO3;
CAS         64601-15-6;
InChIKey    MQJFOCCWCPIOEV-UHFFFAOYSA-N;
MW          275.433;      // g/mol [origin=calculated method=formula-sum]
Tc          1021.53;      // K   [origin=predictive method=joback]
Pc          15.451;      // bar [origin=predictive method=joback]
omega       1.3187;      // -   [origin=predictive method=lee-kesler]
Tb          831.62;      // K   [origin=predictive method=joback]
HvapTb      89169.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.07 1.38956 -0.0005322 -2.1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 1; } { group OH; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decanoic acid;2-(propan-2-ylamino)ethanol" "decanoic acid, compound with 2-(isopropylamino)ethanol (1:1)" "decanoic acid; 2-(propan-2-ylamino)ethanol" "decanoic acid - 2-(propan-2-ylamino)ethanol (1:1)" "decanoic acid compd. with 2-[(1-methylethyl)amino]ethanol (1:1)" );
standardThermochemistry
{
    dHf_298   -918860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     983.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-423120.0
}
