/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenyldiethynylsilane  (C16H12Si, CAS 1675-57-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H12Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diphenyldiethynylsilane;
formula     C16H12Si;
CAS         1675-57-6;
InChIKey    GXVUNEVBRUNGTK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          232.357;      // g/mol [origin=calculated method=formula-sum]
Tc          876.39;      // K   [origin=predictive method=joback]
Pc          27.240;      // bar [origin=predictive method=joback]
omega       0.3310;      // -   [origin=predictive method=lee-kesler]
Tb          600.68;      // K   [origin=predictive method=joback]
HvapTb      55772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.09 0.972 -0.00048606 4.978e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CH_C; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 2; } { group tC; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethynyl(diphenyl)silane" "diethynyl-diphenyl-silane" "silane, diethynyldiphenyl-" "benzene,1,1'-(diethynylsilylene)bis-" "silane,diethynyldiphenyl- (7ci,8ci,9ci); diethynyldiphenylsilane;diphenyldiethynylsilane" );
gibbsFormation
{
    dHf_298   571670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     631.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=650040.0
    phase     gas;
}
