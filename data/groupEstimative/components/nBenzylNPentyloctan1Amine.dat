/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzyl-n-pentyloctan-1-amine  (C20H35N, CAS 70289-19-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzylNPentyloctan1Amine;
formula     C20H35N;
CAS         70289-19-9;
InChIKey    HZXJAHXCQKNONC-UHFFFAOYSA-N;
MW          289.507;      // g/mol [origin=calculated method=formula-sum]
Tc          878.43;      // K   [origin=predictive method=joback]
Pc          12.674;      // bar [origin=predictive method=joback]
omega       0.8489;      // -   [origin=predictive method=lee-kesler]
Tb          696.32;      // K   [origin=predictive method=joback]
HvapTb      64433.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.888 1.94884 -0.001208 2.897e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-pentyl-n-(phenylmethyl)octan-1-amine" "benzylamine, n-octyl-n-pentyl-" "benzylamine, n-octyl-n-pentyl-," );
gibbsFormation
{
    dHf_298   -152070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     844.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=340710.0
    phase     gas;
}
