/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyltrimethoxysilane  (C5H14O3Si, CAS 5314-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H14O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethyltrimethoxysilane;
formula     C5H14O3Si;
CAS         5314-55-6;
InChIKey    SBRXLTRZCJVAPH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          150.249;      // g/mol [origin=calculated method=formula-sum]
Tc          554.98;      // K   [origin=predictive method=joback]
Pc          28.627;      // bar [origin=predictive method=joback]
omega       0.3779;      // -   [origin=predictive method=lee-kesler]
Tb          382.66;      // K   [origin=predictive method=joback]
HvapTb      34248.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (115.661 0.08308 0.0004996 -3.333e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH3O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl(trimethoxy)silane" "silane, ethyltrimethoxy-" "silane,ethyltrimethoxy-" );
standardThermochemistry
{
    dHf_298   -654810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-428540.0
}
