/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenmetrazine  (C11H15NO, CAS 134-49-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenmetrazine;
formula     C11H15NO;
CAS         134-49-6;
InChIKey    OOBHFESNSZDWIU-UHFFFAOYSA-N;
MW          177.247;      // g/mol [origin=calculated method=formula-sum]
Tc          815.22;      // K   [origin=predictive method=joback]
Pc          32.467;      // bar [origin=predictive method=joback]
omega       0.4845;      // -   [origin=predictive method=lee-kesler]
Tb          568.34;      // K   [origin=predictive method=joback]
HvapTb      53744.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.44 1.04912 -0.0005569 8.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group FCH2O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-2-phenyl-morpholine" "3-methyl-2-phenylmorpholine" "fenmetrazin" "oxazimedrine" "defenmetrazin" "morpholine, 3-methyl-2-phenyl-" "phenmetrazin" "dexphenmetrazine" "probese-p" "psychamine a 66" "fenmetrazina" "phenmetraline" );
gibbsFormation
{
    dHf_298   -94050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     347.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172480.0
    phase     gas;
}
