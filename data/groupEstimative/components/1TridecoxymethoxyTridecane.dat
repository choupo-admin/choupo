/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(tridecoxymethoxy)tridecane  (C27H56O2, CAS 68975-76-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TridecoxymethoxyTridecane;
formula     C27H56O2;
CAS         68975-76-8;
InChIKey    HUORXJRUKHMTDN-UHFFFAOYSA-N;
MW          412.743;      // g/mol [origin=calculated method=formula-sum]
Tc          1059.05;      // K   [origin=predictive method=joback]
Pc          6.768;      // bar [origin=predictive method=joback]
omega       0.5821;      // -   [origin=predictive method=lee-kesler]
Tb          862.20;      // K   [origin=predictive method=joback]
HvapTb      80516.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.345 2.44244 -0.001223 2.005e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 23; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 25; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1'-[methylenebis(oxy)]bistridecane" "1,1'-(methylenebis(oxy))bistridecane" "tridecane, 1,1'-(methylenebis(oxy))bis-" "tridecane, 1,1'-[methylenebis(oxy)]bis-" "1,1'-methylenebis(oxy-n-tridecane)" "tridecane,1,1'-[methylenebis(oxy)]bis-" );
gibbsFormation
{
    dHf_298   -865050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1230.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-33540.0
    phase     gas;
}
