/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-1-pentyne  (C6H10, CAS 7154-75-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl1Pentyne;
formula     C6H10;
CAS         7154-75-8;
InChIKey    OXRWICUICBZVAE-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          506.17;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       0.2109;      // -   [origin=predictive method=lee-kesler]
Tb          326.56;      // K   [origin=predictive method=joback]
HvapTb      28420.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.531 0.48584 -0.00030173 7.809e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylpent-1-yne" "1-pentyne, 4-methyl-" "isobutylacetylene" "isobutyl acetylene" "isobutylethyne" );
gibbsFormation
{
    dHf_298   119450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=220270.0
    phase     gas;
}
