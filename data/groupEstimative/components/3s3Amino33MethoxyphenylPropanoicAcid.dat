/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3s)-3-amino-3-(3-methoxyphenyl)propanoic acid  (C10H13NO3, CAS 68443-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3s3Amino33MethoxyphenylPropanoicAcid;
formula     C10H13NO3;
CAS         68443-98-1;
InChIKey    FGMPGCPZEOXEES-VIFPVBQESA-N;
MW          195.218;      // g/mol [origin=calculated method=formula-sum]
Tc          929.04;      // K   [origin=predictive method=joback]
Pc          33.606;      // bar [origin=predictive method=joback]
omega       1.0356;      // -   [origin=predictive method=lee-kesler]
Tb          700.08;      // K   [origin=predictive method=joback]
HvapTb      70619.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.101 0.87082 -0.00049256 9.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s)-3-azanyl-3-(3-methoxyphenyl)propanoic acid" "(s)-3-amino-3-(3-methoxyphenyl)propanoic acid" "(s)-3-amino-3-(3-methoxy-phenyl)-propionic acid" "(r)-3-amino-3-(3-methoxyphenyl)propanoic acid;" "benzenepropanoic acid, b-amino-3-methoxy-, (br)-" "(s)-3-amino-3-(3-methoxy-phenyl)-propanoic acid" );
gibbsFormation
{
    dHf_298   -478650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-248800.0
    phase     gas;
}
