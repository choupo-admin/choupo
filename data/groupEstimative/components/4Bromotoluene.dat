/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromotoluene  (C7H7Br, CAS 106-38-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromotoluene;
formula     C7H7Br;
CAS         106-38-7;
InChIKey    ZBTMRBYMKUEVEU-UHFFFAOYSA-N;
MW          171.037;      // g/mol [origin=calculated method=formula-sum]
Tc          691.41;      // K   [origin=predictive method=joback]
Pc          44.150;      // bar [origin=predictive method=joback]
omega       0.3629;      // -   [origin=predictive method=lee-kesler]
Tb          457.58;      // K   [origin=predictive method=joback]
HvapTb      40549.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.89 0.56862 -0.00039256 1.068e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-methyl-benzene" "p-bromotoluene" "1-bromo-4-methylbenzene" "benzene, 1-bromo-4-methyl-" "toluene, p-bromo-" "4-methylbromobenzene" "p-tolyl bromide" "p-methylbromobenzene" "p-methylphenyl bromide" "parabromotoluene" "1-methyl-4-bromobenzene" "4-bromo-1-methylbenzene" );
standardThermochemistry
{
    dHf_298   63580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     367.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125160.0
}
