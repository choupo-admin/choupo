/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonadecyl methanoate  (C20H40O2, CAS 66455-49-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C20H40O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nonadecylMethanoate;
formula     C20H40O2;
CAS         66455-49-0;
InChIKey    HNKCZZOHAXMGMR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          312.538;      // g/mol [origin=calculated method=formula-sum]
Tc          791.66;      // K   [origin=predictive method=joback]
Pc          10.233;      // bar [origin=predictive method=joback]
omega       0.7731;      // -   [origin=predictive method=lee-kesler]
Tb          633.62;      // K   [origin=predictive method=joback]
HvapTb      57741.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.792 1.91192 -0.0012172 3.235e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -379680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1118.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161480.0
    phase     gas;
}
