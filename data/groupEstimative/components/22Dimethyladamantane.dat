/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyladamantane  (C12H20, CAS 19740-34-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyladamantane;
formula     C12H20;
CAS         19740-34-2;
InChIKey    KOLCSQBNCFAWAM-UHFFFAOYSA-N;
MW          164.292;      // g/mol [origin=calculated method=formula-sum]
Tc          706.02;      // K   [origin=predictive method=joback]
Pc          25.611;      // bar [origin=predictive method=joback]
omega       0.3578;      // -   [origin=predictive method=lee-kesler]
Tb          489.55;      // K   [origin=predictive method=joback]
HvapTb      40448.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-201.98 1.82584 -0.001665 6.412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 4; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 4; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[3.3.1.13,7]decane,2,2-dimethyl-" "2,2-dimethyltricyclo(3.3.1.1(3,7))decane;" );
standardThermochemistry
{
    dHf_298   -104210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=199400.0
}
