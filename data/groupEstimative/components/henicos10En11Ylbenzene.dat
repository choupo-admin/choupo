/*--------------------------------*- Choupo -*-----------------------*\
  Component: henicos-10-en-11-ylbenzene  (C27H46, CAS 6703-78-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        henicos10En11Ylbenzene;
formula     C27H46;
CAS         6703-78-2;
InChIKey    LCSNKHFQEKIGGQ-UHFFFAOYSA-N;
MW          370.665;      // g/mol [origin=calculated method=formula-sum]
Tc          1041.88;      // K   [origin=predictive method=joback]
Pc          8.540;      // bar [origin=predictive method=joback]
omega       0.7880;      // -   [origin=predictive method=lee-kesler]
Tb          848.08;      // K   [origin=predictive method=joback]
HvapTb      78010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.433 2.50984 -0.0015623 3.848e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 17; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-phenyl-10-henicosene" );
standardThermochemistry
{
    dHf_298   -256650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1090.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=360540.0
}
