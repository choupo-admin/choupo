/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclotriol  (C20H26O3, CAS 135768-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclotriol;
formula     C20H26O3;
CAS         135768-83-1;
InChIKey    PAMNOUDFJQSYMD-GDJIPBGISA-N;
MW          314.425;      // g/mol [origin=calculated method=formula-sum]
Tc          1213.26;      // K   [origin=predictive method=joback]
Pc          28.444;      // bar [origin=predictive method=joback]
omega       1.6823;      // -   [origin=predictive method=lee-kesler]
Tb          976.45;      // K   [origin=predictive method=joback]
HvapTb      105177.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-377.42 3.40472 -0.00366692 1.585e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group C; count 3; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 3; } { group C_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "14alpha,17alpha-ethano-1,3,5(10)-estratriene-3,16alpha,17-beta-triol" "(16-alpha,17-alpha)-14,21-cyclo-19-norpregna-1,3,5(10)-triene-3,16,17-triol" "14,21-cyclo-19-norpregna-1,3,5(10)-triene-3,16,17-triol, (16-alpha,17-alpha)-" );
standardThermochemistry
{
    dHf_298   -422760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     733.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-8950.0
}
