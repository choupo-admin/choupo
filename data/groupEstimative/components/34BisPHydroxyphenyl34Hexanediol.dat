/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-bis(p-hydroxyphenyl)-3,4-hexanediol  (C18H22O4, CAS 7507-01-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34BisPHydroxyphenyl34Hexanediol;
formula     C18H22O4;
CAS         7507-01-9;
InChIKey    MOGCNGHSEICQCE-UHFFFAOYSA-N;
MW          302.37;      // g/mol [origin=calculated method=formula-sum]
Tc          1239.84;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       1.8816;      // -   [origin=predictive method=lee-kesler]
Tb          1003.94;      // K   [origin=predictive method=joback]
HvapTb      117008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-137.488 2.18484 -0.00193492 6.836e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 8; } { group AC; count 2; } { group OH; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-bis(4-hydroxyphenyl)hexane-3,4-diol" "3,4-bis(4-hydroxyphenyl)-3,4-hexanediol" "3,4-hexanediol, 3,4-bis(4-hydroxyphenyl)-" "3, 3,4-bis(p-hydroxyphenyl)-" "3, 3,4-bis(4-hydroxyphenyl)-" ".alpha.,.alpha.'-dihydroxydiethylstilbestrol" "alpha,alpha-dihydroxydiethylstilbestrol" "alpha,alpha'-dihydroxydiethylstilbestrol" "3,4-hexanediol, 3,4-bis(p-hydroxyphenyl)-" );
gibbsFormation
{
    dHf_298   -618370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-251700.0
    phase     gas;
}
