/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, 2-propenyl ester, polymer with butyl 2-propenoate  (C14H22O4, CAS 61488-62-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2Methyl2PropenylEsterPolymerWithButyl2Propenoa;
formula     C14H22O4;
CAS         61488-62-8;
InChIKey    GELZPXRWIHMAKT-UHFFFAOYSA-N;
MW          254.326;      // g/mol [origin=calculated method=formula-sum]
Tc          812.80;      // K   [origin=predictive method=joback]
Pc          15.885;      // bar [origin=predictive method=joback]
omega       0.7754;      // -   [origin=predictive method=lee-kesler]
Tb          627.68;      // K   [origin=predictive method=joback]
HvapTb      59936.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.134 0.95794 -0.0002048 -1.22e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate;prop-2-enyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 2-propen-1-yl ester, polymer with butyl 2-propenoate" "butyl prop-2-enoate; prop-2-enyl 2-methylprop-2-enoate" );
gibbsFormation
{
    dHf_298   -711970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     893.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-403530.0
    phase     gas;
}
