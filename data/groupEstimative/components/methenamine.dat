/*--------------------------------*- Choupo -*-----------------------*\
  Component: methenamine  (C6H12N4, CAS 100-97-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methenamine;
formula     C6H12N4;
CAS         100-97-0;
InChIKey    VKYKSIONXSXAKP-UHFFFAOYSA-N;
MW          140.19;      // g/mol [origin=calculated method=formula-sum]
Tc          590.66;      // K   [origin=predictive method=joback]
Pc          51.906;      // bar [origin=predictive method=joback]
omega       0.6323;      // -   [origin=predictive method=lee-kesler]
Tb          408.06;      // K   [origin=predictive method=joback]
HvapTb      37272.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-198.51 1.6304 -0.001719 6.82e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2N; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group N; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexamethylenetetramine" "urotropine" "hexamine" "1,3,5,7-tetraazaadamantane" "aminoform" "methenamin" "urotropin" "uritone" "aminoformaldehyde" "hexamethylenamine" "ammonioformaldehyde" "methenaminum" );
gibbsFormation
{
    dHf_298   400850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     250.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=684440.0
    phase     gas;
}
