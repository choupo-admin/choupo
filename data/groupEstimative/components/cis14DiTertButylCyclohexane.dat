/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-1,4-di-tert-butyl-cyclohexane  (C14H28, CAS 4789-34-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis14DiTertButylCyclohexane;
formula     C14H28;
CAS         4789-34-8;
InChIKey    IBTCQHAOKZFUES-UHFFFAOYSA-N;
MW          196.378;      // g/mol [origin=calculated method=formula-sum]
Tc          739.62;      // K   [origin=predictive method=joback]
Pc          18.077;      // bar [origin=predictive method=joback]
omega       0.3446;      // -   [origin=predictive method=lee-kesler]
Tb          528.34;      // K   [origin=predictive method=joback]
HvapTb      44286.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-118.45 1.68112 -0.001107 2.806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 2; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-ditert-butylcyclohexane" "trans-1,4-di-tert-butyl-cyclohexane" "trans-1,4-bis(1,1-dimethylethyl)-cyclo" "cyclohexane, 1,4-bis(1,1-dimethylethyl)-" "1,4-di-tert-butylcyclohexane" "cis-1,4-bis(1,1-dimethylethyl)-cyclohexa" );
gibbsFormation
{
    dHf_298   -315810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89420.0
    phase     gas;
}
