/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-ethoxyacrylate  (C7H12O3, CAS 1001-26-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Ethoxyacrylate;
formula     C7H12O3;
CAS         1001-26-9;
InChIKey    ITQFPVUDTFABDH-UHFFFAOYSA-N;
MW          144.17;      // g/mol [origin=calculated method=formula-sum]
Tc          625.56;      // K   [origin=predictive method=joback]
Pc          29.218;      // bar [origin=predictive method=joback]
omega       0.5414;      // -   [origin=predictive method=lee-kesler]
Tb          444.56;      // K   [origin=predictive method=joback]
HvapTb      40951.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.252 0.57084 -0.0002352 7.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-ethoxyprop-2-enoate" "3-ethoxyacrylic acid ethyl ester" "ethyl3-ethoxy-2-propenoate" "ethyl trans-3-ethoxyacrylate" );
standardThermochemistry
{
    dHf_298   -520090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-327090.0
}
