/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-h-10053  (C11H16O2, CAS 774-64-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agH10053;
formula     C11H16O2;
CAS         774-64-1;
InChIKey    MTQPZHNZYWAXEH-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          726.57;      // K   [origin=predictive method=joback]
Pc          23.315;      // bar [origin=predictive method=joback]
omega       0.6689;      // -   [origin=predictive method=lee-kesler]
Tb          536.67;      // K   [origin=predictive method=joback]
HvapTb      50112.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.593 0.91896 -0.0005773 1.454e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH=C; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH; count 1; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dimethyl-5-pentylidene-furan-2-one" "3,4-dimethyl-5-pentylidene-5h-furan-2-one" "2(5h)-furanone,3,4-dimethyl-5-pentylidene-, (5z)-" "2,4-nonadienoicacid, 4-hydroxy-2,3-dimethyl-, g-lactone (6ci,7ci,8ci); 2,3-dimethyl-4-hydroxy-2,4-nonadienoic acidlactone; bovolid; bovolide" );
gibbsFormation
{
    dHf_298   -383640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144010.0
    phase     gas;
}
