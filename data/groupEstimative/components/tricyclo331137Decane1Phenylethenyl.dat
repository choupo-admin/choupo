/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(3.3.1.13,7)decane, 1-(phenylethenyl)-  (C18H20, CAS 74203-39-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo331137Decane1Phenylethenyl;
formula     C18H20;
CAS         74203-39-7;
InChIKey    NILZZMRDRCUCON-UHFFFAOYSA-N;
MW          236.358;      // g/mol [origin=calculated method=formula-sum]
Tc          935.91;      // K   [origin=predictive method=joback]
Pc          24.314;      // bar [origin=predictive method=joback]
omega       0.4731;      // -   [origin=predictive method=lee-kesler]
Tb          667.18;      // K   [origin=predictive method=joback]
HvapTb      58541.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-229.72 2.1936 -0.00198586 7.4528e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-phenylethynyl)adamantane" "tricyclo[3.3.1.13,7]decane, 1-(phenylethenyl)-" "1-adamantyl phenylacetylene" "4-adamantyl-ethynylbenzene" );
gibbsFormation
{
    dHf_298   301120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=572840.0
    phase     gas;
}
