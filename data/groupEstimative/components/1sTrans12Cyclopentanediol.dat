/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1s)-trans-1,2-cyclopentanediol  (C5H10O2, CAS 63261-45-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1sTrans12Cyclopentanediol;
formula     C5H10O2;
CAS         63261-45-0;
InChIKey    VCVOSERVUCJNPR-WHFBIAKZSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          689.23;      // K   [origin=predictive method=joback]
Pc          53.513;      // bar [origin=predictive method=joback]
omega       1.1198;      // -   [origin=predictive method=lee-kesler]
Tb          508.97;      // K   [origin=predictive method=joback]
HvapTb      60030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.62 0.652 -0.000381 7.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,2s)-cyclopentane-1,2-diol" "(1s,2s)-trans-1,2-cyclopentanediol" "(1s,2s)-(+)-trans-1,2-cyclopentanediol" "(s)-trans-1,2-cyclopentanediol" );
standardThermochemistry
{
    dHf_298   -410850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     359.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-253580.0
}
