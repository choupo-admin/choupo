/*--------------------------------*- Choupo -*-----------------------*\
  Component: .alpha.-hydroequiline  (C18H22O2, CAS 3563-27-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaHydroequiline;
formula     C18H22O2;
CAS         3563-27-7;
InChIKey    NLLMJANWPUQQTA-UHFFFAOYSA-N;
MW          270.372;      // g/mol [origin=calculated method=formula-sum]
Tc          1081.28;      // K   [origin=predictive method=joback]
Pc          27.240;      // bar [origin=predictive method=joback]
omega       1.2574;      // -   [origin=predictive method=lee-kesler]
Tb          844.37;      // K   [origin=predictive method=joback]
HvapTb      87870.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-219.65 2.34742 -0.00217156 8.337e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "13-methyl-6,9,11,12,14,15,16,17-octahydrocyclopenta[a]phenanthrene-3,17-diol" "dihydroequilin" "beta-dihydroequilin" "estra-1,3,5(10),7-tetraene-3,17-diol, (17.alpha.)-" "alpha-equilol" "alpha-dihydroequilin" "17alpha-dihydroequilin" "estra-1,3,5(10),7-tetraene-3,17alpha-diol" "estra-1,3,5(10),7-tetraene-3,17beta-diol" "dihydroequilin 17alpha-form" "agn-pc-00io98" "estra-1,3,5(10),7-tetraene-3,17-diol" );
standardThermochemistry
{
    dHf_298   -272040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77200.0
}
