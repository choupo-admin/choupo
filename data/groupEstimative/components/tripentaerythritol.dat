/*--------------------------------*- Choupo -*-----------------------*\
  Component: tripentaerythritol  (C15H32O10, CAS 78-24-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tripentaerythritol;
formula     C15H32O10;
CAS         78-24-0;
InChIKey    PTJWCLYPVFJWMP-UHFFFAOYSA-N;
MW          372.411;      // g/mol [origin=calculated method=formula-sum]
Tc          1980.77;      // K   [origin=predictive method=joback]
Pc          27.730;      // bar [origin=predictive method=joback]
omega       0.2122;      // -   [origin=predictive method=lee-kesler]
Tb          1315.39;      // K   [origin=predictive method=joback]
HvapTb      183348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.162 1.9518 -0.0013288 3.518e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group C; count 3; } { group OH; count 8; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group C; count 3; } { group OH; count 8; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[2-[[2,2-bis(hydroxymethyl)-3-oxidanyl-propoxy]methyl]-2-(hydroxymethyl)-3-oxidanyl-propoxy]methyl]-2-(hydroxymethyl)propane-1,3-diol" "tripentaerytritol" "tris(pentaerythritol)" "1,3-propanediol, 2,2-bis[[3-hydroxy-2,2-bis(hydroxymethyl)propoxy]methyl]-" "1,3-propanediol, 2,2-bis((3-hydroxy-2,2-bis(hydroxymethyl)propoxy)methyl)-" "2-[[3-hydroxy-2-[[3-hydroxy-2,2-bis(hydroxymethyl)propoxy]methyl]-2-(hydroxymethyl)propoxy]methyl]-2-(hydroxymethyl)propane-1,3-diol" "tripentaerythritol (8ci)" "1, 2,2-bis[[3-hydroxy-2,2-bis(hydroxymethyl)propoxy]methyl]-" "4,8-dioxa-2,2,6,6,10,10-hexahydroxymethylundecane-1,11-diol" "1,3-propanediol, 2,2-bis[[3-hydroxy-2,2-bis( hydroxymethyl)propoxy]methyl]-" "2,2-bis((3-hydroxy-2,2-bis(hydroxymethyl)propoxy)methyl)-1,3-propanediol; 1,3-propanediol, 2,2-bis[[3-hydroxy-2,2-bis(hydroxymethyl)propoxy]methyl]-" );
standardThermochemistry
{
    dHf_298   -1861460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1053.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1220620.0
}
