/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1757593  (C9H18O3, CAS 10213-74-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1757593;
formula     C9H18O3;
CAS         10213-74-8;
InChIKey    ZLPVZWUOBAHGNY-UHFFFAOYSA-N;
MW          174.24;      // g/mol [origin=calculated method=formula-sum]
Tc          758.40;      // K   [origin=predictive method=joback]
Pc          24.950;      // bar [origin=predictive method=joback]
omega       0.8796;      // -   [origin=predictive method=lee-kesler]
Tb          573.01;      // K   [origin=predictive method=joback]
HvapTb      54814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.125 0.85234 -0.0004306 6.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-ethylbutoxy)propanoic acid" "3-(2-ethylbutoxy)propionic acid" "3-(2-ethylbutoxy) propionic acid" "propanoic acid, 3-(2-ethylbutoxy)-" "propionic acid, 3-(2-ethylbutoxy)-" "propanoic acid,3-(2-ethylbutoxy)-" "kyselina 3-(2-ethylbutoxy)propionova" "propionicacid, 3-(2-ethylbutoxy)- (6ci,8ci); 3-(2-ethylbutoxy)propionic acid" );
standardThermochemistry
{
    dHf_298   -716860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-426450.0
}
