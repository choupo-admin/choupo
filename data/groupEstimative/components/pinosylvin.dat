/*--------------------------------*- Choupo -*-----------------------*\
  Component: pinosylvin  (C14H12O2, CAS 22139-77-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pinosylvin;
formula     C14H12O2;
CAS         22139-77-1;
InChIKey    YCVPRTHEGLPYPB-VOTSOKGWSA-N;
MW          212.248;      // g/mol [origin=calculated method=formula-sum]
Tc          1004.91;      // K   [origin=predictive method=joback]
Pc          41.623;      // bar [origin=predictive method=joback]
omega       0.9455;      // -   [origin=predictive method=lee-kesler]
Tb          738.68;      // K   [origin=predictive method=joback]
HvapTb      77296.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.67 1.5052 -0.00139672 5.2e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-[(e)-2-phenylethenyl]benzene-1,3-diol" "pinosylvine" "trans-3,5-dihydroxystilbene" "3,5-stilbenediol" "5-styrylresorcinol" "(e)-5-(2-phenylethenyl)-1,3-benzenediol" "(e)-3,5-stilbenediol" "5-(2-phenylethenyl)benzene-1,3-diol" "3,5-stilbenediol, (e)-" "1,3-benzenediol, 5-(2-phenylethenyl)-, (e)-" "pound inverted question markpinosylvin" "3,5-dihydroxystilbene" );
gibbsFormation
{
    dHf_298   -96630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62800.0
    phase     gas;
}
