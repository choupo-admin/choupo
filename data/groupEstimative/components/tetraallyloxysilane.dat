/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraallyloxysilane  (C12H20O4Si, CAS 1067-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H20O4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetraallyloxysilane;
formula     C12H20O4Si;
CAS         1067-43-2;
InChIKey    SQAIGLXMIMWFEQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          256.373;      // g/mol [origin=calculated method=formula-sum]
Tc          728.37;      // K   [origin=predictive method=joback]
Pc          17.507;      // bar [origin=predictive method=joback]
omega       0.6875;      // -   [origin=predictive method=lee-kesler]
Tb          551.96;      // K   [origin=predictive method=joback]
HvapTb      49560.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (122.834 0.6048 0.0001382 -2.352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 4; } { group CH2O; count 4; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 4; } { group dCH; count 4; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrakis(prop-2-enyl) silicate" "tetraallyl orthosilicate" "tetrakis(allyloxy)silane" "tetraallyl silicate" "silicic acid (h4sio4), tetraallyl ester" "allyl silicate ((c3h5o)4si)" "silicic acid (h4sio4), tetra-2-propenyl ester" "silicic acid (h4sio4), tetra-2-propen-1-yl ester" "allyl silicate" "silicic acid, tetraallyl ester" "silicic acid (h4sio4),tetra-2-propen-1-yl ester" );
gibbsFormation
{
    dHf_298   -429790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     776.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-123240.0
    phase     gas;
}
