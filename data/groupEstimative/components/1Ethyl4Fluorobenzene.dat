/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethyl-4-fluorobenzene  (C8H9F, CAS 459-47-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethyl4Fluorobenzene;
formula     C8H9F;
CAS         459-47-2;
InChIKey    BLDNWXVISIXWKZ-UHFFFAOYSA-N;
MW          124.158;      // g/mol [origin=calculated method=formula-sum]
Tc          612.99;      // K   [origin=predictive method=joback]
Pc          33.999;      // bar [origin=predictive method=joback]
omega       0.3489;      // -   [origin=predictive method=lee-kesler]
Tb          413.57;      // K   [origin=predictive method=joback]
HvapTb      35523.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.899 0.63722 -0.00039196 9.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-4-fluoranyl-benzene" "p-fluoroethylbenzene" "p-ethyl fluorobenzene" "ethyl-4-fluorobenzene" "p-ethylfluorobenzene" "4-ethylfluorobenzene" "4-ethyl-1-fluorobenzene" "1-ethyl-4-fluorobenzene;4-ethylfluorobenzene;4-fluoroethylbenzene;p-fluoroethylbenzene;" );
gibbsFormation
{
    dHf_298   -179500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75550.0
    phase     gas;
}
