/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanone, 2-cyclohexylidene-  (C12H18O, CAS 1011-12-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanone2Cyclohexylidene;
formula     C12H18O;
CAS         1011-12-7;
InChIKey    TYDSIOSLHQWFOU-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          851.32;      // K   [origin=predictive method=joback]
Pc          29.124;      // bar [origin=predictive method=joback]
omega       0.4901;      // -   [origin=predictive method=lee-kesler]
Tb          599.54;      // K   [origin=predictive method=joback]
HvapTb      49645.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.3 1.0977 -0.000511 4.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyclohexylidenecyclohexan-1-one" "bicyclohexyliden-2-one" "dianon" "cyclohexylidenecyclohexanone" "2-cyclohexylidenecyclohexanone" "cyclohexanone, cyclohexylidene-" );
standardThermochemistry
{
    dHf_298   -244550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=2590.0
}
