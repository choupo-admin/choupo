/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxyphenyl 4-butylbenzoate  (C18H20O3, CAS 35684-23-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxyphenyl4Butylbenzoate;
formula     C18H20O3;
CAS         35684-23-2;
InChIKey    BISLKTRYMAGJLH-UHFFFAOYSA-N;
MW          284.355;      // g/mol [origin=calculated method=formula-sum]
Tc          977.55;      // K   [origin=predictive method=joback]
Pc          18.483;      // bar [origin=predictive method=joback]
omega       0.8831;      // -   [origin=predictive method=lee-kesler]
Tb          755.40;      // K   [origin=predictive method=joback]
HvapTb      71355.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.777 1.31904 -0.00067812 9.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methoxyphenyl) 4-butylbenzoate" "4-butylbenzoic acid, 4-methoxyphenyl ester" "benzoic acid, 4-butyl-, 4-methoxyphenyl ester" "4'-methoxyphenyl 4-butylbenzoate" );
standardThermochemistry
{
    dHf_298   -414230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     694.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-109130.0
}
