/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-butadiene, 1,4-bis(methylthio)-, (z,z)-  (C6H10S2, CAS 35822-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Butadiene14BisMethylthioZZ;
formula     C6H10S2;
CAS         35822-49-2;
InChIKey    DEKIQJNFHBLPMQ-GLIMQPGKSA-N;
MW          146.266;      // g/mol [origin=calculated method=formula-sum]
Tc          717.07;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.3660;      // -   [origin=predictive method=lee-kesler]
Tb          482.76;      // K   [origin=predictive method=joback]
HvapTb      42500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.27 0.60262 -0.0003898 9.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group CH3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 4; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1z,3z)-1,4-bis(methylsulfanyl)buta-1,3-diene" );
gibbsFormation
{
    dHf_298   151010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=226320.0
    phase     gas;
}
