/*--------------------------------*- Choupo -*-----------------------*\
  Component: levomenol  (C15H26O, CAS 515-69-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        levomenol;
formula     C15H26O;
CAS         515-69-5;
InChIKey    RGZSQWQPBWRIAQ-UHFFFAOYSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          857.36;      // K   [origin=predictive method=joback]
Pc          19.510;      // bar [origin=predictive method=joback]
omega       0.8780;      // -   [origin=predictive method=lee-kesler]
Tb          659.48;      // K   [origin=predictive method=joback]
HvapTb      65788.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.328 1.61518 -0.00108174 2.871e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-2-(4-methylcyclohex-3-en-1-yl)hept-5-en-2-ol" "alpha-bisabolol" "epi-.alpha.-bisabolol" "6-epi-.alpha.-bisabolol" "7-epi-.alpha.-bisabolol" "6-methyl-2-(4-methyl-3-cyclohexen-1-yl)-5-hepten-2-ol" "6-methyl-2-(4-methylcyclohex-3-enyl)hept-5-en-2-ol" "3-cyclohexene-1-methanol, .alpha.,4-dimethyl-.alpha.-(4-methyl-3-pentenyl)-, [s-(r*,r*)]-" "a-bisabolol" "(+)-.alpha.-bisabolol" "(+/-)-alpha-bisabolol" "(-)-.alpha.-bisabolol" );
gibbsFormation
{
    dHf_298   -305850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     667.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57890.0
    phase     gas;
}
