/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-trimethylsilyl-3,3-dimethyl-1-butyne  (C9H18Si, CAS 14630-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H18Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Trimethylsilyl33Dimethyl1Butyne;
formula     C9H18Si;
CAS         14630-42-3;
InChIKey    GKWFJPNWRGGCSB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          154.328;      // g/mol [origin=calculated method=formula-sum]
Tc          618.83;      // K   [origin=predictive method=joback]
Pc          24.435;      // bar [origin=predictive method=joback]
omega       0.1820;      // -   [origin=predictive method=lee-kesler]
Tb          412.69;      // K   [origin=predictive method=joback]
HvapTb      36778.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.61 0.62872 -0.00013066 -7.042e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 1; } { group C_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylbut-1-ynyl(trimethyl)silane" "1-butyne, 3,3-dimethyl-1-trimethylsilyl-" "3,3-dimethyl-1-trimethylsilyl-1-butyne" "(3,3-dimethyl-1-butynyl)(trimethyl)silane" "silane, (3,3-dimethyl-1-butynyl)trimethyl-" "1-(trimethylsilyl)neohexyne" "2,2,5,5-tetramethyl-2-silahex-3-yne" "3,3-dimethyl-1-(trimethylsilyl)-1-butyne" "(3,3-dimethylbut-1-yn-1-yl)(trimethyl)silane" "silane,(3,3-dimethyl-1-butyn-1-yl)trimethyl-" );
gibbsFormation
{
    dHf_298   -77160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125780.0
    phase     gas;
}
