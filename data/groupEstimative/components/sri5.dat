/*--------------------------------*- Choupo -*-----------------------*\
  Component: sri-5  (C16H30N4O2, CAS 1553-36-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sri5;
formula     C16H30N4O2;
CAS         1553-36-2;
InChIKey    ZDTDUAYRLVDHEJ-UHFFFAOYSA-N;
MW          310.442;      // g/mol [origin=calculated method=formula-sum]
Tc          1004.06;      // K   [origin=predictive method=joback]
Pc          18.420;      // bar [origin=predictive method=joback]
omega       1.3984;      // -   [origin=predictive method=lee-kesler]
Tb          812.92;      // K   [origin=predictive method=joback]
HvapTb      81760.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.86 2.242 -0.0017756 5.7172e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH2N; count 2; } { group CONHCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group CH2_ring; count 4; } { group CdO; count 2; } { group NH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(aziridin-1-yl)-n-[8-[2-(aziridin-1-yl)ethanoylamino]octyl]ethanamide" "acetamide, n,n'-octamethylenebis(2-(1-aziridinyl)-" "n,n'-bis(aziridineacetyl)-1,8-octamethylenediamine" "n,n'-bis(aziridinylacetyl)-1,8-octamethylenediamine" "1,8-octamethylenediamine, n,n'-bis(aziridinylacetyl)-" "1,8-octylmethylenediamine,n,n'-bis(aziridinylacetyl)-" "1-aziridineacetamide, n,n'-(octamethylene)bis-" "1,n,n'-bis(aziridinylacetyl)-" "1, n,n'-bis(aziridinylacetyl)-" "1-aziridineacetamide,n'-octamethylenebis-" "1-aziridineacetamide,n'-1,8-octanediylbis-" "1-aziridineacetamide, n,n'-1,8-octanediylbis-" );
gibbsFormation
{
    dHf_298   -158130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     810.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=387460.0
    phase     gas;
}
