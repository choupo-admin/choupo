/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-trichloro-2,4,6-trimethylbenzene  (C9H9Cl3, CAS 5324-68-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Trichloro246Trimethylbenzene;
formula     C9H9Cl3;
CAS         5324-68-5;
InChIKey    VMNISWKTOHUZQN-UHFFFAOYSA-N;
MW          223.521;      // g/mol [origin=calculated method=formula-sum]
Tc          799.10;      // K   [origin=predictive method=joback]
Pc          26.653;      // bar [origin=predictive method=joback]
omega       0.5136;      // -   [origin=predictive method=lee-kesler]
Tb          569.39;      // K   [origin=predictive method=joback]
HvapTb      54369.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (70.97 0.50286 -0.000223 2.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACCH3; count 3; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dC_ring; count 6; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-tris(chloranyl)-2,4,6-trimethyl-benzene" "mesitylene, 2,4,6-trichloro-" "benzene, 1,3,5-trichloro-2,4,6-trimethyl-" "mesitylene,4,6-trichloro-" "2,6-trichloromesitylene" "1,5-trichloro-2,4,6-trimethylbenzene" "benzene,3,5-trichloro-2,4,6-trimethyl-" "1,3,5-trichloro-2,4,6-trimethyl-benzene" );
gibbsFormation
{
    dHf_298   -97130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53370.0
    phase     gas;
}
