/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl vinyl ether  (C5H8O, CAS 3917-15-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylVinylEther;
formula     C5H8O;
CAS         3917-15-5;
InChIKey    ZXABMDQSAABDMG-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          501.12;      // K   [origin=predictive method=joback]
Pc          37.592;      // bar [origin=predictive method=joback]
omega       0.2847;      // -   [origin=predictive method=lee-kesler]
Tb          329.78;      // K   [origin=predictive method=joback]
HvapTb      27794.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.861 0.3756 -0.000183 2.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethenoxyprop-1-ene" "ether, allyl vinyl" "vinyl allyl ether" "1-propene, 3-(ethenyloxy)-" "allyl ethenyl ether" "3-ethenoxy-1-propene" "1-propene, 3-(ethenyloxy)- (9ci)" );
standardThermochemistry
{
    dHf_298   -27890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61900.0
}
