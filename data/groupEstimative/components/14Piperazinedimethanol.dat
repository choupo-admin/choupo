/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-piperazinedimethanol  (C6H14N2O2, CAS 3312-58-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Piperazinedimethanol;
formula     C6H14N2O2;
CAS         3312-58-1;
InChIKey    NQEQVKVMCQIFFB-UHFFFAOYSA-N;
MW          146.19;      // g/mol [origin=calculated method=formula-sum]
Tc          732.26;      // K   [origin=predictive method=joback]
Pc          49.177;      // bar [origin=predictive method=joback]
omega       1.4570;      // -   [origin=predictive method=lee-kesler]
Tb          561.80;      // K   [origin=predictive method=joback]
HvapTb      66788.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.668 1.0574 -0.0008178 2.522e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group OH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(hydroxymethyl)piperazin-1-yl]methanol" "n,n'-dimethylolpiperazine" "n,n'-dimethylolpiperazine;" );
gibbsFormation
{
    dHf_298   -249590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=3920.0
    phase     gas;
}
