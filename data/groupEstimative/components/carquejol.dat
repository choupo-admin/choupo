/*--------------------------------*- Choupo -*-----------------------*\
  Component: carquejol  (C10H14O, CAS 23734-06-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carquejol;
formula     C10H14O;
CAS         23734-06-7;
InChIKey    CBYONFNNEHVJSW-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          726.65;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.7283;      // -   [origin=predictive method=lee-kesler]
Tb          530.34;      // K   [origin=predictive method=joback]
HvapTb      54514.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.19 0.88982 -0.00049628 9.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 2; } { group dC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylidene-6-prop-1-en-2-yl-cyclohex-2-en-1-ol" "o-mentha-1(7),4,8-trien-3-ol, (2r,3s)-" "2-cyclohexen-1-ol, 5-methylene-6-(1-methylethenyl)-, (1s-cis)-" "5-methylidene-6-prop-1-en-2-ylcyclohex-2-en-1-ol" "(1s,6r)-5-methylidene-6-prop-1-en-2-ylcyclohex-2-en-1-ol" );
standardThermochemistry
{
    dHf_298   -110320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75570.0
}
