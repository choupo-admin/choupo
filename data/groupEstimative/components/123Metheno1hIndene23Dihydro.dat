/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-metheno-1h-indene,2,3-dihydro  (C10H8, CAS 34305-47-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Metheno1hIndene23Dihydro;
formula     C10H8;
CAS         34305-47-0;
InChIKey    PLEXSVUROUFKLD-UHFFFAOYSA-N;
MW          128.174;      // g/mol [origin=calculated method=formula-sum]
Tc          669.80;      // K   [origin=predictive method=joback]
Pc          37.638;      // bar [origin=predictive method=joback]
omega       0.4105;      // -   [origin=predictive method=lee-kesler]
Tb          454.26;      // K   [origin=predictive method=joback]
HvapTb      39362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.99 1.2896 -0.00132156 5.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-metheno-1h-indene, 2,3-dihydro-" "tetracyclo[6.1.1.02,7.09,10]deca-2(7),3,5-triene" );
gibbsFormation
{
    dHf_298   204190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     20.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=371140.0
    phase     gas;
}
