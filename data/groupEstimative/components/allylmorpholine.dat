/*--------------------------------*- Choupo -*-----------------------*\
  Component: allylmorpholine  (C7H13NO, CAS 696-57-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylmorpholine;
formula     C7H13NO;
CAS         696-57-1;
InChIKey    SUSANAYXICMXBL-UHFFFAOYSA-N;
MW          127.187;      // g/mol [origin=calculated method=formula-sum]
Tc          613.33;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.4010;      // -   [origin=predictive method=lee-kesler]
Tb          415.78;      // K   [origin=predictive method=joback]
HvapTb      37625.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.259 0.9279 -0.0006614 1.859e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-prop-2-enylmorpholine" "n-allylmorpholine" "4-allylmorpholine" "n-allyl morpholine" "4-allyl-morpholine" "4-(prop-2-en-1-yl)morpholine" "morpholine,4-(2-propen-1-yl)-, hydrochloride (1:1)" "morpholine,4-(2-propenyl)-, hydrochloride (9ci); morpholine, 4-allyl-, hydrochloride (8ci)" );
gibbsFormation
{
    dHf_298   -46030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164820.0
    phase     gas;
}
