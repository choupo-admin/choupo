/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperazine  (C4H10N2, CAS 110-85-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperazine;
formula     C4H10N2;
CAS         110-85-0;
InChIKey    GLUUGHFHXGJENI-UHFFFAOYSA-N;
MW          86.138;      // g/mol [origin=calculated method=formula-sum]
Tc          641.10;      // K   [origin=predictive method=joback]
Pc          57.917;      // bar [origin=predictive method=joback]
omega       0.3409;      // -   [origin=predictive method=lee-kesler]
Tb          412.44;      // K   [origin=predictive method=joback]
HvapTb      38752.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.45 0.5056 -0.000209 8.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group NH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethylenediamine" "hexahydropyrazine" "piperazidine" "antiren" "uvilon" "dispermine" "lumbrical" "piperazin" "pipersol" "wurmirazin" "1,4-diazacyclohexane" "eraverm" );
standardThermochemistry
{
    dHf_298   24390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     311.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=190380.0
}
