/*--------------------------------*- Choupo -*-----------------------*\
  Component: val-gly  (C7H14N2O3, CAS 686-43-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        valGly;
formula     C7H14N2O3;
CAS         686-43-1;
InChIKey    IOUPEELXVYPCPG-UHFFFAOYSA-N;
MW          174.2;      // g/mol [origin=calculated method=formula-sum]
Tc          892.34;      // K   [origin=predictive method=joback]
Pc          36.642;      // bar [origin=predictive method=joback]
omega       1.2099;      // -   [origin=predictive method=lee-kesler]
Tb          680.96;      // K   [origin=predictive method=joback]
HvapTb      71387.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.401 0.84154 -0.0005093 1.1156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(2-azanyl-3-methyl-butanoyl)amino]ethanoic acid" "l-valylglycine" "2-[(2-amino-3-methylbutanoyl)amino]acetic acid" );
gibbsFormation
{
    dHf_298   -573960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     581.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-313810.0
    phase     gas;
}
