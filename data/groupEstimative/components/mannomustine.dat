/*--------------------------------*- Choupo -*-----------------------*\
  Component: mannomustine  (C10H22Cl2N2O4, CAS 576-68-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mannomustine;
formula     C10H22Cl2N2O4;
CAS         576-68-1;
InChIKey    MQXVYODZCMMZEM-ZYUZMQFOSA-N;
MW          305.196;      // g/mol [origin=calculated method=formula-sum]
Tc          1196.02;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       1.8572;      // -   [origin=predictive method=lee-kesler]
Tb          970.56;      // K   [origin=predictive method=joback]
HvapTb      124660.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.596 1.2794 -0.0007926 1.84e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group OH; count 4; } { group CH2NH; count 2; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH; count 4; } { group Cl; count 2; } { group OH; count 4; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3r,4r,5r)-1,6-bis(2-chloroethylamino)hexane-2,3,4,5-tetrol" "mannitol nitrogen mustard" "bcm (cytostatic)" "mannit-lost [german]" "mannit-mustard [german]" "mannomustinum [inn-latin]" "mannomustine [inn:ban:dcf]" "1,6-bis((2-chloroethyl)amino)-1,6-dideoxy-d-mannitol" "1,6-bis[(2-chloroethyl)amino]-1,6-dideoxy-d-mannitol" "mannomustinum" "manomustina" "mannit-mustard" );
standardThermochemistry
{
    dHf_298   -804310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     859.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-368800.0
}
