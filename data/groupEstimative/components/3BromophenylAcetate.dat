/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromophenyl acetate  (C8H7BrO2, CAS 35065-86-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3BromophenylAcetate;
formula     C8H7BrO2;
CAS         35065-86-2;
InChIKey    CDLTWXBTYNNYLN-UHFFFAOYSA-N;
MW          215.046;      // g/mol [origin=calculated method=formula-sum]
Tc          772.45;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.5673;      // -   [origin=predictive method=lee-kesler]
Tb          538.68;      // K   [origin=predictive method=joback]
HvapTb      50182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.61 0.60882 -0.00035236 6.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3COO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-bromophenyl) ethanoate" "phenol, 3-bromo-, acetate" "3-bromo-phenyl acetate" "3-bromo-phenylacetate" "(3-bromophenyl) acetate" "phenol, 3-bromo-,1-acetate" "(3-bromo-phenyl)-acetic acid" "phenol,3-bromo-, acetate (9ci); phenol, m-bromo-, acetate (6ci); 3-bromophenylacetate; m-acetoxybromobenzene; m-bromophenyl acetate" );
gibbsFormation
{
    dHf_298   -274340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-176790.0
    phase     gas;
}
