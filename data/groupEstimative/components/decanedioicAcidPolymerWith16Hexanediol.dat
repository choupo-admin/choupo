/*--------------------------------*- Choupo -*-----------------------*\
  Component: decanedioic acid, polymer with 1,6-hexanediol  (C16H32O6, CAS 26745-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decanedioicAcidPolymerWith16Hexanediol;
formula     C16H32O6;
CAS         26745-88-0;
InChIKey    HZOTTWYEWUMPPM-UHFFFAOYSA-N;
MW          320.426;      // g/mol [origin=calculated method=formula-sum]
Tc          1288.62;      // K   [origin=predictive method=joback]
Pc          16.259;      // bar [origin=predictive method=joback]
omega       1.2799;      // -   [origin=predictive method=lee-kesler]
Tb          1042.46;      // K   [origin=predictive method=joback]
HvapTb      119190.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.944 1.4872 -0.0006378 3.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 14; } { group OH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 14; } { group OH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decanedioic acid;hexane-1,6-diol" "decanedioic acid; hexane-1,6-diol" "sebacic acid, 1,6-hexanediol polymer" );
standardThermochemistry
{
    dHf_298   -1490190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1094.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-982380.0
}
