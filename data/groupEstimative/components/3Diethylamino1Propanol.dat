/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-diethylamino-1-propanol  (C7H17NO, CAS 622-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Diethylamino1Propanol;
formula     C7H17NO;
CAS         622-93-5;
InChIKey    WKCYFSZDBICRKL-UHFFFAOYSA-N;
MW          131.219;      // g/mol [origin=calculated method=formula-sum]
Tc          623.70;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.8840;      // -   [origin=predictive method=lee-kesler]
Tb          464.38;      // K   [origin=predictive method=joback]
HvapTb      49898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.875 0.82674 -0.0005 1.193e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(diethylamino)propan-1-ol" "n,n-diethyl-3-hydroxypropylamine" "1-propanol, 3-(diethylamino)-" "3-(diethylamino)propanol" "3-diethylaminopropan-1-ol" "3-(diethylamino)-1-propanol" "3-(diethylamino)propyl alcohol" "gamma-diaethylaminopropanol [german]" "gamma-diaethylaminopropanol" "1-propanol,3-(diethylamino)-" "wkcyfszdbicrkl-uhfffaoysa-" "3-di-ethylamino-1-propanol" );
standardThermochemistry
{
    dHf_298   -272510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17980.0
}
