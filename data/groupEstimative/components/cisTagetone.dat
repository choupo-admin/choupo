/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-tagetone  (C10H16O, CAS 6752-80-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cisTagetone;
formula     C10H16O;
CAS         6752-80-3;
InChIKey    RJXKHBTYHGBOKV-VQHVLOKHSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          674.31;      // K   [origin=predictive method=joback]
Pc          24.801;      // bar [origin=predictive method=joback]
omega       0.5038;      // -   [origin=predictive method=lee-kesler]
Tb          482.55;      // K   [origin=predictive method=joback]
HvapTb      43580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.389 0.93166 -0.0006137 1.6486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5e)-2,6-dimethylocta-5,7-dien-4-one" "5,7-octadien-4-one, 2,6-dimethyl-, (z)-" "(e)-2,6-dimethylocta-5,7-dien-4-one" "(z)-2,6-dimethylocta-5,7-dien-4-one" "(5e)-2,6-dimethyl-octa-5,7-dien-4-one" );
gibbsFormation
{
    dHf_298   -134730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61470.0
    phase     gas;
}
