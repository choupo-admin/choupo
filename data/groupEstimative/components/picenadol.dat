/*--------------------------------*- Choupo -*-----------------------*\
  Component: picenadol  (C16H25NO, CAS 79201-85-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        picenadol;
formula     C16H25NO;
CAS         79201-85-7;
InChIKey    RTOHPIRUUAKHOZ-BBRMVZONSA-N;
MW          247.382;      // g/mol [origin=calculated method=formula-sum]
Tc          925.35;      // K   [origin=predictive method=joback]
Pc          23.025;      // bar [origin=predictive method=joback]
omega       0.7981;      // -   [origin=predictive method=lee-kesler]
Tb          696.27;      // K   [origin=predictive method=joback]
HvapTb      67340.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-169.708 2.12056 -0.00185136 6.845e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(3r,4s)-1,3-dimethyl-4-propyl-piperidin-4-yl]phenol" "picenadol [inn]" "picenadolum [inn-latin]" "phenol, 3-(1,3-dimethyl-4-propyl-4-piperidinyl)-, trans-(+-)-" "picenadolum" "(+-)-3-(1,3-dimethyl-4-propyl-4-piperidinyl)phenol" "( inverted exclamation marka)-3-(1,3-dimethyl-4-propyl-4-piperidinyl)phenol" "phenol, 3-(1,3-dimethyl-4-propyl-4-piperidinyl)-, hydrochloride, trans-(+-)-" );
gibbsFormation
{
    dHf_298   -191440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     692.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175760.0
    phase     gas;
}
