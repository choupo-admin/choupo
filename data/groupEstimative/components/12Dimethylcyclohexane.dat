/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dimethylcyclohexane  (C8H16, CAS 583-57-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dimethylcyclohexane;
formula     C8H16;
CAS         583-57-3;
InChIKey    KVZJLSYJROEPSQ-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          597.97;      // K   [origin=predictive method=joback]
Pc          30.390;      // bar [origin=predictive method=joback]
omega       0.2487;      // -   [origin=predictive method=lee-kesler]
Tb          397.52;      // K   [origin=predictive method=joback]
HvapTb      33522.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.05 0.85944 -0.000437 6.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane, 1,2-dimethyl-" "hexahydro-o-xylene" "trans-1,2-dimethylcyclohexane" "cyclohexane, 1,2-dimethyl-, trans-" "cyclohexane, 1,2-dimethyl-, (1r,2r)-rel-" "cyclohexane, 1,2-dimethyl-, (1r,2s)-rel-" "cyclohexane,2-dimethyl-" "agn-pc-03cz4h" "cyclohexane, 1,2-dimethyl- (cis/trans)" "cyclohexane, 1,2-dimethyl- (8ci)(9ci)" "1,2-dimethylcyclohexane, cis-trans, 99%" "1,2-dimethylcyclohexane, mixture of cis and trans" );
standardThermochemistry
{
    dHf_298   -174470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=33220.0
}
