/*--------------------------------*- Choupo -*-----------------------*\
  Component: dispiro(2.0.2.4)decane  (C10H16, CAS 24029-74-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dispiro2024Decane;
formula     C10H16;
CAS         24029-74-1;
InChIKey    BNGAGYMTAFZQJE-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          692.44;      // K   [origin=predictive method=joback]
Pc          37.180;      // bar [origin=predictive method=joback]
omega       0.3008;      // -   [origin=predictive method=lee-kesler]
Tb          458.04;      // K   [origin=predictive method=joback]
HvapTb      35772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-267.97 2.0072 -0.002255 1e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dispiro[2.0.2^{4}.4^{3}]decane" "dispiro[2.0.2.4]decane" "dispiro[2.0.2.4]decane(8ci,9ci)" );
gibbsFormation
{
    dHf_298   13330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=200200.0
    phase     gas;
}
