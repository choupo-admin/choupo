/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propanol  (C3H8O, CAS 71-23-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propanol;
formula     C3H8O;
CAS         71-23-8;
InChIKey    BDERNNFJNOPAEC-UHFFFAOYSA-N;
MW          60.096;      // g/mol [origin=calculated method=formula-sum]
Tc          522.56;      // K   [origin=predictive method=joback]
Pc          50.015;      // bar [origin=predictive method=joback]
omega       0.6078;      // -   [origin=predictive method=lee-kesler]
Tb          360.42;      // K   [origin=predictive method=joback]
HvapTb      38951.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.452 0.32282 -0.0001698 3.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-1-ol" "propanol" "propyl alcohol" "n-propanol" "ethylcarbinol" "n-propyl alcohol" "1-hydroxypropane" "optal" "osmosol extra" "propylic alcohol" "propanol-1" "n-propan-1-ol" );
standardThermochemistry
{
    dHf_298   -257480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-162440.0
}
