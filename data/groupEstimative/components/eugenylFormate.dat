/*--------------------------------*- Choupo -*-----------------------*\
  Component: eugenyl formate  (C11H12O3, CAS 10031-96-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H12O3 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        eugenylFormate;
formula     C11H12O3;
CAS         10031-96-6;
InChIKey    JUTKIGGQRLHTJN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          192.214;      // g/mol [origin=calculated method=formula-sum]
Tc          690.11;      // K   [origin=predictive method=joback]
Pc          26.680;      // bar [origin=predictive method=joback]
omega       0.4242;      // -   [origin=predictive method=lee-kesler]
Tb          483.44;      // K   [origin=predictive method=joback]
HvapTb      43047.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.409 0.77582 -0.00053662 1.547e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group HCOO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methoxy-4-prop-2-enyl-phenyl) methanoate" "eugenol formate" "4-allyl-2-methoxyphenol formate" "4-allyl-2-methoxyphenyl formate" "phenol, 4-allyl-2-methoxy-, formate" "2-methoxy-4-(2-propenyl)phenyl formate" "4-(2-propenyl)-2-methoxyphenyl formate" "4-(2-propen-1-yl)-2-methoxyphenyl formate" "2-methoxy-4-(1-allyl)phenyl formate" "phenol, 2-methoxy-4-(2-propenyl)-, formate" "phenol, 4-allyl-2-methoxy-, formate (ester)" "(2-methoxy-4-prop-2-enylphenyl) formate" );
gibbsFormation
{
    dHf_298   12880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     655.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161690.0
    phase     gas;
}
