/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonanedioic acid, polymer with 2,3-dibromo-2-butene-1,4-diol and 1,2,3-propanetriol  (C16H30Br2O9, CAS 71113-97-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonanedioicAcidPolymerWith23Dibromo2Butene14DiolAnd123Propan;
formula     C16H30Br2O9;
CAS         71113-97-8;
InChIKey    BKMHZPXBRFCXDY-ITDJAWRYSA-N;
MW          526.215;      // g/mol [origin=calculated method=formula-sum]
Tc          2039.25;      // K   [origin=predictive method=joback]
Pc          23.025;      // bar [origin=predictive method=joback]
omega       0.4568;      // -   [origin=predictive method=lee-kesler]
Tb          1456.20;      // K   [origin=predictive method=joback]
HvapTb      182121.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (106.771 1.4851 -0.0005486 -3.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 1; } { group OH; count 5; } { group COOH; count 2; } { group Br; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 11; } { group CH; count 1; } { group dC; count 2; } { group Br; count 2; } { group OH; count 5; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-2,3-bis(bromanyl)but-2-ene-1,4-diol;nonanedioic acid;propane-1,2,3-triol" "azelaic acid, glycerol, 2,3-dibromo-2-butene-1,4-diol polymer" );
gibbsFormation
{
    dHf_298   -1913480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1432.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1408280.0
    phase     gas;
}
