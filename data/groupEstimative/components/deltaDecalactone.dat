/*--------------------------------*- Choupo -*-----------------------*\
  Component: delta-decalactone  (C10H18O2, CAS 705-86-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        deltaDecalactone;
formula     C10H18O2;
CAS         705-86-2;
InChIKey    GHBSPIPJMLAMEP-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          686.10;      // K   [origin=predictive method=joback]
Pc          24.556;      // bar [origin=predictive method=joback]
omega       0.5778;      // -   [origin=predictive method=lee-kesler]
Tb          497.63;      // K   [origin=predictive method=joback]
HvapTb      45346.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.156 1.04032 -0.0005994 1.201e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-pentyloxan-2-one" "5-decanolide" "6-pentyltetrahydro-2h-pyran-2-one" "amyl-delta-valerolactone" "2h-pyran-2-one, tetrahydro-6-pentyl-" "5-decalactone" "decan-5-olide" "delta-decanolactone" "decanolide-1,5" "5-pentyl-5-pentanolide" ".delta.-amylvalerolactone" "5-hydroxydecanoic acid delta-lactone" );
standardThermochemistry
{
    dHf_298   -500370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-228400.0
}
