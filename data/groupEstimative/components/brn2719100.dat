/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2719100  (C11H17NO, CAS 42900-95-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2719100;
formula     C11H17NO;
CAS         42900-95-8;
InChIKey    LCWKIAHCEIHHJE-UHFFFAOYSA-N;
MW          179.263;      // g/mol [origin=calculated method=formula-sum]
Tc          794.63;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       0.7326;      // -   [origin=predictive method=lee-kesler]
Tb          580.98;      // K   [origin=predictive method=joback]
HvapTb      58737.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.029 1.12948 -0.00084068 2.659e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(dimethylamino)methyl]-2,6-dimethyl-phenol" "mesitol, alpha(sup 4)-(dimethylamino)-" "alpha(sup 4)-(dimethylamino)mesitol" "4-((dimethylamino)methyl)-2,6-xylenol" "2,6-dimethyl-4-dimethylaminomethylphenol" "phenol, 2,6-dimethyl-4-(dimethylaminomethyl)-" "phenol, 4-((dimethylamino)methyl)-2,6-dimethyl-" "4-((dimethylamino)methyl)-2,6-dimethylphenol" "phenol, 4-[(dimethylamino)methyl]-2,6-dimethyl-" "4-(dimethylaminomethyl)-2,6-dimethylphenol" );
gibbsFormation
{
    dHf_298   -166560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91050.0
    phase     gas;
}
