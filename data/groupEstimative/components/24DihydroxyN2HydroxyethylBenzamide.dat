/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dihydroxy-n-(2-hydroxyethyl)benzamide  (C9H11NO4, CAS 24207-41-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24DihydroxyN2HydroxyethylBenzamide;
formula     C9H11NO4;
CAS         24207-41-8;
InChIKey    HHSJOVPBCHTADG-UHFFFAOYSA-N;
MW          197.19;      // g/mol [origin=calculated method=formula-sum]
Tc          1010.30;      // K   [origin=predictive method=joback]
Pc          60.561;      // bar [origin=predictive method=joback]
omega       1.8384;      // -   [origin=predictive method=lee-kesler]
Tb          789.66;      // K   [origin=predictive method=joback]
HvapTb      93793.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.598 1.1713 -0.00107002 3.9886e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group OH; count 1; } { group ACOH; count 2; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 2; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-hydroxyethyl)-2,4-bis(oxidanyl)benzamide" "2,4-dihydroxybenzoic ethanolamide" "benzamide, 2,4-dihydroxy-n-(2-hydroxyethyl)-" "(2,4-dihydroxyphenyl)-n-(2-hydroxyethyl)carboxamide" "n-(2-hydroxyethyl)-.beta.-resorcylamide" "s340" "benzamide,2,4-dihydroxy-n-(2-hydroxyethyl)-" );
standardThermochemistry
{
    dHf_298   -558520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-348280.0
}
