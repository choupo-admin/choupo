/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-Methyl-2-(3-penten-1-yl)benzene  (C12H16, CAS 6047-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl23Penten1YlBenzene;
formula     C12H16;
CAS         6047-69-4;
InChIKey    NKEQCTWCOZGWSY-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          719.94;      // K   [origin=predictive method=joback]
Pc          24.950;      // bar [origin=predictive method=joback]
omega       0.4513;      // -   [origin=predictive method=lee-kesler]
Tb          509.98;      // K   [origin=predictive method=joback]
HvapTb      45202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.808 1.02544 -0.00067696 1.796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-2-pent-3-enylbenzene" "2-(3-Pentenyl)toluene" "2-pentene, 5-o-tolyl-" "5-o-tolyl-2-pentene" "Benzene, 1-methyl-2-(3-penten-1-yl)-" "Benzene, 1-methyl-2-(3-pentenyl)-" "o-3-pentenyltoluene" "NS00044932" );
gibbsFormation
{
    dHf_298   51270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233160.0
    phase     gas;
}
