/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-hydroxyethoxy)phenol  (C8H10O3, CAS 49650-88-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32HydroxyethoxyPhenol;
formula     C8H10O3;
CAS         49650-88-6;
InChIKey    KKOWMCYVIXBCGE-UHFFFAOYSA-N;
MW          154.165;      // g/mol [origin=calculated method=formula-sum]
Tc          811.72;      // K   [origin=predictive method=joback]
Pc          48.834;      // bar [origin=predictive method=joback]
omega       1.1459;      // -   [origin=predictive method=lee-kesler]
Tb          604.54;      // K   [origin=predictive method=joback]
HvapTb      67781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.418 0.8103 -0.00061836 1.976e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-hydroxyethyloxy)phenol" "phenol, 3-(2-hydroxyethoxy)-" "o-hydroxyethylresorcinol" "3-hydroxyphenylglycol" "3-hydroxyphenyl glycol" "meta-hydroxyphenylglycol" "o-hydroxyethyl resorcinol" "2-(m-hydroxyphenoxy)ethanol" "2-(3-hydroxyphenoxy)ethanol" "ambap49650-88-6" "beta-(3-hydroxyphenoxy)ethanol" "resorcinol monohydroxyethyl ether" );
standardThermochemistry
{
    dHf_298   -433680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-267550.0
}
