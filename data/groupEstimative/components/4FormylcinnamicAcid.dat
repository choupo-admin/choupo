/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-formylcinnamic acid  (C10H8O3, CAS 23359-08-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H8O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4FormylcinnamicAcid;
formula     C10H8O3;
CAS         23359-08-2;
InChIKey    LBOUHDMYVURTMA-AATRIKPKSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          176.171;      // g/mol [origin=calculated method=formula-sum]
Tc          817.70;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.6858;      // -   [origin=predictive method=lee-kesler]
Tb          586.15;      // K   [origin=predictive method=joback]
HvapTb      55541.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.89 0.8943 -0.00079376 2.805e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-(4-methanoylphenyl)prop-2-enoic acid" "3-(4-formylphenyl)acrylic acid" "(2e)-3-(4-formylphenyl)prop-2-enoic acid" "p-formylcinnamic acid" "p-formylcinnamicacid" "3-(4-formylphenyl)prop-2-enoic acid" "4-formylcinnamic acid, predominantly trans" "(e)-3-(4-formylphenyl)prop-2-enoic acid" );
gibbsFormation
{
    dHf_298   -181270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83630.0
    phase     gas;
}
