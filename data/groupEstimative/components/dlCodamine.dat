/*--------------------------------*- Choupo -*-----------------------*\
  Component: dl-codamine  (C20H25NO4, CAS 5977-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dlCodamine;
formula     C20H25NO4;
CAS         5977-85-5;
InChIKey    OKORHWXYDBSYNO-UHFFFAOYSA-N;
MW          343.423;      // g/mol [origin=calculated method=formula-sum]
Tc          1126.90;      // K   [origin=predictive method=joback]
Pc          18.740;      // bar [origin=predictive method=joback]
omega       1.2046;      // -   [origin=predictive method=lee-kesler]
Tb          897.54;      // K   [origin=predictive method=joback]
HvapTb      89514.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.259 1.74788 -0.0011146 2.836e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 3; } { group ACCH2; count 2; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH3O; count 3; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 7; } { group OH_phenol; count 1; } { group O; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(3,4-dimethoxyphenyl)methyl]-6-methoxy-2-methyl-3,4-dihydro-1h-isoquinolin-7-ol" "codamine" "1,2,3,4-tetrahydro-6-methoxy-2-methyl-1-veratryl-7-isoquinolinol" "1-(3,4-dimethoxybenzyl)-6-methoxy-2-methyl-1,2,3,4-tetrahydroisoquinolin-7-ol" "codamine, dl-" "(s)-1-((3,4-dimethoxyphenyl)methyl)-1,2,3,4-tetrahydro-6-methoxy-2-methylisoquinolin-7-ol" "(s)-1-[(3,4-dimethoxyphenyl)methyl]-1,2,3,4-tetrahydro-6-methoxy-2-methylisoquinolin-7-ol" "codamine, (rs)-" "(+/-)-codamine" "(.+-.)-codamine" "codamine dl-form [mi]" "codamine, (+/-)-" );
gibbsFormation
{
    dHf_298   -462590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     683.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5730.0
    phase     gas;
}
