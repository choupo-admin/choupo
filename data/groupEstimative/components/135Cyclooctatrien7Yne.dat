/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-cyclooctatrien-7-yne  (C8H6, CAS 4514-69-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Cyclooctatrien7Yne;
formula     C8H6;
CAS         4514-69-6;
InChIKey    FTUHNRIAHPFOPQ-UHFFFAOYSA-N;
MW          102.136;      // g/mol [origin=calculated method=formula-sum]
Tc          653.49;      // K   [origin=predictive method=joback]
Pc          45.654;      // bar [origin=predictive method=joback]
omega       0.2082;      // -   [origin=predictive method=lee-kesler]
Tb          413.34;      // K   [origin=predictive method=joback]
HvapTb      37168.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.03 0.5946 -0.0004175 1.1338e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 3; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group dCH_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloocta-1,3,5-trien-7-yne" );
standardThermochemistry
{
    dHf_298   311850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     339.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=341320.0
}
