/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[2-(phenylmethoxy)ethyl]pyridine  (C14H15NO, CAS 72187-39-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22PhenylmethoxyEthylPyridine;
formula     C14H15NO;
CAS         72187-39-4;
InChIKey    JUKWUVUJUABESO-UHFFFAOYSA-N;
MW          213.28;      // g/mol [origin=calculated method=formula-sum]
Tc          892.10;      // K   [origin=predictive method=joback]
Pc          27.240;      // bar [origin=predictive method=joback]
omega       0.6534;      // -   [origin=predictive method=lee-kesler]
Tb          649.40;      // K   [origin=predictive method=joback]
HvapTb      59930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.087 1.14656 -0.00069846 1.534e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 2; } { group O; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-phenylmethoxyethyl)pyridine" "2-[2-(benzyloxy)ethyl]pyridine" "pyridine, 2-[2-(phenylmethoxy)ethyl]-" "2-(2-(phenylmethoxy)ethyl)pyridine" "pyridine, 2-(2-(phenylmethoxy)ethyl)-" "2-(2-benzyloxy-ethyl)-pyridine" "pyridine,2-[2-(phenylmethoxy)ethyl]-" "1-(phenylmethoxy)-2-(2-pyridyl)ethane" );
standardThermochemistry
{
    dHf_298   41340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=263870.0
}
