/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-vinylpyridine  (C7H7N, CAS 100-43-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Vinylpyridine;
formula     C7H7N;
CAS         100-43-6;
InChIKey    KFDVPJUYSDEJTH-UHFFFAOYSA-N;
MW          105.14;      // g/mol [origin=calculated method=formula-sum]
Tc          667.27;      // K   [origin=predictive method=joback]
Pc          43.511;      // bar [origin=predictive method=joback]
omega       0.3143;      // -   [origin=predictive method=lee-kesler]
Tb          436.82;      // K   [origin=predictive method=joback]
HvapTb      38992.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.31 0.60366 -0.00042036 1.168e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethenylpyridine" "pyridine, 4-ethenyl-" "pyridine, 4-vinyl-" "gamma-vinylpyridine" "poly(4-vinylpyridine)" "4vp" "4-vinylpyridine homopolymer" "pyridine, 4-ethenyl-, homopolymer" "4-ethenylpyridine, homopolymer" "u040" "poly(4-vinylpyridine-co-ethylvinylbenzene), cross-linked" );
gibbsFormation
{
    dHf_298   206940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=285360.0
    phase     gas;
}
