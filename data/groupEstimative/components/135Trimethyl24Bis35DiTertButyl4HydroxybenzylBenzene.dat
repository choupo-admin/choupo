/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-trimethyl-2,4-bis(3,5-di-tert-butyl-4-hydroxybenzyl)benzene  (C39H56O2, CAS 41642-52-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Trimethyl24Bis35DiTertButyl4HydroxybenzylBenzene;
formula     C39H56O2;
CAS         41642-52-8;
InChIKey    RHIVSELDHMBPHG-UHFFFAOYSA-N;
MW          556.875;      // g/mol [origin=calculated method=formula-sum]
Tc          1674.79;      // K   [origin=predictive method=joback]
Pc          7.246;      // bar [origin=predictive method=joback]
omega       0.6197;      // -   [origin=predictive method=lee-kesler]
Tb          1360.12;      // K   [origin=predictive method=joback]
HvapTb      135376.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.618 3.8088 -0.002855 8.84e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group C; count 4; } { group ACH; count 5; } { group AC; count 6; } { group ACCH3; count 3; } { group ACCH2; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 15; } { group CH2; count 2; } { group C; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 13; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-ditert-butyl-4-[[3-[(3,5-ditert-butyl-4-oxidanyl-phenyl)methyl]-2,4,6-trimethyl-phenyl]methyl]phenol" "phenol, 4,4'-((2,4,6-trimethyl-1,3-phenylene)bis(methylene))bis(2,6-bis(1,1-dimethylethyl)-" "phenol, 4,4'-[(2,4,6-trimethyl-1,3-phenylene)bis(methylene)]bis[2,6-bis(1,1-dimethylethyl)-" "2,6-ditert-butyl-4-[[3-[(3,5-ditert-butyl-4-hydroxyphenyl)methyl]-2,4,6-trimethylphenyl]methyl]phenol" );
standardThermochemistry
{
    dHf_298   -620080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1203.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=239810.0
}
