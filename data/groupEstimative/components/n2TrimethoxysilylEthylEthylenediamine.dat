/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-(trimethoxysilyl)ethyl)ethylenediamine  (C7H20N2O3Si, CAS 7719-00-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H20N2O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        n2TrimethoxysilylEthylEthylenediamine;
formula     C7H20N2O3Si;
CAS         7719-00-8;
InChIKey    FPFKERZHIGFTEI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          208.333;      // g/mol [origin=calculated method=formula-sum]
Tc          735.81;      // K   [origin=predictive method=joback]
Pc          25.227;      // bar [origin=predictive method=joback]
omega       0.8156;      // -   [origin=predictive method=lee-kesler]
Tb          551.12;      // K   [origin=predictive method=joback]
HvapTb      55777.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (119.124 0.41116 0.0002988 -2.88e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3O; count 3; } { group CH2NH2; count 1; } { group CH2NH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group O; count 3; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-(2-trimethoxysilylethyl)ethane-1,2-diamine" "n-[2-(trimethoxysilyl)ethyl]ethylenediamine" "n-(2-trimethoxysilylethyl)ethane-1,2-diamine" );
standardThermochemistry
{
    dHf_298   -608830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     681.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255860.0
}
