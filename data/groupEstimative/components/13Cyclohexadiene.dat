/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-cyclohexadiene  (C6H8, CAS 592-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Cyclohexadiene;
formula     C6H8;
CAS         592-57-4;
InChIKey    MGNZXYYWBUKAII-UHFFFAOYSA-N;
MW          80.13;      // g/mol [origin=calculated method=formula-sum]
Tc          568.55;      // K   [origin=predictive method=joback]
Pc          45.408;      // bar [origin=predictive method=joback]
omega       0.2048;      // -   [origin=predictive method=lee-kesler]
Tb          359.42;      // K   [origin=predictive method=joback]
HvapTb      30272.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.55 0.6104 -0.00041356 1.064e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexa-1,3-diene" "cyclohexadiene" "1,2-dihydrobenzene" "3-cyclohexen-1,2-ylene" "1,3-cyclohexadien" "cyclohexadiene-1,3" "benzene,dihydro- (1ci)" "agn-pc-01z5p7" "1,3-chd" );
standardThermochemistry
{
    dHf_298   23050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     326.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91720.0
}
