/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclododeca-1,5-diene  (C12H20, CAS 1502-04-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclododeca15Diene;
formula     C12H20;
CAS         1502-04-1;
InChIKey    KEMUGHMYINTXKW-UHFFFAOYSA-N;
MW          164.292;      // g/mol [origin=calculated method=formula-sum]
Tc          767.97;      // K   [origin=predictive method=joback]
Pc          27.412;      // bar [origin=predictive method=joback]
omega       0.3006;      // -   [origin=predictive method=lee-kesler]
Tb          522.32;      // K   [origin=predictive method=joback]
HvapTb      44660.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.73 1.1228 -0.00046156 -1.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -137750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     680.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69640.0
    phase     gas;
}
