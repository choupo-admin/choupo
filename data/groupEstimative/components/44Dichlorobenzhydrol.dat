/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-dichlorobenzhydrol  (C13H10Cl2O, CAS 90-97-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dichlorobenzhydrol;
formula     C13H10Cl2O;
CAS         90-97-1;
InChIKey    PHUYGURFBULKPA-UHFFFAOYSA-N;
MW          253.122;      // g/mol [origin=calculated method=formula-sum]
Tc          962.60;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.9987;      // -   [origin=predictive method=lee-kesler]
Tb          726.96;      // K   [origin=predictive method=joback]
HvapTb      75469.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.75 1.0155 -0.00068612 1.72e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(4-chlorophenyl)methanol" "bis(4-chlorphenyl)methanol" "benzenemethanol, 4-chloro-.alpha.-(4-chlorophenyl)-" "bis(4-chlorophenyl)methan-1-ol" "p,p'-dichlorobenzhydrol" "bis(4-chlorophenyl)-methanol" "4,4'-dichloro-alpha-phenylbenzylic alcohol" "benzenemethanol, 4-chloro-alpha-(4-chlorophenyl)-" );
gibbsFormation
{
    dHf_298   -50520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=101020.0
    phase     gas;
}
