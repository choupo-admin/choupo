/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentalenol, octahydro-3a,6a-dimethyl-, acetate  (C12H20O2, CAS 91499-02-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PentalenolOctahydro3a6aDimethylAcetate;
formula     C12H20O2;
CAS         91499-02-4;
InChIKey    BHYNNKGORVTDNQ-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          771.20;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.4916;      // -   [origin=predictive method=lee-kesler]
Tb          550.21;      // K   [origin=predictive method=joback]
HvapTb      47272.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-187.38 1.92896 -0.0018918 7.811e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group C; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3a,6a-dimethyl-1,2,3,4,5,6-hexahydropentalen-1-yl) ethanoate" "1-pentalenol, octahydro-3a,6a-dimethyl-, 1-acetate" );
gibbsFormation
{
    dHf_298   -464870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-181600.0
    phase     gas;
}
