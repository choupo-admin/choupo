/*--------------------------------*- Choupo -*-----------------------*\
  Component: trifluoromethyl (2-hydroxy-1-propenyl) ketone  (C5H5F3O2, CAS 7291-30-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trifluoromethyl2Hydroxy1PropenylKetone;
formula     C5H5F3O2;
CAS         7291-30-7;
InChIKey    HZWABPCDJWBJSC-RQOWECAXSA-N;
MW          154.087;      // g/mol [origin=calculated method=formula-sum]
Tc          626.84;      // K   [origin=predictive method=joback]
Pc          38.965;      // bar [origin=predictive method=joback]
omega       0.8750;      // -   [origin=predictive method=lee-kesler]
Tb          458.67;      // K   [origin=predictive method=joback]
HvapTb      46440.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.08 0.66592 -0.000567 1.8696e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group OH; count 1; } { group CH3CO; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } { group F; count 3; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-5,5,5-tris(fluoranyl)-4-oxidanyl-pent-3-en-2-one" "5,5,5-trifluoro-4-hydroxypent-3-en-2-one" "(z)-5,5,5-trifluoro-4-hydroxypent-3-en-2-one" );
standardThermochemistry
{
    dHf_298   -900990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-784440.0
}
