/*--------------------------------*- Choupo -*-----------------------*\
  Component: padimate a  (C14H21NO2, CAS 14779-78-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        padimateA;
formula     C14H21NO2;
CAS         14779-78-3;
InChIKey    LXTZRIBXKVRLOA-UHFFFAOYSA-N;
MW          235.327;      // g/mol [origin=calculated method=formula-sum]
Tc          818.66;      // K   [origin=predictive method=joback]
Pc          19.877;      // bar [origin=predictive method=joback]
omega       0.7891;      // -   [origin=predictive method=lee-kesler]
Tb          622.24;      // K   [origin=predictive method=joback]
HvapTb      59146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.726 1.26456 -0.00071996 1.363e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentyl 4-(dimethylamino)benzoate" "padimatum" "amyl dimethyl paba" "pentyl dimethyl paba" "benzoic acid, 4-(dimethylamino)-, pentyl ester" "amyl-p-dimethylaminobenzoate" "amyl 4-(dimethylamino)benzoate" "pentyl p-(dimethylamino)benzoate" "padimate a (usan)" "padimate a [usan]" "p-dimethylaminobenzoic acid, pentyl ester" "benzoic acid, p-dimethylamino-, pentyl ester" );
gibbsFormation
{
    dHf_298   -356980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     656.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29810.0
    phase     gas;
}
