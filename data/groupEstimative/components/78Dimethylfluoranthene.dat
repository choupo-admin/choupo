/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7,8-dimethylfluoranthene  (C18H14, CAS 38048-87-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        78Dimethylfluoranthene;
formula     C18H14;
CAS         38048-87-2;
InChIKey    SPKFXXMEJPYVQE-UHFFFAOYSA-N;
MW          230.31;      // g/mol [origin=calculated method=formula-sum]
Tc          953.77;      // K   [origin=predictive method=joback]
Pc          24.362;      // bar [origin=predictive method=joback]
omega       0.7210;      // -   [origin=predictive method=lee-kesler]
Tb          707.28;      // K   [origin=predictive method=joback]
HvapTb      64870.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.05 1.46104 -0.00123412 4.278e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 6; } { group ACCH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "fluoranthene, 7,8-dimethyl-" );
gibbsFormation
{
    dHf_298   303550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=488760.0
    phase     gas;
}
