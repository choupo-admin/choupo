/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,9-bis[1,1-dimethyl-2-[3-(3-tert-butyl-4-hydroxy-5-methylphenyl)propionyloxy]ethyl]-2,4,8,10-tetraoxaspiro[5.5]undecane  (C43H64O10, CAS 90498-90-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        39Bis11Dimethyl233TertButyl4Hydroxy5MethylphenylPropionyloxy;
formula     C43H64O10;
CAS         90498-90-1;
InChIKey    CGRTZESQZZGAAU-UHFFFAOYSA-N;
MW          740.975;      // g/mol [origin=calculated method=formula-sum]
Tc          2167.58;      // K   [origin=predictive method=joback]
Pc          6.253;      // bar [origin=predictive method=joback]
omega       0.1051;      // -   [origin=predictive method=lee-kesler]
Tb          1659.68;      // K   [origin=predictive method=joback]
HvapTb      171436.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-212.584 4.90324 -0.00375036 1.1756e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group CH2; count 2; } { group CH; count 2; } { group C; count 5; } { group ACH; count 4; } { group AC; count 2; } { group ACCH3; count 2; } { group ACCH2; count 2; } { group ACOH; count 2; } { group CH2COO; count 2; } { group FCH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group CH2; count 6; } { group C; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } { group O_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-[3-[1-[3-(3-tert-butyl-5-methyl-4-oxidanyl-phenyl)propanoyloxy]-2-methyl-propan-2-yl]-2,4,8,10-tetraoxaspiro[5.5]undecan-9-yl]-2-methyl-propyl] 3-(3-tert-butyl-5-methyl-4-oxidanyl-phenyl)propanoate" "benzenepropanoic acid, 3-(1,1-dimethylethyl)-4-hydroxy-5-methyl-, 1,1'-(2,4,8,10-tetraoxaspiro(5.5)undecane-3,9-diylbis(2,2-dimethyl-2,1-ethanediyl)) ester" "benzenepropanoic acid, 3-(1,1-dimethylethyl)-4-hydroxy-5-methyl-, 1,1'-[2,4,8,10-tetraoxaspiro[5.5]undecane-3,9-diylbis(2,2-dimethyl-2,1-ethanediyl)] ester" "benzenepropanoic acid, 3-(1,1-dimethylethyl)-4-hydroxy-5-methyl-, 2,4,8,10-tetraoxaspiro(5.5)undecane-3,9-diylbis(2,2-dimethyl-2,1-ethanediyl) ester" "benzenepropanoic acid, 3-(1,1-dimethylethyl)-4-hydroxy-5-methyl-, 2,4,8,10-tetraoxaspiro[5.5]undecane-3,9-diylbis(2,2-dimethyl-2,1-ethanediyl) ester" "sumilizer ga 80" "o827" );
gibbsFormation
{
    dHf_298   -1946150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1334.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-717820.0
    phase     gas;
}
