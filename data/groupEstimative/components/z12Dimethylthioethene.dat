/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-1,2-dimethylthioethene  (C4H8S2, CAS 764-44-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        z12Dimethylthioethene;
formula     C4H8S2;
CAS         764-44-3;
InChIKey    MRWRXEYAMMSGNE-ARJAWSKDSA-N;
MW          120.228;      // g/mol [origin=calculated method=formula-sum]
Tc          662.82;      // K   [origin=predictive method=joback]
Pc          43.511;      // bar [origin=predictive method=joback]
omega       0.3049;      // -   [origin=predictive method=lee-kesler]
Tb          432.84;      // K   [origin=predictive method=joback]
HvapTb      38090.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.27 0.39262 -0.0001972 2.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-1,2-bis(methylsulfanyl)ethene" "(z)-ch3sch=chsch3" );
gibbsFormation
{
    dHf_298   75070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=129260.0
    phase     gas;
}
