/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-bis(1-butylpentyl)-2,2'-bipyridine  (C28H44N2, CAS 72230-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Bis1Butylpentyl22Bipyridine;
formula     C28H44N2;
CAS         72230-93-4;
InChIKey    BLDQUHPMDSICNF-UHFFFAOYSA-N;
MW          408.674;      // g/mol [origin=calculated method=formula-sum]
Tc          1239.44;      // K   [origin=predictive method=joback]
Pc          9.433;      // bar [origin=predictive method=joback]
omega       0.8897;      // -   [origin=predictive method=lee-kesler]
Tb          1010.08;      // K   [origin=predictive method=joback]
HvapTb      95442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.018 2.4664 -0.00145264 3.258e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } { group C5H3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group Nd_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-nonan-5-yl-2-(4-nonan-5-ylpyridin-2-yl)pyridine" "2,2'-bipyridine, 4,4'-bis(1-butylpentyl)-" "2,2'-bipyridine,4,4'-bis(1-butylpentyl)-" "4,4'-bis(5-nonyl)-2,2'-bipyridine;4,4'-di(5-nonyl)-2,2'-bipyridine" );
gibbsFormation
{
    dHf_298   -116110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1027.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=539660.0
    phase     gas;
}
