/*--------------------------------*- Choupo -*-----------------------*\
  Component: rotoxamina  (C16H19ClN2O, CAS 5560-77-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        rotoxamina;
formula     C16H19ClN2O;
CAS         5560-77-0;
InChIKey    OJFSXZCBGQGRNV-INIZCTEOSA-N;
MW          290.791;      // g/mol [origin=calculated method=formula-sum]
Tc          986.62;      // K   [origin=predictive method=joback]
Pc          21.553;      // bar [origin=predictive method=joback]
omega       0.8358;      // -   [origin=predictive method=lee-kesler]
Tb          749.57;      // K   [origin=predictive method=joback]
HvapTb      71084.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.088 1.4137 -0.00087642 1.982e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } { group C5H4N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(s)-(4-chlorophenyl)-pyridin-2-yl-methoxy]-n,n-dimethyl-ethanamine" "rotoxaminum" "twiston" "(-)-2-(p-chloro-alpha-(2-(dimethylamino)ethoxy)benzyl)pyridine" "levocarbinoxamine" "(l)-carbinoxamine" "(-)-carbinoxamine" "rotoxamine [usan]" "rotoxamine (usan/inn)" "(s)-(-)-carbinoxamine" "2-[(s)-(4-chlorophenyl)(pyridin-2-yl)methoxy]-n,n-dimethylethanamine" "(-)-2-(4-chlor-alpha-(2-dimethylaminoethoxy)benzyl)pyridin" );
standardThermochemistry
{
    dHf_298   35100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=367490.0
}
