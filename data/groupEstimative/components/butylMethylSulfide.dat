/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl methyl sulfide  (C5H12S, CAS 628-29-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylMethylSulfide;
formula     C5H12S;
CAS         628-29-5;
InChIKey    WCXXISMIJBRDQK-UHFFFAOYSA-N;
MW          104.211;      // g/mol [origin=calculated method=formula-sum]
Tc          572.99;      // K   [origin=predictive method=joback]
Pc          35.389;      // bar [origin=predictive method=joback]
omega       0.3225;      // -   [origin=predictive method=lee-kesler]
Tb          382.78;      // K   [origin=predictive method=joback]
HvapTb      33541.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.943 0.47323 -0.000208 2.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylsulfanylbutane" "1-(Methylsulfanyl)butane" "1-(Methylthio)butane" "2-thiahexane" "Butane, 1-(methylthio)-" "butyl methyl thioether" "methyl butyl sulfide" "methyl n-butyl sulfide" "sulfide, butyl methyl" "n-butyl methyl sulfide" "α-(methylthio)butane" "butyl methyl sulphide" );
gibbsFormation
{
    dHf_298   -104660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24340.0
    phase     gas;
}
