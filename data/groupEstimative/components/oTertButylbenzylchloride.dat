/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-tert-butylbenzylchloride  (C11H15Cl, CAS 56240-38-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oTertButylbenzylchloride;
formula     C11H15Cl;
CAS         56240-38-1;
InChIKey    FCNALCYSVKFCNX-UHFFFAOYSA-N;
MW          182.691;      // g/mol [origin=calculated method=formula-sum]
Tc          739.44;      // K   [origin=predictive method=joback]
Pc          25.611;      // bar [origin=predictive method=joback]
omega       0.3983;      // -   [origin=predictive method=lee-kesler]
Tb          517.14;      // K   [origin=predictive method=joback]
HvapTb      46107.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.299 1.04306 -0.00073096 2.012e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-2-(chloromethyl)benzene" "2-tert-butylbenzyl chloride" "1-(chloromethyl)-2-tert-butyl-benzene" "benzene, 1-(chloromethyl)-2-(1,1-dimethylethyl)-" "benzene,1-(chloromethyl)-2-(1,1-dimethylethyl)-" "toluene,o-tert-butyl-a-chloro-(6ci,7ci); o-(chloromethyl)-tert-butylbenzene; o-tert-butyl-a-chlorotoluene" );
standardThermochemistry
{
    dHf_298   -69800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135430.0
}
