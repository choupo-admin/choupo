/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyl-2,4-dihydro-1h-naphthalene  (C12H16, CAS 13556-55-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyl24Dihydro1hNaphthalene;
formula     C12H16;
CAS         13556-55-3;
InChIKey    QJPWWLKPLICOLS-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          751.40;      // K   [origin=predictive method=joback]
Pc          29.092;      // bar [origin=predictive method=joback]
omega       0.3754;      // -   [origin=predictive method=lee-kesler]
Tb          517.07;      // K   [origin=predictive method=joback]
HvapTb      44178.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.98 1.43864 -0.00129956 4.996e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene,2,3,4-tetrahydro-2,2-dimethyl-" );
standardThermochemistry
{
    dHf_298   15930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196100.0
}
