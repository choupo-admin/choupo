/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethyleneglycol dipelargonate  (C24H46O6, CAS 106-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triethyleneglycolDipelargonate;
formula     C24H46O6;
CAS         106-06-9;
InChIKey    UBQXQCCAPASFJR-UHFFFAOYSA-N;
MW          430.626;      // g/mol [origin=calculated method=formula-sum]
Tc          1118.01;      // K   [origin=predictive method=joback]
Pc          7.953;      // bar [origin=predictive method=joback]
omega       0.7240;      // -   [origin=predictive method=lee-kesler]
Tb          910.00;      // K   [origin=predictive method=joback]
HvapTb      88652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (82.89 2.04784 -0.0008706 5.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group CH2COO; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 20; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-nonanoyloxyethoxy)ethoxy]ethyl nonanoate" "ethane-1,2-diylbis(oxyethane-2,1-diyl) dinonanoate" "triethylene glycol dinonanoate" "nonanoic acid, 1,2-ethanediylbis(oxy-2,1-ethanediyl) ester" "tri(ethylene glycol) dinonanoate" "nonanoic acid, 1,1'-(1,2-ethanediylbis(oxy-2,1-ethanediyl)) ester" "nonanoic acid, 1,1'-[1,2-ethanediylbis(oxy-2,1-ethanediyl)] ester" "ethylenebis(oxyethylene) dinonanoate" );
gibbsFormation
{
    dHf_298   -1437690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1215.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-679540.0
    phase     gas;
}
