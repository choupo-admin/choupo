/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,5-trimethylcyclohexyl methacrylate  (C13H22O2, CAS 7779-31-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        335TrimethylcyclohexylMethacrylate;
formula     C13H22O2;
CAS         7779-31-9;
InChIKey    DABQKEQFLJIRHU-UHFFFAOYSA-N;
MW          210.317;      // g/mol [origin=calculated method=formula-sum]
Tc          771.34;      // K   [origin=predictive method=joback]
Pc          20.109;      // bar [origin=predictive method=joback]
omega       0.5064;      // -   [origin=predictive method=lee-kesler]
Tb          562.27;      // K   [origin=predictive method=joback]
HvapTb      50009.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.92 1.52498 -0.0011168 3.568e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3,3,5-trimethylcyclohexyl) 2-methylprop-2-enoate" "3,3,5-trimethylcyclohexyl 2-methylprop-2-enoate" "3,3,5-trimethylcyclohexyl methacrylate, mixture of isomers" "2-propenoic acid, 2-methyl-, 3,3,5-trimethylcyclohexyl ester" "2-propenoic acid,2-methyl-, 3,3,5-trimethylcyclohexyl ester" "methacrylicacid, 3,3,5-trimethylcyclohexyl ester (8ci); 3,3,5-trimethylcyclohexylmethacrylate" );
gibbsFormation
{
    dHf_298   -484410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     659.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-168960.0
    phase     gas;
}
