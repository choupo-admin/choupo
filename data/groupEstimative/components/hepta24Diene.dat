/*--------------------------------*- Choupo -*-----------------------*\
  Component: hepta-2,4-diene  (C7H12, CAS 31357-24-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hepta24Diene;
formula     C7H12;
CAS         31357-24-1;
InChIKey    XTJLXXCARCJVPJ-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          549.78;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.2872;      // -   [origin=predictive method=lee-kesler]
Tb          368.08;      // K   [origin=predictive method=joback]
HvapTb      31092.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.839 0.70884 -0.0005246 1.669e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-heptadiene,(2z,4e)-" "2,4-heptadiene,(z,e)- (8ci,9ci); cis,trans-2,4-heptadiene; cis-2-trans-4-heptadiene" );
gibbsFormation
{
    dHf_298   46630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=168500.0
    phase     gas;
}
