/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl mercaptan  (C7H8S, CAS 100-53-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylMercaptan;
formula     C7H8S;
CAS         100-53-8;
InChIKey    UENWRTRMUIOCKN-UHFFFAOYSA-N;
MW          124.201;      // g/mol [origin=calculated method=formula-sum]
Tc          688.46;      // K   [origin=predictive method=joback]
Pc          44.742;      // bar [origin=predictive method=joback]
omega       0.3118;      // -   [origin=predictive method=lee-kesler]
Tb          449.30;      // K   [origin=predictive method=joback]
HvapTb      40189.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.489 0.6172 -0.0004106 1.032e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenylmethanethiol" "benzenemethanethiol" "benzylthiol" "alpha-toluenethiol" "thiobenzyl alcohol" "alpha-toluolthiol" "benzylhydrosulfide" "benzyl hydrosulfide" ".alpha.-toluenethiol" "alpha-tolyl mercaptan" "phenylmethyl mercaptan" "methanethiol, phenyl-" );
standardThermochemistry
{
    dHf_298   87200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=149860.0
}
