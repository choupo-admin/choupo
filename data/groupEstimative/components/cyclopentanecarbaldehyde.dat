/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentanecarbaldehyde  (C6H10O, CAS 872-53-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentanecarbaldehyde;
formula     C6H10O;
CAS         872-53-7;
InChIKey    VELDYOPRLMJFIK-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          604.71;      // K   [origin=predictive method=joback]
Pc          42.166;      // bar [origin=predictive method=joback]
omega       0.3531;      // -   [origin=predictive method=lee-kesler]
Tb          400.82;      // K   [origin=predictive method=joback]
HvapTb      35927.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.65 0.68 -0.000423 9.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentanecarboxaldehyde" "cyclopentanealdehyde" "cyclopentancarbaldehyd" "1-formylcyclopentane" "cyclopentylformaldehyde" "formylcyclopentane" "cyclopentyl aldehyde" "cyclopentylmethanal" "cyclopentane-1-carboxaldehyde" "cyclopentyl carboxaldehyde" "s963" );
gibbsFormation
{
    dHf_298   -192270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-63330.0
    phase     gas;
}
