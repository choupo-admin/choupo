/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexadecanol  (C16H34O, CAS 14852-31-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexadecanol;
formula     C16H34O;
CAS         14852-31-4;
InChIKey    FVDRFBGMOWJEOR-UHFFFAOYSA-N;
MW          242.447;      // g/mol [origin=calculated method=formula-sum]
Tc          818.85;      // K   [origin=predictive method=joback]
Pc          14.197;      // bar [origin=predictive method=joback]
omega       1.0733;      // -   [origin=predictive method=lee-kesler]
Tb          657.42;      // K   [origin=predictive method=joback]
HvapTb      67501.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.047 1.56374 -0.0008802 1.885e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecan-2-ol" "hexadecanol-2" "2-hexadecanol, (2r)-" "2-hexadecanol, (2s)-" "methyl tetradecyl carbinol" );
gibbsFormation
{
    dHf_298   -531080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     820.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55420.0
    phase     gas;
}
