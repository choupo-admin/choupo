/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-fluoro-1,4-dihydro-1,4-methanonaphthalene  (C11H9F, CAS 58653-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Fluoro14Dihydro14Methanonaphthalene;
formula     C11H9F;
CAS         58653-71-7;
InChIKey    ABCQDMLSRHMYNP-UHFFFAOYSA-N;
MW          160.191;      // g/mol [origin=calculated method=formula-sum]
Tc          716.00;      // K   [origin=predictive method=joback]
Pc          32.765;      // bar [origin=predictive method=joback]
omega       0.4517;      // -   [origin=predictive method=lee-kesler]
Tb          495.56;      // K   [origin=predictive method=joback]
HvapTb      42809.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.91 1.1181 -0.0009622 3.337e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group ACCH; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-methanonaphthalene,6-fluoro-1,4-dihydro-" "1,4-methanonaphthalene, 6-fluoro-1,4-dihydro-" );
gibbsFormation
{
    dHf_298   -43350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     259.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103640.0
    phase     gas;
}
