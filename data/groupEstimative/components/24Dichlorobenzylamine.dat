/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dichlorobenzylamine  (C7H7Cl2N, CAS 95-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dichlorobenzylamine;
formula     C7H7Cl2N;
CAS         95-00-1;
InChIKey    SJUKJZSTBBSGHF-UHFFFAOYSA-N;
MW          176.04;      // g/mol [origin=calculated method=formula-sum]
Tc          783.85;      // K   [origin=predictive method=joback]
Pc          38.771;      // bar [origin=predictive method=joback]
omega       0.5339;      // -   [origin=predictive method=lee-kesler]
Tb          543.79;      // K   [origin=predictive method=joback]
HvapTb      54187.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.491 0.5464 -0.00033832 7.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CH2NH2; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,4-dichlorophenyl)methanamine" "benzenemethanamine, 2,4-dichloro-" "benzylamine, 2,4-dichloro-" "(2,4-dichlorophenyl)methylamine" "1-(2,4-dichlorophenyl)methanamine" "2,4-dichloro-benzylamine" "benzylamine, 2,4-dichloro- (8ci)" "p342" );
gibbsFormation
{
    dHf_298   28090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143800.0
    phase     gas;
}
