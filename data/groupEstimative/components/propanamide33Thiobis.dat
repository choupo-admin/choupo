/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanamide, 3,3'-thiobis-  (C6H12N2O2S, CAS 5459-10-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanamide33Thiobis;
formula     C6H12N2O2S;
CAS         5459-10-9;
InChIKey    GNAYFTGREAJJLY-UHFFFAOYSA-N;
MW          176.234;      // g/mol [origin=calculated method=formula-sum]
Tc          885.40;      // K   [origin=predictive method=joback]
Pc          42.330;      // bar [origin=predictive method=joback]
omega       1.0523;      // -   [origin=predictive method=lee-kesler]
Tb          658.46;      // K   [origin=predictive method=joback]
HvapTb      70541.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.734 0.63599 -0.0003118 3.652e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CONH2; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CdO; count 2; } { group NH2; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3-azanyl-3-oxidanylidene-propyl)sulfanylpropanamide" "3,3'-thiodipropionamide" "3-[(3-amino-3-oxopropyl)thio]propanamide" ".beta.,.beta.'-thiodipropionamide" "4-thia-dipropionic acid 1,7-diamide" "3,3'-thiobis(propionamide)" "3,3'-thiobis[propionamide]" "3,3'-thiodipropanamide" "3,3'-thiobispropanamide" "propanamide,3'-thiobis-" "3,3'-thiobispropionamide" "propionamide,3'-thiobis-" );
standardThermochemistry
{
    dHf_298   -282880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-92180.0
}
