/*--------------------------------*- Choupo -*-----------------------*\
  Component: sahrekkusu  (C11H11N, CAS 9003-54-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sahrekkusu;
formula     C11H11N;
CAS         9003-54-7;
InChIKey    SCUZVMOVTVSBLE-UHFFFAOYSA-N;
MW          157.216;      // g/mol [origin=calculated method=formula-sum]
Tc          811.37;      // K   [origin=predictive method=joback]
Pc          25.715;      // bar [origin=predictive method=joback]
omega       0.4656;      // -   [origin=predictive method=lee-kesler]
Tb          574.80;      // K   [origin=predictive method=joback]
HvapTb      51788.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.82 0.6585 -0.0002058 -4.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group ACRY; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenylbenzene;prop-2-enenitrile" "acrilafil" "dikaril" "lorkaril" "lustran" "piccoflex" "polysan" "tyrilfoam" "dialux" "kostil" "sanrex" "litac" );
gibbsFormation
{
    dHf_298   270280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=358250.0
    phase     gas;
}
