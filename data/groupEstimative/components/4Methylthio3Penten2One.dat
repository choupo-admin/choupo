/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylthio-3-penten-2-one  (C6H10OS, CAS 60887-86-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylthio3Penten2One;
formula     C6H10OS;
CAS         60887-86-7;
InChIKey    JEVVTPRSFIWIPW-GQCTYLIASA-N;
MW          130.205;      // g/mol [origin=calculated method=formula-sum]
Tc          678.66;      // K   [origin=predictive method=joback]
Pc          36.421;      // bar [origin=predictive method=joback]
omega       0.4309;      // -   [origin=predictive method=lee-kesler]
Tb          463.57;      // K   [origin=predictive method=joback]
HvapTb      42551.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.52 0.56015 -0.0003298 7.276e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group dC; count 1; } { group CdO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-4-methylsulfanylpent-3-en-2-one" "ch3sc(ch3)=chc(=o)ch3" );
standardThermochemistry
{
    dHf_298   -130450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-24490.0
}
