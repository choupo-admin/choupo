/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-butadiene-2-ol  (C4H6O, CAS 59120-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Butadiene2Ol;
formula     C4H6O;
CAS         59120-04-6;
InChIKey    DYBUYNXFWDRGMW-UHFFFAOYSA-N;
MW          70.091;      // g/mol [origin=calculated method=formula-sum]
Tc          548.62;      // K   [origin=predictive method=joback]
Pc          49.524;      // bar [origin=predictive method=joback]
omega       0.5772;      // -   [origin=predictive method=lee-kesler]
Tb          376.54;      // K   [origin=predictive method=joback]
HvapTb      39917.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.13 0.3777 -0.0002723 8.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "buta-1,3-dien-2-ol" "ch2=chc(oh)=ch2" );
gibbsFormation
{
    dHf_298   -37050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13110.0
    phase     gas;
}
