/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-diphenylsuccinic acid  (C16H14O4, CAS 7584-72-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DiphenylsuccinicAcid;
formula     C16H14O4;
CAS         7584-72-7;
InChIKey    PVXCQHHWNDJIJP-UHFFFAOYSA-N;
MW          270.284;      // g/mol [origin=calculated method=formula-sum]
Tc          1159.55;      // K   [origin=predictive method=joback]
Pc          27.759;      // bar [origin=predictive method=joback]
omega       1.3177;      // -   [origin=predictive method=lee-kesler]
Tb          909.18;      // K   [origin=predictive method=joback]
HvapTb      89314.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.63 1.4794 -0.0010606 2.852e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group ACCH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-diphenylbutanedioic acid" "butanedioic acid, 2,3-diphenyl-" "2,3-diphenyl-butanedioic acid" "2,3-di(phenyl)butanedioic acid" "butanedioic acid,2,3-diphenyl-" "racemic-2,3-diphenylbutanedioic acid" "(r*,s*)-2,3-diphenylsuccinic acid" "(r,r)-2,3-diphenylsuccinic acid" "bim-0004755.p001" "butanedioic acid, 2,3-diphenyl-, (r*,s*)-" "succinicacid, 2,3-diphenyl- (6ci,7ci,8ci); 2,3-diphenylsuccinic acid; a,a'-diphenylsuccinic acid; a,b-diphenylsuccinic acid" );
standardThermochemistry
{
    dHf_298   -611610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     653.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-384040.0
}
