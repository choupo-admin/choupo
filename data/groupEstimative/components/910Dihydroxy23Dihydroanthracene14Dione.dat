/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,10-dihydroxy-2,3-dihydroanthracene-1,4-dione  (C14H10O4, CAS 17648-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        910Dihydroxy23Dihydroanthracene14Dione;
formula     C14H10O4;
CAS         17648-03-2;
InChIKey    FVXPBEUYCCZFJT-UHFFFAOYSA-N;
MW          242.23;      // g/mol [origin=calculated method=formula-sum]
Tc          1169.11;      // K   [origin=predictive method=joback]
Pc          46.913;      // bar [origin=predictive method=joback]
omega       1.3173;      // -   [origin=predictive method=lee-kesler]
Tb          888.10;      // K   [origin=predictive method=joback]
HvapTb      86914.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.87 1.2726 -0.00102556 3.5e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 4; } { group ACOH; count 2; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 6; } { group OH_phenol; count 2; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10-bis(oxidanyl)-2,3-dihydroanthracene-1,4-dione" "2,3-dihydro-9,10-dihydroxy-1,4-anthracenedione" "leuco-1,4-dihydroxyanthraquinone" "2,3-dihydro-9,10-dihydroxyanthracene-1,4-dione" "1,4-anthracenedione, 2,3-dihydro-9,10-dihydroxy-" "2,3-dihydro-1,4-dihydroxyanthraquinone" "leucoquinazarin" "2,4-dihydroxyanthraquinone" "9, 2,3-dihydro-1,4-dihydroxy-" "anthraquinone,3-dihydro-1,4-dihydroxy" "anthraquinone, 2,3-dihydro-1,4-dihydroxy" "9,10-dihydroxy-2,3-dihydro-anthracene-1,4-dione" );
standardThermochemistry
{
    dHf_298   -470670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     341.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-231260.0
}
