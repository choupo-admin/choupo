/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane,2-cyclopenten-1-yl-  (C11H18, CAS 2690-15-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexane2Cyclopenten1Yl;
formula     C11H18;
CAS         2690-15-5;
InChIKey    NUDIIKZTYHUYMF-UHFFFAOYSA-N;
MW          150.265;      // g/mol [origin=calculated method=formula-sum]
Tc          715.06;      // K   [origin=predictive method=joback]
Pc          29.124;      // bar [origin=predictive method=joback]
omega       0.3149;      // -   [origin=predictive method=lee-kesler]
Tb          485.27;      // K   [origin=predictive method=joback]
HvapTb      41058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-125.42 1.2466 -0.00077028 1.73e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopent-2-en-1-ylcyclohexane" );
standardThermochemistry
{
    dHf_298   -97790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132700.0
}
