/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetracyclo[5.3.0.02,6.03,10]decane  (C10H14, CAS 34511-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetracyclo5300260310Decane;
formula     C10H14;
CAS         34511-84-7;
InChIKey    NUFMNRYWZHLLTD-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          642.95;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.3598;      // -   [origin=predictive method=lee-kesler]
Tb          437.48;      // K   [origin=predictive method=joback]
HvapTb      36544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-185.05 1.5236 -0.001383 5.084e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetracyclo(5.3.0.02,6.03,10)decane" "tetracyclo[5.3.0.02,6.03,10]decane(9ci)" "tetracyclo[5.3.0.02,6.05,8]decane;tetrahydrohypostrophene" );
gibbsFormation
{
    dHf_298   13110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     59.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=285100.0
    phase     gas;
}
