/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonane, 1,1,1-trifluoro-  (C9H17F3, CAS 55757-34-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonane111Trifluoro;
formula     C9H17F3;
CAS         55757-34-1;
InChIKey    CWRXCYHKNPSCOC-UHFFFAOYSA-N;
MW          182.229;      // g/mol [origin=calculated method=formula-sum]
Tc          548.74;      // K   [origin=predictive method=joback]
Pc          20.699;      // bar [origin=predictive method=joback]
omega       0.5227;      // -   [origin=predictive method=lee-kesler]
Tb          400.10;      // K   [origin=predictive method=joback]
HvapTb      31881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.493 1.02002 -0.0006868 1.846e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group C; count 1; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(fluoranyl)nonane" );
gibbsFormation
{
    dHf_298   -826170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-556690.0
    phase     gas;
}
