\*---------------------------------------------------------------------------*/

name        hexadecylIsocyanate;
formula     C17H33NO;
CAS         1943-84-6;
InChIKey    GFLXBRUGMACJLQ-UHFFFAOYSA-N;
MW          267.457;      // g/mol [origin=calculated method=formula-sum]
Tc          822.64;      // K   [origin=predictive method=joback]
Pc          12.977;      // bar [origin=predictive method=joback]
omega       0.9150;      // -   [origin=predictive method=lee-kesler]
Tb          655.23;      // K   [origin=predictive method=joback]
HvapTb      62968.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group dCd; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanatohexadecane" "hexadecane, 1-isocyanato-" "hexadecane,1-isocyanato-" "1-hexadecanol,isocyanate (5ci); isocyanic acid, hexadecyl ester (6ci,7ci,8ci); hexadecylisocyanate" );
