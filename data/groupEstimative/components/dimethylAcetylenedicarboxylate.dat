/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl acetylenedicarboxylate  (C6H6O4, CAS 762-42-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylAcetylenedicarboxylate;
formula     C6H6O4;
CAS         762-42-5;
InChIKey    VHILMKFSCRWWIJ-UHFFFAOYSA-N;
MW          142.11;      // g/mol [origin=calculated method=formula-sum]
Tc          668.65;      // K   [origin=predictive method=joback]
Pc          37.916;      // bar [origin=predictive method=joback]
omega       0.5070;      // -   [origin=predictive method=lee-kesler]
Tb          462.32;      // K   [origin=predictive method=joback]
HvapTb      45916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (65.81 0.31444 -2.126e-05 -7.502e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C_C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group tC; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl but-2-ynedioate" "2-butynedioic acid, dimethyl ester" "dimethyl butynedioate" "dimethyl 2-butynedioate" "acetylenedicarboxylic acid dimethyl ester" "acetylenedicarboxylic acid, dimethyl ester" "methyl acetylenedicarboxylate" "bis(methoxycarbonyl)acetylene" "1,2-bis(methoxycarbonyl)acetylene" "di(carbomethoxy)acetylene" "dimethyl ethynedicarboxylate" "1,2-bis(methoxycarbonyl)ethyne" );
standardThermochemistry
{
    dHf_298   -529430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-418300.0
}
