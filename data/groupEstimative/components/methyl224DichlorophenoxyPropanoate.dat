/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-(2,4-dichlorophenoxy)propanoate  (C10H10Cl2O3, CAS 23844-57-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl224DichlorophenoxyPropanoate;
formula     C10H10Cl2O3;
CAS         23844-57-7;
InChIKey    SCHCPDWDIOTCMJ-UHFFFAOYSA-N;
MW          249.087;      // g/mol [origin=calculated method=formula-sum]
Tc          842.68;      // K   [origin=predictive method=joback]
Pc          26.164;      // bar [origin=predictive method=joback]
omega       0.7053;      // -   [origin=predictive method=lee-kesler]
Tb          620.10;      // K   [origin=predictive method=joback]
HvapTb      59653.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.5 0.65744 -0.00025572 -1.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 1; } { group CH-O; count 1; } { group ACCl; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-[2,4-bis(chloranyl)phenoxy]propanoate" "2,4-dp methyl ester" "dichlorprop-methyl ester" "methyl 2-(2,4-dichlorophenoxy)propionate" "dichlorprop methyl ester" "dichlorprop-methyl" "dichlorprop, methyl ester" "dichlorprop-methyl [iso]" "methyl (1)-2-(2,4-dichlorophenoxy)propionate" "propanoic acid, 2-(2,4-dichlorophenoxy)-, methyl ester" "propanoic acid, 2-(2',4'-dichlorophenoxy)-, methyl ester" );
gibbsFormation
{
    dHf_298   -522400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-315200.0
    phase     gas;
}
