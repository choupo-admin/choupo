/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetic acid, bromo-, pentachlorophenyl ester  (C8H2BrCl5O2, CAS 21219-23-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aceticAcidBromoPentachlorophenylEster;
formula     C8H2BrCl5O2;
CAS         21219-23-8;
InChIKey    KLKJDOXPPVLZCE-UHFFFAOYSA-N;
MW          387.256;      // g/mol [origin=calculated method=formula-sum]
Tc          998.11;      // K   [origin=predictive method=joback]
Pc          29.505;      // bar [origin=predictive method=joback]
omega       0.8865;      // -   [origin=predictive method=lee-kesler]
Tb          745.75;      // K   [origin=predictive method=joback]
HvapTb      74755.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (131.261 0.4048 -0.0001862 7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group CH2COO; count 1; } { group ACCl; count 5; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dC_ring; count 6; } { group Cl; count 5; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,3,4,5,6-pentakis(chloranyl)phenyl] 2-bromanylethanoate" "pentachlorophenyl bromoacetate" "(2,3,4,5,6-pentachlorophenyl) 2-bromoacetate" );
standardThermochemistry
{
    dHf_298   -398920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-274960.0
}
