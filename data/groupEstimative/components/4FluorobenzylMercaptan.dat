/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluorobenzyl mercaptan  (C7H7FS, CAS 15894-04-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4FluorobenzylMercaptan;
formula     C7H7FS;
CAS         15894-04-9;
InChIKey    RKTRHMNWVZRZJQ-UHFFFAOYSA-N;
MW          142.191;      // g/mol [origin=calculated method=formula-sum]
Tc          680.74;      // K   [origin=predictive method=joback]
Pc          41.356;      // bar [origin=predictive method=joback]
omega       0.3677;      // -   [origin=predictive method=lee-kesler]
Tb          453.55;      // K   [origin=predictive method=joback]
HvapTb      40034.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.099 0.5695 -0.00035996 8.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH2SH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-fluorophenyl)methanethiol" "4-fluoro benzyl mercaptan" "benzenemethanethiol, 4-fluoro-" "4-fluorobenzylmercaptan" "4-fluorobenzenemethanethiol" "4-fluorobenzylthiol" "4-fluorobenzyl thiol" "agn-pc-0ckfre" "p-fluorobenzenemethanethiol" "p-fluorotoluene-alpha-thiol" "4-fluoro-alpha-toluenethiol" "i342" );
gibbsFormation
{
    dHf_298   -120380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-54580.0
    phase     gas;
}
