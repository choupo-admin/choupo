/*--------------------------------*- Choupo -*-----------------------*\
  Component: octamethyltetrasila[2.2](2,5)thiophenophane  (C16H28S2Si4, CAS 114184-41-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H28S2Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        octamethyltetrasila2225Thiophenophane;
formula     C16H28S2Si4;
CAS         114184-41-7;
InChIKey    BVJHTSJAOOXKRY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          396.86;      // g/mol [origin=calculated method=formula-sum]
Tc          974.77;      // K   [origin=predictive method=joback]
Pc          14.261;      // bar [origin=predictive method=joback]
omega       0.4169;      // -   [origin=predictive method=lee-kesler]
Tb          722.00;      // K   [origin=predictive method=joback]
HvapTb      68664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (109.91 0.78858 0.00031384 -4.022e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group Si; count 4; } { group C4H2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octamethyltetrasila(2.2)(2,5)thiophenophane" );
standardThermochemistry
{
    dHf_298   -271030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1087.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=19120.0
}
