/*--------------------------------*- Choupo -*-----------------------*\
  Component: einecs 233-025-2  (C26H50O6, CAS 10024-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        einecs2330252;
formula     C26H50O6;
CAS         10024-58-5;
InChIKey    KCNIYOMOUYURBQ-UHFFFAOYSA-N;
MW          458.68;      // g/mol [origin=calculated method=formula-sum]
Tc          1182.18;      // K   [origin=predictive method=joback]
Pc          7.157;      // bar [origin=predictive method=joback]
omega       0.5682;      // -   [origin=predictive method=lee-kesler]
Tb          955.76;      // K   [origin=predictive method=joback]
HvapTb      93104.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (81.072 2.23784 -0.0009794 7.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 18; } { group CH2COO; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 22; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-decanoyloxyethoxy)ethoxy]ethyl decanoate" "decanoic acid, diester with triethylene glycol (mixed isomers)" "didecanoyltriethylene glycol ester (mixed isomers)" "1,2-ethanediylbis(oxy-2,1-ethanediyl) didecanoate" "decanoic acid, 1,1'-(1,2-ethanediylbis(oxy-2,1-ethanediyl)) ester" "decanoic acid, 1,1'-[1,2-ethanediylbis(oxy-2,1-ethanediyl)] ester" );
standardThermochemistry
{
    dHf_298   -1478970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1293.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-662700.0
}
