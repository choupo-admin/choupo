/*--------------------------------*- Choupo -*-----------------------*\
  Component: buta-1,3-diene;dodecane-1-thiol;prop-2-enoic acid  (C19H36O2S, CAS 67874-90-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        buta13DieneDodecane1ThiolProp2EnoicAcid;
formula     C19H36O2S;
CAS         67874-90-2;
InChIKey    LGDUGJIPIBMOAY-UHFFFAOYSA-N;
MW          328.555;      // g/mol [origin=calculated method=formula-sum]
Tc          1037.11;      // K   [origin=predictive method=joback]
Pc          11.577;      // bar [origin=predictive method=joback]
omega       0.9419;      // -   [origin=predictive method=lee-kesler]
Tb          835.53;      // K   [origin=predictive method=joback]
HvapTb      80367.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (77.771 1.41452 -0.0003439 -1.337e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH2=CH; count 3; } { group COOH; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH2; count 3; } { group dCH; count 3; } { group COOH; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, telomer with 1,3-butadiene and 1-dodecanethiol" "buta-1,3-diene; dodecane-1-thiol; prop-2-enoic acid" );
gibbsFormation
{
    dHf_298   -594230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1213.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-151420.0
    phase     gas;
}
