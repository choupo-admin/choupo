/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicarboxydine  (C20H24N2O6, CAS 73758-56-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicarboxydine;
formula     C20H24N2O6;
CAS         73758-56-2;
InChIKey    FFTZKJNDWLEIQY-UHFFFAOYSA-N;
MW          388.42;      // g/mol [origin=calculated method=formula-sum]
Tc          1483.17;      // K   [origin=predictive method=joback]
Pc          19.270;      // bar [origin=predictive method=joback]
omega       1.5648;      // -   [origin=predictive method=lee-kesler]
Tb          1211.40;      // K   [origin=predictive method=joback]
HvapTb      127744.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.276 1.607 -0.00086844 1.466e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 6; } { group AC; count 4; } { group CH2O; count 2; } { group ACNH2; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 2; } { group COOH; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-azanyl-4-[3-azanyl-4-(4-oxidanyl-4-oxidanylidene-butoxy)phenyl]phenoxy]butanoic acid" "gamma,gamma'-,3,3'-benzidine dioxydibutyric acid" "butyric acid, 4,4'-(3,3'-diamino-p,p'-biphenylenedioxy)di-" "4-[2-amino-4-[3-amino-4-(4-hydroxy-4-oxobutoxy)phenyl]phenoxy]butanoic acid" );
gibbsFormation
{
    dHf_298   -926350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     929.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-461100.0
    phase     gas;
}
