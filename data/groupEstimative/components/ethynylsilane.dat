/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethynylsilane  (C2H4Si, CAS 1066-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C2H4Si (delta H+3Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethynylsilane;
formula     C2H4Si;
CAS         1066-27-9;
InChIKey    SRNLFSKWPCUYHC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          56.139;      // g/mol [origin=calculated method=formula-sum]
Tc          398.94;      // K   [origin=predictive method=joback]
Pc          55.196;      // bar [origin=predictive method=joback]
omega       0.0603;      // -   [origin=predictive method=lee-kesler]
Tb          234.78;      // K   [origin=predictive method=joback]
HvapTb      19757.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.56 0.203 -0.00028833 1.3959e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH_C; count 1; } { group SiH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   263100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=241410.0
}
