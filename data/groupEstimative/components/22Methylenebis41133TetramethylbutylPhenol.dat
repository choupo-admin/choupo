/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-methylenebis(4-(1,1,3,3-tetramethylbutyl)phenol)  (C29H44O2, CAS 27725-17-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Methylenebis41133TetramethylbutylPhenol;
formula     C29H44O2;
CAS         27725-17-3;
InChIKey    NHKWEDRAPLIPAU-UHFFFAOYSA-N;
MW          424.669;      // g/mol [origin=calculated method=formula-sum]
Tc          1324.93;      // K   [origin=predictive method=joback]
Pc          11.141;      // bar [origin=predictive method=joback]
omega       0.9852;      // -   [origin=predictive method=lee-kesler]
Tb          1074.76;      // K   [origin=predictive method=joback]
HvapTb      106868.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-178.417 3.2946 -0.00268204 8.889e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group CH2; count 2; } { group C; count 4; } { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group CH2; count 3; } { group C; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[2-oxidanyl-5-(2,4,4-trimethylpentan-2-yl)phenyl]methyl]-4-(2,4,4-trimethylpentan-2-yl)phenol" "phenol, 2,2'-methylenebis(4-(1,1,3,3-tetramethylbutyl)-" "phenol, 2,2'-methylenebis[4-(1,1,3,3-tetramethylbutyl)-" "2,2'-methylenebis[4-(1,1,3,3-tetramethylbutyl)phenol]" "phenol,2,2'-methylenebis[4-(1,1,3,3-tetramethylbutyl)-" "4,4'-bis(1,1,3,3-tetramethylbutyl)-2,2'-methylenediphenol" "2-[[2-hydroxy-5-(2,4,4-trimethylpentan-2-yl)phenyl]methyl]-4-(2,4,4-trimethylpentan-2-yl)phenol" );
gibbsFormation
{
    dHf_298   -581390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     957.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100980.0
    phase     gas;
}
