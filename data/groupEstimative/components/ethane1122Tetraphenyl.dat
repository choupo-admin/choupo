/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethane, 1,1,2,2-tetraphenyl-  (C26H22, CAS 632-50-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethane1122Tetraphenyl;
formula     C26H22;
CAS         632-50-8;
InChIKey    RUGHUJBHQWALKM-UHFFFAOYSA-N;
MW          334.462;      // g/mol [origin=calculated method=formula-sum]
Tc          1177.51;      // K   [origin=predictive method=joback]
Pc          17.743;      // bar [origin=predictive method=joback]
omega       0.7656;      // -   [origin=predictive method=lee-kesler]
Tb          900.32;      // K   [origin=predictive method=joback]
HvapTb      81798.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-159.73 2.17 -0.0015218 3.992e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 20; } { group AC; count 2; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group dCH_ring; count 20; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,2-triphenylethylbenzene" "benzene, 1,1',1'',1'''-(1,2-ethanediylidene)tetrakis-" "bibenzhydryl" "sym-tetraphenylethane" "1,2,2-tetraphenylethane" "1,1,2,2-tetraphenylethane" "ethane,1,2,2-tetraphenyl-" "tetraphenylethylene dianion sodium salt" ".alpha.,.beta.,.beta.-tetraphenylethane" "benzene,1',1'',1'''-ethenetetrayltetrakis-" "benzene,1',1'',1'''-(1,2-ethanediylidene)tetrakis-" "benzene,1,1',1'',1'''-(1,2-ethanediylidene)tetrakis-" );
standardThermochemistry
{
    dHf_298   355590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     724.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=612800.0
}
