/*--------------------------------*- Choupo -*-----------------------*\
  Component: 12-tetradecen-9-yn-1-ol, acetate, (12e)-  (C16H26O2, CAS 71394-01-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Tetradecen9Yn1OlAcetate12e;
formula     C16H26O2;
CAS         71394-01-9;
InChIKey    XEGTWQITZCHUAR-UHFFFAOYSA-N;
MW          250.382;      // g/mol [origin=calculated method=formula-sum]
Tc          822.81;      // K   [origin=predictive method=joback]
Pc          15.537;      // bar [origin=predictive method=joback]
omega       0.7824;      // -   [origin=predictive method=lee-kesler]
Tb          637.06;      // K   [origin=predictive method=joback]
HvapTb      60727.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.129 1.33924 -0.00074366 1.4848e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH=CH; count 1; } { group CH3COO; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group dCH; count 2; } { group tC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradec-12-en-9-ynyl ethanoate" "12-tetradecen-9-yn-1-ol, 1-acetate, (12e)-" );
standardThermochemistry
{
    dHf_298   -301330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     795.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56490.0
}
