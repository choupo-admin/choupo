/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluorobenzoic acid  (C7H5FO2, CAS 445-29-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2FluorobenzoicAcid;
formula     C7H5FO2;
CAS         445-29-4;
InChIKey    NSTREUWFTAOOKS-UHFFFAOYSA-N;
MW          140.113;      // g/mol [origin=calculated method=formula-sum]
Tc          758.08;      // K   [origin=predictive method=joback]
Pc          42.719;      // bar [origin=predictive method=joback]
omega       0.6871;      // -   [origin=predictive method=lee-kesler]
Tb          536.20;      // K   [origin=predictive method=joback]
HvapTb      50461.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.39 0.593 -0.00041016 1.063e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group COOH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-fluoranylbenzoic acid" "o-fluorobenzoic acid" "benzoic acid, 2-fluoro-" "benzoic acid, o-fluoro-" "o-fluorbenzoesaeure" "ofba" "o-fluorbenzoesaeure [german]" "2-fluoro-benzoic acid" "ortho-fluorobenzoic acid" "10.14272/nstreuwftaooks-uhfffaoysa-n" "doi:10.14272/nstreuwftaooks-uhfffaoysa-n" "benzoic acid, o-fluoro-;o-fluorobenzoic acid;o-fluorbenzoesaeure;benzoic acid, 2-fluoro-;o-fluorbenzoesaeure [german];" );
standardThermochemistry
{
    dHf_298   -509130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-427880.0
}
