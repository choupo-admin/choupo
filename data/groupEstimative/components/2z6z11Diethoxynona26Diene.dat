/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2z,6z)-1,1-diethoxynona-2,6-diene  (C13H24O2, CAS 67674-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2z6z11Diethoxynona26Diene;
formula     C13H24O2;
CAS         67674-37-7;
InChIKey    GCIRJCKOUVCUBZ-UHFFFAOYSA-N;
MW          212.333;      // g/mol [origin=calculated method=formula-sum]
Tc          726.02;      // K   [origin=predictive method=joback]
Pc          17.536;      // bar [origin=predictive method=joback]
omega       0.6827;      // -   [origin=predictive method=lee-kesler]
Tb          549.76;      // K   [origin=predictive method=joback]
HvapTb      48880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.025 1.15836 -0.0006322 1.282e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH=CH; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group dCH; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diethoxynona-2,6-diene" "2,6-nonadiene, 1,1-diethoxy-, (2e,6z)-" "2,6-nonadiene, 1,1-diethoxy-, (2z,6z)-" );
gibbsFormation
{
    dHf_298   -346930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     662.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6580.0
    phase     gas;
}
