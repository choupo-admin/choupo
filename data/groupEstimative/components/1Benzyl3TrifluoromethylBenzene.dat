/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-benzyl-3-(trifluoromethyl)benzene  (C14H11F3, CAS 75198-32-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Benzyl3TrifluoromethylBenzene;
formula     C14H11F3;
CAS         75198-32-2;
InChIKey    SHNGXCGDFPNOCG-UHFFFAOYSA-N;
MW          236.236;      // g/mol [origin=calculated method=formula-sum]
Tc          792.73;      // K   [origin=predictive method=joback]
Pc          24.243;      // bar [origin=predictive method=joback]
omega       0.5490;      // -   [origin=predictive method=lee-kesler]
Tb          572.84;      // K   [origin=predictive method=joback]
HvapTb      48225.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.549 1.2777 -0.00095416 2.702e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(phenylmethyl)-3-(trifluoromethyl)benzene" "3-trifluoromethyldiphenylmethane" "benzene, 1-(phenylmethyl)-3-(trifluoromethyl)-" );
standardThermochemistry
{
    dHf_298   -467780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-299400.0
}
