/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-3-cyclohexen-1-one  (C7H10O, CAS 31883-98-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl3Cyclohexen1One;
formula     C7H10O;
CAS         31883-98-4;
InChIKey    MHBNXZDNKOXHCX-UHFFFAOYSA-N;
MW          110.156;      // g/mol [origin=calculated method=formula-sum]
Tc          683.93;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.3514;      // -   [origin=predictive method=lee-kesler]
Tb          455.94;      // K   [origin=predictive method=joback]
HvapTb      37115.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.51 0.53362 -0.00016964 -2.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylcyclohex-3-en-1-one" "3-cyclohexen-1-one, 3-methyl-" "3-cyclohexen-1-one,3-methyl-" "1-methylcyclohex-1-en-5-one;3-methyl-3-cyclohexen-1-one; 3-methyl-3-cyclohexenone" );
standardThermochemistry
{
    dHf_298   -204540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     318.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-62040.0
}
