/*--------------------------------*- Choupo -*-----------------------*\
  Component: veramin ed 4  (C18H40N2O8, CAS 27014-42-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        veraminEd4;
formula     C18H40N2O8;
CAS         27014-42-2;
InChIKey    VZNCZGIMPKAVMR-UHFFFAOYSA-N;
MW          412.524;      // g/mol [origin=calculated method=formula-sum]
Tc          1456.27;      // K   [origin=predictive method=joback]
Pc          14.240;      // bar [origin=predictive method=joback]
omega       0.5069;      // -   [origin=predictive method=lee-kesler]
Tb          1094.72;      // K   [origin=predictive method=joback]
HvapTb      136104.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (88.308 1.8448 -0.0008582 9.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2N; count 2; } { group C2H5O2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 18; } { group OH; count 4; } { group O; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[bis[2-(2-hydroxyethyloxy)ethyl]amino]ethyl-[2-(2-hydroxyethyloxy)ethyl]amino]ethoxy]ethanol" "veramin ed 40" "ethylenediamine ethoxylate" "ethylenediamine, ethoxylated" "ethylenediamine ethylene oxide adduct" "poly(oxy-1,2-ethanediyl), alpha,alpha',alpha'',alpha'''-(1,2-ethanediylbis(nitrilodi-2,1-ethanediyl))tetrakis(omega-hydroxy-" "poly(oxy-1,2-ethanediyl), alpha,alpha',alpha'',alpha'''- (1,2-ethanediylbis(nitrilodi-2,1-ethanediyl))tetrakis(omega- hydroxy-" "6,9-bis[2-(2-hydroxyethoxy)ethyl]-3,12-dioxa-6,9-diazatetradecane-1,14-diol" "2-[2-[2-[bis[2-(2-hydroxyethoxy)ethyl]amino]ethyl-[2-(2-hydroxyethoxy)ethyl]amino]ethoxy]ethanol" );
standardThermochemistry
{
    dHf_298   -1417590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1137.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-645040.0
}
