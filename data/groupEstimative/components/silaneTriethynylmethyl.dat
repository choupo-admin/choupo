/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, triethynylmethyl-  (C7H6Si, CAS 1849-39-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H6Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneTriethynylmethyl;
formula     C7H6Si;
CAS         1849-39-4;
InChIKey    QQLFJFKDDGCTQJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          118.21;      // g/mol [origin=calculated method=formula-sum]
Tc          543.10;      // K   [origin=predictive method=joback]
Pc          40.777;      // bar [origin=predictive method=joback]
omega       0.0740;      // -   [origin=predictive method=lee-kesler]
Tb          331.52;      // K   [origin=predictive method=joback]
HvapTb      31044.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (78.68 0.18092 7.001e-05 -8.993e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH_C; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 3; } { group tC; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethynyl(methyl)silane" );
gibbsFormation
{
    dHf_298   576270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=572510.0
    phase     gas;
}
