/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-ornithine  (C5H12N2O2, CAS 70-26-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lOrnithine;
formula     C5H12N2O2;
CAS         70-26-8;
InChIKey    AHLPHDHHMVZTML-BYPYZUCNSA-N;
MW          132.163;      // g/mol [origin=calculated method=formula-sum]
Tc          819.21;      // K   [origin=predictive method=joback]
Pc          45.225;      // bar [origin=predictive method=joback]
omega       1.0166;      // -   [origin=predictive method=lee-kesler]
Tb          604.13;      // K   [origin=predictive method=joback]
HvapTb      64782.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.243 0.6593 -0.0004108 9.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2NH2; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group COOH; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2,5-bis(azanyl)pentanoic acid" "ornithine" "(s)-ornithine" "(s)-2,5-diaminopentanoic acid" "(s)-alpha,delta-diaminovaleric acid" "l-norvaline, 5-amino-" "ornithine (van)" "l( )-ornithine" "ornithinum [latin]" "(s)-2,5-diaminopentanoate" "polyornithine" "ornithine, l-" );
standardThermochemistry
{
    dHf_298   -434500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-222230.0
}
