/*--------------------------------*- Choupo -*-----------------------*\
  Component: larixol acetate  (C24H38O4, CAS 1438-66-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        larixolAcetate;
formula     C24H38O4;
CAS         1438-66-0;
InChIKey    CFEOXVWJRPHLSF-UHFFFAOYSA-N;
MW          390.564;      // g/mol [origin=calculated method=formula-sum]
Tc          1091.01;      // K   [origin=predictive method=joback]
Pc          10.535;      // bar [origin=predictive method=joback]
omega       0.8145;      // -   [origin=predictive method=lee-kesler]
Tb          874.80;      // K   [origin=predictive method=joback]
HvapTb      79310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-176.418 2.93032 -0.0023487 8.108e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 3; } { group C; count 3; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(3-acetyloxy-3-methyl-pent-4-enyl)-4a,8,8-trimethyl-3-methylidene-2,4,5,6,7,8a-hexahydro-1h-naphthalen-1-yl] ethanoate" "agn-pc-00hu1g" "[(1s,4r,4ar,8as)-4-[(3s)-3-acetyloxy-3-methylpent-4-enyl]-4a,8,8-trimethyl-3-methylidene-2,4,5,6,7,8a-hexahydro-1h-naphthalen-1-yl] acetate" "[4-(3-acetyloxy-3-methylpent-4-enyl)-4a,8,8-trimethyl-3-methylidene-2,4,5,6,7,8a-hexahydro-1h-naphthalen-1-yl] acetate" );
gibbsFormation
{
    dHf_298   -881910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1034.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-286790.0
    phase     gas;
}
