/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonanamide, n,n-bis(2-hydroxyethyl)-  (C13H27NO3, CAS 3077-37-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonanamideNNBis2Hydroxyethyl;
formula     C13H27NO3;
CAS         3077-37-0;
InChIKey    WODYOUWSWYOPBP-UHFFFAOYSA-N;
MW          245.363;      // g/mol [origin=calculated method=formula-sum]
Tc          919.11;      // K   [origin=predictive method=joback]
Pc          20.272;      // bar [origin=predictive method=joback]
omega       1.5504;      // -   [origin=predictive method=lee-kesler]
Tb          747.71;      // K   [origin=predictive method=joback]
HvapTb      86679.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.679 1.40272 -0.0008381 1.9146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group OH; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group OH; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(2-hydroxyethyl)nonanamide" "pelargonic acid, diethanolamine soap" "pelargonic diethanolamide" "pelargonic acid, diethanolamine amide" "n,n-bis(2-hydroxyethyl)nonan-1-amide" );
standardThermochemistry
{
    dHf_298   -661160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     806.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-233200.0
}
