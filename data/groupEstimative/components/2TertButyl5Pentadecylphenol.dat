/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tert-butyl-5-pentadecylphenol  (C25H44O, CAS 32360-03-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TertButyl5Pentadecylphenol;
formula     C25H44O;
CAS         32360-03-5;
InChIKey    TUWLHUWKVRSCPR-UHFFFAOYSA-N;
MW          360.626;      // g/mol [origin=calculated method=formula-sum]
Tc          1083.48;      // K   [origin=predictive method=joback]
Pc          10.181;      // bar [origin=predictive method=joback]
omega       0.9285;      // -   [origin=predictive method=lee-kesler]
Tb          880.65;      // K   [origin=predictive method=joback]
HvapTb      85900.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.836 2.52088 -0.00172852 4.919e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 13; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 14; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tert-butyl-5-pentadecyl-phenol" "phenol, 2-(1,1-dimethylethyl)-5-pentadecyl-" "5-pentadecyl-2-tert-butyl-phenol" );
gibbsFormation
{
    dHf_298   -520330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1004.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110620.0
    phase     gas;
}
