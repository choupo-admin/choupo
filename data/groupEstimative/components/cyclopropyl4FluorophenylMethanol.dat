/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropyl(4-fluorophenyl)methanol  (C10H11FO, CAS 827-88-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropyl4FluorophenylMethanol;
formula     C10H11FO;
CAS         827-88-3;
InChIKey    MJODBWDKPXYVMF-UHFFFAOYSA-N;
MW          166.195;      // g/mol [origin=calculated method=formula-sum]
Tc          759.68;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.8531;      // -   [origin=predictive method=lee-kesler]
Tb          557.81;      // K   [origin=predictive method=joback]
HvapTb      56179.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.35 1.018 -0.00075456 2.226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropyl-(4-fluorophenyl)methanol" "cyclopropyl(4-fluorophenyl)methan-1-ol" "alpha-cyclopropyl-4-fluorobenzyl alcohol" "benzenemethanol, a-cyclopropyl-4-fluoro-" "a-cyclopropyl-4-fluorobenzyl alcohol" "benzylalcohol, a-cyclopropyl-p-fluoro- (7ci,8ci)" );
gibbsFormation
{
    dHf_298   -305490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-137220.0
    phase     gas;
}
