/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-((9-tetradecynyl)oxy)-tetrahydro-2h-pyran  (C19H34O2, CAS 19754-59-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        29TetradecynylOxyTetrahydro2hPyran;
formula     C19H34O2;
CAS         19754-59-7;
InChIKey    XVYMXOGWTFACKK-UHFFFAOYSA-N;
MW          294.479;      // g/mol [origin=calculated method=formula-sum]
Tc          907.05;      // K   [origin=predictive method=joback]
Pc          13.687;      // bar [origin=predictive method=joback]
omega       0.8176;      // -   [origin=predictive method=lee-kesler]
Tb          712.24;      // K   [origin=predictive method=joback]
HvapTb      67389.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.609 1.71492 -0.00087376 1.3998e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group tC; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tetradec-9-ynoxyoxane" "2h-pyran, tetrahydro-2-(9-tetradecynyloxy)-" "2h-pyran, tetrahydro-2-(9-tetradecyn-1-yloxy)-" "2-(tetradec-9-yn-1-yloxy)tetrahydro-2h-pyran" );
gibbsFormation
{
    dHf_298   -373090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     797.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=145230.0
    phase     gas;
}
