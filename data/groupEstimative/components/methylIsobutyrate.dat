/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl isobutyrate  (C5H10O2, CAS 547-63-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylIsobutyrate;
formula     C5H10O2;
CAS         547-63-7;
InChIKey    BHIWKHZACMWKOJ-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          550.25;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.3685;      // -   [origin=predictive method=lee-kesler]
Tb          371.78;      // K   [origin=predictive method=joback]
HvapTb      33743.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.07 0.42996 -0.0001568 -9.3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-methylpropanoate" "isobutyric acid, methyl ester" "propanoic acid, 2-methyl-, methyl ester" "methyl isobutanoate" "methyl 2-methylpropionate" "methyl isobutyrate (natural)" "isobutyric acid methyl ester" "methylisobutyrate" "agn-pc-0cqnx3" "methyl methacrylate polymer" "methylester kyseliny isomaselne" "2-methylpropanoic acid methyl ester" );
standardThermochemistry
{
    dHf_298   -469090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-321590.0
}
