/*--------------------------------*- Choupo -*-----------------------*\
  Component: 13-methyl-17-prop-2-enyl-2,3,6,7,8,9,10,11,12,14,15,16-dodecahydro-1h-cyclopenta[a]phenanthren-17-ol  (C21H32O, CAS 432-60-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Methyl17Prop2Enyl236789101112141516Dodecahydro1hCyclopenta;
formula     C21H32O;
CAS         432-60-0;
InChIKey    ATXHVCQZZJYMCF-UHFFFAOYSA-N;
MW          300.486;      // g/mol [origin=calculated method=formula-sum]
Tc          1036.57;      // K   [origin=predictive method=joback]
Pc          17.217;      // bar [origin=predictive method=joback]
omega       0.9682;      // -   [origin=predictive method=lee-kesler]
Tb          812.53;      // K   [origin=predictive method=joback]
HvapTb      76895.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-306.499 2.98372 -0.00269534 1.0325e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 4; } { group C; count 2; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -207060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     769.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=253390.0
    phase     gas;
}
