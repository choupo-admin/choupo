/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylenecyclopentene  (C6H8, CAS 930-26-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylenecyclopentene;
formula     C6H8;
CAS         930-26-7;
InChIKey    YWQLRBQGXHZJCF-UHFFFAOYSA-N;
MW          80.13;      // g/mol [origin=calculated method=formula-sum]
Tc          554.93;      // K   [origin=predictive method=joback]
Pc          42.943;      // bar [origin=predictive method=joback]
omega       0.2283;      // -   [origin=predictive method=lee-kesler]
Tb          355.15;      // K   [origin=predictive method=joback]
HvapTb      29967.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.92 0.5585 -0.00038028 1.03e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylidenecyclopentene" "cyclopentene,3-methylene-" );
standardThermochemistry
{
    dHf_298   55670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     318.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=126940.0
}
