/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-allylvaleric acid  (C8H14O2, CAS 1575-72-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AllylvalericAcid;
formula     C8H14O2;
CAS         1575-72-0;
InChIKey    UMYDNZXEHYSVFY-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          716.83;      // K   [origin=predictive method=joback]
Pc          29.313;      // bar [origin=predictive method=joback]
omega       0.7245;      // -   [origin=predictive method=lee-kesler]
Tb          524.39;      // K   [origin=predictive method=joback]
HvapTb      49508.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.457 0.80052 -0.0005101 1.289e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propylpent-4-enoic acid" "2-propyl-4-pentenoic acid" "2-allylpentanoic acid" "4-pentenoic acid, 2-propyl-" "4-ene-vpa" "r,s-4-en-vpa" "(+-)-4-en-valproic acid" "2-n-propyl-4-pentenoic acid" "pentanoic acid, 2-(2-propenyl)-" "(+-)-2-n-propyl-4-pentenoic acid" "4-en-valproic acid" "4-en-metabolite" );
gibbsFormation
{
    dHf_298   -438570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-242030.0
    phase     gas;
}
