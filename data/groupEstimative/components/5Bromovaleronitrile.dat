/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-bromovaleronitrile  (C5H8BrN, CAS 5414-21-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Bromovaleronitrile;
formula     C5H8BrN;
CAS         5414-21-1;
InChIKey    NWWWGAKVHCSAEU-UHFFFAOYSA-N;
MW          162.03;      // g/mol [origin=calculated method=formula-sum]
Tc          690.42;      // K   [origin=predictive method=joback]
Pc          36.553;      // bar [origin=predictive method=joback]
omega       0.5453;      // -   [origin=predictive method=lee-kesler]
Tb          482.24;      // K   [origin=predictive method=joback]
HvapTb      43637.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.534 0.4518 -0.0002886 7.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2CN; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group Br; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bromanylpentanenitrile" "5-bromopentanenitrile" "pentanenitrile, 5-bromo-" "snxhflqiuzjp@" "4-bromobutyl cyanide" );
standardThermochemistry
{
    dHf_298   44680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=138720.0
}
