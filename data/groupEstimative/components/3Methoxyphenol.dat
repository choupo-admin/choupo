/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxyphenol  (C7H8O2, CAS 150-19-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxyphenol;
formula     C7H8O2;
CAS         150-19-6;
InChIKey    ASHGTJPOSUFTGB-UHFFFAOYSA-N;
MW          124.139;      // g/mol [origin=calculated method=formula-sum]
Tc          716.97;      // K   [origin=predictive method=joback]
Pc          49.108;      // bar [origin=predictive method=joback]
omega       0.5460;      // -   [origin=predictive method=lee-kesler]
Tb          489.48;      // K   [origin=predictive method=joback]
HvapTb      48876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.8 0.68132 -0.00053356 1.759e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-hydroxyanisole" "m-methoxyphenol" "phenol, 3-methoxy-" "m-guaiacol" "m-hydroxyanisole" "resorcinol monomethyl ether" "1-hydroxy-3-methoxybenzene" "resorcinol methyl ether" "phenol, m-methoxy-" "3-hydroxyanisol" "3-methoxy phenol" "3-(methyloxy)phenol" );
standardThermochemistry
{
    dHf_298   -260810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     359.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-139150.0
}
