/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenedioic acid (2z)-, isodecyl ester  (C14H24O4, CAS 68186-70-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenedioicAcid2zIsodecylEster;
formula     C14H24O4;
CAS         68186-70-9;
InChIKey    IOERSEDKYYZDFT-UHFFFAOYSA-N;
MW          256.342;      // g/mol [origin=calculated method=formula-sum]
Tc          916.64;      // K   [origin=predictive method=joback]
Pc          17.246;      // bar [origin=predictive method=joback]
omega       1.0974;      // -   [origin=predictive method=lee-kesler]
Tb          727.37;      // K   [origin=predictive method=joback]
HvapTb      70899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.307 1.35574 -0.0008028 1.732e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group CH=CH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group dCH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(8-methylnonoxy)-4-oxidanylidene-but-2-enoic acid" );
gibbsFormation
{
    dHf_298   -887900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     789.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-509500.0
    phase     gas;
}
