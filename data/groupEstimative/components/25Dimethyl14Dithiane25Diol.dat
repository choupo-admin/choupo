/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethyl-1,4-dithiane-2,5-diol  (C6H12O2S2, CAS 55704-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethyl14Dithiane25Diol;
formula     C6H12O2S2;
CAS         55704-78-4;
InChIKey    NHKIYYMFGJBOTK-UHFFFAOYSA-N;
MW          180.28;      // g/mol [origin=calculated method=formula-sum]
Tc          852.35;      // K   [origin=predictive method=joback]
Pc          54.066;      // bar [origin=predictive method=joback]
omega       1.1660;      // -   [origin=predictive method=lee-kesler]
Tb          632.26;      // K   [origin=predictive method=joback]
HvapTb      71750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.99 1.35006 -0.0014916 6.748e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 2; } { group OH; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group OH; count 2; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dimethyl-2,5-dihydroxy-1,4-dithiane" "2-mercaptopropanone" "2,5-dimethyl-2,5-dihydroxy-p-dithiane" "1,4-dithiane-2,5-diol, 2,5-dimethyl-" "2,5-dimethyl-p-dithiane-2,5-diol" "2,5-dihydroxy-2,5-dimethyl-1,4-dithiane" "1-mercaptopropanone (dimer)" "1,5-diol, 2,5-dimethyl-" "2,5-dimethyl-[1,4]dithiane-2,5-diol" "1-mercaptopropanone (dimer); 2,5-dihydroxy-2,5-dimethyl-1,4-dithiane; 2,5-dimethyl-1,4-dithiane-2,5-diol; 2,5-dimethyl-2,5-dihydroxy-p-dithiane" );
standardThermochemistry
{
    dHf_298   -316650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     658.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-188520.0
}
