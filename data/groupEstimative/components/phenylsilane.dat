/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylsilane  (C6H5Si, CAS 694-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H5Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        phenylsilane;
formula     C6H5Si;
CAS         694-53-1;
InChIKey    XJWOWXZSFTXJEX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          105.191;      // g/mol [origin=calculated method=formula-sum]
Tc          572.06;      // K   [origin=predictive method=joback]
Pc          47.497;      // bar [origin=predictive method=joback]
omega       0.2293;      // -   [origin=predictive method=lee-kesler]
Tb          362.86;      // K   [origin=predictive method=joback]
HvapTb      31079.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.88 0.598 -0.0005412 1.943e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenylsilicon" "silane, phenyl-" "benzene, silyl-" "silylbenzene" "fenylsilan" "phenylsilane, silyl-" );
gibbsFormation
{
    dHf_298   125170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     248.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164430.0
    phase     gas;
}
