/*--------------------------------*- Choupo -*-----------------------*\
  Component: perfluorohxamethyl benzvalene  (C12F18, CAS 22186-64-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        perfluorohxamethylBenzvalene;
formula     C12F18;
CAS         22186-64-7;
InChIKey    FICGHCVUNRMIDX-UHFFFAOYSA-N;
MW          486.096;      // g/mol [origin=calculated method=formula-sum]
Tc          584.17;      // K   [origin=predictive method=joback]
Pc          14.816;      // bar [origin=predictive method=joback]
omega       0.7910;      // -   [origin=predictive method=lee-kesler]
Tb          454.46;      // K   [origin=predictive method=joback]
HvapTb      15750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-338.23 3.5586 -0.004683 2.1696e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 4; } { group C=C; count 1; } { group CF3; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 6; } { group C_ring; count 4; } { group dC_ring; count 2; } { group F; count 18; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo(3.1.0.02,6)hex-3-ene, 1,2,3,4,5,6-hexakis(trifluoromethyl)-" );
gibbsFormation
{
    dHf_298   -3561150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     816.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3239800.0
    phase     gas;
}
