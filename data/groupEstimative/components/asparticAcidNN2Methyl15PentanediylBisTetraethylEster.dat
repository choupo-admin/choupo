/*--------------------------------*- Choupo -*-----------------------*\
  Component: aspartic acid, n,n'-(2-methyl-1,5-pentanediyl)bis-, tetraethyl ester  (C22H40N2O8, CAS 168253-59-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        asparticAcidNN2Methyl15PentanediylBisTetraethylEster;
formula     C22H40N2O8;
CAS         168253-59-6;
InChIKey    IIXYXWPAODWTJR-FQECFTEESA-N;
MW          460.568;      // g/mol [origin=calculated method=formula-sum]
Tc          1276.37;      // K   [origin=predictive method=joback]
Pc          9.409;      // bar [origin=predictive method=joback]
omega       0.8324;      // -   [origin=predictive method=lee-kesler]
Tb          1034.86;      // K   [origin=predictive method=joback]
HvapTb      105902.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (77.06 2.0448 -0.0009014 4.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 6; } { group CH; count 3; } { group CH2COO; count 2; } { group CH2NH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 10; } { group CH; count 3; } { group COO; count 4; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl (2s)-2-[[5-[[(2s)-1,4-diethoxy-1,4-bis(oxidanylidene)butan-2-yl]amino]-4-methyl-pentyl]amino]butanedioate" "aspartic acid, n,n'-(2-methyl-1,5-pentanediyl)bis-, 1,1',4,4'-tetraethyl ester" );
standardThermochemistry
{
    dHf_298   -1675430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1270.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-935660.0
}
