/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butyn-1-ol  (C4H6O, CAS 764-01-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butyn1Ol;
formula     C4H6O;
CAS         764-01-2;
InChIKey    NEEDEQSZOUAJMU-UHFFFAOYSA-N;
MW          70.091;      // g/mol [origin=calculated method=formula-sum]
Tc          577.87;      // K   [origin=predictive method=joback]
Pc          54.870;      // bar [origin=predictive method=joback]
omega       0.5603;      // -   [origin=predictive method=lee-kesler]
Tb          392.30;      // K   [origin=predictive method=joback]
HvapTb      43329.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.101 0.26802 -0.00013206 2.518e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-2-yn-1-ol" "hydroxymethylmethylacetylene" "2-butynol" "2-butynyl alcohol" "2-butyne-1-ol" "1-hydroxybut-2-yne" "but-2-in-1-ol" "b129" );
gibbsFormation
{
    dHf_298   -5820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48780.0
    phase     gas;
}
