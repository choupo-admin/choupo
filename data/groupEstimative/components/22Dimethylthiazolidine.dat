/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethylthiazolidine  (C5H11NS, CAS 19351-18-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethylthiazolidine;
formula     C5H11NS;
CAS         19351-18-9;
InChIKey    SNPQRYOQWLOTFA-UHFFFAOYSA-N;
MW          117.21;      // g/mol [origin=calculated method=formula-sum]
Tc          660.91;      // K   [origin=predictive method=joback]
Pc          47.301;      // bar [origin=predictive method=joback]
omega       0.2828;      // -   [origin=predictive method=lee-kesler]
Tb          425.90;      // K   [origin=predictive method=joback]
HvapTb      38400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.39 0.90345 -0.0008663 3.617e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2NH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group NH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyl-1,3-thiazolidine" "thiazolidine, 2,2-dimethyl-" "2,2-dimethyltetrahydrothiazole" "822-44-6 (hydrochloride)" "2,2-dimethyl-1,3-thiazolidine;" "u726" );
gibbsFormation
{
    dHf_298   12260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=149850.0
    phase     gas;
}
