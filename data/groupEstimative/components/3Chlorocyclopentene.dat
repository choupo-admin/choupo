/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chlorocyclopentene  (C5H7Cl, CAS 96-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chlorocyclopentene;
formula     C5H7Cl;
CAS         96-40-2;
InChIKey    LPSWJRSLXCPGBK-UHFFFAOYSA-N;
MW          102.561;      // g/mol [origin=calculated method=formula-sum]
Tc          573.88;      // K   [origin=predictive method=joback]
Pc          43.340;      // bar [origin=predictive method=joback]
omega       0.2183;      // -   [origin=predictive method=lee-kesler]
Tb          365.87;      // K   [origin=predictive method=joback]
HvapTb      31658.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.47 0.5613 -0.00038328 1.01e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylcyclopentene" "cyclopentene, 3-chloro-" "3-chloro-cyclopentene" );
standardThermochemistry
{
    dHf_298   -44010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     296.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45800.0
}
