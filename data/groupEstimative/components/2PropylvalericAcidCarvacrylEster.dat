/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propylvaleric acid carvacryl ester  (C18H28O2, CAS 30129-30-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropylvalericAcidCarvacrylEster;
formula     C18H28O2;
CAS         30129-30-7;
InChIKey    IUDMBDWVRIJRDE-UHFFFAOYSA-N;
MW          276.42;      // g/mol [origin=calculated method=formula-sum]
Tc          902.69;      // K   [origin=predictive method=joback]
Pc          14.524;      // bar [origin=predictive method=joback]
omega       0.8168;      // -   [origin=predictive method=lee-kesler]
Tb          705.42;      // K   [origin=predictive method=joback]
HvapTb      65893.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.264 1.473 -0.00076432 1.206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-5-propan-2-yl-phenyl) 2-propylpentanoate" "carvacryl 2-propylvalerate" "valeric acid, 2-propyl-, carvacryl ester" "pentanoic acid, 2-propyl-, carvaryl ester" "valericacid, 2-propyl-, carvacryl ester (8ci)" "(2-methyl-5-propan-2-ylphenyl) 2-propylpentanoate" "2-methyl-5-(propan-2-yl)phenyl 2-propylpentanoate" "pentanoic acid,2-propyl-, 2-methyl-5-(1-methylethyl)phenyl ester" );
gibbsFormation
{
    dHf_298   -529100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     770.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-121420.0
    phase     gas;
}
