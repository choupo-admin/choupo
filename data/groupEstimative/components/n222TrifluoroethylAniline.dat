/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2,2,2-trifluoroethyl)aniline  (C8H8F3N, CAS 351-61-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n222TrifluoroethylAniline;
formula     C8H8F3N;
CAS         351-61-1;
InChIKey    IHCPNFMGAKAAKN-UHFFFAOYSA-N;
MW          175.153;      // g/mol [origin=calculated method=formula-sum]
Tc          646.80;      // K   [origin=predictive method=joback]
Pc          32.357;      // bar [origin=predictive method=joback]
omega       0.5197;      // -   [origin=predictive method=lee-kesler]
Tb          454.07;      // K   [origin=predictive method=joback]
HvapTb      38367.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.699 0.9223 -0.0007122 2.087e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group F; count 3; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[2,2,2-tris(fluoranyl)ethyl]aniline" "aniline, n-(2,2,2-trifluoroethyl)-" "phenyl(2,2,2-trifluoroethyl)amine" "phenyl-(2,2,2-trifluoro-ethyl)-amine" );
standardThermochemistry
{
    dHf_298   -515530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-363310.0
}
