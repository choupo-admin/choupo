/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butene, 2-iodo-3-methyl-  (C5H9I, CAS 66702-99-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butene2Iodo3Methyl;
formula     C5H9I;
CAS         66702-99-6;
InChIKey    LZJDPXGFTKZILT-UHFFFAOYSA-N;
MW          196.027;      // g/mol [origin=calculated method=formula-sum]
Tc          633.66;      // K   [origin=predictive method=joback]
Pc          36.377;      // bar [origin=predictive method=joback]
omega       0.2217;      // -   [origin=predictive method=lee-kesler]
Tb          411.06;      // K   [origin=predictive method=joback]
HvapTb      36215.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.53 0.53766 -0.000418 1.392e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group I; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dC; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-iodanyl-3-methyl-but-2-ene" );
standardThermochemistry
{
    dHf_298   27980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112460.0
}
