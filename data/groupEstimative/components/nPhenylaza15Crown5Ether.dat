/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-phenylaza-15-crown 5-ether  (C16H25NO4, CAS 66750-10-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nPhenylaza15Crown5Ether;
formula     C16H25NO4;
CAS         66750-10-5;
InChIKey    SGDQOAKAHLFKBV-UHFFFAOYSA-N;
MW          295.379;      // g/mol [origin=calculated method=formula-sum]
Tc          1037.22;      // K   [origin=predictive method=joback]
Pc          24.435;      // bar [origin=predictive method=joback]
omega       0.7397;      // -   [origin=predictive method=lee-kesler]
Tb          770.98;      // K   [origin=predictive method=joback]
HvapTb      75683.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.48 1.6286 -0.0007 5.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 5; } { group AC; count 1; } { group FCH2O; count 4; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "13-phenyl-1,4,7,10-tetraoxa-13-azacyclopentadecane" "n-phenylaza-15-crown-5" "sgdqoakahlfkbv-uhfffaoysa-" "n-phenyl-13-aza-1,4,7,10-tetraoxacyclopentadecane" "1,4,7,10-tetraoxa-13-azacyclopentadecane, 13-phenyl-" "13-phenyl-1,4,7,10-tetraoxa-13-aza-cyclopentadecane" "1-n-phenylaza-15-crown-5;1-phenyl-4,7,10,13-tetraoxa-1-azacyclopentadecane; n-phenylaza-15-crown-5;n-phenylaza-15-crown-5" );
standardThermochemistry
{
    dHf_298   -572130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     654.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-102090.0
}
