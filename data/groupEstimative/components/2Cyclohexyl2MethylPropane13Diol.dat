/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexyl-2-methyl-propane-1,3-diol  (C10H20O2, CAS 2037-62-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexyl2MethylPropane13Diol;
formula     C10H20O2;
CAS         2037-62-9;
InChIKey    XZUSMSQZIRXYGI-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          815.69;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       1.2302;      // -   [origin=predictive method=lee-kesler]
Tb          629.08;      // K   [origin=predictive method=joback]
HvapTb      70345.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.698 1.26972 -0.0008338 2.089e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -508620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-213030.0
    phase     gas;
}
