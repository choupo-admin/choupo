/*--------------------------------*- Choupo -*-----------------------*\
  Component: crotonic acid isobutyl ester  (C8H14O2, CAS 589-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        crotonicAcidIsobutylEster;
formula     C8H14O2;
CAS         589-66-2;
InChIKey    XDOWKOALJBOBBL-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          628.61;      // K   [origin=predictive method=joback]
Pc          27.099;      // bar [origin=predictive method=joback]
omega       0.4804;      // -   [origin=predictive method=lee-kesler]
Tb          444.58;      // K   [origin=predictive method=joback]
HvapTb      40379.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.161 0.73496 -0.0004038 7.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropyl but-2-enoate" "isobutyl crotonate" "isobutyl 2-butenoate" "2-butenoic acid, 2-methylpropyl ester" "2-butenoic acid, 2-methylpropyl ester, (2e)-" "crotonicacid, isobutyl ester (6ci,8ci);2-methylpropyl crotonate;isobutyl 2-butenoate;isobutyl crotonate;" );
gibbsFormation
{
    dHf_298   -413790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-216110.0
    phase     gas;
}
