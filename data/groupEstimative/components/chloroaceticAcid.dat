/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloroacetic acid  (C2H3ClO2, CAS 79-11-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloroaceticAcid;
formula     C2H3ClO2;
CAS         79-11-8;
InChIKey    FOCAUTSVDIKZOP-UHFFFAOYSA-N;
MW          94.494;      // g/mol [origin=calculated method=formula-sum]
Tc          632.71;      // K   [origin=predictive method=joback]
Pc          54.225;      // bar [origin=predictive method=joback]
omega       0.5412;      // -   [origin=predictive method=lee-kesler]
Tb          428.30;      // K   [origin=predictive method=joback]
HvapTb      41595.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.561 0.2514 -0.000178 4.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylethanoic acid" "monochloroacetic acid" "acetic acid, chloro-" "acide chloracetique" "chloroethanoic acid" "chloracetic acid" "monochloroethanoic acid" "monochloressigsaeure" "chloroacetic acid, solid" "monochloorazijnzuur" ".alpha.-chloroacetic acid" "monochloracetic acid" );
gibbsFormation
{
    dHf_298   -450620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     320.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-389880.0
    phase     gas;
}
