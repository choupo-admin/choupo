/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzeneoctadecanol  (C24H42O, CAS 68141-06-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneoctadecanol;
formula     C24H42O;
CAS         68141-06-0;
InChIKey    LBVYOCXVSZXQQN-UHFFFAOYSA-N;
MW          346.599;      // g/mol [origin=calculated method=formula-sum]
Tc          1062.38;      // K   [origin=predictive method=joback]
Pc          10.413;      // bar [origin=predictive method=joback]
omega       1.0027;      // -   [origin=predictive method=lee-kesler]
Tb          867.58;      // K   [origin=predictive method=joback]
HvapTb      87973.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.542 2.2389 -0.0013434 3.097e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 17; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 18; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "18-phenyloctadecan-1-ol" "18-phenyloctadecanol" "phenyloctadecyl alcohol" );
gibbsFormation
{
    dHf_298   -454390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1035.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=126790.0
    phase     gas;
}
