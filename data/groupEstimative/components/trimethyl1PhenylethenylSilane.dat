/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethyl(1-phenylethenyl)silane  (C11H16Si, CAS 1923-01-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethyl1PhenylethenylSilane;
formula     C11H16Si;
CAS         1923-01-9;
InChIKey    WNAGIMQWCVOKKX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          176.334;      // g/mol [origin=calculated method=formula-sum]
Tc          693.93;      // K   [origin=predictive method=joback]
Pc          24.605;      // bar [origin=predictive method=joback]
omega       0.2930;      // -   [origin=predictive method=lee-kesler]
Tb          475.92;      // K   [origin=predictive method=joback]
HvapTb      42060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.88 0.74366 -0.0002162 -5.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "silane,trimethyl(1-phenylethenyl)-" "silane, trimethyl(1-phenylethenyl)-" "benzene,[1-(trimethylsilyl)ethenyl]-" "silane,trimethyl(1-phenylethenyl)- (9ci); silane, trimethyl(1-phenylvinyl)-(6ci,7ci,8ci); 1-phenyl-1-(trimethylsilyl)ethene; 1-phenyl-1-(trimethylsilyl)ethylene;trimethyl(1-phenylethenyl)silane; trimethyl(1-phenylvinyl)silane; a-(trimethylsilyl)styrene" );
standardThermochemistry
{
    dHf_298   -29820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128680.0
}
