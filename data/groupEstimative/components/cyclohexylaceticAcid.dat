/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexylacetic acid  (C8H14O2, CAS 5292-21-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylaceticAcid;
formula     C8H14O2;
CAS         5292-21-7;
InChIKey    LJOODBDWMQKMFB-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          768.24;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.6432;      // -   [origin=predictive method=lee-kesler]
Tb          547.70;      // K   [origin=predictive method=joback]
HvapTb      50995.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.389 0.9367 -0.000565 1.216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyclohexylethanoic acid" "cyclohexaneacetic acid" "cyclohexylethanoic acid" "2-cyclohexylacetic acid" "hexahydrophenylacetic acid" "cyclohexane-acetic acid" "2-cyclohexyl-acetic acid" "agn-pc-04y270" "ljoodbdwmqkmfb-uhfffaoysa-" "m220" );
gibbsFormation
{
    dHf_298   -504400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-302980.0
    phase     gas;
}
