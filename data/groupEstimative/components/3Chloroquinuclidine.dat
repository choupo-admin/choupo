/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloroquinuclidine  (C7H12ClN, CAS 42332-45-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloroquinuclidine;
formula     C7H12ClN;
CAS         42332-45-6;
InChIKey    NOLVABYTFMDREN-UHFFFAOYSA-N;
MW          145.63;      // g/mol [origin=calculated method=formula-sum]
Tc          636.10;      // K   [origin=predictive method=joback]
Pc          37.000;      // bar [origin=predictive method=joback]
omega       0.3627;      // -   [origin=predictive method=lee-kesler]
Tb          427.38;      // K   [origin=predictive method=joback]
HvapTb      37602.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.88 1.0917 -0.000884 2.872e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH2N; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 2; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-1-azabicyclo[2.2.2]octane" "3-chloro-1-azabicyclo[2.2.2]octane" "3-chloro-1-azabicyclo(2.2.2)octane" );
standardThermochemistry
{
    dHf_298   3420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     317.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=216310.0
}
