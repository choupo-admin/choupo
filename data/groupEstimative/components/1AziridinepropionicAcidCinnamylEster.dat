/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-aziridinepropionic acid, cinnamyl ester  (C14H17NO2, CAS 99900-94-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1AziridinepropionicAcidCinnamylEster;
formula     C14H17NO2;
CAS         99900-94-4;
InChIKey    RSXZHIIMNHPJJM-QPJJXVBHSA-N;
MW          231.295;      // g/mol [origin=calculated method=formula-sum]
Tc          838.79;      // K   [origin=predictive method=joback]
Pc          24.076;      // bar [origin=predictive method=joback]
omega       0.7923;      // -   [origin=predictive method=lee-kesler]
Tb          628.56;      // K   [origin=predictive method=joback]
HvapTb      58492.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.267 1.531 -0.0011928 3.66e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-3-phenylprop-2-enyl] 3-(aziridin-1-yl)propanoate" "3-phenylprop-2-en-1-yl 3-(aziridin-1-yl)propanoate" );
gibbsFormation
{
    dHf_298   -128990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140600.0
    phase     gas;
}
