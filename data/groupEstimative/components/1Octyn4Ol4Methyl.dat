/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octyn-4-ol, 4-methyl-  (C9H16O, CAS 22128-43-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octyn4Ol4Methyl;
formula     C9H16O;
CAS         22128-43-4;
InChIKey    VWNNGOBVFMFPNE-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          663.06;      // K   [origin=predictive method=joback]
Pc          30.090;      // bar [origin=predictive method=joback]
omega       0.7315;      // -   [origin=predictive method=lee-kesler]
Tb          484.59;      // K   [origin=predictive method=joback]
HvapTb      50869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.696 0.92474 -0.00066393 1.9599e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyloct-1-yn-4-ol" "agn-pc-00jxil" "(?a'a a'a currency)-4-methyl-1-octyn-4-ol;4-methyl-1-octyn-4-ol; 4-methyl-4-hydroxy-1-octyne" );
standardThermochemistry
{
    dHf_298   -98170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113990.0
}
