/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene-1,3-dicarboxylic acid;hexane-1,6-diamine;hexanedioic acid;nonanedioic acid  (C29H48N2O12, CAS 63410-51-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene13DicarboxylicAcidHexane16DiamineHexanedioicAcidNonan;
formula     C29H48N2O12;
CAS         63410-51-5;
InChIKey    WFEBLEQFCBRTFA-UHFFFAOYSA-N;
MW          616.705;      // g/mol [origin=calculated method=formula-sum]
Tc          3007.03;      // K   [origin=predictive method=joback]
Pc          9.172;      // bar [origin=predictive method=joback]
omega       -0.2579;      // -   [origin=predictive method=lee-kesler]
Tb          1917.10;      // K   [origin=predictive method=joback]
HvapTb      208234.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (119.957 2.4304 -0.00079596 -1.271e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 15; } { group ACH; count 4; } { group AC; count 2; } { group CH2NH2; count 2; } { group COOH; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 17; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 6; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid; hexane-1,6-diamine; hexanedioic acid; nonanedioic acid" );
gibbsFormation
{
    dHf_298   -2785730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1918.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1948760.0
    phase     gas;
}
