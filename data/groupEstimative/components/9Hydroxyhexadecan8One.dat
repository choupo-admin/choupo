/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-hydroxyhexadecan-8-one  (C16H32O2, CAS 4444-11-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Hydroxyhexadecan8One;
formula     C16H32O2;
CAS         4444-11-5;
InChIKey    GEOUKYZTVQMHGL-UHFFFAOYSA-N;
MW          256.43;      // g/mol [origin=calculated method=formula-sum]
Tc          881.39;      // K   [origin=predictive method=joback]
Pc          14.896;      // bar [origin=predictive method=joback]
omega       1.1744;      // -   [origin=predictive method=lee-kesler]
Tb          711.29;      // K   [origin=predictive method=joback]
HvapTb      74247.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.688 1.53574 -0.0008615 1.7946e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 1; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-oxidanylhexadecan-8-one" "8-hexadecanone,9-hydroxy-" "8-hexadecanone, 9-hydroxy-" "9-hydroxy-8-hexadecanone;capryloin;octanoin;octyloin;" );
standardThermochemistry
{
    dHf_298   -643660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     847.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-184340.0
}
