/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 4733109  (C5H8F3NO, CAS 31185-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn4733109;
formula     C5H8F3NO;
CAS         31185-56-5;
InChIKey    PLIMSFKVMRGKNH-UHFFFAOYSA-N;
MW          155.119;      // g/mol [origin=calculated method=formula-sum]
Tc          581.27;      // K   [origin=predictive method=joback]
Pc          36.686;      // bar [origin=predictive method=joback]
omega       0.4062;      // -   [origin=predictive method=lee-kesler]
Tb          394.69;      // K   [origin=predictive method=joback]
HvapTb      34193.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.16 0.72882 -0.0004667 1.067e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH-O; count 1; } { group CH2NH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group F; count 3; } { group O_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-2-(trifluoromethyl)-1,3-oxazolidine" "oxazolidine, 5-methyl-2-trifluoromethyl-" "oxazolidine,5-methyl-2-(trifluoromethyl)-" );
standardThermochemistry
{
    dHf_298   -797660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     256.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-559940.0
}
