/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl pyridine-3,4-dicarboxylate  (C11H13NO4, CAS 1678-52-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylPyridine34Dicarboxylate;
formula     C11H13NO4;
CAS         1678-52-0;
InChIKey    SIOSRDUNOOIMCE-UHFFFAOYSA-N;
MW          223.228;      // g/mol [origin=calculated method=formula-sum]
Tc          870.85;      // K   [origin=predictive method=joback]
Pc          26.380;      // bar [origin=predictive method=joback]
omega       0.8516;      // -   [origin=predictive method=lee-kesler]
Tb          653.08;      // K   [origin=predictive method=joback]
HvapTb      64042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.162 0.8346 -0.00035882 7.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C5H3N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group COO; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cinchomeronic ester" "diethyl 3,4-pyridinedicarboxylate" "ethyl 4-(ethoxycarbonyl)pyridine-3-carboxylate" "diethyl 3 4-pyridinedicarboxylate" "3,4-pyridinedicarboxylicacid, 3,4-diethyl ester" "3,4-pyridinedicarboxylicacid, diethyl ester (7ci,8ci,9ci);diethyl 3,4-pyridinedicarboxylate;" );
gibbsFormation
{
    dHf_298   -647080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-399170.0
    phase     gas;
}
