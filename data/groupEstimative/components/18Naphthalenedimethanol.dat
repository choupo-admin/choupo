/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-naphthalenedimethanol  (C12H12O2, CAS 2026-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Naphthalenedimethanol;
formula     C12H12O2;
CAS         2026-08-6;
InChIKey    DINZUYYYXDLSJE-UHFFFAOYSA-N;
MW          188.226;      // g/mol [origin=calculated method=formula-sum]
Tc          914.78;      // K   [origin=predictive method=joback]
Pc          37.180;      // bar [origin=predictive method=joback]
omega       1.4749;      // -   [origin=predictive method=lee-kesler]
Tb          714.14;      // K   [origin=predictive method=joback]
HvapTb      80904.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.188 1.0102 -0.00072364 2.08e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACCH2; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[8-(hydroxymethyl)naphthalen-1-yl]methanol" "1,8-bis(hydroxymethyl)naphthalene" "naphthalene-1,8-diyldimethanol" "[8-(hydroxymethyl)naphthyl]methan-1-ol" );
gibbsFormation
{
    dHf_298   -190810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23680.0
    phase     gas;
}
