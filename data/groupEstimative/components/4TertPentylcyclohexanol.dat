/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-pentylcyclohexanol  (C11H22O, CAS 5349-51-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertPentylcyclohexanol;
formula     C11H22O;
CAS         5349-51-9;
InChIKey    VDQZABQVXYELSI-UHFFFAOYSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          749.57;      // K   [origin=predictive method=joback]
Pc          25.227;      // bar [origin=predictive method=joback]
omega       0.7306;      // -   [origin=predictive method=lee-kesler]
Tb          555.11;      // K   [origin=predictive method=joback]
HvapTb      55583.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.959 1.30426 -0.0008024 1.828e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-methylbutan-2-yl)cyclohexan-1-ol" "4-tert-amylcyclohexanol" "cyclohexanol, 4-tert-pentyl-" "p-tert-amylcyclohexanol" "4-(2-methylbutan-2-yl)cyclohexanol" "trans-4-tert-pentylcyclohexanol" "cyclohexanol, 4-(1,1-dimethylpropyl)-" "cis-4-tert-pentylcyclohexanol" "4-(tert-pentyl)cyclohexanol" "trans-4-t-pentylcyclohexanol" "trans-4-tert-amylcyclohexanol" "4-tert-amylcyclohexanol, 99%" );
standardThermochemistry
{
    dHf_298   -397370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75500.0
}
