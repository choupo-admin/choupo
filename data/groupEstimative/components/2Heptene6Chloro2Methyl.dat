/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-heptene, 6-chloro-2-methyl-  (C8H15Cl, CAS 80325-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Heptene6Chloro2Methyl;
formula     C8H15Cl;
CAS         80325-37-7;
InChIKey    MPUQSYDHMKFTGX-UHFFFAOYSA-N;
MW          146.658;      // g/mol [origin=calculated method=formula-sum]
Tc          610.76;      // K   [origin=predictive method=joback]
Pc          26.084;      // bar [origin=predictive method=joback]
omega       0.3673;      // -   [origin=predictive method=lee-kesler]
Tb          423.67;      // K   [origin=predictive method=joback]
HvapTb      37437.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.048 0.79646 -0.0005211 1.417e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH=C; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-chloranyl-2-methyl-hept-2-ene" "agn-pc-00k3c8" );
gibbsFormation
{
    dHf_298   -122040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=73780.0
    phase     gas;
}
