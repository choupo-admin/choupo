/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-bromoacenaphthene  (C12H9Br, CAS 2051-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Bromoacenaphthene;
formula     C12H9Br;
CAS         2051-98-1;
InChIKey    QALKJGMGKYKMKE-UHFFFAOYSA-N;
MW          233.108;      // g/mol [origin=calculated method=formula-sum]
Tc          864.41;      // K   [origin=predictive method=joback]
Pc          37.546;      // bar [origin=predictive method=joback]
omega       0.5966;      // -   [origin=predictive method=lee-kesler]
Tb          608.06;      // K   [origin=predictive method=joback]
HvapTb      54693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.34 1.1079 -0.0009892 3.55e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 3; } { group ACCH2; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bromanyl-1,2-dihydroacenaphthylene" "5-bromo-1,2-dihydroacenaphthylene" "acenaphthene, 5-bromo-" "acenaphthene, 5-bromo- (8ci)" "qalkjgmgkykmke-uhfffaoysa-" "acenaphthylene,5-bromo-1,2-dihydro-" "acenaphthylene, 5-bromo-1,2-dihydro- (9ci)" );
gibbsFormation
{
    dHf_298   227810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=335210.0
    phase     gas;
}
