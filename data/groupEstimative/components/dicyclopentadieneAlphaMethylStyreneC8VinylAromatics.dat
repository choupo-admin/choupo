/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicyclopentadiene, alpha-methyl styrene, c8 vinyl aromatics  (C27H30, CAS 56236-54-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicyclopentadieneAlphaMethylStyreneC8VinylAromatics;
formula     C27H30;
CAS         56236-54-5;
InChIKey    FOSUQUPFLHTPQG-UHFFFAOYSA-N;
MW          354.537;      // g/mol [origin=calculated method=formula-sum]
Tc          1144.58;      // K   [origin=predictive method=joback]
Pc          12.930;      // bar [origin=predictive method=joback]
omega       0.6460;      // -   [origin=predictive method=lee-kesler]
Tb          884.90;      // K   [origin=predictive method=joback]
HvapTb      79762.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-147.85 2.26312 -0.00125926 2.115e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 4; } { group CH2=CH; count 1; } { group CH=CH; count 2; } { group CH2=C; count 1; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group dCH_ring; count 14; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7-methano-1h-indene, 3a,4,7,7a-tetrahydro-, polymer with ethenylbenzene and (1-methylethenyl)benzene" );
gibbsFormation
{
    dHf_298   197740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     828.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=581250.0
    phase     gas;
}
