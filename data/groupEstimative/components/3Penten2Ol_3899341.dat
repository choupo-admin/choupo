/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-penten-2-ol  (C5H10O, CAS 3899-34-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Penten2Ol;
formula     C5H10O;
CAS         3899-34-1;
InChIKey    GJYMQFMQRRNLCY-ONEGZZNKSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          583.44;      // K   [origin=predictive method=joback]
Pc          41.839;      // bar [origin=predictive method=joback]
omega       0.6371;      // -   [origin=predictive method=lee-kesler]
Tb          409.90;      // K   [origin=predictive method=joback]
HvapTb      42973.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.23 0.53874 -0.0003656 1.05e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-pent-3-en-2-ol" "trans-3-penten-2-ol" "methyl propenyl carbinol" "3-penten-2-ol, predominantly trans" ".alpha.,.gamma.-dimethylallyl alcohol" "(3e)-3-penten-2-ol" "3-penten-2-ol (trans)" "(3e)pent-3-en-2-ol" );
standardThermochemistry
{
    dHf_298   -186820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-67820.0
}
