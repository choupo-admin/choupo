/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl cyclopent-2-en-1-ylmalonate  (C12H18O4, CAS 53608-93-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylCyclopent2En1Ylmalonate;
formula     C12H18O4;
CAS         53608-93-8;
InChIKey    UAZCLBJEBNSEDV-UHFFFAOYSA-N;
MW          226.272;      // g/mol [origin=calculated method=formula-sum]
Tc          804.39;      // K   [origin=predictive method=joback]
Pc          21.918;      // bar [origin=predictive method=joback]
omega       0.7605;      // -   [origin=predictive method=lee-kesler]
Tb          604.60;      // K   [origin=predictive method=joback]
HvapTb      57281.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.588 1.11584 -0.00055768 6.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-cyclopent-2-en-1-ylpropanedioate" "agn-pc-00dkr4" "diethyl 2-(2-cyclopenten-1-yl)malonate" "2-cyclopent-2-enyl-malonic acid diethyl ester" "diethyl 2-[(1s)-cyclopent-2-en-1-yl]propanedioate" "2-(1-cyclopent-2-enyl)-propanedioic acid diethyl ester" );
standardThermochemistry
{
    dHf_298   -812590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     628.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-506510.0
}
