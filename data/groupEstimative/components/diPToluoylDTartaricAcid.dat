/*--------------------------------*- Choupo -*-----------------------*\
  Component: di-p-toluoyl-d-tartaric acid  (C20H18O8, CAS 32634-68-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diPToluoylDTartaricAcid;
formula     C20H18O8;
CAS         32634-68-7;
InChIKey    CMIBUZBMZCBCAT-HOTGVXAUSA-N;
MW          386.356;      // g/mol [origin=calculated method=formula-sum]
Tc          1383.21;      // K   [origin=predictive method=joback]
Pc          18.871;      // bar [origin=predictive method=joback]
omega       1.5106;      // -   [origin=predictive method=lee-kesler]
Tb          1127.10;      // K   [origin=predictive method=joback]
HvapTb      114356.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.15 1.63084 -0.00095492 1.688e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 2; } { group COOH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,3s)-2,3-bis[(4-methylphenyl)carbonyloxy]butanedioic acid" "(+)-di-1,4-toluoyl-d-tartaric acid" "(2s,3s)-2,3-bis[(4-methylbenzoyl)oxy]succinic acid" "(-)-di-p-toluoyl-l-trataric acid" "(2s,3s)-2,3-bis((4-methylbenzoyl)oxy)succinic acid" "(2s,3s)-2,3-bis[(4-methylbenzoyl)oxy]butanedioic acid" "o,o'-di-p-toluoyl-d-tartaric acid" "di-p-toluoyl-l-tartaric acid monohydrate" "d-(+)-di-p-toluoyl-tartaric acid" "(+)-di-(p-toluoyl)-d-tartaric acid" "(2s,3s)-2,3-bis(4-methylbenzoyloxy)butanedioic acid" "(2s,3s)-(+)-2,3-bis[(4-methylbenzoyl)oxy]succinic acid" );
gibbsFormation
{
    dHf_298   -1351670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     899.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-990360.0
    phase     gas;
}
