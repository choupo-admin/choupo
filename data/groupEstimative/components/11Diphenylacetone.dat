/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diphenylacetone  (C15H14O, CAS 781-35-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diphenylacetone;
formula     C15H14O;
CAS         781-35-1;
InChIKey    DBNWBEGCONIRGQ-UHFFFAOYSA-N;
MW          210.276;      // g/mol [origin=calculated method=formula-sum]
Tc          896.29;      // K   [origin=predictive method=joback]
Pc          26.986;      // bar [origin=predictive method=joback]
omega       0.6205;      // -   [origin=predictive method=lee-kesler]
Tb          649.59;      // K   [origin=predictive method=joback]
HvapTb      59894.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.88 1.24892 -0.0008391 2.0876e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diphenylpropan-2-one" "1,1-diphenyl-2-propanone" "2-propanone, 1,1-diphenyl-" "methyl diphenylmethyl ketone" "ketone, diphenylmethyl methyl" "1,1-diphenyl acetone" "benzhydryl methyl ketone" "2-propanone, diphenyl-" "unsym-diphenylacetone" "2-propanone,1-diphenyl-" "1,1-diphenyl-propan-2-one" "1,1-di(phenyl)propan-2-one" );
standardThermochemistry
{
    dHf_298   2270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=168880.0
}
