/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dichlorobut-1-ene  (C4H6Cl2, CAS 7013-11-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dichlorobut1Ene;
formula     C4H6Cl2;
CAS         7013-11-8;
InChIKey    LKINOBKAEGPXMI-UHFFFAOYSA-N;
MW          124.992;      // g/mol [origin=calculated method=formula-sum]
Tc          556.78;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.2454;      // -   [origin=predictive method=lee-kesler]
Tb          362.10;      // K   [origin=predictive method=joback]
HvapTb      32290.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.67 0.38322 -0.000263 7.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group CHCl; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(chloranyl)but-1-ene" "1-butene, 2,3-dichloro-" );
standardThermochemistry
{
    dHf_298   -47010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35790.0
}
