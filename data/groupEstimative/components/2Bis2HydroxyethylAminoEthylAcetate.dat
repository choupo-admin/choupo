/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[bis(2-hydroxyethyl)amino]ethyl acetate  (C8H17NO4, CAS 14806-73-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bis2HydroxyethylAminoEthylAcetate;
formula     C8H17NO4;
CAS         14806-73-6;
InChIKey    COYBSBIBDYUILE-UHFFFAOYSA-N;
MW          191.227;      // g/mol [origin=calculated method=formula-sum]
Tc          800.38;      // K   [origin=predictive method=joback]
Pc          30.899;      // bar [origin=predictive method=joback]
omega       1.6031;      // -   [origin=predictive method=lee-kesler]
Tb          637.66;      // K   [origin=predictive method=joback]
HvapTb      76210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.916 0.90092 -0.0004902 8.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group OH; count 2; } { group CH3COO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group OH; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2-hydroxyethyl)amino]ethyl ethanoate" "2-(bis(2-hydroxyethyl)amino)ethyl acetate" "ethanol, 2,2'-((2-(acetyloxy)ethyl)imino)bis-" "ethanol, 2,2'-[[2-(acetyloxy)ethyl]imino]bis-" );
standardThermochemistry
{
    dHf_298   -762660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     636.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-456750.0
}
