/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2s,3s)-2-amino-3-methoxybutanoic acid  (C5H11NO3, CAS 104195-80-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2s3s2Amino3MethoxybutanoicAcid;
formula     C5H11NO3;
CAS         104195-80-4;
InChIKey    FYCWLJLGIAUCCL-IMJSIDKUSA-N;
MW          133.147;      // g/mol [origin=calculated method=formula-sum]
Tc          762.48;      // K   [origin=predictive method=joback]
Pc          41.463;      // bar [origin=predictive method=joback]
omega       0.8487;      // -   [origin=predictive method=lee-kesler]
Tb          553.58;      // K   [origin=predictive method=joback]
HvapTb      56163.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.57 0.54014 -0.0002596 3.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH3O; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group O; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,3s)-2-azanyl-3-methoxy-butanoic acid" );
standardThermochemistry
{
    dHf_298   -605790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-396120.0
}
