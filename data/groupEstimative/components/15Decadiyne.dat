/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-decadiyne  (C10H14, CAS 53963-03-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Decadiyne;
formula     C10H14;
CAS         53963-03-4;
InChIKey    IWIDILFDSIIOSB-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          625.55;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       0.3378;      // -   [origin=predictive method=lee-kesler]
Tb          427.52;      // K   [origin=predictive method=joback]
HvapTb      39864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.135 0.71012 -0.00042399 1.0517e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH_C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group tCH; count 1; } { group tC; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "deca-1,5-diyne" "1,5-decadiyne;timtec-bb sbb008878;1,5-decadiynne;decadiynne;1,5-decadiyne (9ci);1,5-decadiyne 96%" );
gibbsFormation
{
    dHf_298   314470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=459190.0
    phase     gas;
}
