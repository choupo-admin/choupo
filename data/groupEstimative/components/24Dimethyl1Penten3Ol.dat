/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethyl-1-penten-3-ol  (C7H14O, CAS 19781-54-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dimethyl1Penten3Ol;
formula     C7H14O;
CAS         19781-54-5;
InChIKey    DWLSOADTNMPXFH-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          621.25;      // K   [origin=predictive method=joback]
Pc          33.220;      // bar [origin=predictive method=joback]
omega       0.6860;      // -   [origin=predictive method=lee-kesler]
Tb          447.62;      // K   [origin=predictive method=joback]
HvapTb      46489.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.23 0.69456 -0.000419 1.001e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 2; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-dimethylpent-1-en-3-ol" "2,4-dimethyl-1-pentene-3-ol" "1-penten-3-ol,2,4-dimethyl-" );
standardThermochemistry
{
    dHf_298   -234960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-54350.0
}
