/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxabicyclo[2.2.0]hex-5-en-3-one  (C5H4O2, CAS 22980-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Oxabicyclo220Hex5En3One;
formula     C5H4O2;
CAS         22980-23-0;
InChIKey    QAVYTTBRXJVSNJ-UHFFFAOYSA-N;
MW          96.085;      // g/mol [origin=calculated method=formula-sum]
Tc          568.56;      // K   [origin=predictive method=joback]
Pc          47.760;      // bar [origin=predictive method=joback]
omega       0.3909;      // -   [origin=predictive method=lee-kesler]
Tb          376.32;      // K   [origin=predictive method=joback]
HvapTb      33905.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.71 0.689 -0.00067408 2.538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxabicyclo[2.2.0]hex-5-en-2-one" "2-oxa-3-oxobicyclo(2.2.0)hex-5-ene" "2-oxa-3-oxobicyclo[2.2.0]hex-5-ene" );
standardThermochemistry
{
    dHf_298   -248110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     144.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-143490.0
}
