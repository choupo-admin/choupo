/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-sec-butyl-2-(1-phenylethyl)phenol  (C18H22O, CAS 2622-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4SecButyl21PhenylethylPhenol;
formula     C18H22O;
CAS         2622-83-5;
InChIKey    QJNBIFRUSFIANU-UHFFFAOYSA-N;
MW          254.373;      // g/mol [origin=calculated method=formula-sum]
Tc          988.31;      // K   [origin=predictive method=joback]
Pc          21.959;      // bar [origin=predictive method=joback]
omega       0.8327;      // -   [origin=predictive method=lee-kesler]
Tb          749.52;      // K   [origin=predictive method=joback]
HvapTb      73114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.269 1.66296 -0.00121352 3.612e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-butan-2-yl-2-(1-phenylethyl)phenol" "4-sec-butyl-2-(.alpha.-methylbenzyl)phenol" "4-sec-butyl-2-(.alpha.-methylbenzyl)alcohol" "4-(methylpropyl)-2-(phenylethyl)phenol" "4-sec-butyl-2-(a-methylbenzyl)phenol" "4-sec-butyl-2-(alpha-methylbenzyl)phenol" "4-(1-methylpropyl)-2-(1-phenylethyl)phenol" "phenol, 4-sec-butyl-2-(.alpha.-methylbenzyl)-" "phenol, 4-(1-methylpropyl)-2-(1-phenylethyl)-" );
standardThermochemistry
{
    dHf_298   -141130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     645.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=156370.0
}
