/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrabenazine  (C19H27NO3, CAS 58-46-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrabenazine;
formula     C19H27NO3;
CAS         58-46-8;
InChIKey    MKJIEFSOBYUXJB-UHFFFAOYSA-N;
MW          317.429;      // g/mol [origin=calculated method=formula-sum]
Tc          1040.41;      // K   [origin=predictive method=joback]
Pc          16.471;      // bar [origin=predictive method=joback]
omega       0.9700;      // -   [origin=predictive method=lee-kesler]
Tb          818.35;      // K   [origin=predictive method=joback]
HvapTb      72870.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.939 1.67878 -0.00088368 1.487e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2CO; count 1; } { group CH3O; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10-dimethoxy-3-(2-methylpropyl)-1,3,4,6,7,11b-hexahydrobenzo[a]quinolizin-2-one" "nitoman" "rubigen" "xenazine" "tetra benazin" "tetrabenazina" "tetrabenazinum" "tetrabenzaine" "tetrabenzine" "tetrabenazinum [inn-latin]" "xenazine (tn)" "nitoman (tn)" );
standardThermochemistry
{
    dHf_298   -433820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77770.0
}
