/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyethyl acrylate  (C5H8O3, CAS 818-61-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyethylAcrylate;
formula     C5H8O3;
CAS         818-61-1;
InChIKey    OMIGHNLMNHATMP-UHFFFAOYSA-N;
MW          116.116;      // g/mol [origin=calculated method=formula-sum]
Tc          633.51;      // K   [origin=predictive method=joback]
Pc          41.144;      // bar [origin=predictive method=joback]
omega       0.8630;      // -   [origin=predictive method=lee-kesler]
Tb          461.08;      // K   [origin=predictive method=joback]
HvapTb      50140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.052 0.438 -0.0002069 1.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hydroxyethyl prop-2-enoate" "hydroxyethyl acrylate" "ethylene glycol monoacrylate" "2-propenoic acid, 2-hydroxyethyl ester" "acrylic acid 2-hydroxyethyl ester" "acrylic acid, 2-hydroxyethyl ester" "bisomer 2hea" "2-(acryloyloxy)ethanol" "ethylene glycol, acrylate" "ethylene glycol, monoacrylate" "poly(2-hydroxyethyl acrylate)" "2-propenoic acid, 2-hydroxyethyl ester, homopolymer" );
gibbsFormation
{
    dHf_298   -490610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-368130.0
    phase     gas;
}
