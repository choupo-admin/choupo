/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-butoxyethoxy)ethyl acetate  (C10H20O4, CAS 124-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22ButoxyethoxyEthylAcetate;
formula     C10H20O4;
CAS         124-17-4;
InChIKey    VXQBJTKSVGFQOL-UHFFFAOYSA-N;
MW          204.266;      // g/mol [origin=calculated method=formula-sum]
Tc          700.15;      // K   [origin=predictive method=joback]
Pc          20.530;      // bar [origin=predictive method=joback]
omega       0.7985;      // -   [origin=predictive method=lee-kesler]
Tb          531.46;      // K   [origin=predictive method=joback]
HvapTb      50081.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (70.207 0.77264 -0.0002036 -5.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH3COO; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-butoxyethoxy)ethyl ethanoate" "butoxyethoxyethyl acetate" "diethylene glycol monobutyl ether acetate" "butyl carbitol acetate" "ethanol, 2-(2-butoxyethoxy)-, acetate" "butyl diethylene glycol acetate" "ektasolve db acetate" "diglycol monobutyl ether acetate" "butyl diglycol acetate" "2-(2-butoxyethoxy)ethanol acetate" "glycol ether db aceatate" "diethylene glycol butyl ether acetate" );
gibbsFormation
{
    dHf_298   -831450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-487050.0
    phase     gas;
}
