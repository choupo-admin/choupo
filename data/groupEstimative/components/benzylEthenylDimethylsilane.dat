/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl(ethenyl)dimethylsilane  (C11H16Si, CAS 18001-46-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzylEthenylDimethylsilane;
formula     C11H16Si;
CAS         18001-46-2;
InChIKey    YWUOHGZSMYKDCM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          176.334;      // g/mol [origin=calculated method=formula-sum]
Tc          689.77;      // K   [origin=predictive method=joback]
Pc          24.483;      // bar [origin=predictive method=joback]
omega       0.3180;      // -   [origin=predictive method=lee-kesler]
Tb          476.04;      // K   [origin=predictive method=joback]
HvapTb      41980.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.189 0.74374 -0.0002139 -5.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl-dimethyl-(phenylmethyl)silane" "benzyl(dimethyl)vinylsilane" "vinyldimethylbenzylsilane" "benzyl-ethenyl-dimethylsilane" "benzene,[(ethenyldimethylsilyl)methyl]-" "silane,benzyldimethylvinyl- (7ci,8ci); silane, ethenyldimethyl(phenylmethyl)- (9ci);benzyldimethylvinylsilane" );
gibbsFormation
{
    dHf_298   -20030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=137230.0
    phase     gas;
}
