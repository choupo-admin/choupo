/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyethyl methacrylate, methoxyethyl methacrylate polymer  (C13H22O6, CAS 29403-24-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyethylMethacrylateMethoxyethylMethacrylatePolymer;
formula     C13H22O6;
CAS         29403-24-5;
InChIKey    DBVGDYOGBAYKRO-UHFFFAOYSA-N;
MW          274.313;      // g/mol [origin=calculated method=formula-sum]
Tc          903.80;      // K   [origin=predictive method=joback]
Pc          17.729;      // bar [origin=predictive method=joback]
omega       1.2056;      // -   [origin=predictive method=lee-kesler]
Tb          722.60;      // K   [origin=predictive method=joback]
HvapTb      77549.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (108.134 0.85366 -4.92e-05 -1.945e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2=C; count 2; } { group OH; count 1; } { group CH3O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH2; count 2; } { group dC; count 2; } { group OH; count 1; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hydroxyethyl 2-methylprop-2-enoate;2-methoxyethyl 2-methylprop-2-enoate" "2-hydroxyethyl 2-methylprop-2-enoate- 2-methoxyethyl 2-methylprop-2-enoate(1:1)" "2-propenoic acid, 2-methyl-, 2-hydroxyethyl ester, polymer with 2-methoxyethyl 2-methyl-2-propenoate" "2-hydroxyethyl 2-methylprop-2-enoate; 2-methoxyethyl 2-methylprop-2-enoate" );
standardThermochemistry
{
    dHf_298   -1111000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     917.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-750160.0
}
