/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholest-5-en-3-yl docos-13-enoate  (C49H86O2, CAS 24516-39-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholest5En3YlDocos13Enoate;
formula     C49H86O2;
CAS         24516-39-0;
InChIKey    SQHUGNAFKZZXOT-UHFFFAOYSA-N;
MW          707.225;      // g/mol [origin=calculated method=formula-sum]
Tc          1921.12;      // K   [origin=predictive method=joback]
Pc          3.710;      // bar [origin=predictive method=joback]
omega       -0.3294;      // -   [origin=predictive method=lee-kesler]
Tb          1421.14;      // K   [origin=predictive method=joback]
HvapTb      129494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-320.449 5.58032 -0.00410544 1.2996e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 28; } { group CH; count 7; } { group C; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 21; } { group CH; count 2; } { group dCH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] docos-13-enoate" "cholest-5-en-3-ol (3.beta.)-, (13z)-13-docosenoate" "cholest-5-en-3-ol (3.beta.)-, 3-(13z)-13-docosenoate" );
standardThermochemistry
{
    dHf_298   -989140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1797.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=295390.0
}
