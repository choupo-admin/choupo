/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-benzyloxybromobenzene  (C13H11BrO, CAS 6793-92-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Benzyloxybromobenzene;
formula     C13H11BrO;
CAS         6793-92-6;
InChIKey    OUQSGILAXUXMGI-UHFFFAOYSA-N;
MW          263.134;      // g/mol [origin=calculated method=formula-sum]
Tc          898.83;      // K   [origin=predictive method=joback]
Pc          32.028;      // bar [origin=predictive method=joback]
omega       0.6324;      // -   [origin=predictive method=lee-kesler]
Tb          643.96;      // K   [origin=predictive method=joback]
HvapTb      58591.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.749 0.9965 -0.00063916 1.489e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group CH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-phenylmethoxy-benzene" "1-(benzyloxy)-4-bromobenzene" "1-benzyloxy-4-bromobenzene" "1-bromo-4-(phenylmethoxy)benzene" "1-bromo-4-benzyloxybenzene" "4-benzyloxy-bromobenzene" "4-benzyl-oxybromobenzene" "p-(benzyloxy)bromobenzene" "4-(benzyloxy)bromobenzene" "benzyl p-bromophenyl ether" "4-bromophenyl benzyl ether" "4-benzyloxy-1-bromobenzene" );
gibbsFormation
{
    dHf_298   44050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=183090.0
    phase     gas;
}
