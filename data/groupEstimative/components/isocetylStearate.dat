/*--------------------------------*- Choupo -*-----------------------*\
  Component: isocetyl stearate  (C34H68O2, CAS 25339-09-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isocetylStearate;
formula     C34H68O2;
CAS         25339-09-7;
InChIKey    LGEZTMRIZWCDLW-UHFFFAOYSA-N;
MW          508.916;      // g/mol [origin=calculated method=formula-sum]
Tc          1315.36;      // K   [origin=predictive method=joback]
Pc          5.007;      // bar [origin=predictive method=joback]
omega       0.0948;      // -   [origin=predictive method=lee-kesler]
Tb          1035.30;      // K   [origin=predictive method=joback]
HvapTb      98297.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.291 3.18496 -0.0017344 3.358e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 28; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 29; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "14-methylpentadecyl octadecanoate" "kessco ics" "octadecanoic acid, isohexadecyl ester" "stearic acid, isocetyl ester" "isohexadecyl stearate" "14-methylpentadecyl stearate" "stearic acid, isohexadecyl ester" "octadecanoic acid, isocetyl ester" );
gibbsFormation
{
    dHf_298   -1067650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1522.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77410.0
    phase     gas;
}
