/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methylnicotinic acid  (C7H7NO2, CAS 3222-47-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6MethylnicotinicAcid;
formula     C7H7NO2;
CAS         3222-47-7;
InChIKey    RZOKQIPOABEQAM-UHFFFAOYSA-N;
MW          137.138;      // g/mol [origin=calculated method=formula-sum]
Tc          832.48;      // K   [origin=predictive method=joback]
Pc          45.408;      // bar [origin=predictive method=joback]
omega       0.7343;      // -   [origin=predictive method=lee-kesler]
Tb          590.63;      // K   [origin=predictive method=joback]
HvapTb      57488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.42 0.61498 -0.00040302 1.025e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C5H3N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group COOH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylpyridine-3-carboxylic acid" "6-methyl nicotinic acid" "3-pyridinecarboxylic acid, 6-methyl-" "2-methyl-5-pyridinecarboxylic acid" "2-methylpyridine-5-carboxylic acid" "2-methyl-5-pyridine carboxylic acid" "agn-pc-00gqtk" "5-carboxy-2-methylpyridine" "u239" "6-methylpyridine-3-carboxylate;6-methylpyridine-3-carboxylic acid;" );
gibbsFormation
{
    dHf_298   -280230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-156020.0
    phase     gas;
}
