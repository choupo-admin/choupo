/*--------------------------------*- Choupo -*-----------------------*\
  Component: alternariol  (C14H10O5, CAS 641-38-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alternariol;
formula     C14H10O5;
CAS         641-38-3;
InChIKey    CEBXXEKPIIDJHL-UHFFFAOYSA-N;
MW          258.229;      // g/mol [origin=calculated method=formula-sum]
Tc          1142.37;      // K   [origin=predictive method=joback]
Pc          50.658;      // bar [origin=predictive method=joback]
omega       1.6218;      // -   [origin=predictive method=lee-kesler]
Tb          886.90;      // K   [origin=predictive method=joback]
HvapTb      99451.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.92 1.61272 -0.00168836 6.911e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 4; } { group ACCH3; count 1; } { group ACOH; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3,7,9-tris(oxidanyl)benzo[c]chromen-6-one" "alternariol from alternaria sp." "3,4,4'-trihydroxy-6'-methyl-2-biphenylcarboxylic acid, gamma lactone" "3,7,9-trihydroxy-1-methylbenzo[c]chromen-6-one" "aoh" "3,7,9-trihydroxy-1-methyl-6h-benzo[c]chromen-6-one" "6h-dibenzo(b,d)pyran-6-one, 1-methyl-3,7,9-trihydroxy-" "3,7,9-trihydroxy-1-methyl-6h-dibenzo(b,d)pyran-6-one" "3,7,9-trihydroxy-1-methyl-6h-dibenzo[b,d]pyran-6-one" "3,4',5-trihydroxy-6'-methyldibenzo-alpha-pyrone" "brd-k62196712-001-01-3" "6h-dibenzo[b,d]pyran-6-one, 3,7,9-trihydroxy-1-methyl-" );
standardThermochemistry
{
    dHf_298   -631230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-406540.0
}
