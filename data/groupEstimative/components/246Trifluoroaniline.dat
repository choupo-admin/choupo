/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trifluoroaniline  (C6H4F3N, CAS 363-81-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trifluoroaniline;
formula     C6H4F3N;
CAS         363-81-5;
InChIKey    BJSVKBGQDHUBHZ-UHFFFAOYSA-N;
MW          147.099;      // g/mol [origin=calculated method=formula-sum]
Tc          647.31;      // K   [origin=predictive method=joback]
Pc          39.755;      // bar [origin=predictive method=joback]
omega       0.5417;      // -   [origin=predictive method=lee-kesler]
Tb          448.84;      // K   [origin=predictive method=joback]
HvapTb      41402.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.19 0.4137 -0.00022528 3.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACNH2; count 1; } { group ACF; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-tris(fluoranyl)aniline" "2-amino-1,3,5-trifluorobenzene" "2,4,6-trifluorobenzenamine" "2,4,6-trifluorophenylamine" "2,4,6-trifluoro aniline" "wt201" "363-81-5 2,4,6-trifluoroaniline" "aniline,2,4,6-trifluoro- (8ci);2,4,6-trifluorobenzenamine;2-amino-1,3,5-trifluorobenzene;" );
gibbsFormation
{
    dHf_298   -519590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-434820.0
    phase     gas;
}
