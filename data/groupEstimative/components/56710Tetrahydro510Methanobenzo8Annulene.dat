/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,6,7,10-tetrahydro-5,10-methanobenzo[8]annulene  (C13H14, CAS 42919-38-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        56710Tetrahydro510Methanobenzo8Annulene;
formula     C13H14;
CAS         42919-38-0;
InChIKey    BMSYSIHHJDIMEP-UHFFFAOYSA-N;
MW          170.255;      // g/mol [origin=calculated method=formula-sum]
Tc          786.07;      // K   [origin=predictive method=joback]
Pc          29.893;      // bar [origin=predictive method=joback]
omega       0.4273;      // -   [origin=predictive method=lee-kesler]
Tb          545.61;      // K   [origin=predictive method=joback]
HvapTb      47760.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.36 1.3366 -0.00102884 3.17e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=CH; count 1; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,10-methanobenzocyclooctene,5,6,9,10-tetrahydro-" "5,10-methanobenzocyclooctene, 5,6,9,10-tetrahydro-" );
standardThermochemistry
{
    dHf_298   110630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=300720.0
}
