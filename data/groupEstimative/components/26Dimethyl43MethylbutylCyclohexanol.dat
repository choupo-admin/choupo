/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethyl-4-(3-methylbutyl)cyclohexanol  (C13H26O, CAS 71820-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethyl43MethylbutylCyclohexanol;
formula     C13H26O;
CAS         71820-42-3;
InChIKey    IYCAAVOUGBNPPO-UHFFFAOYSA-N;
MW          198.35;      // g/mol [origin=calculated method=formula-sum]
Tc          777.53;      // K   [origin=predictive method=joback]
Pc          19.579;      // bar [origin=predictive method=joback]
omega       0.8261;      // -   [origin=predictive method=lee-kesler]
Tb          594.32;      // K   [origin=predictive method=joback]
HvapTb      60325.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.108 1.32138 -0.0006318 7.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 5; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethyl-4-(3-methylbutyl)cyclohexan-1-ol" "cyclohexanol, 2,6-dimethyl-4-(3-methylbutyl)-" "agn-pc-02tz7c" );
standardThermochemistry
{
    dHf_298   -475860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-79360.0
}
