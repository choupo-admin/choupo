/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-1,2-cyclobutanedicarboxylic acid  (C6H8O4, CAS 3396-14-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans12CyclobutanedicarboxylicAcid;
formula     C6H8O4;
CAS         3396-14-3;
InChIKey    SUSAGCZZQKACKE-UHFFFAOYSA-N;
MW          144.126;      // g/mol [origin=calculated method=formula-sum]
Tc          858.87;      // K   [origin=predictive method=joback]
Pc          44.802;      // bar [origin=predictive method=joback]
omega       1.0230;      // -   [origin=predictive method=lee-kesler]
Tb          634.24;      // K   [origin=predictive method=joback]
HvapTb      63054.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.79 0.7902 -0.0005662 1.574e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobutane-1,2-dicarboxylic acid" "usaf st-3" "1,2-cyclobutanedicarboxylic acid" "1,2-cyclobutanedicarboxylic acid, trans-" "1,2-cyclobutanedicarboxylic acid, (e)-" "trans-cyclobutane-1,2-dicarboxylic acid" "1,2-cyclobutanedicarboxylic acid, cis-" "1,2-cyclobutanedicarboxylicacid" "cis-1,2-cyclobutanedicarboxylic acid" );
gibbsFormation
{
    dHf_298   -821410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-647240.0
    phase     gas;
}
