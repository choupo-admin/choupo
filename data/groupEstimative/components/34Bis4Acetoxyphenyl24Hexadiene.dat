/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-bis(4-acetoxyphenyl)-2,4-hexadiene  (C22H22O4, CAS 84-19-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Bis4Acetoxyphenyl24Hexadiene;
formula     C22H22O4;
CAS         84-19-5;
InChIKey    YWLLGDVBTLPARJ-UHFFFAOYSA-N;
MW          350.414;      // g/mol [origin=calculated method=formula-sum]
Tc          1124.93;      // K   [origin=predictive method=joback]
Pc          15.093;      // bar [origin=predictive method=joback]
omega       0.9727;      // -   [origin=predictive method=lee-kesler]
Tb          890.80;      // K   [origin=predictive method=joback]
HvapTb      85332.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.25 1.74728 -0.00108432 2.36e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 2; } { group ACH; count 8; } { group AC; count 4; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 2; } { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[4-(4-acetyloxyphenyl)hexa-2,4-dien-3-yl]phenyl] ethanoate" "dienestrol diacetate" "agn-pc-04t8rm" "[4-[4-(4-acetyloxyphenyl)hexa-2,4-dien-3-yl]phenyl] acetate" "[4-[(2z,4e)-4-(4-acetyloxyphenyl)hexa-2,4-dien-3-yl]phenyl] acetate" "phenol,4,4'-(1,2-diethylidene-1,2-ethanediyl)bis-, diacetate (9ci)" );
gibbsFormation
{
    dHf_298   -466990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     868.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-137480.0
    phase     gas;
}
