/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclooctylmethanol  (C9H18O, CAS 3637-63-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclooctylmethanol;
formula     C9H18O;
CAS         3637-63-6;
InChIKey    ZHPBLHYKDKSZCQ-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          727.87;      // K   [origin=predictive method=joback]
Pc          33.220;      // bar [origin=predictive method=joback]
omega       0.7028;      // -   [origin=predictive method=lee-kesler]
Tb          525.79;      // K   [origin=predictive method=joback]
HvapTb      53080.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.849 0.9957 -0.0004844 5.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclooctanemethanol" "cyclooctylmethan-1-ol" "cyclo octyl carbinol" );
standardThermochemistry
{
    dHf_298   -339320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-111670.0
}
