/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-heptadecene  (C17H34, CAS 6765-39-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Heptadecene;
formula     C17H34;
CAS         6765-39-5;
InChIKey    ADOBXTDBFNCOBN-UHFFFAOYSA-N;
MW          238.459;      // g/mol [origin=calculated method=formula-sum]
Tc          745.96;      // K   [origin=predictive method=joback]
Pc          12.683;      // bar [origin=predictive method=joback]
omega       0.7542;      // -   [origin=predictive method=lee-kesler]
Tb          585.24;      // K   [origin=predictive method=joback]
HvapTb      52766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.556 1.59882 -0.0009239 2.085e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptadec-1-ene" "hexahydroaplotaxene" "alkenes, c>10 .alpha.-" );
standardThermochemistry
{
    dHf_298   -268780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     813.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=180100.0
}
