/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-hydroxy-4-(trifluoromethyl)coumarin  (C10H5F3O3, CAS 575-03-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Hydroxy4TrifluoromethylCoumarin;
formula     C10H5F3O3;
CAS         575-03-1;
InChIKey    CCKWMCUOHJAVOL-UHFFFAOYSA-N;
MW          230.141;      // g/mol [origin=calculated method=formula-sum]
Tc          819.26;      // K   [origin=predictive method=joback]
Pc          36.072;      // bar [origin=predictive method=joback]
omega       0.9020;      // -   [origin=predictive method=lee-kesler]
Tb          604.76;      // K   [origin=predictive method=joback]
HvapTb      58470.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.5 1.1479 -0.00110936 4.098e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group F; count 3; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-oxidanyl-4-(trifluoromethyl)chromen-2-one" "7-hydroxy-4-trifluoromethylcoumarin" "7-hydroxy-4-(trifluoromethyl)-2h-chromen-2-one" "7-hydroxy-4-(trifluoromethyl)chromen-2-one" "4-(trifluoromethyl)umbelliferone" "7,4-hfc" "trifluoromethylumbelliferone" "4-(trifluoromethyl)umbelliferon" "beta-trifluoromethylumbelliferone" "4-(trifluoromethyl)umbeilliferone" "4-trifluoromethylumbelliferone" "7-hydroxy-4-trifluoromethyl-chromen-2-one" );
standardThermochemistry
{
    dHf_298   -970730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-809590.0
}
