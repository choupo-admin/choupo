/*--------------------------------*- Choupo -*-----------------------*\
  Component: propionamide  (C3H7NO, CAS 79-05-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propionamide;
formula     C3H7NO;
CAS         79-05-0;
InChIKey    QLNJFJADRCOGBJ-UHFFFAOYSA-N;
MW          73.095;      // g/mol [origin=calculated method=formula-sum]
Tc          591.77;      // K   [origin=predictive method=joback]
Pc          52.056;      // bar [origin=predictive method=joback]
omega       0.4545;      // -   [origin=predictive method=lee-kesler]
Tb          394.64;      // K   [origin=predictive method=joback]
HvapTb      39659.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.011 0.32272 -0.0001641 2.646e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propanamide" "propylamide" "propionic amide" "propanimidic acid" "propionimidic acid" "propionic acid amide" "propanimidic acid (van)" "propionimidic acid (van)" "propioamide" "amid kyseliny propionove" "s216" );
gibbsFormation
{
    dHf_298   -184040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-88090.0
    phase     gas;
}
