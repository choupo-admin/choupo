/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloromethyl-2,4-diisocyanatobenzene  (C9H5ClN2O2, CAS 51979-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloromethyl24Diisocyanatobenzene;
formula     C9H5ClN2O2;
CAS         51979-57-8;
InChIKey    LCJLEYPRGLFMGM-UHFFFAOYSA-N;
MW          208.601;      // g/mol [origin=calculated method=formula-sum]
Tc          843.88;      // K   [origin=predictive method=joback]
Pc          35.856;      // bar [origin=predictive method=joback]
omega       0.7782;      // -   [origin=predictive method=lee-kesler]
Tb          612.93;      // K   [origin=predictive method=joback]
HvapTb      62677.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 1; } { group dCd; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(chloromethyl)-2,4-diisocyanato-benzene" "4-chloromethyl-1,3-phenylene diisocyanate" "1-(chloromethyl)-2,4-diisocyanatobenzene" );
