/*--------------------------------*- Choupo -*-----------------------*\
  Component: alkenes, c9-11, c10-rich  (C10H16, CAS 68526-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alkenesC911C10Rich;
formula     C10H16;
CAS         68526-56-7;
InChIKey    FDBJNQUXZRDJHC-KQQUZDAGSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          615.64;      // K   [origin=predictive method=joback]
Pc          24.219;      // bar [origin=predictive method=joback]
omega       0.4061;      // -   [origin=predictive method=lee-kesler]
Tb          433.40;      // K   [origin=predictive method=joback]
HvapTb      37100.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.557 0.97382 -0.0007107 2.2e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e,7e)-deca-1,3,7-triene" "decene (petroleum)" "c10-rich c9-11 alkenes" );
gibbsFormation
{
    dHf_298   110140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=281600.0
    phase     gas;
}
