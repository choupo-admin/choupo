/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2-methylpropoxy)-4-oxobutanoic acid  (C8H14O4, CAS 20279-40-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        42Methylpropoxy4OxobutanoicAcid;
formula     C8H14O4;
CAS         20279-40-7;
InChIKey    RGTLSFNPTLNPDZ-UHFFFAOYSA-N;
MW          174.196;      // g/mol [origin=calculated method=formula-sum]
Tc          778.86;      // K   [origin=predictive method=joback]
Pc          28.173;      // bar [origin=predictive method=joback]
omega       0.9161;      // -   [origin=predictive method=lee-kesler]
Tb          585.93;      // K   [origin=predictive method=joback]
HvapTb      57585.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.943 0.76574 -0.0003926 5.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-methylpropoxy)-4-oxidanylidene-butanoic acid" "butanedioic acid, 1-(2-methylpropyl) ester" "butanedioic acid, mono(2-methylpropyl) ester" );
gibbsFormation
{
    dHf_298   -881280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-640240.0
    phase     gas;
}
