/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenedicarboxylic acid, polymer with 2,2-dimethyl-1,3-propanediol and 2-ethyl-2-(hydroxymethyl)-1,3-propanediol, 2-ethylhexanoate  (C27H46O10, CAS 72347-84-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BenzenedicarboxylicAcidPolymerWith22Dimethyl13PropanediolA;
formula     C27H46O10;
CAS         72347-84-3;
InChIKey    VQJLKUIYEIGYOP-UHFFFAOYSA-N;
MW          530.655;      // g/mol [origin=calculated method=formula-sum]
Tc          2300.93;      // K   [origin=predictive method=joback]
Pc          10.589;      // bar [origin=predictive method=joback]
omega       -0.0720;      // -   [origin=predictive method=lee-kesler]
Tb          1562.88;      // K   [origin=predictive method=joback]
HvapTb      184693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.52 2.4584 -0.00109856 5.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 10; } { group CH; count 1; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 4; } { group COOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 10; } { group CH; count 1; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 4; } { group COOH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid;2,2-bis(hydroxymethyl)butyl 2-ethylhexanoate;2,2-dimethylpropane-1,3-diol" "trimethylolpropane, neopentyl glycol, isophthalic acid polymer, 2-ethylhexanoate" );
standardThermochemistry
{
    dHf_298   -2248310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1584.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1472510.0
}
