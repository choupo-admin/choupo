/*--------------------------------*- Choupo -*-----------------------*\
  Component: norbornane, 2-chloro-  (C7H11Cl, CAS 29342-53-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norbornane2Chloro;
formula     C7H11Cl;
CAS         29342-53-8;
InChIKey    PJWBUKHIZPKRJF-UHFFFAOYSA-N;
MW          130.615;      // g/mol [origin=calculated method=formula-sum]
Tc          621.18;      // K   [origin=predictive method=joback]
Pc          35.643;      // bar [origin=predictive method=joback]
omega       0.2801;      // -   [origin=predictive method=lee-kesler]
Tb          410.27;      // K   [origin=predictive method=joback]
HvapTb      35250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.25 0.9413 -0.000716 2.216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylbicyclo[2.2.1]heptane" "exo-2-chloronorborane" "bicyclo[2.2.1]heptane, 2-chloro-" "norbornane, 2-chloro-, exo-" "bicyclo[2.2.1]heptane, 2-chloro-, exo-" "bicyclo(2.2.1)heptane, 2-chloro-" "exo-2-chloronorbornane" "bicyclo(2.2.1)heptane, 2-chloro-, exo-" "agn-pc-01n0bv" ".+/-.-exo-2-chloronorbornane" "2-chlorobicyclo[2.2.1]heptane" "3-chlorobicyclo[2.2.1]heptane" );
standardThermochemistry
{
    dHf_298   -84450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     259.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97820.0
}
