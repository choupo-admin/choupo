/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-4-(trifluoromethyl)benzamide  (C10H10F3NO, CAS 25771-21-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyl4TrifluoromethylBenzamide;
formula     C10H10F3NO;
CAS         25771-21-5;
InChIKey    NOFXHGGTQGRTTJ-UHFFFAOYSA-N;
MW          217.19;      // g/mol [origin=calculated method=formula-sum]
Tc          715.59;      // K   [origin=predictive method=joback]
Pc          27.212;      // bar [origin=predictive method=joback]
omega       0.6534;      // -   [origin=predictive method=lee-kesler]
Tb          520.95;      // K   [origin=predictive method=joback]
HvapTb      45834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.34 1.07254 -0.00079926 2.2546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CF3; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-p-trifluorobenzamide" "benzamide,n,n-dimethyl-4-(trifluoromethyl)-" "p-toluamide,a,a,a-trifluoro-n,n-dimethyl- (8ci); n,n-dimethyl-4-(trifluoromethyl)benzamide" );
gibbsFormation
{
    dHf_298   -666800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-463630.0
    phase     gas;
}
