/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-hydroxy-2-methylbutyrate  (C7H14O3, CAS 77-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Hydroxy2Methylbutyrate;
formula     C7H14O3;
CAS         77-70-3;
InChIKey    KIYWRWLZHQZKKD-UHFFFAOYSA-N;
MW          146.186;      // g/mol [origin=calculated method=formula-sum]
Tc          683.19;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.8730;      // -   [origin=predictive method=lee-kesler]
Tb          506.93;      // K   [origin=predictive method=joback]
HvapTb      53966.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.752 0.77386 -0.0004646 9.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-methyl-2-oxidanyl-butanoate" "ethyl 2-hydroxy-2-methylbutanoate" "butanoic acid, 2-hydroxy-2-methyl-, ethyl ester" "agn-pc-00n85n" "butanoic acid,2-hydroxy-2-methyl-, ethyl ester" "butyricacid, 2-hydroxy-2-methyl-, ethyl ester (6ci,7ci,8ci); 2-hydroxy-2-methylbutyricacid ethyl ester; butanoic acid, 2-hydroxy-2-methyl-, ethyl ester, (?a'a a'a currency)-" );
standardThermochemistry
{
    dHf_298   -666070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-436290.0
}
