/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraalkofen bpe  (C73H108O12, CAS 6683-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraalkofenBpe;
formula     C73H108O12;
CAS         6683-19-8;
InChIKey    BGYHLZZASRKEJE-UHFFFAOYSA-N;
MW          1177.655;      // g/mol [origin=calculated method=formula-sum]
Tc          8767.27;      // K   [origin=predictive method=joback]
Pc          2.572;      // bar [origin=predictive method=joback]
omega       -0.5670;      // -   [origin=predictive method=lee-kesler]
Tb          2542.69;      // K   [origin=predictive method=joback]
HvapTb      262512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-238.998 7.67908 -0.00572912 1.7114e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 24; } { group CH2; count 4; } { group C; count 9; } { group ACH; count 8; } { group AC; count 8; } { group ACCH2; count 4; } { group ACOH; count 4; } { group CH2COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 24; } { group CH2; count 12; } { group C; count 9; } { group dCH_ring; count 8; } { group dC_ring; count 16; } { group OH_phenol; count 4; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-[3-(3,5-ditert-butyl-4-oxidanyl-phenyl)propanoyloxy]-2,2-bis[3-(3,5-ditert-butyl-4-oxidanyl-phenyl)propanoyloxymethyl]propyl] 3-(3,5-ditert-butyl-4-oxidanyl-phenyl)propanoate" "phenosane 23" "dovernox 10" "pentaerythritol tetrakis(3-(3,5-di-tert-butyl-4-hydroxyphenyl)propionate)" "fenozan 22" "fenozan 23" "naugard 10" "anox 20am" "adk stab ao 60" "mark ao 60" "anox 20" "ao 60" );
standardThermochemistry
{
    dHf_298   -2752800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     2485.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-898020.0
}
