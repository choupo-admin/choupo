/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-heptadecenedioic acid, (8z)-  (C17H30O4, CAS 253687-28-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8HeptadecenedioicAcid8z;
formula     C17H30O4;
CAS         253687-28-4;
InChIKey    VDTSYDDUGXHLDV-UPHRSURJSA-N;
MW          298.423;      // g/mol [origin=calculated method=formula-sum]
Tc          1085.65;      // K   [origin=predictive method=joback]
Pc          14.568;      // bar [origin=predictive method=joback]
omega       1.2649;      // -   [origin=predictive method=lee-kesler]
Tb          883.74;      // K   [origin=predictive method=joback]
HvapTb      87722.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.547 1.7404 -0.00113 2.945e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 13; } { group CH=CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 13; } { group dCH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-heptadec-8-enedioic acid" );
standardThermochemistry
{
    dHf_298   -977530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     917.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-515340.0
}
