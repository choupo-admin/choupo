/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(pentafluorophenyl)acetamide  (C8H4F5NO, CAS 653-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PentafluorophenylAcetamide;
formula     C8H4F5NO;
CAS         653-20-3;
InChIKey    DGTVZQUNYUHWBK-UHFFFAOYSA-N;
MW          225.116;      // g/mol [origin=calculated method=formula-sum]
Tc          743.41;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.9127;      // -   [origin=predictive method=lee-kesler]
Tb          556.97;      // K   [origin=predictive method=joback]
HvapTb      52290.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (77.511 0.4803 -0.0002141 1.496e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACCH2; count 1; } { group ACF; count 5; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dC_ring; count 6; } { group F; count 5; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,3,4,5,6-pentakis(fluoranyl)phenyl]ethanamide" "2-(2,3,4,5,6-pentafluorophenyl)acetamide" );
standardThermochemistry
{
    dHf_298   -1088610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-955780.0
}
