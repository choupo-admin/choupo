/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans 2-nonenoic acid amide  (C9H17NO, CAS 14952-05-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans2NonenoicAcidAmide;
formula     C9H17NO;
CAS         14952-05-7;
InChIKey    PRCOWBGHTCNVDZ-BQYQJAHWSA-N;
MW          155.241;      // g/mol [origin=calculated method=formula-sum]
Tc          729.24;      // K   [origin=predictive method=joback]
Pc          27.412;      // bar [origin=predictive method=joback]
omega       0.7232;      // -   [origin=predictive method=lee-kesler]
Tb          536.08;      // K   [origin=predictive method=joback]
HvapTb      52973.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.625 0.91272 -0.0005743 1.4526e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=CH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-non-2-enamide" "2-nonenamide" "trans-2-nonenoic acid amide" );
gibbsFormation
{
    dHf_298   -190660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42650.0
    phase     gas;
}
