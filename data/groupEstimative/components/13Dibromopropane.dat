/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dibromopropane  (C3H6Br2, CAS 109-64-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dibromopropane;
formula     C3H6Br2;
CAS         109-64-8;
InChIKey    VEFLKXRACNJHOV-UHFFFAOYSA-N;
MW          201.889;      // g/mol [origin=calculated method=formula-sum]
Tc          609.27;      // K   [origin=predictive method=joback]
Pc          53.435;      // bar [origin=predictive method=joback]
omega       0.4013;      // -   [origin=predictive method=lee-kesler]
Tb          400.56;      // K   [origin=predictive method=joback]
HvapTb      35142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.543 0.3652 -0.0002822 9.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(bromanyl)propane" "trimethylene bromide" "trimethylene dibromide" "propane, 1,3-dibromo-" "1,3-dibrompropan" ".alpha.,.gamma.-dibromopropane" "alpha,gamma-dibromopropane" "trimethylenebromide" "1,3-dibromo propane" "1,3-dibromo-propane" ".omega.,.omega.'-dibromopropane" ".omega.,.omega.-dibromopropane;trimethylene dibromide;propane, 1,3-dibromo-;1/c3h6br2/c4-2-1-3-5/h1-3h;1,3-dibromopropane/109-64-8;1,3-dibromopropane / trimethylene dibromide;trimethylene bromide;" );
gibbsFormation
{
    dHf_298   -52590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=3020.0
    phase     gas;
}
