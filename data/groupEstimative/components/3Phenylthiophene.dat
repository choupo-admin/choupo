/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylthiophene  (C10H8S, CAS 2404-87-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenylthiophene;
formula     C10H8S;
CAS         2404-87-7;
InChIKey    ZDQZVKVIYAPRON-UHFFFAOYSA-N;
MW          160.234;      // g/mol [origin=calculated method=formula-sum]
Tc          788.25;      // K   [origin=predictive method=joback]
Pc          39.906;      // bar [origin=predictive method=joback]
omega       0.3627;      // -   [origin=predictive method=lee-kesler]
Tb          526.16;      // K   [origin=predictive method=joback]
HvapTb      47754.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.85 0.87601 -0.00066042 1.933e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thiophene, 3-phenyl-" "3-phenyl-thiophene" "zdqzvkviyapron-uhfffaoysa-" "nicotine 3-heteroaromatic analogue 25" );
gibbsFormation
{
    dHf_298   216970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=280140.0
    phase     gas;
}
