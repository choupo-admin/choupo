/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ketoglutaric acid  (C5H6O5, CAS 328-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2KetoglutaricAcid;
formula     C5H6O5;
CAS         328-50-7;
InChIKey    KPGXRSRHYNQIFN-UHFFFAOYSA-N;
MW          146.098;      // g/mol [origin=calculated method=formula-sum]
Tc          872.64;      // K   [origin=predictive method=joback]
Pc          47.107;      // bar [origin=predictive method=joback]
omega       1.2572;      // -   [origin=predictive method=lee-kesler]
Tb          658.89;      // K   [origin=predictive method=joback]
HvapTb      67798.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.902 0.5524 -0.0003747 9.526e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2CO; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CdO; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylidenepentanedioic acid" "2-oxopentanedioic acid" "alpha-ketoglutaric acid" "2-oxoglutaric acid" "2-oxoglutarate" "oxoglutaric acid" "alpha-ketoglutarate" "2-ketoglutarate" "alphaketoglutaric acid" "2-oxo-1,5-pentanedioic acid" "glutaric acid, alpha keto" "pentanedioic acid, 2-oxo-" );
standardThermochemistry
{
    dHf_298   -959650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-825520.0
}
