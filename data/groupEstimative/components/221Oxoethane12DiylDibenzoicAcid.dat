/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-(1-oxoethane-1,2-diyl)dibenzoic acid  (C16H12O5, CAS 4281-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        221Oxoethane12DiylDibenzoicAcid;
formula     C16H12O5;
CAS         4281-16-7;
InChIKey    YPNGOYFSQMSAOZ-UHFFFAOYSA-N;
MW          284.267;      // g/mol [origin=calculated method=formula-sum]
Tc          1223.64;      // K   [origin=predictive method=joback]
Pc          28.263;      // bar [origin=predictive method=joback]
omega       1.5191;      // -   [origin=predictive method=lee-kesler]
Tb          973.89;      // K   [origin=predictive method=joback]
HvapTb      98160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.309 1.3206 -0.00090142 2.2736e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group CH2CO; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group CdO; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-carboxyphenyl)-2-oxidanylidene-ethyl]benzoic acid" "2,2'-(1-oxo-1,2-ethanediyl)bisbenzoic acid" "benzoic acid, 2,2'-(1-oxo-1,2-ethanediyl)bis-" "acide (carboxy-2-benzoyl)-alpha ortho-toluique [french]" "benzoic acid, 2,2'-(oxoethylene)di-" "benzoic acid, 2,2'-(oxoethylene)di- (8ci)" "acide (carboxy-2-benzoyl)-alpha ortho-toluique" "2-[2-(2-carboxyphenyl)-2-oxoethyl]benzoic acid" );
gibbsFormation
{
    dHf_298   -736570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     687.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-527340.0
    phase     gas;
}
