/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptyl acetate  (C9H18O2, CAS 112-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptylAcetate;
formula     C9H18O2;
CAS         112-06-1;
InChIKey    ZCZSIDMEHXZRLG-UHFFFAOYSA-N;
MW          158.241;      // g/mol [origin=calculated method=formula-sum]
Tc          634.33;      // K   [origin=predictive method=joback]
Pc          23.181;      // bar [origin=predictive method=joback]
omega       0.5978;      // -   [origin=predictive method=lee-kesler]
Tb          463.74;      // K   [origin=predictive method=joback]
HvapTb      43035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.116 0.80404 -0.0003712 3.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-heptyl acetate" "acetic acid, heptyl ester" "heptyl alcohol, acetate" "heptyl ethanoate" "n-heptyl acetate" "heptanyl acetate" "n-heptyl ethanoate" "acetate c-7" "acetic acid n-heptyl ester" "heptanol acetate" "fema no. 2547" "acetic acid heptyl ester" );
standardThermochemistry
{
    dHf_298   -546370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-285470.0
}
