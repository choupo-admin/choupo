/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-bromobicyclo[2.2.1]hept-2-ene  (C7H9Br, CAS 5810-82-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Bromobicyclo221Hept2Ene;
formula     C7H9Br;
CAS         5810-82-2;
InChIKey    DWPPXNJBRSZQHD-UHFFFAOYSA-N;
MW          173.053;      // g/mol [origin=calculated method=formula-sum]
Tc          664.05;      // K   [origin=predictive method=joback]
Pc          42.552;      // bar [origin=predictive method=joback]
omega       0.3378;      // -   [origin=predictive method=lee-kesler]
Tb          438.16;      // K   [origin=predictive method=joback]
HvapTb      37592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.17 0.9167 -0.00075428 2.509e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 3; } { group CH=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bromanylbicyclo[2.2.1]hept-2-ene" "bicyclo(2.2.1)hept-2-ene, 5-bromo-, exo-" "6-bromobicyclo[2.2.1]hept-2-ene" "bicyclo[2.2.1]hept-2-ene,5-bromo-,endo-" "bicyclo[2.2.1]hept-2-ene,5-bromo-,exo-" "bicyclo(2.2.1)hept-2-ene, 5-bromo-, endo-" );
gibbsFormation
{
    dHf_298   15400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     239.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=154030.0
    phase     gas;
}
