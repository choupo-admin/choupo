/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylethylenediamine  (C4H12N2, CAS 108-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylethylenediamine;
formula     C4H12N2;
CAS         108-00-9;
InChIKey    DILRJUIACXKSQE-UHFFFAOYSA-N;
MW          88.154;      // g/mol [origin=calculated method=formula-sum]
Tc          556.38;      // K   [origin=predictive method=joback]
Pc          41.785;      // bar [origin=predictive method=joback]
omega       0.4352;      // -   [origin=predictive method=lee-kesler]
Tb          376.09;      // K   [origin=predictive method=joback]
HvapTb      37182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.948 0.56964 -0.0003498 8.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2NH2; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n',n'-dimethylethane-1,2-diamine" "2-dimethylaminoethylamine" "2-(dimethylamino)ethylamine" "1,2-ethanediamine, n,n-dimethyl-" "n,n-dimethylethanediamine" "(2-aminoethyl)dimethylamine" "ethylenediamine, n,n-dimethyl-" "n,n-dimethyl-1,2-ethanediamine" "n,n-dimethyl-1,2-ethylenediamine" "2-aminoethyldimethylamine" "n-(2-aminoethyl)-n,n-dimethylamine" "beta-(dimethylamino)ethylamine" );
standardThermochemistry
{
    dHf_298   -24570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160030.0
}
