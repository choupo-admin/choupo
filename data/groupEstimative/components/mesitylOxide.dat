/*--------------------------------*- Choupo -*-----------------------*\
  Component: mesityl oxide  (C6H10O, CAS 141-79-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mesitylOxide;
formula     C6H10O;
CAS         141-79-7;
InChIKey    SHOJXDKTYKFBRD-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          585.55;      // K   [origin=predictive method=joback]
Pc          35.685;      // bar [origin=predictive method=joback]
omega       0.3642;      // -   [origin=predictive method=lee-kesler]
Tb          394.79;      // K   [origin=predictive method=joback]
HvapTb      35734.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.08 0.56576 -0.00037 1.0036e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group dC; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylpent-3-en-2-one" "3-penten-2-one, 4-methyl-" "4-methyl-3-penten-2-one" "acetone, isopropylidene-" "isopropylideneacetone" "isobutenyl methyl ketone" "methyl isobutenyl ketone" "3-isohexen-2-one" "isopropylidene acetone" "mesityloxid" "mesityloxyde" "oxyde de mesityle" );
gibbsFormation
{
    dHf_298   -172320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57610.0
    phase     gas;
}
