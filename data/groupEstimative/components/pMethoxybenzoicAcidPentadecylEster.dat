/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-methoxybenzoic acid, pentadecyl ester  (C23H38O3, CAS 56954-74-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pMethoxybenzoicAcidPentadecylEster;
formula     C23H38O3;
CAS         56954-74-6;
InChIKey    SBIJFQKFVBDDDU-UHFFFAOYSA-N;
MW          362.554;      // g/mol [origin=calculated method=formula-sum]
Tc          1031.19;      // K   [origin=predictive method=joback]
Pc          10.260;      // bar [origin=predictive method=joback]
omega       0.9351;      // -   [origin=predictive method=lee-kesler]
Tb          838.14;      // K   [origin=predictive method=joback]
HvapTb      79547.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.284 1.93244 -0.00098596 1.512e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadecyl 4-methoxybenzoate" "benzoic acid, 4-methoxy-, pentadecyl ester" "4-methoxybenzoic acid pentadecyl ester" );
standardThermochemistry
{
    dHf_298   -742490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1001.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-169810.0
}
