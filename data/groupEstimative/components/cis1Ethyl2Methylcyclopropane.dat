/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-1-ethyl-2-methylcyclopropane  (C6H12, CAS 19781-68-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis1Ethyl2Methylcyclopropane;
formula     C6H12;
CAS         19781-68-1;
InChIKey    SAHWBARCQUAFSM-UHFFFAOYSA-N;
MW          84.162;      // g/mol [origin=calculated method=formula-sum]
Tc          516.69;      // K   [origin=predictive method=joback]
Pc          34.725;      // bar [origin=predictive method=joback]
omega       0.2459;      // -   [origin=predictive method=lee-kesler]
Tb          338.95;      // K   [origin=predictive method=joback]
HvapTb      28554.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.869 0.69824 -0.0004674 1.313e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-2-methyl-cyclopropane" "cyclopropane, 1-ethyl-2-methyl-" "1-methyl-trans-2-ethyl-cyclopropane" "cyclopropane, 1-ethyl-2-methyl-, cis-" "agn-pc-03cz5f" "trans-1-ethyl-2-methylcyclopropane" );
standardThermochemistry
{
    dHf_298   -114710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     257.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=52680.0
}
