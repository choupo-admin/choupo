/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalene, 1-(1-methylpropyl)-  (C14H16, CAS 1680-58-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphthalene11Methylpropyl;
formula     C14H16;
CAS         1680-58-6;
InChIKey    NDLQGVXBUFZFIX-UHFFFAOYSA-N;
MW          184.282;      // g/mol [origin=calculated method=formula-sum]
Tc          797.11;      // K   [origin=predictive method=joback]
Pc          25.176;      // bar [origin=predictive method=joback]
omega       0.5079;      // -   [origin=predictive method=lee-kesler]
Tb          570.12;      // K   [origin=predictive method=joback]
HvapTb      50948.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.569 1.19764 -0.00084188 2.366e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 7; } { group AC; count 2; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butan-2-ylnaphthalene" "1-(butan-2-yl)naphthalene" "agn-pc-00l671" "naphthalene, (1-methylpropyl)-" "1-(1-methyl-propyl)-naphthalene" );
standardThermochemistry
{
    dHf_298   78560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=273990.0
}
