/*--------------------------------*- Choupo -*-----------------------*\
  Component: isophytol  (C20H40O, CAS 505-32-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isophytol;
formula     C20H40O;
CAS         505-32-8;
InChIKey    KEVYVLWNCKMXJX-UHFFFAOYSA-N;
MW          296.539;      // g/mol [origin=calculated method=formula-sum]
Tc          916.45;      // K   [origin=predictive method=joback]
Pc          11.406;      // bar [origin=predictive method=joback]
omega       0.9767;      // -   [origin=predictive method=lee-kesler]
Tb          741.51;      // K   [origin=predictive method=joback]
HvapTb      73663.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.511 2.0614 -0.0012989 3.244e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 9; } { group CH; count 3; } { group C; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 9; } { group CH; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7,11,15-tetramethylhexadec-1-en-3-ol" "3,7,11,15-tetramethyl-1-hexadecen-3-ol" "1-hexadecen-3-ol, 3,7,11,15-tetramethyl-" "1-hexadecene-3-ol, 3,7,11,15-tetramethyl" "1-phyten-3-ol" "iso-phytol" "1-hexadecyl-3-ol, 3,7,11,15-tetramethyl" "1-hexadecen-3-ol,7,11,15-tetramethyl- (van8c" "3, 7, 11, 15 - tetramethyl-1-hexadecen-3-ol" "1-hexadecen-3-ol, 3,7,11,15-tetramethyl- (van) (8ci)" "1-hexadecen-3-ol, 3,7,11,15-tetramethyl- (van) (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   -507520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     913.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64060.0
    phase     gas;
}
