/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-buten-2-one, 4-(3-methylbicyclo[2.2.1]hept-5-en-2-yl)-  (C12H16O, CAS 6268-90-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Buten2One43Methylbicyclo221Hept5En2Yl;
formula     C12H16O;
CAS         6268-90-2;
InChIKey    YUGCMCNBXRSJKU-UHFFFAOYSA-N;
MW          176.259;      // g/mol [origin=calculated method=formula-sum]
Tc          752.39;      // K   [origin=predictive method=joback]
Pc          25.000;      // bar [origin=predictive method=joback]
omega       0.5216;      // -   [origin=predictive method=lee-kesler]
Tb          539.76;      // K   [origin=predictive method=joback]
HvapTb      48682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.79 1.31904 -0.00096458 2.8646e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 4; } { group CH=CH; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-methyl-3-bicyclo[2.2.1]hept-5-enyl)but-3-en-2-one" );
standardThermochemistry
{
    dHf_298   -129830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125400.0
}
