/*--------------------------------*- Choupo -*-----------------------*\
  Component: vitacampher  (C10H14O2, CAS 4745-55-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vitacampher;
formula     C10H14O2;
CAS         4745-55-5;
InChIKey    BZFVGPPELIFTQP-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          794.40;      // K   [origin=predictive method=joback]
Pc          33.529;      // bar [origin=predictive method=joback]
omega       0.5427;      // -   [origin=predictive method=lee-kesler]
Tb          558.44;      // K   [origin=predictive method=joback]
HvapTb      46208.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-158.02 1.60954 -0.001673 7.292e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 2; } { group CH2CO; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group CdO_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7-dimethyl-3-oxidanylidene-bicyclo[2.2.1]heptane-7-carbaldehyde" "pi-oxocamphor" "trans-pi-oxocamphor" "1,7-dimethyl-2-oxobicyclo[2.2.1]heptane-7-carbaldehyde" "7-norbornanecarboxaldehyde, 1,7-dimethyl-2-oxo-, trans-" "trans-pi-oxocamphor [jan]" "4,7-dimethyl-3-oxobicyclo[2.2.1]heptane-7-carbaldehyde" "(1s,4r)-4,7-dimethyl-3-oxobicyclo[2.2.1]heptane-7-carbaldehyde" "bicyclo(2.2.1)heptane-7-carboxaldehyde, 1,7-dimethyl-2-oxo-, anti-" "bicyclo(2.2.1)heptane-7-carboxaldehyde, 1,7-dimethyl-2-oxo-, anti- (9ci)" );
gibbsFormation
{
    dHf_298   -323430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98080.0
    phase     gas;
}
