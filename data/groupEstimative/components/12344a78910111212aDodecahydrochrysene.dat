/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4,4a,7,8,9,10,11,12,12a-dodecahydrochrysene  (C18H24, CAS 1610-22-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12344a78910111212aDodecahydrochrysene;
formula     C18H24;
CAS         1610-22-6;
InChIKey    DISXLARWFONJQP-UHFFFAOYSA-N;
MW          240.39;      // g/mol [origin=calculated method=formula-sum]
Tc          938.70;      // K   [origin=predictive method=joback]
Pc          21.394;      // bar [origin=predictive method=joback]
omega       0.5974;      // -   [origin=predictive method=lee-kesler]
Tb          690.76;      // K   [origin=predictive method=joback]
HvapTb      60488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-176.51 1.9068 -0.00136228 3.902e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group ACH; count 2; } { group ACCH2; count 3; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chrysene, 1,2,3,4,4a,7,8,9,10,11,12,12a-dodecahydro-" "1,3,4,5,6,7,8,9,10,10a-dodecahydrochrysene" "1,3,4,4a,7,8,9,10,11,12,12a-dodecahydrochrysene" "1,3,4,5,6,7,8,13,14,15,16-dodecahydrochrysene" "chrysene,2,3,4,4a,7,8,9,10,11,12,12a-dodecahydro-" );
gibbsFormation
{
    dHf_298   7530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=337860.0
    phase     gas;
}
