/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl (11beta,12alpha,13xi,15beta)-15-[(3,4-dimethylpent-2-enoyl)oxy]-3,11,12-trihydroxy-2,16-dioxo-13,20-epoxypicras-3-en-21-oate  (C28H36O11, CAS 41451-75-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl11beta12alpha13xi15beta1534Dimethylpent2EnoylOxy31112T;
formula     C28H36O11;
CAS         41451-75-6;
InChIKey    IRQXZTBHNKVIRL-UHFFFAOYSA-N;
MW          548.585;      // g/mol [origin=calculated method=formula-sum]
Tc          1830.41;      // K   [origin=predictive method=joback]
Pc          12.329;      // bar [origin=predictive method=joback]
omega       0.6324;      // -   [origin=predictive method=lee-kesler]
Tb          1418.54;      // K   [origin=predictive method=joback]
HvapTb      155114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-237.62 3.75952 -0.0033204 1.2512e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 8; } { group C; count 3; } { group CH=C; count 1; } { group OH; count 3; } { group CH2CO; count 1; } { group FCH2O; count 1; } { group C=C; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 7; } { group C_ring; count 3; } { group dC_ring; count 2; } { group OH; count 3; } { group O_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -1866790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     938.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1060940.0
    phase     gas;
}
