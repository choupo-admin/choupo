name        isocyanatotrimethylsilane;
formula     C4H9NOSi;
CAS         1118-02-1;
InChIKey    NIZHERJWXFHGGU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          115.207;      // g/mol [origin=calculated method=formula-sum]
Tc          545.42;      // K   [origin=predictive method=joback]
Pc          36.820;      // bar [origin=predictive method=joback]
omega       0.2804;      // -   [origin=predictive method=lee-kesler]
Tb          359.19;      // K   [origin=predictive method=joback]
HvapTb      34324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
