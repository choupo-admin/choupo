}
aliases     ( "isocyanato(trimethyl)silane" "trimethylsilyl isocyanate" "silane, isocyanatotrimethyl-" "trimethylsilylisocyanate" "(trimethylsilyl)isocyanate" "isocyanatotrimethylsilane;isocyanic acid, trimethylsilyl ester;trimethylisocyanatosilane;trimethylsilyl isocyanate;" );
