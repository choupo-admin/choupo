/*--------------------------------*- Choupo -*-----------------------*\
  Component: levodopa  (C9H11NO4, CAS 59-92-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        levodopa;
formula     C9H11NO4;
CAS         59-92-7;
InChIKey    WTDRDQBEARUVNC-LURJTMIESA-N;
MW          197.19;      // g/mol [origin=calculated method=formula-sum]
Tc          1060.62;      // K   [origin=predictive method=joback]
Pc          59.263;      // bar [origin=predictive method=joback]
omega       1.5388;      // -   [origin=predictive method=lee-kesler]
Tb          811.04;      // K   [origin=predictive method=joback]
HvapTb      91349.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.629 1.2077 -0.00112892 4.261e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-3-[3,4-bis(oxidanyl)phenyl]propanoic acid" "l-dopa" "dopar" "3-hydroxy-l-tyrosine" "3,4-dihydroxy-l-phenylalanine" "bendopa" "larodopa" "levopa" "cidandopa" "dopaidan" "dopalina" "insulamina" );
gibbsFormation
{
    dHf_298   -668940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-451830.0
    phase     gas;
}
