/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butene, 2,3-dichloro-  (C4H6Cl2, CAS 1587-26-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butene23Dichloro;
formula     C4H6Cl2;
CAS         1587-26-4;
InChIKey    YRCBNVMRRBIDNF-UHFFFAOYSA-N;
MW          124.992;      // g/mol [origin=calculated method=formula-sum]
Tc          570.14;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.2397;      // -   [origin=predictive method=lee-kesler]
Tb          369.90;      // K   [origin=predictive method=joback]
HvapTb      33386.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.47 0.41724 -0.000323 1.054e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(chloranyl)but-2-ene" "2-butene, 2,3-dichloro-, (z)-" );
standardThermochemistry
{
    dHf_298   -59730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22060.0
}
