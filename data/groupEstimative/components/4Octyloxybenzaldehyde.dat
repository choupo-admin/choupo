/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-octyloxybenzaldehyde  (C15H22O2, CAS 24083-13-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H22O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Octyloxybenzaldehyde;
formula     C15H22O2;
CAS         24083-13-4;
InChIKey    KVOWZHASDIKNFK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          234.339;      // g/mol [origin=calculated method=formula-sum]
Tc          764.10;      // K   [origin=predictive method=joback]
Pc          18.659;      // bar [origin=predictive method=joback]
omega       0.6528;      // -   [origin=predictive method=lee-kesler]
Tb          573.30;      // K   [origin=predictive method=joback]
HvapTb      51959.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.353 1.23532 -0.00079836 2.098e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-octoxybenzaldehyde" "4-(octyloxy)benzaldehyde" "benzaldehyde, 4-(octyloxy)-" "4-n-octyloxybenzaldehyde" "p-octyloxybenzaldehyde" "p-(octyloxy)benzaldehyde" "benzaldehyde,4-(octyloxy)-" "p-(octyloxy)benzaldehyde;benzaldehyde,p-(octyloxy)- (7ci,8ci);4-(octyloxy)benzaldehyde;4-(n-octyloxy)benzaldehyde;" );
standardThermochemistry
{
    dHf_298   -183640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     719.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117160.0
}
