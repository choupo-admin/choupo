/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chlorooctane  (C8H17Cl, CAS 111-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chlorooctane;
formula     C8H17Cl;
CAS         111-85-3;
InChIKey    CNDHHGUSRIZDSL-UHFFFAOYSA-N;
MW          148.674;      // g/mol [origin=calculated method=formula-sum]
Tc          590.99;      // K   [origin=predictive method=joback]
Pc          24.435;      // bar [origin=predictive method=joback]
omega       0.4598;      // -   [origin=predictive method=lee-kesler]
Tb          420.07;      // K   [origin=predictive method=joback]
HvapTb      37787.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.507 0.77062 -0.0004318 9.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyloctane" "n-octyl chloride" "octane, 1-chloro-" "octyl chloride" "chlorooctane" "capryl chloride" "octane, chloro-" "1-octyl chloride" "1-chloro-octane" );
standardThermochemistry
{
    dHf_298   -224190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4550.0
}
