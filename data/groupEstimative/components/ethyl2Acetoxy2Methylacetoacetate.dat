/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-acetoxy-2-methylacetoacetate  (C9H14O5, CAS 25409-39-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Acetoxy2Methylacetoacetate;
formula     C9H14O5;
CAS         25409-39-6;
InChIKey    RHFWCEYBHLGCKH-UHFFFAOYSA-N;
MW          202.206;      // g/mol [origin=calculated method=formula-sum]
Tc          767.67;      // K   [origin=predictive method=joback]
Pc          25.252;      // bar [origin=predictive method=joback]
omega       0.7841;      // -   [origin=predictive method=lee-kesler]
Tb          572.60;      // K   [origin=predictive method=joback]
HvapTb      55892.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.411 0.84708 -0.0004297 4.456e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH3CO; count 1; } { group CH3COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CdO; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-acetyloxy-2-methyl-3-oxidanylidene-butanoate" "ethyl 2-acetyllactate acetate" "ethyl 2-acetyloxy-2-methyl-3-oxobutanoate" "butanoic acid, 2-(acetyloxy)-2-methyl-3-oxo-, ethyl ester" "butanoic acid,2-(acetyloxy)-2-methyl-3-oxo-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -984980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-721920.0
}
