/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(pentan-2-yl)aniline  (C11H17N, CAS 30273-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pentan2YlAniline;
formula     C11H17N;
CAS         30273-14-4;
InChIKey    AKSSDFIINGVZJQ-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          773.07;      // K   [origin=predictive method=joback]
Pc          27.906;      // bar [origin=predictive method=joback]
omega       0.5791;      // -   [origin=predictive method=lee-kesler]
Tb          555.03;      // K   [origin=predictive method=joback]
HvapTb      53271.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.908 0.97824 -0.00058536 1.308e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 4; } { group ACCH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-pentan-2-ylaniline" "benzenamine, 4-(1-methylbutyl)-" "p-sec-amylaniline" );
gibbsFormation
{
    dHf_298   -16800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=208530.0
    phase     gas;
}
