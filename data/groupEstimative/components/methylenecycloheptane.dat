/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylenecycloheptane  (C8H14, CAS 2505-03-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylenecycloheptane;
formula     C8H14;
CAS         2505-03-5;
InChIKey    XJYOAWSHIQNEGC-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          622.33;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       0.2614;      // -   [origin=predictive method=lee-kesler]
Tb          410.29;      // K   [origin=predictive method=joback]
HvapTb      34471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.76 0.7853 -0.000409 6.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 6; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylidenecycloheptane" "cycloheptane, methylene" "cycloheptylmethyl" "methylene-cycloheptane" "cycloheptane,methylene-" "cycloheptane, methylene-" );
gibbsFormation
{
    dHf_298   -55710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89620.0
    phase     gas;
}
