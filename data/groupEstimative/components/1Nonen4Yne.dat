/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-nonen-4-yne  (C9H14, CAS 31508-12-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Nonen4Yne;
formula     C9H14;
CAS         31508-12-0;
InChIKey    GCZWNQLPRSOVNI-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          601.28;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       0.3364;      // -   [origin=predictive method=lee-kesler]
Tb          411.20;      // K   [origin=predictive method=joback]
HvapTb      37110.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.274 0.68902 -0.00039656 9.228e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2=CH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "non-1-en-4-yne" "1-nonen-4-yne;1-nonen-4-yne,96%;1-nonen-4-yne 96%" );
gibbsFormation
{
    dHf_298   168640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=315540.0
    phase     gas;
}
