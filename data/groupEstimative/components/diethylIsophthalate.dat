/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl isophthalate  (C12H14O4, CAS 636-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylIsophthalate;
formula     C12H14O4;
CAS         636-53-3;
InChIKey    JLVWYWVLMFVCDI-UHFFFAOYSA-N;
MW          222.24;      // g/mol [origin=calculated method=formula-sum]
Tc          829.93;      // K   [origin=predictive method=joback]
Pc          23.935;      // bar [origin=predictive method=joback]
omega       0.7932;      // -   [origin=predictive method=lee-kesler]
Tb          622.26;      // K   [origin=predictive method=joback]
HvapTb      60058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.192 0.89584 -0.00040396 1.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl benzene-1,3-dicarboxylate" "1,3-benzenedicarboxylic acid, diethyl ester" "diethyl m-phthalate" "isophthalic acid, diethyl ester" "1,3-benzenedicarboxylic acid, 1,3-diethyl ester" "diethyl isophthlate" "k004" "benzene-1,3-dicarboxylic acid diethyl ester" "1,3-benzenedicarboxylicacid, 1,3-diethyl ester" );
standardThermochemistry
{
    dHf_298   -700510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-467800.0
}
