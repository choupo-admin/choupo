/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl linolelaidate  (C19H34O2, CAS 2566-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylLinolelaidate;
formula     C19H34O2;
CAS         2566-97-4;
InChIKey    WTTJVINHCBCLGX-ZDVGBALWSA-N;
MW          294.479;      // g/mol [origin=calculated method=formula-sum]
Tc          875.56;      // K   [origin=predictive method=joback]
Pc          11.625;      // bar [origin=predictive method=joback]
omega       0.8777;      // -   [origin=predictive method=lee-kesler]
Tb          700.86;      // K   [origin=predictive method=joback]
HvapTb      65211.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.338 1.79404 -0.0010828 2.526e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH=CH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group dCH; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (9e,12e)-octadeca-9,12-dienoate" "methyl octadeca-9,12-dienoate" "methyl linoleate hydroperoxide" "linolelaidic acid methyl ester" "linolelaidic acid, methyl ester" "9,12-octadecadienoic acid, methyl ester, (e,e)-" "methyl trans,trans-9,12-octadecadienoate" "methyl (9e,12e)-9,12-octadecadienoate" "9,12-octadecadienoic acid (9z,12z)-, methyl ester, hydroperoxide" "9,12-octadecadienoic acid (z,z)-, methyl ester, hydroperoxide" "methyl linoleate" "9,12-octadecadienoic acid, methyl ester" );
gibbsFormation
{
    dHf_298   -518330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     934.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40830.0
    phase     gas;
}
