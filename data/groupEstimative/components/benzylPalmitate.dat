/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl palmitate  (C23H38O2, CAS 41755-60-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylPalmitate;
formula     C23H38O2;
CAS         41755-60-6;
InChIKey    CKEVMZSLVHLLBF-UHFFFAOYSA-N;
MW          346.555;      // g/mol [origin=calculated method=formula-sum]
Tc          1000.71;      // K   [origin=predictive method=joback]
Pc          10.473;      // bar [origin=predictive method=joback]
omega       0.9173;      // -   [origin=predictive method=lee-kesler]
Tb          810.74;      // K   [origin=predictive method=joback]
HvapTb      76475.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.515 2.05512 -0.001164 2.309e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl) hexadecanoate" "benzyl hexadecanoate" "palmitic acid benzyl ester" "hexadecanoic acid benzyl ester" "hexadecanoic acid, phenylmethyl ester" );
standardThermochemistry
{
    dHf_298   -598800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     996.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55180.0
}
