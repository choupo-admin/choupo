/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,15-pentadecanediol  (C15H32O2, CAS 14722-40-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        115Pentadecanediol;
formula     C15H32O2;
CAS         14722-40-8;
InChIKey    ZBPYFGWSQQFVCJ-UHFFFAOYSA-N;
MW          244.419;      // g/mol [origin=calculated method=formula-sum]
Tc          893.07;      // K   [origin=predictive method=joback]
Pc          16.338;      // bar [origin=predictive method=joback]
omega       1.3707;      // -   [origin=predictive method=lee-kesler]
Tb          727.16;      // K   [origin=predictive method=joback]
HvapTb      82342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.165 1.4968 -0.000853 1.869e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 15; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 15; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadecane-1,15-diol" "pentadeca methylene glycol" "1,15-dihydroxypentadecane;a,w-pentadecanediol;" );
gibbsFormation
{
    dHf_298   -657390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     842.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-198220.0
    phase     gas;
}
