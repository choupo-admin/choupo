/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexyl(phenyl)methanol  (C13H18O, CAS 945-49-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylPhenylMethanol;
formula     C13H18O;
CAS         945-49-3;
InChIKey    QDYKZBKCLHBUHU-UHFFFAOYSA-N;
MW          190.286;      // g/mol [origin=calculated method=formula-sum]
Tc          856.44;      // K   [origin=predictive method=joback]
Pc          29.861;      // bar [origin=predictive method=joback]
omega       0.8327;      // -   [origin=predictive method=lee-kesler]
Tb          635.01;      // K   [origin=predictive method=joback]
HvapTb      63528.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.83 1.3219 -0.0008292 1.879e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexylphenylmethanol" "methanol, cyclohexylphenyl-" "cyclohexanemethanol, alpha-phenyl-" "cyclohexylphenylmethan-1-ol" "ar-cyclohexylbenzenemethanol" "benzyl alcohol, cyclohexyl-" "cyclohexylhydroxymethylbenzene" "benzenemethanol, ar-cyclohexyl-" "benzenemethanol, alpha-cyclohexyl-" "benzenemethanol, .alpha.-cyclohexyl-" "benzenemethanol, alpha-cyclohexyl- (9ci)" );
standardThermochemistry
{
    dHf_298   -178310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56180.0
}
