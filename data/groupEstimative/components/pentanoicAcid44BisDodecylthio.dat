/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentanoic acid, 4,4-bis(dodecylthio)-  (C29H58O2S2, CAS 4200-61-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentanoicAcid44BisDodecylthio;
formula     C29H58O2S2;
CAS         4200-61-7;
InChIKey    XWIMFKGLFGDSOG-UHFFFAOYSA-N;
MW          502.901;      // g/mol [origin=calculated method=formula-sum]
Tc          1425.71;      // K   [origin=predictive method=joback]
Pc          6.712;      // bar [origin=predictive method=joback]
omega       0.4440;      // -   [origin=predictive method=lee-kesler]
Tb          1142.96;      // K   [origin=predictive method=joback]
HvapTb      109650.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.146 2.92424 -0.0017178 3.786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 22; } { group C; count 1; } { group COOH; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 24; } { group C; count 1; } { group COOH; count 1; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4-bis(dodecylsulfanyl)pentanoic acid" "4,4-bis(dodecylthio)valeric acid" "4,4-bis(dodecylthio)pentanoic acid" );
standardThermochemistry
{
    dHf_298   -917170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1422.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-81530.0
}
