/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetracyclo[5.2.1.02,6.03,5]decane,(1.alpha.,2.alpha.,3.beta.,5.beta.,6.alpha.,7.alpha.)-  (C10H14, CAS 53862-36-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetracyclo521026035Decane1Alpha2Alpha3Beta5Beta6Alpha7Alpha;
formula     C10H14;
CAS         53862-36-5;
InChIKey    RQMXABDSHYTRIF-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          642.95;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.3598;      // -   [origin=predictive method=lee-kesler]
Tb          437.48;      // K   [origin=predictive method=joback]
HvapTb      36544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-185.05 1.5236 -0.001383 5.084e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   13110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     59.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=285100.0
}
