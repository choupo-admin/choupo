/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromoeicosane  (C20H41Br, CAS 4276-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromoeicosane;
formula     C20H41Br;
CAS         4276-49-7;
InChIKey    CZASMUMJSKOHFJ-UHFFFAOYSA-N;
MW          361.452;      // g/mol [origin=calculated method=formula-sum]
Tc          895.70;      // K   [origin=predictive method=joback]
Pc          10.617;      // bar [origin=predictive method=joback]
omega       0.8947;      // -   [origin=predictive method=lee-kesler]
Tb          723.36;      // K   [origin=predictive method=joback]
HvapTb      66549.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.101 1.94202 -0.0011356 2.609e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 19; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 19; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylicosane" "eicosyl bromide" "1-bromoicosane" "eicosane, 1-bromo-" "bromoicosane" "arachidyl bromide" );
gibbsFormation
{
    dHf_298   -429800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     986.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=131840.0
    phase     gas;
}
