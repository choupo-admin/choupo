/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-cyclohexylpyridin-2-amine  (C11H16N2, CAS 15513-16-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nCyclohexylpyridin2Amine;
formula     C11H16N2;
CAS         15513-16-3;
InChIKey    UUMQKWWKCDCMJS-UHFFFAOYSA-N;
MW          176.263;      // g/mol [origin=calculated method=formula-sum]
Tc          853.69;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.5559;      // -   [origin=predictive method=lee-kesler]
Tb          601.38;      // K   [origin=predictive method=joback]
HvapTb      55431.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.77 1.20196 -0.00074466 1.671e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CHNH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group NH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexyl-pyridin-2-yl-amine" "n2-cyclohexylpyridin-2-amine" "2-pyridinamine,n-cyclohexyl-" "brd-k32406882-001-01-7" );
gibbsFormation
{
    dHf_298   106740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=345040.0
    phase     gas;
}
