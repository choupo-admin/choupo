/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-trans-3-methylisopropylcyclopentane  (C9H18, CAS 61828-03-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Trans3Methylisopropylcyclopentane;
formula     C9H18;
CAS         61828-03-3;
InChIKey    CDTDMKCVKCGRPD-IUCAKERBSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          610.99;      // K   [origin=predictive method=joback]
Pc          26.930;      // bar [origin=predictive method=joback]
omega       0.2950;      // -   [origin=predictive method=lee-kesler]
Tb          415.69;      // K   [origin=predictive method=joback]
HvapTb      35188.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.52 0.96996 -0.000541 1.067e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,3s)-1-methyl-3-propan-2-yl-cyclopentane" "cyclopentane, 1-methyl-3-(1-methylethyl)-, trans" "(1s,3s)-1-methyl-3-propan-2-ylcyclopentane" "1-methyl-trans-3-isopropylcyclopentane" );
gibbsFormation
{
    dHf_298   -194230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=51300.0
    phase     gas;
}
