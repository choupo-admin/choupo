/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1-benzylpiperidin-4-yl)ethanol  (C14H21NO, CAS 76876-70-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        21Benzylpiperidin4YlEthanol;
formula     C14H21NO;
CAS         76876-70-5;
InChIKey    FBFPTWSKNJHCGT-UHFFFAOYSA-N;
MW          219.328;      // g/mol [origin=calculated method=formula-sum]
Tc          871.08;      // K   [origin=predictive method=joback]
Pc          26.004;      // bar [origin=predictive method=joback]
omega       1.0169;      // -   [origin=predictive method=lee-kesler]
Tb          666.50;      // K   [origin=predictive method=joback]
HvapTb      68013.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.627 1.5445 -0.0010394 2.676e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1-(phenylmethyl)piperidin-4-yl]ethanol" "n-benzyl-4-(2-hydroxyethyl)piperidine" "1-benzyl-4-(2-hydroxyethyl)piperdine" "2-[1-benzyl-4-piperidyl]ethan-1-ol" "4-piperidineethanol,1-(phenylmethyl)-" "1-benzyl-4-piperidineethanol;2-(1-benzylpiperidin-4-yl)ethanol;n-benzyl-4-(2-hydroxyethyl)piperidine;" );
standardThermochemistry
{
    dHf_298   -119980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     611.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=189920.0
}
