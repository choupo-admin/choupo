/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-naphthalenediamine,n,n,n',n'-tetramethyl-  (C14H18N2, CAS 10075-69-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15NaphthalenediamineNNNNTetramethyl;
formula     C14H18N2;
CAS         10075-69-1;
InChIKey    TYMBOHQMUQAOBA-UHFFFAOYSA-N;
MW          214.312;      // g/mol [origin=calculated method=formula-sum]
Tc          816.82;      // K   [origin=predictive method=joback]
Pc          24.507;      // bar [origin=predictive method=joback]
omega       0.6629;      // -   [origin=predictive method=lee-kesler]
Tb          600.42;      // K   [origin=predictive method=joback]
HvapTb      56084.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.97 1.38008 -0.00099684 2.87e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 6; } { group AC; count 4; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n1,n5,n5-tetramethylnaphthalene-1,5-diamine" "1,5-naphthalenediamine, n,n,n',n'-tetramethyl-" "1,5-naphthalenediamine,n1,n1,n5,n5-tetramethyl-" "1-n,1-n,5-n,5-n-tetramethylnaphthalene-1,5-diamine" "1,5-naphthalenediamine,n,n,n',n'-tetramethyl- (7ci,8ci,9ci); 1,5-bisdimethylaminonaphthalene;n,n,n',n'-tetramethyl-1,5-naphthalenediamine" );
standardThermochemistry
{
    dHf_298   207430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=488360.0
}
