/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisooctyl adipate  (C22H42O4, CAS 1330-86-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisooctylAdipate;
formula     C22H42O4;
CAS         1330-86-5;
InChIKey    CJFLBOQMPJCWLR-UHFFFAOYSA-N;
MW          370.574;      // g/mol [origin=calculated method=formula-sum]
Tc          1003.40;      // K   [origin=predictive method=joback]
Pc          9.161;      // bar [origin=predictive method=joback]
omega       0.8742;      // -   [origin=predictive method=lee-kesler]
Tb          818.52;      // K   [origin=predictive method=joback]
HvapTb      78604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.344 1.99608 -0.0009902 1.354e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 14; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(6-methylheptyl) hexanedioate" "bis(6-methylheptyl) adipate" "hexanedioic acid, diisooctyl ester" "diiosoctyl adipate" "diisoctyl adipate" "adipic acid, di-isooctyl ester" "hexanedioic acid, 1,6-diisooctyl ester" "hexanedioic acid,1,6-bis(6-methylheptyl) ester" "adipicacid, bis(6-methylheptyl) ester (8ci); hexanedioic acid, bis(6-methylheptyl)ester (9ci); 1-heptanol, 6-methyl-, adipate; bis(6-methylheptyl) adipate" );
gibbsFormation
{
    dHf_298   -1142530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1096.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-491260.0
    phase     gas;
}
