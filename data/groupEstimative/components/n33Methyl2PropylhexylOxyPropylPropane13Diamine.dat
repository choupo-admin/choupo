/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-{3-[(3-methyl-2-propylhexyl)oxy]propyl}propane-1,3-diamine  (C16H36N2O, CAS 68479-02-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n33Methyl2PropylhexylOxyPropylPropane13Diamine;
formula     C16H36N2O;
CAS         68479-02-7;
InChIKey    YSMCUJMPCRLHOP-UHFFFAOYSA-N;
MW          272.477;      // g/mol [origin=calculated method=formula-sum]
Tc          887.19;      // K   [origin=predictive method=joback]
Pc          13.871;      // bar [origin=predictive method=joback]
omega       1.0172;      // -   [origin=predictive method=lee-kesler]
Tb          709.92;      // K   [origin=predictive method=joback]
HvapTb      69921.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.761 1.61056 -0.000834 1.449e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 2; } { group CH2O; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 2; } { group O; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-[3-(3-methyl-2-propyl-hexoxy)propyl]propane-1,3-diamine" "n-isodecyloxypropyl trimethylene diamine" "1,3-propanediamine, n-(3-(decyloxy)propyl)-, branched" "1,3-propanediamine, n1-(3-(decyloxy)propyl)-, branched" "n'-[3-(3-methyl-2-propylhexoxy)propyl]propane-1,3-diamine" "1,3-propanediamine, n-(3-(decyloxy)propyl)-, branched and linear" "1,3-propanediamine, n1-(3-(decyloxy)propyl)-, branched and linear" );
standardThermochemistry
{
    dHf_298   -429090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     863.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=129800.0
}
