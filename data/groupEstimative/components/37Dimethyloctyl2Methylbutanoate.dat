/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethyloctyl 2-methylbutanoate  (C15H30O2, CAS 68368-54-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethyloctyl2Methylbutanoate;
formula     C15H30O2;
CAS         68368-54-7;
InChIKey    SQALVBRSOCSXNI-UHFFFAOYSA-N;
MW          242.403;      // g/mol [origin=calculated method=formula-sum]
Tc          772.53;      // K   [origin=predictive method=joback]
Pc          14.468;      // bar [origin=predictive method=joback]
omega       0.7560;      // -   [origin=predictive method=lee-kesler]
Tb          599.70;      // K   [origin=predictive method=joback]
HvapTb      55227.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.616 1.3918 -0.0007072 1.087e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 6; } { group CH; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 6; } { group CH; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrahydrogeranyl 2-methylbutyrate" "butanoic acid, 2-methyl-, 3,7-dimethyloctyl ester" "tetrahydrogeranyl 2-methyl-2-ethylacetate" );
gibbsFormation
{
    dHf_298   -686050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     762.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-242270.0
    phase     gas;
}
