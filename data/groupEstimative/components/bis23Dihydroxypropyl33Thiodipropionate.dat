/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2,3-dihydroxypropyl) 3,3'-thiodipropionate  (C12H22O8S, CAS 68928-36-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis23Dihydroxypropyl33Thiodipropionate;
formula     C12H22O8S;
CAS         68928-36-9;
InChIKey    OOTUIMGUOKCPKY-UHFFFAOYSA-N;
MW          326.36;      // g/mol [origin=calculated method=formula-sum]
Tc          1275.15;      // K   [origin=predictive method=joback]
Pc          26.057;      // bar [origin=predictive method=joback]
omega       1.6227;      // -   [origin=predictive method=lee-kesler]
Tb          1027.22;      // K   [origin=predictive method=joback]
HvapTb      129877.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (80.198 1.17639 -0.0005276 2.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group OH; count 4; } { group CH2COO; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group CH; count 2; } { group OH; count 4; } { group COO; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(oxidanyl)propyl 3-[3-[2,3-bis(oxidanyl)propoxy]-3-oxidanylidene-propyl]sulfanylpropanoate" "bis(2,3-dihydroxypropyl) 3,3'-thiobispropionate" "propanoic acid, 3,3'-thiobis-, 1,1'-bis(2,3-dihydroxypropyl) ester" "propanoic acid, 3,3'-thiobis-, bis(2,3-dihydroxypropyl) ester" "propanoic acid,3,3'-thiobis-, 1,1'-bis(2,3-dihydroxypropyl) ester" "propanoicacid, 3,3'-thiobis-, bis(2,3-dihydroxypropyl) ester (9ci)" "2,3-dihydroxypropyl 3-[3-(2,3-dihydroxypropoxy)-3-oxopropyl]sulfanylpropanoate" );
standardThermochemistry
{
    dHf_298   -1503180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     971.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1089620.0
}
