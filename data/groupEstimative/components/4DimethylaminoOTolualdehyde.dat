/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-dimethylamino-o-tolualdehyde  (C10H13NO, CAS 1199-59-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H13NO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4DimethylaminoOTolualdehyde;
formula     C10H13NO;
CAS         1199-59-3;
InChIKey    XZWMCPUAUNHGPF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          163.22;      // g/mol [origin=calculated method=formula-sum]
Tc          657.62;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.3977;      // -   [origin=predictive method=lee-kesler]
Tb          453.90;      // K   [origin=predictive method=joback]
HvapTb      41124.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.7 0.88796 -0.00068292 2.176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CHO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(dimethylamino)-2-methyl-benzaldehyde" "4-(dimethylamino)-2-methylbenzaldehyde" "benzaldehyde, 4-(dimethylamino)-2-methyl-" "4-dimethylamino-2-methylbenzaldehyde" "benzaldehyde,4-(dimethylamino)-2-methyl-" );
standardThermochemistry
{
    dHf_298   107840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=281210.0
}
