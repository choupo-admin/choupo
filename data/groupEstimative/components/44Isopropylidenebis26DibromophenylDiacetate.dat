/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-isopropylidenebis(2,6-dibromophenyl) diacetate  (C19H16Br4O4, CAS 33798-02-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Isopropylidenebis26DibromophenylDiacetate;
formula     C19H16Br4O4;
CAS         33798-02-6;
InChIKey    ZUBOJXBQSZDOID-UHFFFAOYSA-N;
MW          627.949;      // g/mol [origin=calculated method=formula-sum]
Tc          1366.31;      // K   [origin=predictive method=joback]
Pc          21.335;      // bar [origin=predictive method=joback]
omega       1.3905;      // -   [origin=predictive method=lee-kesler]
Tb          1095.41;      // K   [origin=predictive method=joback]
HvapTb      105670.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.71 1.46308 -0.00093816 2.106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 8; } { group CH3COO; count 2; } { group Br; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group Br; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[2-[4-acetyloxy-3,5-bis(bromanyl)phenyl]propan-2-yl]-2,6-bis(bromanyl)phenyl] ethanoate" "phenol, 4,4'-(1-methylethylidene)bis(2,6-dibromo-, diacetate" "phenol, 4,4'-(1-methylethylidene)bis[2,6-dibromo-, diacetate" "phenol, 4,4'-(1-methylethylidene)bis(2,6-dibromo-, 1,1'-diacetate" "phenol, 4,4'-(1-methylethylidene)bis[2,6-dibromo-, 1,1'-diacetate" "[4-[2-(4-acetyloxy-3,5-dibromophenyl)propan-2-yl]-2,6-dibromophenyl] acetate" );
standardThermochemistry
{
    dHf_298   -569240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     914.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-284480.0
}
