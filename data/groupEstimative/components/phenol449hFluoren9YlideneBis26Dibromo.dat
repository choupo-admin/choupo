/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 4,4'-(9h-fluoren-9-ylidene)bis[2,6-dibromo-  (C25H14Br4O2, CAS 94854-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol449hFluoren9YlideneBis26Dibromo;
formula     C25H14Br4O2;
CAS         94854-03-2;
InChIKey    VYTXKAABSCYYEU-UHFFFAOYSA-N;
MW          666.001;      // g/mol [origin=calculated method=formula-sum]
Tc          1654.61;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       1.8712;      // -   [origin=predictive method=lee-kesler]
Tb          1332.52;      // K   [origin=predictive method=joback]
HvapTb      134506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.73 2.6302 -0.00270268 1.0986e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 12; } { group AC; count 10; } { group ACOH; count 2; } { group Br; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 12; } { group Br; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[9-[3,5-bis(bromanyl)-4-oxidanyl-phenyl]fluoren-9-yl]-2,6-bis(bromanyl)phenol" "phenol, 4,4'-(9h-fluoren-9-ylidene)bis(2,6-dibromo-" "agn-pc-00pgis" );
gibbsFormation
{
    dHf_298   169030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     863.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=378980.0
    phase     gas;
}
