/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylheptanal  (C8H16O, CAS 16630-91-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylheptanal;
formula     C8H16O;
CAS         16630-91-4;
InChIKey    DHEKCFIOOSCJRW-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          605.51;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       0.5219;      // -   [origin=predictive method=lee-kesler]
Tb          430.86;      // K   [origin=predictive method=joback]
HvapTb      39734.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.334 0.74424 -0.0004076 8.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylheptan-1-al" "heptanal, 2-methyl-" "heptanal, methyl-" "agn-pc-00n60v" );
gibbsFormation
{
    dHf_298   -299310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85480.0
    phase     gas;
}
