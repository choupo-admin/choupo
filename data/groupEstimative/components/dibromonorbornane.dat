/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibromonorbornane  (C7H10Br2, CAS 26637-71-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibromonorbornane;
formula     C7H10Br2;
CAS         26637-71-8;
InChIKey    WQLOPWOVROOXQQ-UHFFFAOYSA-N;
MW          253.965;      // g/mol [origin=calculated method=formula-sum]
Tc          757.94;      // K   [origin=predictive method=joback]
Pc          47.236;      // bar [origin=predictive method=joback]
omega       0.4190;      // -   [origin=predictive method=lee-kesler]
Tb          505.40;      // K   [origin=predictive method=joback]
HvapTb      42584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.75 1.3028 -0.001371 5.788e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,7-bis(bromanyl)bicyclo[2.2.1]heptane" "7,7-dibromobicyclo[2.2.1]heptane" "dibromobicycloheptane (mixed isomers)" "norbornane, dibromo-" "agn-pc-03i4ja" "norbornane, dibromo- (8ci)" "7,7-dibromobicyclo[2.2.1]hepta-1,3,5-triene" );
standardThermochemistry
{
    dHf_298   -810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132900.0
}
