/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-didecanoyloxydiphenyldiacetylene  (C36H46O4, CAS 92341-28-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Didecanoyloxydiphenyldiacetylene;
formula     C36H46O4;
CAS         92341-28-1;
InChIKey    PBQTWTYWXMTXRB-UHFFFAOYSA-N;
MW          542.76;      // g/mol [origin=calculated method=formula-sum]
Tc          1505.29;      // K   [origin=predictive method=joback]
Pc          7.257;      // bar [origin=predictive method=joback]
omega       0.6103;      // -   [origin=predictive method=lee-kesler]
Tb          1221.04;      // K   [origin=predictive method=joback]
HvapTb      120724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.886 2.73784 -0.00148944 2.6216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group ACH; count 8; } { group AC; count 4; } { group CH2COO; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group tC; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[4-(4-decanoyloxyphenyl)buta-1,3-diynyl]phenyl] decanoate" );
standardThermochemistry
{
    dHf_298   -426210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1379.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=242660.0
}
