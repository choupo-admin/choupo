/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylbut-2-enedioic acid  (C5H6O4, CAS 498-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylbut2EnedioicAcid;
formula     C5H6O4;
CAS         498-24-8;
InChIKey    HNEGQIOMVPPMNR-UHFFFAOYSA-N;
MW          130.099;      // g/mol [origin=calculated method=formula-sum]
Tc          828.38;      // K   [origin=predictive method=joback]
Pc          46.721;      // bar [origin=predictive method=joback]
omega       1.0090;      // -   [origin=predictive method=lee-kesler]
Tb          609.06;      // K   [origin=predictive method=joback]
HvapTb      61090.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.33 0.60032 -0.0004795 1.535e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group dC; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-2-methylbut-2-enedioic acid" "(z)-2-methyl-2-butenedioicacid;methylmaleic acid;" );
standardThermochemistry
{
    dHf_298   -739640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-624930.0
}
