/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1'-acetoxyelemicin  (C14H18O5, CAS 110011-81-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Acetoxyelemicin;
formula     C14H18O5;
CAS         110011-81-9;
InChIKey    JSRJRLXSMHLTLD-UHFFFAOYSA-N;
MW          266.293;      // g/mol [origin=calculated method=formula-sum]
Tc          885.89;      // K   [origin=predictive method=joback]
Pc          19.372;      // bar [origin=predictive method=joback]
omega       0.8973;      // -   [origin=predictive method=lee-kesler]
Tb          683.26;      // K   [origin=predictive method=joback]
HvapTb      64599.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (96.39 0.81798 -0.00016638 -9.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH; count 1; } { group CH3COO; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3,4,5-trimethoxyphenyl)prop-2-enyl ethanoate" "3,4,5-trimethoxy-alpha-vinylbenzyl alcohol acetate" "benzenemethanol, a-ethenyl-3,4,5-trimethoxy-,1-acetate" "benzyl alcohol, 3,4,5-trimethoxy-alpha-vinyl-, acetate" "benzenemethanol, alpha-ethenyl-3,4,5-trimethoxy-, acetate" "1-(3,4,5-trimethoxyphenyl)prop-2-enyl acetate" "1-(3,4,5-trimethoxyphenyl)prop-2-en-1-yl acetate" "benzenemethanol,a-ethenyl-3,4,5-trimethoxy-,acetate (9ci)" );
standardThermochemistry
{
    dHf_298   -723960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-389450.0
}
