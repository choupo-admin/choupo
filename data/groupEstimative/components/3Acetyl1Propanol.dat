/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-acetyl-1-propanol  (C5H10O2, CAS 1071-73-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Acetyl1Propanol;
formula     C5H10O2;
CAS         1071-73-4;
InChIKey    JSHPTIGHEWEXRW-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          632.77;      // K   [origin=predictive method=joback]
Pc          42.002;      // bar [origin=predictive method=joback]
omega       0.8656;      // -   [origin=predictive method=lee-kesler]
Tb          460.05;      // K   [origin=predictive method=joback]
HvapTb      50149.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.993 0.48482 -0.0002599 4.906e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-oxidanylpentan-2-one" "5-hydroxypentan-2-one" "5-hydroxy-2-pentanone" "3-acetopropanol" "3-acetylpropanol" ".gamma.-acetopropanol" "5-hydroxy-pentan-2-one" "2-pentanone, 5-hydroxy-" "acetopropyl alcohol" "gamma-acetopropanol" "propanol, 3-acetyl-" "gamma-acetylpropyl alcohol" );
standardThermochemistry
{
    dHf_298   -411340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-274520.0
}
