\*---------------------------------------------------------------------------*/

name        tinuvin144;
formula     C42H72N2O5;
CAS         63843-89-0;
InChIKey    FLPKSBDJMLUTEX-UHFFFAOYSA-N;
MW          685.047;      // g/mol [origin=calculated method=formula-sum]
Tc          1798.87;      // K   [origin=predictive method=joback]
Pc          5.336;      // bar [origin=predictive method=joback]
omega       0.1683;      // -   [origin=predictive method=lee-kesler]
Tb          1422.29;      // K   [origin=predictive method=joback]
HvapTb      135386.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-390.676 5.79144 -0.00512948 1.9319e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 15; } { group CH2; count 7; } { group CH; count 2; } { group C; count 7; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3N; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 17; } { group CH2; count 4; } { group C; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group COO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(1,2,2,6,6-pentamethylpiperidin-4-yl) 2-butyl-2-[(3,5-ditert-butyl-4-oxidanyl-phenyl)methyl]propanedioate" "di-(1,2,2,6,6-pentamethyl-4-piperidyl)-2-butyl-2-(3,5-di-tert-butyl-4-hydroxybenzyl)malonate" "bis(1,2,2,6,6-pentamethylpiperidin-4-yl) butyl(3,5-di-tert-butyl-4-hydroxybenzyl)malonate" "bis(1,2,2,6,6-pentamethyl-4-piperidyl) ((3,5-bis(1,1-dimethylethyl)-4-hydroxyphenyl)methyl)butylmalonate" "bis(1,2,2,6,6-pentamethyl-4-piperidyl) [[3,5-bis(1,1-dimethylethyl)-4-hydroxyphenyl]methyl]butylmalonate" "propanedioic acid, ((3,5-bis(1,1-dimethylethyl)-4-hydroxyphenyl)methyl)butyl-, bis(1,2,2,6,6-pentamethyl-4-piperidinyl) ester" "propanedioic acid, 2-((3,5-bis(1,1-dimethylethyl)-4-hydroxyphenyl)methyl)-2-butyl-, 1,3-bis(1,2,2,6,6-pentamethyl-4-piperidinyl) ester" "propanedioic acid, 2-[[3,5-bis(1,1-dimethylethyl)-4-hydroxyphenyl]methyl]-2-butyl-, 1,3-bis(1,2,2,6,6-pentamethyl-4-piperidinyl) ester" "tpc-i138" "bis(1,2,2,6,6-pentamethyl-4-piperidyl) 2-butyl-2-[(4-hydroxy-3,5-ditert-butyl-phenyl)methyl]propanedioate" "bis(1,2,2,6,6-pentamethyl-4-piperidyl)[[3,5-bis(1,1-dimethylethyl)-4-hydroxyphenyl]methyl]butylmalonate" "bis(1,2,2,6,6-pentamethylpiperidin-4-yl) 2-butyl-2-[(3,5-ditert-butyl-4-hydroxyphenyl)methyl]propanedioate" );
