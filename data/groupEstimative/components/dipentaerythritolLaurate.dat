/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipentaerythritol laurate  (C21H42O7, CAS 71010-53-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipentaerythritolLaurate;
formula     C21H42O7;
CAS         71010-53-2;
InChIKey    IWESMQHBWXNAIU-HXUWFJFHSA-N;
MW          406.56;      // g/mol [origin=calculated method=formula-sum]
Tc          1356.01;      // K   [origin=predictive method=joback]
Pc          11.329;      // bar [origin=predictive method=joback]
omega       0.6329;      // -   [origin=predictive method=lee-kesler]
Tb          1058.80;      // K   [origin=predictive method=joback]
HvapTb      123828.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (72.717 1.93142 -0.0008996 1.004e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH; count 2; } { group OH; count 3; } { group CH2COO; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group CH; count 2; } { group OH; count 3; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2r)-2-(hydroxymethyl)-3-[[2-(hydroxymethyl)-3-oxidanyl-propoxy]methoxy]propyl] dodecanoate" "dodecanoic acid, ester with 2,2'-(oxybis(methylene))bis(2-(hydroxymethyl)-1,3-propanediol)" "[(2r)-3-hydroxy-2-[[3-hydroxy-2-(hydroxymethyl)propoxy]methoxymethyl]propyl] dodecanoate" );
gibbsFormation
{
    dHf_298   -1525740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1181.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-809770.0
    phase     gas;
}
