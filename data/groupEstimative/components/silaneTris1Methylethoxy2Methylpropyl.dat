/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, tris(1-methylethoxy)(2-methylpropyl)-  (C13H30O3Si, CAS 118337-14-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H30O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneTris1Methylethoxy2Methylpropyl;
formula     C13H30O3Si;
CAS         118337-14-7;
InChIKey    VAHGFPQZZOPQLJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          262.465;      // g/mol [origin=calculated method=formula-sum]
Tc          740.39;      // K   [origin=predictive method=joback]
Pc          14.736;      // bar [origin=predictive method=joback]
omega       0.6183;      // -   [origin=predictive method=lee-kesler]
Tb          563.94;      // K   [origin=predictive method=joback]
HvapTb      50504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (101.661 0.86676 5.16e-05 -2.401e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 1; } { group CH; count 1; } { group CH-O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 1; } { group CH; count 4; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropyl-tri(propan-2-yloxy)silane" );
standardThermochemistry
{
    dHf_298   -841050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     784.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-370940.0
}
