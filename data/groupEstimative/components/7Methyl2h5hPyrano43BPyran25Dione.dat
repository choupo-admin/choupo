/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-methyl-2h,5h-pyrano-(4,3-b)pyran-2,5-dione  (C9H6O4, CAS 7316-90-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Methyl2h5hPyrano43BPyran25Dione;
formula     C9H6O4;
CAS         7316-90-7;
InChIKey    PHEAWXJSRBQCPL-UHFFFAOYSA-N;
MW          178.143;      // g/mol [origin=calculated method=formula-sum]
Tc          769.65;      // K   [origin=predictive method=joback]
Pc          35.305;      // bar [origin=predictive method=joback]
omega       0.7478;      // -   [origin=predictive method=lee-kesler]
Tb          557.20;      // K   [origin=predictive method=joback]
HvapTb      53748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.6 0.75752 -0.00058852 1.746e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group C=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methylpyrano[3,2-c]pyran-2,5-dione" "7-methyl-2h,5h-pyrano-[4,3-b]pyran-2,5-dione" );
gibbsFormation
{
    dHf_298   -538440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-397930.0
    phase     gas;
}
