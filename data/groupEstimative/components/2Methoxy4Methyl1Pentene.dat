/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-4-methyl-1-pentene  (C7H14O, CAS 53119-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy4Methyl1Pentene;
formula     C7H14O;
CAS         53119-71-4;
InChIKey    UMNBAOUYVWEPKA-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          553.47;      // K   [origin=predictive method=joback]
Pc          29.155;      // bar [origin=predictive method=joback]
omega       0.3459;      // -   [origin=predictive method=lee-kesler]
Tb          378.30;      // K   [origin=predictive method=joback]
HvapTb      32608.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.661 0.59146 -0.0002744 3.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-4-methyl-pent-1-ene" "2-methoxy-4-methylpent-1-ene" );
standardThermochemistry
{
    dHf_298   -209670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-20090.0
}
