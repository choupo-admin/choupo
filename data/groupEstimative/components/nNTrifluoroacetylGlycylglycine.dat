/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-[n-(trifluoroacetyl)glycylglycine  (C6H7F3N2O4, CAS 400-58-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNTrifluoroacetylGlycylglycine;
formula     C6H7F3N2O4;
CAS         400-58-8;
InChIKey    UWXMXPPHLZYYPM-UHFFFAOYSA-N;
MW          228.126;      // g/mol [origin=calculated method=formula-sum]
Tc          877.73;      // K   [origin=predictive method=joback]
Pc          35.899;      // bar [origin=predictive method=joback]
omega       1.4471;      // -   [origin=predictive method=lee-kesler]
Tb          685.05;      // K   [origin=predictive method=joback]
HvapTb      68731.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.132 0.8822 -0.000656 1.7982e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 1; } { group CF3; count 1; } { group CONHCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group F; count 3; } { group CdO; count 2; } { group COOH; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2,2,2-tris(fluoranyl)ethanoylamino]ethanoylamino]ethanoic acid" "n-(n-(trifluoroacetyl)glycylglycine" "2-[[2-[(2,2,2-trifluoroacetyl)amino]acetyl]amino]acetic acid" );
gibbsFormation
{
    dHf_298   -1232740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1004920.0
    phase     gas;
}
