/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylcarbamazine  (C10H21N3O, CAS 90-89-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylcarbamazine;
formula     C10H21N3O;
CAS         90-89-1;
InChIKey    RCKMWOKWVGPNJF-UHFFFAOYSA-N;
MW          199.298;      // g/mol [origin=calculated method=formula-sum]
Tc          721.49;      // K   [origin=predictive method=joback]
Pc          26.763;      // bar [origin=predictive method=joback]
omega       0.7764;      // -   [origin=predictive method=lee-kesler]
Tb          535.27;      // K   [origin=predictive method=joback]
HvapTb      51123.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.218 1.46536 -0.0010685 3.0856e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH3N; count 1; } { group CH2N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CdO; count 1; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-4-methyl-piperazine-1-carboxamide" "carbamazine" "hetrazan" "notezine" "cypip" "carbilazine" "banocide" "caricide" "ethodryl" "spatonin" "bitirazine" "caracide" );
gibbsFormation
{
    dHf_298   -72740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=293100.0
    phase     gas;
}
