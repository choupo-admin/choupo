/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylene-cyclopropanecarboxylic acid ethyl ester  (C7H10O2, CAS 18941-94-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethyleneCyclopropanecarboxylicAcidEthylEster;
formula     C7H10O2;
CAS         18941-94-1;
InChIKey    SPCOBAXZQGNBHE-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          612.74;      // K   [origin=predictive method=joback]
Pc          33.182;      // bar [origin=predictive method=joback]
omega       0.4544;      // -   [origin=predictive method=lee-kesler]
Tb          423.88;      // K   [origin=predictive method=joback]
HvapTb      38655.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.019 0.64742 -0.0003902 8.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-methylidenecyclopropane-1-carboxylate" "ethyl 2-methylenecyclopropanecarboxylate" "cyclopropanecarboxylic acid, methylene-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -348050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-188480.0
}
