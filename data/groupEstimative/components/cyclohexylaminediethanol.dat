/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexylaminediethanol  (C10H21NO2, CAS 4500-29-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylaminediethanol;
formula     C10H21NO2;
CAS         4500-29-2;
InChIKey    HHPDFYDITNAMAM-UHFFFAOYSA-N;
MW          187.283;      // g/mol [origin=calculated method=formula-sum]
Tc          821.81;      // K   [origin=predictive method=joback]
Pc          31.175;      // bar [origin=predictive method=joback]
omega       1.4092;      // -   [origin=predictive method=lee-kesler]
Tb          644.75;      // K   [origin=predictive method=joback]
HvapTb      73684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.916 1.2678 -0.0007746 1.744e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 1; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "abbomeen e-2 aerosol" "2-[cyclohexyl(2-hydroxyethyl)amino]ethanol" "cyclohexyldiethanolamine" "abbomeen e-2" "diethanolcyclohexylamine" "n-cyclohexyldiethanolamine" "n,n-di(2-hydroxyethyl)cyclohexylamine" "n,n-dihydroxyethylcyclohexylamine" "cyclohexylaminodiethanol" "cyclohexylbis(2-hydroxyethyl)amine" "ethanol, 2,2'-(cyclohexylimino)bis-" "n,n-bis(2-hydroxyethyl)cyclohexylamine" );
gibbsFormation
{
    dHf_298   -432340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105090.0
    phase     gas;
}
