/*--------------------------------*- Choupo -*-----------------------*\
  Component: 13-docosenenitrile, (13z)-  (C22H41N, CAS 73170-89-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Docosenenitrile13z;
formula     C22H41N;
CAS         73170-89-5;
InChIKey    WNVYKFYGFCBJSI-KTKRTIGZSA-N;
MW          319.577;      // g/mol [origin=calculated method=formula-sum]
Tc          994.08;      // K   [origin=predictive method=joback]
Pc          9.166;      // bar [origin=predictive method=joback]
omega       0.8516;      // -   [origin=predictive method=lee-kesler]
Tb          809.20;      // K   [origin=predictive method=joback]
HvapTb      75002.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.292 2.04862 -0.0012258 2.917e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CH=CH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group dCH; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-docos-13-enenitrile" );
gibbsFormation
{
    dHf_298   -215310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1012.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=347760.0
    phase     gas;
}
