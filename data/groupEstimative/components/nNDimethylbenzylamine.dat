/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylbenzylamine  (C9H13N, CAS 103-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylbenzylamine;
formula     C9H13N;
CAS         103-83-3;
InChIKey    XXBDWLFCJWSEKW-UHFFFAOYSA-N;
MW          135.21;      // g/mol [origin=calculated method=formula-sum]
Tc          649.21;      // K   [origin=predictive method=joback]
Pc          32.541;      // bar [origin=predictive method=joback]
omega       0.3987;      // -   [origin=predictive method=lee-kesler]
Tb          444.64;      // K   [origin=predictive method=joback]
HvapTb      39947.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.889 0.90384 -0.0006096 1.588e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-1-phenyl-methanamine" "n-benzyldimethylamine" "benzyldimethylamine" "dimethylbenzylamine" "benzenemethanamine, n,n-dimethyl-" "bdma" "n,n-dimethyl-1-phenylmethanamine" "benzylamine, n,n-dimethyl-" "benzyl-n,n-dimethylamine" "n,n-dimethyl-n-benzylamine" "n-(phenylmethyl)dimethylamine" "n,n-dimethylbenzenemethanamine" );
gibbsFormation
{
    dHf_298   74970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=248090.0
    phase     gas;
}
