/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-methoxy-2-(1-methylpropyl)-  (C11H16O, CAS 18272-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1Methoxy21Methylpropyl;
formula     C11H16O;
CAS         18272-71-4;
InChIKey    XGEOZYQKQHPUFZ-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          711.08;      // K   [origin=predictive method=joback]
Pc          25.846;      // bar [origin=predictive method=joback]
omega       0.4803;      // -   [origin=predictive method=lee-kesler]
Tb          504.92;      // K   [origin=predictive method=joback]
HvapTb      45040.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.899 0.85316 -0.00043096 6.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butan-2-yl-2-methoxy-benzene" "1-butan-2-yl-2-methoxybenzene" "1-(butan-2-yl)-2-methoxybenzene" );
standardThermochemistry
{
    dHf_298   -182810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37080.0
}
