/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-thiaproline  (C4H7NO2S, CAS 34592-47-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lThiaproline;
formula     C4H7NO2S;
CAS         34592-47-7;
InChIKey    DZLNHFMRPBPULJ-VKHMYHEASA-N;
MW          133.165;      // g/mol [origin=calculated method=formula-sum]
Tc          794.79;      // K   [origin=predictive method=joback]
Pc          57.917;      // bar [origin=predictive method=joback]
omega       0.6691;      // -   [origin=predictive method=lee-kesler]
Tb          548.29;      // K   [origin=predictive method=joback]
HvapTb      54489.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.89 0.56731 -0.0003519 7.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group COOH; count 1; } { group NH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r)-1,3-thiazolidine-4-carboxylic acid" "(r)-thiazolidine-4-carboxylic acid" "l-thioproline" "(r)-4-thiazolidinecarboxylic acid" "l-thiazolidine-4-carboxylic acid" "(4r)-4-thiazolidinecarboxylic acid" "(r)-(-)-4-thiazolidinecarboxylic acid" "thioproline" "l-4-thiazolidinecarboxylic acid" "thiazolidinecarboxylic acid" "l- thiazolidine-4-carboxylic acid" "4-thiazolidinecarboxylic acid, l-" );
gibbsFormation
{
    dHf_298   -332610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-196990.0
    phase     gas;
}
