/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperidine  (C5H11N, CAS 110-89-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperidine;
formula     C5H11N;
CAS         110-89-4;
InChIKey    NQRYJNQNLNOLGT-UHFFFAOYSA-N;
MW          85.15;      // g/mol [origin=calculated method=formula-sum]
Tc          603.55;      // K   [origin=predictive method=joback]
Pc          48.562;      // bar [origin=predictive method=joback]
omega       0.2711;      // -   [origin=predictive method=lee-kesler]
Tb          386.77;      // K   [origin=predictive method=joback]
HvapTb      34220.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.28 0.614 -0.000324 5.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexahydropyridine" "azacyclohexane" "cyclopentimine" "pentamethylenimine" "pentamethyleneimine" "cypentil" "perhydropyridine" "pyridine, hexahydro-" "azinane" "piperidin" "pentamethyleneamine" "piperidine solution" );
gibbsFormation
{
    dHf_298   -34060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=111090.0
    phase     gas;
}
