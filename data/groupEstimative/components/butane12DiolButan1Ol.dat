/*--------------------------------*- Choupo -*-----------------------*\
  Component: butane-1,2-diol;butan-1-ol  (C8H20O3, CAS 144437-84-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butane12DiolButan1Ol;
formula     C8H20O3;
CAS         144437-84-3;
InChIKey    LRKPGLNUNYIODV-UHFFFAOYSA-N;
MW          164.245;      // g/mol [origin=calculated method=formula-sum]
Tc          822.97;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       1.7094;      // -   [origin=predictive method=lee-kesler]
Tb          660.14;      // K   [origin=predictive method=joback]
HvapTb      83345.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.625 0.66554 -9.1e-05 -1.043e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "poly(1,2-butylene glycol) monobutyl ether" );
standardThermochemistry
{
    dHf_298   -782040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     718.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-501180.0
}
