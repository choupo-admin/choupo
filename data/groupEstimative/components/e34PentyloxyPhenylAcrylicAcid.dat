/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-3-(4-(pentyloxy)phenyl)acrylic acid  (C14H18O3, CAS 62718-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e34PentyloxyPhenylAcrylicAcid;
formula     C14H18O3;
CAS         62718-63-2;
InChIKey    WXPBGFBUVHLMSK-UHFFFAOYSA-N;
MW          234.295;      // g/mol [origin=calculated method=formula-sum]
Tc          936.39;      // K   [origin=predictive method=joback]
Pc          22.208;      // bar [origin=predictive method=joback]
omega       1.0079;      // -   [origin=predictive method=lee-kesler]
Tb          723.67;      // K   [origin=predictive method=joback]
HvapTb      69228.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.526 1.20302 -0.00074736 1.766e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-pentoxyphenyl)prop-2-enoic acid" "4-amyloxycinnamic acid" "(2z)-3-[4-(pentyloxy)phenyl]prop-2-enoic acid" "2-propenoic acid,3-[4-(pentyloxy)phenyl]-, (2e)-" "2-propenoicacid, 3-[4-(pentyloxy)phenyl]-, (e)-; 4-pentoxycinnamic acid" );
standardThermochemistry
{
    dHf_298   -472500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-198910.0
}
