/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylformamide dimethyl acetal  (C5H13NO2, CAS 4637-24-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylformamideDimethylAcetal;
formula     C5H13NO2;
CAS         4637-24-5;
InChIKey    ZSXGLVDWWRXATF-UHFFFAOYSA-N;
MW          119.164;      // g/mol [origin=calculated method=formula-sum]
Tc          539.18;      // K   [origin=predictive method=joback]
Pc          33.567;      // bar [origin=predictive method=joback]
omega       0.4309;      // -   [origin=predictive method=lee-kesler]
Tb          370.84;      // K   [origin=predictive method=joback]
HvapTb      33199.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.97 0.48228 -0.000142 -2.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH3O; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethoxy-n,n-dimethyl-methanamine" "1,1-dimethoxytrimethylamine" "1,1-dimethoxy-n,n-dimethylmethanamine" "methanamine, 1,1-dimethoxy-n,n-dimethyl-" "1,1-dimethoxy-n,n-dimethylmethanamin" "(dimethoxymethyl)dimethylamine" "dimethylformamide-dimethylacetal" "trimethylamine, 1,1-dimethoxy-" "1,1-dimethoxy-n,n-dimethylmethylamine" "dimethylformamide dimethyl acetal" "dmfdma, redistilled" "n,n-dimethylformamidedimethylacetal" );
gibbsFormation
{
    dHf_298   -348720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-110440.0
    phase     gas;
}
