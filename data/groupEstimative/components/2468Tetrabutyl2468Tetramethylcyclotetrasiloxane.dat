  Component: 2,4,6,8-tetrabutyl-2,4,6,8-tetramethylcyclotetrasiloxane  (C20H48O4Si4, CAS 14685-29-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C20H48O4Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2468Tetrabutyl2468Tetramethylcyclotetrasiloxane;
formula     C20H48O4Si4;
CAS         14685-29-1;
InChIKey    WRMMUMWFPNLNGA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          464.94;      // g/mol [origin=calculated method=formula-sum]
Tc          975.47;      // K   [origin=predictive method=joback]
Pc          8.324;      // bar [origin=predictive method=joback]
omega       0.6694;      // -   [origin=predictive method=lee-kesler]
Tb          786.28;      // K   [origin=predictive method=joback]
HvapTb      79724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (155.962 1.23496 0.0004214 -5.792e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 12; } { group SiO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 12; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6,8-tetrabutyl-2,4,6,8-tetramethyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" "cyclotetrasiloxane, 2,4,6,8-tetrabutyl-2,4,6,8-tetramethyl-" "cyclotetrasiloxane,2,4,6,8-tetrabutyl-2,4,6,8-tetramethyl-" );
gibbsFormation
{
    dHf_298   -1343630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1207.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-589640.0
    phase     gas;
}
