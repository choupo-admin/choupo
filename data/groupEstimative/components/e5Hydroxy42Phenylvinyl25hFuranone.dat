/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-5-hydroxy-4-(2-phenylvinyl)-2(5h)-furanone  (C12H10O3, CAS 91269-98-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e5Hydroxy42Phenylvinyl25hFuranone;
formula     C12H10O3;
CAS         91269-98-6;
InChIKey    BRSGPHVHVGTCQM-UHFFFAOYSA-N;
MW          202.209;      // g/mol [origin=calculated method=formula-sum]
Tc          880.13;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       1.0679;      // -   [origin=predictive method=lee-kesler]
Tb          666.28;      // K   [origin=predictive method=joback]
HvapTb      69493.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.57 1.0995 -0.00082024 2.358e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanyl-3-(2-phenylethenyl)-2h-furan-5-one" );
gibbsFormation
{
    dHf_298   -287660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-123320.0
    phase     gas;
}
