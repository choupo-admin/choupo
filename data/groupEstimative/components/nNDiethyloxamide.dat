/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-diethyloxamide  (C6H12N2O2, CAS 615-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethyloxamide;
formula     C6H12N2O2;
CAS         615-84-9;
InChIKey    FFYAVOJIYAAUNX-UHFFFAOYSA-N;
MW          144.174;      // g/mol [origin=calculated method=formula-sum]
Tc          738.86;      // K   [origin=predictive method=joback]
Pc          37.090;      // bar [origin=predictive method=joback]
omega       0.9105;      // -   [origin=predictive method=lee-kesler]
Tb          544.96;      // K   [origin=predictive method=joback]
HvapTb      55314.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.732 0.67024 -0.0003624 6.312e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CONHCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CdO; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-diethylethanediamide" "nn'-diethyloxamide" "ethanediamide, n,n'-diethyl-" "n-ethyl-n'-ethylethane-1,2-diamide" );
standardThermochemistry
{
    dHf_298   -285390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-79420.0
}
