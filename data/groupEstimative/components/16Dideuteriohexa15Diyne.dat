/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-dideuteriohexa-1,5-diyne  (C6H4D2, CAS 73385-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H4D2 (delta D+2H-2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        16Dideuteriohexa15Diyne;
formula     C6H4D2;
CAS         73385-31-6;
InChIKey    YFIBSNDOVCWPBL-QDNHWIQGSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          80.126;      // g/mol [origin=calculated method=formula-sum]
Tc          505.52;      // K   [origin=predictive method=joback]
Pc          44.563;      // bar [origin=predictive method=joback]
omega       0.1752;      // -   [origin=predictive method=lee-kesler]
Tb          317.12;      // K   [origin=predictive method=joback]
HvapTb      28666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.992 0.386 -0.00029446 9.698e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group tCH; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-hexadiyne-1,6-d2" "1,5-hexadiyne-1,6-d2(9ci)" );
standardThermochemistry
{
    dHf_298   416630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     328.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=445780.0
}
