/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxyphenylacetic acid  (C8H8O3, CAS 621-37-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3HydroxyphenylaceticAcid;
formula     C8H8O3;
CAS         621-37-4;
InChIKey    FVMDYYGIDFPZAX-UHFFFAOYSA-N;
MW          152.149;      // g/mol [origin=calculated method=formula-sum]
Tc          873.66;      // K   [origin=predictive method=joback]
Pc          49.804;      // bar [origin=predictive method=joback]
omega       0.9555;      // -   [origin=predictive method=lee-kesler]
Tb          635.45;      // K   [origin=predictive method=joback]
HvapTb      65856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.609 0.8903 -0.00077156 2.706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-hydroxyphenyl)ethanoic acid" "3-hydroxyphenylacetate" "(3-hydroxyphenyl)acetic acid" "3-hydroxybenzeneacetic acid" "m-hydroxyphenylacetic acid" "(m-hydroxyphenyl)acetic acid" "2-(3-hydroxyphenyl)acetic acid" "metahydroxy phenylacetic acid" "benzeneacetic acid, 3-hydroxy-" "acetic acid, (m-hydroxyphenyl)-" "(3-hydroxy-phenyl)-acetic acid" "3-hydroxyphenylaceticacid" );
gibbsFormation
{
    dHf_298   -499500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-369640.0
    phase     gas;
}
