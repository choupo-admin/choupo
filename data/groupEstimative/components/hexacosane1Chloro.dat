/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexacosane, 1-chloro-  (C26H53Cl, CAS 56134-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexacosane1Chloro;
formula     C26H53Cl;
CAS         56134-53-3;
InChIKey    OMQRHANPZIOLFM-UHFFFAOYSA-N;
MW          401.16;      // g/mol [origin=calculated method=formula-sum]
Tc          1018.76;      // K   [origin=predictive method=joback]
Pc          7.107;      // bar [origin=predictive method=joback]
omega       0.6550;      // -   [origin=predictive method=lee-kesler]
Tb          831.91;      // K   [origin=predictive method=joback]
HvapTb      77855.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.855 2.48062 -0.001411 3.072e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 24; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 25; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylhexacosane" );
gibbsFormation
{
    dHf_298   -595710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1202.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=156110.0
    phase     gas;
}
