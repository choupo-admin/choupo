/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4-trimethyl-2-pentene  (C8H16, CAS 565-77-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        234Trimethyl2Pentene;
formula     C8H16;
CAS         565-77-5;
InChIKey    SZFRZEBLZFTODC-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          569.27;      // K   [origin=predictive method=joback]
Pc          27.240;      // bar [origin=predictive method=joback]
omega       0.2869;      // -   [origin=predictive method=lee-kesler]
Tb          386.12;      // K   [origin=predictive method=joback]
HvapTb      33132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.63 0.7896 -0.000503 1.345e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4-trimethylpent-2-ene" "2-pentene, 2,3,4-trimethyl-" "2,4-trimethyl-2-pentene" "2-pentene,3,4-trimethyl-" "2-pentene,2,3,4-trimethyl-" );
gibbsFormation
{
    dHf_298   -116090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77160.0
    phase     gas;
}
