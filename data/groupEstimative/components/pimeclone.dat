/*--------------------------------*- Choupo -*-----------------------*\
  Component: pimeclone  (C12H21NO, CAS 534-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pimeclone;
formula     C12H21NO;
CAS         534-84-9;
InChIKey    PRFPQYGTPKDLHJ-UHFFFAOYSA-N;
MW          195.306;      // g/mol [origin=calculated method=formula-sum]
Tc          828.47;      // K   [origin=predictive method=joback]
Pc          27.155;      // bar [origin=predictive method=joback]
omega       0.5572;      // -   [origin=predictive method=lee-kesler]
Tb          593.92;      // K   [origin=predictive method=joback]
HvapTb      49591.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.309 1.3797 -0.0007614 1.333e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 1; } { group CH2CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(piperidin-1-ylmethyl)cyclohexan-1-one" "2-(1-piperidinylmethyl)cyclohexanone" "2-(piperidin-1-ylmethyl)cyclohexanone" "na-66" "2-(piperidylmethyl)cyclohexan-1-one" "cyclohexanone, 2-(1-piperidinylmethyl)-" "2-(1-piperidinylmethyl)-cyclohexanone" );
gibbsFormation
{
    dHf_298   -226040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107060.0
    phase     gas;
}
