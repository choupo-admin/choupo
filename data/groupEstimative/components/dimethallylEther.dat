/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethallyl ether  (C8H14O, CAS 628-56-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethallylEther;
formula     C8H14O;
CAS         628-56-8;
InChIKey    XMHDLKFMJMNOAX-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          575.65;      // K   [origin=predictive method=joback]
Pc          27.440;      // bar [origin=predictive method=joback]
omega       0.3752;      // -   [origin=predictive method=lee-kesler]
Tb          398.18;      // K   [origin=predictive method=joback]
HvapTb      34632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.752 0.66044 -0.0003508 6.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2=C; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 2; } { group dC; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-3-(2-methylprop-2-enoxy)prop-1-ene" "2-methyl-3-[(2-methyl-2-propenyl)oxy]-1-propene" "1-propene,2-methyl-3-[(2-methyl-2-propen-1-yl)oxy]-" "2-methyl-3-[(2-methylprop-2-en-1-yl)oxy]prop-1-ene" "1-propene,3,3'-oxybis[2-methyl- (9ci); ether, bis(2-methylallyl) (6ci,7ci,8ci);bis(2-methyl-2-propen-1-yl) ether; bis(2-methyl-2-propenyl) ether;bis(2-methylallyl) ether; bismethallyl ether; dimethallyl ether" );
gibbsFormation
{
    dHf_298   -109390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70060.0
    phase     gas;
}
