/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl fumarate  (C8H12O4, CAS 623-91-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylFumarate;
formula     C8H12O4;
CAS         623-91-6;
InChIKey    IEPRKVQEAMIZSS-AATRIKPKSA-N;
MW          172.18;      // g/mol [origin=calculated method=formula-sum]
Tc          689.30;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       0.6684;      // -   [origin=predictive method=lee-kesler]
Tb          503.24;      // K   [origin=predictive method=joback]
HvapTb      48174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.252 0.67424 -0.000306 1.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl (e)-but-2-enedioate" "fumaric acid, diethyl ester" "anti-psoriaticum" "diethyl (2e)-but-2-enedioate" "2-butenedioic acid (e)-, diethyl ester" "fumaric acid diethyl ester" "trans-2-butenedioic acid diethyl ester" "2-butenedioic acid (2e)-, diethyl ester" "2-butenedioic acid(e)-,diethyl ester" "(e)-but-2-enedioic acid diethyl ester" "2-butenedioic acid, diethyl ester, (e)-" "2-butenedioic acid (2e)-, 1,4-diethyl ester" );
gibbsFormation
{
    dHf_298   -725790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-524040.0
    phase     gas;
}
