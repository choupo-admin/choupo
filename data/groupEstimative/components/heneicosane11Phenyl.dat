/*--------------------------------*- Choupo -*-----------------------*\
  Component: heneicosane, 11-phenyl-  (C27H48, CAS 40775-09-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heneicosane11Phenyl;
formula     C27H48;
CAS         40775-09-5;
InChIKey    NDSAOEARRHEOPX-UHFFFAOYSA-N;
MW          372.681;      // g/mol [origin=calculated method=formula-sum]
Tc          1035.08;      // K   [origin=predictive method=joback]
Pc          8.300;      // bar [origin=predictive method=joback]
omega       0.7756;      // -   [origin=predictive method=lee-kesler]
Tb          843.60;      // K   [origin=predictive method=joback]
HvapTb      77584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.242 2.49584 -0.0014794 3.351e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 18; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "henicosan-11-ylbenzene" "benzene, (1-decylundecyl)-" "11-phenylheneicosane" );
standardThermochemistry
{
    dHf_298   -369360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1091.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=286430.0
}
