/*--------------------------------*- Choupo -*-----------------------*\
  Component: thieno[3,4-d]thiepin, hexahydro-  (C8H12S2, CAS 92224-19-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thieno34DThiepinHexahydro;
formula     C8H12S2;
CAS         92224-19-6;
InChIKey    YYADWRUXGLTHDP-UHFFFAOYSA-N;
MW          172.304;      // g/mol [origin=calculated method=formula-sum]
Tc          771.50;      // K   [origin=predictive method=joback]
Pc          38.965;      // bar [origin=predictive method=joback]
omega       0.2994;      // -   [origin=predictive method=lee-kesler]
Tb          508.02;      // K   [origin=predictive method=joback]
HvapTb      45832.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.93 1.00002 -0.00069088 1.848e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,3a,7,8,8a-hexahydrothieno[3,4-d]thiepine" "thieno(3,4-d)thiepin, hexahydro-" );
gibbsFormation
{
    dHf_298   60810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=199260.0
    phase     gas;
}
