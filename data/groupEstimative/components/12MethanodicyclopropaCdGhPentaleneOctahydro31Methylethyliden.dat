/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-methanodicyclopropa(cd,gh)pentalene, octahydro-3-(1-methylethylidene)-  (C12H14, CAS 65915-87-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12MethanodicyclopropaCdGhPentaleneOctahydro31Methylethyliden;
formula     C12H14;
CAS         65915-87-9;
InChIKey    TWFAFTMHAQJXQN-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          671.08;      // K   [origin=predictive method=joback]
Pc          26.708;      // bar [origin=predictive method=joback]
omega       0.4753;      // -   [origin=predictive method=lee-kesler]
Tb          474.75;      // K   [origin=predictive method=joback]
HvapTb      40779.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-199.28 1.79884 -0.001813 7.256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 8; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH_ring; count 8; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   115170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     -106.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=440290.0
    phase     gas;
}
