/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(octylthio)ethanol  (C10H22OS, CAS 3547-33-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OctylthioEthanol;
formula     C10H22OS;
CAS         3547-33-9;
InChIKey    KXPXKNBDCUOENF-UHFFFAOYSA-N;
MW          190.345;      // g/mol [origin=calculated method=formula-sum]
Tc          763.68;      // K   [origin=predictive method=joback]
Pc          23.360;      // bar [origin=predictive method=joback]
omega       1.0282;      // -   [origin=predictive method=lee-kesler]
Tb          589.36;      // K   [origin=predictive method=joback]
HvapTb      61350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.689 0.98221 -0.0005104 9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group OH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group OH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-octylsulfanylethanol" "ethanol, 2-(octylthio)-" "2-hydroxyethyl octyl sulfide" "r-874 phillips" "2-hydroxyethyl n-octyl sulfide" "2-hydroxyethyl-n-octyl sulfide" "2-octylthioethan-1-ol" "2-(oktylthio)ethanol" "2-(octylsulfanyl)ethanol" "2-hydroxyethyl octyl sulphide" "2-(hydroxyethyl)n-octyl sulfide" "t34" );
standardThermochemistry
{
    dHf_298   -360090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     657.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-70380.0
}
