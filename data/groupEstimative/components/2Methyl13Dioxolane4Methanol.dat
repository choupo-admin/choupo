/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1,3-dioxolane-4-methanol  (C5H10O3, CAS 3773-93-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl13Dioxolane4Methanol;
formula     C5H10O3;
CAS         3773-93-1;
InChIKey    ZCYJBTKNPHKPPN-UHFFFAOYSA-N;
MW          118.132;      // g/mol [origin=calculated method=formula-sum]
Tc          659.68;      // K   [origin=predictive method=joback]
Pc          45.839;      // bar [origin=predictive method=joback]
omega       0.7758;      // -   [origin=predictive method=lee-kesler]
Tb          470.69;      // K   [origin=predictive method=joback]
HvapTb      52371.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.269 0.61202 -0.0003228 5.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-1,3-dioxolan-4-yl)methanol" "1,3-dioxolane-4-methanol, 2-methyl-" "agn-pc-01zaym" );
gibbsFormation
{
    dHf_298   -522620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     206.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-289000.0
    phase     gas;
}
