/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl isocyanate  (C2H3NO, CAS 624-83-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylIsocyanate;
formula     C2H3NO;
CAS         624-83-9;
InChIKey    HAMGRBXTJNITHG-UHFFFAOYSA-N;
MW          57.052;      // g/mol [origin=calculated method=formula-sum]
Tc          491.13;      // K   [origin=predictive method=joback]
Pc          56.026;      // bar [origin=predictive method=joback]
omega       0.2847;      // -   [origin=predictive method=lee-kesler]
Tb          312.03;      // K   [origin=predictive method=joback]
HvapTb      29578.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group dCd; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylimino(oxidanylidene)methane" "methane, isocyanato-" "isocyanatomethane" "methyl carbonimide" "methylcarbylamine" "iso-cyanatomethane" "isocyanate de methyle" "methylisocyanate" "isocyanic acid, methyl ester" "(methylimino)(oxo)methane" "methylisocyanaat" "methyl isocyanat" );
