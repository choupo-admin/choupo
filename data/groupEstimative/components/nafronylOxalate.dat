/*--------------------------------*- Choupo -*-----------------------*\
  Component: nafronyl oxalate  (C26H35NO7, CAS 3200-06-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nafronylOxalate;
formula     C26H35NO7;
CAS         3200-06-4;
InChIKey    SSAJNPNVUYMUCI-UHFFFAOYSA-N;
MW          473.566;      // g/mol [origin=calculated method=formula-sum]
Tc          1535.23;      // K   [origin=predictive method=joback]
Pc          12.048;      // bar [origin=predictive method=joback]
omega       1.0983;      // -   [origin=predictive method=lee-kesler]
Tb          1249.99;      // K   [origin=predictive method=joback]
HvapTb      126499.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.904 2.43084 -0.00135658 2.293e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 2; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } { group COOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group O_ring; count 1; } { group COOH; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethyl 2-(naphthalen-1-ylmethyl)-3-(oxolan-2-yl)propanoate;ethanedioic acid" "naftidrofuryl oxalate" "2-(diethylamino)ethyl 3-(naphthalen-1-yl)-2-((tetrahydrofuran-2-yl)methyl)propanoate oxalate" "dubimax" "dusodril" "praxilene" "iridus" "nafronyl oxalate (usan)" "alpha-[1-naphthylmethyl]-2-tetrahydrofuranpropionic acid diethylaminoethyl ester" "clarantin" "praxilene (tn)" "prestwick_696" );
standardThermochemistry
{
    dHf_298   -1302550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1117.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-666710.0
}
