/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxy-3-methyl-2-butanone  (C5H10O2, CAS 115-22-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hydroxy3Methyl2Butanone;
formula     C5H10O2;
CAS         115-22-0;
InChIKey    BNDRWEVUODOUDW-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          640.24;      // K   [origin=predictive method=joback]
Pc          43.056;      // bar [origin=predictive method=joback]
omega       0.7464;      // -   [origin=predictive method=lee-kesler]
Tb          456.82;      // K   [origin=predictive method=joback]
HvapTb      48853.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.48 0.61066 -0.0004317 1.2096e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group OH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-3-oxidanyl-butan-2-one" "3-methylacetoin" "3-hydroxy-3-methylbutan-2-one" "methylacetoin" "2-butanone, 3-hydroxy-3-methyl-" "dimethylacetylcarbinol" "2-hydroxy-2-methyl-3-butanone" "2-methyl-2-hydroxybutan-3-one" "1-hydroxy-1-methylethyl methyl ketone" "3-hydroxy-3-ethylbutanone" );
standardThermochemistry
{
    dHf_298   -420090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-271680.0
}
