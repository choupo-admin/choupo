/*--------------------------------*- Choupo -*-----------------------*\
  Component: (-)-lupinine  (C10H19NO, CAS 486-70-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lupinine;
formula     C10H19NO;
CAS         486-70-4;
InChIKey    HDVAWXXJVMJBAR-VHSXEESVSA-N;
MW          169.268;      // g/mol [origin=calculated method=formula-sum]
Tc          756.43;      // K   [origin=predictive method=joback]
Pc          32.541;      // bar [origin=predictive method=joback]
omega       0.8588;      // -   [origin=predictive method=lee-kesler]
Tb          559.31;      // K   [origin=predictive method=joback]
HvapTb      56918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.449 1.3847 -0.0009644 2.639e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 2; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1r,9ar)-2,3,4,6,7,8,9,9a-octahydro-1h-quinolizin-1-yl]methanol" "lupinine" "octahydroquinolizine-1-methanol" "((1r,9ar)-octahydro-1h-quinolizin-1-yl)methanol" "(1r-trans)-octahydro-2h-quinolizine-1-methanol" "(1r,9ar)-octahydro-2h-quinolizin-1-ylmethanol" "((1r,2r)-6-azabicyclo[4.4.0]dec-2-yl)methan-1-ol" "(+/-)-lupinine" "lupinine dl-form [mi]" "lupinine, (+/-)-" "2h-quinolizine-1-methanol, octahydro-, (1r-trans)-" "sdccgmls-0066745.p001" );
gibbsFormation
{
    dHf_298   -207310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=92480.0
    phase     gas;
}
