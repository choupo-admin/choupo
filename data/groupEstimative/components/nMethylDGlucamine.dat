/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyl-d-glucamine  (C7H17NO5, CAS 6284-40-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylDGlucamine;
formula     C7H17NO5;
CAS         6284-40-8;
InChIKey    MBBZMMPHUWSWHV-BDVNFPICSA-N;
MW          195.215;      // g/mol [origin=calculated method=formula-sum]
Tc          1065.58;      // K   [origin=predictive method=joback]
Pc          52.132;      // bar [origin=predictive method=joback]
omega       2.4408;      // -   [origin=predictive method=lee-kesler]
Tb          869.07;      // K   [origin=predictive method=joback]
HvapTb      119455.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.042 0.93862 -0.0005704 1.296e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group OH; count 5; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 4; } { group OH; count 5; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3r,4r,5s)-6-(methylamino)hexane-1,2,3,4,5-pentol" "meglumine" "n-methylglucamine" "meglumin" "1-deoxy-1-methylaminosorbitol" "megluminum" "methylglucamin" "meglumina" "n-methyl-d(-)-glucamine" "1-deoxy-1-(methylamino)-d-glucitol" "glucantime" "n-methylsorbitylamine" );
gibbsFormation
{
    dHf_298   -916610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     685.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-596410.0
    phase     gas;
}
