/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-tribromoanisole  (C7H5Br3O, CAS 607-99-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Tribromoanisole;
formula     C7H5Br3O;
CAS         607-99-8;
InChIKey    YXTRCOAFNXQTKL-UHFFFAOYSA-N;
MW          344.828;      // g/mol [origin=calculated method=formula-sum]
Tc          885.81;      // K   [origin=predictive method=joback]
Pc          50.015;      // bar [origin=predictive method=joback]
omega       0.7152;      // -   [origin=predictive method=lee-kesler]
Tb          622.28;      // K   [origin=predictive method=joback]
HvapTb      57153.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.59 0.46282 -0.00029028 7.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-tris(bromanyl)-2-methoxy-benzene" "1,3,5-tribromo-2-methoxybenzene" "anisole, 2,4,6-tribromo-" "benzene, 1,3,5-tribromo-2-methoxy-" "2,4,6-tribromo-1-methoxybenzene" "2,6-tribromoanisole" "anisole,4,6-tribromo-" "methyl 2,6-tribromophenyl ether" "yxtrcoafnxqtkl-uhfffaoysa-" "benzene,3,5-tribromo-2-methoxy-" "methyl 2,4,6-tribromophenyl ether" "benzene,1,3,5-tribromo-2-methoxy-" );
gibbsFormation
{
    dHf_298   -38920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29540.0
    phase     gas;
}
