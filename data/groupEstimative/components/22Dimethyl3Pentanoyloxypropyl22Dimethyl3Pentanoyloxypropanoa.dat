/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,2-dimethyl-3-pentanoyloxypropyl) 2,2-dimethyl-3-pentanoyloxypropanoate  (C20H36O6, CAS 71850-74-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl3Pentanoyloxypropyl22Dimethyl3Pentanoyloxypropanoa;
formula     C20H36O6;
CAS         71850-74-3;
InChIKey    WIAWMBFCOXRNOS-UHFFFAOYSA-N;
MW          372.502;      // g/mol [origin=calculated method=formula-sum]
Tc          1016.64;      // K   [origin=predictive method=joback]
Pc          10.507;      // bar [origin=predictive method=joback]
omega       0.9438;      // -   [origin=predictive method=lee-kesler]
Tb          825.40;      // K   [origin=predictive method=joback]
HvapTb      79743.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.989 1.99112 -0.001124 1.993e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 7; } { group C; count 2; } { group CH2COO; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 9; } { group C; count 2; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,2-dimethyl-3-pentanoyloxy-propyl) 2,2-dimethyl-3-pentanoyloxy-propanoate" "pentanoic acid, 3-(2,2-dimethyl-1-oxo-3-((1-oxopentyl)oxy)propoxy)-2,2-dimethylpropyl ester" "pentanoic acid 3-[2,2-dimethyl-1-oxo-3-[(1-oxopentyl)oxy]propoxy]-2,2-dimethylpropyl ester" "pentanoic acid, 3-[2,2-dimethyl-1-oxo-3-[(1-oxopentyl)oxy]propoxy]-2,2-dimethylpropyl ester" "pentanoic acid,3-[2,2-dimethyl-1-oxo-3-[(1-oxopentyl)oxy]propoxy]-2,2-dimethylpropyl ester" );
standardThermochemistry
{
    dHf_298   -1425470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1011.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-807910.0
}
