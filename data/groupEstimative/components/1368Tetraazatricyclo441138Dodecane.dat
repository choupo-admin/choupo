  Component: 1,3,6,8-tetraazatricyclo(4.4.1.1(3,8))dodecane  (C8H16N4, CAS 51-46-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1368Tetraazatricyclo441138Dodecane;
formula     C8H16N4;
CAS         51-46-7;
InChIKey    YHNNUDUEGSHVGJ-UHFFFAOYSA-N;
MW          168.244;      // g/mol [origin=calculated method=formula-sum]
Tc          656.16;      // K   [origin=predictive method=joback]
Pc          42.719;      // bar [origin=predictive method=joback]
omega       0.6640;      // -   [origin=predictive method=lee-kesler]
Tb          462.36;      // K   [origin=predictive method=joback]
HvapTb      42068.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-210.57 1.8012 -0.001735 6.46e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2N; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group N; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,6,8-tetraazatricyclo[4.4.1.13,8]dodecane" "1,3,6,8-tetraazatricyclo(4.4.1.1(sup 3,8))dodecane" "1,3,6,8-tetraazatricyclo(4.4.1.13,8)dodecane" "1,4,6,9-tetrazatricyclo(4.4.1.1.4,9)dodecane" "1,4,6,9-tetraaza-tricyclo-(4.4.1.1(sup 9,4))dodecan [german]" "1,3,6,8-tetraazatricyclo[4.4.1.1(3,8)]dodecane" "dezant" "1,6,8-tetraazatricyclo[4.4.1.13,8]dodecane" "1,6,9-tetrazatricyclo[4.4.1.1.4,9]dodecane" "1,4,6,9-tetraazatricyclo-(4.4.1.19,4)dodecan" "1,6,8-tetraazatricyclo(4.4.1.1(3,8))dodecane" "1,3,6,8-tetraazatricyclo[4.4.1.1<3,8>]dodecane" );
standardThermochemistry
{
    dHf_298   347250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=677080.0
}
