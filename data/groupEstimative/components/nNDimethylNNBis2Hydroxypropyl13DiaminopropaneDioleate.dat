/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-n',n'-bis(2-hydroxypropyl)-1,3-diaminopropane dioleate  (C29H60N2O4, CAS 72018-19-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylNNBis2Hydroxypropyl13DiaminopropaneDioleate;
formula     C29H60N2O4;
CAS         72018-19-0;
InChIKey    GJTVOKRWPCVEEN-KVVVOXFISA-N;
MW          500.809;      // g/mol [origin=calculated method=formula-sum]
Tc          1639.63;      // K   [origin=predictive method=joback]
Pc          7.100;      // bar [origin=predictive method=joback]
omega       0.0597;      // -   [origin=predictive method=lee-kesler]
Tb          1222.55;      // K   [origin=predictive method=joback]
HvapTb      134232.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.401 2.9511 -0.0015878 2.855e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 18; } { group CH; count 2; } { group CH=CH; count 1; } { group OH; count 2; } { group CH3N; count 1; } { group CH2N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 19; } { group CH; count 2; } { group dCH; count 2; } { group OH; count 2; } { group COOH; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[3-(dimethylamino)propyl-(2-oxidanylpropyl)amino]propan-2-ol;(z)-octadec-9-enoic acid" "n,n-dimethyl-n',n'-bis(2-hydroxypropyl)-1,3-diaminopropane monooleate" "9-octadecenoic acid (9z)-, compd. with 1,1'-((3-(dimethylamino)propyl)imino)bis(2-propanol) (1:1)" "9-octadecenoic acid (9z)-, compd. with 1,1'-((3-(dimethylamino)propyl)imino)bis(2-propanol) (2:1)" );
standardThermochemistry
{
    dHf_298   -1166520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1554.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-232110.0
}
