/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-bis(dichloromethyl)benzene  (C8H6Cl4, CAS 77251-47-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BisDichloromethylBenzene;
formula     C8H6Cl4;
CAS         77251-47-9;
InChIKey    VOWDXSFJQOEFSH-UHFFFAOYSA-N;
MW          243.936;      // g/mol [origin=calculated method=formula-sum]
Tc          808.08;      // K   [origin=predictive method=joback]
Pc          30.796;      // bar [origin=predictive method=joback]
omega       0.4599;      // -   [origin=predictive method=lee-kesler]
Tb          563.14;      // K   [origin=predictive method=joback]
HvapTb      53104.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.21 0.6644 -0.00046356 1.196e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CHCl2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis[bis(chloranyl)methyl]benzene" "benzene, 1,4-bis(dichloromethyl)-" "1,4-di(dichloromethyl)benzene" "u190" "alpha,alpha,alpha',alpha'-tetrachloro-p-xylene" );
gibbsFormation
{
    dHf_298   -56910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66660.0
    phase     gas;
}
