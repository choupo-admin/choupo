/*--------------------------------*- Choupo -*-----------------------*\
  Component: trihexyl 2-hydroxypropane-1,2,3-tricarboxylate  (C24H44O7, CAS 16544-70-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trihexyl2Hydroxypropane123Tricarboxylate;
formula     C24H44O7;
CAS         16544-70-0;
InChIKey    AMMPRZCMKXDUNE-UHFFFAOYSA-N;
MW          444.609;      // g/mol [origin=calculated method=formula-sum]
Tc          1256.73;      // K   [origin=predictive method=joback]
Pc          8.671;      // bar [origin=predictive method=joback]
omega       0.6977;      // -   [origin=predictive method=lee-kesler]
Tb          1012.33;      // K   [origin=predictive method=joback]
HvapTb      106622.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.117 2.27926 -0.0012002 1.848e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 15; } { group C; count 1; } { group OH; count 1; } { group CH2COO; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 17; } { group C; count 1; } { group OH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trihexyl 2-oxidanylpropane-1,2,3-tricarboxylate" "1,2,3-propanetricarboxylicacid, 2-hydroxy-, 1,2,3-trihexyl ester" "1,2,3-propanetricarboxylicacid, 2-hydroxy-, trihexyl ester (9ci); citric acid, trihexyl ester (6ci,7ci,8ci);linplast 6ct; trihexyl citrate" );
gibbsFormation
{
    dHf_298   -1651510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1256.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-913890.0
    phase     gas;
}
