/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylbenzyl isocyanate  (C9H9NO, CAS 56651-57-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethylbenzylIsocyanate;
formula     C9H9NO;
CAS         56651-57-1;
InChIKey    KNYDWDHLGFMGCO-UHFFFAOYSA-N;
MW          147.177;      // g/mol [origin=calculated method=formula-sum]
Tc          722.58;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.5168;      // -   [origin=predictive method=lee-kesler]
Tb          503.85;      // K   [origin=predictive method=joback]
HvapTb      48098.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(isocyanatomethyl)-4-methyl-benzene" "1-(isocyanatomethyl)-4-methylbenzene" "(4-methylphenyl)methanisocyanate" "benzene, 1-isocyanatomethyl-4-methyl-" "benzene,1-(isocyanatomethyl)-4-methyl-" "1-(isocyanatomethyl)-4-methylbenzene;4-methylbenzyl isocyanide;4-methylbenzylisocyanate;p-methylbenzyl isocyanate;" );
