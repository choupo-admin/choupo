/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromocyclooctane  (C8H15Br, CAS 1556-09-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromocyclooctane;
formula     C8H15Br;
CAS         1556-09-8;
InChIKey    KFKLBMQLKLKHLU-UHFFFAOYSA-N;
MW          191.112;      // g/mol [origin=calculated method=formula-sum]
Tc          714.94;      // K   [origin=predictive method=joback]
Pc          36.202;      // bar [origin=predictive method=joback]
omega       0.3246;      // -   [origin=predictive method=lee-kesler]
Tb          476.89;      // K   [origin=predictive method=joback]
HvapTb      40610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.04 0.9049 -0.000471 6.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromanylcyclooctane" "cyclooctyl bromide" "cyclooctane, bromo-" "kfklbmqlklkhlu-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -140120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31050.0
}
