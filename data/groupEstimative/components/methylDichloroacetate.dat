/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl dichloroacetate  (C3H4Cl2O2, CAS 116-54-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylDichloroacetate;
formula     C3H4Cl2O2;
CAS         116-54-1;
InChIKey    HKMLRUAPIDAGIE-UHFFFAOYSA-N;
MW          142.963;      // g/mol [origin=calculated method=formula-sum]
Tc          598.16;      // K   [origin=predictive method=joback]
Pc          40.725;      // bar [origin=predictive method=joback]
omega       0.3873;      // -   [origin=predictive method=lee-kesler]
Tb          400.88;      // K   [origin=predictive method=joback]
HvapTb      38061.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.67 0.25352 -8.88e-05 -1.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CHCl2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,2-bis(chloranyl)ethanoate" "dichloroacetic acid methyl ester" "methyl 2,2-dichloroacetate" "acetic acid, dichloro-, methyl ester" "acetic acid, 2,2-dichloro-, methyl ester" "n716" );
gibbsFormation
{
    dHf_298   -459290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-362290.0
    phase     gas;
}
