/*--------------------------------*- Choupo -*-----------------------*\
  Component: tridecenal  (C13H24O, CAS 7774-82-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tridecenal;
formula     C13H24O;
CAS         7774-82-5;
InChIKey    VMUNAKQXJLHODT-UHFFFAOYSA-N;
MW          196.334;      // g/mol [origin=calculated method=formula-sum]
Tc          721.82;      // K   [origin=predictive method=joback]
Pc          18.263;      // bar [origin=predictive method=joback]
omega       0.7541;      // -   [origin=predictive method=lee-kesler]
Tb          549.86;      // K   [origin=predictive method=joback]
HvapTb      51210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.711 1.23332 -0.0007602 1.888e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridec-2-enal" "2-tridecen-1-al" );
gibbsFormation
{
    dHf_298   -280010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     674.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39280.0
    phase     gas;
}
