/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4-biphenylyl)butanoic acid methyl ester  (C17H18O2, CAS 24254-67-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34BiphenylylButanoicAcidMethylEster;
formula     C17H18O2;
CAS         24254-67-9;
InChIKey    CRQARNDWPSBDKT-UHFFFAOYSA-N;
MW          254.329;      // g/mol [origin=calculated method=formula-sum]
Tc          936.84;      // K   [origin=predictive method=joback]
Pc          20.850;      // bar [origin=predictive method=joback]
omega       0.7367;      // -   [origin=predictive method=lee-kesler]
Tb          704.68;      // K   [origin=predictive method=joback]
HvapTb      65669.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.349 1.35264 -0.00080496 1.596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 9; } { group AC; count 2; } { group ACCH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-(4-phenylphenyl)butanoate" "methyl 3-(1,1'-biphenyl-4-yl)butanoate" "4-biphenylpropionicacid, b-methyl-, methyl ester (8ci)" "[1,1'-biphenyl]-4-propanoicacid, b-methyl-, methyl ester" );
standardThermochemistry
{
    dHf_298   -255180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5360.0
}
