/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorodiiodomethane  (CHClI2, CAS 638-73-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorodiiodomethane;
formula     CHClI2;
CAS         638-73-3;
InChIKey    RYPFDEIVUZVDCE-UHFFFAOYSA-N;
MW          302.269;      // g/mol [origin=calculated method=formula-sum]
Tc          717.28;      // K   [origin=predictive method=joback]
Pc          51.981;      // bar [origin=predictive method=joback]
omega       0.1904;      // -   [origin=predictive method=lee-kesler]
Tb          445.75;      // K   [origin=predictive method=joback]
HvapTb      40563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.57 0.1895 -0.000217 8.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl; count 1; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group Cl; count 1; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranyl-bis(iodanyl)methane" "methane, chlorodiiodo-" "chloro(diiodo)methane" "methane, chlorodiiodo-(6ci,9ci)" "chlorodiiodomethane;diiodochloromethane" );
standardThermochemistry
{
    dHf_298   68750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=59410.0
}
