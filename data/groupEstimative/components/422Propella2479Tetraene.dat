/*--------------------------------*- Choupo -*-----------------------*\
  Component: [4.2.2]propella-2,4,7,9-tetraene  (C10H8, CAS 88090-34-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        422Propella2479Tetraene;
formula     C10H8;
CAS         88090-34-0;
InChIKey    HLHKYPRYFGATQL-UHFFFAOYSA-N;
MW          128.174;      // g/mol [origin=calculated method=formula-sum]
Tc          699.58;      // K   [origin=predictive method=joback]
Pc          44.682;      // bar [origin=predictive method=joback]
omega       0.2958;      // -   [origin=predictive method=lee-kesler]
Tb          454.68;      // K   [origin=predictive method=joback]
HvapTb      36940.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-236.85 1.7832 -0.00220412 1.0168e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 2; } { group CH=CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 2; } { group dCH_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4.2.2)-propella-2,4,7,9-tetraene" );
gibbsFormation
{
    dHf_298   244450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     326.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=320040.0
    phase     gas;
}
