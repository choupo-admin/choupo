/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butoxyethyl nonanoate  (C15H30O3, CAS 20442-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButoxyethylNonanoate;
formula     C15H30O3;
CAS         20442-11-9;
InChIKey    XHYOMWNQYADXSZ-UHFFFAOYSA-N;
MW          258.402;      // g/mol [origin=calculated method=formula-sum]
Tc          788.80;      // K   [origin=predictive method=joback]
Pc          14.027;      // bar [origin=predictive method=joback]
omega       0.8978;      // -   [origin=predictive method=lee-kesler]
Tb          623.44;      // K   [origin=predictive method=joback]
HvapTb      58801.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.162 1.31084 -0.0005866 5.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH2COO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonanoic acid, 2-butoxyethyl ester" "nonanoic acid 2-butoxyethyl ester" "2-butoxyethyl nonan-1-oate" );
standardThermochemistry
{
    dHf_298   -802430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     802.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-339950.0
}
