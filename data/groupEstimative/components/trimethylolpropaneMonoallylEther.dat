/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolpropane monoallyl ether  (C9H18O3, CAS 682-11-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolpropaneMonoallylEther;
formula     C9H18O3;
CAS         682-11-1;
InChIKey    LZDXRPVSAKWYDH-UHFFFAOYSA-N;
MW          174.24;      // g/mol [origin=calculated method=formula-sum]
Tc          771.54;      // K   [origin=predictive method=joback]
Pc          29.092;      // bar [origin=predictive method=joback]
omega       1.3676;      // -   [origin=predictive method=lee-kesler]
Tb          605.75;      // K   [origin=predictive method=joback]
HvapTb      69430.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.325 0.96942 -0.0006103 1.5e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group CH2=CH; count 1; } { group OH; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-2-(prop-2-enoxymethyl)propane-1,3-diol" "trimethylolpropane allyl ether" "2-allyloxymethyl-2-ethylpropanediol" "1,1,1-trimethylolpropane monoallyl ether" "2-(allyloxymethyl)-2-ethyl-1,3-propanediol" "1-butanol, 2,2-(dihydroxymethyl)-, monoallyl ether" "ether, allyl (2,2-bis(hydroxymethyl)butyl)" "1,3-propanediol, 2-ethyl-2-((2-propenyloxy)methyl)-" "1,3-propanediol, 2-ethyl-2-[(2-propenyloxy)methyl]-" "1,3-propanediol, 2-ethyl-2-((2-propen-1-yloxy)methyl)-" "1,3-propanediol, 2-ethyl-2-[(2-propen-1-yloxy)methyl]-" "2-ethyl-2-[(prop-2-en-1-yloxy)methyl]propane-1,3-diol" );
standardThermochemistry
{
    dHf_298   -549090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-263060.0
}
