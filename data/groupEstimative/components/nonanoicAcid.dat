/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonanoic acid  (C9H18O2, CAS 112-05-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonanoicAcid;
formula     C9H18O2;
CAS         112-05-0;
InChIKey    FBUKVWPVBMHYJY-UHFFFAOYSA-N;
MW          158.241;      // g/mol [origin=calculated method=formula-sum]
Tc          733.97;      // K   [origin=predictive method=joback]
Pc          25.176;      // bar [origin=predictive method=joback]
omega       0.8330;      // -   [origin=predictive method=lee-kesler]
Tb          551.03;      // K   [origin=predictive method=joback]
HvapTb      52792.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.693 0.90962 -0.0005384 1.239e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pelargonic acid" "n-nonanoic acid" "nonylic acid" "pelargic acid" "nonoic acid" "n-nonylic acid" "1-octanecarboxylic acid" "n-nonoic acid" "cirrasol 185a" "nonanoate" "pelargon" "hexacid c-9" );
standardThermochemistry
{
    dHf_298   -579360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-319010.0
}
