/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylphthalic acid  (C9H8O4, CAS 4316-23-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethylphthalicAcid;
formula     C9H8O4;
CAS         4316-23-8;
InChIKey    CWJJAFQCTXFSTA-UHFFFAOYSA-N;
MW          180.159;      // g/mol [origin=calculated method=formula-sum]
Tc          967.38;      // K   [origin=predictive method=joback]
Pc          38.916;      // bar [origin=predictive method=joback]
omega       1.1786;      // -   [origin=predictive method=lee-kesler]
Tb          733.18;      // K   [origin=predictive method=joback]
HvapTb      73556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.4 0.76252 -0.00050812 1.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phthalic acid, 4-methyl-" "4-methyl phthalic acid" "1,2-benzenedicarboxylic acid, 4-methyl-" "4-methylbenzene-1,2-dicarboxylic acid" "4-methyl-o-phthalate" "4-methyl-phthalic acid" "phthalic acid, 4-methyl- (8ci)" "4-methyl-1,2-benzenedicarboxylic acid" "1,2-benzenedicarboxylicacid, 4-methyl-" "s715" );
standardThermochemistry
{
    dHf_298   -716040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-569770.0
}
