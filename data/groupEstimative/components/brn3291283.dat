/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3291283  (C12H15NO3, CAS 63887-17-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3291283;
formula     C12H15NO3;
CAS         63887-17-2;
InChIKey    PPLORUTUJXLHEI-UHFFFAOYSA-N;
MW          221.256;      // g/mol [origin=calculated method=formula-sum]
Tc          920.11;      // K   [origin=predictive method=joback]
Pc          28.874;      // bar [origin=predictive method=joback]
omega       1.3413;      // -   [origin=predictive method=lee-kesler]
Tb          721.14;      // K   [origin=predictive method=joback]
HvapTb      76845.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.323 1.0044 -0.00056536 1.0606e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 1; } { group CH2O; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-hydroxyethyl)-2-prop-2-enoxy-benzamide" "benzamide, o-allyloxy-n-(beta-hydroxyethyl)-" "n-(2-hydroxyethyl)-2-prop-2-enoxybenzamide" "n-(2-hydroxyethyl)-2-(prop-2-en-1-yloxy)benzamide" );
gibbsFormation
{
    dHf_298   -284080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40570.0
    phase     gas;
}
