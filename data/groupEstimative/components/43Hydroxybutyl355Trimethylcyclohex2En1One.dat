/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(3-hydroxybutyl)-3,5,5-trimethylcyclohex-2-en-1-one  (C13H22O2, CAS 36151-02-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        43Hydroxybutyl355Trimethylcyclohex2En1One;
formula     C13H22O2;
CAS         36151-02-7;
InChIKey    UEEJDIUOCUCVHN-UHFFFAOYSA-N;
MW          210.317;      // g/mol [origin=calculated method=formula-sum]
Tc          879.81;      // K   [origin=predictive method=joback]
Pc          22.828;      // bar [origin=predictive method=joback]
omega       0.9693;      // -   [origin=predictive method=lee-kesler]
Tb          675.86;      // K   [origin=predictive method=joback]
HvapTb      64993.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.468 1.38248 -0.00095144 2.985e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5,5-trimethyl-4-(3-oxidanylbutyl)cyclohex-2-en-1-one" "3-oxo-7,8-dihydro-.alpha.-ionol" "2-cyclohexen-1-one, 4-(3-hydroxybutyl)-3,5,5-trimethyl-" "4-(3-hydroxybutyl)-3,5,5-trimethyl-cyclohex-2-en-1-one" );
standardThermochemistry
{
    dHf_298   -511330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-171690.0
}
