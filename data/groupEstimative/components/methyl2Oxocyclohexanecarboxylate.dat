/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-oxocyclohexanecarboxylate  (C8H12O3, CAS 41302-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Oxocyclohexanecarboxylate;
formula     C8H12O3;
CAS         41302-34-5;
InChIKey    JEENWEAPRWGXSG-UHFFFAOYSA-N;
MW          156.181;      // g/mol [origin=calculated method=formula-sum]
Tc          753.10;      // K   [origin=predictive method=joback]
Pc          32.992;      // bar [origin=predictive method=joback]
omega       0.5235;      // -   [origin=predictive method=lee-kesler]
Tb          528.23;      // K   [origin=predictive method=joback]
HvapTb      45485.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.15 0.66282 -0.0001538 -7.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-oxidanylidenecyclohexane-1-carboxylate" "2-methoxycarbonylcyclohexanone" "methyl cyclohexanone-2-carboxylate" "2-carbomethoxycyclohexanone" "cyclohexanecarboxylic acid, 2-oxo-, methyl ester" "methyl 2-oxocyclohexane-1-carboxylate" "2-hydroxy methyl cyclohexanone" "2-oxocyclohexanecarboxylic acid, methyl ester" "ghl.pd_mitscher_leg0.110" "2-(methoxycarbonyl)cyclohexanone" "methyl 2-cyclohexanonecarboxylate" "methyl 2-oxocyclohexylcarboxylate" );
gibbsFormation
{
    dHf_298   -609110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-392030.0
    phase     gas;
}
