/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyl acetate  (C8H8O2, CAS 122-79-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylAcetate;
formula     C8H8O2;
CAS         122-79-2;
InChIKey    IPBVNPXQWQGGJP-UHFFFAOYSA-N;
MW          136.15;      // g/mol [origin=calculated method=formula-sum]
Tc          683.96;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       0.4378;      // -   [origin=predictive method=lee-kesler]
Tb          467.54;      // K   [origin=predictive method=joback]
HvapTb      43085.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.88 0.63012 -0.000348 5.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenyl ethanoate" "phenol acetate" "acetylphenol" "acetic acid, phenyl ester" "acetic acid phenyl ester" "acetyl phenol" "acetic acid,phenyl ester" "acetoxybenzene" "acetates" "(acetyloxy)benzene" "(4-acetoxy)polystyrene" "fenylester kyseliny octove" );
gibbsFormation
{
    dHf_298   -289200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-181480.0
    phase     gas;
}
