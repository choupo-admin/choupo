/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dichlorohexanoic acid  (C6H10Cl2O2, CAS 18240-70-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DichlorohexanoicAcid;
formula     C6H10Cl2O2;
CAS         18240-70-5;
InChIKey    CNWRQGGFKSSJSS-UHFFFAOYSA-N;
MW          185.044;      // g/mol [origin=calculated method=formula-sum]
Tc          765.39;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       0.7020;      // -   [origin=predictive method=lee-kesler]
Tb          554.02;      // K   [origin=predictive method=joback]
HvapTb      53588.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.343 0.76402 -0.0005878 1.781e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group COOH; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group Cl; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)hexanoic acid" "2,2-dichlorohexanoicacid" "hexanoic acid,2,2-dichloro-" );
standardThermochemistry
{
    dHf_298   -557670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-365290.0
}
