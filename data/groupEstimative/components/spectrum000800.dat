/*--------------------------------*- Choupo -*-----------------------*\
  Component: spectrum_000800  (C12H14O4, CAS 34346-90-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spectrum000800;
formula     C12H14O4;
CAS         34346-90-2;
InChIKey    XDSHNNRBLSBDAP-UHFFFAOYSA-N;
MW          222.24;      // g/mol [origin=calculated method=formula-sum]
Tc          844.38;      // K   [origin=predictive method=joback]
Pc          24.777;      // bar [origin=predictive method=joback]
omega       0.8481;      // -   [origin=predictive method=lee-kesler]
Tb          635.86;      // K   [origin=predictive method=joback]
HvapTb      60476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.69 0.69136 -0.00020288 -3.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 4; } { group CHO; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3,4,5-trimethoxyphenyl)prop-2-enal" "2-propenal, 3-(3,4,5-trimethoxyphenyl)-, (2e)-" "2-propenal,3-(3,4,5-trimethoxyphenyl)-" );
standardThermochemistry
{
    dHf_298   -453910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200620.0
}
