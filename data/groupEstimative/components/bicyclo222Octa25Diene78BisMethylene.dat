/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo(2.2.2)octa-2,5-diene, 7,8-bis(methylene)-  (C10H10, CAS 51698-73-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo222Octa25Diene78BisMethylene;
formula     C10H10;
CAS         51698-73-8;
InChIKey    OYLLJPWBOVQTSR-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          660.50;      // K   [origin=predictive method=joback]
Pc          32.357;      // bar [origin=predictive method=joback]
omega       0.3440;      // -   [origin=predictive method=lee-kesler]
Tb          447.06;      // K   [origin=predictive method=joback]
HvapTb      38926.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.79 0.8894 -0.00065756 1.968e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH=CH; count 2; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethylidenebicyclo[2.2.2]octa-5,7-diene" "bicyclo[2.2.2]octa-2,5-diene,7,8-bis(methylene)-" );
gibbsFormation
{
    dHf_298   167590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     277.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=296700.0
    phase     gas;
}
