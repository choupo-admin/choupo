/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenoxyacetamide  (C8H9NO2, CAS 621-88-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenoxyacetamide;
formula     C8H9NO2;
CAS         621-88-5;
InChIKey    AOPRXJXHLWYPQR-UHFFFAOYSA-N;
MW          151.165;      // g/mol [origin=calculated method=formula-sum]
Tc          787.85;      // K   [origin=predictive method=joback]
Pc          41.516;      // bar [origin=predictive method=joback]
omega       0.6840;      // -   [origin=predictive method=lee-kesler]
Tb          558.14;      // K   [origin=predictive method=joback]
HvapTb      55475.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.061 0.6556 -0.0003563 5.666e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenoxyethanamide" "2-phenoxyacetamide" "acetamide, 2-phenoxy-" "phenoxyacetic amide" "alpha-phenoxyacetamide" "agn-pc-0d6cdt" );
standardThermochemistry
{
    dHf_298   -182930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-38580.0
}
