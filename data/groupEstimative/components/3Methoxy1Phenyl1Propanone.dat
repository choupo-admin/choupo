/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxy-1-phenyl-1-propanone  (C10H12O2, CAS 55563-72-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxy1Phenyl1Propanone;
formula     C10H12O2;
CAS         55563-72-9;
InChIKey    MZBFZHPHBGPWDT-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          744.13;      // K   [origin=predictive method=joback]
Pc          30.830;      // bar [origin=predictive method=joback]
omega       0.5944;      // -   [origin=predictive method=lee-kesler]
Tb          531.37;      // K   [origin=predictive method=joback]
HvapTb      49286.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.248 0.78372 -0.0004217 6.946e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxy-1-phenyl-propan-1-one" "3-methoxy-1-phenylpropan-1-one" "1-propanone, 3-methoxy-1-phenyl-" );
gibbsFormation
{
    dHf_298   -258000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-88190.0
    phase     gas;
}
