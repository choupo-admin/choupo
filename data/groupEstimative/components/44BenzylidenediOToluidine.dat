/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-benzylidenedi-o-toluidine  (C21H22N2, CAS 82-87-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44BenzylidenediOToluidine;
formula     C21H22N2;
CAS         82-87-1;
InChIKey    FANQUUGICQRGJV-UHFFFAOYSA-N;
MW          302.421;      // g/mol [origin=calculated method=formula-sum]
Tc          1189.72;      // K   [origin=predictive method=joback]
Pc          21.061;      // bar [origin=predictive method=joback]
omega       1.0267;      // -   [origin=predictive method=lee-kesler]
Tb          924.66;      // K   [origin=predictive method=joback]
HvapTb      92710.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.42 1.65384 -0.00103404 2.371e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 2; } { group ACCH3; count 2; } { group ACCH; count 1; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(4-azanyl-3-methyl-phenyl)-phenyl-methyl]-2-methyl-aniline" "benzenamine, 4,4'-(phenylmethylene)bis(2-methyl-" "benzenamine, 4,4'-(phenylmethylene)bis[2-methyl-" "4-[(4-amino-3-methylphenyl)-phenylmethyl]-2-methylaniline" );
gibbsFormation
{
    dHf_298   249240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     723.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=555110.0
    phase     gas;
}
