/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexa-3,5-dien-2-one  (C6H8O, CAS 2957-06-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexa35Dien2One;
formula     C6H8O;
CAS         2957-06-4;
InChIKey    DACOGBAZMZEGQL-UHFFFAOYSA-N;
MW          96.129;      // g/mol [origin=calculated method=formula-sum]
Tc          582.63;      // K   [origin=predictive method=joback]
Pc          37.317;      // bar [origin=predictive method=joback]
omega       0.3673;      // -   [origin=predictive method=lee-kesler]
Tb          391.59;      // K   [origin=predictive method=joback]
HvapTb      34984.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.38 0.54582 -0.0003906 1.1596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-hexadien-2-one" "3,5-hexadien-2-one, (e)-" );
standardThermochemistry
{
    dHf_298   -37100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38780.0
}
