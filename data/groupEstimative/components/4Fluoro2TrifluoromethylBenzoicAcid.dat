/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluoro-2-(trifluoromethyl)benzoic acid  (C8H4F4O2, CAS 141179-72-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Fluoro2TrifluoromethylBenzoicAcid;
formula     C8H4F4O2;
CAS         141179-72-8;
InChIKey    JUHPDXOIGLHXTC-UHFFFAOYSA-N;
MW          208.11;      // g/mol [origin=calculated method=formula-sum]
Tc          759.34;      // K   [origin=predictive method=joback]
Pc          32.393;      // bar [origin=predictive method=joback]
omega       0.8181;      // -   [origin=predictive method=lee-kesler]
Tb          558.64;      // K   [origin=predictive method=joback]
HvapTb      49602.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.2 0.7897 -0.00061852 1.82e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group COOH; count 1; } { group ACF; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-fluoranyl-2-(trifluoromethyl)benzoic acid" "alpha,alpha,alpha,4-tetrafluoro-o-toluic acid" "4-fluoro-2(trifluoromethyl)benzoic acid" "4-fluoro-2-(trifluoromethyl)benzoicacid" "juhpdxoiglhxtc-uhfffaoysa-" "4-fluoro-2-trifluoromethylbenzoic acid" "a," "a," "a,4-tetrafluoro-o-toluic acid" "r764" "4-fluoro-2-(trifluoromethyl) benzoic acid" "benzoicacid, 4-fluoro-2-(trifluoromethyl)-" );
standardThermochemistry
{
    dHf_298   -1138320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1010680.0
}
