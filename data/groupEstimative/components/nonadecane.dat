/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonadecane  (C19H40, CAS 629-92-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonadecane;
formula     C19H40;
CAS         629-92-5;
InChIKey    LQERIDTXQFOHKA-UHFFFAOYSA-N;
MW          268.529;      // g/mol [origin=calculated method=formula-sum]
Tc          793.78;      // K   [origin=predictive method=joback]
Pc          10.806;      // bar [origin=predictive method=joback]
omega       0.8020;      // -   [origin=predictive method=lee-kesler]
Tb          634.32;      // K   [origin=predictive method=joback]
HvapTb      57888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.383 1.80884 -0.0010098 2.149e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 17; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-nonadecane" "nonadekan" "istd" "nonadecane, n-" "ai3-36122" "CH3-[CH2]17-ch3" "nonadecane, analytical standard" "CH3-(CH2)17-CH3" "nonadecane; nsc 77136; n-nonadecane" "nonadecan" "nonadecane,(S)" "qspl 079" );
gibbsFormation
{
    dHf_298   -435490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     896.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109100.0
    phase     gas;
}
