/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2559209  (C19H16, CAS 5831-10-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2559209;
formula     C19H16;
CAS         5831-10-7;
InChIKey    VGKLBQNFNHMWNC-UHFFFAOYSA-N;
MW          244.337;      // g/mol [origin=calculated method=formula-sum]
Tc          983.24;      // K   [origin=predictive method=joback]
Pc          22.741;      // bar [origin=predictive method=joback]
omega       0.7349;      // -   [origin=predictive method=lee-kesler]
Tb          734.43;      // K   [origin=predictive method=joback]
HvapTb      67268.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.08 1.54644 -0.00124212 4.098e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 7; } { group AC; count 5; } { group ACCH3; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11,17-dimethyl-15h-cyclopenta[a]phenanthrene" "15h-cyclopenta(a)phenanthrene, 11,17-dimethyl-" );
standardThermochemistry
{
    dHf_298   276750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=485080.0
}
