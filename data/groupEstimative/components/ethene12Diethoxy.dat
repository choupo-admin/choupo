/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethene, 1,2-diethoxy-  (C6H12O2, CAS 16484-86-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethene12Diethoxy;
formula     C6H12O2;
CAS         16484-86-9;
InChIKey    HDUOBOAWDSZFTJ-AATRIKPKSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          559.83;      // K   [origin=predictive method=joback]
Pc          31.704;      // bar [origin=predictive method=joback]
omega       0.4181;      // -   [origin=predictive method=lee-kesler]
Tb          385.88;      // K   [origin=predictive method=joback]
HvapTb      33728.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.252 0.46744 -0.0001644 -2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=CH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1,2-diethoxyethene" "1,2-diethoxyethene" "1,2-diethoxyethylene" "ethylene, 1,2-diethoxy-" "1,2-diaethoxy-aethen [german]" "1,2-diaethoxy-aethen" "[(e)-2-ethoxy-ethenoxy]-ethane" "ethene, 1,2-diethoxy- (9ci)" );
gibbsFormation
{
    dHf_298   -314390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130140.0
    phase     gas;
}
