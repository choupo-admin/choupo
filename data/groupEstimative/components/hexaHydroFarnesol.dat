/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexa-hydro-farnesol  (C15H32O, CAS 6750-34-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexaHydroFarnesol;
formula     C15H32O;
CAS         6750-34-1;
InChIKey    HDPUXESLSOZSIB-UHFFFAOYSA-N;
MW          228.42;      // g/mol [origin=calculated method=formula-sum]
Tc          798.24;      // K   [origin=predictive method=joback]
Pc          15.476;      // bar [origin=predictive method=joback]
omega       1.0177;      // -   [origin=predictive method=lee-kesler]
Tb          633.66;      // K   [origin=predictive method=joback]
HvapTb      64499.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.502 1.48058 -0.0008322 1.756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7,11-trimethyldodecan-1-ol" "1-dodecanol, 3,7,11-trimethyl-" "3,7,11-trimethyl-1-dodecanol" "1-dodecanol,3,7,11-trimethyl-" "1-dodececanol,3,7,11-trimethyl" "3,7,11-trimethyl-1-dodecanol;farnesanol; hexahydrofarnesol" );
standardThermochemistry
{
    dHf_298   -521000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     762.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68720.0
}
