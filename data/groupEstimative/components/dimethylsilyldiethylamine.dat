/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylsilyldiethylamine  (C6H16NSi, CAS 13686-66-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H16NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dimethylsilyldiethylamine;
formula     C6H16NSi;
CAS         13686-66-3;
InChIKey    ADTGAVILDBXARD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          130.286;      // g/mol [origin=calculated method=formula-sum]
Tc          515.59;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       0.3084;      // -   [origin=predictive method=lee-kesler]
Tb          350.02;      // K   [origin=predictive method=joback]
HvapTb      31140.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.152 0.59468 -0.0002078 -1.1e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethylamino(dimethyl)silicon" "n,n-diethyl-1,1-dimethylsilylamine" "silanamine, n,n-diethyl-1,1-dimethyl-" "(diethylamino)dimethylsilyl" "n,n-diethyl-1,1-dimethylsilanamine" );
standardThermochemistry
{
    dHf_298   -155450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58040.0
}
