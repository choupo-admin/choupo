/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1-trifluoro-7-methyloctane-2,4-dione  (C9H13F3O2, CAS 14189-31-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Trifluoro7Methyloctane24Dione;
formula     C9H13F3O2;
CAS         14189-31-2;
InChIKey    CODKKBRZQLFZKF-UHFFFAOYSA-N;
MW          210.195;      // g/mol [origin=calculated method=formula-sum]
Tc          679.73;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.7483;      // -   [origin=predictive method=lee-kesler]
Tb          507.40;      // K   [origin=predictive method=joback]
HvapTb      44985.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.543 0.96994 -0.0006526 1.6602e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2CO; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group F; count 3; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(fluoranyl)-7-methyl-octane-2,4-dione" "2,4-octanedione, 1,1,1-trifluoro-7-methyl-" );
standardThermochemistry
{
    dHf_298   -1056610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     606.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-816970.0
}
