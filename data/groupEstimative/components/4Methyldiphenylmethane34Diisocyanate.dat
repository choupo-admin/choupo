  Component: 4-methyldiphenylmethane-3,4-diisocyanate  (C16H12N2O2, CAS 75790-84-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyldiphenylmethane34Diisocyanate;
formula     C16H12N2O2;
CAS         75790-84-0;
InChIKey    OYVQDJGKYZFGDE-UHFFFAOYSA-N;
MW          264.284;      // g/mol [origin=calculated method=formula-sum]
Tc          1008.03;      // K   [origin=predictive method=joback]
Pc          25.277;      // bar [origin=predictive method=joback]
omega       0.9519;      // -   [origin=predictive method=lee-kesler]
Tb          767.32;      // K   [origin=predictive method=joback]
HvapTb      76812.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group ACCH3; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCd; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-isocyanato-4-[(4-isocyanatophenyl)methyl]-1-methyl-benzene" "2-isocyanato-4-[(4-isocyanatophenyl)methyl]-1-methylbenzene" "benzene, 2-isocyanato-4-((4-isocyanatophenyl)methyl)-1-methyl-" "benzene, 2-isocyanato-4-[(4-isocyanatophenyl)methyl]-1-methyl-" "4-methyldiphenylmethane-3,4-diisocyanate [diisocyanates]" "5-(p-isocyanatobenzyl)-o-tolyl isocyanate" "3,4'-diisocyanato-4-methyldiphenylmethane" "2-isocyanato-4-(4-isocyanatobenzyl)-1-methylbenzene" );
