/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecanedinitrile  (C14H24N2, CAS 7735-44-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecanedinitrile;
formula     C14H24N2;
CAS         7735-44-6;
InChIKey    JTOFSXGLSGTDCB-UHFFFAOYSA-N;
MW          220.36;      // g/mol [origin=calculated method=formula-sum]
Tc          913.88;      // K   [origin=predictive method=joback]
Pc          14.657;      // bar [origin=predictive method=joback]
omega       0.9559;      // -   [origin=predictive method=lee-kesler]
Tb          724.08;      // K   [origin=predictive method=joback]
HvapTb      67714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.162 1.2034 -0.0006758 1.428e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,12-dicyanododecane" "tetradecandinitril" );
standardThermochemistry
{
    dHf_298   -2530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     713.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=333360.0
}
