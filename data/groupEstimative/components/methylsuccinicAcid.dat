/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylsuccinic acid  (C5H8O4, CAS 498-21-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylsuccinicAcid;
formula     C5H8O4;
CAS         498-21-5;
InChIKey    WXUAQHNMJWJLTG-UHFFFAOYSA-N;
MW          132.115;      // g/mol [origin=calculated method=formula-sum]
Tc          815.64;      // K   [origin=predictive method=joback]
Pc          43.742;      // bar [origin=predictive method=joback]
omega       1.0419;      // -   [origin=predictive method=lee-kesler]
Tb          604.58;      // K   [origin=predictive method=joback]
HvapTb      60664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.861 0.58632 -0.0003966 1.038e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbutanedioic acid" "2-methylsuccinic acid" "pyrotartaric acid" "butanedioic acid, methyl-" "methyl succinic acid" "succinic acid, methyl-" "1,2-propanedicarboxylic acid" "d-methylsuccinic acid" "2-methyl-butanedioic acid" "butanedioic acid, 2-methyl-" "methylsuccinate" "2-methylbutanedioate" );
standardThermochemistry
{
    dHf_298   -852350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-699040.0
}
