/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylthio-3-buten-1-yne  (C5H6S, CAS 3448-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylthio3Buten1Yne;
formula     C5H6S;
CAS         3448-56-4;
InChIKey    NKMNGGDPEPZMPK-SNAWJCMRSA-N;
MW          98.163;      // g/mol [origin=calculated method=formula-sum]
Tc          593.49;      // K   [origin=predictive method=joback]
Pc          45.592;      // bar [origin=predictive method=joback]
omega       0.2223;      // -   [origin=predictive method=lee-kesler]
Tb          377.06;      // K   [origin=predictive method=joback]
HvapTb      33357.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.54 0.39931 -0.00028773 8.649e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH_C; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group tCH; count 1; } { group tC; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-methylsulfanylbut-1-en-3-yne" "but-1-en-3-ynyl methyl sulfide" "(1e)-1-(methylthio)but-1-en-3-yne" "1-buten-3-yne, 1-(methylthio)-, (1e)-" );
standardThermochemistry
{
    dHf_298   304460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=327630.0
}
