/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dibromocyclopentene  (C5H6Br2, CAS 1890-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dibromocyclopentene;
formula     C5H6Br2;
CAS         1890-04-6;
InChIKey    AKAJVSSDORNOIX-UHFFFAOYSA-N;
MW          225.911;      // g/mol [origin=calculated method=formula-sum]
Tc          698.77;      // K   [origin=predictive method=joback]
Pc          52.739;      // bar [origin=predictive method=joback]
omega       0.3671;      // -   [origin=predictive method=lee-kesler]
Tb          456.09;      // K   [origin=predictive method=joback]
HvapTb      39834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.04 0.6044 -0.00045028 1.32e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group CH=CH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-bis(bromanyl)cyclopentene" "cyclopentene, 3,5-dibromo-" );
standardThermochemistry
{
    dHf_298   4050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     322.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78660.0
}
