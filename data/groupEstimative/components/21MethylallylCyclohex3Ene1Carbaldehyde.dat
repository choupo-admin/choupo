/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1-methylallyl)cyclohex-3-ene-1-carbaldehyde  (C11H16O, CAS 18126-38-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        21MethylallylCyclohex3Ene1Carbaldehyde;
formula     C11H16O;
CAS         18126-38-0;
InChIKey    FZOJSMSNVKNZQH-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          720.14;      // K   [origin=predictive method=joback]
Pc          26.516;      // bar [origin=predictive method=joback]
omega       0.4800;      // -   [origin=predictive method=lee-kesler]
Tb          510.22;      // K   [origin=predictive method=joback]
HvapTb      46154.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.27 1.04882 -0.00060658 1.201e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 3; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-but-3-en-2-ylcyclohex-3-ene-1-carbaldehyde" "2-(but-3-en-2-yl)cyclohex-3-ene-1-carbaldehyde" "3-cyclohexene-1-carboxaldehyde, 2-(1-methyl-2-propenyl)-" "3-cyclohexene-1-carboxaldehyde, 2-(1-methyl-2-propen-1-yl)-" );
gibbsFormation
{
    dHf_298   -144040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74320.0
    phase     gas;
}
