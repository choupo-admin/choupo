/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorotetrahydropyran  (C5H9ClO, CAS 1768-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chlorotetrahydropyran;
formula     C5H9ClO;
CAS         1768-64-5;
InChIKey    DHRSKOBIDIDMJZ-UHFFFAOYSA-N;
MW          120.576;      // g/mol [origin=calculated method=formula-sum]
Tc          613.42;      // K   [origin=predictive method=joback]
Pc          42.220;      // bar [origin=predictive method=joback]
omega       0.2703;      // -   [origin=predictive method=lee-kesler]
Tb          397.93;      // K   [origin=predictive method=joback]
HvapTb      36048.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.05 0.6047 -0.0003357 5.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group FCH2O; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Cl; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyloxane" "4-chlorotetrahydro-2h-pyran" "4-chlorooxane" "2h-pyran, 4-chlorotetrahydro-" "4-chloro-tetrahydro-2h-pyran" "4-chloro-tetrahydro-pyran" "2h-pyran,4-chlorotetrahydro-" "am794" );
gibbsFormation
{
    dHf_298   -239950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     302.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-82380.0
    phase     gas;
}
