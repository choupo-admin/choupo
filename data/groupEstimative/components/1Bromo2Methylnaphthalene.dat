/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2-methylnaphthalene  (C11H9Br, CAS 2586-62-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo2Methylnaphthalene;
formula     C11H9Br;
CAS         2586-62-1;
InChIKey    CMIMBQIBIZZZHQ-UHFFFAOYSA-N;
MW          221.097;      // g/mol [origin=calculated method=formula-sum]
Tc          824.29;      // K   [origin=predictive method=joback]
Pc          36.334;      // bar [origin=predictive method=joback]
omega       0.5177;      // -   [origin=predictive method=lee-kesler]
Tb          573.06;      // K   [origin=predictive method=joback]
HvapTb      51755.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.67 0.88542 -0.00067984 2.106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACCH3; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-methyl-naphthalene" "naphthalene, 1-bromo-2-methyl-" "2-methyl-1-bromonaphthalene" ".beta.-methyl-.alpha.-bromonaphthalene" );
gibbsFormation
{
    dHf_298   160620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=255860.0
    phase     gas;
}
