/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chlorocyclohexene  (C6H9Cl, CAS 2441-97-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chlorocyclohexene;
formula     C6H9Cl;
CAS         2441-97-6;
InChIKey    LNGQLHZIYFQUIR-UHFFFAOYSA-N;
MW          116.588;      // g/mol [origin=calculated method=formula-sum]
Tc          608.48;      // K   [origin=predictive method=joback]
Pc          39.555;      // bar [origin=predictive method=joback]
omega       0.2339;      // -   [origin=predictive method=lee-kesler]
Tb          393.02;      // K   [origin=predictive method=joback]
HvapTb      34056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.5 0.6467 -0.00039128 8.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=CH; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylcyclohexene" "cyclohexene, 3-chloro-" "3-cyclohexenyl chloride" "3-chloro-1-cyclohexene" "1,2,3,4-tetrahydrochlorobenzene" "cyclohexene, 3-chloro-, (r)-" "3-chloro-cyclohexene" "3-chlorocyclohexene-1" "2-cyclohexenylchloride; 3-chloro-1-cyclohexene; 3-chlorocyclohexene; 3-cyclohexenyl chloride" );
standardThermochemistry
{
    dHf_298   -70810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42120.0
}
