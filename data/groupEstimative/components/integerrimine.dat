/*--------------------------------*- Choupo -*-----------------------*\
  Component: integerrimine  (C18H25NO5, CAS 480-79-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        integerrimine;
formula     C18H25NO5;
CAS         480-79-5;
InChIKey    HKODIGSRFALUTA-IKZAEVNJSA-N;
MW          335.4;      // g/mol [origin=calculated method=formula-sum]
Tc          1084.23;      // K   [origin=predictive method=joback]
Pc          18.595;      // bar [origin=predictive method=joback]
omega       1.3163;      // -   [origin=predictive method=lee-kesler]
Tb          871.88;      // K   [origin=predictive method=joback]
HvapTb      89734.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-145.02 2.25846 -0.00179654 5.942e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 3; } { group C; count 1; } { group CH=C; count 2; } { group OH; count 1; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 2; } { group OH; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "squalidin" "inegerrimine" "intergerrimine" "squalidine" "(15e)-12-hydroxysenecionan-11,16-dione" "senecionine, (15e)-isomer" "senecionan-11,16-dione, 12-hydroxy-, (15e)-" "senecionan-11,16-dione, 12-hydroxy-, (15e)- (9ci)" );
standardThermochemistry
{
    dHf_298   -816950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     771.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-347560.0
}
