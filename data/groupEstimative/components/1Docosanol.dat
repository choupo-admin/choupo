/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-docosanol  (C22H46O, CAS 661-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Docosanol;
formula     C22H46O;
CAS         661-19-8;
InChIKey    NOPFSRXAKWQILS-UHFFFAOYSA-N;
MW          326.609;      // g/mol [origin=calculated method=formula-sum]
Tc          973.48;      // K   [origin=predictive method=joback]
Pc          9.538;      // bar [origin=predictive method=joback]
omega       0.9252;      // -   [origin=predictive method=lee-kesler]
Tb          795.14;      // K   [origin=predictive method=joback]
HvapTb      81245.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.819 2.12782 -0.0012034 2.604e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 21; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 21; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "docosan-1-ol" "behenyl alcohol" "docosanol" "behenic alcohol" "abreva" "docosyl alcohol" "n-docosanol" "lidakol" "lidavol" "tadenan" "erazaban" "healip" );
gibbsFormation
{
    dHf_298   -649640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1063.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2460.0
    phase     gas;
}
