/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-1-benzopyran-2-one, 7-(diethylamino)-4-(4-morpholinyl)-  (C17H22N2O3, CAS 114145-42-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2h1Benzopyran2One7Diethylamino44Morpholinyl;
formula     C17H22N2O3;
CAS         114145-42-5;
InChIKey    BGIJUZQSYSVYBN-UHFFFAOYSA-N;
MW          302.374;      // g/mol [origin=calculated method=formula-sum]
Tc          984.11;      // K   [origin=predictive method=joback]
Pc          20.946;      // bar [origin=predictive method=joback]
omega       1.0440;      // -   [origin=predictive method=lee-kesler]
Tb          766.48;      // K   [origin=predictive method=joback]
HvapTb      74609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.928 1.84064 -0.00133986 3.802e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group FCH2O; count 1; } { group CH2N; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group O_ring; count 1; } { group COO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(diethylamino)-4-morpholin-4-yl-chromen-2-one" );
gibbsFormation
{
    dHf_298   -268410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=155630.0
    phase     gas;
}
