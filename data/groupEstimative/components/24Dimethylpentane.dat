/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethylpentane  (C7H16, CAS 108-08-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dimethylpentane;
formula     C7H16;
CAS         108-08-7;
InChIKey    BZHMBWZPUJHVEE-UHFFFAOYSA-N;
MW          100.205;      // g/mol [origin=calculated method=formula-sum]
Tc          530.39;      // K   [origin=predictive method=joback]
Pc          28.475;      // bar [origin=predictive method=joback]
omega       0.2939;      // -   [origin=predictive method=lee-kesler]
Tb          358.88;      // K   [origin=predictive method=joback]
HvapTb      30400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.839 0.68068 -0.0003634 7.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentane, 2,4-dimethyl-" "diisopropylmethane" );
gibbsFormation
{
    dHf_298   -198370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=3180.0
    phase     gas;
}
