/*--------------------------------*- Choupo -*-----------------------*\
  Component: tribicyclo[2.2.1]hept-2-ylmethanol  (C22H34O, CAS 17687-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tribicyclo221Hept2Ylmethanol;
formula     C22H34O;
CAS         17687-75-1;
InChIKey    JNDULIIEHFWRQA-UHFFFAOYSA-N;
MW          314.513;      // g/mol [origin=calculated method=formula-sum]
Tc          1055.75;      // K   [origin=predictive method=joback]
Pc          16.484;      // bar [origin=predictive method=joback]
omega       0.9794;      // -   [origin=predictive method=lee-kesler]
Tb          831.15;      // K   [origin=predictive method=joback]
HvapTb      79016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-335.29 3.0507 -0.002391 7.538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH; count 9; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group CH2_ring; count 12; } { group CH_ring; count 9; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(3-bicyclo[2.2.1]heptanyl)methanol" "methanol, tri-2-norbornyl-," );
standardThermochemistry
{
    dHf_298   -301090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=305450.0
}
