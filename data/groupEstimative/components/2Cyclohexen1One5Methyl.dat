/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexen-1-one, 5-methyl-  (C7H10O, CAS 7214-50-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexen1One5Methyl;
formula     C7H10O;
CAS         7214-50-8;
InChIKey    NQICQYZVEPBJON-UHFFFAOYSA-N;
MW          110.156;      // g/mol [origin=calculated method=formula-sum]
Tc          672.52;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.3247;      // -   [origin=predictive method=lee-kesler]
Tb          446.29;      // K   [origin=predictive method=joback]
HvapTb      36144.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.87 0.56662 -0.00018128 -2.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylcyclohex-2-en-1-one" );
standardThermochemistry
{
    dHf_298   -213410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     282.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60120.0
}
