/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,7-nonatriene, 4,8-dimethyl-  (C11H18, CAS 19945-61-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        137Nonatriene48Dimethyl;
formula     C11H18;
CAS         19945-61-0;
InChIKey    LUKZREJJLWEWQM-UHFFFAOYSA-N;
MW          150.265;      // g/mol [origin=calculated method=formula-sum]
Tc          643.61;      // K   [origin=predictive method=joback]
Pc          22.292;      // bar [origin=predictive method=joback]
omega       0.4014;      // -   [origin=predictive method=lee-kesler]
Tb          456.04;      // K   [origin=predictive method=joback]
HvapTb      39486.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.848 1.06866 -0.0007697 2.355e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 3; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,8-dimethylnona-1,3,7-triene" "4,8-dimethyl-1,3,7-nonatriene" "1,3,7-nonatriene,4,8-dimethyl-, (3e)-" "1,3,7-nonatriene,4,8-dimethyl-, (e)- (8ci); (3e)-4,8-dimethyl-1,3,7-nonatriene;(e)-4,8-dimethyl-1,3,7-nonatriene; 4,8-dimethyl-1,3(e),7-nonatriene;e-4,8-dimethyl-1,3,7-nonatriene" );
gibbsFormation
{
    dHf_298   69920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=272920.0
    phase     gas;
}
