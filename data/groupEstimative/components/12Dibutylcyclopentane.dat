/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibutylcyclopentane  (C13H26, CAS 62199-52-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibutylcyclopentane;
formula     C13H26;
CAS         62199-52-4;
InChIKey    XQUKCZAAJLJJPJ-UHFFFAOYSA-N;
MW          182.351;      // g/mol [origin=calculated method=formula-sum]
Tc          690.94;      // K   [origin=predictive method=joback]
Pc          18.595;      // bar [origin=predictive method=joback]
omega       0.5128;      // -   [origin=predictive method=lee-kesler]
Tb          507.65;      // K   [origin=predictive method=joback]
HvapTb      44480.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.474 1.34404 -0.0007554 1.548e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH2_ring; count 3; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentane, 1,2-dibutyl-" );
standardThermochemistry
{
    dHf_298   -271510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87420.0
}
