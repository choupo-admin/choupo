/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanoic acid, 3,3'-thiobis-, polymer with 2-ethyl-2-(hydroxymethyl)-1,3-propanediol and 2,2'-oxybis(ethanol)  (C16H34O10S, CAS 68928-65-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanoicAcid33ThiobisPolymerWith2Ethyl2Hydroxymethyl13Propa;
formula     C16H34O10S;
CAS         68928-65-4;
InChIKey    NNDDVKNDYDJURG-UHFFFAOYSA-N;
MW          418.498;      // g/mol [origin=calculated method=formula-sum]
Tc          1975.83;      // K   [origin=predictive method=joback]
Pc          19.355;      // bar [origin=predictive method=joback]
omega       0.3660;      // -   [origin=predictive method=lee-kesler]
Tb          1408.37;      // K   [origin=predictive method=joback]
HvapTb      177452.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (126.262 1.44001 -0.0003348 -1.607e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group C; count 1; } { group OH; count 4; } { group COOH; count 2; } { group C2H5O2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group C; count 1; } { group OH; count 5; } { group O; count 1; } { group COOH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-2-(hydroxymethyl)propane-1,3-diol;2-(2-hydroxyethyloxy)ethanol;3-(3-hydroxy-3-oxopropylsulfanyl)propanoic acid" );
gibbsFormation
{
    dHf_298   -2157600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1389.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1566640.0
    phase     gas;
}
