/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodo-3,3-dimethylbut-1-yne  (C6H9I, CAS 23700-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodo33Dimethylbut1Yne;
formula     C6H9I;
CAS         23700-63-2;
InChIKey    ICXZUQNBHRVDHZ-UHFFFAOYSA-N;
MW          208.038;      // g/mol [origin=calculated method=formula-sum]
Tc          682.92;      // K   [origin=predictive method=joback]
Pc          37.317;      // bar [origin=predictive method=joback]
omega       0.1754;      // -   [origin=predictive method=lee-kesler]
Tb          435.79;      // K   [origin=predictive method=joback]
HvapTb      39179.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.21 0.58886 -0.00046366 1.5098e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group I; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group tC; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyl-3,3-dimethyl-but-1-yne" "1-iodo-3,3-dimethyl-1-butyne" );
standardThermochemistry
{
    dHf_298   173250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=263400.0
}
