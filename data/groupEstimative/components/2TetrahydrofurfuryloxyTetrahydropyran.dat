/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(tetrahydrofurfuryloxy)tetrahydropyran  (C10H18O3, CAS 710-14-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TetrahydrofurfuryloxyTetrahydropyran;
formula     C10H18O3;
CAS         710-14-5;
InChIKey    XXNUDHUOMVIIFN-UHFFFAOYSA-N;
MW          186.251;      // g/mol [origin=calculated method=formula-sum]
Tc          764.18;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.5161;      // -   [origin=predictive method=lee-kesler]
Tb          539.55;      // K   [origin=predictive method=joback]
HvapTb      49970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.149 1.1384 -0.0005898 8.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group CH2O; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group O; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(oxolan-2-ylmethoxy)oxane" "2(3)-(tetrahydrofurfuryloxy)tetrahydropyran" "tetrahydro((tetrahydrofuryl)methoxy)-2h-pyran" "2h-pyran, tetrahydro-2-[(tetrahydrofurfuryl)oxy]-" "2h-pyran, tetrahydro-2-[(tetrahydro-2-furanyl)methoxy]-" "2-(oxolan-2-ylmethoxy)-2h-3,4,5,6-tetrahydropyran" );
standardThermochemistry
{
    dHf_298   -531150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-182920.0
}
