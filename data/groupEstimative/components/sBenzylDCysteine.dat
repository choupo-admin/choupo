/*--------------------------------*- Choupo -*-----------------------*\
  Component: s-benzyl-d-cysteine  (C10H13NO2S, CAS 3054-01-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sBenzylDCysteine;
formula     C10H13NO2S;
CAS         3054-01-1;
InChIKey    GHBAYRBVXCRIHT-SECBINFHSA-N;
MW          211.279;      // g/mol [origin=calculated method=formula-sum]
Tc          988.09;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       1.0321;      // -   [origin=predictive method=lee-kesler]
Tb          741.46;      // K   [origin=predictive method=joback]
HvapTb      74364.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.098 0.98789 -0.0006304 1.442e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-3-(phenylmethylsulfanyl)propanoic acid" "3-benzylthioalanine" "l-s-benzylcysteine" "s-benzylcysteine" "(r)-s-benzylcysteine" "s-benzyl-l-cysteine" "(s)-2-amino-3-(benzylthio)propanoic acid" "l-cysteine, s-(phenylmethyl)-" "alanine, 3-(benzylthio)-, l-" "alanine, 3-(benzylthio)-, l- (8ci)" "(2s)-2-amino-3-benzylsulfanylpropanoic acid" "(s)-2-amino-3- (s-benzylthio)propanoic acid" );
gibbsFormation
{
    dHf_298   -293090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-101050.0
    phase     gas;
}
