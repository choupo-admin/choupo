/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxepanone, polymer with 2,2-bis(hydroxymethyl)-1,3-propanediol and 1,3-diisocyanatomethylbenzene  (C20H28N2O8, CAS 70729-83-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OxepanonePolymerWith22BisHydroxymethyl13PropanediolAnd13Dii;
formula     C20H28N2O8;
CAS         70729-83-8;
InChIKey    YLDKQLHGYDCXRB-UHFFFAOYSA-N;
MW          424.45;      // g/mol [origin=calculated method=formula-sum]
Tc          1610.20;      // K   [origin=predictive method=joback]
Pc          19.579;      // bar [origin=predictive method=joback]
omega       1.1589;      // -   [origin=predictive method=lee-kesler]
Tb          1273.64;      // K   [origin=predictive method=joback]
HvapTb      156759.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 8; } { group C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group OH; count 4; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group dCd; count 2; } { group CH2_ring; count 5; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 4; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)propane-1,3-diol;1,3-diisocyanato-2-methyl-benzene;oxepan-2-one" "1,3-diisocyanatomethylbenzene, epsilon-caprolactone, pentaerythritol polymer" );
