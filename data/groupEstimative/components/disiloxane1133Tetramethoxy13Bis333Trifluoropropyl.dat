/*--------------------------------*- Choupo -*-----------------------*\
  Component: disiloxane, 1,1,3,3-tetramethoxy-1,3-bis(3,3,3-trifluoropropyl)-  (C10H20F6O5Si2, CAS 109961-44-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H20F6O5Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        disiloxane1133Tetramethoxy13Bis333Trifluoropropyl;
formula     C10H20F6O5Si2;
CAS         109961-44-6;
InChIKey    OUYJUMDQQVWPLF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          390.423;      // g/mol [origin=calculated method=formula-sum]
Tc          680.87;      // K   [origin=predictive method=joback]
Pc          13.369;      // bar [origin=predictive method=joback]
omega       0.7640;      // -   [origin=predictive method=lee-kesler]
Tb          532.46;      // K   [origin=predictive method=joback]
HvapTb      42998.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (190.534 0.54788 0.0004224 -4.232e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH3O; count 4; } { group CF3; count 2; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 2; } { group F; count 6; } { group O; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[dimethoxy-[3,3,3-tris(fluoranyl)propyl]silyl]oxy-dimethoxy-[3,3,3-tris(fluoranyl)propyl]silane" "disiloxane, 1,3-bis(3,3,3-trifluoropropyl)-1,1,3,3-tetramethoxy-" "[dimethoxy(3,3,3-trifluoropropyl)silyl]oxy-dimethoxy-(3,3,3-trifluoropropyl)silane" );
gibbsFormation
{
    dHf_298   -2328230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     967.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1864380.0
    phase     gas;
}
