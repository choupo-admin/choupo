/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-3-methylbut-1-yne  (C5H7Cl, CAS 63150-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro3Methylbut1Yne;
formula     C5H7Cl;
CAS         63150-17-4;
InChIKey    UTRVPGKFJHDJKE-UHFFFAOYSA-N;
MW          102.561;      // g/mol [origin=calculated method=formula-sum]
Tc          531.19;      // K   [origin=predictive method=joback]
Pc          40.108;      // bar [origin=predictive method=joback]
omega       0.2184;      // -   [origin=predictive method=lee-kesler]
Tb          341.11;      // K   [origin=predictive method=joback]
HvapTb      30579.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.331 0.39762 -0.00026773 7.519e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2Cl; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group tCH; count 1; } { group tC; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-3-methyl-but-1-yne" "1-butyne, 4-chloro-3-methyl-" "chloromethyl butyne" );
gibbsFormation
{
    dHf_298   124350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     344.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=199920.0
    phase     gas;
}
