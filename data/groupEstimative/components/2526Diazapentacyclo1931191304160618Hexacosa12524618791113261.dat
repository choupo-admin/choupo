name        2526Diazapentacyclo1931191304160618Hexacosa12524618791113261;
formula     C24H16N2;
CAS         64031-65-8;
InChIKey    OOIJMELXAYQWOH-UHFFFAOYSA-N;
MW          332.406;      // g/mol [origin=calculated method=formula-sum]
Tc          1287.08;      // K   [origin=predictive method=joback]
Pc          23.070;      // bar [origin=predictive method=joback]
omega       0.9794;      // -   [origin=predictive method=lee-kesler]
