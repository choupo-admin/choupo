}
aliases     ( "25,26-diazapentacyclo[19.3.1.19,13.04,16.06,18]hexacosa-1(25),2,4,6(18),7,9,11,13(26),14,16,19,21,23-tridecaene" "25,26-diazapentacyclo[19.3.1.19,13.04,16.06,18]hexacosa-1(25),2,4,6(18),7,9,11,13(26),14,16,19,21,23-tridecaene(9ci)" );
