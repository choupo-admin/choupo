    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 4; } { group ACH; count 2; } { group AC; count 4; } { group C5H3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
