/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentasiloxane, dodecaethoxy-  (C24H60O16Si5, CAS 4935-68-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C24H60O16Si5 (delta Si+5; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pentasiloxaneDodecaethoxy;
formula     C24H60O16Si5;
CAS         4935-68-6;
InChIKey    XGNHNODGNBXORF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          745.153;      // g/mol [origin=calculated method=formula-sum]
Tc          1422.25;      // K   [origin=predictive method=joback]
Pc          5.179;      // bar [origin=predictive method=joback]
omega       0.0954;      // -   [origin=predictive method=lee-kesler]
Tb          1114.44;      // K   [origin=predictive method=joback]
HvapTb      109048.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (593.162 0.24184 0.0025682 -1.6884e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group CH2O; count 12; } { group Si; count 1; } { group SiO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group CH2; count 12; } { group O; count 16; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[diethoxy(triethoxysilyloxy)silyl] diethyl silicate" "pentasiloxane, 1,1,1,3,3,5,5,7,7,9,9,9-dodecaethoxy-" "dodecaethoxypentasiloxane" );
gibbsFormation
{
    dHf_298   -3212310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1903.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2052600.0
    phase     gas;
}
