/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hydroxy-2-naphthopiperidide  (C16H17NO2, CAS 29777-42-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hydroxy2Naphthopiperidide;
formula     C16H17NO2;
CAS         29777-42-2;
InChIKey    FQCIVXJPSZVUCI-UHFFFAOYSA-N;
MW          255.317;      // g/mol [origin=calculated method=formula-sum]
Tc          1036.39;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       1.0303;      // -   [origin=predictive method=lee-kesler]
Tb          783.20;      // K   [origin=predictive method=joback]
HvapTb      78157.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.38 1.7904 -0.00148054 4.9006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 6; } { group AC; count 3; } { group ACOH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-oxidanylnaphthalen-2-yl)-piperidin-1-yl-methanone" "piperidine, 1-(1-hydroxy-2-naphthoyl)-" "1-hydroxy-2-naphthoic acid piperidide" "methanone, (1-hydroxy-2-naphthalenyl)-1-piperidinyl-" "piperidine, 1-[(1-hydroxy-2-naphthalenyl)carbonyl]-" "1-((1-hydroxy-2-naphthyl)carbonyl)piperidine" "1-[(1-hydroxy-2-naphthyl)carbonyl]piperidine" "piperidine, 1-((1-hydroxy-2-naphthalenyl)carbonyl)-" "(1-hydroxynaphthalen-2-yl)-piperidin-1-ylmethanone" "methanone,(1-hydroxy-2-naphthalenyl)-1-piperidinyl-" );
standardThermochemistry
{
    dHf_298   -98980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     618.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164770.0
}
