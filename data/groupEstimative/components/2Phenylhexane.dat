/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenylhexane  (C12H18, CAS 6031-02-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenylhexane;
formula     C12H18;
CAS         6031-02-3;
InChIKey    CYBSWFUWEZFKNJ-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          704.20;      // K   [origin=predictive method=joback]
Pc          24.243;      // bar [origin=predictive method=joback]
omega       0.4547;      // -   [origin=predictive method=lee-kesler]
Tb          500.40;      // K   [origin=predictive method=joback]
HvapTb      44194.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.607 1.07084 -0.0006634 1.566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexan-2-ylbenzene" "benzene, (1-methylpentyl)-" "hexane, 2-phenyl-" "benzene,(1-methylpentyl)-" "1-(hexan-2-yl)benzene" "hexane,2-phenyl- (6ci,7ci,8ci); (1-methylpentyl)benzene; (2-hexyl)benzene;2-phenylhexane" );
gibbsFormation
{
    dHf_298   -59760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160130.0
    phase     gas;
}
