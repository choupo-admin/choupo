/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dichloropropanal  (C3H4Cl2O, CAS 10140-89-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dichloropropanal;
formula     C3H4Cl2O;
CAS         10140-89-3;
InChIKey    IZRKUJREXIKAQM-UHFFFAOYSA-N;
MW          126.964;      // g/mol [origin=calculated method=formula-sum]
Tc          587.54;      // K   [origin=predictive method=joback]
Pc          44.563;      // bar [origin=predictive method=joback]
omega       0.3930;      // -   [origin=predictive method=lee-kesler]
Tb          391.32;      // K   [origin=predictive method=joback]
HvapTb      37374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.661 0.2828 -0.0001764 3.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHO; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group Cl; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(chloranyl)propanal" "2,3-dichloropropionaldehyde" "1,2-dichloro-3-propional" "propionaldehyde, 2,3-dichloro-" "alpha,beta-dichloropropionaldehyde" "propanal, 2,3-dichloro-" "propionaldehyde,2,3-dichloro- (6ci,7ci,8ci); 2,3-dichloropropanal; 2,3-dichloropropionaldehyde;a,b-dichloropropionaldehyde" );
standardThermochemistry
{
    dHf_298   -227590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-151440.0
}
