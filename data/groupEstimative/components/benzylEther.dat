/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl ether  (C14H14O, CAS 103-50-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylEther;
formula     C14H14O;
CAS         103-50-4;
InChIKey    MHDVGSVTJDSBDK-UHFFFAOYSA-N;
MW          198.265;      // g/mol [origin=calculated method=formula-sum]
Tc          831.84;      // K   [origin=predictive method=joback]
Pc          27.212;      // bar [origin=predictive method=joback]
omega       0.5520;      // -   [origin=predictive method=lee-kesler]
Tb          595.70;      // K   [origin=predictive method=joback]
HvapTb      53720.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.148 1.1128 -0.0006892 1.516e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenylmethoxymethylbenzene" "dibenzyl ether" "benzyl oxide" "plastikator ba" "ba (plasticizer)" "dibenzylether" "benzene, 1,1'-[oxybis(methylene)]bis-" "ether, dibenzyl" "plasticator ba" "1,1-oxybis methylene, bis benzene" "(oxybis(methylene))dibenzene" "1,1-oxybismethylene, bis benzene" );
gibbsFormation
{
    dHf_298   8550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=186820.0
    phase     gas;
}
