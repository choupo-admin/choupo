/*--------------------------------*- Choupo -*-----------------------*\
  Component: diallyldiethoxysilane  (C10H20O2Si, CAS 13081-67-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H20O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diallyldiethoxysilane;
formula     C10H20O2Si;
CAS         13081-67-9;
InChIKey    NWQIWFOQNHTTIA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          200.353;      // g/mol [origin=calculated method=formula-sum]
Tc          642.17;      // K   [origin=predictive method=joback]
Pc          19.788;      // bar [origin=predictive method=joback]
omega       0.4967;      // -   [origin=predictive method=lee-kesler]
Tb          468.00;      // K   [origin=predictive method=joback]
HvapTb      41628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (79.634 0.58124 7.08e-05 -1.842e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=CH; count 2; } { group CH2O; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH2; count 2; } { group dCH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethoxy-bis(prop-2-enyl)silane" "silane,diethoxydi-2-propen-1-yl-" );
gibbsFormation
{
    dHf_298   -374930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     685.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105760.0
    phase     gas;
}
