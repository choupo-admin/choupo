/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluorophenylaziridine  (C8H8FN, CAS 698-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Fluorophenylaziridine;
formula     C8H8FN;
CAS         698-53-3;
InChIKey    FOKDVFBDEKBAKV-UHFFFAOYSA-N;
MW          137.157;      // g/mol [origin=calculated method=formula-sum]
Tc          639.24;      // K   [origin=predictive method=joback]
Pc          40.108;      // bar [origin=predictive method=joback]
omega       0.4309;      // -   [origin=predictive method=lee-kesler]
Tb          433.15;      // K   [origin=predictive method=joback]
HvapTb      37616.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.65 0.9481 -0.00082656 2.85e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2N; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-fluorophenyl)aziridine" );
gibbsFormation
{
    dHf_298   -12670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=115790.0
    phase     gas;
}
