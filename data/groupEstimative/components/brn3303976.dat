/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3303976  (C20H14O, CAS 63018-98-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3303976;
formula     C20H14O;
CAS         63018-98-4;
InChIKey    MFBUUODCOHVEFW-UHFFFAOYSA-N;
MW          270.331;      // g/mol [origin=calculated method=formula-sum]
Tc          1066.48;      // K   [origin=predictive method=joback]
Pc          23.703;      // bar [origin=predictive method=joback]
omega       0.8884;      // -   [origin=predictive method=lee-kesler]
Tb          809.63;      // K   [origin=predictive method=joback]
HvapTb      76042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.27 1.60732 -0.00128574 4.1186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 7; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-benzo[c]phenanthren-5-ylethanone" "benzo(c)phenanthrene, 5-acetyl-" );
gibbsFormation
{
    dHf_298   206620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=392070.0
    phase     gas;
}
