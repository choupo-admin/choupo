/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(1-hydroxyethyl)pyridine  (C7H9NO, CAS 4754-27-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        31HydroxyethylPyridine;
formula     C7H9NO;
CAS         4754-27-2;
InChIKey    QMDUEBURHKSKDG-UHFFFAOYSA-N;
MW          123.155;      // g/mol [origin=calculated method=formula-sum]
Tc          746.05;      // K   [origin=predictive method=joback]
Pc          47.042;      // bar [origin=predictive method=joback]
omega       0.7825;      // -   [origin=predictive method=lee-kesler]
Tb          531.88;      // K   [origin=predictive method=joback]
HvapTb      55953.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.71 0.66358 -0.00043106 1.087e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group OH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group OH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pyridin-3-ylethanol" "3-pyridylmethylcarbinol" "1-(3-pyridyl)ethanol" "methyl-3-pyridylcarbinol" "1-(pyridin-3-yl)ethanol" "1-(pyridin-3-yl)ethan-1-ol" "alpha-methyl-3-pyridinemethanol" "alpha-methylpyridine-3-methanol" "3-pyridinemethanol, alpha-methyl-" "1-pyridin-3-yl-ethanol" "3-pyridinemethanol, a-methyl-" "(r)-3-(1-hydroxyethyl) pyridine" );
gibbsFormation
{
    dHf_298   -76000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58260.0
    phase     gas;
}
