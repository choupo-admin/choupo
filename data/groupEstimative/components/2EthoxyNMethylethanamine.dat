/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethoxy-n-methylethanamine  (C5H13NO, CAS 38256-94-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthoxyNMethylethanamine;
formula     C5H13NO;
CAS         38256-94-9;
InChIKey    QWEJWXUAXUMVFU-UHFFFAOYSA-N;
MW          103.165;      // g/mol [origin=calculated method=formula-sum]
Tc          557.53;      // K   [origin=predictive method=joback]
Pc          34.521;      // bar [origin=predictive method=joback]
omega       0.4826;      // -   [origin=predictive method=lee-kesler]
Tb          386.59;      // K   [origin=predictive method=joback]
HvapTb      35570.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.633 0.49184 -0.0001858 4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2O; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxy-n-methyl-ethanamine" "ethanamine, 2-ethoxy-n-methyl-" "agn-pc-01ucxf" "(2-ethoxyethyl)(methyl)amine" );
gibbsFormation
{
    dHf_298   -225280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-24390.0
    phase     gas;
}
