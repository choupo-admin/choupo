/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanedioic acid, c18-28-alkyl esters  (C22H42O4, CAS 68921-49-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanedioicAcidC1828AlkylEsters;
formula     C22H42O4;
CAS         68921-49-3;
InChIKey    NNFVBMSZYDDWSM-UHFFFAOYSA-N;
MW          370.574;      // g/mol [origin=calculated method=formula-sum]
Tc          1110.48;      // K   [origin=predictive method=joback]
Pc          9.550;      // bar [origin=predictive method=joback]
omega       0.9219;      // -   [origin=predictive method=lee-kesler]
Tb          906.69;      // K   [origin=predictive method=joback]
HvapTb      89137.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.899 2.08982 -0.001151 2.215e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CH2COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 19; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-octadecoxy-4-oxidanylidene-butanoic acid" "c18-c28 alcohol esters of succinic acid" "4-octadecoxy-4-oxobutanoic acid" "4-(octadecyloxy)-4-oxobutanoic acid" );
gibbsFormation
{
    dHf_298   -1164960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1117.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-519920.0
    phase     gas;
}
