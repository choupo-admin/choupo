/*--------------------------------*- Choupo -*-----------------------*\
  Component: sulfide, butyl isopropyl  (C7H16S, CAS 7309-43-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sulfideButylIsopropyl;
formula     C7H16S;
CAS         7309-43-5;
InChIKey    QIAZGMDOMXLGBB-UHFFFAOYSA-N;
MW          132.265;      // g/mol [origin=calculated method=formula-sum]
Tc          619.86;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.3873;      // -   [origin=predictive method=lee-kesler]
Tb          428.10;      // K   [origin=predictive method=joback]
HvapTb      37605.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.443 0.66915 -0.00032 4.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propan-2-ylsulfanylbutane" "butane, 1-[(1-methylethyl)thio]-" "iso-propyl-n-butyl sulfide" "1-(propan-2-ylsulfanyl)butane" "butyl iso-propyl sulfide" );
gibbsFormation
{
    dHf_298   -151220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38740.0
    phase     gas;
}
