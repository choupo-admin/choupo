/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butene,1,2,4-trichloro-  (C4H5Cl3, CAS 2431-54-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butene124Trichloro;
formula     C4H5Cl3;
CAS         2431-54-1;
InChIKey    SXCATGXBSQWDDJ-UHFFFAOYSA-N;
MW          159.434;      // g/mol [origin=calculated method=formula-sum]
Tc          611.97;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.3197;      // -   [origin=predictive method=lee-kesler]
Tb          407.45;      // K   [origin=predictive method=joback]
HvapTb      37691.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.052 0.4241 -0.0003411 1.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group CH2Cl; count 2; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4-tris(chloranyl)but-2-ene" "2-butene, 1,2,4-trichloro-, (z)-" );
standardThermochemistry
{
    dHf_298   -65680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18680.0
}
