/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane,ethoxy-1h-inden-1-yldimethyl-  (C13H18OSi, CAS 41273-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H18OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneEthoxy1hInden1Yldimethyl;
formula     C13H18OSi;
CAS         41273-57-8;
InChIKey    ITKQRDDHHLQZQY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          218.371;      // g/mol [origin=calculated method=formula-sum]
Tc          777.86;      // K   [origin=predictive method=joback]
Pc          22.229;      // bar [origin=predictive method=joback]
omega       0.4690;      // -   [origin=predictive method=lee-kesler]
Tb          558.42;      // K   [origin=predictive method=joback]
HvapTb      50379.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.679 0.92596 -0.00032924 -2.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethoxy-(1h-inden-1-yl)-dimethyl-silane" "ethoxy-(1h-inden-1-yl)-dimethylsilane" "silane, ethoxy-1h-inden-1-yldimethyl-" );
gibbsFormation
{
    dHf_298   -199850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42310.0
    phase     gas;
}
