/*--------------------------------*- Choupo -*-----------------------*\
  Component: nitrilotris(ethyleneoxy)tris(trimethylsilane)  (C15H39NO3Si3, CAS 20836-42-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H39NO3Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nitrilotrisEthyleneoxyTrisTrimethylsilane;
formula     C15H39NO3Si3;
CAS         20836-42-4;
InChIKey    HENDLKHWFJNWGE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          365.736;      // g/mol [origin=calculated method=formula-sum]
Tc          797.11;      // K   [origin=predictive method=joback]
Pc          10.603;      // bar [origin=predictive method=joback]
omega       0.6413;      // -   [origin=predictive method=lee-kesler]
Tb          626.70;      // K   [origin=predictive method=joback]
HvapTb      59139.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (177.516 0.74468 0.0006726 -6.113e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 9; } { group CH2; count 2; } { group CH2O; count 3; } { group CH2N; count 1; } { group Si; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group CH2; count 6; } { group O; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-trimethylsilyloxy-n,n-bis(2-trimethylsilyloxyethyl)ethanamine" "triethylamine, 2,2',2''-tris(trimethylsiloxy)-" "silane, nitrilotris(ethyleneoxy)tris(trimethyl-" "2-[(trimethylsilyl)oxy]-n,n-bis{2-[(trimethylsilyl)oxy]ethyl}ethanamine" );
gibbsFormation
{
    dHf_298   -1016920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1169.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-443080.0
    phase     gas;
}
