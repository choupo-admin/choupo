/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-cyclopentadecadiyne  (C15H22, CAS 4722-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Cyclopentadecadiyne;
formula     C15H22;
CAS         4722-42-3;
InChIKey    LLYOCFZRCOXMHY-UHFFFAOYSA-N;
MW          202.341;      // g/mol [origin=calculated method=formula-sum]
Tc          886.58;      // K   [origin=predictive method=joback]
Pc          25.637;      // bar [origin=predictive method=joback]
omega       0.2978;      // -   [origin=predictive method=lee-kesler]
Tb          606.37;      // K   [origin=predictive method=joback]
HvapTb      54886.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.78 1.2298 -0.00051232 1.356e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 4; } { group CH2_ring; count 11; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentadeca-1,8-diyne" );
standardThermochemistry
{
    dHf_298   235530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     795.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=452680.0
}
