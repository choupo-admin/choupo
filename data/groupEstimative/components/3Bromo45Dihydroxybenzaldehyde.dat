/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-4,5-dihydroxybenzaldehyde  (C7H5BrO3, CAS 16414-34-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H5BrO3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Bromo45Dihydroxybenzaldehyde;
formula     C7H5BrO3;
CAS         16414-34-9;
InChIKey    GVSGSHGXUXLQNS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          217.018;      // g/mol [origin=calculated method=formula-sum]
Tc          855.25;      // K   [origin=predictive method=joback]
Pc          73.933;      // bar [origin=predictive method=joback]
omega       0.8250;      // -   [origin=predictive method=lee-kesler]
Tb          595.24;      // K   [origin=predictive method=joback]
HvapTb      64204.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.23 0.8859 -0.00105828 4.697e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACOH; count 2; } { group CHO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-4,5-bis(oxidanyl)benzaldehyde" "bromodihydroxybenzaldehyde" "5-bromoprotocatechualdehyde" "benzaldehyde,3-bromo-4,5-dihydroxy-" "5-bromo-3,4-dihydroxybenzaldehyde" "benzaldehyde, 3-bromo-4,5-dihydroxy-" );
gibbsFormation
{
    dHf_298   -214590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-140120.0
    phase     gas;
}
