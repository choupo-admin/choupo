/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-biphenylcarboxamide  (C13H11NO, CAS 3815-20-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Biphenylcarboxamide;
formula     C13H11NO;
CAS         3815-20-1;
InChIKey    LUQVCHRDAGWYMG-UHFFFAOYSA-N;
MW          197.237;      // g/mol [origin=calculated method=formula-sum]
Tc          940.78;      // K   [origin=predictive method=joback]
Pc          34.643;      // bar [origin=predictive method=joback]
omega       0.7452;      // -   [origin=predictive method=lee-kesler]
Tb          681.78;      // K   [origin=predictive method=joback]
HvapTb      67133.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.59 1.0554 -0.00070346 1.7156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 9; } { group dC_ring; count 3; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenylbenzamide" "biphenyl-4-carboxamide" "[1,1'-biphenyl]-4-carboxamide" "4-biphenylcarboxamide(6ci,7ci,8ci);4-phenylbenzamide;" );
gibbsFormation
{
    dHf_298   71150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=211300.0
    phase     gas;
}
