/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,2-trifluoro-1-phenylethanol  (C8H7F3O, CAS 340-05-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222Trifluoro1Phenylethanol;
formula     C8H7F3O;
CAS         340-05-6;
InChIKey    VNOMEAQPOMDWSR-UHFFFAOYSA-N;
MW          176.137;      // g/mol [origin=calculated method=formula-sum]
Tc          680.10;      // K   [origin=predictive method=joback]
Pc          35.814;      // bar [origin=predictive method=joback]
omega       0.8015;      // -   [origin=predictive method=lee-kesler]
Tb          495.64;      // K   [origin=predictive method=joback]
HvapTb      48222.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.88 0.886 -0.0006972 2.075e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group F; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(fluoranyl)-1-phenyl-ethanol" "1-phenyl-2,2,2-trifluoroethanol" "alpha-(trifluoromethyl)benzyl alcohol" "2,2,2-trifluoro-1-phenylethan-1-ol" "alpha-(trifluoromethyl) benzyl alcohol" "2,2,2-trifluorophenylethanol" "2,2,2-trifluoro-1-phenyl-ethanol" "alpha-(trifluoromethyl)benzenemethanol" "()-1-phenyl-2,2,2-trifluoroethanol" "()-alpha-(trifluoromethyl)benzyl alcohol" "benzyl alcohol, alpha-(trifluoromethyl)-" "benzenemethanol, alpha-(trifluoromethyl)-" );
gibbsFormation
{
    dHf_298   -726510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-591960.0
    phase     gas;
}
