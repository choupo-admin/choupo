/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylene glycol dibenzoate  (C18H18O5, CAS 120-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyleneGlycolDibenzoate;
formula     C18H18O5;
CAS         120-55-8;
InChIKey    NXQMCAOPTPLPRL-UHFFFAOYSA-N;
MW          314.337;      // g/mol [origin=calculated method=formula-sum]
Tc          1026.11;      // K   [origin=predictive method=joback]
Pc          19.052;      // bar [origin=predictive method=joback]
omega       1.0330;      // -   [origin=predictive method=lee-kesler]
Tb          803.66;      // K   [origin=predictive method=joback]
HvapTb      77438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.966 1.3832 -0.0007176 8.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(phenylcarbonyloxy)ethoxy]ethyl benzoate" "diglycol dibenzoate" "di(ethylene glycol) dibenzoate" "benzo flex 2-45" "oxydiethylene dibenzoate" "ethanol, 2,2'-oxybis-, dibenzoate" "benzoyloxyethoxyethyl benzoate" "dibenzoyldiethyleneglycol ester" "polyoxyethylene (2) dibenzoate" "polyethylene glycol 100 dibenzoate" "diethylene glycol, dibenzoate" "benzoic acid, diester with diethylene glycol" );
standardThermochemistry
{
    dHf_298   -708570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     758.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-400240.0
}
