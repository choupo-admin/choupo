/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-diethyl-1,3-dithiolane  (C7H14S2, CAS 26733-25-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Diethyl13Dithiolane;
formula     C7H14S2;
CAS         26733-25-5;
InChIKey    FMCABCBXHDYTHA-UHFFFAOYSA-N;
MW          162.309;      // g/mol [origin=calculated method=formula-sum]
Tc          707.25;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.3111;      // -   [origin=predictive method=lee-kesler]
Tb          470.94;      // K   [origin=predictive method=joback]
HvapTb      41906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.308 1.12126 -0.0010544 4.272e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dithiolane, 2,2-diethyl-" "1,3-dithiolane,2,2-diethyl-" );
standardThermochemistry
{
    dHf_298   -21570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118840.0
}
