/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-phenylenediacrylic acid  (C12H10O4, CAS 16323-43-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pPhenylenediacrylicAcid;
formula     C12H10O4;
CAS         16323-43-6;
InChIKey    AAFXQFIGKBLKMC-UHFFFAOYSA-N;
MW          218.208;      // g/mol [origin=calculated method=formula-sum]
Tc          1042.74;      // K   [origin=predictive method=joback]
Pc          31.847;      // bar [origin=predictive method=joback]
omega       1.2417;      // -   [origin=predictive method=lee-kesler]
Tb          805.16;      // K   [origin=predictive method=joback]
HvapTb      79488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.79 1.147 -0.00090596 2.83e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[4-(3-oxidanyl-3-oxidanylidene-prop-1-enyl)phenyl]prop-2-enoic acid" "2-propenoic acid, 3,3'-(1,4-phenylene)bis-" "3,3'-(p-phenylene)diacrylic acid" "agn-pc-0cjk58" "3,3-(1,4-phenylene)bis-2-propenoic acid" "2-propenoic acid,3,3'-(1,4-phenylene)bis-" "3-[4-(3-hydroxy-3-oxoprop-1-enyl)phenyl]prop-2-enoic acid" );
standardThermochemistry
{
    dHf_298   -532050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-374440.0
}
