/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-6-chloro-4-(trifluoromethyl)aniline  (C7H4BrClF3N, CAS 109919-26-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo6Chloro4TrifluoromethylAniline;
formula     C7H4BrClF3N;
CAS         109919-26-8;
InChIKey    OVJCOPVKCCJSFE-UHFFFAOYSA-N;
MW          274.464;      // g/mol [origin=calculated method=formula-sum]
Tc          801.35;      // K   [origin=predictive method=joback]
Pc          37.592;      // bar [origin=predictive method=joback]
omega       0.6861;      // -   [origin=predictive method=lee-kesler]
Tb          572.08;      // K   [origin=predictive method=joback]
HvapTb      53152.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.89 0.6795 -0.00054328 1.657e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACNH2; count 1; } { group ACCl; count 1; } { group Br; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 3; } { group Cl; count 1; } { group Br; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-6-chloranyl-4-(trifluoromethyl)aniline" "4-amino-3-bromo-5-chlorobenzotrifluoride" "2-bromo-6-chloro-4-trifluoromethylaniline" "2-bromo-6-chloro-4-(trifluoromethyl)phenylamine" "buttpark 44\03-53" "2-bromo-6-chloro-4-(trifluoromethyl)aniline," "benzenamine, 2-bromo-6-chloro-4-(trifluoromethyl)-" );
standardThermochemistry
{
    dHf_298   -538390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-421170.0
}
