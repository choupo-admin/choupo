/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, dimethyl-, polymer with ethenylbenzene and 1-propene tetramer  (C28H42O, CAS 76584-98-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenolDimethylPolymerWithEthenylbenzeneAnd1PropeneTetramer;
formula     C28H42O;
CAS         76584-98-0;
InChIKey    MPFOLCLMYHWHOJ-UHFFFAOYSA-N;
MW          394.643;      // g/mol [origin=calculated method=formula-sum]
Tc          1212.18;      // K   [origin=predictive method=joback]
Pc          8.964;      // bar [origin=predictive method=joback]
omega       0.6603;      // -   [origin=predictive method=lee-kesler]
Tb          969.60;      // K   [origin=predictive method=joback]
HvapTb      94270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (104.14 1.47022 0.00020838 -5.178e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2=CH; count 5; } { group ACH; count 8; } { group AC; count 1; } { group ACCH3; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH2; count 5; } { group dCH; count 5; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethylphenol;ethenylbenzene;prop-1-ene" "styrene, tetrapropylene, dimethylphenol polymer" );
standardThermochemistry
{
    dHf_298   -267920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1569.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160850.0
}
