/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(bromomethyl)tetramethyldisiloxane  (C6H16Br2OSi2, CAS 2351-13-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H16Br2OSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13BisBromomethylTetramethyldisiloxane;
formula     C6H16Br2OSi2;
CAS         2351-13-5;
InChIKey    UPKHMNVQWIFQBW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          320.171;      // g/mol [origin=calculated method=formula-sum]
Tc          708.49;      // K   [origin=predictive method=joback]
Pc          27.326;      // bar [origin=predictive method=joback]
omega       0.4156;      // -   [origin=predictive method=lee-kesler]
Tb          494.42;      // K   [origin=predictive method=joback]
HvapTb      44818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (120.952 0.17468 0.0004952 -3.608e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group Br; count 2; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group Br; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromomethyl-[bromomethyl(dimethyl)silyl]oxy-dimethyl-silane" "bis(bromomethyl)tetramethyldisiloxane" "disiloxane, 1,3-bis(bromomethyl)-1,1,3,3-tetramethyl-" "1,3-bis(bromomethyl)-1,1,3,3-tetramethyldisiloxane" "disiloxane,3-bis(bromomethyl)-1,1,3,3-tetramethyl-" "bromomethyl-[bromomethyl(dimethyl)silyl]oxy-dimethylsilane" "disiloxane,1,3-bis(bromomethyl)-1,1,3,3-tetramethyl-" );
gibbsFormation
{
    dHf_298   -469970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     756.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-286240.0
    phase     gas;
}
