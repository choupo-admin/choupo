/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-fluoro-2-methoxyphenyl)ethanone  (C9H9FO2, CAS 51788-80-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Fluoro2MethoxyphenylEthanone;
formula     C9H9FO2;
CAS         51788-80-8;
InChIKey    YOXBPWVWNQROBJ-UHFFFAOYSA-N;
MW          168.167;      // g/mol [origin=calculated method=formula-sum]
Tc          725.27;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.6033;      // -   [origin=predictive method=lee-kesler]
Tb          517.72;      // K   [origin=predictive method=joback]
HvapTb      47567.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.35 0.58154 -0.00024962 1.336e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3CO; count 1; } { group CH3O; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-fluoranyl-2-methoxy-phenyl)ethanone" "4'-fluoro-2'-methoxyacetophenone" "4-fluoro-2-methoxyacetophenone" "1-(4-fluoro-2-methoxyphenyl)ethan-1-one" "2'-methoxy-4'-fluoroacetophenone" "4'-fluoro-2'-methoxyacetophenone," "1-acetyl-4-fluoro-2-methoxybenzene" "2-methoxy-4-fluoroacetophenone" "1-(4-fluoro-2-methoxy-phenyl)-ethanone" "ethanone,1-(4-fluoro-2-methoxyphenyl)-" "1-(4-fluoro-2-methoxyphenyl)ethanone;4'-fluoro-2'-methoxyacetophenone;" );
standardThermochemistry
{
    dHf_298   -456410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-310680.0
}
