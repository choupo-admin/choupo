/*--------------------------------*- Choupo -*-----------------------*\
  Component: dinonyl phthalate  (C26H42O4, CAS 84-76-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dinonylPhthalate;
formula     C26H42O4;
CAS         84-76-4;
InChIKey    DROMNWUQASBTFM-UHFFFAOYSA-N;
MW          418.618;      // g/mol [origin=calculated method=formula-sum]
Tc          1154.03;      // K   [origin=predictive method=joback]
Pc          8.712;      // bar [origin=predictive method=joback]
omega       0.8424;      // -   [origin=predictive method=lee-kesler]
Tb          942.58;      // K   [origin=predictive method=joback]
HvapTb      91222.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.466 2.22584 -0.00116556 1.846e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dinonyl benzene-1,2-dicarboxylate" "dinonylphthalate" "phthalic acid, dinonyl ester" "nonyl phthalate" "bisoflex dnp" "unimoll dn" "bisolflex 91" "bisoflex 91" "di-n-nonyl phthalate" "1,2-benzenedicarboxylic acid, dinonyl ester" "ditrimethylhexyl phthalate" "di-n-nonylphthalate (dnnp)" );
gibbsFormation
{
    dHf_298   -989470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1158.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-349920.0
    phase     gas;
}
