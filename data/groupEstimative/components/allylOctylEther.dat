/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl octyl ether  (C11H22O, CAS 3295-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylOctylEther;
formula     C11H22O;
CAS         3295-97-4;
InChIKey    IELYMBBIHQDONA-UHFFFAOYSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          635.20;      // K   [origin=predictive method=joback]
Pc          19.771;      // bar [origin=predictive method=joback]
omega       0.5957;      // -   [origin=predictive method=lee-kesler]
Tb          470.38;      // K   [origin=predictive method=joback]
HvapTb      41820.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.398 0.96562 -0.0004865 8.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2=CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-prop-2-enoxyoctane" "allyl n-octyl ether" "1-(allyloxy)octane;" "1-(prop-2-en-1-yloxy)octane" );
gibbsFormation
{
    dHf_298   -277160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24580.0
    phase     gas;
}
