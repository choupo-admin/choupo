/*--------------------------------*- Choupo -*-----------------------*\
  Component: (isopropylidene)bis(4,1-phenyleneoxyethylene) dilaurate  (C43H68O6, CAS 32154-05-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylideneBis41PhenyleneoxyethyleneDilaurate;
formula     C43H68O6;
CAS         32154-05-5;
InChIKey    DPZRLVKUOYEOLE-UHFFFAOYSA-N;
MW          681.011;      // g/mol [origin=calculated method=formula-sum]
Tc          1912.47;      // K   [origin=predictive method=joback]
Pc          4.491;      // bar [origin=predictive method=joback]
omega       -0.2444;      // -   [origin=predictive method=lee-kesler]
Tb          1404.81;      // K   [origin=predictive method=joback]
HvapTb      135526.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.934 3.70188 -0.00200432 3.498e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 20; } { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH2COO; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 24; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-[2-[4-(2-dodecanoyloxyethoxy)phenyl]propan-2-yl]phenoxy]ethyl dodecanoate" "propane-2,2-diylbis(benzene-4,1-diyloxyethane-2,1-diyl) didodecanoate" "dodecanoic acid, (1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyl) ester" "dodecanoic acid, 1,1'-((1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyl)) ester" "dodecanoic acid, 1,1'-[(1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyl)] ester" );
gibbsFormation
{
    dHf_298   -1388480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1692.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-311160.0
    phase     gas;
}
