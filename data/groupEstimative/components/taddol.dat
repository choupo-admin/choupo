/*--------------------------------*- Choupo -*-----------------------*\
  Component: (-)-taddol  (C31H30O4, CAS 93379-48-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        taddol;
formula     C31H30O4;
CAS         93379-48-7;
InChIKey    OWVIRVJQDVCGQX-VSGBNLITSA-N;
MW          466.577;      // g/mol [origin=calculated method=formula-sum]
Tc          1535.75;      // K   [origin=predictive method=joback]
Pc          15.911;      // bar [origin=predictive method=joback]
omega       1.3817;      // -   [origin=predictive method=lee-kesler]
Tb          1253.58;      // K   [origin=predictive method=joback]
HvapTb      131978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-263.23 3.31744 -0.0027132 8.868e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 3; } { group ACH; count 20; } { group AC; count 4; } { group OH; count 2; } { group CH-O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 20; } { group dC_ring; count 4; } { group OH; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(4r,5r)-2,2-dimethyl-5-[oxidanyl(diphenyl)methyl]-1,3-dioxolan-4-yl]-diphenyl-methanol" "taddol" "((4r,5r)-2,2-dimethyl-1,3-dioxolane-4,5-diyl)bis(diphenylmethanol)" "(-)-2,3-o-isopropylidene-1,1,4,4-tetraphenyl-l-threitol" "(-)-trans-alpha,alpha'-(2,2-dimethyl-1,3-dioxolane-4,5-diyl)bis(diphenylmethanol)" "(4r,5r)-2,2-dimethyl-alpha,alpha,alpha',alpha'-tetraphenyldioxolane-4,5-dimethanol" "1,1,4,4-tetraphenyl-2,3-o-isopropylidene-l-threitol" "(-)-2,3-o-isopropylidene-1,1,4,4-tetrphenyl-l-threitol" "(4r,5r)-4,5-bis(diphenylhydroxymethyl)-2,2-dimethyldioxolane" "(-)-4,5-bis[hydroxy(diphenyl)methyl]-2,2-dimethyl-1,3-dioxolane" "(2r,3r)-2,3-o-isopropylidene-1,1,4,4-tetraphenyl-1,2,3,4-butanetetrol" "[(4r,5r)-5-[hydroxy(diphenyl)methyl]-2,2-dimethyl-1,3-dioxolan-4-yl]-diphenylmethanol" );
standardThermochemistry
{
    dHf_298   -287970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     793.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=235220.0
}
