/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylbut-2-en-2-ol  (C5H10O, CAS 34454-78-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylbut2En2Ol;
formula     C5H10O;
CAS         34454-78-9;
InChIKey    BZAZNULYLRVMSW-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          586.39;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       0.6118;      // -   [origin=predictive method=lee-kesler]
Tb          410.10;      // K   [origin=predictive method=joback]
HvapTb      43521.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.93 0.53266 -0.000367 1.091e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group OH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-1-en-1,2-dimethyl-1-ol" "3-methyl-2-buten-2-ol" );
standardThermochemistry
{
    dHf_298   -201120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-82480.0
}
