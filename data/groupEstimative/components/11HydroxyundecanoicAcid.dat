/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11-hydroxyundecanoic acid  (C11H22O3, CAS 3669-80-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11HydroxyundecanoicAcid;
formula     C11H22O3;
CAS         3669-80-5;
InChIKey    KNRCBASNXNXUQQ-UHFFFAOYSA-N;
MW          202.294;      // g/mol [origin=calculated method=formula-sum]
Tc          864.32;      // K   [origin=predictive method=joback]
Pc          22.828;      // bar [origin=predictive method=joback]
omega       1.3706;      // -   [origin=predictive method=lee-kesler]
Tb          688.97;      // K   [origin=predictive method=joback]
HvapTb      73923.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.78 1.1336 -0.0006776 1.575e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-oxidanylundecanoic acid" "11-hydroxy-undecanoic acid" "11-hydroxyundecanoicacid" "undecanoic acid,11-hydroxy-" "omega-hydroxy hendecanoic acid" "undecanoic acid, 11-hydroxy-" );
standardThermochemistry
{
    dHf_298   -772870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     688.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-438990.0
}
