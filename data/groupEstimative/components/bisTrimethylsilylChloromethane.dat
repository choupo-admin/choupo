/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(trimethylsilyl)chloromethane  (C7H19ClSi2, CAS 5926-35-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H19ClSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bisTrimethylsilylChloromethane;
formula     C7H19ClSi2;
CAS         5926-35-2;
InChIKey    XNJGZHVYPBNLEB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          194.849;      // g/mol [origin=calculated method=formula-sum]
Tc          588.30;      // K   [origin=predictive method=joback]
Pc          21.453;      // bar [origin=predictive method=joback]
omega       0.2001;      // -   [origin=predictive method=lee-kesler]
Tb          399.55;      // K   [origin=predictive method=joback]
HvapTb      35761.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (89.37 0.26922 0.000449 -3.538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CHCl; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[chloranyl(trimethylsilyl)methyl]-trimethyl-silane" "(chloromethanediyl)bis(trimethylsilane)" "chlorobis(trimethylsilyl)methane" "bis(trimethylsilyl)methyl chloride" "silane, (chloromethylene)bis[trimethyl-" "[chloro(trimethylsilyl)methyl]-trimethylsilane" "silane,1,1'-(chloromethylene)bis[1,1,1-trimethyl-" );
standardThermochemistry
{
    dHf_298   -432070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     705.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-215830.0
}
