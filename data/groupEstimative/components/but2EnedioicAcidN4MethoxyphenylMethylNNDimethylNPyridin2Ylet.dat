/*--------------------------------*- Choupo -*-----------------------*\
  Component: but-2-enedioic acid; n'-[(4-methoxyphenyl)methyl]-n,n-dimethyl-n'-pyridin-2-ylethane-1,2-diamine  (C21H27N3O5, CAS 59-33-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        but2EnedioicAcidN4MethoxyphenylMethylNNDimethylNPyridin2Ylet;
formula     C21H27N3O5;
CAS         59-33-6;
InChIKey    JXYWFNAQESKDNC-UHFFFAOYSA-N;
MW          401.463;      // g/mol [origin=calculated method=formula-sum]
Tc          1392.52;      // K   [origin=predictive method=joback]
Pc          16.458;      // bar [origin=predictive method=joback]
omega       1.4041;      // -   [origin=predictive method=lee-kesler]
Tb          1136.00;      // K   [origin=predictive method=joback]
HvapTb      114840.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.697 1.91532 -0.00105162 1.728e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } { group C5H4N; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group O; count 1; } { group COOH; count 2; } { group N; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-2-enedioic acid;n'-[(4-methoxyphenyl)methyl]-n,n-dimethyl-n'-pyridin-2-yl-ethane-1,2-diamine" "1,2-ethanediamine, n1-[(4-methoxyphenyl)methyl]-n2,n2-dimethyl-n1-2-pyridinyl-, (2z)-2-butenedioate (1:1);anthisan;histosol;n-(4-methoxybenzyl)-n',n'-dimethyl-n-(2-pyridinyl)-1,2-ethanediamine (2z)-2-butenedioate (1:1);n-(4-methoxybenzyl)-n',n'-dimethyl-n-(pyridin-2-yl)ethane-1,2-diamine (2z)-but-2-enedioate (1:1);n-(4-methoxybenzyl)-n',n'-dimethyl-n-pyridin-2-ylethane-1,2-diamine (2z)-but-2-enedioate;n-[(4-methoxyphenyl)methyl]-n',n'-dimethyl-n-2-pyridinyl-1,2-ethanediamine (2z)-2-butenedioate (1:1);n-p-methoxybenzyl-n',n'-dimethyl-n-a-pyridylethylenediamine maleate;thylogen;" );
standardThermochemistry
{
    dHf_298   -674490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1018.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-177620.0
}
