/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxy-n,n-dimethylpropanamide  (C6H13NO2, CAS 53185-52-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethoxyNNDimethylpropanamide;
formula     C6H13NO2;
CAS         53185-52-7;
InChIKey    LBVMWHCOFMFPEG-UHFFFAOYSA-N;
MW          131.175;      // g/mol [origin=calculated method=formula-sum]
Tc          601.62;      // K   [origin=predictive method=joback]
Pc          32.653;      // bar [origin=predictive method=joback]
omega       0.5665;      // -   [origin=predictive method=lee-kesler]
Tb          425.61;      // K   [origin=predictive method=joback]
HvapTb      40149.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.602 0.60656 -0.0002855 3.376e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3O; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group O; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxy-n,n-dimethyl-propanamide" "propanamide, 3-methoxy-n,n-dimethyl-" "3-methoxy-n,n-dimethylpropionamide" "3-methoxy-n,n-dimethyl-propionamide" );
gibbsFormation
{
    dHf_298   -344440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-123500.0
    phase     gas;
}
