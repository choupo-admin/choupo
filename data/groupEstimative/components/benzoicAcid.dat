/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid  (C7H6O2, CAS 65-85-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid;
formula     C7H6O2;
CAS         65-85-0;
InChIKey    WPYMKLBDIGXBTP-UHFFFAOYSA-N;
MW          122.123;      // g/mol [origin=calculated method=formula-sum]
Tc          764.70;      // K   [origin=predictive method=joback]
Pc          46.277;      // bar [origin=predictive method=joback]
omega       0.6233;      // -   [origin=predictive method=lee-kesler]
Tb          531.95;      // K   [origin=predictive method=joback]
HvapTb      50616.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.78 0.6407 -0.0004608 1.256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dracylic acid" "benzeneformic acid" "benzenecarboxylic acid" "phenylformic acid" "carboxybenzene" "benzenemethanoic acid" "phenylcarboxylic acid" "retardex" "benzoesaeure gk" "benzoesaeure gv" "retarder ba" "tenn-plas" );
standardThermochemistry
{
    dHf_298   -301550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-223440.0
}
