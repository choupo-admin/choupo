/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl retinamide  (C22H33NO, CAS 33631-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylRetinamide;
formula     C22H33NO;
CAS         33631-41-3;
InChIKey    WKYDOCGICAMTKE-NBIQJRODSA-N;
MW          327.512;      // g/mol [origin=calculated method=formula-sum]
Tc          1072.18;      // K   [origin=predictive method=joback]
Pc          12.939;      // bar [origin=predictive method=joback]
omega       0.8928;      // -   [origin=predictive method=lee-kesler]
Tb          852.31;      // K   [origin=predictive method=joback]
HvapTb      78634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.289 2.46092 -0.0020095 7.0726e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 3; } { group C; count 1; } { group CH=CH; count 2; } { group CH=C; count 2; } { group C=C; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group dCH; count 6; } { group dC; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2e,4e,6e,8e)-n-ethyl-3,7-dimethyl-9-(2,6,6-trimethylcyclohexen-1-yl)nona-2,4,6,8-tetraenamide" "n-ethylretinamide" "n-ethyl retinamide" "retinamide, n-ethyl-" "retinoic acid ethyl amide" "vitamin a acid ethylamide" "all-trans-n-ethylretinamide" "retinamide, n-ethyl-, all-trans-" "(2z,4e,6e,8e)-n-ethyl-3,7-dimethyl-9-(2,6,6-trimethyl-1-cyclohexenyl)nona-2,4,6,8-tetraenamide" );
gibbsFormation
{
    dHf_298   -2820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1034.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=428270.0
    phase     gas;
}
