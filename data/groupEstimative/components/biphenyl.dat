/*--------------------------------*- Choupo -*-----------------------*\
  Component: biphenyl  (C12H10, CAS 92-52-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        biphenyl;
formula     C12H10;
CAS         92-52-4;
InChIKey    ZUOUZKKEUPVFJK-UHFFFAOYSA-N;
MW          154.212;      // g/mol [origin=calculated method=formula-sum]
Tc          777.48;      // K   [origin=predictive method=joback]
Pc          34.279;      // bar [origin=predictive method=joback]
omega       0.3766;      // -   [origin=predictive method=lee-kesler]
Tb          527.52;      // K   [origin=predictive method=joback]
HvapTb      46858.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.83 0.986 -0.0006914 1.826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1'-biphenyl" "1,1′-biphenyl" "1,1′-diphenyl" "bibenzene" "carolid al" "diphenyl" "phenylbenzene" "tetrosin ly" "1,1'-diphenyl" "xenene" "phenador-x" "lemonene" );
gibbsFormation
{
    dHf_298   182050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=274980.0
    phase     gas;
}
