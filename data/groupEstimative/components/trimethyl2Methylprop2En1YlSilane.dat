/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethyl(2-methylprop-2-en-1-yl)silane  (C7H16Si, CAS 18292-38-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethyl2Methylprop2En1YlSilane;
formula     C7H16Si;
CAS         18292-38-1;
InChIKey    OWVJMAKUWHECNI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          128.29;      // g/mol [origin=calculated method=formula-sum]
Tc          534.55;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       0.2164;      // -   [origin=predictive method=lee-kesler]
Tb          357.72;      // K   [origin=predictive method=joback]
HvapTb      30880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.661 0.44258 3.26e-05 -1.259e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH2=C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(2-methylprop-2-enyl)silane" "methallyltrimethylsilane" "silane, trimethyl(2-methyl-2-propenyl)-" "(2-methyl-allyl)trimethylsilane" "silane,trimethyl(2-methyl-2-propen-1-yl)-" );
gibbsFormation
{
    dHf_298   -183790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17410.0
    phase     gas;
}
