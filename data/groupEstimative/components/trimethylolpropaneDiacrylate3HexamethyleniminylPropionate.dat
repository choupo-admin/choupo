/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolpropane diacrylate 3-(hexamethyleniminyl)propionate  (C21H33NO6, CAS 73003-78-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolpropaneDiacrylate3HexamethyleniminylPropionate;
formula     C21H33NO6;
CAS         73003-78-8;
InChIKey    HZGOAUDVKRQMPN-UHFFFAOYSA-N;
MW          395.496;      // g/mol [origin=calculated method=formula-sum]
Tc          1087.49;      // K   [origin=predictive method=joback]
Pc          12.056;      // bar [origin=predictive method=joback]
omega       1.0460;      // -   [origin=predictive method=lee-kesler]
Tb          881.53;      // K   [origin=predictive method=joback]
HvapTb      84706.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.664 2.19272 -0.0013014 2.493e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group C; count 1; } { group CH2=CH; count 2; } { group CH2COO; count 1; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 6; } { group COO; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(prop-2-enoyloxymethyl)butyl 3-(azepan-1-yl)propanoate" "1h-azepine-1-propanoic acid, hexahydro-, 2,2-bis(((1-oxo-2-propen-1-yl)oxy)methyl)butyl ester" "1h-azepine-1-propanoic acid, hexahydro-, 2,2-bis[[(1-oxo-2-propen-1-yl)oxy]methyl]butyl ester" "1h-azepine-1-propanoic acid, hexahydro-, 2,2-bis(((1-oxo-2-propenyl)oxy)methyl)butyl ester" );
standardThermochemistry
{
    dHf_298   -1044310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1107.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-483710.0
}
