/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylene glycol diallyl ether  (C8H14O2, CAS 7529-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyleneGlycolDiallylEther;
formula     C8H14O2;
CAS         7529-27-3;
InChIKey    CARNFEUGBMWTON-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          591.69;      // K   [origin=predictive method=joback]
Pc          26.680;      // bar [origin=predictive method=joback]
omega       0.5039;      // -   [origin=predictive method=lee-kesler]
Tb          420.84;      // K   [origin=predictive method=joback]
HvapTb      36882.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.634 0.5974 -0.0002352 9.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 2; } { group dCH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-prop-2-enoxyethoxy)prop-1-ene" "1,2-bis(2-propenyloxy)ethane" "1-propene, 3,3'-[1,2-ethanediylbis(oxy)]bis-" "ethylene glycol, diallyl ether" "3,3'-(1,2-ethanediylbis(oxy))dipropene" "1-propene, 3,3'-(1,2-ethanediylbis(oxy))bis-" "diallylether ethylenglykolu" "1,2-bis(allyloxy) ethane" "1-propene,3,3'-[1,2-ethanediylbis(oxy)]bis-" "ethane,1,2-bis(allyloxy)- (6ci,7ci,8ci); 1,2-bis(allyloxy)ethane;1,2-diallyloxyethane; 3,3'-[1,2-ethanediylbis(oxy)]bis[1-propene];4,7-dioxa-1,9-decadiene; ethylene glycol diallyl ether; ethylidene diallylether" );
gibbsFormation
{
    dHf_298   -222030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17840.0
    phase     gas;
}
