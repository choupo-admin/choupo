/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylphenethylamine  (C9H13N, CAS 589-08-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylphenethylamine;
formula     C9H13N;
CAS         589-08-2;
InChIKey    SASNBVQSOZSTPD-UHFFFAOYSA-N;
MW          135.21;      // g/mol [origin=calculated method=formula-sum]
Tc          691.84;      // K   [origin=predictive method=joback]
Pc          33.106;      // bar [origin=predictive method=joback]
omega       0.4933;      // -   [origin=predictive method=lee-kesler]
Tb          482.37;      // K   [origin=predictive method=joback]
HvapTb      44340.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.408 0.85612 -0.0005456 1.319e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-2-phenyl-ethanamine" "phenethylamine, n-methyl-" "n-methyl-2-phenylethanamine" "n-methyl-2-phenylethylamine" "benzeneethanamine, n-methyl-" "n-methyl-phenethylamine" "1-phenyl-2-methylaminoethane" "methyl-phenethyl-amine" "n-methyl-n-(2-phenylethyl)amine" "methyl(2-phenylethyl)amine" "n-methyl-beta-phenylethylamine" "1-phenyl-2-methylamino-aethan" );
gibbsFormation
{
    dHf_298   60910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=226700.0
    phase     gas;
}
