/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyltrimethoxysilane  (C5H12O3Si, CAS 2768-02-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H12O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        vinyltrimethoxysilane;
formula     C5H12O3Si;
CAS         2768-02-7;
InChIKey    NKSJNEHGWDZZQF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          148.233;      // g/mol [origin=calculated method=formula-sum]
Tc          555.29;      // K   [origin=predictive method=joback]
Pc          29.959;      // bar [origin=predictive method=joback]
omega       0.3543;      // -   [origin=predictive method=lee-kesler]
Tb          379.34;      // K   [origin=predictive method=joback]
HvapTb      33578.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (112.67 0.06306 0.0004767 -3.159e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH3O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl(trimethoxy)silane" "trimethoxyvinylsilane" "silane, ethenyltrimethoxy-" "ethenyltrimethoxysilane" "trimethoxy(vinyl)silane" "(trimethoxysilyl)ethene" "vinyl trimethoxy silane" "vts-m" "(trimethoxysilyl)ethylene" "silane, trimethoxyvinyl-" "a 171 (silane derivative)" "ethenyl-trimethoxysilane" );
standardThermochemistry
{
    dHf_298   -529380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-340700.0
}
