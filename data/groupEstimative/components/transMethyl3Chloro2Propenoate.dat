/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-methyl 3-chloro-2-propenoate  (C4H5ClO2, CAS 5135-18-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        transMethyl3Chloro2Propenoate;
formula     C4H5ClO2;
CAS         5135-18-2;
InChIKey    ZLDNFLVIPPOXQL-UHFFFAOYSA-N;
MW          120.532;      // g/mol [origin=calculated method=formula-sum]
Tc          584.04;      // K   [origin=predictive method=joback]
Pc          39.956;      // bar [origin=predictive method=joback]
omega       0.3749;      // -   [origin=predictive method=lee-kesler]
Tb          390.93;      // K   [origin=predictive method=joback]
HvapTb      36248.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.37 0.35582 -0.0002034 3.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group Cl_C=C_; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-chloranylprop-2-enoate" "methyl chloroacrylate" "2-propenoic acid, 3-chloro-, methyl ester" "2-propenoic acid, 3-chloro-, methyl ester, (2z)-" );
standardThermochemistry
{
    dHf_298   -341690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-259280.0
}
