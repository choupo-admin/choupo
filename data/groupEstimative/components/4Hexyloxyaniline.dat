/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hexyloxyaniline  (C12H19NO, CAS 39905-57-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hexyloxyaniline;
formula     C12H19NO;
CAS         39905-57-2;
InChIKey    DJRKHTCUXRGYEU-UHFFFAOYSA-N;
MW          193.29;      // g/mol [origin=calculated method=formula-sum]
Tc          808.41;      // K   [origin=predictive method=joback]
Pc          24.654;      // bar [origin=predictive method=joback]
omega       0.7431;      // -   [origin=predictive method=lee-kesler]
Tb          600.77;      // K   [origin=predictive method=joback]
HvapTb      58295.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.365 1.00412 -0.00052556 8.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-hexoxyaniline" "4-(hexyloxy)aniline" "p-hexyloxyaniline" "benzenamine, 4-(hexyloxy)-" "(p-hexyloxy)aniline" "4-(hexyloxy)benzenamine" "aniline, (p-hexyloxy)-" "4-hexyloxyphenylamine" "p-hexyl-oxyaniline" "(4-hexoxy-phenyl)-amine" "benzenamine,4-(hexyloxy)-" "4-hexyloxyaniline  (nominal conc.)" );
standardThermochemistry
{
    dHf_298   -164380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114390.0
}
