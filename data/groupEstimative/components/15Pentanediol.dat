/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-pentanediol  (C5H12O2, CAS 111-29-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Pentanediol;
formula     C5H12O2;
CAS         111-29-5;
InChIKey    ALQSHHUCVQOPAS-UHFFFAOYSA-N;
MW          104.149;      // g/mol [origin=calculated method=formula-sum]
Tc          656.34;      // K   [origin=predictive method=joback]
Pc          43.626;      // bar [origin=predictive method=joback]
omega       1.2676;      // -   [origin=predictive method=lee-kesler]
Tb          498.36;      // K   [origin=predictive method=joback]
HvapTb      60082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.925 0.5468 -0.000309 6.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentane-1,5-diol" "pentamethylene glycol" "pentylene glycol" "1,5-dihydroxypentane" "1,5-pentylene glycol" "1,5-pentamethylene glycol" ".alpha.,.omega.-pentanediol" "alpha,omega-pentanediol" ".omega.-pentanediol" );
gibbsFormation
{
    dHf_298   -450990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-282420.0
    phase     gas;
}
