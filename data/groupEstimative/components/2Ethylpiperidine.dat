/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylpiperidine  (C7H15N, CAS 1484-80-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethylpiperidine;
formula     C7H15N;
CAS         1484-80-6;
InChIKey    QBBKKFZGCDJDQK-UHFFFAOYSA-N;
MW          113.204;      // g/mol [origin=calculated method=formula-sum]
Tc          639.44;      // K   [origin=predictive method=joback]
Pc          36.290;      // bar [origin=predictive method=joback]
omega       0.3383;      // -   [origin=predictive method=lee-kesler]
Tb          427.86;      // K   [origin=predictive method=joback]
HvapTb      38363.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.159 0.77752 -0.0003774 4.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperidine, 2-ethyl-" ".alpha.-ethylpiperidine" "2-ethylpiperidin" "2-ethyl-piperidine" "alpha-ethylpiperidine" "u502" );
gibbsFormation
{
    dHf_298   -95680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120220.0
    phase     gas;
}
