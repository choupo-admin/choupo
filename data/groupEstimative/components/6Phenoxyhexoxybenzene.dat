/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-phenoxyhexoxybenzene  (C18H22O2, CAS 10125-18-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Phenoxyhexoxybenzene;
formula     C18H22O2;
CAS         10125-18-5;
InChIKey    BLBMCHWSWYHXFF-UHFFFAOYSA-N;
MW          270.372;      // g/mol [origin=calculated method=formula-sum]
Tc          926.15;      // K   [origin=predictive method=joback]
Pc          18.611;      // bar [origin=predictive method=joback]
omega       0.8139;      // -   [origin=predictive method=lee-kesler]
Tb          709.64;      // K   [origin=predictive method=joback]
HvapTb      65034.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.284 1.4296 -0.0007958 1.444e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1'-[hexane-1,6-diylbis(oxy)]dibenzene" "benzene,1,1'-[1,6-hexanediylbis(oxy)]bis-" "benzene, 1,1'-(1,6-hexanediylbis(oxy))bis-" );
gibbsFormation
{
    dHf_298   -206230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     666.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=115500.0
    phase     gas;
}
