/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxyphenyl acetate  (C9H10O3, CAS 1200-06-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethoxyphenylAcetate;
formula     C9H10O3;
CAS         1200-06-2;
InChIKey    YAPCNXGBNRDBIW-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          730.12;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       0.5664;      // -   [origin=predictive method=lee-kesler]
Tb          517.82;      // K   [origin=predictive method=joback]
HvapTb      48383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.01 0.60244 -0.00022436 -1.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methoxyphenyl) ethanoate" "p-acetoxyanisole" "p-methoxyphenyl acetate" "phenol, 4-methoxy-, acetate" "phenol, p-methoxy-, acetate" "(4-methoxyphenyl) acetate" "acetic acid 4-methoxy-phenyl ester" "acetic acid (4-methoxyphenyl) ester" "phenol, p-methoxy-, acetate (8ci)" "benzenemethanol,ar-methoxy-, 1-acetate" "o306" "benzenemethanol,ar-methoxy-, acetate (9ci); benzyl alcohol, ar-methoxy-, acetate (8ci); anisylacetate" );
standardThermochemistry
{
    dHf_298   -453530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-287690.0
}
