/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxy-4-methyl-5-propylfuran-2(5h)-one  (C8H12O3, CAS 28664-37-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hydroxy4Methyl5Propylfuran25hOne;
formula     C8H12O3;
CAS         28664-37-1;
InChIKey    RSJIVJVBFQHLPW-UHFFFAOYSA-N;
MW          156.181;      // g/mol [origin=calculated method=formula-sum]
Tc          729.39;      // K   [origin=predictive method=joback]
Pc          32.541;      // bar [origin=predictive method=joback]
omega       1.0044;      // -   [origin=predictive method=lee-kesler]
Tb          548.90;      // K   [origin=predictive method=joback]
HvapTb      59017.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.452 0.71894 -0.0004206 9.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH_ring; count 1; } { group dC_ring; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-4-oxidanyl-2-propyl-2h-furan-5-one" "2(5h)-furanone, 3-hydroxy-4-methyl-5-propyl-" "4-hydroxy-3-methyl-2-propyl-2h-furan-5-one" "2(5h)-furanone,3-hydroxy-4-methyl-5-propyl-" "3-methyl-4-propyl-2-hydroxy-2-butan-1,4-olide" );
gibbsFormation
{
    dHf_298   -570320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-359260.0
    phase     gas;
}
