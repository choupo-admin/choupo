/*--------------------------------*- Choupo -*-----------------------*\
  Component: denudatine  (C22H33NO2, CAS 26166-37-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        denudatine;
formula     C22H33NO2;
CAS         26166-37-0;
InChIKey    OVXLNQAYPUEDSI-UQSSLJFWSA-N;
MW          343.511;      // g/mol [origin=calculated method=formula-sum]
Tc          1136.24;      // K   [origin=predictive method=joback]
Pc          18.170;      // bar [origin=predictive method=joback]
omega       1.4084;      // -   [origin=predictive method=lee-kesler]
Tb          921.40;      // K   [origin=predictive method=joback]
HvapTb      94915.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-422.599 3.84334 -0.0039514 1.6555e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 7; } { group C; count 3; } { group CH2=C; count 1; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 7; } { group C_ring; count 3; } { group dC_ring; count 1; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "16,17-didehydro-21-ethyl-4-methyl-7,20-cycloatidane-11-beta,15-beta-diol" "7,20-cycloatidane-11,15-diol, 16,17-didehydro-21-ethyl-4-methyl-, (11-beta,15-beta)-" );
standardThermochemistry
{
    dHf_298   -248940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=341770.0
}
