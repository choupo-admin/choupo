/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylcapricamide  (C11H23NO, CAS 23220-25-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylcapricamide;
formula     C11H23NO;
CAS         23220-25-9;
InChIKey    OJNCCSNXHKTDGS-UHFFFAOYSA-N;
MW          185.311;      // g/mol [origin=calculated method=formula-sum]
Tc          729.44;      // K   [origin=predictive method=joback]
Pc          20.699;      // bar [origin=predictive method=joback]
omega       0.8277;      // -   [origin=predictive method=lee-kesler]
Tb          555.32;      // K   [origin=predictive method=joback]
HvapTb      53262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.962 1.09704 -0.0006045 1.2116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyldecanamide" "decanamide, n-methyl-" );
standardThermochemistry
{
    dHf_298   -329480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     651.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=2210.0
}
