/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylresorcinol  (C7H8O2, CAS 608-25-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylresorcinol;
formula     C7H8O2;
CAS         608-25-3;
InChIKey    ZTMADXFOCUXMJE-UHFFFAOYSA-N;
MW          124.139;      // g/mol [origin=calculated method=formula-sum]
Tc          791.14;      // K   [origin=predictive method=joback]
Pc          62.888;      // bar [origin=predictive method=joback]
omega       0.7236;      // -   [origin=predictive method=lee-kesler]
Tb          547.68;      // K   [origin=predictive method=joback]
HvapTb      59480.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.22 0.89912 -0.00090092 3.638e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbenzene-1,3-diol" "2,6-dihydroxytoluene" "1,3-benzenediol, 2-methyl-" "resorcinol, 2-methyl-" "2-methylresorcin" "2-methyl-1,3-benzenediol" "toluene-2,6-diol" "1,3-dihydroxy-2-methylbenzene" "2-methyl-1,3-dihydroxybenzene" "2-methyl resorcinol" "1,3-benzenediol, methyl-" "2-methyl-benzene-1,3-diol" );
gibbsFormation
{
    dHf_298   -305900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-188770.0
    phase     gas;
}
