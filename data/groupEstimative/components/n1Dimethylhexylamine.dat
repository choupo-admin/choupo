/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,1-dimethylhexylamine  (C8H19N, CAS 540-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n1Dimethylhexylamine;
formula     C8H19N;
CAS         540-43-2;
InChIKey    BGWFQRDYRSCOCO-UHFFFAOYSA-N;
MW          129.247;      // g/mol [origin=calculated method=formula-sum]
Tc          604.51;      // K   [origin=predictive method=joback]
Pc          25.899;      // bar [origin=predictive method=joback]
omega       0.5213;      // -   [origin=predictive method=lee-kesler]
Tb          432.37;      // K   [origin=predictive method=joback]
HvapTb      39450.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.276 0.84596 -0.0004632 9.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methylheptan-2-amine" "pacamine" "neosupranol" "oenethyl" "methylaminoheptane" "2-heptylmethylamine" "2-methylaminoheptane" "2-heptanamine, n-methyl-" "hexylamine, n,1-dimethyl-" "hexylamine,1-dimethyl-" "2-heptanamine,n-methyl-" "2-heptanamine, n-methyl- (9ci)" );
standardThermochemistry
{
    dHf_298   -160260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103430.0
}
