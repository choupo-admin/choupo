/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylthiane  (C6H12S, CAS 5161-17-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylthiane;
formula     C6H12S;
CAS         5161-17-1;
InChIKey    MCSVISNPQJAWJX-UHFFFAOYSA-N;
MW          116.222;      // g/mol [origin=calculated method=formula-sum]
Tc          626.60;      // K   [origin=predictive method=joback]
Pc          39.308;      // bar [origin=predictive method=joback]
omega       0.2279;      // -   [origin=predictive method=lee-kesler]
Tb          404.26;      // K   [origin=predictive method=joback]
HvapTb      35191.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.35 0.71033 -0.0004023 7.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2h-thiopyran, tetrahydro-4-methyl-" "thiopyran, tetrahydro-4-methyl-" );
gibbsFormation
{
    dHf_298   -67590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63950.0
    phase     gas;
}
