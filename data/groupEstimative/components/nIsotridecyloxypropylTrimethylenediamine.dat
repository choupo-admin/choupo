/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-isotridecyloxypropyl trimethylenediamine  (C19H42N2O, CAS 151789-07-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nIsotridecyloxypropylTrimethylenediamine;
formula     C19H42N2O;
CAS         151789-07-0;
InChIKey    YZGGABQGIYPLRM-UHFFFAOYSA-N;
MW          314.558;      // g/mol [origin=calculated method=formula-sum]
Tc          958.66;      // K   [origin=predictive method=joback]
Pc          11.253;      // bar [origin=predictive method=joback]
omega       1.0140;      // -   [origin=predictive method=lee-kesler]
Tb          779.00;      // K   [origin=predictive method=joback]
HvapTb      76987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.716 1.88964 -0.000994 1.811e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 1; } { group CH2O; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group CH; count 1; } { group O; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-[3-(11-methyldodecoxy)propyl]propane-1,3-diamine" "c13 branched alkoxypropyleneaminepropyleneamine" "branched(c13)alkyl alkoxypropyleneamine propyleneamine" "1,3-propanediamine, n-(3-(tridecyloxy)propyl)-, branched" "n-{3-[(11-methyldodecyl)oxy]propyl}propane-1,3-diamine" "1,3-propanediamine, n1-(3-(tridecyloxy)propyl)-, branched" "1,3-propanediamine, n-[3-(c11-14-isoalkyloxy)propyl] derivs., c13-rich" "n-(3-(isotridecyloxy)propyl)propane-1,3-diamine" "n-[3-(isotridecyloxy)propyl]propane-1,3-diamine" );
gibbsFormation
{
    dHf_298   -485730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     990.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157500.0
    phase     gas;
}
