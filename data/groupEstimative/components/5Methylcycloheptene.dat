/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methylcycloheptene  (C8H14, CAS 2505-06-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methylcycloheptene;
formula     C8H14;
CAS         2505-06-8;
InChIKey    ASLRNQBBLPDZET-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          617.41;      // K   [origin=predictive method=joback]
Pc          33.802;      // bar [origin=predictive method=joback]
omega       0.2421;      // -   [origin=predictive method=lee-kesler]
Tb          405.62;      // K   [origin=predictive method=joback]
HvapTb      34295.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.33 0.82032 -0.00043328 6.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloheptene, 5-methyl-" );
gibbsFormation
{
    dHf_298   -102510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58790.0
    phase     gas;
}
