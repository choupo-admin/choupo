/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-benzenetetracarboxylic acid  (C10H6O8, CAS 476-73-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234BenzenetetracarboxylicAcid;
formula     C10H6O8;
CAS         476-73-3;
InChIKey    GCAIEATUVJFSMC-UHFFFAOYSA-N;
MW          254.15;      // g/mol [origin=calculated method=formula-sum]
Tc          1301.65;      // K   [origin=predictive method=joback]
Pc          42.386;      // bar [origin=predictive method=joback]
omega       2.0887;      // -   [origin=predictive method=lee-kesler]
Tb          1052.06;      // K   [origin=predictive method=joback]
HvapTb      110772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.19 0.8996 -0.00064068 1.706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,2,3,4-tetracarboxylic acid" "mellophanicacid" "benzenetetracarboxylic acid" "1,2,3,4-benzenetetracarboxylicacid" "1,2,3,4-benzene-tetracarboxylic acid" );
standardThermochemistry
{
    dHf_298   -1448690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1258800.0
}
