/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tetradecylmorpholine  (C18H37NO, CAS 25727-93-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Tetradecylmorpholine;
formula     C18H37NO;
CAS         25727-93-9;
InChIKey    JMJDXDJTXDRLAL-UHFFFAOYSA-N;
MW          283.5;      // g/mol [origin=calculated method=formula-sum]
Tc          846.44;      // K   [origin=predictive method=joback]
Pc          13.281;      // bar [origin=predictive method=joback]
omega       0.8822;      // -   [origin=predictive method=lee-kesler]
Tb          670.78;      // K   [origin=predictive method=joback]
HvapTb      62781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.267 1.99292 -0.0012369 2.994e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "morpholine, 4-tetradecyl-" );
gibbsFormation
{
    dHf_298   -398500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     813.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=169600.0
    phase     gas;
}
