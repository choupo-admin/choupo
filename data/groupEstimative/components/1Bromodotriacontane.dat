/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromodotriacontane  (C32H65Br, CAS 7596-92-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromodotriacontane;
formula     C32H65Br;
CAS         7596-92-1;
InChIKey    PZSASMNKSUOEOD-UHFFFAOYSA-N;
MW          529.776;      // g/mol [origin=calculated method=formula-sum]
Tc          1247.87;      // K   [origin=predictive method=joback]
Pc          5.613;      // bar [origin=predictive method=joback]
omega       0.2806;      // -   [origin=predictive method=lee-kesler]
Tb          997.92;      // K   [origin=predictive method=joback]
HvapTb      93261.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.009 3.08202 -0.0017884 4.037e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 31; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 31; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyldotriacontane" "dotriacontane, 1-bromo-" );
standardThermochemistry
{
    dHf_298   -677480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1453.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=232880.0
}
