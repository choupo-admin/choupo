/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentene  (C5H8, CAS 142-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentene;
formula     C5H8;
CAS         142-29-0;
InChIKey    LPIQUOYDBNQMRZ-UHFFFAOYSA-N;
MW          68.119;      // g/mol [origin=calculated method=formula-sum]
Tc          531.60;      // K   [origin=predictive method=joback]
Pc          47.628;      // bar [origin=predictive method=joback]
omega       0.1910;      // -   [origin=predictive method=lee-kesler]
Tb          333.11;      // K   [origin=predictive method=joback]
HvapTb      27582.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.3 0.581 -0.00041828 1.202e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclopentene" );
standardThermochemistry
{
    dHf_298   -7930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     305.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65440.0
}
