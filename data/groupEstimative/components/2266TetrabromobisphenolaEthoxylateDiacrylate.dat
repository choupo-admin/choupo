/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2',6,6'-tetrabromobisphenola ethoxylate diacrylate  (C25H24Br4O6, CAS 104504-33-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2266TetrabromobisphenolaEthoxylateDiacrylate;
formula     C25H24Br4O6;
CAS         104504-33-8;
InChIKey    OOGPFCFGQOSOOZ-UHFFFAOYSA-N;
MW          740.077;      // g/mol [origin=calculated method=formula-sum]
Tc          1556.01;      // K   [origin=predictive method=joback]
Pc          13.809;      // bar [origin=predictive method=joback]
omega       1.2614;      // -   [origin=predictive method=lee-kesler]
Tb          1270.89;      // K   [origin=predictive method=joback]
HvapTb      122506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (102.274 1.86664 -0.00108836 2.072e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH2=CH; count 2; } { group ACH; count 4; } { group AC; count 8; } { group CH2O; count 2; } { group Br; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group Br; count 4; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-[2-[3,5-bis(bromanyl)-4-(2-prop-2-enoyloxyethoxy)phenyl]propan-2-yl]-2,6-bis(bromanyl)phenoxy]ethyl prop-2-enoate" "tetrabromobisphenol a bis(2-hydroxyethyl) ether bis(acrylate)" "2-propenoic acid, 1,1'-((1-methylethylidene)bis((2,6-dibromo-4,1-phenylene)oxy-2,1-ethanediyl)) ester" "2-propenoic acid, 1,1'-[(1-methylethylidene)bis[(2,6-dibromo-4,1-phenylene)oxy-2,1-ethanediyl]] ester" "bis(p-acryloxyethoxy)tetrabromobisphenol a" "acrylic acid, isopropylidenebis((2,6-dibromo-p-phenylene)oxyethylene) ester" "(1-methylethylidene)bis((2,6-dibromo-4,1-phenylene)oxy-2,1-ethanediyl) diacrylate" "propane-2,2-diylbis[(2,6-dibromobenzene-4,1-diyl)oxyethane-2,1-diyl] bisprop-2-enoate" "2-[2,6-dibromo-4-[2-[3,5-dibromo-4-(2-prop-2-enoyloxyethoxy)phenyl]propan-2-yl]phenoxy]ethyl prop-2-enoate" "2-propenoic acid, (1-methylethylidene)bis((2,6-dibromo-4,1-phenylene)oxy-2,1-ethanediyl) ester" );
standardThermochemistry
{
    dHf_298   -706660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1161.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-268280.0
}
