/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenetole, 2,4,5-trichloro-  (C8H7Cl3O, CAS 6851-44-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenetole245Trichloro;
formula     C8H7Cl3O;
CAS         6851-44-1;
InChIKey    XMLUZDBYNTZUSI-UHFFFAOYSA-N;
MW          225.493;      // g/mol [origin=calculated method=formula-sum]
Tc          787.85;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.5430;      // -   [origin=predictive method=lee-kesler]
Tb          558.97;      // K   [origin=predictive method=joback]
HvapTb      53229.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.781 0.46362 -0.00019168 7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group CH2O; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4-tris(chloranyl)-5-ethoxy-benzene" "2,4,5-trichlorophenetole" "1,2,4-trichloro-5-ethoxybenzene" "benzene, 1,2,4-trichloro-5-ethoxy-" "ambsclk-95" "benzene,1,2,4-trichloro-5-ethoxy-" "phenetole,2,4,5-trichloro- (7ci,8ci); 2,4,5-trichlorophenetole" );
standardThermochemistry
{
    dHf_298   -185770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40790.0
}
