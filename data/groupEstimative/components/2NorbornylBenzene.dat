/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-norbornyl)benzene  (C13H16, CAS 17989-95-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2NorbornylBenzene;
formula     C13H16;
CAS         17989-95-6;
InChIKey    FPSNRVOJKUSUFQ-UHFFFAOYSA-N;
MW          172.271;      // g/mol [origin=calculated method=formula-sum]
Tc          773.61;      // K   [origin=predictive method=joback]
Pc          28.203;      // bar [origin=predictive method=joback]
omega       0.4015;      // -   [origin=predictive method=lee-kesler]
Tb          536.80;      // K   [origin=predictive method=joback]
HvapTb      46497.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.5 1.4256 -0.0010532 3.095e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylbicyclo[2.2.1]heptane" "2-phenylnorbornane" "agn-pc-02vl0t" "3-phenylbicyclo[2.2.1]hepta-1,3,5-triene" );
standardThermochemistry
{
    dHf_298   43980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     353.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=272680.0
}
