/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl pimelate  (C11H20O4, CAS 2050-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylPimelate;
formula     C11H20O4;
CAS         2050-20-6;
InChIKey    LKKOGZVQGQUVHF-UHFFFAOYSA-N;
MW          216.277;      // g/mol [origin=calculated method=formula-sum]
Tc          741.32;      // K   [origin=predictive method=joback]
Pc          19.510;      // bar [origin=predictive method=joback]
omega       0.8399;      // -   [origin=predictive method=lee-kesler]
Tb          567.72;      // K   [origin=predictive method=joback]
HvapTb      54894.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.707 0.93924 -0.0003854 5.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl heptanedioate" "pimelic acid diethyl ester" "1,5-pentanedicarboxylic acid diethyl ester" "pentane-1,5-dicarboxylic acid diethyl ester" "diethylpimelate" "heptanedioic acid, diethyl ester" "diethyl heptane-1,7-dioate" "heptanedioic acid diethyl ester" "heptanedioic acid,1,7-diethyl ester" "p007" );
gibbsFormation
{
    dHf_298   -904930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     687.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-579000.0
    phase     gas;
}
