/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tert-butyl-2-ethenylbenzene; 2-ethylhexyl prop-2-enoate; styrene  (C31H44O2, CAS 64885-17-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButyl2Ethenylbenzene2EthylhexylProp2EnoateStyrene;
formula     C31H44O2;
CAS         64885-17-2;
InChIKey    LIVJGTZWANWYLL-UHFFFAOYSA-N;
MW          448.691;      // g/mol [origin=calculated method=formula-sum]
Tc          1247.13;      // K   [origin=predictive method=joback]
Pc          7.868;      // bar [origin=predictive method=joback]
omega       0.7098;      // -   [origin=predictive method=lee-kesler]
Tb          1014.61;      // K   [origin=predictive method=joback]
HvapTb      94115.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.885 2.3361 -0.00097746 1.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group CH2=CH; count 3; } { group ACH; count 9; } { group AC; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group dCH2; count 3; } { group dCH; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-2-ethenyl-benzene;ethenylbenzene;2-ethylhexyl prop-2-enoate" );
standardThermochemistry
{
    dHf_298   -399840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1348.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=169360.0
}
