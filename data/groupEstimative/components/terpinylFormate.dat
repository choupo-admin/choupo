/*--------------------------------*- Choupo -*-----------------------*\
  Component: terpinyl formate  (C11H18O2, CAS 2153-26-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H18O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        terpinylFormate;
formula     C11H18O2;
CAS         2153-26-6;
InChIKey    IPYLQIQMGUZFCK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          658.29;      // K   [origin=predictive method=joback]
Pc          24.580;      // bar [origin=predictive method=joback]
omega       0.2622;      // -   [origin=predictive method=lee-kesler]
Tb          448.16;      // K   [origin=predictive method=joback]
HvapTb      37794.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.61 1.18936 -0.00090064 2.772e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methylcyclohex-3-en-1-yl)propan-2-yl methanoate" "p-1-menthen-8-yl formate" "p-menth-1-en-8-yl formate" "p-menth-1-en-8-ol, formate" "2-(4-methylcyclohex-3-en-1-yl)propan-2-yl formate" "p-menth-1-en-8-ol, formate (mixed isomers)" "alpha,alpha,4-trimethyl-3-cyclohexene-1-methyl formate" "3-cyclohexene-1-methanol, alpha,alpha,4-trimethyl-, formate" "p-menth-1-en-8-yl-formate" "3-cyclohexene-1-methanol, ?,?,4-trimethyl-, formate" "3-cyclohexene-1-methanol, alpha,alpha,4-trimethyl-, 1-formate" "3-cyclohexene-1-methanol, .alpha.,.alpha.,4-trimethyl-, 1-formate" );
gibbsFormation
{
    dHf_298   -102040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     655.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133320.0
    phase     gas;
}
