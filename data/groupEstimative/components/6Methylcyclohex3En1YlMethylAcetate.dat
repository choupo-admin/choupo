/*--------------------------------*- Choupo -*-----------------------*\
  Component: (6-methylcyclohex-3-en-1-yl)methyl acetate  (C10H16O2, CAS 70289-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methylcyclohex3En1YlMethylAcetate;
formula     C10H16O2;
CAS         70289-14-4;
InChIKey    MRIXAGHIOGSYJY-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          704.95;      // K   [origin=predictive method=joback]
Pc          25.899;      // bar [origin=predictive method=joback]
omega       0.4822;      // -   [origin=predictive method=lee-kesler]
Tb          500.66;      // K   [origin=predictive method=joback]
HvapTb      45673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.679 0.93864 -0.00043848 3.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 2; } { group CH=CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6-methylcyclohex-3-en-1-yl)methyl ethanoate" "3-cyclohexene-1-methanol, 6-methyl-, acetate" );
standardThermochemistry
{
    dHf_298   -475250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230350.0
}
