/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-propylidenephthalide  (C11H10O2, CAS 17369-59-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Propylidenephthalide;
formula     C11H10O2;
CAS         17369-59-4;
InChIKey    NGSZDVVHIGAMOJ-UHFFFAOYSA-N;
MW          174.199;      // g/mol [origin=calculated method=formula-sum]
Tc          765.92;      // K   [origin=predictive method=joback]
Pc          30.490;      // bar [origin=predictive method=joback]
omega       0.6305;      // -   [origin=predictive method=lee-kesler]
Tb          550.67;      // K   [origin=predictive method=joback]
HvapTb      51090.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.149 0.97472 -0.00078106 2.514e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-propylidene-2-benzofuran-1-one" "1(3h)-isobenzofuranone,3-propylidene-" "phthalide,3-propylidene- (6ci,8ci); 3-propylidenephthalide; celeriax;propylidenephthalide" );
standardThermochemistry
{
    dHf_298   -181100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-27730.0
}
