/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dichloro-1-fluoropropane  (C3H5Cl2F, CAS 127404-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichloro1Fluoropropane;
formula     C3H5Cl2F;
CAS         127404-11-9;
InChIKey    JXGAPNVPOVVXPV-UHFFFAOYSA-N;
MW          130.971;      // g/mol [origin=calculated method=formula-sum]
Tc          523.26;      // K   [origin=predictive method=joback]
Pc          38.771;      // bar [origin=predictive method=joback]
omega       0.2394;      // -   [origin=predictive method=lee-kesler]
Tb          339.14;      // K   [origin=predictive method=joback]
HvapTb      28929.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.561 0.44002 -0.0003684 1.2e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CCl2F; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group F; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)-1-fluoranyl-propane" "dichlorofluoropropane" "propane, 1,1-dichloro-1-fluoro-" );
gibbsFormation
{
    dHf_298   -341590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     332.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-241450.0
    phase     gas;
}
