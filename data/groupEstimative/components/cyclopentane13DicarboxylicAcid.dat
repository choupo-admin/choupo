/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentane-1,3-dicarboxylic acid  (C7H10O4, CAS 4056-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentane13DicarboxylicAcid;
formula     C7H10O4;
CAS         4056-78-4;
InChIKey    LNGJOYPCXLOTKL-UHFFFAOYSA-N;
MW          158.153;      // g/mol [origin=calculated method=formula-sum]
Tc          889.01;      // K   [origin=predictive method=joback]
Pc          40.829;      // bar [origin=predictive method=joback]
omega       1.0351;      // -   [origin=predictive method=lee-kesler]
Tb          661.39;      // K   [origin=predictive method=joback]
HvapTb      65452.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.82 0.8756 -0.0005742 1.394e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-cyclopentanedicarboxylic acid" "norcamphoric acid" "1,3-cyclopentanedicarboxylicacid,(1s-trans)-(9ci)" "(1s,3r)-cyclopentane-1,3-dicarboxylic acid" "norcamphoricacid (6ci)" "agn-pc-0d83lj" "1,3-cyclopentanedicarboxylicacid" );
standardThermochemistry
{
    dHf_298   -848210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-650920.0
}
