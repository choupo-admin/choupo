/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,4-dihydroxy-3-methylphenyl)ethanone  (C9H10O3, CAS 10139-84-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        124Dihydroxy3MethylphenylEthanone;
formula     C9H10O3;
CAS         10139-84-1;
InChIKey    KMTLZBUHQPQFAV-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          893.60;      // K   [origin=predictive method=joback]
Pc          50.658;      // bar [origin=predictive method=joback]
omega       0.9927;      // -   [origin=predictive method=lee-kesler]
Tb          652.29;      // K   [origin=predictive method=joback]
HvapTb      71340.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.38 1.00164 -0.00092398 3.5366e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[3-methyl-2,4-bis(oxidanyl)phenyl]ethanone" "2',4'-dihydroxy-3'-methylacetophenone" "1-(2,4-dihydroxy-3-methylphenyl)ethan-1-one" "ethanone, 1-(2,4-dihydroxy-3-methylphenyl)-" "1-acetyl-2,4-dihydroxy-3-methylbenzene" "h183" "acetophenone, 2',4'-dihydroxy-3'-methyl- (6ci);1-(2,4-dihydroxy-3-methylphenyl)ethanone;3-methylresacetophenone;4-acetyl-2-methylresorcinol;" );
gibbsFormation
{
    dHf_298   -471230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-310480.0
    phase     gas;
}
