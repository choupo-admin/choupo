/*--------------------------------*- Choupo -*-----------------------*\
  Component: di(2,6-dimethylphenol)  (C16H18O2, CAS 2417-04-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        di26Dimethylphenol;
formula     C16H18O2;
CAS         2417-04-1;
InChIKey    YGYPMFPGZQPETF-UHFFFAOYSA-N;
MW          242.318;      // g/mol [origin=calculated method=formula-sum]
Tc          1048.08;      // K   [origin=predictive method=joback]
Pc          29.092;      // bar [origin=predictive method=joback]
omega       1.0682;      // -   [origin=predictive method=lee-kesler]
Tb          800.20;      // K   [origin=predictive method=joback]
HvapTb      84438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.11 1.43728 -0.00115356 3.968e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group ACCH3; count 4; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3,5-dimethyl-4-oxidanyl-phenyl)-2,6-dimethyl-phenol" "2,2',6,6'-tetramethyl-p,p'-biphenol" "3,3,5,5-tetramehtyl [1,1'-biphenyl] 4,4'-diol" "4-(4-hydroxy-3,5-dimethylphenyl)-2,6-dimethylphenol" "(1,1'-biphenyl)-4,4'-diol, 3,3',5,5'-tetramethyl-" "[1,1'-biphenyl]-4,4'-diol, 3,3',5,5'-tetramethyl-" "3,3,5,5-tetramethylbiphenyl-4,4-diol" "2,2',6,6'-tetramethyl-4,4'-biphenol" "3,3',5,5'-tetramethyl-4,4'-dihydroxybiphenyl" );
standardThermochemistry
{
    dHf_298   -301010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-39100.0
}
