/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromodec-1-ene  (C10H19Br, CAS 3017-67-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromodec1Ene;
formula     C10H19Br;
CAS         3017-67-2;
InChIKey    WFIITSVBZDMEFY-UHFFFAOYSA-N;
MW          219.166;      // g/mol [origin=calculated method=formula-sum]
Tc          675.61;      // K   [origin=predictive method=joback]
Pc          23.519;      // bar [origin=predictive method=joback]
omega       0.5697;      // -   [origin=predictive method=lee-kesler]
Tb          491.12;      // K   [origin=predictive method=joback]
HvapTb      43699.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.693 0.97192 -0.0006168 1.611e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2=C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH2; count 1; } { group dC; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyldec-1-ene" "2-bromo-1-decene" "1-decene, 2-bromo-" );
gibbsFormation
{
    dHf_298   -107760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=126930.0
    phase     gas;
}
