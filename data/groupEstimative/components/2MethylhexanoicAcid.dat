/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylhexanoic acid  (C7H14O2, CAS 4536-23-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylhexanoicAcid;
formula     C7H14O2;
CAS         4536-23-6;
InChIKey    CVKMFSAVYPAZTQ-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          695.80;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.6990;      // -   [origin=predictive method=lee-kesler]
Tb          504.83;      // K   [origin=predictive method=joback]
HvapTb      47952.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.557 0.72554 -0.0004328 9.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanoic acid, 2-methyl-" "2-methylcaproic acid" "methylhexanoic acid" "2-hexanecarboxylic acid" "alpha-methylcaproic acid" ".alpha.-methylcaproic acid" "(s)-2-methylhexanoic acid" "2-methyl hexanoic acid" "2-methyl-hexanoic acid" "hexanoic acid, methyl-" "cvkmfsavypaztq-uhfffaoysa-" "caproicacid, a-methyl- (3ci);2-hexanecarboxylic acid;2-methylcaproic acid;a-methylcaproic acid;" );
standardThermochemistry
{
    dHf_298   -543360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-338290.0
}
