/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 3-methylbenzoate  (C12H16O2, CAS 6640-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl3Methylbenzoate;
formula     C12H16O2;
CAS         6640-77-3;
InChIKey    KECCQYFSODJESB-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          768.65;      // K   [origin=predictive method=joback]
Pc          23.819;      // bar [origin=predictive method=joback]
omega       0.6363;      // -   [origin=predictive method=lee-kesler]
Tb          564.04;      // K   [origin=predictive method=joback]
HvapTb      52651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.217 0.95064 -0.00049856 7.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, 3-methyl-, butyl ester" );
standardThermochemistry
{
    dHf_298   -383230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-157430.0
}
