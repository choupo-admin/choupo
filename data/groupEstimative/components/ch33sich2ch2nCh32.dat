/*--------------------------------*- Choupo -*-----------------------*\
  Component: (ch3)3sich2ch2n(ch3)2  (C7H19NSi, CAS 23138-94-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H19NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ch33sich2ch2nCh32;
formula     C7H19NSi;
CAS         23138-94-5;
InChIKey    KSGNPJFPFWTYLJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          145.321;      // g/mol [origin=calculated method=formula-sum]
Tc          542.12;      // K   [origin=predictive method=joback]
Pc          24.703;      // bar [origin=predictive method=joback]
omega       0.3153;      // -   [origin=predictive method=lee-kesler]
Tb          373.60;      // K   [origin=predictive method=joback]
HvapTb      33513.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.652 0.5866 -5.48e-05 -1.077e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH3N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-2-trimethylsilyl-ethanamine" "(ch3)3si(ch2)2n(ch3)2" "n,n-dimethyl-2-trimethylsilylethanamine" "ethanamine, n,n-dimethyl-2-(trimethylsilyl)-" );
standardThermochemistry
{
    dHf_298   -231900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14080.0
}
