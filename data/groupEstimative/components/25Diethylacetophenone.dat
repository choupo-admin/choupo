/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-diethylacetophenone  (C12H16O, CAS 2797-80-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Diethylacetophenone;
formula     C12H16O;
CAS         2797-80-0;
InChIKey    XCNCPXSQWCEGBQ-UHFFFAOYSA-N;
MW          176.259;      // g/mol [origin=calculated method=formula-sum]
Tc          774.95;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.6127;      // -   [origin=predictive method=lee-kesler]
Tb          564.67;      // K   [origin=predictive method=joback]
HvapTb      52652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.968 0.91796 -0.00050742 9.826e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,5-diethylphenyl)ethanone" "ethanone, 1-(2,5-diethylphenyl)-" );
standardThermochemistry
{
    dHf_298   -190000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14390.0
}
