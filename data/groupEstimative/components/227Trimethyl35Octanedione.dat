/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,7-trimethyl-3,5-octanedione  (C11H20O2, CAS 69725-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        227Trimethyl35Octanedione;
formula     C11H20O2;
CAS         69725-37-7;
InChIKey    KEBPOWLGOOTMPK-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          749.33;      // K   [origin=predictive method=joback]
Pc          22.229;      // bar [origin=predictive method=joback]
omega       0.6660;      // -   [origin=predictive method=lee-kesler]
Tb          555.35;      // K   [origin=predictive method=joback]
HvapTb      51888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.548 1.1246 -0.0007122 1.7302e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH; count 1; } { group C; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,7-trimethyloctane-3,5-dione" "3,5-octanedione, 2,2,7-trimethyl-" "2,2,7-trimethyl-3,5-octanedione;2,2,7-trimethyloctane-3,5-dione;" );
gibbsFormation
{
    dHf_298   -509560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     589.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-215700.0
    phase     gas;
}
