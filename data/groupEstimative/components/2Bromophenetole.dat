/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromophenetole  (C8H9BrO, CAS 583-19-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromophenetole;
formula     C8H9BrO;
CAS         583-19-7;
InChIKey    JVEQWIQHHWNMQX-UHFFFAOYSA-N;
MW          201.063;      // g/mol [origin=calculated method=formula-sum]
Tc          730.25;      // K   [origin=predictive method=joback]
Pc          38.198;      // bar [origin=predictive method=joback]
omega       0.4896;      // -   [origin=predictive method=lee-kesler]
Tb          502.88;      // K   [origin=predictive method=joback]
HvapTb      45185.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.701 0.60042 -0.00033596 6.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-ethoxy-benzene" "1-bromo-2-ethoxybenzene" "o-bromophenetole" "benzene, 1-bromo-2-ethoxy-" );
standardThermochemistry
{
    dHf_298   -89280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28580.0
}
