/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanamide, n-hexyl-  (C9H19NO, CAS 10264-24-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanamideNHexyl;
formula     C9H19NO;
CAS         10264-24-1;
InChIKey    WVNFFHLXDXOSGO-UHFFFAOYSA-N;
MW          157.257;      // g/mol [origin=calculated method=formula-sum]
Tc          686.68;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.7368;      // -   [origin=predictive method=lee-kesler]
Tb          509.56;      // K   [origin=predictive method=joback]
HvapTb      48810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.856 0.90704 -0.0004957 9.736e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-hexylpropanamide" "propionamide, n-hexyl-" );
gibbsFormation
{
    dHf_298   -288200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14630.0
    phase     gas;
}
