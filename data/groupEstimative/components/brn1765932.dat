name        brn1765932;
formula     C9H19NO2Si;
CAS         1067-99-8;
InChIKey    PPDNYHIVHCJXAM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          201.341;      // g/mol [origin=calculated method=formula-sum]
Tc          740.53;      // K   [origin=predictive method=joback]
Pc          19.561;      // bar [origin=predictive method=joback]
omega       0.6575;      // -   [origin=predictive method=lee-kesler]
Tb          553.84;      // K   [origin=predictive method=joback]
HvapTb      51220.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (103.525 0.46106 0.000202 -2.372e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH2O; count 2; } { group CH2CN; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group O; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[diethoxy(methyl)silyl]butanenitrile" "4-(diethoxymethylsilyl)butyronitrile" "(3-cyanopropyl)diethoxy(methyl) silane" "butyronitrile, 4-(diethoxymethylsilyl)-" "silane, (3-cyanopropyl)diethoxy(methyl)-" "diethoxy-3-kyanpropyl-methylsilan" );
standardThermochemistry
{
