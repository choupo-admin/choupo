/*--------------------------------*- Choupo -*-----------------------*\
  Component: bi-2-cyclopropen-1-yl, 1,1'-dimethyl-, trans-  (C8H10, CAS 76486-72-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bi2Cyclopropen1Yl11DimethylTrans;
formula     C8H10;
CAS         76486-72-1;
InChIKey    DEPCHIDGJCISPK-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          607.75;      // K   [origin=predictive method=joback]
Pc          37.916;      // bar [origin=predictive method=joback]
omega       0.2849;      // -   [origin=predictive method=lee-kesler]
Tb          399.66;      // K   [origin=predictive method=joback]
HvapTb      33323.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-125.0 1.18604 -0.00129192 5.641e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cycloprop-2-en-1-yl-1,3-dimethyl-cyclopropene" "3-cycloprop-2-en-1-yl-1,3-dimethylcyclopropene" );
gibbsFormation
{
    dHf_298   56480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     275.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=182780.0
    phase     gas;
}
