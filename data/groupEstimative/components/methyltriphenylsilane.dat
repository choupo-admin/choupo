/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyltriphenylsilane  (C19H18Si, CAS 791-29-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C19H18Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methyltriphenylsilane;
formula     C19H18Si;
CAS         791-29-7;
InChIKey    GIGVICQLYWGMGW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          274.438;      // g/mol [origin=calculated method=formula-sum]
Tc          986.85;      // K   [origin=predictive method=joback]
Pc          21.256;      // bar [origin=predictive method=joback]
omega       0.5051;      // -   [origin=predictive method=lee-kesler]
Tb          715.76;      // K   [origin=predictive method=joback]
HvapTb      65010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.28 1.36592 -0.0006886 7.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 15; } { group AC; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl(triphenyl)silane" "silane, methyltriphenyl-" "triphenylmethylsilane" "methyl-tri(phenyl)silane" "methyl(triphenyl)silane;triphenylmethylsilane;silane, methyltriphenyl-;" );
standardThermochemistry
{
    dHf_298   162480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     703.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=341570.0
}
