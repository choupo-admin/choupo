/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 2-butoxycyclopropane-1-carboxylate  (C12H22O3, CAS 63937-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl2Butoxycyclopropane1Carboxylate;
formula     C12H22O3;
CAS         63937-32-6;
InChIKey    OJUUXCCHJGMHEO-UHFFFAOYSA-N;
MW          214.305;      // g/mol [origin=calculated method=formula-sum]
Tc          734.23;      // K   [origin=predictive method=joback]
Pc          19.153;      // bar [origin=predictive method=joback]
omega       0.7491;      // -   [origin=predictive method=lee-kesler]
Tb          556.87;      // K   [origin=predictive method=joback]
HvapTb      51727.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.414 1.15024 -0.0005882 9.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 2; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropanecarboxylic acid, 2-butoxy-, butyl ester" "butyl-2-butoxycyklopropankarboxylat" );
standardThermochemistry
{
    dHf_298   -688050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-312170.0
}
