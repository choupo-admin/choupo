/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3'-[(phenylimino)bis(ethane-2,1-diyloxy)]dipropanenitrile  (C16H21N3O2, CAS 68391-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33PhenyliminoBisEthane21DiyloxyDipropanenitrile;
formula     C16H21N3O2;
CAS         68391-48-0;
InChIKey    LHIVWGDROKTSST-UHFFFAOYSA-N;
MW          287.363;      // g/mol [origin=calculated method=formula-sum]
Tc          1066.11;      // K   [origin=predictive method=joback]
Pc          15.885;      // bar [origin=predictive method=joback]
omega       1.1365;      // -   [origin=predictive method=lee-kesler]
Tb          853.80;      // K   [origin=predictive method=joback]
HvapTb      81305.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.748 1.312 -0.0007064 1.199e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 2; } { group CH2N; count 1; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } { group N; count 1; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-[2-(2-cyanoethoxy)ethyl-phenyl-amino]ethoxy]propanenitrile" "3,3'-((phenylimino)bis(ethane-2,1-diyloxy))bispropiononitrile" "3,3'-[(phenylimino)bis(ethane-2,1-diyloxy)]bispropiononitrile" "propanenitrile, 3,3'-((phenylimino)bis(2,1-ethanediyloxy))bis-" "propanenitrile, 3,3'-[(phenylimino)bis(2,1-ethanediyloxy)]bis-" "3-[2-[n-[2-(2-cyanoethoxy)ethyl]anilino]ethoxy]propanenitrile" );
standardThermochemistry
{
    dHf_298   -4190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     723.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=363390.0
}
