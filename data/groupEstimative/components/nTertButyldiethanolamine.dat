/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-tert-butyldiethanolamine  (C8H19NO2, CAS 2160-93-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nTertButyldiethanolamine;
formula     C8H19NO2;
CAS         2160-93-2;
InChIKey    XHJGXOOOMKCJPP-UHFFFAOYSA-N;
MW          161.245;      // g/mol [origin=calculated method=formula-sum]
Tc          739.08;      // K   [origin=predictive method=joback]
Pc          31.385;      // bar [origin=predictive method=joback]
omega       1.3392;      // -   [origin=predictive method=lee-kesler]
Tb          576.21;      // K   [origin=predictive method=joback]
HvapTb      67507.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.966 1.08156 -0.0007566 2.129e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[tert-butyl(2-hydroxyethyl)amino]ethanol" "tert-butyldiethanolamine" "2,2'-(tert-butylimino)diethanol" "2,2-(tert-butylimino)diethanol" "ethanol, 2,2'-(tert-butylimino)di-" "ethanol, 2,2'-((1,1-dimethylethyl)imino)bis-" "ethanol, 2,2'-[(1,1-dimethylethyl)imino]bis-" "2,2'-((1,1-dimethylethyl)imino)bisethanol" "ethanol, 2,2'-(tert-butylimino)di- (6ci,7ci,8ci)" "n-tert-butyl diethanolamine" "xhjgxooomkcjpp-uhfffaoysa-" "[2,2-(tert-butylimino)diethanol]" );
standardThermochemistry
{
    dHf_298   -454130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-143540.0
}
