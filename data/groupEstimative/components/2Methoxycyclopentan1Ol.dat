/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxycyclopentan-1-ol  (C6H12O2, CAS 7429-45-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxycyclopentan1Ol;
formula     C6H12O2;
CAS         7429-45-0;
InChIKey    YVXLDOASGKIXII-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          648.63;      // K   [origin=predictive method=joback]
Pc          40.466;      // bar [origin=predictive method=joback]
omega       0.7074;      // -   [origin=predictive method=lee-kesler]
Tb          462.09;      // K   [origin=predictive method=joback]
HvapTb      47987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.32 0.64982 -0.000294 2.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentanol, 2-methoxy-, trans-" "cyclopentanol, 2-methoxy-, cis-" "cyclopentanol, 2-methoxy-" "cyclopentanol,2-methoxy-,cis-" "cyclopentanol,2-methoxy-,trans-" );
standardThermochemistry
{
    dHf_298   -411480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     359.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-213340.0
}
