/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(3-indenyl)ethane  (C20H18, CAS 18657-57-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Bis3IndenylEthane;
formula     C20H18;
CAS         18657-57-3;
InChIKey    CQAQBIQKEFJNRZ-UHFFFAOYSA-N;
MW          258.364;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.08;      // K   [origin=predictive method=joback]
Pc          21.877;      // bar [origin=predictive method=joback]
omega       0.7511;      // -   [origin=predictive method=lee-kesler]
Tb          751.62;      // K   [origin=predictive method=joback]
HvapTb      68342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.708 1.7508 -0.0013842 4.416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=C; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-(3h-inden-1-yl)ethyl]-1h-indene" "1h-indene, 3,3'-(1,2-ethanediyl)bis-" "3,3'-ethylenebis(1h-indene)" "cqaqbiqkefjnrz-uhfffaoysa-" "1h-indene,3,3'-(1,2-ethanediyl)bis-" );
standardThermochemistry
{
    dHf_298   272890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=500660.0
}
