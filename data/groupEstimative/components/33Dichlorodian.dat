/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3'-dichlorodian  (C15H14Cl2O2, CAS 79-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dichlorodian;
formula     C15H14Cl2O2;
CAS         79-98-1;
InChIKey    XBQRPFBBTWXIFI-UHFFFAOYSA-N;
MW          297.175;      // g/mol [origin=calculated method=formula-sum]
Tc          1107.63;      // K   [origin=predictive method=joback]
Pc          31.456;      // bar [origin=predictive method=joback]
omega       1.0427;      // -   [origin=predictive method=lee-kesler]
Tb          838.99;      // K   [origin=predictive method=joback]
HvapTb      88362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.49 1.60064 -0.00144584 5.246e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 6; } { group AC; count 2; } { group ACOH; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group Cl; count 2; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-4-[2-(3-chloranyl-4-oxidanyl-phenyl)propan-2-yl]phenol" "3,3'-dichlorobisphenol a" "2,2-bis(3-chloro-4-hydroxyphenyl)propane" "2,2-bis(4-hydroxy-3-chlorophenyl)propane" "4,4'-isopropylidenebis(o-chlorophenol)" "4,4'-isopropylidenebis(2-chlorophenol)" "phenol, 4,4'-(1-methylethylidene)bis(2-chloro-" "phenol, 4,4'-(1-methylethylidene)bis[2-chloro-" "4,4'-isopropylidenebis[2-chlorophenol]" "trichlorobisphenol a" "2,2'-dichlorobisphenol a" "3,3',5-trichlorobisphenol a" );
standardThermochemistry
{
    dHf_298   -297660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49280.0
}
