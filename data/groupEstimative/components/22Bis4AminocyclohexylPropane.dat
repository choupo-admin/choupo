/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(4-aminocyclohexyl)propane  (C15H30N2, CAS 3377-24-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Bis4AminocyclohexylPropane;
formula     C15H30N2;
CAS         3377-24-0;
InChIKey    BDBZTOMUANOKRT-UHFFFAOYSA-N;
MW          238.419;      // g/mol [origin=calculated method=formula-sum]
Tc          960.46;      // K   [origin=predictive method=joback]
Pc          21.023;      // bar [origin=predictive method=joback]
omega       0.6599;      // -   [origin=predictive method=lee-kesler]
Tb          714.39;      // K   [origin=predictive method=joback]
HvapTb      69210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.57 1.86964 -0.001102 2.24e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 2; } { group C; count 1; } { group CHNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(4-azanylcyclohexyl)propan-2-yl]cyclohexan-1-amine" "cyclohexanamine, 4,4'-(1-methylethylidene)bis-" "4,4'-isopropylidenebis(cyclohexylamine)" "4-[2-(4-aminocyclohexyl)propan-2-yl]cyclohexan-1-amine" );
gibbsFormation
{
    dHf_298   -226140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     658.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=244640.0
    phase     gas;
}
