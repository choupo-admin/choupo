/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenylbutanal  (C10H12O, CAS 18328-11-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenylbutanal;
formula     C10H12O;
CAS         18328-11-5;
InChIKey    NHFRGTVSKOPUBK-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          713.33;      // K   [origin=predictive method=joback]
Pc          31.811;      // bar [origin=predictive method=joback]
omega       0.5446;      // -   [origin=predictive method=lee-kesler]
Tb          503.74;      // K   [origin=predictive method=joback]
HvapTb      46850.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.707 0.8494 -0.0005444 1.312e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzenebutanal" "4-phenylbutyraldehyde" "butyraldehyde, 4-phenyl-" "4-phenyl-butyraldehyde" "butyraldehyde,4-phenyl- (8ci); 4-phenylbutanal; 4-phenylbutyraldehyde; g-phenylbutyraldehyde" );
standardThermochemistry
{
    dHf_298   -98780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46210.0
}
