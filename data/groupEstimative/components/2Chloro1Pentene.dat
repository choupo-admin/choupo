/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-1-pentene  (C5H9Cl, CAS 42131-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro1Pentene;
formula     C5H9Cl;
CAS         42131-85-1;
InChIKey    RYAVTKZLXAVVAQ-UHFFFAOYSA-N;
MW          104.577;      // g/mol [origin=calculated method=formula-sum]
Tc          527.96;      // K   [origin=predictive method=joback]
Pc          35.096;      // bar [origin=predictive method=joback]
omega       0.2670;      // -   [origin=predictive method=lee-kesler]
Tb          347.99;      // K   [origin=predictive method=joback]
HvapTb      30519.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.552 0.46552 -0.0002938 7.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylpent-1-ene" "2-chloropent-1-ene" "1-pentene, 2-chloro-" );
gibbsFormation
{
    dHf_298   -46630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58580.0
    phase     gas;
}
