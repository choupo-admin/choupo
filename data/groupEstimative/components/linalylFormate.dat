/*--------------------------------*- Choupo -*-----------------------*\
  Component: linalyl formate  (C11H18O2, CAS 115-99-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H18O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        linalylFormate;
formula     C11H18O2;
CAS         115-99-1;
InChIKey    JZOCDHMHLGUPFI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          610.50;      // K   [origin=predictive method=joback]
Pc          21.755;      // bar [origin=predictive method=joback]
omega       0.3089;      // -   [origin=predictive method=lee-kesler]
Tb          425.19;      // K   [origin=predictive method=joback]
HvapTb      35779.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.948 1.18266 -0.0010084 3.549e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethylocta-1,6-dien-3-yl methanoate" "linalool, formate" "linolool, formate" "1,6-octadien-3-ol, 3,7-dimethyl-, formate" "3,7-dimethyl-1,6-octadien-3-yl formate" "3,7-dimethyl-1,6-octadien-3-ol formate" "3,7-dimethylocta-1,6-dien-3-yl formate" "1,6-octadien-3-ol, 3,7-dimethyl-, 3-formate" "linalool formate" "linalool formate (6ci)" "1, 3,7-dimethyl-, formate" );
gibbsFormation
{
    dHf_298   30190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     713.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=248050.0
    phase     gas;
}
