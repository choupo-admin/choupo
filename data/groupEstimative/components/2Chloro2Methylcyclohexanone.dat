/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-2-methylcyclohexanone  (C7H11ClO, CAS 10409-46-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro2Methylcyclohexanone;
formula     C7H11ClO;
CAS         10409-46-8;
InChIKey    IDRWHLQDVSLCBJ-UHFFFAOYSA-N;
MW          146.614;      // g/mol [origin=calculated method=formula-sum]
Tc          725.37;      // K   [origin=predictive method=joback]
Pc          37.090;      // bar [origin=predictive method=joback]
omega       0.3415;      // -   [origin=predictive method=lee-kesler]
Tb          484.80;      // K   [origin=predictive method=joback]
HvapTb      39086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.75 0.92132 -0.000747 2.757e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group Cl; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-2-methyl-cyclohexan-1-one" "cyclohexanone,2-chloro-2-methyl-" "2-chloro-2-methyl-cyclohexanone" "2-chloro-2-methylcyclohexan-1-one" "cyclohexanone, 2-chloro-2-methyl-" "2-chloro-2-methyl cyclohexanone" );
gibbsFormation
{
    dHf_298   -271690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-107500.0
    phase     gas;
}
