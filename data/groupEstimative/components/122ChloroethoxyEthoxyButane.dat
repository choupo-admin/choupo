/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[2-(2-chloroethoxy)ethoxy]butane  (C8H17ClO2, CAS 1120-23-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        122ChloroethoxyEthoxyButane;
formula     C8H17ClO2;
CAS         1120-23-6;
InChIKey    DZWMJKOIMKFXIJ-UHFFFAOYSA-N;
MW          180.672;      // g/mol [origin=calculated method=formula-sum]
Tc          635.52;      // K   [origin=predictive method=joback]
Pc          23.634;      // bar [origin=predictive method=joback]
omega       0.6120;      // -   [origin=predictive method=lee-kesler]
Tb          464.91;      // K   [origin=predictive method=joback]
HvapTb      42607.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.507 0.64422 -0.0002098 -1.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2O; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-(2-chloroethyloxy)ethoxy]butane" "1-(2-butoxyethoxy)-2-chloroethane" "1-(2-(2-chloroethoxy)ethoxy)butane" "butane, 1-(2-(2-chloroethoxy)ethoxy)-" "butane, 1-[2-(2-chloroethoxy)ethoxy]-" "2-beta-butoxyethoxyethyl chloride" "ethane, 1-butoxy-2-(2-chloroethoxy)-" );
gibbsFormation
{
    dHf_298   -488630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-205450.0
    phase     gas;
}
