/*--------------------------------*- Choupo -*-----------------------*\
  Component: .delta.-hexadecalactone  (C16H30O2, CAS 7370-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        deltaHexadecalactone;
formula     C16H30O2;
CAS         7370-44-7;
InChIKey    ZMJKQSSFLIFELJ-UHFFFAOYSA-N;
MW          254.414;      // g/mol [origin=calculated method=formula-sum]
Tc          812.90;      // K   [origin=predictive method=joback]
Pc          14.861;      // bar [origin=predictive method=joback]
omega       0.8284;      // -   [origin=predictive method=lee-kesler]
Tb          634.91;      // K   [origin=predictive method=joback]
HvapTb      58702.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.61 1.61032 -0.0009258 1.915e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-undecyloxan-2-one" "tetrahydro-6-undecyl-2h-pyran-2-one" "6-undecyltetrahydro-2h-pyran-2-one" "hexadecalactone" "n-hexadecalactone" "5-hexadecanolide" "delta-hexadecalactone" "agn-pc-00gulg" "2h-pyran-2-one,tetrahydro-6-undecyl-" "2h-pyran-2-one, tetrahydro-6-undecyl-" "hexadecanoicacid, 5-hydroxy-, d-lactone (7ci); 5-hexadecanolide; 6-undecyltetrahydro-2h-pyran-2-one;tetrahydro-6-undecyl-2h-pyran-2-one; d-hexadecalactone; d-hexadecanolide; d-palmitolactone" );
gibbsFormation
{
    dHf_298   -624210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     760.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-177880.0
    phase     gas;
}
