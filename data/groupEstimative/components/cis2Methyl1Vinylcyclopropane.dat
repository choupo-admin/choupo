/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-2-methyl-1-vinylcyclopropane  (C6H10, CAS 2628-57-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis2Methyl1Vinylcyclopropane;
formula     C6H10;
CAS         2628-57-1;
InChIKey    JVVPJIPOOZHNTM-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          517.25;      // K   [origin=predictive method=joback]
Pc          36.509;      // bar [origin=predictive method=joback]
omega       0.2238;      // -   [origin=predictive method=lee-kesler]
Tb          335.63;      // K   [origin=predictive method=joback]
HvapTb      27884.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.86 0.67822 -0.0004903 1.487e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenyl-2-methyl-cyclopropane" "1-ethenyl-2-methylcyclopropane" "cyclopropane, 1-ethenyl-2-methyl-" "agn-pc-03f9qj" );
gibbsFormation
{
    dHf_298   10720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     252.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140520.0
    phase     gas;
}
