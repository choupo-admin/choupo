/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-methoxyvinyl)benzene  (C9H10O, CAS 4747-15-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethoxyvinylBenzene;
formula     C9H10O;
CAS         4747-15-3;
InChIKey    CTHJQRHPNQEPAB-UHFFFAOYSA-N;
MW          134.178;      // g/mol [origin=calculated method=formula-sum]
Tc          675.14;      // K   [origin=predictive method=joback]
Pc          33.960;      // bar [origin=predictive method=joback]
omega       0.3798;      // -   [origin=predictive method=lee-kesler]
Tb          458.78;      // K   [origin=predictive method=joback]
HvapTb      40272.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.88 0.73672 -0.0004698 1.14e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxyethenylbenzene" "(2-methoxyethenyl)benzene" "benzene, [(1e)-2-methoxyethenyl]-" "benzene, [(1z)-2-methoxyethenyl]-" "beta-methoxystyrene;methyl alpha-styryl ether;2-methoxyethenyl]benzene;methyl 2-phenylvinyl ether;" );
gibbsFormation
{
    dHf_298   -7560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112530.0
    phase     gas;
}
