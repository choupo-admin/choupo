/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-methoxy-3,7-dimethyloctane-1,2-diol  (C11H24O3, CAS 62439-40-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Methoxy37Dimethyloctane12Diol;
formula     C11H24O3;
CAS         62439-40-1;
InChIKey    IABAOBVWYBZJEZ-UHFFFAOYSA-N;
MW          204.31;      // g/mol [origin=calculated method=formula-sum]
Tc          822.07;      // K   [origin=predictive method=joback]
Pc          23.293;      // bar [origin=predictive method=joback]
omega       1.3606;      // -   [origin=predictive method=lee-kesler]
Tb          653.95;      // K   [origin=predictive method=joback]
HvapTb      73776.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.134 1.19128 -0.0007026 1.554e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group OH; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methoxy-3,7-dimethyl-octane-1,2-diol" "1,2-octanediol, 7-methoxy-3,7-dimethyl-" );
standardThermochemistry
{
    dHf_298   -726360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-338940.0
}
