/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-4-cyclohexylbenzene  (C12H15Br, CAS 25109-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo4Cyclohexylbenzene;
formula     C12H15Br;
CAS         25109-28-8;
InChIKey    LVIJLEREXMVRAN-UHFFFAOYSA-N;
MW          239.156;      // g/mol [origin=calculated method=formula-sum]
Tc          848.23;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.4739;      // -   [origin=predictive method=lee-kesler]
Tb          591.53;      // K   [origin=predictive method=joback]
HvapTb      52108.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.04 1.1657 -0.00074556 1.759e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-cyclohexyl-benzene" "1-brom-4-cyclohexylbenzol" "zlchem 88" "4-bromophenylcyclohexane" "4-bromo-1-cyclohexylbenzene" "p-bromocyclohexylbenzene" "benzene, 1-bromo-4-cyclohexyl-" "lvijlerexmvran-uhfffaoysa-" "u867" );
standardThermochemistry
{
    dHf_298   14700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191710.0
}
