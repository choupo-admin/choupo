/*--------------------------------*- Choupo -*-----------------------*\
  Component: stearyl arachidate  (C38H76O2, CAS 22432-79-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        stearylArachidate;
formula     C38H76O2;
CAS         22432-79-7;
InChIKey    XPRSWAIUFMEQLF-UHFFFAOYSA-N;
MW          565.024;      // g/mol [origin=calculated method=formula-sum]
Tc          1499.76;      // K   [origin=predictive method=joback]
Pc          4.232;      // bar [origin=predictive method=joback]
omega       -0.2100;      // -   [origin=predictive method=lee-kesler]
Tb          1127.26;      // K   [origin=predictive method=joback]
HvapTb      107589.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.245 3.55904 -0.0019488 3.839e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 34; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 35; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecyl icosanoate" "octadecyl eicosanoate" "eicosanoic acid, octadecyl ester" "arachidic acid stearyl ester" "heptadecyl arachidate" "octadecanyl eicosanoate" "eicosanoic acid,octadecyl ester" "we(18:0/20:0)" );
standardThermochemistry
{
    dHf_298   -1144930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1687.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41290.0
}
