/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dibromobut-2-ene-1,4-diol  (C4H6Br2O2, CAS 3234-02-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dibromobut2Ene14Diol;
formula     C4H6Br2O2;
CAS         3234-02-4;
InChIKey    MELXIJRBKWTTJH-UHFFFAOYSA-N;
MW          245.898;      // g/mol [origin=calculated method=formula-sum]
Tc          809.11;      // K   [origin=predictive method=joback]
Pc          67.407;      // bar [origin=predictive method=joback]
omega       1.4879;      // -   [origin=predictive method=lee-kesler]
Tb          611.72;      // K   [origin=predictive method=joback]
HvapTb      70844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.652 0.548 -0.0004858 1.752e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 2; } { group Br; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dC; count 2; } { group Br; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(bromanyl)but-2-ene-1,4-diol" "2-butene-1,4-diol, 2,3-dibromo-" "(2e)-2,3-dibromo-2-butene-1,4-diol" "agn-pc-00ltu5" );
gibbsFormation
{
    dHf_298   -280050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199080.0
    phase     gas;
}
