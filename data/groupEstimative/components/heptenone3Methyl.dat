/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptenone, 3-methyl-  (C8H14O, CAS 96721-08-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptenone3Methyl;
formula     C8H14O;
CAS         96721-08-3;
InChIKey    IZBMUZVSTLWUTH-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          628.15;      // K   [origin=predictive method=joback]
Pc          28.719;      // bar [origin=predictive method=joback]
omega       0.4623;      // -   [origin=predictive method=lee-kesler]
Tb          440.55;      // K   [origin=predictive method=joback]
HvapTb      40186.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.898 0.75576 -0.0004788 1.2416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylhept-3-en-2-one" );
gibbsFormation
{
    dHf_298   -213600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40770.0
    phase     gas;
}
