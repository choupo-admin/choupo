/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-3-(trifluoromethyl)oxolan-2-one  (C6H7F3O2, CAS 139547-12-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl3TrifluoromethylOxolan2One;
formula     C6H7F3O2;
CAS         139547-12-9;
InChIKey    QYTOOVCITOVYEL-UHFFFAOYSA-N;
MW          168.114;      // g/mol [origin=calculated method=formula-sum]
Tc          561.92;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.4590;      // -   [origin=predictive method=lee-kesler]
Tb          391.75;      // K   [origin=predictive method=joback]
HvapTb      32214.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.66 0.80462 -0.0005938 1.629e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group F; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-3-(trifluoromethyl)-3,4,5-trihydrofuran-2-one" "4-hydroxy-2-trifluoromethylpentanoic acid lactone" "5-methyl-3-(trifluoromethyl)dihydrofuran-2(3h)-one" "gamma-methyl-alpha-(trifluoromethyl)-gamma-butyrolactone" );
standardThermochemistry
{
    dHf_298   -1029070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-839280.0
}
