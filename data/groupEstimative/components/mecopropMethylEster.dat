/*--------------------------------*- Choupo -*-----------------------*\
  Component: mecoprop methyl ester  (C11H13ClO3, CAS 2786-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mecopropMethylEster;
formula     C11H13ClO3;
CAS         2786-19-8;
InChIKey    YWGAULPFWIQKRB-UHFFFAOYSA-N;
MW          228.672;      // g/mol [origin=calculated method=formula-sum]
Tc          820.64;      // K   [origin=predictive method=joback]
Pc          24.654;      // bar [origin=predictive method=joback]
omega       0.6925;      // -   [origin=predictive method=lee-kesler]
Tb          605.55;      // K   [origin=predictive method=joback]
HvapTb      57494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.7 0.74566 -0.00028972 -8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group CH-O; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-(4-chloranyl-2-methyl-phenoxy)propanoate" "mcpp-ester" "mecoprop-methyl" "mcpp ester" "mecoprop-methyl ester" "mecoprop-methyl [iso]" "mcpp methyl ester solution" "propanoic acid, 2-(4-chloro-2-methylphenoxy)-, methyl ester, (2r)-" "methyl 2-((4-chloro-o-tolyl)oxy)propionate" "methyl 2-(4-chloro-2-methylphenoxy)propioate" "methyl 2-(4-chloro-2-methylphenoxy)propanoate" "propionic acid, 2-((4-chloro-o-tolyl)oxy)-, methyl ester" );
standardThermochemistry
{
    dHf_298   -527300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     552.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-294850.0
}
