/*--------------------------------*- Choupo -*-----------------------*\
  Component: (trimethylcyclohexenyl)acetonitrile  (C11H17N, CAS 72845-44-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylcyclohexenylAcetonitrile;
formula     C11H17N;
CAS         72845-44-4;
InChIKey    AJXXENOFRKHAJD-SECBINFHSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          796.45;      // K   [origin=predictive method=joback]
Pc          23.542;      // bar [origin=predictive method=joback]
omega       0.5051;      // -   [origin=predictive method=lee-kesler]
Tb          572.62;      // K   [origin=predictive method=joback]
HvapTb      50481.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.689 1.25566 -0.00102204 3.721e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(5s)-3,3,5-trimethylcyclohexen-1-yl]ethanenitrile" "1-cyclohexene-1-acetonitrile, 3,3,5(or 3,5,5)-trimethyl-" "2-[(5s)-3,3,5-trimethylcyclohexen-1-yl]acetonitrile" );
gibbsFormation
{
    dHf_298   -9960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     543.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=206500.0
    phase     gas;
}
