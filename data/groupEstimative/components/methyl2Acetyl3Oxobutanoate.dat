/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-acetyl-3-oxobutanoate  (C7H10O4, CAS 4619-66-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Acetyl3Oxobutanoate;
formula     C7H10O4;
CAS         4619-66-3;
InChIKey    UHCPCQYUMVLUKU-UHFFFAOYSA-N;
MW          158.153;      // g/mol [origin=calculated method=formula-sum]
Tc          722.54;      // K   [origin=predictive method=joback]
Pc          32.616;      // bar [origin=predictive method=joback]
omega       0.7364;      // -   [origin=predictive method=lee-kesler]
Tb          525.28;      // K   [origin=predictive method=joback]
HvapTb      51687.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.97 0.56396 -0.0002282 -3.58e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH3CO; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CdO; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-ethanoyl-3-oxidanylidene-butanoate" "methyl diacetoacetate" "methyl diacetylacetate" "methyl 2-acetylacetoacetate" "methylester kyseliny diacetoctove" "2-acetyl-3-oxo-butyric acid methyl ester" "butanoic acid, 2-acetyl-3-oxo-, methyl ester" "butanoic acid, 2-acetyl-3-oxo-, methyl ester (9ci)" );
standardThermochemistry
{
    dHf_298   -735530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-562590.0
}
