/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethoxy-n,n-diethylaniline  (C12H19NO, CAS 1864-92-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3EthoxyNNDiethylaniline;
formula     C12H19NO;
CAS         1864-92-2;
InChIKey    ODQSBWZDOSNPAH-UHFFFAOYSA-N;
MW          193.29;      // g/mol [origin=calculated method=formula-sum]
Tc          736.99;      // K   [origin=predictive method=joback]
Pc          23.270;      // bar [origin=predictive method=joback]
omega       0.6224;      // -   [origin=predictive method=lee-kesler]
Tb          540.68;      // K   [origin=predictive method=joback]
HvapTb      49697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.817 1.06616 -0.00059476 1.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethoxy-n,n-diethyl-aniline" "n,n-diethyl-m-phenetidine" "n,n-diethyl-3-ethoxyaniline" "m-(diethylamino)phenetole" "benzenamine, 3-ethoxy-n,n-diethyl-" "n,n-diethyl-3-phenetidine" "1-(diethylamino)-3-ethoxybenzene" "m-phenetidine,n-diethyl-" "m-phenetidine, n,n-diethyl- (8ci)" );
standardThermochemistry
{
    dHf_298   -130640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158720.0
}
