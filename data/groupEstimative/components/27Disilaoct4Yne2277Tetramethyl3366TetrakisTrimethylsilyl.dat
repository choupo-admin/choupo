/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7-disilaoct-4-yne, 2,2,7,7-tetramethyl-3,3,6,6-tetrakis(trimethylsilyl)-  (C22H54Si6, CAS 20932-80-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C22H54Si6 (delta Si+6; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        27Disilaoct4Yne2277Tetramethyl3366TetrakisTrimethylsilyl;
formula     C22H54Si6;
CAS         20932-80-3;
InChIKey    ZOVHEXYJTVBFAS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          487.184;      // g/mol [origin=calculated method=formula-sum]
Tc          924.55;      // K   [origin=predictive method=joback]
Pc          6.739;      // bar [origin=predictive method=joback]
omega       0.1986;      // -   [origin=predictive method=lee-kesler]
Tb          713.90;      // K   [origin=predictive method=joback]
HvapTb      65890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (196.41 0.95876 0.00106434 -9.2982e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 18; } { group C; count 2; } { group C_C; count 1; } { group Si; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 18; } { group C; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[1,1,4,4,4-pentakis(trimethylsilyl)but-2-ynyl]silane" "but-2-yne-1,1,1,4,4,4-hexaylhexakis(trimethylsilane)" );
standardThermochemistry
{
    dHf_298   -912330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1665.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-285720.0
}
