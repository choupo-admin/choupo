/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dimethylcyclopentanol  (C7H14O, CAS 19550-46-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dimethylcyclopentanol;
formula     C7H14O;
CAS         19550-46-0;
InChIKey    LLIFEWZQIYEVKX-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          656.08;      // K   [origin=predictive method=joback]
Pc          38.771;      // bar [origin=predictive method=joback]
omega       0.6269;      // -   [origin=predictive method=lee-kesler]
Tb          462.79;      // K   [origin=predictive method=joback]
HvapTb      46652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.72 1.09994 -0.000992 3.912e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dimethylcyclopentan-1-ol" "agn-pc-00kzii" "1,3-dimethyl cyclopentanol" "cyclopentanol,1,3-dimethyl-" "cyclopentanol, 1,3-dimethyl-" );
gibbsFormation
{
    dHf_298   -284660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105410.0
    phase     gas;
}
