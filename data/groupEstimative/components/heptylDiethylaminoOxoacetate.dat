/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptyl (diethylamino)oxoacetate  (C13H25NO3, CAS 60254-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptylDiethylaminoOxoacetate;
formula     C13H25NO3;
CAS         60254-66-2;
InChIKey    CSBKKQVPRRRVQQ-UHFFFAOYSA-N;
MW          243.347;      // g/mol [origin=calculated method=formula-sum]
Tc          794.63;      // K   [origin=predictive method=joback]
Pc          17.361;      // bar [origin=predictive method=joback]
omega       0.9534;      // -   [origin=predictive method=lee-kesler]
Tb          621.57;      // K   [origin=predictive method=joback]
HvapTb      60728.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.148 1.27996 -0.0006827 1.1476e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group COO; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group CdO; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptyl 2-(diethylamino)-2-oxidanylidene-ethanoate" "heptyl n,n-diethyloxamate" "acetic acid, (diethylamino)oxo-, heptyl ester" "heptyl 2-(diethylamino)-2-oxoacetate" );
gibbsFormation
{
    dHf_298   -673980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     756.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-269930.0
    phase     gas;
}
