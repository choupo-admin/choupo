/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyldecanamide  (C12H25NO, CAS 14433-76-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyldecanamide;
formula     C12H25NO;
CAS         14433-76-2;
InChIKey    HNXNKTMIVROLTK-UHFFFAOYSA-N;
MW          199.338;      // g/mol [origin=calculated method=formula-sum]
Tc          709.28;      // K   [origin=predictive method=joback]
Pc          18.757;      // bar [origin=predictive method=joback]
omega       0.7734;      // -   [origin=predictive method=lee-kesler]
Tb          540.47;      // K   [origin=predictive method=joback]
HvapTb      51095.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.352 1.23976 -0.0007229 1.5996e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decanamide, n,n-dimethyl-" "n,n-dimethylcapramide" "n,n-dimethylcapylamide" "n,n-dimethyldecanoamide" "n,n-dimethyldecan-1-amide" "nn-dimethyldecanamide" "decanamide,n-dimethyl-" "n,n-dimethylcapramide;" "n,n-dimethyl decanamide" "n,n-dimethyldecanamide, tech" );
gibbsFormation
{
    dHf_298   -336060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     666.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32020.0
    phase     gas;
}
