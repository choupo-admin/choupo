/*--------------------------------*- Choupo -*-----------------------*\
  Component: formestane  (C19H26O3, CAS 566-48-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        formestane;
formula     C19H26O3;
CAS         566-48-3;
InChIKey    OSVMTWJCGUFAOD-KZQROQTASA-N;
MW          302.414;      // g/mol [origin=calculated method=formula-sum]
Tc          1161.69;      // K   [origin=predictive method=joback]
Pc          21.197;      // bar [origin=predictive method=joback]
omega       1.1760;      // -   [origin=predictive method=lee-kesler]
Tb          915.38;      // K   [origin=predictive method=joback]
HvapTb      82578.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-220.47 2.44414 -0.002064 7.686e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 3; } { group C; count 2; } { group OH; count 1; } { group CH2CO; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dC_ring; count 2; } { group OH; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s)-10,13-dimethyl-4-oxidanyl-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthrene-3,17-dione" "lentaron" "4-hydroxyandrostenedione" "4-hydroxyandrost-4-ene-3,17-dione" "4-hydroxy-4-androstene-3,17-dione" "4-oh-a" "b, aromatase inhibitor" "4-oha" "formestane [inn:ban]" "4-hydroxy-delta(sub 4)-androstenedione" "androst-4-ene-3,17-dione, 4-hydroxy-" "(8r,9s,10r,13s,14s)-4-hydroxy-10,13-dimethyl-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthrene-3,17-dione" );
gibbsFormation
{
    dHf_298   -557740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98390.0
    phase     gas;
}
