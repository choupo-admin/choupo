/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethyl-2-hexanone  (C8H16O, CAS 19550-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dimethyl2Hexanone;
formula     C8H16O;
CAS         19550-10-8;
InChIKey    YGXOERUAAWTDEV-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          619.11;      // K   [origin=predictive method=joback]
Pc          27.498;      // bar [origin=predictive method=joback]
omega       0.4601;      // -   [origin=predictive method=lee-kesler]
Tb          435.63;      // K   [origin=predictive method=joback]
HvapTb      39372.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.389 0.74768 -0.0003991 7.396e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dimethylhexan-2-one" "2-hexanone, 3,4-dimethyl-" "2-hexanone,4-dimethyl-" "2-hexanone, 3,4-dimethyl- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -331590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-117320.0
}
