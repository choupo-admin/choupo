/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propene, 1,1-diethoxy-  (C7H14O2, CAS 21504-43-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propene11Diethoxy;
formula     C7H14O2;
CAS         21504-43-8;
InChIKey    AKKQRBAJPYHABK-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          585.17;      // K   [origin=predictive method=joback]
Pc          28.689;      // bar [origin=predictive method=joback]
omega       0.4400;      // -   [origin=predictive method=lee-kesler]
Tb          408.64;      // K   [origin=predictive method=joback]
HvapTb      36034.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.652 0.56236 -0.0002211 1.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH=C; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diethoxyprop-1-ene" );
gibbsFormation
{
    dHf_298   -344820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130270.0
    phase     gas;
}
