/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexaneoctanoic acid, (((2-ethylhexyl)oxy)carbonyl)-4-hexyl-, 2-ethylhexyl ester  (C37H70O4, CAS 72245-39-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexaneoctanoicAcid2EthylhexylOxyCarbonyl4Hexyl2Ethylhex;
formula     C37H70O4;
CAS         72245-39-7;
InChIKey    BZEHQVOONDIRHV-PRTBYXSSSA-N;
MW          578.963;      // g/mol [origin=calculated method=formula-sum]
Tc          1508.19;      // K   [origin=predictive method=joback]
Pc          4.716;      // bar [origin=predictive method=joback]
omega       -0.0128;      // -   [origin=predictive method=lee-kesler]
Tb          1171.93;      // K   [origin=predictive method=joback]
HvapTb      111805.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.018 3.4902 -0.0017764 2.671e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 24; } { group CH; count 5; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 22; } { group CH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2s)-2-ethylhexyl] (1r,2s,5s)-5-[8-[(2s)-2-ethylhexoxy]-8-oxidanylidene-octyl]-2-hexyl-cyclohexane-1-carboxylate" "[(2s)-2-ethylhexyl] (1r,2s,5s)-5-[8-[(2s)-2-ethylhexoxy]-8-oxooctyl]-2-hexylcyclohexane-1-carboxylate" );
gibbsFormation
{
    dHf_298   -1438490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1565.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-355930.0
    phase     gas;
}
