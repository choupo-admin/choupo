/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibutyl (z)-but-2-enedioate; ethenyl acetate; 2-methylpentane-2,4-diol  (C22H40O8, CAS 67939-18-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibutylZBut2EnedioateEthenylAcetate2Methylpentane24Diol;
formula     C22H40O8;
CAS         67939-18-8;
InChIKey    OLBDATVUROYYEY-OTMFCZTRSA-N;
MW          432.554;      // g/mol [origin=calculated method=formula-sum]
Tc          1316.24;      // K   [origin=predictive method=joback]
Pc          9.852;      // bar [origin=predictive method=joback]
omega       0.8210;      // -   [origin=predictive method=lee-kesler]
Tb          1061.95;      // K   [origin=predictive method=joback]
HvapTb      118337.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (108.007 1.71682 -0.0004021 -1.993e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 7; } { group CH; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group OH; count 2; } { group CH3COO; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 7; } { group CH; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 3; } { group OH; count 2; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibutyl (z)-but-2-enedioate;ethenyl ethanoate;2-methylpentane-2,4-diol" "2-butenedioic acid (2z)-, 1,4-dibutyl ester, polymer with ethenyl acetate and 2-methyl-2,4-pentanediol" "2-butenedioic acid (2z)-, dibutyl ester, polymer with ethenyl acetate and 2-methyl-2,4-pentanediol" "vinyl acetate, dibutyl maleate, hexylene glycol resin" );
gibbsFormation
{
    dHf_298   -1748330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1424.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1111450.0
    phase     gas;
}
