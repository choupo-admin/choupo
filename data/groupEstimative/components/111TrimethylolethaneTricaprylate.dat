/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1-trimethylolethane tricaprylate  (C29H54O6, CAS 67874-06-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111TrimethylolethaneTricaprylate;
formula     C29H54O6;
CAS         67874-06-0;
InChIKey    YGVPUMJJMNBLAR-UHFFFAOYSA-N;
MW          498.745;      // g/mol [origin=calculated method=formula-sum]
Tc          1290.01;      // K   [origin=predictive method=joback]
Pc          6.351;      // bar [origin=predictive method=joback]
omega       0.4017;      // -   [origin=predictive method=lee-kesler]
Tb          1034.55;      // K   [origin=predictive method=joback]
HvapTb      101073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.281 2.72028 -0.0014418 2.345e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 18; } { group C; count 1; } { group CH2COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 21; } { group C; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-methyl-3-octanoyloxy-2-(octanoyloxymethyl)propyl] octanoate" "trimethylolethane trioctanoate" "trimethanol ethane tricaprylate" "octanoic acid, 1,1'-(2-methyl-2-(((1-oxooctyl)oxy)methyl)-1,3-propanediyl) ester" "octanoic acid, 1,1'-[2-methyl-2-[[(1-oxooctyl)oxy]methyl]-1,3-propanediyl] ester" "octanoic acid, 2-methyl-2-(((1-oxooctyl)oxy)methyl)-1,3-propanediyl ester" );
gibbsFormation
{
    dHf_298   -1602480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1400.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-734970.0
    phase     gas;
}
