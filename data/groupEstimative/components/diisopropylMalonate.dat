/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisopropyl malonate  (C9H16O4, CAS 13195-64-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisopropylMalonate;
formula     C9H16O4;
CAS         13195-64-7;
InChIKey    QRVSDVDFJFKYKA-UHFFFAOYSA-N;
MW          188.223;      // g/mol [origin=calculated method=formula-sum]
Tc          704.72;      // K   [origin=predictive method=joback]
Pc          23.657;      // bar [origin=predictive method=joback]
omega       0.6842;      // -   [origin=predictive method=lee-kesler]
Tb          521.08;      // K   [origin=predictive method=joback]
HvapTb      49666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.161 0.76108 -0.000283 -1.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipropan-2-yl propanedioate" "malonic acid diisopropyl ester" "propanedioic acid, bis(1-methylethyl) ester" "qrvsdvdfjfkyka-uhfffaoysa-" "dimethylethyl propane-1,3-dioate" "propanedioic acid dipropan-2-yl ester" "i957" "malonicacid, diisopropyl ester (7ci,8ci);propanedioic acid, bis(1-methylethyl) ester(9ci);propanedioic acid,1,3-bis(1-methylethyl) ester;" );
gibbsFormation
{
    dHf_298   -874210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-600720.0
    phase     gas;
}
