/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloropropyl acetate  (C5H9ClO2, CAS 628-09-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ChloropropylAcetate;
formula     C5H9ClO2;
CAS         628-09-1;
InChIKey    KPOHQIPNNIMWRL-UHFFFAOYSA-N;
MW          136.575;      // g/mol [origin=calculated method=formula-sum]
Tc          591.87;      // K   [origin=predictive method=joback]
Pc          33.412;      // bar [origin=predictive method=joback]
omega       0.4598;      // -   [origin=predictive method=lee-kesler]
Tb          409.65;      // K   [origin=predictive method=joback]
HvapTb      38516.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.643 0.43082 -0.000174 2e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3COO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylpropyl ethanoate" "1-propanol, 3-chloro-, acetate" "3-chloropropanol acetate" "gamma-chloropropyl acetate" ".gamma.-chloropropyl acetate" "3-chlorprop-1-ylacetat [german]" "acetic acid 3-chloro-propyl ester" "3-chlorprop-1-ylacetat" "1-acetoxy-3-chloropropane" "3-chloro-propyl acetate" "1-propanol, 3-chloro-,1-acetate" "u264" );
standardThermochemistry
{
    dHf_298   -479550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-331080.0
}
