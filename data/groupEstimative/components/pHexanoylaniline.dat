/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-hexanoylaniline  (C12H17NO, CAS 38237-76-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pHexanoylaniline;
formula     C12H17NO;
CAS         38237-76-2;
InChIKey    YDQJFPLRVSPPGE-UHFFFAOYSA-N;
MW          191.274;      // g/mol [origin=calculated method=formula-sum]
Tc          849.31;      // K   [origin=predictive method=joback]
Pc          26.735;      // bar [origin=predictive method=joback]
omega       0.8012;      // -   [origin=predictive method=lee-kesler]
Tb          632.22;      // K   [origin=predictive method=joback]
HvapTb      62631.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.776 1.03932 -0.00061786 1.3416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-aminophenyl)hexan-1-one" "p-amino caprophenone" "4'-aminohexanophenone" "4-aminohexanoylphenone" "caprophenone, p-amino-" "hexanophenone, 4'-amino-" "4-hexanoylaniline" );
standardThermochemistry
{
    dHf_298   -144740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     589.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90470.0
}
