/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[3.2.1.02,4]octane,3,3-dimethyl-8-methylene  (C11H16, CAS 66930-02-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo321024Octane33Dimethyl8Methylene;
formula     C11H16;
CAS         66930-02-7;
InChIKey    QVLXPNOMPCIUJR-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          662.47;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       0.3649;      // -   [origin=predictive method=lee-kesler]
Tb          457.29;      // K   [origin=predictive method=joback]
HvapTb      38037.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-168.54 1.63254 -0.001611 6.6e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 4; } { group C; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo(3.2.1.02,4)octane, 3,3-dimethyl-8-methylene-, (1alpha,2alpha,4alpha,5alpha)-" "3,3-dimethyl-8-methylidenetricyclo[3.2.1.02,4]octane" "tricyclo[3.2.1.0(2,4)]octane, 3,3-dimethyl-8-methylene-, (1.alpha.,2.alpha.,4.alpha.,5.alpha.)-" );
standardThermochemistry
{
    dHf_298   12990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     252.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=268260.0
}
