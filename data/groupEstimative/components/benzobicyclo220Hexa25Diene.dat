/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzobicyclo(2.2.0)hexa-2,5-diene  (C10H8, CAS 20847-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzobicyclo220Hexa25Diene;
formula     C10H8;
CAS         20847-82-9;
InChIKey    JYKMWOMRHHJZMI-UHFFFAOYSA-N;
MW          128.174;      // g/mol [origin=calculated method=formula-sum]
Tc          690.53;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.3774;      // -   [origin=predictive method=lee-kesler]
Tb          464.16;      // K   [origin=predictive method=joback]
HvapTb      40566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.27 1.0804 -0.00100484 3.71e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzobicyclo[2.2.0]hexa-2,5-diene" "tricyclo[4.4.0.02,5]deca-1(10),3,6,8-tetraene" );
gibbsFormation
{
    dHf_298   191030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     175.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=311760.0
    phase     gas;
}
