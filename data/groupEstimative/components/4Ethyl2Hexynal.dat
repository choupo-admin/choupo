/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethyl-2-hexynal  (C8H12O, CAS 71932-97-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethyl2Hexynal;
formula     C8H12O;
CAS         71932-97-3;
InChIKey    XZYAPQCJDYFPBN-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          638.87;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.4275;      // -   [origin=predictive method=lee-kesler]
Tb          439.86;      // K   [origin=predictive method=joback]
HvapTb      41886.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.892 0.59444 -0.00031546 6.038e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CHO; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group tC; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethylhex-2-ynal" "hex-2-ynal, 4-ethyl-" "2-hexynal, 4-ethyl-" );
standardThermochemistry
{
    dHf_298   -27010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117320.0
}
