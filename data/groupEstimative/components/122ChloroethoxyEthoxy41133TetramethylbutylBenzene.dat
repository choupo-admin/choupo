/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-(2-chloroethoxy)ethoxy)-4-(1,1,3,3-tetramethylbutyl)benzene  (C18H29ClO2, CAS 65925-28-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        122ChloroethoxyEthoxy41133TetramethylbutylBenzene;
formula     C18H29ClO2;
CAS         65925-28-2;
InChIKey    FITQCDWGUKECBJ-UHFFFAOYSA-N;
MW          312.878;      // g/mol [origin=calculated method=formula-sum]
Tc          924.80;      // K   [origin=predictive method=joback]
Pc          14.101;      // bar [origin=predictive method=joback]
omega       0.7500;      // -   [origin=predictive method=lee-kesler]
Tb          718.91;      // K   [origin=predictive method=joback]
HvapTb      65213.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.135 1.7075 -0.00106156 2.468e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-(2-chloroethyloxy)ethoxy]-4-(2,4,4-trimethylpentan-2-yl)benzene" "1-[2-(2-chloroethoxy)ethoxy]-4-(1,1,3,3-tetramethylbutyl)benzene" "benzene, 1-[2-(2-chloroethoxy)ethoxy]-4-(1,1,3,3-tetramethylbutyl)-" "benzene, 1-(2-(2-chloroethoxy)ethoxy)-4-(1,1,3,3-tetramethylbutyl)-" "1-[2-(2-chloroethoxy)ethoxy]-4-(2,4,4-trimethylpentan-2-yl)benzene" );
standardThermochemistry
{
    dHf_298   -487470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     722.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12790.0
}
