/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonadecanenitrile  (C19H37N, CAS 28623-46-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonadecanenitrile;
formula     C19H37N;
CAS         28623-46-3;
InChIKey    MVDGSHXQMOKTDJ-UHFFFAOYSA-N;
MW          279.512;      // g/mol [origin=calculated method=formula-sum]
Tc          912.18;      // K   [origin=predictive method=joback]
Pc          10.631;      // bar [origin=predictive method=joback]
omega       0.8920;      // -   [origin=predictive method=lee-kesler]
Tb          736.40;      // K   [origin=predictive method=joback]
HvapTb      68366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.617 1.74362 -0.0009788 2.086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonadecanonitrile" "octadecyl cyanide" "nitriles, c16-22" "1-cyanooctadecane" "stearyl cyanide" "nonadecane nitrile" "(c16-c22)alkylnitrile" );
gibbsFormation
{
    dHf_298   -270610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     902.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=242280.0
    phase     gas;
}
