/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane, 2,2-diiodo-  (C3H6I2, CAS 630-13-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propane22Diiodo;
formula     C3H6I2;
CAS         630-13-7;
InChIKey    AZUCPFMKPGFGTB-UHFFFAOYSA-N;
MW          295.881;      // g/mol [origin=calculated method=formula-sum]
Tc          718.10;      // K   [origin=predictive method=joback]
Pc          42.663;      // bar [origin=predictive method=joback]
omega       0.1680;      // -   [origin=predictive method=lee-kesler]
Tb          451.29;      // K   [origin=predictive method=joback]
HvapTb      39722.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.93 0.49264 -0.000474 1.762e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(iodanyl)propane" "agn-pc-00a0f4" );
standardThermochemistry
{
    dHf_298   39740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     345.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93460.0
}
