/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-(+)-pantolactone  (C6H10O3, CAS 5405-40-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sPantolactone;
formula     C6H10O3;
CAS         5405-40-3;
InChIKey    SERHXTVXHNVDKA-SCSAIBSYSA-N;
MW          130.143;      // g/mol [origin=calculated method=formula-sum]
Tc          676.83;      // K   [origin=predictive method=joback]
Pc          41.356;      // bar [origin=predictive method=joback]
omega       0.8208;      // -   [origin=predictive method=lee-kesler]
Tb          489.59;      // K   [origin=predictive method=joback]
HvapTb      51489.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.16 0.96934 -0.0009358 3.82e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s)-4,4-dimethyl-3-oxidanyl-oxolan-2-one" "l-pantolactone" "(3s)-3-hydroxy-4,4-dimethyldihydrofuran-2(3h)-one" "(s)-3-hydroxy-4,4-dimethyldihydrofuran-2(3h)-one" "(s)-dihydro-3-hydroxy-4,4-dimethyl-2(3h)-furanone" "(s)-(+)-alpha-hydroxy-beta,beta-dimethyl-gamma-butyrolactone" "(s)-(+)-beta,beta-dimethyl-alpha-hydroxy-gamma-butyrolactone" "l-()-pantoyl lactone" "l-(+)-pantoyl lactone" "(3s)-3-hydroxy-4,4-dimethyl-2-oxolanone" "(3s)-3-hydroxy-4,4-dimethyloxolan-2-one" "(s)-(+)-" "a," "a-dimethyl-" "a-hydroxy-" "a-butyrolactone" );
gibbsFormation
{
    dHf_298   -568980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-400000.0
    phase     gas;
}
