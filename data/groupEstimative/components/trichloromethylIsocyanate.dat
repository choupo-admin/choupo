/*--------------------------------*- Choupo -*-----------------------*\
  Component: trichloromethyl isocyanate  (C2Cl3NO, CAS 30121-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trichloromethylIsocyanate;
formula     C2Cl3NO;
CAS         30121-98-3;
InChIKey    OXBFBRZWBIXFGO-UHFFFAOYSA-N;
MW          160.378;      // g/mol [origin=calculated method=formula-sum]
Tc          642.61;      // K   [origin=predictive method=joback]
Pc          49.039;      // bar [origin=predictive method=joback]
omega       0.3586;      // -   [origin=predictive method=lee-kesler]
Tb          421.09;      // K   [origin=predictive method=joback]
HvapTb      41437.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group C; count 1; } { group dCd; count 1; } { group Cl; count 3; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(chloranyl)-isocyanato-methane" "trichloro(isocyanato)methane" "snylbqdjhtqdtauth@" "trichloromethylisocyanate" "methane,trichloroisocyanato-" "methane, trichloroisocyanato-" "isocyanic acid trichloromethyl ester" "isocyanic acid, trichloromethyl ester" "isocyanicacid, trichloromethyl ester (7ci,8ci);trichloromethyl isocyanate;trichloro(isocyanato)methane;" );
