/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1-phenyl-1-butanol  (C11H16O, CAS 3968-86-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Phenyl1Butanol;
formula     C11H16O;
CAS         3968-86-3;
InChIKey    XYYQWQIEEXLXDX-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          767.02;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.8371;      // -   [origin=predictive method=lee-kesler]
Tb          569.26;      // K   [origin=predictive method=joback]
HvapTb      58259.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.089 1.01574 -0.0006426 1.54e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-1-phenyl-butan-1-ol" "agn-pc-0d4sm3" "2-methyl-1-phenylbutan-1-ol" "benzenemethanol, a-(1-methylpropyl)-" "(1s,2r)-2-methyl-1-phenylbutan-1-ol" "benzylalcohol, a-sec-butyl- (6ci,7ci,8ci); a-(1-methylpropyl)benzenemethanol;a-sec-butylbenzyl alcohol" );
gibbsFormation
{
    dHf_298   -196630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12450.0
    phase     gas;
}
