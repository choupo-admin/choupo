/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 2-oxidanylpropanoate;ethyl prop-2-enoate;methyl 2-methylprop-2-enoate  (C17H30O7, CAS 65379-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl2OxidanylpropanoateEthylProp2EnoateMethyl2Methylprop2En;
formula     C17H30O7;
CAS         65379-49-9;
InChIKey    NYMULGZZMRSNIH-UHFFFAOYSA-N;
MW          346.42;      // g/mol [origin=calculated method=formula-sum]
Tc          1045.65;      // K   [origin=predictive method=joback]
Pc          12.557;      // bar [origin=predictive method=joback]
omega       1.1298;      // -   [origin=predictive method=lee-kesler]
Tb          851.00;      // K   [origin=predictive method=joback]
HvapTb      91276.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (143.234 1.0419 0.0001307 -3.687e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, methyl ester, polymer with butyl 2-hydroxypropanoate and ethyl 2-propenoate" "butyl 2-hydroxypropanoate; ethyl prop-2-enoate; methyl 2-methylprop-2-enoate" );
gibbsFormation
{
    dHf_298   -1485730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1215.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1020500.0
    phase     gas;
}
