/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-bromophenoxy)ethanol  (C8H9BrO2, CAS 34743-88-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24BromophenoxyEthanol;
formula     C8H9BrO2;
CAS         34743-88-9;
InChIKey    QYIOGYCRGNHDNK-UHFFFAOYSA-N;
MW          217.062;      // g/mol [origin=calculated method=formula-sum]
Tc          805.32;      // K   [origin=predictive method=joback]
Pc          42.943;      // bar [origin=predictive method=joback]
omega       1.0050;      // -   [origin=predictive method=lee-kesler]
Tb          595.06;      // K   [origin=predictive method=joback]
HvapTb      61864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.992 0.6344 -0.00036636 7.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group Br; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-bromanylphenoxy)ethanol" "2-(p-bromophenoxy)ethanol" ".beta.-(p-bromophenoxy)ethanol" "2-(4-bromophenoxy)ethan-1-ol" "ethanol, 2-(4-bromophenoxy)-" "ethylene glycol mono(4-bromophenyl) ether" "2-(4'-bromophenoxy)ethanol" );
standardThermochemistry
{
    dHf_298   -241510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-108240.0
}
