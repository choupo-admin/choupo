/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-cyclopentadiene,2-methyl-  (C6H8, CAS 3727-31-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Cyclopentadiene2Methyl;
formula     C6H8;
CAS         3727-31-9;
InChIKey    AHQZRFBZJSCKAV-UHFFFAOYSA-N;
MW          80.13;      // g/mol [origin=calculated method=formula-sum]
Tc          561.98;      // K   [origin=predictive method=joback]
Pc          43.056;      // bar [origin=predictive method=joback]
omega       0.2336;      // -   [origin=predictive method=lee-kesler]
Tb          360.13;      // K   [origin=predictive method=joback]
HvapTb      30762.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.13 0.56052 -0.00039292 1.114e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylcyclopenta-1,3-diene" "2-methyl-1,3-cyclopentadiene" "2-methylcyclopentadiene" "2-methyl-1,3-cyclopentanediene" "cyclopentadiene,2-methyl- (6ci,7ci); 2-methyl-1,3-cyclopentadiene; 2-methylcyclopentadiene" );
standardThermochemistry
{
    dHf_298   17740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     300.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94190.0
}
