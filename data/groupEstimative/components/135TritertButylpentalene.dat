/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-tritert-butylpentalene  (C20H30, CAS 50356-52-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135TritertButylpentalene;
formula     C20H30;
CAS         50356-52-0;
InChIKey    LSMDTOOJZQSBES-UHFFFAOYSA-N;
MW          270.46;      // g/mol [origin=calculated method=formula-sum]
Tc          922.21;      // K   [origin=predictive method=joback]
Pc          14.392;      // bar [origin=predictive method=joback]
omega       0.5829;      // -   [origin=predictive method=lee-kesler]
Tb          700.41;      // K   [origin=predictive method=joback]
HvapTb      61492.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.7 2.09548 -0.00165192 5.3e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 9; } { group C; count 3; } { group CH=C; count 3; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group C; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentalene,1,3,5-tris(1,1-dimethylethyl)-" "1,3,5-tri-tert-butylpentalene" );
gibbsFormation
{
    dHf_298   -134650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=310450.0
    phase     gas;
}
