/*--------------------------------*- Choupo -*-----------------------*\
  Component: vectomer(tm) 4020 vinyl ether  (C25H40O6, CAS 131132-77-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vectomerTm4020VinylEther;
formula     C25H40O6;
CAS         131132-77-9;
InChIKey    SDNBHBGJJPWRJG-UHFFFAOYSA-N;
MW          436.589;      // g/mol [origin=calculated method=formula-sum]
Tc          1173.09;      // K   [origin=predictive method=joback]
Pc          9.681;      // bar [origin=predictive method=joback]
omega       0.9129;      // -   [origin=predictive method=lee-kesler]
Tb          956.00;      // K   [origin=predictive method=joback]
HvapTb      89778.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.333 2.294 -0.001022 6.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 4; } { group CH2=CH; count 2; } { group CH2COO; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group dCH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[[4-(ethenoxymethyl)cyclohexyl]methyl] pentanedioate" "bis[4-(vinyloxymethyl)cyclohexylmethyl] glutarate" "pentanedioic acid, bis((4-((ethenyloxy)methyl)cyclohexyl)methyl) ester" "pentanedioic acid,1,5-bis[[4-[(ethenyloxy)methyl]cyclohexyl]methyl] ester" "pentanedioic acid, 1,5-bis((4-((ethenyloxy)methyl)cyclohexyl)methyl) ester" "pentanedioic acid, 1,5-bis[[4-[(ethenyloxy)methyl]cyclohexyl]methyl] ester" "pentanedioic acid, bis[[4-[(ethenyloxy)methyl]cyclohexyl]methyl] ester" "vectomer&reg; 4020 vinyl ether" );
standardThermochemistry
{
    dHf_298   -1139510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1100.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-461960.0
}
