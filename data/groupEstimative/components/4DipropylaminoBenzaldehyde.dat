/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(dipropylamino)benzaldehyde  (C13H19NO, CAS 613-28-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H19NO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4DipropylaminoBenzaldehyde;
formula     C13H19NO;
CAS         613-28-5;
InChIKey    HDOZLDYBGNJMMZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          205.301;      // g/mol [origin=calculated method=formula-sum]
Tc          712.34;      // K   [origin=predictive method=joback]
Pc          22.504;      // bar [origin=predictive method=joback]
omega       0.5443;      // -   [origin=predictive method=lee-kesler]
Tb          517.56;      // K   [origin=predictive method=joback]
HvapTb      47140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.726 1.23244 -0.00091316 2.782e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-(dipropylamino)benzaldehyde" "benzaldehyde, 4-(dipropylamino)-" "4-dipropylamino-benzaldehyde" "benzaldehyde,4-(dipropylamino)-" "4-(n,n-dipropylamino)benzaldehyde" );
standardThermochemistry
{
    dHf_298   57390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=316100.0
}
