/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-4-methylcyclohexane  (C7H13Br, CAS 6294-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo4Methylcyclohexane;
formula     C7H13Br;
CAS         6294-40-2;
InChIKey    RLOHLPHAOHGRNM-UHFFFAOYSA-N;
MW          177.085;      // g/mol [origin=calculated method=formula-sum]
Tc          663.70;      // K   [origin=predictive method=joback]
Pc          36.776;      // bar [origin=predictive method=joback]
omega       0.3128;      // -   [origin=predictive method=lee-kesler]
Tb          440.80;      // K   [origin=predictive method=joback]
HvapTb      37731.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.95 0.80262 -0.000454 8.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-methyl-cyclohexane" "p-methylcyclohexyl bromide" "cyclohexane, 1-bromo-4-methyl-" "4-bromo-1-methylcyclohexane" "cyclohexane, 1-bromo-4-methyl-, trans-" );
standardThermochemistry
{
    dHf_298   -127500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39120.0
}
