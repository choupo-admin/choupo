/*--------------------------------*- Choupo -*-----------------------*\
  Component: acrylonitrile butadiene styrene  (C15H17N, CAS 9003-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acrylonitrileButadieneStyrene;
formula     C15H17N;
CAS         9003-56-9;
InChIKey    XECAHXYUAAWDEL-UHFFFAOYSA-N;
MW          211.308;      // g/mol [origin=calculated method=formula-sum]
Tc          895.82;      // K   [origin=predictive method=joback]
Pc          17.955;      // bar [origin=predictive method=joback]
omega       0.5209;      // -   [origin=predictive method=lee-kesler]
Tb          661.08;      // K   [origin=predictive method=joback]
HvapTb      59646.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.02 0.7923 -5.44e-05 -1.783e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 3; } { group ACH; count 5; } { group AC; count 1; } { group ACRY; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 4; } { group dCH; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "abs resin" "buta-1,3-diene;ethenylbenzene;prop-2-enenitrile" "acrylonitrile-butadiene-styrene copolymer" "acrylonitrile-butadiene-styrene copolymers" "styrene, acrylonitrile, butadiene polymer" "2-propenenitrile, polymer with 1,3-butadiene and ethenylbenzene" "buta-1,3-diene; prop-2-enenitrile; styrene" "abs" "acrylonitrile, polymer with 1,3-butadiene and styrene" "poly(acrylonitrile-co-butadiene-co-styrene)" "acrylonitrile 1,3-butadiene styrene polymer" "67952-85-6 (ammonium salt)" );
gibbsFormation
{
    dHf_298   326960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     836.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=462850.0
    phase     gas;
}
