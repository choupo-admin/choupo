/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-4-methylpentane  (C6H13Br, CAS 30310-22-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo4Methylpentane;
formula     C6H13Br;
CAS         30310-22-6;
InChIKey    IUXIOXCOPJFKMQ-UHFFFAOYSA-N;
MW          165.074;      // g/mol [origin=calculated method=formula-sum]
Tc          594.88;      // K   [origin=predictive method=joback]
Pc          34.239;      // bar [origin=predictive method=joback]
omega       0.3602;      // -   [origin=predictive method=lee-kesler]
Tb          402.16;      // K   [origin=predictive method=joback]
HvapTb      34609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.261 0.62386 -0.0003804 9.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-4-methyl-pentane" "pentane, 2-bromo-4-methyl-" "4-bromo-2-methylpentane" "2-bromo-4-methyl-pentane" "pentane,2-bromo-4-methyl-" "2-bromo-4-methylpentane;4-methyl-2-pentyl bromide;pentane, 2-bromo-4-methyl-;" );
standardThermochemistry
{
    dHf_298   -151400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9080.0
}
