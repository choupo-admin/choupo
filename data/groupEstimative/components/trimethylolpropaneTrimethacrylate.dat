/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolpropane trimethacrylate  (C18H26O6, CAS 3290-92-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolpropaneTrimethacrylate;
formula     C18H26O6;
CAS         3290-92-4;
InChIKey    OKKRPWIIYQTPQF-UHFFFAOYSA-N;
MW          338.4;      // g/mol [origin=calculated method=formula-sum]
Tc          965.96;      // K   [origin=predictive method=joback]
Pc          13.023;      // bar [origin=predictive method=joback]
omega       0.9606;      // -   [origin=predictive method=lee-kesler]
Tb          772.55;      // K   [origin=predictive method=joback]
HvapTb      74817.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.234 1.61498 -0.000919 1.612e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group CH2=C; count 3; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group dCH2; count 3; } { group dC; count 3; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(2-methylprop-2-enoyloxymethyl)butyl 2-methylprop-2-enoate" "acryester tmp" "chemlink 30" "ptma" "blemmer ptt" "light ester tmp" "hi-cross m" "nk ester tmpt" "tmptma" "nk ester m tmpt" "trimethylolpropane trimethancrylate" "perkalink 400-50d" );
gibbsFormation
{
    dHf_298   -1028520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     945.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-589720.0
    phase     gas;
}
