/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-dimethylnaphthalene  (C12H12, CAS 569-41-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Dimethylnaphthalene;
formula     C12H12;
CAS         569-41-5;
InChIKey    XAABPYINPXYOLM-UHFFFAOYSA-N;
MW          156.228;      // g/mol [origin=calculated method=formula-sum]
Tc          761.43;      // K   [origin=predictive method=joback]
Pc          30.057;      // bar [origin=predictive method=joback]
omega       0.4415;      // -   [origin=predictive method=lee-kesler]
Tb          529.78;      // K   [origin=predictive method=joback]
HvapTb      47546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.77 0.94224 -0.00066284 1.884e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACCH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene, 1,8-dimethyl-" "ambap569-41-5" "1,8-dmn" );
standardThermochemistry
{
    dHf_298   113650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=249960.0
}
