/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,5-trimethyl-1,3-dioxane-4,6-dione  (C7H10O4, CAS 3709-18-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        225Trimethyl13Dioxane46Dione;
formula     C7H10O4;
CAS         3709-18-0;
InChIKey    KJMCAXYHYPDRAV-UHFFFAOYSA-N;
MW          158.153;      // g/mol [origin=calculated method=formula-sum]
Tc          668.43;      // K   [origin=predictive method=joback]
Pc          32.173;      // bar [origin=predictive method=joback]
omega       0.5762;      // -   [origin=predictive method=lee-kesler]
Tb          474.24;      // K   [origin=predictive method=joback]
HvapTb      44271.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.83 0.98516 -0.0009116 3.569e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycl-isopropylidene methylmalonate" "methyl meldrum's acid" "methylmalonic acid cyclic isopropylidene ester" "kjmcaxyhypdrav-uhfffaoysa-" "i137" "1,3-dioxane-4,6-dione,2,2,5-trimethyl-" "methyl meldrum inverted exclamation mark s acid" );
standardThermochemistry
{
    dHf_298   -748510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-553030.0
}
