/*--------------------------------*- Choupo -*-----------------------*\
  Component: {3-[bis(2-chloroethyl)amino]phenyl}(piperidin-1-yl)methanone  (C16H22Cl2N2O, CAS 24813-03-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bis2ChloroethylAminoPhenylPiperidin1YlMethanone;
formula     C16H22Cl2N2O;
CAS         24813-03-4;
InChIKey    IEJBRKRLLHCIRJ-UHFFFAOYSA-N;
MW          329.265;      // g/mol [origin=calculated method=formula-sum]
Tc          993.79;      // K   [origin=predictive method=joback]
Pc          19.930;      // bar [origin=predictive method=joback]
omega       0.9699;      // -   [origin=predictive method=lee-kesler]
Tb          770.90;      // K   [origin=predictive method=joback]
HvapTb      74316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.926 1.777 -0.00124086 3.3126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH2N; count 1; } { group CH2Cl; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-[bis(2-chloroethyl)amino]phenyl]-piperidin-1-yl-methanone" "1-((bis(2-chloroethyl)amino)benzoyl)piperidine" "ketone, m-(bis(2-chloroethyl)amino)phenyl piperidino" "piperidine, 1-(m-(bis(2-chloroethyl)amino)benzoyl)-" "[3-[bis(2-chloroethyl)amino]phenyl]-piperidin-1-ylmethanone" "methanone,[3-[bis(2-chloroethyl)amino]phenyl]-1-piperidinyl-" "piperidine,1-[3-[bis(2-chloroethyl)amino]benzoyl]- (9ci); piperidine,1-[m-[bis(2-chloroethyl)amino]benzoyl]- (8ci)" );
standardThermochemistry
{
    dHf_298   -76690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     784.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=299660.0
}
