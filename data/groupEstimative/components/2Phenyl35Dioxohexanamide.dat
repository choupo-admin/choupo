/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenyl-3,5-dioxohexanamide  (C12H13NO3, CAS 72333-16-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenyl35Dioxohexanamide;
formula     C12H13NO3;
CAS         72333-16-5;
InChIKey    MUMLRUWBPLCGKT-NSHDSACASA-N;
MW          219.24;      // g/mol [origin=calculated method=formula-sum]
Tc          967.21;      // K   [origin=predictive method=joback]
Pc          31.385;      // bar [origin=predictive method=joback]
omega       1.0656;      // -   [origin=predictive method=lee-kesler]
Tb          734.54;      // K   [origin=predictive method=joback]
HvapTb      75073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.039 1.04872 -0.0006507 1.4048e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-3,5-bis(oxidanylidene)-2-phenyl-hexanamide" "benzeneacetamide, alpha-(1,3-dioxobutyl)-" "(2s)-3,5-dioxo-2-phenylhexanamide" );
gibbsFormation
{
    dHf_298   -363710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-160180.0
    phase     gas;
}
