/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzobicyclo[2.2.2]octadiene  (C16H14, CAS 5675-64-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzobicyclo222Octadiene;
formula     C16H14;
CAS         5675-64-9;
InChIKey    VPPCQVCZKDIGGG-UHFFFAOYSA-N;
MW          206.288;      // g/mol [origin=calculated method=formula-sum]
Tc          883.67;      // K   [origin=predictive method=joback]
Pc          27.354;      // bar [origin=predictive method=joback]
omega       0.5648;      // -   [origin=predictive method=lee-kesler]
Tb          633.94;      // K   [origin=predictive method=joback]
HvapTb      56568.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.11 1.568 -0.00130812 4.388e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10-ethanoanthracene, 9,10-dihydro-" "9,10-ethanoanthracene" "agn-pc-02lwpw" "agn-pc-03dq26" "tetracyclo[6.6.2.0^{2,7}.0^{9,14}]hexadeca-2(7),3,5,9(14),10,12-hexaene" "{dibenzobicyclo[2.2.2]octadiene}; 1,4-endo-o-phenylenenaphthalene, 1,2,3,4-tetrahydro-; 9, 10-ethanoanthracene, 9,10-dihydro-; 9,10-dihydro-9,10-ethanoanthracene" );
gibbsFormation
{
    dHf_298   234470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     333.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=435100.0
    phase     gas;
}
