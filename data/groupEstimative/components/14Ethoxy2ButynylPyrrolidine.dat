/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-ethoxy-2-butynyl)pyrrolidine  (C10H17NO, CAS 3921-98-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Ethoxy2ButynylPyrrolidine;
formula     C10H17NO;
CAS         3921-98-0;
InChIKey    ZBAFCMGYLCWSKS-UHFFFAOYSA-N;
MW          167.252;      // g/mol [origin=calculated method=formula-sum]
Tc          691.87;      // K   [origin=predictive method=joback]
Pc          29.250;      // bar [origin=predictive method=joback]
omega       0.4997;      // -   [origin=predictive method=lee-kesler]
Tb          487.94;      // K   [origin=predictive method=joback]
HvapTb      44853.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.137 1.03252 -0.00065886 1.6698e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH2O; count 1; } { group CH2N; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group tC; count 2; } { group CH2_ring; count 4; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-ethoxybut-2-ynyl)pyrrolidine" "pyrrolidine, 1-(4-ethoxy-2-butynyl)-" );
standardThermochemistry
{
    dHf_298   44860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=298260.0
}
