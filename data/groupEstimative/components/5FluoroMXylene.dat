/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-fluoro-m-xylene  (C8H9F, CAS 461-97-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5FluoroMXylene;
formula     C8H9F;
CAS         461-97-2;
InChIKey    RCWIWNUVHNAUQC-UHFFFAOYSA-N;
MW          124.158;      // g/mol [origin=calculated method=formula-sum]
Tc          619.47;      // K   [origin=predictive method=joback]
Pc          33.412;      // bar [origin=predictive method=joback]
omega       0.3486;      // -   [origin=predictive method=lee-kesler]
Tb          418.55;      // K   [origin=predictive method=joback]
HvapTb      36185.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.6 0.57774 -0.00032492 6.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-3,5-dimethyl-benzene" "3,5-dimethylfluorobenzene" "1-fluoro-3,5-dimethylbenzene" "1,3-dimethyl-5-fluorobenzene" "1-fluoro-3,5-dimethyl-benzene" "u443" "m-xylene,5-fluoro- (7ci,8ci);1-fluoro-3,5-dimethylbenzene;3,5-dimethylfluorobenzene;5-fluoro-1,3-dimethylbenzene;5-fluoro-m-xylene;" );
gibbsFormation
{
    dHf_298   -190970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85180.0
    phase     gas;
}
