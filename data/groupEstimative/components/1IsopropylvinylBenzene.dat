/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-isopropylvinyl)benzene  (C11H14, CAS 17498-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1IsopropylvinylBenzene;
formula     C11H14;
CAS         17498-71-4;
InChIKey    POZGETMIPGBFGQ-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          689.58;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       0.3564;      // -   [origin=predictive method=lee-kesler]
Tb          474.08;      // K   [origin=predictive method=joback]
HvapTb      41378.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.38 0.95574 -0.0006342 1.639e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbut-1-en-2-ylbenzene" "benzene, (2-methyl-1-methylenepropyl)-" "1-isopropylvinylbenzene" "(2-methyl-1-methylene-propyl)-benzene" );
standardThermochemistry
{
    dHf_298   76520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=231000.0
}
