/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-h-02033  (C15H22N2, CAS 75751-20-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agH02033;
formula     C15H22N2;
CAS         75751-20-1;
InChIKey    WWHRITWAHDSGEL-UHFFFAOYSA-N;
MW          230.355;      // g/mol [origin=calculated method=formula-sum]
Tc          840.81;      // K   [origin=predictive method=joback]
Pc          23.496;      // bar [origin=predictive method=joback]
omega       0.6998;      // -   [origin=predictive method=lee-kesler]
Tb          623.42;      // K   [origin=predictive method=joback]
HvapTb      56144.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-174.43 2.04908 -0.00192228 7.476e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 2; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5,6-tetramethylspiro[benzimidazole-2,1'-cyclopentane]" "1',3',5',6'-tetramethylspiro[cyclopentane-1,2'-(2,3-dihydrobenzimidazole)]" "1',3',5',6'-tetramethylspiro(cyclopentane-1,2'-(2,3-dihydrobenzo[d]imidazole))" "1',3',5',6'-tetramethylspiro(cyclopentane-1,2'-(2,3-dihydrobenzimidazole))" "1,3,5,6-tetramethyl-1,3-dihydrospiro[benzimidazole-2,1'-cyclopentane]" );
standardThermochemistry
{
    dHf_298   171590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=516320.0
}
