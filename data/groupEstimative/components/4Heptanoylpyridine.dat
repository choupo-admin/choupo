/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-heptanoylpyridine  (C12H17NO, CAS 32941-30-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Heptanoylpyridine;
formula     C12H17NO;
CAS         32941-30-3;
InChIKey    MLBWTXHUVGBPNL-UHFFFAOYSA-N;
MW          191.274;      // g/mol [origin=calculated method=formula-sum]
Tc          824.14;      // K   [origin=predictive method=joback]
Pc          25.637;      // bar [origin=predictive method=joback]
omega       0.7169;      // -   [origin=predictive method=lee-kesler]
Tb          608.41;      // K   [origin=predictive method=joback]
HvapTb      57538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.505 1.07068 -0.00065076 1.4986e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2CO; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group CdO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pyridin-4-ylheptan-1-one" "pyridine, 4-heptanoyl-" "ketone, heptyl 4-pyridyl" "1-(4-pyridyl)-1-heptanone" "1-(pyridin-4-yl)heptan-1-one" );
standardThermochemistry
{
    dHf_298   -134270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110700.0
}
