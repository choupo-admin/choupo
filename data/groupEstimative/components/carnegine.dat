/*--------------------------------*- Choupo -*-----------------------*\
  Component: carnegine  (C13H19NO2, CAS 5852-92-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carnegine;
formula     C13H19NO2;
CAS         5852-92-6;
InChIKey    HRSIPKSSEVRSPG-UHFFFAOYSA-N;
MW          221.3;      // g/mol [origin=calculated method=formula-sum]
Tc          810.04;      // K   [origin=predictive method=joback]
Pc          22.981;      // bar [origin=predictive method=joback]
omega       0.7121;      // -   [origin=predictive method=lee-kesler]
Tb          602.68;      // K   [origin=predictive method=joback]
HvapTb      55570.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.87 1.12988 -0.00062428 1.214e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3O; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,7-dimethoxy-1,2-dimethyl-3,4-dihydro-1h-isoquinoline" "carnegine hcl" "isoquinoline, 1,2,3,4-tetrahydro-6,7-dimethoxy-1,2-dimethyl-, (.+/-.)-" "6,7-dimethoxy-1,2-dimethyl-1,2,3,4-tetrahydroisoquinoline" "(+-)-1,2,3,4-tetrahydro-6,7-dimethoxy-1,2-dimethylisoquinoline" "isoquinoline, 1,2,3,4-tetrahydro-6,7-dimethoxy-1,2-dimethyl- (.+-.)-" "isoquinoline, 1,2,3,4-tetrahydro-6,7-dimethoxy-1,2-dimethyl-, (+-)-" "isoquinoline, 1,2,3,4-tetrahydro-6,7-dimethoxy-1,2-dimethyl-, (.+-.)-" );
gibbsFormation
{
    dHf_298   -233640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103630.0
    phase     gas;
}
