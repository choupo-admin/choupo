/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisopropyl (s)-(-)-malate  (C10H18O5, CAS 83541-68-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisopropylSMalate;
formula     C10H18O5;
CAS         83541-68-8;
InChIKey    XYVHRFVONMVDGK-QMMMGPOBSA-N;
MW          218.249;      // g/mol [origin=calculated method=formula-sum]
Tc          813.36;      // K   [origin=predictive method=joback]
Pc          23.749;      // bar [origin=predictive method=joback]
omega       1.1693;      // -   [origin=predictive method=lee-kesler]
Tb          635.70;      // K   [origin=predictive method=joback]
HvapTb      68183.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.861 0.89598 -0.000371 1.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 3; } { group OH; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 3; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipropan-2-yl (2s)-2-oxidanylbutanedioate" "(-)-diisopropyl-l-malate" );
gibbsFormation
{
    dHf_298   -1052360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     670.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-731560.0
    phase     gas;
}
