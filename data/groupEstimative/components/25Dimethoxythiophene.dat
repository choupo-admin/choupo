/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethoxythiophene  (C6H8O2S, CAS 58386-20-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethoxythiophene;
formula     C6H8O2S;
CAS         58386-20-2;
InChIKey    FPRUDKWOQNIYOG-UHFFFAOYSA-N;
MW          144.188;      // g/mol [origin=calculated method=formula-sum]
Tc          676.11;      // K   [origin=predictive method=joback]
Pc          40.108;      // bar [origin=predictive method=joback]
omega       0.4273;      // -   [origin=predictive method=lee-kesler]
Tb          457.78;      // K   [origin=predictive method=joback]
HvapTb      42056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.99 0.38905 -0.00012258 -1.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3O; count 2; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group O; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thiophene, 2,5-dimethoxy-" );
gibbsFormation
{
    dHf_298   -212910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     367.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85580.0
    phase     gas;
}
