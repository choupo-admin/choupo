/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-dodecylresorcinol  (C18H30O2, CAS 24305-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Dodecylresorcinol;
formula     C18H30O2;
CAS         24305-56-4;
InChIKey    JJWVPHWHEGQZOE-UHFFFAOYSA-N;
MW          278.436;      // g/mol [origin=calculated method=formula-sum]
Tc          1004.50;      // K   [origin=predictive method=joback]
Pc          18.627;      // bar [origin=predictive method=joback]
omega       1.1897;      // -   [origin=predictive method=lee-kesler]
Tb          799.36;      // K   [origin=predictive method=joback]
HvapTb      83966.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.219 1.94412 -0.00149932 4.947e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-dodecylbenzene-1,3-diol" "4-n-dodecylresorcinol" "4-n-laurylresorcinol" "1,3-benzenediol,4-dodecyl-" "ambap24305-56-4" );
standardThermochemistry
{
    dHf_298   -532940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     803.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96150.0
}
