/*--------------------------------*- Choupo -*-----------------------*\
  Component: dihydroxymaleic acid  (C4H4O6, CAS 526-84-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dihydroxymaleicAcid;
formula     C4H4O6;
CAS         526-84-1;
InChIKey    BZCOSCNPHJNQBP-UPHRSURJSA-N;
MW          148.07;      // g/mol [origin=calculated method=formula-sum]
Tc          970.93;      // K   [origin=predictive method=joback]
Pc          72.063;      // bar [origin=predictive method=joback]
omega       2.2025;      // -   [origin=predictive method=lee-kesler]
Tb          770.42;      // K   [origin=predictive method=joback]
HvapTb      92302.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.47 0.5732 -0.0004882 1.63e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group OH; count 2; } { group COOH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC; count 2; } { group OH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-2,3-bis(oxidanyl)but-2-enedioic acid" "maleic acid, dihydroxy-" "2-butenedioic acid,3-dihydroxy-, (z)-" "2,3-dihydroxymaleic acid" "maleic acid, dihydroxy- (8ci)" "2-butenedioic acid, 2,3-dihydroxy-, (z)- (9ci)" );
standardThermochemistry
{
    dHf_298   -1033250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-915540.0
}
