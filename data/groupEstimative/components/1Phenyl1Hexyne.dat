/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl-1-hexyne  (C12H14, CAS 1129-65-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyl1Hexyne;
formula     C12H14;
CAS         1129-65-3;
InChIKey    VBRLZTLFLNZEPZ-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          736.10;      // K   [origin=predictive method=joback]
Pc          28.323;      // bar [origin=predictive method=joback]
omega       0.3946;      // -   [origin=predictive method=lee-kesler]
Tb          509.84;      // K   [origin=predictive method=joback]
HvapTb      46734.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.367 0.91512 -0.00056806 1.3608e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-1-ynylbenzene" "benzene, 1-hexynyl-" "1-hexyne, 1-phenyl-" "1-hexynylbenzene" "hex-1-ynyl-benzene" "hex-1-yn-1-ylbenzene" "1-butyl-2-phenylacetylene" "benzene, 1-hexyn-1-yl-" "1-hexyne,1-phenyl- (6ci,7ci,8ci); benzene, 1-hexynyl- (9ci); (1-hexyn-1-yl)benzene;1-butyl-2-phenylacetylene; 1-phenyl-1-hexyne; butylphenylacetylene" );
standardThermochemistry
{
    dHf_298   217820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=365370.0
}
