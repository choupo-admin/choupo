/*--------------------------------*- Choupo -*-----------------------*\
  Component: dianol 33  (C21H28O4, CAS 116-37-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dianol33;
formula     C21H28O4;
CAS         116-37-0;
InChIKey    MIUUNYUUEFHIHM-UHFFFAOYSA-N;
MW          344.451;      // g/mol [origin=calculated method=formula-sum]
Tc          1188.55;      // K   [origin=predictive method=joback]
Pc          17.118;      // bar [origin=predictive method=joback]
omega       1.4233;      // -   [origin=predictive method=lee-kesler]
Tb          968.49;      // K   [origin=predictive method=joback]
HvapTb      104322.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.668 1.80128 -0.00106392 2.208e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group C2H4O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-[2-[4-(2-oxidanylpropoxy)phenyl]propan-2-yl]phenoxy]propan-2-ol" "isopropylidenediphenoxypropanol" "bisphenol a bis(2-hydroxypropyl) ether" "hydroxypropylated diphenylolpropane" "oxypropyldiphenylolpropane" "propane, 2,2-bis[4-(2-hydroxypropyloxy)-phenyl]-" "bisphenol a-propylene oxide adduct (1:2)" "1,1'-isopropylidenebis(p-phenyleneoxy)dipropan-2-ol" "bisphenol a bis(beta-hydroxypropyl) ether" "2,2-bis(4-(2-hydroxypropoxy)phenyl)propane" "2,2-bis(p-(2-hydroxypropoxy)phenyl)propane" "2,2-bis(4-(beta-hydroxypropoxy)phenyl)propane" );
standardThermochemistry
{
    dHf_298   -614860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     815.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154180.0
}
