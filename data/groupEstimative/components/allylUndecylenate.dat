/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl undecylenate  (C14H24O2, CAS 7493-76-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylUndecylenate;
formula     C14H24O2;
CAS         7493-76-7;
InChIKey    VJOZUTGJXVDWDJ-UHFFFAOYSA-N;
MW          224.344;      // g/mol [origin=calculated method=formula-sum]
Tc          742.02;      // K   [origin=predictive method=joback]
Pc          16.351;      // bar [origin=predictive method=joback]
omega       0.7724;      // -   [origin=predictive method=lee-kesler]
Tb          571.50;      // K   [origin=predictive method=joback]
HvapTb      52825.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.589 1.239 -0.000689 1.331e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2=CH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group dCH2; count 2; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl undec-10-enoate" "10-undecenoic acid, 2-propenyl ester" "10-undecenoic acid, allyl ester" "10-undecenoic acid, 2-propen-1-yl ester" "allyl undec-10-enoate" "2-propenyl 10-undecenoate" "prop-2-en-1-yl undec-10-enoate" "10-undecenoic acid, allyl ester (8ci)" "10-undecenoic acid,2-propen-1-yl ester" );
standardThermochemistry
{
    dHf_298   -398710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     743.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-67690.0
}
