/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-1,2-cyclohexanediol diacetate  (C10H16O4, CAS 1759-71-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis12CyclohexanediolDiacetate;
formula     C10H16O4;
CAS         1759-71-3;
InChIKey    NSTPWRQTPXJRSP-UHFFFAOYSA-N;
MW          200.234;      // g/mol [origin=calculated method=formula-sum]
Tc          766.17;      // K   [origin=predictive method=joback]
Pc          25.100;      // bar [origin=predictive method=joback]
omega       0.6346;      // -   [origin=predictive method=lee-kesler]
Tb          559.72;      // K   [origin=predictive method=joback]
HvapTb      52788.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.05 0.93984 -0.0003566 -2.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-acetyloxycyclohexyl) ethanoate" "1,2-cyclohexanediol, diacetate, cis-" "cyclohexane, 1,2-diacetoxy-, trans-" "1,2-cyclohexanediol diacetate, trans-" "(2-acetyloxycyclohexyl) acetate" "1,2-cyclohexanol diacetate, cis-" "cyclohexane-cic-1,2-diol diacetate" "[(1s,2r)-2-acetyloxy-2,5,5-trideuteriocyclohexyl] acetate" );
gibbsFormation
{
    dHf_298   -850310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-570680.0
    phase     gas;
}
