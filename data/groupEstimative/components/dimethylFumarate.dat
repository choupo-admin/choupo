/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl fumarate  (C6H8O4, CAS 624-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylFumarate;
formula     C6H8O4;
CAS         624-49-7;
InChIKey    LDCRTTXIJACKKU-ONEGZZNKSA-N;
MW          144.126;      // g/mol [origin=calculated method=formula-sum]
Tc          647.64;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.5673;      // -   [origin=predictive method=lee-kesler]
Tb          457.48;      // K   [origin=predictive method=joback]
HvapTb      43722.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.07 0.48424 -0.0001972 -6.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl (e)-but-2-enedioate" "fumaric acid, dimethyl ester" "fumaderm" "methyl fumarate" "2-butenedioic acid (e)-, dimethyl ester" "dimethyl trans-ethylenedicarboxylate" "boletic acid dimethyl ester" "fumaric acid dimethyl ester" "trans-butenedioic acid dimethyl ester" "allomaleic acid dimethyl ester" "trans-1,2-ethylenedicarboxylic acid dimethyl ester" "dimethyl (2e)-but-2-enedioate" );
gibbsFormation
{
    dHf_298   -684510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-540880.0
    phase     gas;
}
