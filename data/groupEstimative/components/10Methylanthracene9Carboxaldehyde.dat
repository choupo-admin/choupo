/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-methylanthracene-9-carboxaldehyde  (C16H12O, CAS 7072-00-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H12O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        10Methylanthracene9Carboxaldehyde;
formula     C16H12O;
CAS         7072-00-6;
InChIKey    KVWSVUPNZVIFBN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          220.271;      // g/mol [origin=calculated method=formula-sum]
Tc          867.88;      // K   [origin=predictive method=joback]
Pc          26.735;      // bar [origin=predictive method=joback]
omega       0.5451;      // -   [origin=predictive method=lee-kesler]
Tb          621.68;      // K   [origin=predictive method=joback]
HvapTb      56379.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.05 1.26712 -0.00110312 3.889e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 5; } { group ACCH3; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-methylanthracene-9-carbaldehyde" "9-anthracenecarboxaldehyde, 10-methyl-" "9-methyl-10-anthraldehyde" "9-anthracenecarboxaldehyde,10-methyl-" );
gibbsFormation
{
    dHf_298   287140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=424620.0
    phase     gas;
}
