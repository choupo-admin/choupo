/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-dodecanone  (C12H24O, CAS 6064-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Dodecanone;
formula     C12H24O;
CAS         6064-27-3;
InChIKey    ZAQZICGOYPRHCK-UHFFFAOYSA-N;
MW          184.323;      // g/mol [origin=calculated method=formula-sum]
Tc          698.28;      // K   [origin=predictive method=joback]
Pc          18.789;      // bar [origin=predictive method=joback]
omega       0.7145;      // -   [origin=predictive method=lee-kesler]
Tb          528.03;      // K   [origin=predictive method=joback]
HvapTb      49052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.661 1.11584 -0.0006103 1.2256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecan-6-one" "amyl hexylketone" );
gibbsFormation
{
    dHf_298   -403590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-78760.0
    phase     gas;
}
