/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxy-3,4-dihydronaphthalen-1(2h)-one  (C10H10O2, CAS 21032-12-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxy34Dihydronaphthalen12hOne;
formula     C10H10O2;
CAS         21032-12-2;
InChIKey    BGPJTIXJFAGUIF-UHFFFAOYSA-N;
MW          162.188;      // g/mol [origin=calculated method=formula-sum]
Tc          858.85;      // K   [origin=predictive method=joback]
Pc          40.058;      // bar [origin=predictive method=joback]
omega       0.9219;      // -   [origin=predictive method=lee-kesler]
Tb          631.07;      // K   [origin=predictive method=joback]
HvapTb      61803.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.45 0.8224 -0.00044456 7.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanyl-3,4-dihydro-2h-naphthalen-1-one" "4-hydroxy-1-tetralone" "naphthalenone, 3,4-dihydro-4-hydroxy-" "3,4-dihydro-4-hydroxy-1(2h)-naphthalenone" "3,4-dihydro-4-hydroxynaphthalen-1(2h)-one" "4-hydroxy-3,4-dihydro-2h-naphthalen-1-one" "1(2h)-naphthalenone, 3,4-dihydro-4-hydroxy-" );
standardThermochemistry
{
    dHf_298   -247960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-74660.0
}
