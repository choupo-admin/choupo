/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl(1-ethoxyethylidene)malonate  (C11H18O5, CAS 3044-06-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl1EthoxyethylideneMalonate;
formula     C11H18O5;
CAS         3044-06-2;
InChIKey    TWYCKMOLLPVQMA-UHFFFAOYSA-N;
MW          230.26;      // g/mol [origin=calculated method=formula-sum]
Tc          779.08;      // K   [origin=predictive method=joback]
Pc          20.309;      // bar [origin=predictive method=joback]
omega       0.8290;      // -   [origin=predictive method=lee-kesler]
Tb          594.06;      // K   [origin=predictive method=joback]
HvapTb      57422.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.643 0.89588 -0.0003628 1.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH2O; count 1; } { group C=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group dC; count 2; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-(1-ethoxyethylidene)propanedioate" "diethyl 2-(1-ethoxyethylidene)malonate" "propanedioic acid, (1-ethoxyethylidene)-, diethyl ester" "malonic acid, (1-ethoxyethylidene)-, diethyl ester" "propanedioic acid, 2-(1-ethoxyethylidene)-, 1,3-diethyl ester" "diethyl (1-ethoxyethylidene)malonate" );
standardThermochemistry
{
    dHf_298   -939510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     683.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-620880.0
}
