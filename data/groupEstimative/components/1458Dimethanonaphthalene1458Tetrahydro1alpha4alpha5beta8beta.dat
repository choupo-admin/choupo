/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4:5,8-dimethanonaphthalene, 1,4,5,8-tetrahydro-, (1alpha,4alpha,5beta,8beta)-  (C12H12, CAS 97253-51-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1458Dimethanonaphthalene1458Tetrahydro1alpha4alpha5beta8beta;
formula     C12H12;
CAS         97253-51-5;
InChIKey    KWPLEXGYQPSPLP-UHFFFAOYSA-N;
MW          156.228;      // g/mol [origin=calculated method=formula-sum]
Tc          734.18;      // K   [origin=predictive method=joback]
Pc          31.847;      // bar [origin=predictive method=joback]
omega       0.4439;      // -   [origin=predictive method=lee-kesler]
Tb          508.56;      // K   [origin=predictive method=joback]
HvapTb      44158.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-157.05 1.4604 -0.00133756 4.916e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group CH=CH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4:5,8-dimethanonaphthalene, 1,4,5,8-tetrahydro-, (1alpha,4alpha,5alpha,8alpha)-" "1,4:5,8-dimethanonaphthalene, 1,4,5,8-tetrahydro-, (1.alpha.,4.alpha.,5.alpha.,8.alpha.)-" "1,4:5,8-dimethanonaphthalene, 1,4,5,8-tetrahydro-, (1.alpha.,4.alpha.,5.beta.,8.beta.)-" );
gibbsFormation
{
    dHf_298   150590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     137.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=363780.0
    phase     gas;
}
