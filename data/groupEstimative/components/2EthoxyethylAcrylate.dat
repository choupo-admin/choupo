/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethoxyethyl acrylate  (C7H12O3, CAS 106-74-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthoxyethylAcrylate;
formula     C7H12O3;
CAS         106-74-1;
InChIKey    FWWXYLGCHHIKNY-UHFFFAOYSA-N;
MW          144.17;      // g/mol [origin=calculated method=formula-sum]
Tc          613.24;      // K   [origin=predictive method=joback]
Pc          28.905;      // bar [origin=predictive method=joback]
omega       0.5530;      // -   [origin=predictive method=lee-kesler]
Tb          437.08;      // K   [origin=predictive method=joback]
HvapTb      40323.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.443 0.53082 -0.0001743 -2.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxyethyl prop-2-enoate" "cellosolve acrylate" "2-propenoic acid, 2-ethoxyethyl ester" "ethoxyethyl acrylate" "ethylene glycol monoethyl ether acrylate" "2-ethoxyethyl 2-propenoate" "acrylic acid, 2-ethoxyethyl ester" "acrylic acid, 2-ethoxyethanol ester" "2-ethoxyethyl-2-propenoate" "ethylene glycol monoethyl ether propenoate" "ethanol, 2-ethoxy-, acrylate" "ai3-15741 (usda)" );
standardThermochemistry
{
    dHf_298   -511880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-319470.0
}
