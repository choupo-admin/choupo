/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(m-chlorophenyl)-2,2-dichloroethanol  (C8H7Cl3O, CAS 27683-61-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1MChlorophenyl22Dichloroethanol;
formula     C8H7Cl3O;
CAS         27683-61-0;
InChIKey    INLMRTPMNPOFAV-UHFFFAOYSA-N;
MW          225.493;      // g/mol [origin=calculated method=formula-sum]
Tc          838.51;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       0.8830;      // -   [origin=predictive method=lee-kesler]
Tb          617.89;      // K   [origin=predictive method=joback]
HvapTb      65398.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.61 0.6916 -0.00047356 1.204e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group CHCl2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)-1-(3-chlorophenyl)ethanol" "ethanol, 1-(m-chlorophenyl)-2,2-dichloro-" "m-chloro-alpha-(dichloromethyl)benzyl alcohol" "benzyl alcohol, m-chloro-alpha-(dichloromethyl)-" "2,2-dichloro-1-(3-chlorophenyl)ethanol" "benzyl alcohol, m-chloro-alpha-dichloromethyl-" "m-chloro-.alpha.-(dichloromethyl)benzyl alcohol" "benzenemethanol, 3-chloro-alpha-(dichloromethyl)-" "benzenemethanol, 3-chloro-.alpha.-(dichloromethyl)-" "benzyl alcohol, m-chloro-.alpha.-(dichloromethyl)-" "benzenemethanol, 3-chloro-alpha-(dichloromethyl)- (9ci)" );
gibbsFormation
{
    dHf_298   -193400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58230.0
    phase     gas;
}
