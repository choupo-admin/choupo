/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-fluoroadamantane  (C10H15F, CAS 768-92-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Fluoroadamantane;
formula     C10H15F;
CAS         768-92-3;
InChIKey    CPWSNJSGSXXVLD-UHFFFAOYSA-N;
MW          154.228;      // g/mol [origin=calculated method=formula-sum]
Tc          658.95;      // K   [origin=predictive method=joback]
Pc          31.002;      // bar [origin=predictive method=joback]
omega       0.3441;      // -   [origin=predictive method=lee-kesler]
Tb          447.73;      // K   [origin=predictive method=joback]
HvapTb      35488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-200.01 1.6741 -0.001628 6.512e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 3; } { group CF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyladamantane" "fluoroadamantane" "1-fluoro-adamantane" "1-adamantyl fluoride" "agn-pc-03dpi3" "tricyclo[3.3.1.13,7]decane, 1-fluoro-" "tricyclo[3.3.1.1~3,7~]decane, 1-fluoro-" );
gibbsFormation
{
    dHf_298   -238700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     353.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-4540.0
    phase     gas;
}
