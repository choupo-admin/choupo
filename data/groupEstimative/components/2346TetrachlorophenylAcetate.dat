/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,6-tetrachlorophenyl acetate  (C8H4Cl4O2, CAS 5435-60-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2346TetrachlorophenylAcetate;
formula     C8H4Cl4O2;
CAS         5435-60-9;
InChIKey    RHZFLXLMXCNOHX-UHFFFAOYSA-N;
MW          273.918;      // g/mol [origin=calculated method=formula-sum]
Tc          875.68;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.6821;      // -   [origin=predictive method=lee-kesler]
Tb          637.18;      // K   [origin=predictive method=joback]
HvapTb      63273.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (95.88 0.41932 -0.00016144 -1.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 1; } { group CH3COO; count 1; } { group ACCl; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Cl; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,3,4,6-tetrakis(chloranyl)phenyl] ethanoate" "(2,3,4,6-tetrachlorophenyl) acetate" "phenol, 2,3,4,6-tetrachloro-, acetate" "acetic acid, 2,3,4,6-tetrachlorophenyl ester" );
gibbsFormation
{
    dHf_298   -398040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-267720.0
    phase     gas;
}
