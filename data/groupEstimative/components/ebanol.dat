/*--------------------------------*- Choupo -*-----------------------*\
  Component: ebanol  (C14H24O, CAS 67801-20-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ebanol;
formula     C14H24O;
CAS         67801-20-1;
InChIKey    RNLHVODSMDJCBR-VURMDHGXSA-N;
MW          208.345;      // g/mol [origin=calculated method=formula-sum]
Tc          825.39;      // K   [origin=predictive method=joback]
Pc          20.869;      // bar [origin=predictive method=joback]
omega       0.8596;      // -   [origin=predictive method=lee-kesler]
Tb          630.37;      // K   [origin=predictive method=joback]
HvapTb      62370.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.55 1.6813 -0.00138324 5.002e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 2; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-3-methyl-5-(2,2,3-trimethylcyclopent-3-en-1-yl)pent-4-en-2-ol" "3-methyl-5-(2,2,3-trimethyl-3-cyclopenten-1-yl)-4-penten-2-ol" "3-methyl-5-(2,2,3-trimethyl-3-cyclopenten-1-yl)pent-4-en-2-ol" "3-methyl-5-(2,2,3-trimethyl-3-cyclopenten-1-yl)-4-penten-2-ol ( isomer)" );
standardThermochemistry
{
    dHf_298   -276170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     659.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49200.0
}
