/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-cyclohexyloxan-2-one  (C11H18O2, CAS 62948-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Cyclohexyloxan2One;
formula     C11H18O2;
CAS         62948-64-5;
InChIKey    ZRQYQZPQEMHNPP-UHFFFAOYSA-N;
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          762.90;      // K   [origin=predictive method=joback]
Pc          27.440;      // bar [origin=predictive method=joback]
omega       0.4911;      // -   [origin=predictive method=lee-kesler]
Tb          540.06;      // K   [origin=predictive method=joback]
HvapTb      48001.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.67 1.2574 -0.0007348 1.416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group CH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-cyclohexyltetrahydro-2h-pyran-2-one" "2h-pyran-2-one, 4-cyclohexyltetrahydro-" "2h-pyran-2-one, 4-cyclohexyltetrahydro-, (+-)-" );
gibbsFormation
{
    dHf_298   -466690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-195530.0
    phase     gas;
}
