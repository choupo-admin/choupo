/*--------------------------------*- Choupo -*-----------------------*\
  Component: cinnamic aldehyde dimethyl acetal  (C11H14O2, CAS 4364-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cinnamicAldehydeDimethylAcetal;
formula     C11H14O2;
CAS         4364-06-1;
InChIKey    MBAOABFNWSOOLU-CMDGGOBGSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          739.13;      // K   [origin=predictive method=joback]
Pc          27.212;      // bar [origin=predictive method=joback]
omega       0.5217;      // -   [origin=predictive method=lee-kesler]
Tb          526.52;      // K   [origin=predictive method=joback]
HvapTb      46746.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.88 0.86944 -0.0004708 8.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-3,3-dimethoxyprop-1-enyl]benzene" "3-phenyl-2-propenal dimethyl acetal" "benzene, (3,3-dimethoxy-1-propenyl)-" "cinnamaldehyde dimethyl acetyl" "(3,3-dimethoxy-1-propenyl)benzene" "(3,3-dimethoxypropen-1-yl)benzene" "3,3-dimethoxy-1-phenylprop-1-ene" "cinnamaldehyde, dimethyl acetal" "benzene, (3,3-dimethoxy-1-propen-1-yl)-" "cinnamic aldehyde, dimethyl acetal" );
standardThermochemistry
{
    dHf_298   -186340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21930.0
}
