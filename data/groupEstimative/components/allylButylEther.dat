/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl butyl ether  (C7H14O, CAS 3739-64-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylButylEther;
formula     C7H14O;
CAS         3739-64-8;
InChIKey    IBTLFDCPAJLATQ-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          546.66;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.4037;      // -   [origin=predictive method=lee-kesler]
Tb          378.86;      // K   [origin=predictive method=joback]
HvapTb      32916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.034 0.58562 -0.0002689 3.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-prop-2-enoxybutane" "ether, allyl butyl" "butane, 1-(2-propenyloxy)-" "butyl allyl ether" "allyl n-butyl ether" "1-(allyloxy)butane" "butane,1-(2-propen-1-yloxy)-" "butane,1-(2-propenyloxy)- (9ci); ether, allyl butyl (6ci,7ci,8ci); 1-(allyloxy)butane;allyl butyl ether; butyl allyl ether; n-butyl allyl ether" );
gibbsFormation
{
    dHf_298   -194600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9100.0
    phase     gas;
}
