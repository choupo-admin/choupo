/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, pentachloropropoxy-  (C9H7Cl5O, CAS 36518-74-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenePentachloropropoxy;
formula     C9H7Cl5O;
CAS         36518-74-8;
InChIKey    GJMNJUGLIPUBHJ-UHFFFAOYSA-N;
MW          308.404;      // g/mol [origin=calculated method=formula-sum]
Tc          899.80;      // K   [origin=predictive method=joback]
Pc          24.314;      // bar [origin=predictive method=joback]
omega       0.7135;      // -   [origin=predictive method=lee-kesler]
Tb          666.67;      // K   [origin=predictive method=joback]
HvapTb      65549.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (122.252 0.45322 -0.0001528 -1.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group AC; count 1; } { group CH2O; count 1; } { group ACCl; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dC_ring; count 6; } { group Cl; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(chloranyl)-6-propoxy-benzene" "pentachlorophenyl propyl ether" "1,2,3,4,5-pentachloro-6-propoxybenzene" );
standardThermochemistry
{
    dHf_298   -260830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75490.0
}
