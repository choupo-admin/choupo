/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-bromo-4-(2-propenyl)-  (C9H9Br, CAS 2294-43-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1Bromo42Propenyl;
formula     C9H9Br;
CAS         2294-43-1;
InChIKey    LIGHOIDTGDLAKK-UHFFFAOYSA-N;
MW          197.075;      // g/mol [origin=calculated method=formula-sum]
Tc          731.24;      // K   [origin=predictive method=joback]
Pc          36.509;      // bar [origin=predictive method=joback]
omega       0.4369;      // -   [origin=predictive method=lee-kesler]
Tb          500.02;      // K   [origin=predictive method=joback]
HvapTb      44331.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.699 0.7386 -0.00052426 1.48e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-prop-2-enyl-benzene" "3-(4-bromophenyl)-1-propene" "1-allyl-4-bromobenzene" "1-bromo-4-prop-2-enylbenzene" "3-(4-bromophenyl)prop-1-ene" "4-(prop-1-en-3-yl)bromobenzene" "1-bromo-4-(prop-2-en-1-yl)benzene" "benzene,1-bromo-4-(2-propen-1-yl)-" "benzene,1-allyl-4-bromo- (6ci,7ci,8ci); benzene, 1-bromo-4-(2-propenyl)- (9ci);1-allyl-4-bromobenzene; 1-bromo-4-(2-propenyl)benzene; 1-bromo-4-allylbenzene;3-(4-bromophenyl)-1-propene; 3-(p-bromophenyl)propene; 4-allyl-1-bromobenzene;4-allylbromobenzene; 4-bromo(allyl)benzene; p-allylbromobenzene; p-allylphenylbromide" );
standardThermochemistry
{
    dHf_298   147730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=229840.0
}
