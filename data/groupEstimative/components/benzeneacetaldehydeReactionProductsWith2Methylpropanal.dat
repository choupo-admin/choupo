/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzeneacetaldehyde, reaction products with 2-methylpropanal  (C12H16O2, CAS 68512-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneacetaldehydeReactionProductsWith2Methylpropanal;
formula     C12H16O2;
CAS         68512-06-1;
InChIKey    QUIWBQRTXQXIPD-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          816.33;      // K   [origin=predictive method=joback]
Pc          25.741;      // bar [origin=predictive method=joback]
omega       0.6784;      // -   [origin=predictive method=lee-kesler]
Tb          599.12;      // K   [origin=predictive method=joback]
HvapTb      57928.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.011 0.81364 -0.0002346 -6.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CHO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OdCH_al; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropanal;2-phenylethanal" "2-methylpropanal; 2-phenylacetaldehyde" );
standardThermochemistry
{
    dHf_298   -342540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     652.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-143670.0
}
