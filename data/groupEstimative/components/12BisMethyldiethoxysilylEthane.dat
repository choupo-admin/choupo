/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(methyldiethoxysilyl)ethane  (C12H30O4Si2, CAS 18043-74-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H30O4Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        12BisMethyldiethoxysilylEthane;
formula     C12H30O4Si2;
CAS         18043-74-8;
InChIKey    HITBDIPWYKTHIH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          294.538;      // g/mol [origin=calculated method=formula-sum]
Tc          736.29;      // K   [origin=predictive method=joback]
Pc          13.944;      // bar [origin=predictive method=joback]
omega       0.6606;      // -   [origin=predictive method=lee-kesler]
Tb          566.64;      // K   [origin=predictive method=joback]
HvapTb      52534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (175.616 0.47872 0.0006446 -5.22e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH2O; count 4; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[diethoxy(methyl)silyl]ethyl-diethoxy-methyl-silane" "4,7-diethoxy-4,7-dimethyl-3,8-dioxa-4,7-disiladecane" "2-[diethoxy(methyl)silyl]ethyl-diethoxy-methylsilane" "3,8-dioxa-4,7-disiladecane,4,7-diethoxy-4,7-dimethyl-" "1,2-bis(methyldiethoxysilyl)ethane;1,2-bis[diethoxy(methyl)silyl]ethane" );
standardThermochemistry
{
    dHf_298   -1043130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     921.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-579360.0
}
