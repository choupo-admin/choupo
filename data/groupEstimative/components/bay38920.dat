/*--------------------------------*- Choupo -*-----------------------*\
  Component: bay 38920  (C11H10Cl6O2, CAS 2592-62-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bay38920;
formula     C11H10Cl6O2;
CAS         2592-62-3;
InChIKey    VJWJSBXWCZQODM-UHFFFAOYSA-N;
MW          386.899;      // g/mol [origin=calculated method=formula-sum]
Tc          1033.74;      // K   [origin=predictive method=joback]
Pc          24.826;      // bar [origin=predictive method=joback]
omega       0.6587;      // -   [origin=predictive method=lee-kesler]
Tb          758.62;      // K   [origin=predictive method=joback]
HvapTb      72901.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-156.99 2.12872 -0.0024754 1.1283e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 3; } { group FCH2O; count 2; } { group CCl2; count 1; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group C_ring; count 3; } { group dC_ring; count 2; } { group Cl; count 6; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,7,8,9,10,10-hexachloro-3-methyl-1,5,5a,6,9,9a-hexahydro-6,9-methano-2,4-benzodioxepine" "6,9-methano-2,4-benzodioxepin, 6,7,8,9,10,10-hexachloro-1,5,5a,6,9,9a-hexahydro-3-methyl-" "6,7,8,9,10,10-hexachloro-1,5,5a,6,9,9a-hexahydro-3-methyl-6,9-methano-2,4-benzdioxepin" "2,4-benzodioxepin, 6,7,8,9,10,10-hexachloro-1,5,5a,6,9,9a-hexahydro-6,9-methano-3-methyl-" "6,7,8,9,10,10-hexachloro-1,5,5a,6,9,9a-hexahydro-3-methyl-6,9-methano-2,4-benzodioxepin" );
gibbsFormation
{
    dHf_298   -409350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85030.0
    phase     gas;
}
