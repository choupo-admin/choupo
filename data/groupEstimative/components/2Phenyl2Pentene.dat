/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenyl-2-pentene  (C11H14, CAS 53172-84-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenyl2Pentene;
formula     C11H14;
CAS         53172-84-2;
InChIKey    PLPHXVSTHYOUJO-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          698.12;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       0.3766;      // -   [origin=predictive method=lee-kesler]
Tb          482.00;      // K   [origin=predictive method=joback]
HvapTb      42394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.889 0.98984 -0.0006919 1.944e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-2-en-2-ylbenzene" "benzene,(1-methyl-1-buten-1-yl)-" "2-pentene,2-phenyl- (6ci); benzene, (1-methyl-1-butenyl)- (9ci); 2-phenyl-2-pentene" );
gibbsFormation
{
    dHf_298   73590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225820.0
    phase     gas;
}
