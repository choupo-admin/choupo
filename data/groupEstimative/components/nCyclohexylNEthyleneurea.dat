/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-cyclohexyl-n'-ethyleneurea  (C9H16N2O, CAS 13311-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nCyclohexylNEthyleneurea;
formula     C9H16N2O;
CAS         13311-57-4;
InChIKey    YYBLYFZIRIAHTJ-UHFFFAOYSA-N;
MW          168.24;      // g/mol [origin=calculated method=formula-sum]
Tc          765.24;      // K   [origin=predictive method=joback]
Pc          36.072;      // bar [origin=predictive method=joback]
omega       0.6943;      // -   [origin=predictive method=lee-kesler]
Tb          548.69;      // K   [origin=predictive method=joback]
HvapTb      51332.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.5 1.34 -0.0010113 3.0176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CHNH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 1; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-cyclohexylaziridine-1-carboxamide" "cyclohexyl-n-carbamoylaziridine" "n-cyclohexyl-n-carbamoylaziridine" "n-cyclohexyl-1-aziridinecarboxamide" "1-aziridinecarboxamide, n-cyclohexyl-" );
gibbsFormation
{
    dHf_298   -67050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=201160.0
    phase     gas;
}
