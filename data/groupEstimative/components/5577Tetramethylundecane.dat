/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5,7,7-tetramethylundecane  (C15H32, CAS 74286-95-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5577Tetramethylundecane;
formula     C15H32;
CAS         74286-95-6;
InChIKey    ICXWEQZDTWZYNP-UHFFFAOYSA-N;
MW          212.421;      // g/mol [origin=calculated method=formula-sum]
Tc          712.08;      // K   [origin=predictive method=joback]
Pc          14.568;      // bar [origin=predictive method=joback]
omega       0.5333;      // -   [origin=predictive method=lee-kesler]
Tb          536.34;      // K   [origin=predictive method=joback]
HvapTb      46392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.693 1.68052 -0.0011358 3.111e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 7; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 7; } { group C; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -370430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     662.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=81100.0
}
