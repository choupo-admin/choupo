/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-(+)-n-benzyl-1-phenylethylamine  (C15H17N, CAS 38235-77-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        rNBenzyl1Phenylethylamine;
formula     C15H17N;
CAS         38235-77-7;
InChIKey    ZYZHMSJNPCYUTB-CYBMUJFWSA-N;
MW          211.308;      // g/mol [origin=calculated method=formula-sum]
Tc          883.62;      // K   [origin=predictive method=joback]
Pc          25.637;      // bar [origin=predictive method=joback]
omega       0.6492;      // -   [origin=predictive method=lee-kesler]
Tb          645.89;      // K   [origin=predictive method=joback]
HvapTb      59584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.449 1.35312 -0.0009064 2.283e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r)-1-phenyl-n-(phenylmethyl)ethanamine" "(r)-(+)-n-benzyl-alpha-methylbenzylamine" "(r)-n-benzyl-1-phenylethanamine" "benzyl[(1r)-1-phenylethyl]amine" "(r)-n-benzyl-1-phenylethylamine" "r-(+)-n-benzyl-1-phenylethylamine" "(s)-(-)-n-benzyl-alpha-phenethylamine" "(r)-(+)-n-(1-phenylethyl)benzylamine" "((1r)-1-phenylethyl)benzylamine" "(1r)-n-benzyl-1-phenylethanamine" "r-(+)-n-benzy-1-phenylethylamine" "r(+)-n-benzyl-alpha-phenethylamine" );
standardThermochemistry
{
    dHf_298   168320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=387190.0
}
