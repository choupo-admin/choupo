/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-2-(prop-2-en-1-yloxy)ethanamine  (C7H15NO, CAS 3205-11-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyl2Prop2En1YloxyEthanamine;
formula     C7H15NO;
CAS         3205-11-6;
InChIKey    OLYONRCXBJKEEM-UHFFFAOYSA-N;
MW          129.203;      // g/mol [origin=calculated method=formula-sum]
Tc          557.88;      // K   [origin=predictive method=joback]
Pc          28.689;      // bar [origin=predictive method=joback]
omega       0.4623;      // -   [origin=predictive method=lee-kesler]
Tb          391.30;      // K   [origin=predictive method=joback]
HvapTb      34959.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.343 0.70954 -0.0003815 7.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-2-prop-2-enoxy-ethanamine" "n,n-dimethyl-2-prop-2-enoxyethanamine" "allyl-2-(n,n-dimethylamino)ethyl ether" );
standardThermochemistry
{
    dHf_298   -127070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=101680.0
}
