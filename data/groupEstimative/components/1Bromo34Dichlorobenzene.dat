/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-3,4-dichlorobenzene  (C6H3BrCl2, CAS 18282-59-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo34Dichlorobenzene;
formula     C6H3BrCl2;
CAS         18282-59-2;
InChIKey    CFPZDVAZISWERM-UHFFFAOYSA-N;
MW          225.894;      // g/mol [origin=calculated method=formula-sum]
Tc          765.83;      // K   [origin=predictive method=joback]
Pc          44.563;      // bar [origin=predictive method=joback]
omega       0.4316;      // -   [origin=predictive method=lee-kesler]
Tb          514.54;      // K   [origin=predictive method=joback]
HvapTb      47755.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.1 0.4277 -0.00031192 8.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCl; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-1,2-bis(chloranyl)benzene" "4-bromo-1,2-dichlorobenzene" "3,4-dichlorobromobenzene" "benzene, 4-bromo-1,2-dichloro-" "3,4-dichlorophenyl bromide" "3,4-dichlorobromobenzene; pterostilbene" "3,4-dichloro-1-bromobenzene;3,4-dichlorobromobenzene;4-bromo-1,2-dichlorobenzene;" );
standardThermochemistry
{
    dHf_298   41270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83250.0
}
