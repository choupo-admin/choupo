/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-chlorophenyl)ethanol  (C8H9ClO, CAS 3391-10-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14ChlorophenylEthanol;
formula     C8H9ClO;
CAS         3391-10-4;
InChIKey    MVOSNPUNXINWAD-UHFFFAOYSA-N;
MW          156.609;      // g/mol [origin=calculated method=formula-sum]
Tc          751.51;      // K   [origin=predictive method=joback]
Pc          38.723;      // bar [origin=predictive method=joback]
omega       0.7863;      // -   [origin=predictive method=lee-kesler]
Tb          543.47;      // K   [origin=predictive method=joback]
HvapTb      57016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.49 0.67212 -0.00042956 1.029e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloro-alpha-methylbenzyl alcohol" "benzenemethanol, 4-chloro-.alpha.-methyl-" "benzyl alcohol, p-chloro-.alpha.-methyl-" "1-(p-chlorophenyl)ethanol" "1-(4-chlorophenyl)ethan-1-ol" "benzenemethanol, 4-chloro-alpha-methyl-" "4-chlorophenylmethylcarbinol" "1-(4-chlorophenyl) ethanol" "alpha-(p-chlorophenyl)ethanol" "4-chloro-a-methylbenzyl alcohol" ".alpha.-(p-chlorophenyl)ethanol" "1-(4-chlorophenyl)ethyl alcohol" );
standardThermochemistry
{
    dHf_298   -156640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31930.0
}
