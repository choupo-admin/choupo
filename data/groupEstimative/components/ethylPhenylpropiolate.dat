/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl phenylpropiolate  (C11H10O2, CAS 2216-94-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylPhenylpropiolate;
formula     C11H10O2;
CAS         2216-94-6;
InChIKey    ACJOYTKWHPEIHW-UHFFFAOYSA-N;
MW          174.199;      // g/mol [origin=calculated method=formula-sum]
Tc          779.08;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       0.4927;      // -   [origin=predictive method=lee-kesler]
Tb          545.18;      // K   [origin=predictive method=joback]
HvapTb      51915.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.951 0.76532 -0.00041906 6.708e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group C_C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-phenylprop-2-ynoate" "ethylphenylpropiolate" "ethyl 3-phenylpropiolate" "ethyl phenylpropriolate" "ethyl phenylacetylenecarboxylate" "ethyl phenylpropynoate" "2-propynoic acid, 3-phenyl-, ethyl ester" "ethyl 3-phenylpropynoate" "ethyl 3-phenyl-2-propynoate" "phenylpropiolic acid ethyl ester" "phenylacetylene monocarboxylic acid ethyl ester" "propiolic acid, phenyl-, ethyl ester" );
gibbsFormation
{
    dHf_298   -78820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46580.0
    phase     gas;
}
