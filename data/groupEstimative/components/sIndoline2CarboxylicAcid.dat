/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-(-)-indoline-2-carboxylic acid  (C9H9NO2, CAS 79815-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sIndoline2CarboxylicAcid;
formula     C9H9NO2;
CAS         79815-20-6;
InChIKey    QNRXNRGSOJZINA-QMMMGPOBSA-N;
MW          163.176;      // g/mol [origin=calculated method=formula-sum]
Tc          882.80;      // K   [origin=predictive method=joback]
Pc          43.169;      // bar [origin=predictive method=joback]
omega       0.8354;      // -   [origin=predictive method=lee-kesler]
Tb          637.98;      // K   [origin=predictive method=joback]
HvapTb      62401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.62 0.9087 -0.00066216 1.909e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CHNH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2,3-dihydro-1h-indole-2-carboxylic acid" "(s)-indoline-2-carboxylic acid" "(s)-(-)-indolin-2-carboxylic acid" "s-(-)-indoline-2-carboxylic acid" "l-(-)-indoline-2-carboxylic acid" "l-indoline-2-carboxylic acid" "s-dic" "h-idc-oh" "(s)-2-carboxyindoline" "(s)-indoline-2-carboxylic" "s-indoline-2-carboxylic acid" "(s)-indole-2-carboxylic acid" );
standardThermochemistry
{
    dHf_298   -243690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-67770.0
}
