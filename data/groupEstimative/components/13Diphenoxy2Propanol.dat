/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diphenoxy-2-propanol  (C15H16O3, CAS 622-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diphenoxy2Propanol;
formula     C15H16O3;
CAS         622-04-8;
InChIKey    NKCVHIPHZCIEFC-UHFFFAOYSA-N;
MW          244.29;      // g/mol [origin=calculated method=formula-sum]
Tc          948.28;      // K   [origin=predictive method=joback]
Pc          26.846;      // bar [origin=predictive method=joback]
omega       1.1342;      // -   [origin=predictive method=lee-kesler]
Tb          732.74;      // K   [origin=predictive method=joback]
HvapTb      74647.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.948 1.1845 -0.0006662 1.18e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diphenoxypropan-2-ol" "glycerol 1,3-diphenyl ether" "1,3-difenoxy-2-propanol" "2-propanol, 1,3-diphenoxy-" "glyceryl alpha,gamma-diphenyl ether" "1,2,3-propanetriol, 1,3-diphenyl diether" "2-propanol,3-diphenoxy-" "glyceryl .alpha.,.gamma.-diphenyl ether" "1,3-propanetriol, 1,3-diphenyl diether" "2-propanol,1,3-diphenoxy-" "(2-hydroxy-3-phenoxypropoxy)benzene" );
gibbsFormation
{
    dHf_298   -301820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49020.0
    phase     gas;
}
