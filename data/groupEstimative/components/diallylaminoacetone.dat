/*--------------------------------*- Choupo -*-----------------------*\
  Component: diallylaminoacetone  (C9H15NO, CAS 73813-61-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diallylaminoacetone;
formula     C9H15NO;
CAS         73813-61-3;
InChIKey    NMQNNHLPNMVSQB-UHFFFAOYSA-N;
MW          153.225;      // g/mol [origin=calculated method=formula-sum]
Tc          644.58;      // K   [origin=predictive method=joback]
Pc          26.653;      // bar [origin=predictive method=joback]
omega       0.5881;      // -   [origin=predictive method=lee-kesler]
Tb          465.19;      // K   [origin=predictive method=joback]
HvapTb      43077.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.607 0.91472 -0.0006055 1.5906e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 2; } { group CH3CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 2; } { group dCH; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[bis(prop-2-enyl)amino]propan-2-one" );
standardThermochemistry
{
    dHf_298   -23280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=182440.0
}
