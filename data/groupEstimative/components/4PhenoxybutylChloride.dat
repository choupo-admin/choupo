/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenoxybutyl chloride  (C10H13ClO, CAS 2651-46-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4PhenoxybutylChloride;
formula     C10H13ClO;
CAS         2651-46-9;
InChIKey    JKXCPAVECBFBOC-UHFFFAOYSA-N;
MW          184.663;      // g/mol [origin=calculated method=formula-sum]
Tc          723.59;      // K   [origin=predictive method=joback]
Pc          27.672;      // bar [origin=predictive method=joback]
omega       0.5239;      // -   [origin=predictive method=lee-kesler]
Tb          514.93;      // K   [origin=predictive method=joback]
HvapTb      46925.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.716 0.8185 -0.0004608 8.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranylbutoxybenzene" "(4-chlorobutoxy)benzene" "4-chlorobutyl phenyl ether" "benzene, (4-chlorobutoxy)-" "4-chlorobutoxybenzene" "4-chlorobutylphenylether" "1-chloro-4-phenoxybutane" "4-chloro-1-phenoxybutane" "1-(4-chlorobutoxy)benzene" "benzene,(4-chlorobutoxy)-" "jkxcpavecbfboc-uhfffaoysa-" "u779" );
gibbsFormation
{
    dHf_298   -161160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28800.0
    phase     gas;
}
