/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-1-methyl-2-propylcyclohexane  (C10H20, CAS 4926-71-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis1Methyl2Propylcyclohexane;
formula     C10H20;
CAS         4926-71-0;
InChIKey    BVYJEKBXVYKYRA-ZJUUUORDSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          639.81;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.3415;      // -   [origin=predictive method=lee-kesler]
Tb          443.28;      // K   [origin=predictive method=joback]
HvapTb      37974.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.868 1.04944 -0.0005458 8.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2s)-1-methyl-2-propyl-cyclohexane" "1-methyl-2-propylcyclohexane, cis" "(1r,2s)-1-methyl-2-propylcyclohexane" );
gibbsFormation
{
    dHf_298   -215750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50060.0
    phase     gas;
}
