/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptafluoropropyl bromide  (C3BrF7, CAS 422-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptafluoropropylBromide;
formula     C3BrF7;
CAS         422-85-5;
InChIKey    LANNRYWUUQMNPF-UHFFFAOYSA-N;
MW          248.923;      // g/mol [origin=calculated method=formula-sum]
Tc          470.78;      // K   [origin=predictive method=joback]
Pc          34.807;      // bar [origin=predictive method=joback]
omega       0.3849;      // -   [origin=predictive method=lee-kesler]
Tb          319.60;      // K   [origin=predictive method=joback]
HvapTb      19100.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.43 0.787 -0.000841 3.135e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Br; count 1; } { group CF3; count 1; } { group CF2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group F; count 7; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-1,1,2,2,3,3,3-heptakis(fluoranyl)propane" "1-bromo-1,1,2,2,3,3,3-heptafluoropropane" "perfluoropropyl bromide" "n-heptafluoropropyl bromide" "propane, 1-bromo-1,1,2,2,3,3,3-heptafluoro-" "1-bromoperfluoropropane" "heptafluoro-n-propyl bromide" "1-bromoheptafluoropropane (fc-217cab1)" "fc-217cab1, 1-bromo-1,1,2,2,3,3,3-heptafluoropropane" "propane,1-bromoheptafluoro- (6ci,7ci,8ci);1-bromoheptafluoropropane;1-bromoperfluoropropane;heptafluoropropyl bromide;perfluoropropyl bromide;" );
standardThermochemistry
{
    dHf_298   -1477940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1366450.0
}
