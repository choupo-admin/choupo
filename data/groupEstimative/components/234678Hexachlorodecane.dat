/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,6,7,8-hexachlorodecane  (C10H16Cl6, CAS 108171-26-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        234678Hexachlorodecane;
formula     C10H16Cl6;
CAS         108171-26-2;
InChIKey    ZPSFPNSXYWWGRF-UHFFFAOYSA-N;
MW          348.938;      // g/mol [origin=calculated method=formula-sum]
Tc          865.12;      // K   [origin=predictive method=joback]
Pc          18.077;      // bar [origin=predictive method=joback]
omega       0.6478;      // -   [origin=predictive method=lee-kesler]
Tb          650.34;      // K   [origin=predictive method=joback]
HvapTb      61836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.052 1.03004 -0.0006618 1.588e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CHCl; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 6; } { group Cl; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,6,7,8-hexakis(chloranyl)decane" "chlorinated paraffins: c12, 60% chlorine" "agn-pc-03vchq" );
standardThermochemistry
{
    dHf_298   -375850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     688.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-52900.0
}
