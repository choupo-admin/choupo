/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorooctan-1-ol  (C8H17ClO, CAS 67700-24-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chlorooctan1Ol;
formula     C8H17ClO;
CAS         67700-24-7;
InChIKey    MMVJPTKAKBJYGU-UHFFFAOYSA-N;
MW          164.673;      // g/mol [origin=calculated method=formula-sum]
Tc          680.34;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       0.8918;      // -   [origin=predictive method=lee-kesler]
Tb          511.81;      // K   [origin=predictive method=joback]
HvapTb      54078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.116 0.81052 -0.0004654 1.023e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group OH; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyloctan-1-ol" "1-octanol, 4-chloro-" "linseed oil, soybean oil, pentaerythritol, ethylene glycol, glycerine, phthalic anhydride polymer" );
standardThermochemistry
{
    dHf_298   -381700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     542.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-134710.0
}
