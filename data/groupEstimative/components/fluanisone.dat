/*--------------------------------*- Choupo -*-----------------------*\
  Component: fluanisone  (C21H25FN2O2, CAS 1480-19-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fluanisone;
formula     C21H25FN2O2;
CAS         1480-19-9;
InChIKey    IRYFCWPNDIUQOW-UHFFFAOYSA-N;
MW          356.441;      // g/mol [origin=calculated method=formula-sum]
Tc          1081.78;      // K   [origin=predictive method=joback]
Pc          17.118;      // bar [origin=predictive method=joback]
omega       1.1059;      // -   [origin=predictive method=lee-kesler]
Tb          859.52;      // K   [origin=predictive method=joback]
HvapTb      81035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.147 2.05822 -0.00138802 3.5406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 8; } { group AC; count 3; } { group CH2CO; count 1; } { group CH3O; count 1; } { group CH2N; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 1; } { group O; count 1; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-fluorophenyl)-4-[4-(2-methoxyphenyl)piperazin-1-yl]butan-1-one" "haloanison" "haloanisone" "fluanison" "sedalande" "anti-pica" "metorin" "fluanisonum [inn-latin]" "haloanizone" "4'-fluoro-4-(4-(o-methoxyphenyl)-1-piperazinyl)butyrophenone" "4'-fluoro-4-[4-(o-methoxyphenyl)-1-piperazinyl]butyrophenone" "4-(4-(o-methoxyphenyl)-1-piperazinyl)-p-fluorobutyrophenone" );
gibbsFormation
{
    dHf_298   -245520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     822.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=180690.0
    phase     gas;
}
