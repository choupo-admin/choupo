/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,3-bis(1-phenylethenyl)-  (C22H18, CAS 34241-86-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene13Bis1Phenylethenyl;
formula     C22H18;
CAS         34241-86-6;
InChIKey    YVWBWDZQFGXBOT-UHFFFAOYSA-N;
MW          282.386;      // g/mol [origin=calculated method=formula-sum]
Tc          1045.86;      // K   [origin=predictive method=joback]
Pc          19.613;      // bar [origin=predictive method=joback]
omega       0.6491;      // -   [origin=predictive method=lee-kesler]
Tb          781.10;      // K   [origin=predictive method=joback]
HvapTb      70876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.89 1.7574 -0.00124996 3.406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 2; } { group ACH; count 14; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dC; count 2; } { group dCH_ring; count 14; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(1-phenylethenyl)benzene" "1,3-bis(1-phenylvinyl)benzene" );
gibbsFormation
{
    dHf_298   431990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     670.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=620540.0
    phase     gas;
}
