/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-butylphenyl 4-(4-butylbenzoyloxy)benzoate  (C28H30O4, CAS 38454-02-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Butylphenyl44ButylbenzoyloxyBenzoate;
formula     C28H30O4;
CAS         38454-02-3;
InChIKey    ACAXIUADIABHTE-UHFFFAOYSA-N;
MW          430.544;      // g/mol [origin=calculated method=formula-sum]
Tc          1293.32;      // K   [origin=predictive method=joback]
Pc          11.507;      // bar [origin=predictive method=joback]
omega       1.0417;      // -   [origin=predictive method=lee-kesler]
Tb          1051.66;      // K   [origin=predictive method=joback]
HvapTb      101550.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.564 2.13904 -0.00120268 2.096e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 12; } { group AC; count 4; } { group ACCH2; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(4-butylphenoxy)carbonylphenyl] 4-butylbenzoate" "benzoic acid, 4-butyl-, 4-[(4-butylphenoxy)carbonyl]phenyl ester" "benzoic acid, 4-butyl-, 4-((4-butylphenoxy)carbonyl)phenyl ester" );
gibbsFormation
{
    dHf_298   -580630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1011.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-127520.0
    phase     gas;
}
