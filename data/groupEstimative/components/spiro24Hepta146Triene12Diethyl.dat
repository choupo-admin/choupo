/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[2.4]hepta-1,4,6-triene, 1,2-diethyl-  (C11H14, CAS 49542-94-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro24Hepta146Triene12Diethyl;
formula     C11H14;
CAS         49542-94-1;
InChIKey    JZICXKTZOLAPPW-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          693.96;      // K   [origin=predictive method=joback]
Pc          29.763;      // bar [origin=predictive method=joback]
omega       0.4226;      // -   [origin=predictive method=lee-kesler]
Tb          481.38;      // K   [origin=predictive method=joback]
HvapTb      41436.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.708 1.37244 -0.00138436 5.774e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH=CH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-diethylspiro[2.4]hepta-1,4,6-triene" "spiro(2.4)hepta-1,4,6-triene, 1,2-diethyl-" "spiro[2,4]hepta-1,4,6-triene,1,2-diethyl" );
gibbsFormation
{
    dHf_298   55050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=223980.0
    phase     gas;
}
