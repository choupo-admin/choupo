/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2e)-n-(2-methylbenzyl)-3-phenylprop-2-enamide  (C17H17NO, CAS 63815-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2eN2Methylbenzyl3Phenylprop2Enamide;
formula     C17H17NO;
CAS         63815-56-5;
InChIKey    IKQJPGLNXOZQNY-VAWYXSNFSA-N;
MW          251.329;      // g/mol [origin=calculated method=formula-sum]
Tc          994.28;      // K   [origin=predictive method=joback]
Pc          23.225;      // bar [origin=predictive method=joback]
omega       0.8790;      // -   [origin=predictive method=lee-kesler]
Tb          755.10;      // K   [origin=predictive method=joback]
HvapTb      71790.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.109 1.46972 -0.00101006 2.6606e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACCH3; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-n-[(2-methylphenyl)methyl]-3-phenyl-prop-2-enamide" "(e)-n-[(2-methylphenyl)methyl]-3-phenylprop-2-enamide" );
gibbsFormation
{
    dHf_298   125490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     659.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=348140.0
    phase     gas;
}
