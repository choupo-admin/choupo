/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl(trimethyl)silane  (C7H18Si, CAS 5037-65-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H18Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tertButylTrimethylSilane;
formula     C7H18Si;
CAS         5037-65-0;
InChIKey    FFXWYTYNILTGIL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          130.306;      // g/mol [origin=calculated method=formula-sum]
Tc          539.24;      // K   [origin=predictive method=joback]
Pc          25.227;      // bar [origin=predictive method=joback]
omega       0.1770;      // -   [origin=predictive method=lee-kesler]
Tb          357.93;      // K   [origin=predictive method=joback]
HvapTb      30174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.87 0.58852 -0.000114 -7.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "silane, trimethyl-tert-butyl-" "(ch3)3csi(ch3)3" "silane, (1,1-dimethylethyl)trimethyl-" );
gibbsFormation
{
    dHf_298   -308180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-93860.0
    phase     gas;
}
