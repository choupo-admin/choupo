/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexanone, 5-hydroxy-2-methyl-  (C7H14O2, CAS 59357-07-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexanone5Hydroxy2Methyl;
formula     C7H14O2;
CAS         59357-07-2;
InChIKey    SULIZEHAPZEYJT-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          681.96;      // K   [origin=predictive method=joback]
Pc          33.841;      // bar [origin=predictive method=joback]
omega       0.8909;      // -   [origin=predictive method=lee-kesler]
Tb          504.93;      // K   [origin=predictive method=joback]
HvapTb      53825.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.811 0.68666 -0.0003751 7.186e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 2; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-5-oxidanyl-hexan-3-one" "5-hydroxy-2-methyl-3-hexanone" "5-hydroxy-2-methylhexan-3-one" );
gibbsFormation
{
    dHf_298   -463180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-262560.0
    phase     gas;
}
