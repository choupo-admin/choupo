/*--------------------------------*- Choupo -*-----------------------*\
  Component: anti-1,2,3,5,6-pentamethyl-4-methylenebicyclo(3.1.0)hex-2-ene  (C12H18, CAS 20055-93-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anti12356Pentamethyl4Methylenebicyclo310Hex2Ene;
formula     C12H18;
CAS         20055-93-0;
InChIKey    HDCJWTTZLOHNHX-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          699.37;      // K   [origin=predictive method=joback]
Pc          24.314;      // bar [origin=predictive method=joback]
omega       0.4017;      // -   [origin=predictive method=lee-kesler]
Tb          491.73;      // K   [origin=predictive method=joback]
HvapTb      41296.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.88 1.7105 -0.00184 8.233e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH; count 1; } { group C; count 2; } { group CH2=C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH2; count 1; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,4,5,6-pentamethyl-2-methylidene-bicyclo[3.1.0]hex-3-ene" "anti-1,2,3,5,6-pentamethyl-4-methylenebicyclo[3.1.0]hex-2-ene" "1,2,3,5,6-pentamethyl-4-methylidenebicyclo[3.1.0]hex-2-ene" );
standardThermochemistry
{
    dHf_298   -16190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=216750.0
}
