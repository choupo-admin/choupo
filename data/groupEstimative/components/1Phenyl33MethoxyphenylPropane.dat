/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl-3-(3-methoxyphenyl)propane  (C16H18O, CAS 67081-95-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyl33MethoxyphenylPropane;
formula     C16H18O;
CAS         67081-95-2;
InChIKey    NKQJUHNXDRPZFM-UHFFFAOYSA-N;
MW          226.319;      // g/mol [origin=calculated method=formula-sum]
Tc          874.26;      // K   [origin=predictive method=joback]
Pc          22.166;      // bar [origin=predictive method=joback]
omega       0.6485;      // -   [origin=predictive method=lee-kesler]
Tb          646.44;      // K   [origin=predictive method=joback]
HvapTb      58834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.667 1.24332 -0.00073096 1.505e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-3-(3-phenylpropyl)benzene" "benzene,1-methoxy-3-(3-phenylpropyl)-" "benzene, 1-methoxy-3-(3-phenylpropyl)-" );
standardThermochemistry
{
    dHf_298   -44200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=194030.0
}
