/*--------------------------------*- Choupo -*-----------------------*\
  Component: eriodictyol  (C15H12O6, CAS 552-58-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eriodictyol;
formula     C15H12O6;
CAS         552-58-9;
InChIKey    SBHXYTNGIZCORC-UHFFFAOYSA-N;
MW          288.255;      // g/mol [origin=calculated method=formula-sum]
Tc          1315.39;      // K   [origin=predictive method=joback]
Pc          65.670;      // bar [origin=predictive method=joback]
omega       1.9144;      // -   [origin=predictive method=lee-kesler]
Tb          1029.40;      // K   [origin=predictive method=joback]
HvapTb      115096.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.55 1.7999 -0.0017289 6.735e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 3; } { group ACOH; count 4; } { group CH2CO; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 7; } { group OH_phenol; count 4; } { group O_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[3,4-bis(oxidanyl)phenyl]-5,7-bis(oxidanyl)-2,3-dihydrochromen-4-one" "3',4',5,7-tetrahydroxyflavanone" "(s)-2-(3,4-dihydroxyphenyl)-2,3-dihydro-5,7-dihydroxy-4-benzopyrone" "5,7,3',5'-tetrahydroxyflavanone" "( inverted exclamation marka)-eriodictyol" "2-(3,4-dihydroxyphenyl)-5,7-dihydroxychroman-4-one" "b50dd53a-d1b0-4fb5-ac5f-c0f43001b7d8" "brd-a35033682-001-01-0" "2-(3,4-dihydroxyphenyl)-5,7-dihydroxy-2,3-dihydrochromen-4-one" "3 inverted exclamation marka,4 inverted exclamation marka,5,7-tetrahydroxyflavanone" "4h-1-benzopyran-4-one, 2-(3,4-dihydroxy-phenyl)-2,3-dihydro-5,7-dihydroxy-, (2s)-" "flavanone,3',4',5,7-tetrahydroxy- (7ci,8ci); (?a'a a'a currency)-5,7,3',4'-tetrahydroxyflavanone; (?a'a a'a currency)-eriodictyol" );
standardThermochemistry
{
    dHf_298   -803640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-487930.0
}
