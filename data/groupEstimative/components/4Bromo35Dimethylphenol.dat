/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-3,5-dimethylphenol  (C8H9BrO, CAS 7463-51-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo35Dimethylphenol;
formula     C8H9BrO;
CAS         7463-51-6;
InChIKey    WMUWDPLTTLJNPE-UHFFFAOYSA-N;
MW          201.063;      // g/mol [origin=calculated method=formula-sum]
Tc          809.95;      // K   [origin=predictive method=joback]
Pc          46.466;      // bar [origin=predictive method=joback]
omega       0.6520;      // -   [origin=predictive method=lee-kesler]
Tb          566.06;      // K   [origin=predictive method=joback]
HvapTb      56451.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.42 0.75874 -0.00063628 2.269e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 2; } { group ACOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-3,5-dimethyl-phenol" "4-bromo-3,5-xylenol" "4-bromo-3,5-dimethyl phenol" "phenol, 4-bromo-3,5-dimethyl-" "4-bromo-3,5-dimethylphenol," "q245" "3,5-xylenol,4-bromo- (6ci,7ci,8ci);2-bromo-3-methyl-5-hydroxytoluene;3,5-dimethyl-4-bromophenol;4-bromo-3,5-xylenol;" );
standardThermochemistry
{
    dHf_298   -145840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-30670.0
}
