/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-benzyloxy-1-propanol  (C10H14O2, CAS 4799-68-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Benzyloxy1Propanol;
formula     C10H14O2;
CAS         4799-68-2;
InChIKey    FUCYABRIJPUVAT-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          760.75;      // K   [origin=predictive method=joback]
Pc          31.847;      // bar [origin=predictive method=joback]
omega       0.9492;      // -   [origin=predictive method=lee-kesler]
Tb          569.68;      // K   [origin=predictive method=joback]
HvapTb      59219.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.316 0.8457 -0.0004708 8.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylmethoxypropan-1-ol" "3-benzyloxypropanol" "3-benzyloxy-propan-1-ol" "1-propanol, 3-(benzyloxy)-" "1-propanol, 3-(phenylmethoxy)-" "3-phenylmethoxy-1-propanol" "3-(benzyloxy)-1-propanol" "3-(benzyloxy)propan-1-ol" "3-phenylmethoxy-propan-1-ol" "3-benzoxypropan-1-ol" "3-(benzyl-oxy)propan-1-ol" "3-benzyloxyl propane-1-ol" );
gibbsFormation
{
    dHf_298   -297650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96090.0
    phase     gas;
}
