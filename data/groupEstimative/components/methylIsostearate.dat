/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl isostearate  (C19H38O2, CAS 5129-61-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylIsostearate;
formula     C19H38O2;
CAS         5129-61-3;
InChIKey    KDQIFKKWPMBNOH-UHFFFAOYSA-N;
MW          298.511;      // g/mol [origin=calculated method=formula-sum]
Tc          860.33;      // K   [origin=predictive method=joback]
Pc          10.899;      // bar [origin=predictive method=joback]
omega       0.8760;      // -   [origin=predictive method=lee-kesler]
Tb          692.10;      // K   [origin=predictive method=joback]
HvapTb      64907.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.344 1.75996 -0.0009184 1.573e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 13; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 14; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 16-methylheptadecanoate" "isooctadecanoic acid, methyl ester" "heptadecanoic acid, 16-methyl-, methyl ester" "16-methylheptadecanoic acid methyl ester" "methyl isooctadecanoate" "heptadecanoic acid,16-methyl-, methyl ester" );
standardThermochemistry
{
    dHf_298   -758050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     937.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203710.0
}
