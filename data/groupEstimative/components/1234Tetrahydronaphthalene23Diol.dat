/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-tetrahydronaphthalene-2,3-diol  (C10H12O2, CAS 41597-55-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234Tetrahydronaphthalene23Diol;
formula     C10H12O2;
CAS         41597-55-1;
InChIKey    DHTGPMXCRKCPTP-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          851.12;      // K   [origin=predictive method=joback]
Pc          41.303;      // bar [origin=predictive method=joback]
omega       1.3063;      // -   [origin=predictive method=lee-kesler]
Tb          650.76;      // K   [origin=predictive method=joback]
HvapTb      73926.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.65 0.9982 -0.00066356 1.692e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group ACH; count 4; } { group ACCH2; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trans-tetraline-2,3-diol" "2,3-naphthalenediol, 1,2,3,4-tetrahydro-, trans-" "tetralin-2,3-diol" "1,2,3,4-tetrahydronaphthalene-cis-2,3-diol" "agn-pc-00give" "2, 1,2,3,4-tetrahydro-, trans-" "1,2,3,4-tetrahydronaphthalene-trans-2,3-diol" );
gibbsFormation
{
    dHf_298   -282830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96600.0
    phase     gas;
}
