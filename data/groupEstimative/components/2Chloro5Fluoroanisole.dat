/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-5-fluoroanisole  (C7H6ClFO, CAS 450-89-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro5Fluoroanisole;
formula     C7H6ClFO;
CAS         450-89-5;
InChIKey    ULVPJKKERHMKLS-UHFFFAOYSA-N;
MW          160.572;      // g/mol [origin=calculated method=formula-sum]
Tc          664.60;      // K   [origin=predictive method=joback]
Pc          35.096;      // bar [origin=predictive method=joback]
omega       0.4323;      // -   [origin=predictive method=lee-kesler]
Tb          455.52;      // K   [origin=predictive method=joback]
HvapTb      40754.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.7 0.42632 -0.00017992 7.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CH3O; count 1; } { group ACCl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-fluoranyl-2-methoxy-benzene" "1-chloro-4-fluoro-2-methoxybenzene" "benzene, 1-chloro-4-fluoro-2-methoxy-" "1-chloro-4-fluoro-2-methoxy-benzene" "anisole,6-chloro-3-fluoro- (8ci);1-chloro-4-fluoro-2-methoxybenzene;" "1-chloro-2-methoxy-4-fluorobenzene;2-chloro-5-fluoroanisole1-chloro-4-fluoro-2-methoxybenzene" );
standardThermochemistry
{
    dHf_298   -318290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-210530.0
}
