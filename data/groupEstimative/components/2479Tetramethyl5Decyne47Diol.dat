/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,7,9-tetramethyl-5-decyne-4,7-diol  (C14H26O2, CAS 126-86-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2479Tetramethyl5Decyne47Diol;
formula     C14H26O2;
CAS         126-86-3;
InChIKey    LXOFYPKXCSULTL-UHFFFAOYSA-N;
MW          226.36;      // g/mol [origin=calculated method=formula-sum]
Tc          892.85;      // K   [origin=predictive method=joback]
Pc          21.354;      // bar [origin=predictive method=joback]
omega       1.2202;      // -   [origin=predictive method=lee-kesler]
Tb          705.94;      // K   [origin=predictive method=joback]
HvapTb      78900.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.008 1.51552 -0.00105646 2.9678e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 2; } { group C; count 2; } { group OH; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 2; } { group C; count 2; } { group tC; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,7,9-tetramethyldec-5-yne-4,7-diol" "surfynol 104a" "surfynol 104e" "2,4,7,9-tetramethyl-5-decyn-4,7-diol" "5-decyne-4,7-diol, 2,4,7,9-tetramethyl-" "1,4-diisobutyl-1,4-dimethylbutynediol" "5-decyne-4,7-diol-2,4,7,9-tetramethyl" "surfynol tg" "acetylenol e 00" "olfine stg-e" "surfynol 104h" "surfynol pg 50" );
standardThermochemistry
{
    dHf_298   -392510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     678.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3040.0
}
