/*--------------------------------*- Choupo -*-----------------------*\
  Component: (6r)-6-methylcyclohex-3-ene-1-carboxylic acid  (C8H12O2, CAS 98072-20-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6r6Methylcyclohex3Ene1CarboxylicAcid;
formula     C8H12O2;
CAS         98072-20-9;
InChIKey    UTEIUSUWIZICDO-ULUSZKPHSA-N;
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          764.84;      // K   [origin=predictive method=joback]
Pc          35.054;      // bar [origin=predictive method=joback]
omega       0.6107;      // -   [origin=predictive method=lee-kesler]
Tb          542.19;      // K   [origin=predictive method=joback]
HvapTb      50978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.67 0.85422 -0.00049688 9.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cyclohexene-1-carboxylic acid, 6-methyl-, (1r,6r)-rel-" "trans-1-methyl-4-cyclohexene-2-carboxylic acid" "trans-6-methylcyclohex-3-ene-1-carboxylic acid" );
standardThermochemistry
{
    dHf_298   -466960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-280730.0
}
