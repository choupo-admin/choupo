/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[bis[3-(dimethylamino)propyl]amino]-2-propanol  (C13H31N3O, CAS 67151-63-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bis3DimethylaminoPropylAmino2Propanol;
formula     C13H31N3O;
CAS         67151-63-7;
InChIKey    NWDRKFORNVPWLY-UHFFFAOYSA-N;
MW          245.411;      // g/mol [origin=calculated method=formula-sum]
Tc          784.96;      // K   [origin=predictive method=joback]
Pc          17.773;      // bar [origin=predictive method=joback]
omega       1.1796;      // -   [origin=predictive method=lee-kesler]
Tb          626.10;      // K   [origin=predictive method=joback]
HvapTb      66952.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.393 1.6505 -0.0010548 2.65e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } { group CH3N; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[bis[3-(dimethylamino)propyl]amino]propan-2-ol" "1-(bis(3-dimethylaminopropyl)amino)-2-propanol" "1-(bis(3-(dimethylamino)propyl)amino)propan-2-ol" "1-{bis[3-(dimethylamino)propyl]amino}propan-2-ol" "2-propanol, 1-(bis(3-(dimethylamino)propyl)amino)-" "2-propanol, 1-[bis[3-(dimethylamino)propyl]amino]-" "1-bis[3-(dimethylamino)propyl]amino-2-propanol" );
gibbsFormation
{
    dHf_298   -266570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     751.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=251660.0
    phase     gas;
}
