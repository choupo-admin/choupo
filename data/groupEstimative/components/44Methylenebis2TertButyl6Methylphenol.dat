/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-methylenebis(2-tert-butyl-6-methylphenol)  (C23H32O2, CAS 96-65-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Methylenebis2TertButyl6Methylphenol;
formula     C23H32O2;
CAS         96-65-1;
InChIKey    RKLRVTKRKFEVQG-UHFFFAOYSA-N;
MW          340.507;      // g/mol [origin=calculated method=formula-sum]
Tc          1197.49;      // K   [origin=predictive method=joback]
Pc          16.155;      // bar [origin=predictive method=joback]
omega       1.0891;      // -   [origin=predictive method=lee-kesler]
Tb          953.90;      // K   [origin=predictive method=joback]
HvapTb      97428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.419 2.35396 -0.00187796 6.239e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 4; } { group AC; count 3; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tert-butyl-4-[(3-tert-butyl-5-methyl-4-oxidanyl-phenyl)methyl]-6-methyl-phenol" "o-cresol, 4,4'-methylenebis[6-tert-butyl-" "phenol, 4,4'-methylenebis[2-(1,1-dimethylethyl)-6-methyl-" "o-cresol,4'-methylenebis[6-tert-butyl-" "6,6'-di-tert-butyl-4,4'-methylenedi-o-cresol" "phenol,4'-methylenebis[2-(1,1-dimethylethyl)-6-methyl-" "2-(tert-butyl)-4-{[3-(tert-butyl)-4-hydroxy-5-methylphenyl]methyl}-6-methylphe nol" "2-(tert-butyl)-4-{[5-(tert-butyl)-4-hydroxy-3-methylphenyl]methyl}-6-methylphe nol" "2-tert-butyl-4-[(3-tert-butyl-4-hydroxy-5-methylphenyl)methyl]-6-methylphenol" );
standardThermochemistry
{
    dHf_298   -462990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     789.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25520.0
}
