/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-hexen-1-ol  (C6H12O, CAS 821-41-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Hexen1Ol;
formula     C6H12O;
CAS         821-41-0;
InChIKey    UIZVMOZAXAMASY-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          590.02;      // K   [origin=predictive method=joback]
Pc          36.290;      // bar [origin=predictive method=joback]
omega       0.7390;      // -   [origin=predictive method=lee-kesler]
Tb          425.74;      // K   [origin=predictive method=joback]
HvapTb      44959.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.266 0.5878 -0.0003559 8.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-5-en-1-ol" "1-hexen-6-ol" "5-hexenol" "agn-pc-0cjg1v" "1-hexen-6-ol;5-hexene-1-ol;6-hydroxy-1-hexene;5-hexenol;" );
standardThermochemistry
{
    dHf_298   -193970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49340.0
}
