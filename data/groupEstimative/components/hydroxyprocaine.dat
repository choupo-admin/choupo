/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydroxyprocaine  (C13H20N2O3, CAS 487-53-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydroxyprocaine;
formula     C13H20N2O3;
CAS         487-53-6;
InChIKey    GHSCYMOJHVOGDJ-UHFFFAOYSA-N;
MW          252.314;      // g/mol [origin=calculated method=formula-sum]
Tc          967.68;      // K   [origin=predictive method=joback]
Pc          26.543;      // bar [origin=predictive method=joback]
omega       1.1932;      // -   [origin=predictive method=lee-kesler]
Tb          752.51;      // K   [origin=predictive method=joback]
HvapTb      80575.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.246 1.38604 -0.00096532 2.685e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COO; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethyl 4-azanyl-2-oxidanyl-benzoate" "oxycaine" "hydroxynovocain" "oxyprocaine" "oxyprocain" "m-hydroxyprocaine" "oxiprocainum" "metahydroxyprocaine" "2-diethylaminoethyl p-aminosalicylate" "diethylaminoethyl p-aminosalicylate" "idrossiprocaina [dcit]" "diethylaminoethanol p-aminosalicylate" );
standardThermochemistry
{
    dHf_298   -479860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     695.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-126400.0
}
