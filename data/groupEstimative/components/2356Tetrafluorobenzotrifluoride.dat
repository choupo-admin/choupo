/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,5,6-tetrafluorobenzotrifluoride  (C7HF7, CAS 651-80-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2356Tetrafluorobenzotrifluoride;
formula     C7HF7;
CAS         651-80-9;
InChIKey    ZVPAJILXQHMKMT-UHFFFAOYSA-N;
MW          218.071;      // g/mol [origin=calculated method=formula-sum]
Tc          556.34;      // K   [origin=predictive method=joback]
Pc          27.269;      // bar [origin=predictive method=joback]
omega       0.5473;      // -   [origin=predictive method=lee-kesler]
Tb          398.02;      // K   [origin=predictive method=joback]
HvapTb      29085.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.98 0.5603 -0.00040664 1.091e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 1; } { group ACF; count 4; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group F; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4,5-tetrakis(fluoranyl)-3-(trifluoromethyl)benzene" "1,2,4,5-tetrafluoro-3-(trifluoromethyl)benzene" "benzene, 1,2,4,5-tetrafluoro-3-(trifluoromethyl)-" "toluene, .alpha.,.alpha.,.alpha.,2,3,5,6-heptafluoro-" "t154" "alpha,alpha,alpha,2,3,5,6-heptafluorotoluene" "2,3,5,6-tetrafluorobenzotrifluoride;1,2,4,5-tetrafluoro-3-(trifluoromethyl)benzene;toluene, a'a" "afa,a'a" "afa,a'a" "afa,2,3,5,6-heptafluoro-;a'a" "afa,a'a" "afa,a'a" "afa,2,3,5,6-heptafluorotoluene;" );
standardThermochemistry
{
    dHf_298   -1378680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1278880.0
}
