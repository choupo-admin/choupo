/*--------------------------------*- Choupo -*-----------------------*\
  Component: nsc 86697  (C36H54N4O2, CAS 13018-50-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nsc86697;
formula     C36H54N4O2;
CAS         13018-50-3;
InChIKey    DMPYTENYPFANFS-UHFFFAOYSA-N;
MW          574.854;      // g/mol [origin=calculated method=formula-sum]
Tc          1662.71;      // K   [origin=predictive method=joback]
Pc          8.580;      // bar [origin=predictive method=joback]
omega       0.6978;      // -   [origin=predictive method=lee-kesler]
Tb          1340.64;      // K   [origin=predictive method=joback]
HvapTb      128944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-327.68 4.45744 -0.003602 1.22092e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 16; } { group C; count 2; } { group ACH; count 10; } { group AC; count 2; } { group CH3N; count 2; } { group CONHCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group CH2_ring; count 8; } { group C_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group CdO; count 2; } { group NH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-bis[(1-methyl-4-phenyl-piperidin-4-yl)methyl]decanediamide" "n,n'-bis(1-methyl-4-phenyl-4-piperidylmethyl)sebacamide" "n,n'-bis[(1-methyl-4-phenylpiperidin-4-yl)methyl]decanediamide" "1,10-decanediamide, n,n'-bis(1-methyl-4-phenyl-4-piperidylmethyl)-" "decanediamide, n,n'-bis((1-methyl-4-phenyl-4-piperidinyl)methyl)-" "decanediamide, n,n'-bis[(1-methyl-4-phenyl-4-piperidinyl)methyl]-" "decanediamide der." "decanediamide,n'-bis[(1-methyl-4-phenyl-4-piperidyl)methyl]-" "diammide sebacica della 4-fenil-4-amminometil-n-metilpiperidina" "decanediamide, n,n'-bis((1-methyl-4-phenyl-4-piperidyl)methyl)-" "decanediamide,n'-bis[(1-methyl-4-phenyl-4-piperidinyl)methyl]-" "decanediamide, n,n'-bis((1-methyl-4-phenyl-4-piperidinyl)methyl)- (9ci)" );
gibbsFormation
{
    dHf_298   -145030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1550.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=681680.0
    phase     gas;
}
