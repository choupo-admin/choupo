/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methoxybicyclo[2.2.2]oct-2-ene  (C9H14O, CAS 56206-38-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methoxybicyclo222Oct2Ene;
formula     C9H14O;
CAS         56206-38-3;
InChIKey    UABPTVVBJJKHMW-UHFFFAOYSA-N;
MW          138.21;      // g/mol [origin=calculated method=formula-sum]
Tc          652.70;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.3579;      // -   [origin=predictive method=lee-kesler]
Tb          444.45;      // K   [origin=predictive method=joback]
HvapTb      38191.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.8 0.99572 -0.00063428 1.559e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 3; } { group CH=CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.2]oct-2-ene,5-methoxy-" "agn-pc-03dvon" "7-methoxybicyclo[2.2.2]oct-2-ene" "bicyclo(2.2.2)oct-2-ene, 5-methoxy-" );
standardThermochemistry
{
    dHf_298   -190590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     297.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39450.0
}
