/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(4-methoxyphenyl)-2-butanone  (C11H14O2, CAS 104-20-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Methoxyphenyl2Butanone;
formula     C11H14O2;
CAS         104-20-1;
InChIKey    PCBSXBYCASFXTM-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          769.63;      // K   [origin=predictive method=joback]
Pc          27.354;      // bar [origin=predictive method=joback]
omega       0.6438;      // -   [origin=predictive method=lee-kesler]
Tb          559.23;      // K   [origin=predictive method=joback]
HvapTb      52174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.142 0.81924 -0.00040906 5.646e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-methoxyphenyl)butan-2-one" "anisylacetone" "2-butanone, 4-(4-methoxyphenyl)-" "2-butanone, 4-(p-methoxyphenyl)-" "4-methoxybenzylacetone" "methyl oxanone" "anisylacetone, p-" "raspberry ketone methyl ether" "4-(p-methoxyphenyl)-2-butanone" "1-(4-methoxyphenyl)-3-butanone" "1-(p-methoxyphenyl)-3-butanone-" "methoxybenzylacetone, p-" );
gibbsFormation
{
    dHf_298   -290110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-89400.0
    phase     gas;
}
