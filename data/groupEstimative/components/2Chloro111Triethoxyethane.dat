/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-1,1,1-triethoxyethane  (C8H17ClO3, CAS 51076-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro111Triethoxyethane;
formula     C8H17ClO3;
CAS         51076-95-0;
InChIKey    URFKLQSFBXBOQU-UHFFFAOYSA-N;
MW          196.671;      // g/mol [origin=calculated method=formula-sum]
Tc          664.43;      // K   [origin=predictive method=joback]
Pc          23.680;      // bar [origin=predictive method=joback]
omega       0.5874;      // -   [origin=predictive method=lee-kesler]
Tb          484.10;      // K   [origin=predictive method=joback]
HvapTb      43721.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.534 0.70686 -0.0002706 5e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2O; count 3; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group Cl; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-1,1,1-triethoxy-ethane" "triethyl orthochloroacetate" "triethyl 2-chloroorthoacetate" "chlorotriethoxyethane" "orthochloroacetic acid triethyl ester" );
standardThermochemistry
{
    dHf_298   -629600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-307610.0
}
