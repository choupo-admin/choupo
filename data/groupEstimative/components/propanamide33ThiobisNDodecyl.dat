/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanamide, 3,3'-thiobis[n-dodecyl-  (C30H60N2O2S, CAS 10508-00-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanamide33ThiobisNDodecyl;
formula     C30H60N2O2S;
CAS         10508-00-6;
InChIKey    OGZYGXNNROAPTD-UHFFFAOYSA-N;
MW          512.882;      // g/mol [origin=calculated method=formula-sum]
Tc          1485.23;      // K   [origin=predictive method=joback]
Pc          6.478;      // bar [origin=predictive method=joback]
omega       0.2523;      // -   [origin=predictive method=lee-kesler]
Tb          1162.86;      // K   [origin=predictive method=joback]
HvapTb      115555.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.516 2.94463 -0.0016278 3.2112e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 23; } { group CONHCH2; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 26; } { group CdO; count 2; } { group NH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-dodecyl-3-[3-(dodecylamino)-3-oxidanylidene-propyl]sulfanyl-propanamide" "n,n'-dilaurylthiodipropionamide" "propanamide, 3,3'-thiobis(n-dodecyl-" "propanamide,3'-thiobis[n-dodecyl-" "propionamide,3'-thiobis[n-dodecyl-" "3,3'-thiobis(n-dodecylpropionamide)" "3,3'-sulfanediylbis(n-dodecylpropanamide)" "propionamide, 3,3'-thiobis(n-dodecyl- (8ci)" "n-dodecyl-3-[3-(dodecylamino)-3-oxopropyl]sulfanylpropanamide" );
standardThermochemistry
{
    dHf_298   -738880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1520.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=155780.0
}
