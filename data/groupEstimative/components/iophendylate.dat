/*--------------------------------*- Choupo -*-----------------------*\
  Component: iophendylate  (C19H29IO2, CAS 99-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iophendylate;
formula     C19H29IO2;
CAS         99-79-6;
InChIKey    LAYLQVBQIBQVLL-UHFFFAOYSA-N;
MW          416.339;      // g/mol [origin=calculated method=formula-sum]
Tc          1029.03;      // K   [origin=predictive method=joback]
Pc          13.369;      // bar [origin=predictive method=joback]
omega       0.9046;      // -   [origin=predictive method=lee-kesler]
Tb          816.90;      // K   [origin=predictive method=joback]
HvapTb      77218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.429 1.66054 -0.00096396 1.978e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2COO; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 10-(4-iodophenyl)undecanoate" "iofendylate" "jofendylatum" "iophendylate, p-" "mulsopaque" "neurotrast" "ethiodan" "myodil" "myodyl" "ethyl iodophenylundecylate" "iofendylatum [inn-latin]" "ethyl 10-(p-iodophenyl)undecylate" );
gibbsFormation
{
    dHf_298   -456120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     880.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42810.0
    phase     gas;
}
