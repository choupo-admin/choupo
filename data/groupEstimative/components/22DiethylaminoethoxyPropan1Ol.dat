/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-diethylaminoethoxy)propan-1-ol  (C9H21NO2, CAS 68092-67-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DiethylaminoethoxyPropan1Ol;
formula     C9H21NO2;
CAS         68092-67-1;
InChIKey    PKFSEFNWSYNKKM-UHFFFAOYSA-N;
MW          175.272;      // g/mol [origin=calculated method=formula-sum]
Tc          693.10;      // K   [origin=predictive method=joback]
Pc          24.975;      // bar [origin=predictive method=joback]
omega       1.0227;      // -   [origin=predictive method=lee-kesler]
Tb          532.12;      // K   [origin=predictive method=joback]
HvapTb      56372.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.125 0.95946 -0.000501 8.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH2N; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(diethylamino)ethoxy]propan-1-ol" "poly(oxy(methyl-1,2-ethanediyl)), " "a-(2-(diethylamino)ethyl)-" "o-hydroxy-" "2-(2-diethylaminoethyloxy)propan-1-ol" "poly(oxy(methyl-1,2-ethanediyl)), alpha-(2-(diethylamino)ethyl)-omega-hydroxy-" );
gibbsFormation
{
    dHf_298   -451290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-108580.0
    phase     gas;
}
