/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholesta-4,6-dien-3-one  (C27H42O, CAS 566-93-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholesta46Dien3One;
formula     C27H42O;
CAS         566-93-8;
InChIKey    XIWMRKFKSRYSIJ-UHFFFAOYSA-N;
MW          382.632;      // g/mol [origin=calculated method=formula-sum]
Tc          1162.06;      // K   [origin=predictive method=joback]
Pc          10.871;      // bar [origin=predictive method=joback]
omega       0.7903;      // -   [origin=predictive method=lee-kesler]
Tb          927.05;      // K   [origin=predictive method=joback]
HvapTb      78005.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-273.407 3.3273 -0.00271812 9.669e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 8; } { group CH; count 6; } { group C; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10,13-dimethyl-17-(6-methylheptan-2-yl)-1,2,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-3-one" "4,6-cholestadien-3-one" "agn-pc-00htiw" "(9beta,17alpha)-cholesta-4,6-dien-3-one" "(14beta,17alpha)-cholesta-4,6-dien-3-one" "(9beta,14beta,17alpha)-cholesta-4,6-dien-3-one" "(8s,9r,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-1,2,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-3-one" );
standardThermochemistry
{
    dHf_298   -394580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     821.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=255380.0
}
