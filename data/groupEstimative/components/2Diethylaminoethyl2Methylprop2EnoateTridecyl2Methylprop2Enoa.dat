/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-diethylaminoethyl 2-methylprop-2-enoate; tridecyl 2-methylprop-2-enoate  (C27H51NO4, CAS 65086-63-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Diethylaminoethyl2Methylprop2EnoateTridecyl2Methylprop2Enoa;
formula     C27H51NO4;
CAS         65086-63-7;
InChIKey    CQDQJVMAQFDDMI-UHFFFAOYSA-N;
MW          453.708;      // g/mol [origin=calculated method=formula-sum]
Tc          1155.22;      // K   [origin=predictive method=joback]
Pc          6.940;      // bar [origin=predictive method=joback]
omega       0.6072;      // -   [origin=predictive method=lee-kesler]
Tb          940.76;      // K   [origin=predictive method=joback]
HvapTb      91667.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.926 2.3368 -0.001004 5.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 15; } { group CH2=C; count 2; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 16; } { group dCH2; count 2; } { group dC; count 2; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethyl 2-methylprop-2-enoate;tridecyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 2-(diethylamino)ethyl ester, polymer with tridecyl 2-methyl-2-propenoate" );
standardThermochemistry
{
    dHf_298   -1047980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1416.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-279680.0
}
