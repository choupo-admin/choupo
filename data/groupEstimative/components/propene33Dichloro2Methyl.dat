/*--------------------------------*- Choupo -*-----------------------*\
  Component: propene, 3,3-dichloro-2-methyl-  (C4H6Cl2, CAS 22227-75-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propene33Dichloro2Methyl;
formula     C4H6Cl2;
CAS         22227-75-4;
InChIKey    IBOBCGSJCSKTKP-UHFFFAOYSA-N;
MW          124.992;      // g/mol [origin=calculated method=formula-sum]
Tc          556.78;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.2454;      // -   [origin=predictive method=lee-kesler]
Tb          362.10;      // K   [origin=predictive method=joback]
HvapTb      32290.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.67 0.38322 -0.000263 7.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(chloranyl)-2-methyl-prop-1-ene" "3,3-dichloroisobutylene" "3,3-dichloro-2-methylpropene" "1,1-dichloro-2-methyl-2-propene" "3,3-dichloro-2-methyl-1-propene" "3,3-dichloro-2-methylprop-1-ene" "1-propene, 3,3-dichloro-2-methyl-" "1-propene, 3,3-dichloro-2-methyl- (9ci)" );
gibbsFormation
{
    dHf_298   -47010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35790.0
    phase     gas;
}
