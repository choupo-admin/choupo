/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromodiiodomethane  (CHBrI2, CAS 557-95-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromodiiodomethane;
formula     CHBrI2;
CAS         557-95-9;
InChIKey    PTGIGXMFLYACDM-UHFFFAOYSA-N;
MW          346.723;      // g/mol [origin=calculated method=formula-sum]
Tc          760.49;      // K   [origin=predictive method=joback]
Pc          60.940;      // bar [origin=predictive method=joback]
omega       0.2479;      // -   [origin=predictive method=lee-kesler]
Tb          474.48;      // K   [origin=predictive method=joback]
HvapTb      42613.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.87 0.2209 -0.000268 1.141e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group I; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group Br; count 1; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromanyl-bis(iodanyl)methane" "methane, bromodiiodo-" "bromo(diiodo)methane" "bromo-diiodo-methane" );
standardThermochemistry
{
    dHf_298   110820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     347.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85660.0
}
