/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-pentanoic acid, trimethylsilyl ester  (C18H38O2Si, CAS 74367-22-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C18H38O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nPentanoicAcidTrimethylsilylEster;
formula     C18H38O2Si;
CAS         74367-22-9;
InChIKey    SHDTWSQDHLKGEO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          314.585;      // g/mol [origin=calculated method=formula-sum]
Tc          839.56;      // K   [origin=predictive method=joback]
Pc          10.673;      // bar [origin=predictive method=joback]
omega       0.7942;      // -   [origin=predictive method=lee-kesler]
Tb          671.06;      // K   [origin=predictive method=joback]
HvapTb      63363.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.753 1.45288 -0.000446 -7.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group CH2COO; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 13; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethylsilyl pentadecanoate" "n-pentadecanoic acid, trimethylsilyl ester" "pentadecanoic acid trimethylsilyl ester" );
standardThermochemistry
{
    dHf_298   -843750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1034.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-314450.0
}
