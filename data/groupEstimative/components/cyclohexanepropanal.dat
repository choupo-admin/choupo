/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanepropanal  (C9H16O, CAS 4361-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanepropanal;
formula     C9H16O;
CAS         4361-28-8;
InChIKey    RKFNAZGRJVNWEW-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          678.64;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       0.4680;      // -   [origin=predictive method=lee-kesler]
Tb          473.73;      // K   [origin=predictive method=joback]
HvapTb      42777.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.498 0.9554 -0.0005398 1.034e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cyclohexylpropanal" "cyclohexanepropionaldehyde" "3-cyclohexylpropionaldehyde" "3-cyclohexyl-propionaldehyde" "3-(cyclohexyl)propionaldehyde" );
gibbsFormation
{
    dHf_298   -260350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-50170.0
    phase     gas;
}
