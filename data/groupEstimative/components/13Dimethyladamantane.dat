/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dimethyladamantane  (C12H20, CAS 702-79-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dimethyladamantane;
formula     C12H20;
CAS         702-79-4;
InChIKey    CWNOIUTVJRWADX-UHFFFAOYSA-N;
MW          164.292;      // g/mol [origin=calculated method=formula-sum]
Tc          720.66;      // K   [origin=predictive method=joback]
Pc          27.759;      // bar [origin=predictive method=joback]
omega       0.3432;      // -   [origin=predictive method=lee-kesler]
Tb          494.46;      // K   [origin=predictive method=joback]
HvapTb      39606.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-257.91 2.14424 -0.002253 9.674e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 2; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "adamantane, 1,3-dimethyl-" "tricyclo[3.3.1.1(3,7)]decane, 1,3-dimethyl-" "ambap702-79-4" "1,3-dimethyltricyclo(3.3.1.13,7)decane" "1,3-dimethyltricyclo[3.3.1.1(3,7)]decane" "adamantane,1,3-dimethyl- (6ci,8ci);1,3-dimethyltricyclo[3.3.1.13,7]decane;1,3-dimethyl-adamantane;tricyclo[3.3.1.13,7]decane,1,3-dimethyl-;" );
standardThermochemistry
{
    dHf_298   -68630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=201620.0
}
