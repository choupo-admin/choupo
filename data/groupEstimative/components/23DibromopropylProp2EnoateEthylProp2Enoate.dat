/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dibromopropyl prop-2-enoate; ethyl prop-2-enoate  (C11H16Br2O4, CAS 68214-84-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DibromopropylProp2EnoateEthylProp2Enoate;
formula     C11H16Br2O4;
CAS         68214-84-6;
InChIKey    CPYYIEKFXZCTAE-UHFFFAOYSA-N;
MW          372.053;      // g/mol [origin=calculated method=formula-sum]
Tc          905.78;      // K   [origin=predictive method=joback]
Pc          22.208;      // bar [origin=predictive method=joback]
omega       0.9324;      // -   [origin=predictive method=lee-kesler]
Tb          694.36;      // K   [origin=predictive method=joback]
HvapTb      66330.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (93.243 0.77532 -0.0001624 -1.092e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2=CH; count 2; } { group Br; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group Br; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(bromanyl)propyl prop-2-enoate;ethyl prop-2-enoate" "2-propenoic acid, 2,3-dibromopropyl ester, polymer with ethyl 2-propenoate" );
standardThermochemistry
{
    dHf_298   -718310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     878.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-481880.0
}
