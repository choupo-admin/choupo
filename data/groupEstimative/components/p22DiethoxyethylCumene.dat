/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-(2,2-diethoxyethyl)cumene  (C15H24O2, CAS 67859-98-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        p22DiethoxyethylCumene;
formula     C15H24O2;
CAS         67859-98-7;
InChIKey    OBKPLJKFWGCMTP-UHFFFAOYSA-N;
MW          236.355;      // g/mol [origin=calculated method=formula-sum]
Tc          815.39;      // K   [origin=predictive method=joback]
Pc          17.955;      // bar [origin=predictive method=joback]
omega       0.7093;      // -   [origin=predictive method=lee-kesler]
Tb          618.42;      // K   [origin=predictive method=joback]
HvapTb      55966.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.283 1.17588 -0.00054076 5.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,2-diethoxyethyl)-4-propan-2-yl-benzene" "1-(2,2-diethoxyethyl)-4-isopropylbenzene" "1-(2,2-diethoxyethyl)-4-(isopropyl)benzene" "benzene, 1-(2,2-diethoxyethyl)-4-(1-methylethyl)-" "(p-isopropylphenyl)acetaldehyde diethyl acetal" "1-(2,2-diethoxyethyl)-4-propan-2-ylbenzene" );
standardThermochemistry
{
    dHf_298   -402870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     631.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-36680.0
}
