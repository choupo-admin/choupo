/*--------------------------------*- Choupo -*-----------------------*\
  Component: cutina e 24pf  (C23H50O7, CAS 138860-92-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cutinaE24pf;
formula     C23H50O7;
CAS         138860-92-1;
InChIKey    DZTJRUYDMKJKPJ-UHFFFAOYSA-N;
MW          438.646;      // g/mol [origin=calculated method=formula-sum]
Tc          1975.06;      // K   [origin=predictive method=joback]
Pc          10.785;      // bar [origin=predictive method=joback]
omega       -0.0790;      // -   [origin=predictive method=lee-kesler]
Tb          1334.61;      // K   [origin=predictive method=joback]
HvapTb      167551.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (92.99 2.00312 -0.0006256 -9.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CH; count 1; } { group OH; count 3; } { group COOH; count 1; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 20; } { group CH; count 1; } { group OH; count 5; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-diol;octadecanoic acid;propane-1,2,3-triol" "nikkol tmgs 15" "ethoxylated glyceryl monostearate" "glycerin monostearate polyethylene glycol ether" "poly(oxy-1,2-ethanediyl), alpha-hydro-omega-hydroxy-, ether with 1,2,3-propanetriol monooctadecanoate (2:1)" );
standardThermochemistry
{
    dHf_298   -1857990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1565.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1097190.0
}
