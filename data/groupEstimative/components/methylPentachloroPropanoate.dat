/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl pentachloro-propanoate  (C4H3Cl5O2, CAS 813-46-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylPentachloroPropanoate;
formula     C4H3Cl5O2;
CAS         813-46-7;
InChIKey    YSCHNGJMUJYQJG-UHFFFAOYSA-N;
MW          260.316;      // g/mol [origin=calculated method=formula-sum]
Tc          766.82;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.4466;      // -   [origin=predictive method=lee-kesler]
Tb          530.03;      // K   [origin=predictive method=joback]
HvapTb      51238.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.17 0.61462 -0.0005448 1.681e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CCl2; count 1; } { group CCl3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 2; } { group Cl; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,2,3,3,3-pentakis(chloranyl)propanoate" "propanoic acid, pentachloro-, methyl ester" "methyl 2,2,3,3,3-pentachloropropanoate" );
standardThermochemistry
{
    dHf_298   -539370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-381540.0
}
