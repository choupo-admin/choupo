/*--------------------------------*- Choupo -*-----------------------*\
  Component: aziridine, 2-ethyl-  (C4H9N, CAS 2549-67-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aziridine2Ethyl;
formula     C4H9N;
CAS         2549-67-9;
InChIKey    CSWPOLMVXVBCSV-UHFFFAOYSA-N;
MW          71.123;      // g/mol [origin=calculated method=formula-sum]
Tc          536.94;      // K   [origin=predictive method=joback]
Pc          47.760;      // bar [origin=predictive method=joback]
omega       0.2901;      // -   [origin=predictive method=lee-kesler]
Tb          346.41;      // K   [origin=predictive method=joback]
HvapTb      31169.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.069 0.52132 -0.0003534 1.028e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylaziridine" "butyleneimine" "ethylethylenimine" "1,2-butylenimine" "2-ethylethylenimine" "2-ethylethyleneimine" "agn-pc-00pzf6" );
standardThermochemistry
{
    dHf_298   -15280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     215.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=131260.0
}
