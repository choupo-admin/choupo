/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethoxypyridine  (C7H9NO2, CAS 6231-18-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethoxypyridine;
formula     C7H9NO2;
CAS         6231-18-1;
InChIKey    IBTGEEMBZJBBSH-UHFFFAOYSA-N;
MW          139.154;      // g/mol [origin=calculated method=formula-sum]
Tc          712.23;      // K   [origin=predictive method=joback]
Pc          38.723;      // bar [origin=predictive method=joback]
omega       0.4899;      // -   [origin=predictive method=lee-kesler]
Tb          489.96;      // K   [origin=predictive method=joback]
HvapTb      45144.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.98 0.4378 -0.00010842 -3.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3O; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group O; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyridine, 2,6-dimethoxy-" "2,6-dimethoxypyridin;" "2,6-dimethoxy pyridine" );
gibbsFormation
{
    dHf_298   -194400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-22110.0
    phase     gas;
}
