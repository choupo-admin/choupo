/*--------------------------------*- Choupo -*-----------------------*\
  Component: propargyl alcohol  (C3H4O, CAS 107-19-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propargylAlcohol;
formula     C3H4O;
CAS         107-19-7;
InChIKey    TVDSBUOJIPERQY-UHFFFAOYSA-N;
MW          56.064;      // g/mol [origin=calculated method=formula-sum]
Tc          524.18;      // K   [origin=predictive method=joback]
Pc          62.393;      // bar [origin=predictive method=joback]
omega       0.5332;      // -   [origin=predictive method=lee-kesler]
Tb          350.54;      // K   [origin=predictive method=joback]
HvapTb      38809.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.231 0.2289 -0.00016573 5.269e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-yn-1-ol" "2-propyn-1-ol" "ethynyl carbinol" "propynyl alcohol" "1-propyn-3-ol" "2-propynol" "2-propynyl alcohol" "ethynylcarbinol" "methanol, ethynyl-" "1-hydroxy-2-propyne" "3-hydroxy-1-propyne" "acetylenylcarbinol" );
standardThermochemistry
{
    dHf_298   34420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     293.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60630.0
}
