/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-benzalacetone  (C10H9ClO, CAS 20766-36-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ChloroBenzalacetone;
formula     C10H9ClO;
CAS         20766-36-3;
InChIKey    VWEPXSRBBXPYSM-AATRIKPKSA-N;
MW          180.631;      // g/mol [origin=calculated method=formula-sum]
Tc          786.73;      // K   [origin=predictive method=joback]
Pc          31.420;      // bar [origin=predictive method=joback]
omega       0.5385;      // -   [origin=predictive method=lee-kesler]
Tb          555.52;      // K   [origin=predictive method=joback]
HvapTb      51881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.74 0.81422 -0.00056986 1.5576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH3CO; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-4-(3-chlorophenyl)but-3-en-2-one" "(e)-4-(3-chlorophenyl)-but-3-en-2-one" "(3-chlorobenzylidene)acetone" "(e)-4-(3-chloro-phenyl)-but-3-en-2-one" );
gibbsFormation
{
    dHf_298   -35770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75470.0
    phase     gas;
}
