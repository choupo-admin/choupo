/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-4-ethylphenol  (C8H9ClO, CAS 18980-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro4Ethylphenol;
formula     C8H9ClO;
CAS         18980-00-2;
InChIKey    QNQRRCHRJHMSLF-UHFFFAOYSA-N;
MW          156.609;      // g/mol [origin=calculated method=formula-sum]
Tc          764.82;      // K   [origin=predictive method=joback]
Pc          41.197;      // bar [origin=predictive method=joback]
omega       0.5774;      // -   [origin=predictive method=lee-kesler]
Tb          532.35;      // K   [origin=predictive method=joback]
HvapTb      53739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.019 0.78682 -0.00065232 2.267e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-4-ethyl-phenol" "phenol, 4-chloro-2-ethyl-" "4-chlor-2-aethylphenol [german]" "4-chlor-2-aethylphenol" "2-chloro-4-ethyl-phenol" "phenol, 2-chloro-4-ethyl-" );
gibbsFormation
{
    dHf_298   -176440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-47290.0
    phase     gas;
}
