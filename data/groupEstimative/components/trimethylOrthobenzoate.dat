/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethyl orthobenzoate  (C10H14O3, CAS 707-07-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylOrthobenzoate;
formula     C10H14O3;
CAS         707-07-3;
InChIKey    IECKAVQTURBPON-UHFFFAOYSA-N;
MW          182.219;      // g/mol [origin=calculated method=formula-sum]
Tc          731.81;      // K   [origin=predictive method=joback]
Pc          28.323;      // bar [origin=predictive method=joback]
omega       0.5168;      // -   [origin=predictive method=lee-kesler]
Tb          519.11;      // K   [origin=predictive method=joback]
HvapTb      46064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.92 0.81116 -0.0003902 4.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethoxymethylbenzene" "benzene, (trimethoxymethyl)-" "(trimethoxymethyl)benzene" "methyl orthobenzoate" "orthobenzoic acid, trimethyl ester" "trimethoxyphenylmethane" "ieckavqturbpon-uhfffaoysa-" "orthobenzoic acid trimethyl ester" "alpha,alpha,alpha-trimethoxytoluene" "orthobenzoic acid, trimethyl ester (8ci)" );
standardThermochemistry
{
    dHf_298   -418610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-166430.0
}
