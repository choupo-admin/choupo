/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxetanone, 4-heptadecylidene-3-tetradecyl-  (C34H64O2, CAS 67845-94-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Oxetanone4Heptadecylidene3Tetradecyl;
formula     C34H64O2;
CAS         67845-94-7;
InChIKey    QRCIXSNAFQIQSW-UHFFFAOYSA-N;
MW          504.884;      // g/mol [origin=calculated method=formula-sum]
Tc          1321.87;      // K   [origin=predictive method=joback]
Pc          5.302;      // bar [origin=predictive method=joback]
omega       0.1617;      // -   [origin=predictive method=lee-kesler]
Tb          1044.85;      // K   [origin=predictive method=joback]
HvapTb      99213.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.632 3.26204 -0.0019663 4.664e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 28; } { group CH; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 28; } { group dCH; count 1; } { group CH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-heptadecylidene-3-tetradecyl-oxetan-2-one" "agn-pc-03vcgo" );
gibbsFormation
{
    dHf_298   -907380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1393.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=43340.0
    phase     gas;
}
