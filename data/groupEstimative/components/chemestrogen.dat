/*--------------------------------*- Choupo -*-----------------------*\
  Component: chemestrogen  (C20H26O2, CAS 85-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chemestrogen;
formula     C20H26O2;
CAS         85-95-0;
InChIKey    DUTFBSAKKUNBAL-UHFFFAOYSA-N;
MW          298.426;      // g/mol [origin=calculated method=formula-sum]
Tc          1110.96;      // K   [origin=predictive method=joback]
Pc          21.553;      // bar [origin=predictive method=joback]
omega       1.1265;      // -   [origin=predictive method=lee-kesler]
Tb          870.48;      // K   [origin=predictive method=joback]
HvapTb      89530.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.988 2.07296 -0.00164892 5.425e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 8; } { group ACCH; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[3-ethyl-4-(4-hydroxyphenyl)hexan-2-yl]phenol" "benzestrol" "benzoestrol" "ocestrol" "4,4'-(1,2-diethyl-3-methyl-1,3-propanediyl)bisphenol" "phenol, 4,4'-(1,2-diethyl-3-methyl-1,3-propanediyl)bis-" "benzestrolo" "benzestrolum" "benzoestrolum" "octoestrol" "octoestrolum" "octofollin" );
gibbsFormation
{
    dHf_298   -353530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     746.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25780.0
    phase     gas;
}
