/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-acetyl-5-chloropentanoate  (C9H15ClO3, CAS 14749-45-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Acetyl5Chloropentanoate;
formula     C9H15ClO3;
CAS         14749-45-2;
InChIKey    JFWRVYZVJGHKCD-UHFFFAOYSA-N;
MW          206.666;      // g/mol [origin=calculated method=formula-sum]
Tc          743.22;      // K   [origin=predictive method=joback]
Pc          23.959;      // bar [origin=predictive method=joback]
omega       0.7574;      // -   [origin=predictive method=lee-kesler]
Tb          554.60;      // K   [origin=predictive method=joback]
HvapTb      53778.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.684 0.78874 -0.0003761 3.826e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH3CO; count 1; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group Cl; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 5-chloranyl-2-ethanoyl-pentanoate" "valeric acid, 2-acetyl-5-chloro-, ethyl ester" );
gibbsFormation
{
    dHf_298   -679970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-428760.0
    phase     gas;
}
