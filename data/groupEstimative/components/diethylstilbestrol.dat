/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylstilbestrol  (C18H20O2, CAS 56-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylstilbestrol;
formula     C18H20O2;
CAS         56-53-1;
InChIKey    RGLYKWWBQGJZGM-ISLYRVAYSA-N;
MW          268.356;      // g/mol [origin=calculated method=formula-sum]
Tc          1081.54;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       1.0695;      // -   [origin=predictive method=lee-kesler]
Tb          829.96;      // K   [origin=predictive method=joback]
HvapTb      86360.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.688 1.88504 -0.00161892 5.712e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(e)-4-(4-hydroxyphenyl)hex-3-en-3-yl]phenol" "stilbestrol" "stilboestrol" "distilbene" "agostilben" "estrobene" "estromenin" "palestrol" "stilbetin" "synestrin" "vagestrol" "fonatol" );
gibbsFormation
{
    dHf_298   -198770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     682.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79380.0
    phase     gas;
}
