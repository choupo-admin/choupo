/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-4'-pentoxy-trans-stilbene  (C20H24O2, CAS 35135-43-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy4PentoxyTransStilbene;
formula     C20H24O2;
CAS         35135-43-4;
InChIKey    ZIQOVNYYJKVZOE-UHFFFAOYSA-N;
MW          296.41;      // g/mol [origin=calculated method=formula-sum]
Tc          988.85;      // K   [origin=predictive method=joback]
Pc          16.155;      // bar [origin=predictive method=joback]
omega       0.8541;      // -   [origin=predictive method=lee-kesler]
Tb          769.52;      // K   [origin=predictive method=joback]
HvapTb      70768.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.686 1.52064 -0.00085432 1.658e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2-[2-(4-pentoxyphenyl)ethenyl]benzene" );
standardThermochemistry
{
    dHf_298   -153230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     725.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=193300.0
}
