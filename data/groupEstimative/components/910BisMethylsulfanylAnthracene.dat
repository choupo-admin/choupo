/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,10-bis(methylsulfanyl)anthracene  (C16H14S2, CAS 10075-83-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        910BisMethylsulfanylAnthracene;
formula     C16H14S2;
CAS         10075-83-9;
InChIKey    JRDYHVRFMFEMMI-UHFFFAOYSA-N;
MW          270.408;      // g/mol [origin=calculated method=formula-sum]
Tc          1059.43;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.7406;      // -   [origin=predictive method=lee-kesler]
Tb          782.82;      // K   [origin=predictive method=joback]
HvapTb      72386.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.35 1.24782 -0.00086972 2.37e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 6; } { group CH3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 6; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "anthracene-9,10-bis(methylthio)-" "anthracene, 9,10-bis(methylthio)-" );
standardThermochemistry
{
    dHf_298   294430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=446900.0
}
