/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4,5-trichlorophenol  (C6H3Cl3O, CAS 609-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        345Trichlorophenol;
formula     C6H3Cl3O;
CAS         609-19-8;
InChIKey    GBNHEBQXJVDXSW-UHFFFAOYSA-N;
MW          197.439;      // g/mol [origin=calculated method=formula-sum]
Tc          818.64;      // K   [origin=predictive method=joback]
Pc          47.236;      // bar [origin=predictive method=joback]
omega       0.6019;      // -   [origin=predictive method=lee-kesler]
Tb          566.43;      // K   [origin=predictive method=joback]
HvapTb      58719.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.88 0.5509 -0.00051728 1.96e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACOH; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4,5-tris(chloranyl)phenol" "phenol, 3,4,5-trichloro-" "3,5-trichlorophenol" "phenol,3,4,5-trichloro-" "gbnhebqxjvdxsw-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -178110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-97620.0
    phase     gas;
}
