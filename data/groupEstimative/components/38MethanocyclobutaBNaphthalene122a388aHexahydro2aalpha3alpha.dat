/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,8-methanocyclobuta(b)naphthalene, 1,2,2a,3,8,8a-hexahydro-,(2aalpha,3alpha,8alpha,8aalpha)-  (C13H14, CAS 67109-90-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        38MethanocyclobutaBNaphthalene122a388aHexahydro2aalpha3alpha;
formula     C13H14;
CAS         67109-90-4;
InChIKey    SHMYIFLHMQKIPZ-UHFFFAOYSA-N;
MW          170.255;      // g/mol [origin=calculated method=formula-sum]
Tc          765.70;      // K   [origin=predictive method=joback]
Pc          29.441;      // bar [origin=predictive method=joback]
omega       0.4606;      // -   [origin=predictive method=lee-kesler]
Tb          535.71;      // K   [origin=predictive method=joback]
HvapTb      46556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-163.08 1.5458 -0.00134556 4.736e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,8-methanocyclobuta[b]naphthalene,1,2,2a,3,8,8a-hexahydro-(2a.alpha.,3.alpha.,8.alpha.,8a.alpha.)-" "3,8-methanocyclobuta[b]naphthalene,1,2,2a,3,8,8a-hexahydro-(2a.alpha.3.beta.,8.beta.,8a.alpha.)-" );
gibbsFormation
{
    dHf_298   123790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     196.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=360100.0
    phase     gas;
}
