/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyltriisopropylsilane  (C12H26Si, CAS 24400-84-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H26Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        allyltriisopropylsilane;
formula     C12H26Si;
CAS         24400-84-8;
InChIKey    AKQHUJRZKBYZLC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          198.425;      // g/mol [origin=calculated method=formula-sum]
Tc          650.97;      // K   [origin=predictive method=joback]
Pc          17.019;      // bar [origin=predictive method=joback]
omega       0.3795;      // -   [origin=predictive method=lee-kesler]
Tb          470.92;      // K   [origin=predictive method=joback]
HvapTb      40766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.761 0.93542 -0.0002467 -6.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 3; } { group CH2=CH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 3; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tri(propan-2-yl)-prop-2-enyl-silane" "tri(propan-2-yl)-prop-2-enylsilane" "akqhujrzkbyzlc-uhfffaoysa-" "silane,tris(1-methylethyl)-2-propen-1-yl-" );
gibbsFormation
{
    dHf_298   -293040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     716.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25920.0
    phase     gas;
}
