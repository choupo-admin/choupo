/*--------------------------------*- Choupo -*-----------------------*\
  Component: gemeprost  (C23H38O5, CAS 64318-79-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gemeprost;
formula     C23H38O5;
CAS         64318-79-2;
InChIKey    KYBOHGVERHWSSV-VNIVIJDLSA-N;
MW          394.552;      // g/mol [origin=calculated method=formula-sum]
Tc          1285.90;      // K   [origin=predictive method=joback]
Pc          11.437;      // bar [origin=predictive method=joback]
omega       1.0500;      // -   [origin=predictive method=lee-kesler]
Tb          1046.83;      // K   [origin=predictive method=joback]
HvapTb      109675.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.723 2.28418 -0.0013088 2.613e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 4; } { group C; count 1; } { group CH=CH; count 2; } { group OH; count 2; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 1; } { group C; count 1; } { group dCH; count 4; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group OH; count 2; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (e)-7-[(1r,2r,3r)-2-[(e,3r)-4,4-dimethyl-3-oxidanyl-oct-1-enyl]-3-oxidanyl-5-oxidanylidene-cyclopentyl]hept-2-enoate" "gemoprost" "preglandin (tn)" "gemeprost (jan/usan/inn)" "n915" "methyl (e)-7-[(1r,2r,3r)-3-hydroxy-2-[(e,3r)-3-hydroxy-4,4-dimethyloct-1-enyl]-5-oxocyclopentyl]hept-2-enoate" );
standardThermochemistry
{
    dHf_298   -1037280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     929.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-381850.0
}
