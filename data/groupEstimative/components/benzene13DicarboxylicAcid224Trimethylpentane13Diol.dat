/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene-1,3-dicarboxylic acid;2,2,4-trimethylpentane-1,3-diol  (C16H24O6, CAS 63687-33-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene13DicarboxylicAcid224Trimethylpentane13Diol;
formula     C16H24O6;
CAS         63687-33-2;
InChIKey    IGUBATUPSTXEOB-UHFFFAOYSA-N;
MW          312.362;      // g/mol [origin=calculated method=formula-sum]
Tc          1309.99;      // K   [origin=predictive method=joback]
Pc          22.062;      // bar [origin=predictive method=joback]
omega       1.6886;      // -   [origin=predictive method=lee-kesler]
Tb          1070.01;      // K   [origin=predictive method=joback]
HvapTb      120056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.501 1.48648 -0.00078016 1.091e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-benzenedicarboxylic acid, polymer with 2,2,4-trimethyl-1,3-pentanediol" "benzene-1,3-dicarboxylic acid; 2,2,4-trimethylpentane-1,3-diol" );
gibbsFormation
{
    dHf_298   -1284440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     924.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-881640.0
    phase     gas;
}
