/*--------------------------------*- Choupo -*-----------------------*\
  Component: dihydro-beta-ionone  (C13H22O, CAS 17283-81-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dihydroBetaIonone;
formula     C13H22O;
CAS         17283-81-7;
InChIKey    QJJDNZGPQDGNDX-UHFFFAOYSA-N;
MW          194.318;      // g/mol [origin=calculated method=formula-sum]
Tc          789.78;      // K   [origin=predictive method=joback]
Pc          21.694;      // bar [origin=predictive method=joback]
omega       0.5898;      // -   [origin=predictive method=lee-kesler]
Tb          579.82;      // K   [origin=predictive method=joback]
HvapTb      52172.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.788 1.44988 -0.0011315 3.9646e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group C; count 1; } { group CH3CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2,6,6-trimethylcyclohexen-1-yl)butan-2-one" "2-butanone, 4-(2,6,6-trimethyl-1-cyclohexen-1-yl)-" "7,8-dihydro-beta-ionone" "oxidized latia luciferin" "4-(2,6,6-trimethylcyclohex-1-en-1-yl)butan-2-one" ".alpha.,.beta.-dihydro-.beta.-ionone" "dihydro-" "a-ionone" "4-(2,6,6-trimethyl-1-cyclohexenyl)-2-butanone" "oxidized-latia-luciferin" "4-(2,6,6-trimethyl-1-cyclohexen-1-yl)-2-butanone" "4-(2,6,6-trimethyl-1-cyclohexen-1-yl)butan-2-one" "4-(2,6,6-trimethyl-1-cyclohexenyl)-butan-2-one" );
standardThermochemistry
{
    dHf_298   -319830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     678.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40680.0
}
