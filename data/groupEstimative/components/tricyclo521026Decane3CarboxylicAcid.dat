/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[5.2.1.02,6]decane-3-carboxylic acid  (C11H16O2, CAS 30772-72-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo521026Decane3CarboxylicAcid;
formula     C11H16O2;
CAS         30772-72-6;
InChIKey    ONBQOCZVFSXWQW-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          836.77;      // K   [origin=predictive method=joback]
Pc          29.666;      // bar [origin=predictive method=joback]
omega       0.7285;      // -   [origin=predictive method=lee-kesler]
Tb          611.94;      // K   [origin=predictive method=joback]
HvapTb      56537.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.48 1.4897 -0.0011506 3.593e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 5; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 5; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7-methano-1h-indenecarboxylic acid, octahydro-" "octahydro-4,7-methano-1h-indenecarboxylic acid" "4,7-methano-1h-indenecarboxylicacid, octahydro-" "tricyclo(5.2.1.02,6)decane-3(4)-carboxylic acid" "4,7-methanoindancarboxylicacid, hexahydro- (7ci); 3(or 4)-carboxytricyclo[5.2.1.02,6]decane; tcd acid s" );
standardThermochemistry
{
    dHf_298   -449080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     302.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147440.0
}
