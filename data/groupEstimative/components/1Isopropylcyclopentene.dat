/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-isopropylcyclopentene  (C8H14, CAS 1462-07-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Isopropylcyclopentene;
formula     C8H14;
CAS         1462-07-3;
InChIKey    HDFWVJAQABCYDP-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          607.97;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.2972;      // -   [origin=predictive method=lee-kesler]
Tb          406.29;      // K   [origin=predictive method=joback]
HvapTb      34534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.41 0.81244 -0.00051764 1.305e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propan-2-ylcyclopentene" "cyclopentene, 1-(1-methylethyl)-" "cyclopentene,1-(1-methylethyl)-" "cyclopentene,1-isopropyl- (6ci,7ci,8ci); 1-isopropyl-1-cyclopentene; 1-isopropylcyclopentene" );
standardThermochemistry
{
    dHf_298   -86600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78630.0
}
