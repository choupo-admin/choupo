/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethyl-6-hepten-2-ol  (C9H18O, CAS 32779-58-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethyl6Hepten2Ol;
formula     C9H18O;
CAS         32779-58-1;
InChIKey    ICHVSYBMEODCOO-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          664.84;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       0.7486;      // -   [origin=predictive method=lee-kesler]
Tb          491.03;      // K   [origin=predictive method=joback]
HvapTb      50421.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.157 0.99856 -0.0006932 1.968e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethylhept-6-en-2-ol" "6-hepten-2-ol, 2,6-dimethyl-" "2,6-dimethyl-hept-6-en-2-ol" );
standardThermochemistry
{
    dHf_298   -274430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29790.0
}
