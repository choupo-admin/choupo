/*--------------------------------*- Choupo -*-----------------------*\
  Component: fenclonine  (C9H10ClNO2, CAS 7424-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fenclonine;
formula     C9H10ClNO2;
CAS         7424-00-2;
InChIKey    NIGWMJHCCYYCSF-UHFFFAOYSA-N;
MW          199.634;      // g/mol [origin=calculated method=formula-sum]
Tc          931.80;      // K   [origin=predictive method=joback]
Pc          36.776;      // bar [origin=predictive method=joback]
omega       0.9641;      // -   [origin=predictive method=lee-kesler]
Tb          692.21;      // K   [origin=predictive method=joback]
HvapTb      70368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.599 0.8458 -0.00056956 1.44e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-3-(4-chlorophenyl)propanoic acid" "4-chlorophenylalanine" "4-chloro-dl-phenylalanine" "dl-p-chlorophenylalanine" "p-chlorophenylalanine" "fenchlonine" "fenclonin" "2-amino-3-(4-chlorophenyl)propanoic acid" "dl-4-chlorophenylalanine" "phenylalanine, 4-chloro-" "dl-pcpa" "para-chlorophenylalanine" );
gibbsFormation
{
    dHf_298   -341530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-164150.0
    phase     gas;
}
