/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentylidenecyclopentane  (C10H18, CAS 53366-55-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentylidenecyclopentane;
formula     C10H18;
CAS         53366-55-5;
InChIKey    UUTALBLZKWDFDU-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          651.73;      // K   [origin=predictive method=joback]
Pc          26.680;      // bar [origin=predictive method=joback]
omega       0.4073;      // -   [origin=predictive method=lee-kesler]
Tb          454.99;      // K   [origin=predictive method=joback]
HvapTb      39207.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.527 1.03452 -0.0006715 1.764e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 1; } { group CH2_ring; count 4; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentane, pentylidene-" "pentylidene-cyclopentane" );
standardThermochemistry
{
    dHf_298   -92880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=123040.0
}
