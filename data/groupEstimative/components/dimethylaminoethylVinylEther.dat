/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylaminoethyl vinyl ether  (C6H13NO, CAS 31442-54-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylaminoethylVinylEther;
formula     C6H13NO;
CAS         31442-54-3;
InChIKey    JWCDUUFOAZFFMX-UHFFFAOYSA-N;
MW          115.176;      // g/mol [origin=calculated method=formula-sum]
Tc          535.33;      // K   [origin=predictive method=joback]
Pc          31.883;      // bar [origin=predictive method=joback]
omega       0.4130;      // -   [origin=predictive method=lee-kesler]
Tb          368.42;      // K   [origin=predictive method=joback]
HvapTb      32733.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.252 0.61454 -0.0003271 6.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethenoxy-n,n-dimethyl-ethanamine" "2-(dimethylamino)ethyl vinyl ether" "vinyl-2-(n,n-dimethylamino)ethyl ether" "2-(vinyloxy)ethyldimethylamine" "ether, 2-(n,n-dimethylamino)ethyl vinyl" "ethylamine, n,n-dimethyl-2-(vinyloxy)- (6ci,7ci,8ci)" "1-dimethylamino-2-vinyloxyethan" "ether,n-dimethylamino)ethyl vinyl" "2-ethenoxy-n,n-dimethylethanamine" "[2-(ethenyloxy)ethyl]dimethylamine" "ethylamine,n-dimethyl-2-(vinyloxy)-" "ethylamine, n,n-dimethyl-2-(vinyloxy)-" );
gibbsFormation
{
    dHf_298   -106430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93260.0
    phase     gas;
}
