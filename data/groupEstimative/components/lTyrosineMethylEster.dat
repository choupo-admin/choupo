/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-tyrosine methyl ester  (C10H13NO3, CAS 1080-06-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lTyrosineMethylEster;
formula     C10H13NO3;
CAS         1080-06-4;
InChIKey    MWZPENIJLUWBSY-VIFPVBQESA-N;
MW          195.218;      // g/mol [origin=calculated method=formula-sum]
Tc          898.78;      // K   [origin=predictive method=joback]
Pc          37.730;      // bar [origin=predictive method=joback]
omega       0.9576;      // -   [origin=predictive method=lee-kesler]
Tb          666.01;      // K   [origin=predictive method=joback]
HvapTb      70804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.809 1.04252 -0.00075976 2.198e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CHNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (2s)-2-azanyl-3-(4-hydroxyphenyl)propanoate" "methyl l-tyrosinate" "h-tyr-ome" "tyrosine methyl ester" "methyl (2s)-2-amino-3-(4-hydroxyphenyl)propanoate" "l-tyrosine-methyl-ester" "(s)-methyl 2-amino-3-(4-hydroxyphenyl)propanoate" "(s)-2-amino-3-(4-hydroxy-phenyl)-propionic acid methyl ester" "tyrosine,methyl ester, l- (6ci,8ci);(s)-2-amino-3-(4-hydroxyphenyl)propionic acidmethyl ester;methyl (2s)-2-amino-3-(4-hydroxyphenyl)propionate;methyl(2s)-3-(4-hydroxyphenyl)-2-aminopropionate;methyltyrosinate;tyrosine methyl ester;l-tyrosine methyl ester;h-tyr-ome;l-tyrosine, methyl ester;methyl l-tyrosinate;tyrosine, methyl ester, l-;" );
standardThermochemistry
{
    dHf_298   -479280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255250.0
}
