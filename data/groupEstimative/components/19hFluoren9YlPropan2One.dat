/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(9h-fluoren-9-yl)propan-2-one  (C16H14O, CAS 2470-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        19hFluoren9YlPropan2One;
formula     C16H14O;
CAS         2470-85-1;
InChIKey    CBBTUJNXYWEYBX-UHFFFAOYSA-N;
MW          222.287;      // g/mol [origin=calculated method=formula-sum]
Tc          919.92;      // K   [origin=predictive method=joback]
Pc          25.533;      // bar [origin=predictive method=joback]
omega       0.7351;      // -   [origin=predictive method=lee-kesler]
Tb          681.07;      // K   [origin=predictive method=joback]
HvapTb      63401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.509 1.38912 -0.00106922 3.3046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propanone, 1-fluoren-9-yl-" "2-propanone, 1-fluoren-9-yl-," );
standardThermochemistry
{
    dHf_298   49090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=245430.0
}
