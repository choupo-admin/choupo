/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(prop-2-enoxymethyl)thiirane  (C6H10OS, CAS 2422-95-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Prop2EnoxymethylThiirane;
formula     C6H10OS;
CAS         2422-95-9;
InChIKey    MRACUOGDIPTXDJ-UHFFFAOYSA-N;
MW          130.205;      // g/mol [origin=calculated method=formula-sum]
Tc          610.29;      // K   [origin=predictive method=joback]
Pc          36.955;      // bar [origin=predictive method=joback]
omega       0.3676;      // -   [origin=predictive method=lee-kesler]
Tb          410.55;      // K   [origin=predictive method=joback]
HvapTb      36415.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.478 0.65591 -0.0004534 1.309e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2O; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group O; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -55900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83090.0
}
