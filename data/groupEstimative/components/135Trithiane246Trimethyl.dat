/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-trithiane, 2,4,6-trimethyl-  (C6H12S3, CAS 2765-04-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Trithiane246Trimethyl;
formula     C6H12S3;
CAS         2765-04-0;
InChIKey    XQVYLDFSPBXACS-UHFFFAOYSA-N;
MW          180.342;      // g/mol [origin=calculated method=formula-sum]
Tc          745.02;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       0.2696;      // -   [origin=predictive method=lee-kesler]
Tb          490.58;      // K   [origin=predictive method=joback]
HvapTb      46197.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.17 0.68619 -0.0003289 3.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CHS; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH_ring; count 3; } { group S_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-trimethyl-1,3,5-trithiane" "s-trithiane, 2,4,6-trimethyl-" "1,3,5-trithiane, 2,4,6-trimethyl, #1" "1,3,5-trithiane, 2,4,6-trimethyl, #2" "trithioacetaldehyde" "thioacetaldehyde trimer" "beta-trithioacetaldehyde" "1,5-trimethyl-s-trithiane" "2,6-trimethyl-s-trithiane" "s-trithiane,4,6-trimethyl-" "thioacetaldehyde beta-form [mi]" "2,6-trimethyl-1,3,5-trithiane" );
standardThermochemistry
{
    dHf_298   -17750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128250.0
}
