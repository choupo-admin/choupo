/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dihydroxybenzamide  (C7H7NO3, CAS 52405-73-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dihydroxybenzamide;
formula     C7H7NO3;
CAS         52405-73-9;
InChIKey    FRXZIFVYTNMCHF-UHFFFAOYSA-N;
MW          153.137;      // g/mol [origin=calculated method=formula-sum]
Tc          931.10;      // K   [origin=predictive method=joback]
Pc          76.812;      // bar [origin=predictive method=joback]
omega       1.1360;      // -   [origin=predictive method=lee-kesler]
Tb          674.08;      // K   [origin=predictive method=joback]
HvapTb      76867.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.37 0.933 -0.00092562 3.6576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 2; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis(oxidanyl)benzamide" "gentisamide" "salicylamide, 5-hydroxy-" "5-hydroxysalicylamide" "benzamide, 2,5-dihydroxy-" "benzamide,2,5-dihydroxy-" "gentisamide(6ci,7ci); 2,5-dihydroxybenzamide; gentisicamide" );
gibbsFormation
{
    dHf_298   -384690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-251240.0
    phase     gas;
}
