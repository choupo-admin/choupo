/*--------------------------------*- Choupo -*-----------------------*\
  Component: (methylthio)ethene  (C3H6S, CAS 1822-74-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylthioEthene;
formula     C3H6S;
CAS         1822-74-8;
InChIKey    AMBKPYJJYUKNFI-UHFFFAOYSA-N;
MW          74.141;      // g/mol [origin=calculated method=formula-sum]
Tc          529.75;      // K   [origin=predictive method=joback]
Pc          47.760;      // bar [origin=predictive method=joback]
omega       0.2084;      // -   [origin=predictive method=lee-kesler]
Tb          333.70;      // K   [origin=predictive method=joback]
HvapTb      28419.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.77 0.26321 -0.0001221 1.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylsulfanylethene" "methyl vinyl sulfide" "ethene, (methylthio)-" "ethene, (methylthio)-(9ci)" "sulfide,methyl vinyl (6ci,7ci,8ci); ethene, (methylthio)-, inner salt; methyl vinylsulfide; methylthioethylene; vinyl methyl sulfide" );
gibbsFormation
{
    dHf_298   62050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     329.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95340.0
    phase     gas;
}
