/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-decyn-1-ol  (C10H18O, CAS 17643-36-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Decyn1Ol;
formula     C10H18O;
CAS         17643-36-6;
InChIKey    KOAOUMQUUZNRLL-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          678.18;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.8909;      // -   [origin=predictive method=lee-kesler]
Tb          510.70;      // K   [origin=predictive method=joback]
HvapTb      54391.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.868 0.8939 -0.00054653 1.3599e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dec-9-yn-1-ol" "10-hydroxy-1-decyne" );
gibbsFormation
{
    dHf_298   -110060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=119570.0
    phase     gas;
}
