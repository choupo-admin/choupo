/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl-1-cyclohexene  (C12H14, CAS 771-98-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyl1Cyclohexene;
formula     C12H14;
CAS         771-98-2;
InChIKey    WCMSFBRREKZZFL-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          773.91;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.3792;      // -   [origin=predictive method=lee-kesler]
Tb          529.20;      // K   [origin=predictive method=joback]
HvapTb      46274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.39 1.098 -0.00071684 1.742e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexen-1-ylbenzene" "1-phenylcyclohexene" "benzene, 1-cyclohexen-1-yl-" "benzene, cyclohexenyl-" "cyclohexene, 1-phenyl-" "phenylcyclohexene" "cyclohexenylbenzene" "1-cyclohexenylbenzene" "1-phenylcyclohex-1-ene" "trans-1-phenylcyclohexene" "cyclohex-1-enylbenzene" "1-cyclohexenyl-benzene" );
standardThermochemistry
{
    dHf_298   66490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=215060.0
}
