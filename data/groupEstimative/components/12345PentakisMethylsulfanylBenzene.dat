/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4,5-pentakis(methylsulfanyl)benzene  (C11H16S5, CAS 65516-74-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12345PentakisMethylsulfanylBenzene;
formula     C11H16S5;
CAS         65516-74-7;
InChIKey    SYAFJBVKTONLAY-UHFFFAOYSA-N;
MW          308.549;      // g/mol [origin=calculated method=formula-sum]
Tc          1133.88;      // K   [origin=predictive method=joback]
Pc          27.183;      // bar [origin=predictive method=joback]
omega       0.7901;      // -   [origin=predictive method=lee-kesler]
Tb          841.78;      // K   [origin=predictive method=joback]
HvapTb      79089.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (114.18 0.70395 -0.00013664 -9.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 5; } { group CH3S; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group S; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentakis(methylthio)benzene" "1,2,3,4,5-penta(methylthio)benzene" );
standardThermochemistry
{
    dHf_298   129630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     760.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=281230.0
}
