/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentafluoropropionic acid, octyl ester  (C11H17F5O2, CAS 1867-95-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentafluoropropionicAcidOctylEster;
formula     C11H17F5O2;
CAS         1867-95-4;
InChIKey    ZPVRQKZQZAFDCY-UHFFFAOYSA-N;
MW          276.245;      // g/mol [origin=calculated method=formula-sum]
Tc          649.57;      // K   [origin=predictive method=joback]
Pc          16.578;      // bar [origin=predictive method=joback]
omega       0.7665;      // -   [origin=predictive method=lee-kesler]
Tb          499.39;      // K   [origin=predictive method=joback]
HvapTb      40810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.193 1.30462 -0.0009056 2.344e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CF3; count 1; } { group CF2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group C; count 2; } { group F; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octyl 2,2,3,3,3-pentakis(fluoranyl)propanoate" "octyl 2,2,3,3,3-pentafluoropropanoate" "octyl pentafluoropropionate" );
gibbsFormation
{
    dHf_298   -1585700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     716.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1237000.0
    phase     gas;
}
