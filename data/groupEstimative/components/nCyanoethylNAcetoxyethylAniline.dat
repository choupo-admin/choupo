/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-cyanoethyl-n-acetoxyethyl aniline  (C13H16N2O2, CAS 22031-33-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nCyanoethylNAcetoxyethylAniline;
formula     C13H16N2O2;
CAS         22031-33-0;
InChIKey    RRGWFPOSTSQIQE-UHFFFAOYSA-N;
MW          232.283;      // g/mol [origin=calculated method=formula-sum]
Tc          907.89;      // K   [origin=predictive method=joback]
Pc          21.493;      // bar [origin=predictive method=joback]
omega       0.9174;      // -   [origin=predictive method=lee-kesler]
Tb          696.46;      // K   [origin=predictive method=joback]
HvapTb      66736.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.116 1.16382 -0.0007016 1.43e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH3COO; count 1; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-cyanoethyl(phenyl)amino]ethyl ethanoate" "2-(n-(2-cyanoethyl)anilino)ethyl acetate" "2-[(2-cyanoethyl)(phenyl)amino]ethyl acetate" "n-acetoxyethyl-n-cyanoethylaniline" "aniline, n-acetoxyethyl-n-cyanoethyl-" "3-((2-(acetyloxy)ethyl)phenylamino)propanenitrile" "propanenitrile, 3-((2-(acetyloxy)ethyl)phenylamino)-" "propanenitrile, 3-[[2-(acetyloxy)ethyl]phenylamino]-" "propionitrile, 3-(n-(2-hydroxyethyl)anilino)-, acetate (ester)" "2-[n-(2-cyanoethyl)anilino]ethyl acetate" "2-((2-cyanoethyl)(phenyl)amino)ethyl acetate" "m746" );
gibbsFormation
{
    dHf_298   -159990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     629.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104580.0
    phase     gas;
}
