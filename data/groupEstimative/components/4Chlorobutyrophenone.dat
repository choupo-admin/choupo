/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorobutyrophenone  (C10H11ClO, CAS 939-52-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chlorobutyrophenone;
formula     C10H11ClO;
CAS         939-52-6;
InChIKey    GHEFQKHLHFXSBR-UHFFFAOYSA-N;
MW          182.647;      // g/mol [origin=calculated method=formula-sum]
Tc          766.18;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       0.5760;      // -   [origin=predictive method=lee-kesler]
Tb          546.38;      // K   [origin=predictive method=joback]
HvapTb      51261.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.857 0.8537 -0.0005531 1.3326e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-1-phenyl-butan-1-one" "4-chloro-1-phenylbutan-1-one" "gamma-chlorobutyrophenone" ".gamma.-chlorobutyrophenone" "4-chloro-1-oxo-1-phenylbutane" "4-chloro-1-phenyl-1-butanone" "1-butanone, 4-chloro-1-phenyl-" );
gibbsFormation
{
    dHf_298   -141520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4880.0
    phase     gas;
}
