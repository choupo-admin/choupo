/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[(2,7,7-trimethylbicyclo[2.2.1]hept-1-yl)methyl]cyclohexanone  (C17H28O, CAS 68036-94-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2277Trimethylbicyclo221Hept1YlMethylCyclohexanone;
formula     C17H28O;
CAS         68036-94-2;
InChIKey    BZMLQIXBJWHOFE-UHFFFAOYSA-N;
MW          248.41;      // g/mol [origin=calculated method=formula-sum]
Tc          925.96;      // K   [origin=predictive method=joback]
Pc          18.887;      // bar [origin=predictive method=joback]
omega       0.5623;      // -   [origin=predictive method=lee-kesler]
Tb          684.82;      // K   [origin=predictive method=joback]
HvapTb      55190.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-235.449 2.39566 -0.0020864 7.96e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 3; } { group C; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 3; } { group C_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(3,7,7-trimethyl-4-bicyclo[2.2.1]heptanyl)methyl]cyclohexan-1-one" "bornyl-2-methylcyclohexanone" "cyclohexanone, 2-methyl(1,7,7-trimethylbicyclo(2.2.1)heptyl)-" "cyclohexanone, 2-methyl(1,7,7-trimethylbicyclo[2.2.1]heptyl)-" "2-methyl(1,7,7-trimethylbicyclo(2.2.1)heptyl)cyclohexan-1-one" );
standardThermochemistry
{
    dHf_298   -348350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77120.0
}
