/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-azabicyclo[2.2.2]octane  (C7H13N, CAS 280-38-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Azabicyclo222Octane;
formula     C7H13N;
CAS         280-38-6;
InChIKey    KPUSZZFAYGWAHZ-UHFFFAOYSA-N;
MW          111.188;      // g/mol [origin=calculated method=formula-sum]
Tc          651.32;      // K   [origin=predictive method=joback]
Pc          41.356;      // bar [origin=predictive method=joback]
omega       0.3332;      // -   [origin=predictive method=lee-kesler]
Tb          430.33;      // K   [origin=predictive method=joback]
HvapTb      38104.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.28 0.938 -0.000644 1.78e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azabicyclo[2.2.2]octane" "isoquinuclidine" "2-azabicyclo(2.2.2)octane" "8-azabicyclo[2.2.2]octa-1,3,5-triene" );
gibbsFormation
{
    dHf_298   -16720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     281.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=193070.0
    phase     gas;
}
