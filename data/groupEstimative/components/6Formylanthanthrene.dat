/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-formylanthanthrene  (C23H12O, CAS 63040-55-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C23H12O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        6Formylanthanthrene;
formula     C23H12O;
CAS         63040-55-1;
InChIKey    PYWOIXYGKFRHKF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          304.348;      // g/mol [origin=calculated method=formula-sum]
Tc          1094.22;      // K   [origin=predictive method=joback]
Pc          23.270;      // bar [origin=predictive method=joback]
omega       0.9043;      // -   [origin=predictive method=lee-kesler]
Tb          833.34;      // K   [origin=predictive method=joback]
HvapTb      76933.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-152.22 1.9524 -0.00197104 7.769e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 11; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 11; } { group dC_ring; count 11; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibenzo(def,mno)chrysene-12-carboxaldehyde" );
standardThermochemistry
{
    dHf_298   602010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=772730.0
}
