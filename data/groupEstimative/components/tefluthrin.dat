/*--------------------------------*- Choupo -*-----------------------*\
  Component: tefluthrin  (C17H14ClF7O2, CAS 79538-32-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tefluthrin;
formula     C17H14ClF7O2;
CAS         79538-32-2;
InChIKey    ZFHGXWPMULPQSE-UHFFFAOYSA-N;
MW          418.733;      // g/mol [origin=calculated method=formula-sum]
Tc          914.38;      // K   [origin=predictive method=joback]
Pc          13.166;      // bar [origin=predictive method=joback]
omega       0.9381;      // -   [origin=predictive method=lee-kesler]
Tb          729.13;      // K   [origin=predictive method=joback]
HvapTb      61981.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.739 1.81256 -0.0015375 5.452e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group Cl_C=C_; count 1; } { group ACF; count 4; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dC_ring; count 6; } { group F; count 7; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,3,5,6-tetrakis(fluoranyl)-4-methyl-phenyl]methyl 3-[2-chloranyl-3,3,3-tris(fluoranyl)prop-1-enyl]-2,2-dimethyl-cyclopropane-1-carboxylate" "(2,3,5,6-tetrafluoro-4-methylphenyl)methyl 3-(2-chloro-3,3,3-trifluoroprop-1-enyl)-2,2-dimethylcyclopropane-1-carboxylate" "cyclopropanecarboxylic acid, 3-[(1z)-2-chloro-3,3,3-trifluoro-1-propenyl]-2,2-dimethyl-, (2,3,5,6-tetrafluoro-4-methylphenyl)methyl ester, (1r,3r)-rel-" "(2,3,5,6-tetrafluoro-4-methylphenyl)methyl (1r,3r)-3-[(z)-2-chloro-3,3,3-trifluoroprop-1-enyl]-2,2-dimethylcyclopropane-1-carboxylate" );
standardThermochemistry
{
    dHf_298   -1774780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     832.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1415100.0
}
