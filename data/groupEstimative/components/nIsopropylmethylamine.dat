/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-isopropylmethylamine  (C4H11N, CAS 4747-21-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nIsopropylmethylamine;
formula     C4H11N;
CAS         4747-21-1;
InChIKey    XHFGWHUWQXTGAT-UHFFFAOYSA-N;
MW          73.139;      // g/mol [origin=calculated method=formula-sum]
Tc          515.40;      // K   [origin=predictive method=joback]
Pc          40.007;      // bar [origin=predictive method=joback]
omega       0.3255;      // -   [origin=predictive method=lee-kesler]
Tb          340.85;      // K   [origin=predictive method=joback]
HvapTb      30546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.64 0.46596 -0.0002456 4.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methylpropan-2-amine" "n-methylisopropylamine" "2-propanamine, n-methyl-" "2-methylaminopropane" "methylisopropylamine" "n-methylisopropyylamine" "ethylamine, n,1-dimethyl-" "ethylamine,1-dimethyl-" "agn-pc-0d5wdx" "methyl(propan-2-yl)amine" "2-propanamine, n-methyl- (9ci)" "ethylamine, n,1-dimethyl- (8ci)" );
standardThermochemistry
{
    dHf_298   -77700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69750.0
}
