/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclopropylethanol  (C5H10O, CAS 765-42-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclopropylethanol;
formula     C5H10O;
CAS         765-42-4;
InChIKey    DKKVKJZXOBFLRY-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          591.54;      // K   [origin=predictive method=joback]
Pc          46.403;      // bar [origin=predictive method=joback]
omega       0.6382;      // -   [origin=predictive method=lee-kesler]
Tb          412.48;      // K   [origin=predictive method=joback]
HvapTb      42928.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.29 0.66962 -0.000502 1.569e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropyl methyl carbinol" "cyclopropylmethylcarbinol" "methylcyclopropylcarbinol" "alpha-methylcyclopropanemethanol" "cyclopropanemethanol, .alpha.-methyl-" "(r)-1-cyclopropylethanol" "1-cyclopropylethan-1-ol" "agn-pc-00porw" "(1s)-1-cyclopropylethanol" "cyclopropanemethanol, a-methyl-" "(s)-1-cyclopropylethanol" "cyclopropanemethanol, alpha-methyl-" );
gibbsFormation
{
    dHf_298   -231240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     301.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87290.0
    phase     gas;
}
