/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl methyl sulfide  (C3H8S, CAS 624-89-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylMethylSulfide;
formula     C3H8S;
CAS         624-89-5;
InChIKey    WXEHBUMAEPOYKP-UHFFFAOYSA-N;
MW          76.157;      // g/mol [origin=calculated method=formula-sum]
Tc          528.70;      // K   [origin=predictive method=joback]
Pc          45.104;      // bar [origin=predictive method=joback]
omega       0.2301;      // -   [origin=predictive method=lee-kesler]
Tb          337.02;      // K   [origin=predictive method=joback]
HvapTb      29089.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.761 0.28323 -9.92e-05 -3.1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylsulfanylethane" "(methylsulfanyl)ethane" "(methylthio)ethane" "1-(methylthio)ethane" "2-thiabutane" "Ethane, (methylthio)-" "ethyl methyl thioether" "methyl ethyl sulfide" "sulfide, ethyl methyl" "methylthioethane" "ethyl methyl sulphide" "methyl ethyl sulphide" );
gibbsFormation
{
    dHf_298   -63380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=7500.0
    phase     gas;
}
