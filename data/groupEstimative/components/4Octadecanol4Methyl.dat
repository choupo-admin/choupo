/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-octadecanol, 4-methyl-  (C19H40O, CAS 54892-13-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Octadecanol4Methyl;
formula     C19H40O;
CAS         54892-13-6;
InChIKey    VMTGGTJUJCMQNI-UHFFFAOYSA-N;
MW          284.528;      // g/mol [origin=calculated method=formula-sum]
Tc          891.77;      // K   [origin=predictive method=joback]
Pc          11.640;      // bar [origin=predictive method=joback]
omega       1.0216;      // -   [origin=predictive method=lee-kesler]
Tb          723.27;      // K   [origin=predictive method=joback]
HvapTb      73271.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.565 1.96866 -0.001212 2.966e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 15; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 15; } { group C; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyloctadecan-4-ol" );
gibbsFormation
{
    dHf_298   -596470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     908.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-24880.0
    phase     gas;
}
