/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiophene, 2-isopropyl-  (C7H10S, CAS 4095-22-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiophene2Isopropyl;
formula     C7H10S;
CAS         4095-22-1;
InChIKey    LOXBELRNKUFSRD-UHFFFAOYSA-N;
MW          126.217;      // g/mol [origin=calculated method=formula-sum]
Tc          652.99;      // K   [origin=predictive method=joback]
Pc          38.198;      // bar [origin=predictive method=joback]
omega       0.2963;      // -   [origin=predictive method=lee-kesler]
Tb          430.40;      // K   [origin=predictive method=joback]
HvapTb      38412.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.9 0.67585 -0.00046922 1.316e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-ylthiophene" "thiophene, 2-(1-methylethyl)-" "2-isopropylthiophene" "2-(propan-2-yl)thiophene" "thiophene, (1-methylethyl)-" );
gibbsFormation
{
    dHf_298   37080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140030.0
    phase     gas;
}
