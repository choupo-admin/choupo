/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1265551  (C19H30N2O4, CAS 60012-89-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1265551;
formula     C19H30N2O4;
CAS         60012-89-7;
InChIKey    JBKOKMWDZHOUNO-UHFFFAOYSA-N;
MW          350.459;      // g/mol [origin=calculated method=formula-sum]
Tc          1039.41;      // K   [origin=predictive method=joback]
Pc          17.909;      // bar [origin=predictive method=joback]
omega       1.0671;      // -   [origin=predictive method=lee-kesler]
Tb          820.32;      // K   [origin=predictive method=joback]
HvapTb      76114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-257.208 2.8402 -0.0023754 8.092e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH; count 2; } { group C; count 1; } { group CH2N; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 12; } { group CH_ring; count 2; } { group C_ring; count 1; } { group COO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,8-bis(piperidin-1-ylmethyl)-2,7-dioxaspiro[4.4]nonane-1,6-dione" "2,7-dioxaspiro(4.4)nonane-1,6-dione, 3,8-bis(1-piperidinylmethyl)-" "2,7-bis(piperidin-1-ylmethyl)-3,8-dioxaspiro[4.4]nonane-4,9-dione" );
gibbsFormation
{
    dHf_298   -626690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     841.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-81160.0
    phase     gas;
}
