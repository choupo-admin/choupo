/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butene, 2-bromo-  (C4H7Br, CAS 23074-36-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butene2Bromo;
formula     C4H7Br;
CAS         23074-36-4;
InChIKey    HQMXRIGBXOFKIU-UHFFFAOYSA-N;
MW          135.004;      // g/mol [origin=calculated method=formula-sum]
Tc          547.68;      // K   [origin=predictive method=joback]
Pc          45.286;      // bar [origin=predictive method=joback]
omega       0.2782;      // -   [origin=predictive method=lee-kesler]
Tb          353.84;      // K   [origin=predictive method=joback]
HvapTb      30343.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.761 0.40192 -0.0002904 8.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylbut-1-ene" "2-bromo-1-butene" "2-bromobut-1-ene" "sjphabimsp@" "2-bromo-1-butene;2-bromobutene;" );
gibbsFormation
{
    dHf_298   16080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     354.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76410.0
    phase     gas;
}
