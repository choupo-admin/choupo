/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1-trifluorotrimethylamine  (C3H6F3N, CAS 677-41-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Trifluorotrimethylamine;
formula     C3H6F3N;
CAS         677-41-8;
InChIKey    JJKSAGOTPUEJKD-UHFFFAOYSA-N;
MW          113.082;      // g/mol [origin=calculated method=formula-sum]
Tc          417.77;      // K   [origin=predictive method=joback]
Pc          37.916;      // bar [origin=predictive method=joback]
omega       0.2923;      // -   [origin=predictive method=lee-kesler]
Tb          275.26;      // K   [origin=predictive method=joback]
HvapTb      20568.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.73 0.57394 -0.000473 1.506e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH3N; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group F; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(fluoranyl)-n,n-dimethyl-methanamine" "1,1,1-trifluoro-n,n-dimethylmethanamine" "cf3n(ch3)2" "1,1,1-trifluoro-n,n-dimethyl-methanamine" );
standardThermochemistry
{
    dHf_298   -634800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     345.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-496430.0
}
