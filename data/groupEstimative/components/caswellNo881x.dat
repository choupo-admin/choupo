/*--------------------------------*- Choupo -*-----------------------*\
  Component: caswell no. 881x  (C10H9Cl3O3, CAS 93-80-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        caswellNo881x;
formula     C10H9Cl3O3;
CAS         93-80-1;
InChIKey    RTWCZQFXFMXXKP-UHFFFAOYSA-N;
MW          283.529;      // g/mol [origin=calculated method=formula-sum]
Tc          979.08;      // K   [origin=predictive method=joback]
Pc          26.819;      // bar [origin=predictive method=joback]
omega       1.0507;      // -   [origin=predictive method=lee-kesler]
Tb          750.24;      // K   [origin=predictive method=joback]
HvapTb      74845.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.563 0.7044 -0.00037308 5.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 2; } { group AC; count 1; } { group CH2O; count 1; } { group COOH; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2,4,5-tris(chloranyl)phenoxy]butanoic acid" "butanoic acid, 4-(2,4,5-trichlorophenoxy)-" "butyric acid, 4-(2,4,5-trichlorophenoxy)-" "2,4,5-t butyric acid" "2,4,5-tb" "2,4,5-tb [iso]" "4-(2,4,5-trichlorophenoxy)butanoic acid" "gamma-(2,4,5-trichlorophenoxy)butyric acid" "2,5-t butyric acid" "2,5-tb" "butyric acid,4,5-trichlorophenoxy)-" "4-(2,5-trichlorophenoxy)butyric acid" );
gibbsFormation
{
    dHf_298   -577320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-367860.0
    phase     gas;
}
