/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dihydro-2-thiaphenalene  (C12H10S, CAS 203-85-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dihydro2Thiaphenalene;
formula     C12H10S;
CAS         203-85-0;
InChIKey    PIUJLKSYKOKWMI-UHFFFAOYSA-N;
MW          186.272;      // g/mol [origin=calculated method=formula-sum]
Tc          851.99;      // K   [origin=predictive method=joback]
Pc          35.986;      // bar [origin=predictive method=joback]
omega       0.4849;      // -   [origin=predictive method=lee-kesler]
Tb          589.02;      // K   [origin=predictive method=joback]
HvapTb      53580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.13 1.13401 -0.00095714 3.247e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h,3h-naphtho[1,8-cd]thiopyran" "1h,3h-naphtho(1,8-cd)thiopyran" "1h,8-cd]thiopyran" );
gibbsFormation
{
    dHf_298   252050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=358280.0
    phase     gas;
}
