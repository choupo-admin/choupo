/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenedioic acid (2z)-, diisononyl ester  (C22H40O4, CAS 53817-54-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenedioicAcid2zDiisononylEster;
formula     C22H40O4;
CAS         53817-54-2;
InChIKey    CBWMVXMQKDYZDQ-UHFFFAOYSA-N;
MW          368.558;      // g/mol [origin=calculated method=formula-sum]
Tc          1009.64;      // K   [origin=predictive method=joback]
Pc          9.456;      // bar [origin=predictive method=joback]
omega       0.8903;      // -   [origin=predictive method=lee-kesler]
Tb          822.68;      // K   [origin=predictive method=joback]
HvapTb      78562.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.162 2.01608 -0.001074 1.828e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(7-methyloctyl) but-2-enedioate" "2-butenedioic acid (2z)-, 1,4-diisononyl ester" );
gibbsFormation
{
    dHf_298   -1025310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1089.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-411040.0
    phase     gas;
}
