/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentenyl radical  (C5H7, CAS 10577-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        cyclopentenylRadical;
formula     C5H7;
CAS         10577-65-8;
InChIKey    MNLVCBKWEVXHGE-UHFFFAOYSA-N;
role        radical;
MW          67.111;      // g/mol [origin=calculated method=formula-sum]
Tc          532.26;      // K   [origin=predictive method=joback]
Pc          48.834;      // bar [origin=predictive method=joback]
omega       0.1904;      // -   [origin=predictive method=lee-kesler]
Tb          332.69;      // K   [origin=predictive method=joback]
HvapTb      27728.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.41 0.553 -0.00041192 1.223e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentene" "cyclopentenyl" "2-cyclopentenyl" "4-cyclopentenyl" "cyclopenten-3-yl" "1-cyclopent-2-enyl" "cyclopent-2-en-1-yl" );
gibbsFormation
{
    dHf_298   20960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     286.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80420.0
    phase     gas;
}
