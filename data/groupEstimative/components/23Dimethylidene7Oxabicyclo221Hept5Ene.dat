/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethylidene-7-oxabicyclo[2.2.1]hept-5-ene  (C8H8O, CAS 56582-02-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethylidene7Oxabicyclo221Hept5Ene;
formula     C8H8O;
CAS         56582-02-6;
InChIKey    ZJMPPRPWOHELIB-UHFFFAOYSA-N;
MW          120.151;      // g/mol [origin=calculated method=formula-sum]
Tc          632.29;      // K   [origin=predictive method=joback]
Pc          37.362;      // bar [origin=predictive method=joback]
omega       0.3663;      // -   [origin=predictive method=lee-kesler]
Tb          424.82;      // K   [origin=predictive method=joback]
HvapTb      38520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.31 0.762 -0.00059398 1.9e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 1; } { group CH2=C; count 2; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-oxabicyclo(2.2.1)hept-2-ene, 5,6-bis(methylene)-" );
standardThermochemistry
{
    dHf_298   25250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     165.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175880.0
}
