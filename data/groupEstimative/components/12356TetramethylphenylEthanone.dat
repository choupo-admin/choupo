/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,3,5,6-tetramethylphenyl)ethanone  (C12H16O, CAS 2142-79-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12356TetramethylphenylEthanone;
formula     C12H16O;
CAS         2142-79-2;
InChIKey    JCNRSGPJXDRATR-UHFFFAOYSA-N;
MW          176.259;      // g/mol [origin=calculated method=formula-sum]
Tc          786.96;      // K   [origin=predictive method=joback]
Pc          24.124;      // bar [origin=predictive method=joback]
omega       0.6109;      // -   [origin=predictive method=lee-kesler]
Tb          574.63;      // K   [origin=predictive method=joback]
HvapTb      53976.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.63 0.799 -0.00037334 4.846e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 1; } { group ACCH3; count 4; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,5,6-tetramethylacetophenone" "2',3',5',6'-tetramethylacetophenone" "1-(2,3,5,6-tetramethylphenyl)ethan-1-one" "methyl duryl ketone" "2,5,6-tetramethylacetophenone" "2',5',6'-tetramethylacetophenone" "1,4,5-tetramethyl-3-acetylbenzene" "ethanone,3,5,6-tetramethylphenyl)-" "1-acetyl-2,3,5,6-tetramethylbenzene" "acetophenone,3',5',6'-tetramethyl-" "acetophenone, 2',3',5',6'-tetramethyl-" "ethanone, 1-(2,3,5,6-tetramethylphenyl)-" );
standardThermochemistry
{
    dHf_298   -212940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-4870.0
}
