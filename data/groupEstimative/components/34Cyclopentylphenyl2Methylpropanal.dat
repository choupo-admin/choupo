/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4-cyclopentylphenyl)-2-methylpropanal  (C15H20O, CAS 66867-37-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Cyclopentylphenyl2Methylpropanal;
formula     C15H20O;
CAS         66867-37-6;
InChIKey    JYUQMOHDWHFCAS-UHFFFAOYSA-N;
MW          216.324;      // g/mol [origin=calculated method=formula-sum]
Tc          865.02;      // K   [origin=predictive method=joback]
Pc          23.114;      // bar [origin=predictive method=joback]
omega       0.6538;      // -   [origin=predictive method=lee-kesler]
Tb          637.96;      // K   [origin=predictive method=joback]
HvapTb      58511.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.119 1.40252 -0.00087996 2.048e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-cyclopentylphenyl)-2-methyl-propanal" "p-cyclopentyl-alpha-methyldihydrocinnamic aldehyde" "benzenepropanal, 4-cyclopentyl-alpha-methyl-" "benzenepropanal, 4-cyclopentyl-.alpha.-methyl-" );
standardThermochemistry
{
    dHf_298   -158250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112790.0
}
