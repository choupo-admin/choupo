/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutene, 1,2-dimethyl-  (C6H10, CAS 1501-58-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobutene12Dimethyl;
formula     C6H10;
CAS         1501-58-2;
InChIKey    PUAKTHBSHFXVAG-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          554.54;      // K   [origin=predictive method=joback]
Pc          39.062;      // bar [origin=predictive method=joback]
omega       0.2643;      // -   [origin=predictive method=lee-kesler]
Tb          361.68;      // K   [origin=predictive method=joback]
HvapTb      30960.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.49 0.56664 -0.000385 1.122e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dimethylcyclobutene" );
gibbsFormation
{
    dHf_298   -45350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     312.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66700.0
    phase     gas;
}
