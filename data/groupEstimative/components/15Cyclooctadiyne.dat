/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-cyclooctadiyne  (C8H8, CAS 49852-40-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Cyclooctadiyne;
formula     C8H8;
CAS         49852-40-6;
InChIKey    URBAEOVIKFSRNB-UHFFFAOYSA-N;
MW          104.152;      // g/mol [origin=calculated method=formula-sum]
Tc          662.91;      // K   [origin=predictive method=joback]
Pc          45.777;      // bar [origin=predictive method=joback]
omega       0.1864;      // -   [origin=predictive method=lee-kesler]
Tb          416.32;      // K   [origin=predictive method=joback]
HvapTb      38100.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.57 0.632 -0.00045632 1.3956e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 4; } { group CH2_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloocta-1,5-diyne" );
gibbsFormation
{
    dHf_298   423130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=478440.0
    phase     gas;
}
