/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, polymer with butyl 2-propenoate and 1,2-cyclohexanediamine  (C16H30N2O4, CAS 72089-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcidPolymerWithButyl2PropenoateAnd12Cyclohexanedia;
formula     C16H30N2O4;
CAS         72089-00-0;
InChIKey    KRQBZJVFEBOOHV-UHFFFAOYSA-N;
MW          314.426;      // g/mol [origin=calculated method=formula-sum]
Tc          1154.50;      // K   [origin=predictive method=joback]
Pc          16.444;      // bar [origin=predictive method=joback]
omega       1.1765;      // -   [origin=predictive method=lee-kesler]
Tb          925.51;      // K   [origin=predictive method=joback]
HvapTb      96431.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.323 1.28682 -0.0001532 -2.461e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2=CH; count 2; } { group CHNH2; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate;cyclohexane-1,2-diamine;prop-2-enoic acid" "butyl acrylate, acrylic acid, 1,2-diaminocyclohexane polymer" );
gibbsFormation
{
    dHf_298   -911940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1120.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-454640.0
    phase     gas;
}
