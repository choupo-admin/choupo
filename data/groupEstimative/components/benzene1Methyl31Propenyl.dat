/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-methyl-3-(1-propenyl)-  (C10H12, CAS 17271-70-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1Methyl31Propenyl;
formula     C10H12;
CAS         17271-70-4;
InChIKey    UUOANSACYXAAOU-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          680.63;      // K   [origin=predictive method=joback]
Pc          30.524;      // bar [origin=predictive method=joback]
omega       0.3546;      // -   [origin=predictive method=lee-kesler]
Tb          464.22;      // K   [origin=predictive method=joback]
HvapTb      40750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.99 0.83544 -0.00056816 1.558e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3-prop-1-enyl-benzene" "agn-pc-0ckfmb" "1-[(z)-1-propenyl]-3-methylbenzene" );
standardThermochemistry
{
    dHf_298   92550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=216320.0
}
