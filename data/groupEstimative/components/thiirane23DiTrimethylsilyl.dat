/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiirane, 2,3-di(trimethylsilyl)-  (C8H20SSi2, CAS 114693-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H20SSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        thiirane23DiTrimethylsilyl;
formula     C8H20SSi2;
CAS         114693-66-2;
InChIKey    SEYGWXIPNFSGOI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          204.478;      // g/mol [origin=calculated method=formula-sum]
Tc          641.41;      // K   [origin=predictive method=joback]
Pc          21.938;      // bar [origin=predictive method=joback]
omega       0.2063;      // -   [origin=predictive method=lee-kesler]
Tb          435.34;      // K   [origin=predictive method=joback]
HvapTb      39406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.77 0.49033 0.0002347 -2.705e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH; count 1; } { group Si; count 2; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-(3-trimethylsilylthiiran-2-yl)silane" "thiirane,2,3-bis(trimethylsilyl)-, (2r,3r)-rel-" "silane,2,3-thiiranediylbis[trimethyl-, trans- (9ci); silane,2,3-thiiranediylbis[trimethyl-, trans-(?a'a a'a currency)-; thiirane, silane deriv." );
gibbsFormation
{
    dHf_298   -333970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-100140.0
    phase     gas;
}
