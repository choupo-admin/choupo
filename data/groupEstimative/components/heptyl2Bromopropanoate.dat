/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptyl 2-bromopropanoate  (C10H19BrO2, CAS 38674-99-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptyl2Bromopropanoate;
formula     C10H19BrO2;
CAS         38674-99-6;
InChIKey    XOLHAEPYINTAFR-UHFFFAOYSA-N;
MW          251.164;      // g/mol [origin=calculated method=formula-sum]
Tc          738.83;      // K   [origin=predictive method=joback]
Pc          22.762;      // bar [origin=predictive method=joback]
omega       0.7418;      // -   [origin=predictive method=lee-kesler]
Tb          552.34;      // K   [origin=predictive method=joback]
HvapTb      51308.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.716 0.94314 -0.0005002 8.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptyl 2-bromanylpropanoate" "2- bromopropionic acid, heptyl ester" "propanoic acid, 2-bromo-, heptyl ester" );
standardThermochemistry
{
    dHf_298   -545960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-265170.0
}
