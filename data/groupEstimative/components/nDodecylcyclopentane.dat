/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-dodecylcyclopentane  (C17H34, CAS 5634-30-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nDodecylcyclopentane;
formula     C17H34;
CAS         5634-30-0;
InChIKey    UFGYKQGTOYNLLD-UHFFFAOYSA-N;
MW          238.459;      // g/mol [origin=calculated method=formula-sum]
Tc          780.74;      // K   [origin=predictive method=joback]
Pc          14.027;      // bar [origin=predictive method=joback]
omega       0.7041;      // -   [origin=predictive method=lee-kesler]
Tb          603.84;      // K   [origin=predictive method=joback]
HvapTb      53693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.049 1.75052 -0.0010284 2.306e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group CH2_ring; count 4; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecylcyclopentane" "cyclopentane, dodecyl-" "dodecane,1-cyclopentyl- (6ci,8ci); 1-cyclopentyldodecane; dodecylcyclopentane;n-dodecylcyclopentane" );
gibbsFormation
{
    dHf_298   -333730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     767.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128810.0
    phase     gas;
}
