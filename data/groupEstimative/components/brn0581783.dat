/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 0581783  (C23H30N2O3, CAS 6442-00-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn0581783;
formula     C23H30N2O3;
CAS         6442-00-8;
InChIKey    PIJNJERADPPXJC-UHFFFAOYSA-N;
MW          382.504;      // g/mol [origin=calculated method=formula-sum]
Tc          1195.29;      // K   [origin=predictive method=joback]
Pc          16.103;      // bar [origin=predictive method=joback]
omega       1.3191;      // -   [origin=predictive method=lee-kesler]
Tb          970.46;      // K   [origin=predictive method=joback]
HvapTb      98217.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.488 2.26114 -0.00150552 3.832e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3O; count 1; } { group CH2N; count 2; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-methoxy-4-prop-1-enyl-phenoxy)-3-(4-phenylpiperazin-1-yl)propan-2-ol" "2-propanol, 1-(2-methoxy-4-propenylphenoxy)-3-(4-phenylpiperazinyl)-" "1-(3-methoxy-4-prop-1-enylphenoxy)-3-(4-phenylpiperazin-1-yl)propan-2-ol" );
standardThermochemistry
{
    dHf_298   -150620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     888.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=357220.0
}
