/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethanolamine phenolate  (C10H17NO3, CAS 64601-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethanolaminePhenolate;
formula     C10H17NO3;
CAS         64601-03-2;
InChIKey    LKLAJENPSUIEBH-UHFFFAOYSA-N;
MW          199.25;      // g/mol [origin=calculated method=formula-sum]
Tc          965.15;      // K   [origin=predictive method=joback]
Pc          40.364;      // bar [origin=predictive method=joback]
omega       1.7700;      // -   [origin=predictive method=lee-kesler]
Tb          766.65;      // K   [origin=predictive method=joback]
HvapTb      92570.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.136 1.027 -0.0005694 1.042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group OH; count 2; } { group ACOH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } { group OH_phenol; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyethylamino)ethanol;phenol" "2-(2-hydroxyethylamino)ethanol; phenol" "phenol, compd. with 2,2'-iminobis(ethanol) (1:1)" "phenol, compound with 2,2'-iminobis(ethanol) (1:1)" );
standardThermochemistry
{
    dHf_298   -541650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-288270.0
}
