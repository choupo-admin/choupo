/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,5-trimethylcyclohexyl phenylacetate  (C17H24O2, CAS 67859-97-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        335TrimethylcyclohexylPhenylacetate;
formula     C17H24O2;
CAS         67859-97-6;
InChIKey    JJRRLZZVCHJDHV-UHFFFAOYSA-N;
MW          260.377;      // g/mol [origin=calculated method=formula-sum]
Tc          912.40;      // K   [origin=predictive method=joback]
Pc          18.420;      // bar [origin=predictive method=joback]
omega       0.6384;      // -   [origin=predictive method=lee-kesler]
Tb          683.91;      // K   [origin=predictive method=joback]
HvapTb      61779.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-124.779 1.84616 -0.0013404 4.107e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3,3,5-trimethylcyclohexyl) 2-phenylethanoate" "benzeneacetic acid, 3,3,5-trimethylcyclohexyl ester" "(3,3,5-trimethylcyclohexyl) 2-phenylacetate" );
standardThermochemistry
{
    dHf_298   -446080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     717.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-102160.0
}
