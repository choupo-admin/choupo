/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropenyl-1,3,5-trimethylbenzene  (C12H16, CAS 14679-13-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropenyl135Trimethylbenzene;
formula     C12H16;
CAS         14679-13-1;
InChIKey    KNMWUHBKZHDEOQ-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          723.40;      // K   [origin=predictive method=joback]
Pc          24.100;      // bar [origin=predictive method=joback]
omega       0.4345;      // -   [origin=predictive method=lee-kesler]
Tb          512.34;      // K   [origin=predictive method=joback]
HvapTb      45978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.71 0.86638 -0.00048428 1.016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-trimethyl-2-prop-1-en-2-yl-benzene" "benzene, 1,3,5-trimethyl-2-(1-methylethenyl)-" "2-(2,4,6-trimethylphenyl)propene" "1,3,5-trimethyl-2-prop-1-en-2-ylbenzene" "benzene,1,3,5-trimethyl-2-(1-methylethenyl)-" "styrene, a,2,4,6-tetramethyl-(6ci,7ci,8ci); 1,3,5-trimethyl-2-(1-methylethenyl)benzene; 2-mesitylpropene" );
standardThermochemistry
{
    dHf_298   26750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212970.0
}
