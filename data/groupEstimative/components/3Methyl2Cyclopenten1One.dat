/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-2-cyclopenten-1-one  (C6H8O, CAS 2758-18-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl2Cyclopenten1One;
formula     C6H8O;
CAS         2758-18-1;
InChIKey    CHCCBPDEADMNCI-UHFFFAOYSA-N;
MW          96.129;      // g/mol [origin=calculated method=formula-sum]
Tc          650.87;      // K   [origin=predictive method=joback]
Pc          42.999;      // bar [origin=predictive method=joback]
omega       0.3352;      // -   [origin=predictive method=lee-kesler]
Tb          428.79;      // K   [origin=predictive method=joback]
HvapTb      34717.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.48 0.44822 -0.00016164 -5.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylcyclopent-2-en-1-one" "2-cyclopenten-1-one, 3-methyl-" "3-methyl-2-cyclopentenone" "1-methyl-1-cyclopenten-3-one" "3-methylcyclopent-2-enone" "3-methyl-1-cyclopent-2-enone" "3-methyl-1-oxocyclopent-2-ene" "3-methyl-cyclopent-2-en-1-one" "3-methyl-2-cyclopenten-1-one;3-methyl-2-cyclopentene-1-one;3-methyl-2-cyclopentenone;nussol;3-methyl-2cyclopentene-1-one;" );
gibbsFormation
{
    dHf_298   -177740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     259.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58360.0
    phase     gas;
}
