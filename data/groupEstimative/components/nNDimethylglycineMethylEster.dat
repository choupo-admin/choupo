/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylglycine methyl ester  (C5H11NO2, CAS 7148-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylglycineMethylEster;
formula     C5H11NO2;
CAS         7148-06-3;
InChIKey    LRZFEBJUJIQVDQ-UHFFFAOYSA-N;
MW          117.148;      // g/mol [origin=calculated method=formula-sum]
Tc          557.59;      // K   [origin=predictive method=joback]
Pc          34.807;      // bar [origin=predictive method=joback]
omega       0.4604;      // -   [origin=predictive method=lee-kesler]
Tb          384.66;      // K   [origin=predictive method=joback]
HvapTb      36174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.061 0.54796 -0.0002662 2.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2COO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-(dimethylamino)ethanoate" "glycine, n,n-dimethyl-, methyl ester" "methyl (dimethylamino) acetate" "methyl n,n-dimethylglycinate" "methyl (dimethylamino)acetate" "methyl 2-(dimethylamino)acetate" "methyl 2-dimethylaminoacetate" "lrzfebjujiqvdq-uhfffaoysa-" "glycine,n-dimethyl-, methyl ester" "glycine, n,n-dimethyl-,methyl ester" );
gibbsFormation
{
    dHf_298   -396280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-208370.0
    phase     gas;
}
