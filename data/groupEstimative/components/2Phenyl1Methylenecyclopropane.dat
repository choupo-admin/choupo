/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenyl-1-methylenecyclopropane  (C10H10, CAS 29817-09-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenyl1Methylenecyclopropane;
formula     C10H10;
CAS         29817-09-2;
InChIKey    UZXGMTRQCZEMNP-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          685.10;      // K   [origin=predictive method=joback]
Pc          34.684;      // bar [origin=predictive method=joback]
omega       0.3449;      // -   [origin=predictive method=lee-kesler]
Tb          460.98;      // K   [origin=predictive method=joback]
HvapTb      40202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.06 0.9083 -0.0006792 2.035e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methylidenecyclopropyl)benzene" "benzene, (methylenecyclopropyl)-" "1-methylene-2-phenylcyclopropane" "(2-methylene-cyclopropyl)-benzene" "benzene,(2-methylenecyclopropyl)-" "1-(methylene)-2-phenylcyclopropane" "benzene,(methylenecyclopropyl)- (8ci,9ci); 1-(methylene)-2-phenylcyclopropane;2-phenyl-1-methylenecyclopropane; 2-phenylmethylenecyclopropane" );
standardThermochemistry
{
    dHf_298   143840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     322.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=259560.0
}
