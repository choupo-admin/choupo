/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl-1-pentyne  (C11H12, CAS 4250-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyl1Pentyne;
formula     C11H12;
CAS         4250-81-1;
InChIKey    DEGIOKWPYFOHGH-UHFFFAOYSA-N;
MW          144.217;      // g/mol [origin=calculated method=formula-sum]
Tc          717.23;      // K   [origin=predictive method=joback]
Pc          31.456;      // bar [origin=predictive method=joback]
omega       0.3464;      // -   [origin=predictive method=lee-kesler]
Tb          486.96;      // K   [origin=predictive method=joback]
HvapTb      44508.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.458 0.82012 -0.00051366 1.2418e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-1-ynylbenzene" "benzene, 1-pentynyl-" "pent-1-yn-1-ylbenzene" "1-pentynylbenzene" "1-phenyl-2-propylacetylene" "benzene, 4-pentyn-1-yl-" "1-phenyl-1-pentyne, 96%" );
standardThermochemistry
{
    dHf_298   238460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=356950.0
}
