/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylpyridin-3-amine  (C7H10N2, CAS 18437-57-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylpyridin3Amine;
formula     C7H10N2;
CAS         18437-57-5;
InChIKey    JEDHEXUPBRMUMB-UHFFFAOYSA-N;
MW          122.171;      // g/mol [origin=calculated method=formula-sum]
Tc          674.45;      // K   [origin=predictive method=joback]
Pc          41.091;      // bar [origin=predictive method=joback]
omega       0.3961;      // -   [origin=predictive method=lee-kesler]
Tb          452.58;      // K   [origin=predictive method=joback]
HvapTb      41705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.01 0.7476 -0.00051006 1.368e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH3N; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-3-pyridinamine" "3-dimethylaminopyridine" "n3,n3-dimethylpyridin-3-amine" "3-pyridinamine, n,n-dimethyl-" "5-dimethylaminopyridine" "dimethyl-3-pyridylamine" "3-dimethylamino-pyridine" "agn-pc-0dberl" "dimethyl-pyridin-3-yl-amine" );
standardThermochemistry
{
    dHf_298   149040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=308300.0
}
