/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-4-fluoro-5-methylaniline  (C7H7ClFN, CAS 124185-35-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro4Fluoro5Methylaniline;
formula     C7H7ClFN;
CAS         124185-35-9;
InChIKey    OXINUINVVAJJSE-UHFFFAOYSA-N;
MW          159.588;      // g/mol [origin=calculated method=formula-sum]
Tc          734.61;      // K   [origin=predictive method=joback]
Pc          37.684;      // bar [origin=predictive method=joback]
omega       0.5321;      // -   [origin=predictive method=lee-kesler]
Tb          510.61;      // K   [origin=predictive method=joback]
HvapTb      49647.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.99 0.49192 -0.00026728 4.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 1; } { group Cl; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-4-fluoranyl-5-methyl-aniline" "2-chloro-4-fluoro-5-methyl aniline" "6-chloro-4-fluoro-m-toluidine" "2-chloro-4-fluoro-5-methyl-phenylamine" "2-chloro-4-fluoro-5-methylphenylamine" "5-amino-4-chloro-2-fluorotoluene" "l232" "3-amino-4-chloro-6-fluoro-toluene" "2-chloro-4-fluoro-5-methyl-benzenamine" );
gibbsFormation
{
    dHf_298   -163750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-48710.0
    phase     gas;
}
