/*--------------------------------*- Choupo -*-----------------------*\
  Component: 13,14-dithiatricyclo(8.2.1.14,7)tetradeca-4,6,10,12-tetraene  (C12H12S2, CAS 73650-69-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1314Dithiatricyclo821147Tetradeca461012Tetraene;
formula     C12H12S2;
CAS         73650-69-8;
InChIKey    SKTFMHHTUSLPCB-UHFFFAOYSA-N;
MW          220.348;      // g/mol [origin=calculated method=formula-sum]
Tc          923.40;      // K   [origin=predictive method=joback]
Pc          35.263;      // bar [origin=predictive method=joback]
omega       0.5051;      // -   [origin=predictive method=lee-kesler]
Tb          641.96;      // K   [origin=predictive method=joback]
HvapTb      59272.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.21 1.19482 -0.00094216 2.994e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C4H2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "13,14-dithiatricyclo[8.2.1.14,7]- tetradeca-4,6,10,12-tetraene" "13,14-dithiatricyclo[8.2.1.14,7]tetradeca-1(12),4,6,10-tetraene" );
gibbsFormation
{
    dHf_298   233370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=356080.0
    phase     gas;
}
