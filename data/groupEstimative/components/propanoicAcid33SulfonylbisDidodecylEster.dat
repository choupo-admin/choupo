/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanoic acid, 3,3'-sulfonylbis-, didodecyl ester  (C30H58O6S, CAS 27326-27-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C30H58O6S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        propanoicAcid33SulfonylbisDidodecylEster;
formula     C30H58O6S;
CAS         27326-27-8;
InChIKey    UMPQTYNTXDMGCO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          546.848;      // g/mol [origin=calculated method=formula-sum]
Tc          1241.39;      // K   [origin=predictive method=joback]
Pc          6.307;      // bar [origin=predictive method=joback]
omega       0.2945;      // -   [origin=predictive method=lee-kesler]
Tb          981.44;      // K   [origin=predictive method=joback]
HvapTb      109006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.076 2.78344 -0.0013936 1.96e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 22; } { group CH2COO; count 2; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 26; } { group COO; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecyl 3-(3-dodecoxy-3-oxidanylidene-propyl)sulfonylpropanoate" "dodecyl 3-(3-dodecoxy-3-oxopropyl)sulfonylpropanoate" );
gibbsFormation
{
    dHf_298   -1792310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1685.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-920680.0
    phase     gas;
}
