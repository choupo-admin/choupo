/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-pentadecylphenoxy)butanamide  (C25H43NO2, CAS 62609-89-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23PentadecylphenoxyButanamide;
formula     C25H43NO2;
CAS         62609-89-6;
InChIKey    YFVJCMFQEOHVMO-UHFFFAOYSA-N;
MW          389.624;      // g/mol [origin=calculated method=formula-sum]
Tc          1165.35;      // K   [origin=predictive method=joback]
Pc          9.821;      // bar [origin=predictive method=joback]
omega       0.9492;      // -   [origin=predictive method=lee-kesler]
Tb          951.64;      // K   [origin=predictive method=joback]
HvapTb      93591.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.775 2.21704 -0.00121726 2.3356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH-O; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanamide, 2-(3-pentadecylphenoxy)-" );
gibbsFormation
{
    dHf_298   -550560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1097.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=92490.0
    phase     gas;
}
