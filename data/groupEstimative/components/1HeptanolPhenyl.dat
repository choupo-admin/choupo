/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-heptanol, phenyl-  (C13H20O, CAS 614-54-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1HeptanolPhenyl;
formula     C13H20O;
CAS         614-54-0;
InChIKey    UAJVCELPUNHGKE-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          804.76;      // K   [origin=predictive method=joback]
Pc          24.147;      // bar [origin=predictive method=joback]
omega       0.9650;      // -   [origin=predictive method=lee-kesler]
Tb          615.46;      // K   [origin=predictive method=joback]
HvapTb      63099.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.225 1.19982 -0.0007482 1.783e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylheptan-1-ol" "1-phenyl-1-heptanol" "1-phenyl-heptan-1-ol" "alpha-n-hexyl benzyl alcohol" );
gibbsFormation
{
    dHf_298   -232630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31730.0
    phase     gas;
}
