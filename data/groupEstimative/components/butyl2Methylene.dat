/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl, 2-methylene-  (C5H9, CAS 60288-48-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        butyl2Methylene;
formula     C5H9;
CAS         60288-48-4;
InChIKey    NIAKVGJCTZXVNA-UHFFFAOYSA-N;
role        radical;
MW          69.127;      // g/mol [origin=calculated method=formula-sum]
Tc          473.55;      // K   [origin=predictive method=joback]
Pc          37.408;      // bar [origin=predictive method=joback]
omega       0.2081;      // -   [origin=predictive method=lee-kesler]
Tb          305.16;      // K   [origin=predictive method=joback]
HvapTb      25485.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.239 0.42872 -0.0002544 6.12e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 2; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbut-1-ene" "2-ethyl-2-propenyl" "2-ethylprop-2-en-1-yl" "2-methylidenebutyl" );
standardThermochemistry
{
    dHf_298   35930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     340.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118240.0
}
