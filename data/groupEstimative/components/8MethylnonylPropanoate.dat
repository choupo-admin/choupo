/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-methylnonyl propanoate  (C13H26O2, CAS 67845-27-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8MethylnonylPropanoate;
formula     C13H26O2;
CAS         67845-27-6;
InChIKey    MQRHJALDOCJMIY-UHFFFAOYSA-N;
MW          214.349;      // g/mol [origin=calculated method=formula-sum]
Tc          723.92;      // K   [origin=predictive method=joback]
Pc          16.619;      // bar [origin=predictive method=joback]
omega       0.7426;      // -   [origin=predictive method=lee-kesler]
Tb          554.82;      // K   [origin=predictive method=joback]
HvapTb      51551.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.798 1.18996 -0.000592 8.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-nonanol, 8-methyl-, propanoate" "1-nonanol, 8-methyl-, 1-propanoate" "propanoic acid 8-methylnonyl ester" );
standardThermochemistry
{
    dHf_298   -634210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-254230.0
}
