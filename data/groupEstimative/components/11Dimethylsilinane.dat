/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethylsilinane  (C7H16Si, CAS 4040-74-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        11Dimethylsilinane;
formula     C7H16Si;
CAS         4040-74-8;
InChIKey    VPVXTYYXTKCTPM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          128.29;      // g/mol [origin=calculated method=formula-sum]
Tc          583.32;      // K   [origin=predictive method=joback]
Pc          30.967;      // bar [origin=predictive method=joback]
omega       0.1931;      // -   [origin=predictive method=lee-kesler]
Tb          381.11;      // K   [origin=predictive method=joback]
HvapTb      32036.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.08 0.62084 -0.000125 -7.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "silacyclohexane, 1,1-dimethyl-" "cyclopentamethylenedimethylsilane" "dimethylsilacyclohexane" "1,1-dimethyl-1-silacyclohexane" "1,1-dimethylsilacyclohexane" "silacyclohexane,1-dimethyl-" "cyclopentamethylene dimethyl silane" );
gibbsFormation
{
    dHf_298   -218610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-52440.0
    phase     gas;
}
