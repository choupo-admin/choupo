/*--------------------------------*- Choupo -*-----------------------*\
  Component: polyurethane y-304  (C17H16N2O4, CAS 25036-33-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        polyurethaneY304;
formula     C17H16N2O4;
CAS         25036-33-3;
InChIKey    ZOUPQIZRXKCDRM-UHFFFAOYSA-N;
MW          312.325;      // g/mol [origin=calculated method=formula-sum]
Tc          1195.93;      // K   [origin=predictive method=joback]
Pc          25.663;      // bar [origin=predictive method=joback]
omega       1.7286;      // -   [origin=predictive method=lee-kesler]
Tb          970.98;      // K   [origin=predictive method=joback]
HvapTb      112028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 3; } { group dCd; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-diol;1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene" "ethane-1,2-diol- 1,1'-methanediylbis(4-isocyanatobenzene)(1:1)" "isocyanic acid, methylenedi-p-phenylene ester, polymer with ethylene glycol" "1,2-ethanediol, polymer with 1,1'-methylenebis(4-isocyanatobenzene)" "1,2-ethanediol, polymer with 1,1'-methylenebis(4-isocyanatobenzene) (9ci)" "ethane-1,2-diol; 1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene" );
