/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-nonanone  (C9H18O, CAS 821-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Nonanone;
formula     C9H18O;
CAS         821-55-6;
InChIKey    VKCYHJWLYTUGCC-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          633.59;      // K   [origin=predictive method=joback]
Pc          24.532;      // bar [origin=predictive method=joback]
omega       0.5752;      // -   [origin=predictive method=lee-kesler]
Tb          459.39;      // K   [origin=predictive method=joback]
HvapTb      42374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.066 0.83084 -0.0004471 8.686e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonan-2-one" "heptyl methyl ketone" "methyl heptyl ketone" "ketone, heptyl methyl" "beta-nonanone" "2-nonanone (natural)" "nonanone" ".beta.-nonanone" );
gibbsFormation
{
    dHf_298   -341670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-104020.0
    phase     gas;
}
