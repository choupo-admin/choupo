/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl dodeca-3,6-dienoate  (C13H22O2, CAS 16106-01-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylDodeca36Dienoate;
formula     C13H22O2;
CAS         16106-01-7;
InChIKey    QOLQXDRXMBPSFD-UHFFFAOYSA-N;
MW          210.317;      // g/mol [origin=calculated method=formula-sum]
Tc          742.89;      // K   [origin=predictive method=joback]
Pc          18.000;      // bar [origin=predictive method=joback]
omega       0.7128;      // -   [origin=predictive method=lee-kesler]
Tb          563.58;      // K   [origin=predictive method=joback]
HvapTb      51855.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.884 1.22404 -0.0007564 1.812e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH=CH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-dodecadienoic acid methyl ester" );
standardThermochemistry
{
    dHf_298   -394490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     700.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-91350.0
}
