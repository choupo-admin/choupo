/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethyl-2,5-dihydro-1h-pyrrole  (C6H11N, CAS 59480-92-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethyl25Dihydro1hPyrrole;
formula     C6H11N;
CAS         59480-92-1;
InChIKey    TXQDHQBSNAJSHQ-UHFFFAOYSA-N;
MW          97.161;      // g/mol [origin=calculated method=formula-sum]
Tc          602.07;      // K   [origin=predictive method=joback]
Pc          39.755;      // bar [origin=predictive method=joback]
omega       0.2941;      // -   [origin=predictive method=lee-kesler]
Tb          395.20;      // K   [origin=predictive method=joback]
HvapTb      35948.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.41 0.60964 -0.00030128 4.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dimethyl-3-pyrroline" "2,5-dimethyl-3-pyrroline, mixture of cis and trans" "1h-pyrrole,2,5-dihydro-2,5-dimethyl-" );
standardThermochemistry
{
    dHf_298   -31440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     253.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=146150.0
}
