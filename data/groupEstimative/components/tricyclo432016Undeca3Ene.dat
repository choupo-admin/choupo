/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(4.3.2.0(1,6))undeca-3-ene  (C11H16, CAS 136630-09-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo432016Undeca3Ene;
formula     C11H16;
CAS         136630-09-6;
InChIKey    AEVSDMKEZBQELO-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          726.71;      // K   [origin=predictive method=joback]
Pc          35.643;      // bar [origin=predictive method=joback]
omega       0.3157;      // -   [origin=predictive method=lee-kesler]
Tb          484.35;      // K   [origin=predictive method=joback]
HvapTb      38462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-266.22 2.0366 -0.00225028 9.862e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group C_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3a,7a-ethano-1h-indene,2,3,4,7-tetrahydro- (9ci)" "tricyclo[4.3.2.0(1,6)undeca-3-ene" );
standardThermochemistry
{
    dHf_298   44310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=226480.0
}
