/*--------------------------------*- Choupo -*-----------------------*\
  Component: 16-hydroxyhexadecanoic acid  (C16H32O3, CAS 506-13-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16HydroxyhexadecanoicAcid;
formula     C16H32O3;
CAS         506-13-8;
InChIKey    UGAGPNKCDRTDHP-UHFFFAOYSA-N;
MW          272.429;      // g/mol [origin=calculated method=formula-sum]
Tc          986.08;      // K   [origin=predictive method=joback]
Pc          15.105;      // bar [origin=predictive method=joback]
omega       1.3086;      // -   [origin=predictive method=lee-kesler]
Tb          803.37;      // K   [origin=predictive method=joback]
HvapTb      85053.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.765 1.6086 -0.0009496 2.17e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 15; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 15; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "16-oxidanylhexadecanoic acid" "juniperic acid" "16-hydroxypalmitic acid" "hexadecanoic acid, 16-hydroxy-" "omega-hydroxypalmitic acid" "16-hydroxy-hexadecanoic acid" "palmitic acid, 16-hydroxy-" "16-hydroxypalmitate" "paragraph signaeeea" "16-oc>>uxoemicroea" ".omega.-hydroxypalmitic acid" "16-oh 16:0" );
gibbsFormation
{
    dHf_298   -876070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     883.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-396890.0
    phase     gas;
}
