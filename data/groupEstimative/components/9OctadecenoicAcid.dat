/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-octadecenoic acid  (C18H34O2, CAS 112-79-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9OctadecenoicAcid;
formula     C18H34O2;
CAS         112-79-8;
InChIKey    ZQPPMHVWECSIRJ-UHFFFAOYSA-N;
MW          282.468;      // g/mol [origin=calculated method=formula-sum]
Tc          943.11;      // K   [origin=predictive method=joback]
Pc          12.710;      // bar [origin=predictive method=joback]
omega       1.0400;      // -   [origin=predictive method=lee-kesler]
Tb          761.11;      // K   [origin=predictive method=joback]
HvapTb      72784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.056 1.78462 -0.0011118 2.784e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group dCH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadec-9-enoic acid" "red oil" "odorless" "mangrove" "d9-octadecenoic acid" "okic acid" "agn-pc-00kg6f" "elaidic acid, reag." "oleic acid_gurudeebansatyavani" "c18:1" "d 100;d 100 (fatty acid);edenor atio5;edenor ftio5;emersol 205;emersol 211;emersol 213nf;emersol 214nf;emersol 233;emersol 6313nf;extra oleic 80r;extra oleic 90;extra oleic 99;extra olein 80;extra olein 90;extra olein 90r;extra olein a 1981;industrene 105;lunac o-ca;lunac o-ll;lunac o-p;lunac o-v;lunac oa;naa 35;neo-fat 92-04;oleine 7503;priolene 6906;priolene 6907;priolene 6928;priolene 6930;priolene 6933;vopcolene 27;wecoline oo;z-9-octadecenoic acid;cis-9-octadecenoic acid;cis-oleic acid;cis-d9-octadecenoic acid;d9-cis-octadecenoic acid;d9-cis-oleic acid;" );
gibbsFormation
{
    dHf_298   -647900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     903.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-163010.0
    phase     gas;
}
