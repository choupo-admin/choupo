/*--------------------------------*- Choupo -*-----------------------*\
  Component: decanamide, n-(2-hydroxypropyl)-  (C13H27NO2, CAS 23054-61-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decanamideN2Hydroxypropyl;
formula     C13H27NO2;
CAS         23054-61-7;
InChIKey    YQSBEIIQKPQGCO-UHFFFAOYSA-N;
MW          229.364;      // g/mol [origin=calculated method=formula-sum]
Tc          865.07;      // K   [origin=predictive method=joback]
Pc          19.069;      // bar [origin=predictive method=joback]
omega       1.2854;      // -   [origin=predictive method=lee-kesler]
Tb          692.82;      // K   [origin=predictive method=joback]
HvapTb      74005.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.829 1.32694 -0.0007469 1.5426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group OH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group OH; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-oxidanylpropyl)decanamide" "capric isopropanolamide" "capric monoisopropanolamide" "n-(2-hydroxypropyl)decanamide" "n-(2-hydroxypropyl)decan-1-amide" );
standardThermochemistry
{
    dHf_298   -528270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     771.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-120210.0
}
