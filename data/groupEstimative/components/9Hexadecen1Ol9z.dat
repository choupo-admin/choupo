/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-hexadecen-1-ol, (9z)-  (C16H32O, CAS 10378-01-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Hexadecen1Ol9z;
formula     C16H32O;
CAS         10378-01-5;
InChIKey    LBIYNOAMNIKVKF-UHFFFAOYSA-N;
MW          240.431;      // g/mol [origin=calculated method=formula-sum]
Tc          825.74;      // K   [origin=predictive method=joback]
Pc          14.680;      // bar [origin=predictive method=joback]
omega       1.0847;      // -   [origin=predictive method=lee-kesler]
Tb          662.02;      // K   [origin=predictive method=joback]
HvapTb      67847.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.547 1.57782 -0.0009608 2.364e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadec-9-en-1-ol" "9-hexadecen-1-ol, (e)-" );
gibbsFormation
{
    dHf_298   -408580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     823.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=27240.0
    phase     gas;
}
