/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,6,7,8-hexahydro-as-indacene  (C12H14, CAS 1076-17-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123678HexahydroAsIndacene;
formula     C12H14;
CAS         1076-17-1;
InChIKey    CGIPSWGAIQVCNY-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          774.88;      // K   [origin=predictive method=joback]
Pc          32.357;      // bar [origin=predictive method=joback]
omega       0.4677;      // -   [origin=predictive method=lee-kesler]
Tb          538.60;      // K   [origin=predictive method=joback]
HvapTb      47012.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.39 1.2412 -0.00101028 3.374e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 2; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "as-indacene,1,2,3,6,7,8-hexahydro-" "cgipswgaiqvcny-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   97390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=270600.0
}
