/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydroxyprogesterone  (C21H30O3, CAS 68-96-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydroxyprogesterone;
formula     C21H30O3;
CAS         68-96-2;
InChIKey    DBPWSSGDRRHUNT-CEGNMAFCSA-N;
MW          330.468;      // g/mol [origin=calculated method=formula-sum]
Tc          1179.74;      // K   [origin=predictive method=joback]
Pc          18.757;      // bar [origin=predictive method=joback]
omega       1.1823;      // -   [origin=predictive method=lee-kesler]
Tb          937.78;      // K   [origin=predictive method=joback]
HvapTb      87407.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-309.71 3.09936 -0.00294234 1.19106e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 3; } { group C; count 3; } { group CH=C; count 1; } { group OH; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 3; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s,17r)-17-ethanoyl-10,13-dimethyl-17-oxidanyl-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthren-3-one" "17alpha-hydroxyprogesterone" "17-hydroxyprogesterone" "prodix" "prodox" "gestageno gador" "setaderm" "oxiprogesteronum" "17alpha-hydroxy-4-pregnene-3,20-dione" "17-hydroxypregn-4-ene-3,20-dione" "gestageno" "17a-hydroxyprogesterone" );
gibbsFormation
{
    dHf_298   -567530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     791.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-91450.0
    phase     gas;
}
