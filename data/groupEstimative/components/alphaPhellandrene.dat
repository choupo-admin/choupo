/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-Phellandrene  (C10H16, CAS 99-83-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaPhellandrene;
formula     C10H16;
CAS         99-83-2;
InChIKey    OGLDWXZKYODSOB-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          657.87;      // K   [origin=predictive method=joback]
Pc          27.469;      // bar [origin=predictive method=joback]
omega       0.3334;      // -   [origin=predictive method=lee-kesler]
Tb          450.81;      // K   [origin=predictive method=joback]
HvapTb      39141.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.63 0.91036 -0.00051192 1.004e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-5-propan-2-ylcyclohexa-1,3-diene" "(±)-α-phellandrene" "1,3-Cyclohexadiene, 2-methyl-5-(1-methylethyl)-" "2-methyl-5-(1-methylethyl)-1,3-cyclohexadiene" "5-isopropyl-2-methyl-1,3-cyclohexadiene" "6-isopropyl-3-methyl-1,3-cyclohexadiene" "alda-364" "menthadiene" "p-mentha-1,5-diene" "p-Mentha-1,5-diene (8CI)" "α-phellandrene" "alpha-fellandrene" );
gibbsFormation
{
    dHf_298   -96600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105620.0
    phase     gas;
}
