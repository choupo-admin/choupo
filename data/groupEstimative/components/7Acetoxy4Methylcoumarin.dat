/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-acetoxy-4-methylcoumarin  (C12H10O4, CAS 2747-05-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Acetoxy4Methylcoumarin;
formula     C12H10O4;
CAS         2747-05-9;
InChIKey    HXVZGASCDAGAPS-UHFFFAOYSA-N;
MW          218.208;      // g/mol [origin=calculated method=formula-sum]
Tc          857.16;      // K   [origin=predictive method=joback]
Pc          27.701;      // bar [origin=predictive method=joback]
omega       0.8268;      // -   [origin=predictive method=lee-kesler]
Tb          638.52;      // K   [origin=predictive method=joback]
HvapTb      61724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.51 0.90784 -0.00057916 1.298e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH3COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methyl-2-oxidanylidene-chromen-7-yl) ethanoate" "4-methylumbelliferyl acetate" "mu-ac" "b-methylumbelliferyl acetate" "4-methyl-2-oxo-2h-chromen-7-yl acetate" "beta-methylumbelliferyl acetate" "2h-1-benzopyran-2-one, 7-(acetyloxy)-4-methyl-" "7-(acetyloxy)-4-methyl-2-benzopyrone" "4-methyl-7-acetyloxy coumarin" "4-methyl umbelliferone acetate" "4-methyl-umbelliferone, acetate" "7-acetoxy-4-methylchromen-2-one" );
gibbsFormation
{
    dHf_298   -566370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-376540.0
    phase     gas;
}
