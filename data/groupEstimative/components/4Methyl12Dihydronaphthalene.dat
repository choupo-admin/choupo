/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-1,2-dihydronaphthalene  (C11H12, CAS 4373-13-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl12Dihydronaphthalene;
formula     C11H12;
CAS         4373-13-1;
InChIKey    NACZXFJTTCJDJR-UHFFFAOYSA-N;
MW          144.217;      // g/mol [origin=calculated method=formula-sum]
Tc          735.09;      // K   [origin=predictive method=joback]
Pc          32.690;      // bar [origin=predictive method=joback]
omega       0.3941;      // -   [origin=predictive method=lee-kesler]
Tb          502.76;      // K   [origin=predictive method=joback]
HvapTb      44366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.94 0.96272 -0.0006882 1.972e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene, 1,2-dihydro-4-methyl-" );
gibbsFormation
{
    dHf_298   87980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=221210.0
    phase     gas;
}
