/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl 2-hydroxypropanoate  (C6H10O3, CAS 5349-55-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allyl2Hydroxypropanoate;
formula     C6H10O3;
CAS         5349-55-3;
InChIKey    CYFIHPJVHCCGTF-UHFFFAOYSA-N;
MW          130.143;      // g/mol [origin=calculated method=formula-sum]
Tc          658.20;      // K   [origin=predictive method=joback]
Pc          36.865;      // bar [origin=predictive method=joback]
omega       0.8759;      // -   [origin=predictive method=lee-kesler]
Tb          483.52;      // K   [origin=predictive method=joback]
HvapTb      51978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.461 0.53892 -0.0002645 2.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl 2-oxidanylpropanoate" "allyl lactate" "prop-2-enyl 2-hydroxypropanoate" "lactic acid, allyl ester" "2-hydroxy-propionic acid allyl ester" "prop-2-en-1-yl 2-hydroxypropanoate" "propanoic acid, 2-hydroxy-, 2-propenyl ester" );
gibbsFormation
{
    dHf_298   -516530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-362150.0
    phase     gas;
}
