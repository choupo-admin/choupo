/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclononane  (C9H18, CAS 293-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclononane;
formula     C9H18;
CAS         293-55-0;
InChIKey    GPTJTTCOVDDHER-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          667.75;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.2549;      // -   [origin=predictive method=lee-kesler]
Tb          442.55;      // K   [origin=predictive method=joback]
HvapTb      36882.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.2 0.9786 -0.000463 4.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aromatic hydrocarbons, c9-17" "cyclononane." );
gibbsFormation
{
    dHf_298   -172910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20760.0
    phase     gas;
}
