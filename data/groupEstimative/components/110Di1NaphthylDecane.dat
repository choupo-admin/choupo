/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,10-di(1-naphthyl)decane  (C30H34, CAS 40339-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        110Di1NaphthylDecane;
formula     C30H34;
CAS         40339-27-3;
InChIKey    MJOQAHPAUSIVEG-UHFFFAOYSA-N;
MW          394.602;      // g/mol [origin=calculated method=formula-sum]
Tc          1221.62;      // K   [origin=predictive method=joback]
Pc          11.291;      // bar [origin=predictive method=joback]
omega       0.9551;      // -   [origin=predictive method=lee-kesler]
Tb          987.28;      // K   [origin=predictive method=joback]
HvapTb      91530.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.48 2.5696 -0.00180996 5.092e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group ACH; count 14; } { group AC; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group dCH_ring; count 14; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(10-naphthalen-1-yldecyl)naphthalene" "1,10-di(.alpha.-naphthyl)decane" "naphthalene, 1,1'-(1,10-decanediyl)bis-" "1,1'-(1,10-decanediyl)bisnaphthalene" "naphthalene,1'-(1,10-decanediyl)bis-" );
gibbsFormation
{
    dHf_298   169730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     881.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=620580.0
    phase     gas;
}
