/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexenedinitrile  (C6H6N2, CAS 1119-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexenedinitrile;
formula     C6H6N2;
CAS         1119-85-3;
InChIKey    BSVZXPLUMFUWHW-UHFFFAOYSA-N;
MW          106.128;      // g/mol [origin=calculated method=formula-sum]
Tc          762.95;      // K   [origin=predictive method=joback]
Pc          31.140;      // bar [origin=predictive method=joback]
omega       0.6034;      // -   [origin=predictive method=lee-kesler]
Tb          545.20;      // K   [origin=predictive method=joback]
HvapTb      49864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.252 0.4634 -0.0003244 9.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH; count 2; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-3-enedinitrile" "1,4-dicyano-2-butene" "1,4-dicyano butene-2" "3-hexenedinitrile,(3e)-" "3-hexenedinitrile,(e)- (8ci); trans-b-hydromucononitrile (6ci); (e)-3-hexenedinitrile;1,4-dicyano-trans-2-butene; trans-1,4-dicyano-2-butene;trans-2-butene-1,4-dicarbonitrile" );
standardThermochemistry
{
    dHf_298   279810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=346220.0
}
