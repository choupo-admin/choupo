/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,2-trifluoroethanol  (C2H3F3O, CAS 75-89-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222Trifluoroethanol;
formula     C2H3F3O;
CAS         75-89-8;
InChIKey    RHQDFWAXVIIEBN-UHFFFAOYSA-N;
MW          100.039;      // g/mol [origin=calculated method=formula-sum]
Tc          478.11;      // K   [origin=predictive method=joback]
Pc          48.630;      // bar [origin=predictive method=joback]
omega       0.6363;      // -   [origin=predictive method=lee-kesler]
Tb          332.12;      // K   [origin=predictive method=joback]
HvapTb      32978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.161 0.389 -0.0003364 1.111e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group F; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(fluoranyl)ethanol" "trifluoroethanol" "ethanol, 2,2,2-trifluoro-" "trifluoroethyl alcohol" "fluorinol 85" "tfetoh" "2,2,2-trifluoroethan-1-ol" "trifluoro ethanol" "perfluoro-1,1-dihydroethanol" "2,2,2-trifluoroethyl alcohol" "tfe" "1h,1h-trifluoroethanol" );
standardThermochemistry
{
    dHf_298   -833920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     341.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-752450.0
}
