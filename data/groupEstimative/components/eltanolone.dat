/*--------------------------------*- Choupo -*-----------------------*\
  Component: eltanolone  (C21H34O2, CAS 128-20-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eltanolone;
formula     C21H34O2;
CAS         128-20-1;
InChIKey    AURFZBICLPNKBZ-YZRLXODZSA-N;
MW          318.501;      // g/mol [origin=calculated method=formula-sum]
Tc          1080.68;      // K   [origin=predictive method=joback]
Pc          16.312;      // bar [origin=predictive method=joback]
omega       1.0380;      // -   [origin=predictive method=lee-kesler]
Tb          856.24;      // K   [origin=predictive method=joback]
HvapTb      82739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-306.35 3.03826 -0.0026227 9.7036e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 6; } { group C; count 2; } { group OH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 9; } { group CH_ring; count 6; } { group C_ring; count 2; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(3r,5r,8r,9s,10s,13s,14s,17s)-10,13-dimethyl-3-oxidanyl-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthren-17-yl]ethanone" "pregnan-3alpha-ol-20-one" "pregnanolone" "pregnanolone ii" "eltanolona" "eltanolonum" "3alpha-hydroxy-5beta-pregnan-20-one" "allopregnanolone" "eltanolonum [inn-latin]" "3alpha,5beta-epimeric pregnanolone" "pregnan-20-one, 3-hydroxy-, (3alpha,5beta)-" "3-alpha-hydroxy-5-beta-pregnan-20-one" );
standardThermochemistry
{
    dHf_298   -532060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     759.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=880.0
}
