/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane, (1-decylundecyl)-  (C27H54, CAS 6703-99-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexane1Decylundecyl;
formula     C27H54;
CAS         6703-99-7;
InChIKey    ZSEPDKTYQJRZIS-UHFFFAOYSA-N;
MW          378.729;      // g/mol [origin=calculated method=formula-sum]
Tc          1025.66;      // K   [origin=predictive method=joback]
Pc          7.729;      // bar [origin=predictive method=joback]
omega       0.7182;      // -   [origin=predictive method=lee-kesler]
Tb          836.47;      // K   [origin=predictive method=joback]
HvapTb      75737.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.942 2.69684 -0.0015292 3.192e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 23; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "henicosan-11-ylcyclohexane" "heneicosane, 11-cyclohexyl-" "11-cyclohexylheneicosane" "11-cyclohexylhenicosane" "cyclohexane,(1-decylundecyl)-" );
standardThermochemistry
{
    dHf_298   -551570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1167.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=198470.0
}
