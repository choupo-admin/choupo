/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-aminocyclopentanol  (C5H11NO, CAS 89381-13-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Aminocyclopentanol;
formula     C5H11NO;
CAS         89381-13-5;
InChIKey    JFFOUICIRBXFRC-UHFFFAOYSA-N;
MW          101.149;      // g/mol [origin=calculated method=formula-sum]
Tc          691.03;      // K   [origin=predictive method=joback]
Pc          50.875;      // bar [origin=predictive method=joback]
omega       0.7736;      // -   [origin=predictive method=lee-kesler]
Tb          489.32;      // K   [origin=predictive method=joback]
HvapTb      53992.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.42 0.6799 -0.000394 8.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 2; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanylcyclopentan-1-ol" "2-amino cyclopentanol" "cyclopentanol, 2-amino-" "2-aminocyclopentan-1-ol" "cis-2-amino-cyclopentanol" "trans-2-amino-cyclopentanol" "agn-pc-00btzg" "cyclopentanol,cis-2-amino-" "cyclopentanol, cis-2-amino-" "cyclopentanol,trans-2-amino-" "cyclopentanol, trans-2-amino-" "1-amino-2-hydroxycyclopentane; 2-hydroxycyclopentylamine" );
standardThermochemistry
{
    dHf_298   -224830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-50310.0
}
