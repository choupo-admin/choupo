/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetylbutyrolactone  (C6H8O3, CAS 517-23-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Acetylbutyrolactone;
formula     C6H8O3;
CAS         517-23-7;
InChIKey    OMQHDIHZSDEIFH-UHFFFAOYSA-N;
MW          128.127;      // g/mol [origin=calculated method=formula-sum]
Tc          656.42;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.5429;      // -   [origin=predictive method=lee-kesler]
Tb          455.71;      // K   [origin=predictive method=joback]
HvapTb      43016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.04 0.64192 -0.0004095 9.336e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethanoyloxolan-2-one" "2(3h)-furanone, 3-acetyldihydro-" "3-acetyldihydro-2(3h)-furanone" "3-acetyl-dihydro-2(3h)-furanone" "2-oxo-3-acetyltetrahydrofuran" "3-acetyltetrahydro-2-furanone" "alpha-acetylbutyrolactone" "alpha-acetyl-gamma-butyrolactone" "3-acetyloxolan-2-one" "alpha-acetobutyrolactone" "2-acetyl-gama-butyrolactone" "3-acetyl-2(3h)-4,5-dihydrofuranone" );
standardThermochemistry
{
    dHf_298   -524230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-378900.0
}
