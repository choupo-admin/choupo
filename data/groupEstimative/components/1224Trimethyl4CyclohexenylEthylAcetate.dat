/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,2,4-trimethyl-4-cyclohexenyl)ethyl acetate  (C13H22O2, CAS 63649-50-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1224Trimethyl4CyclohexenylEthylAcetate;
formula     C13H22O2;
CAS         63649-50-3;
InChIKey    MLQHMXIHRGYDJM-UHFFFAOYSA-N;
MW          210.317;      // g/mol [origin=calculated method=formula-sum]
Tc          782.64;      // K   [origin=predictive method=joback]
Pc          20.382;      // bar [origin=predictive method=joback]
omega       0.5513;      // -   [origin=predictive method=lee-kesler]
Tb          574.08;      // K   [origin=predictive method=joback]
HvapTb      51474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.78 1.462 -0.00107044 3.446e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4,6,6-trimethylcyclohex-3-en-1-yl)ethyl ethanoate" "1-(4,6,6-trimethylcyclohex-3-en-1-yl)ethyl acetate" "alpha,4,6,6-tetramethylcyclohex-3-ene-1-methyl acetate" "3-cyclohexene-1-methanol, alpha,4,6,6-tetramethyl-, acetate" "3-cyclohexene-1-methanol, .alpha.,4,6,6-tetramethyl-, 1-acetate" "3-cyclohexene-1-methanol, .alpha.,4,6,6-tetramethyl-, acetate" "3-cyclohexene-1-methanol, alpha,4,6,6-tetramethyl-, 1-acetate" );
standardThermochemistry
{
    dHf_298   -538680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     657.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-222650.0
}
