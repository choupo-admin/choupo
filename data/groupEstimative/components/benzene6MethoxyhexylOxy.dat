/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene,[(6-methoxyhexyl)oxy]-  (C13H20O2, CAS 61372-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene6MethoxyhexylOxy;
formula     C13H20O2;
CAS         61372-58-5;
InChIKey    FYBTUIHGBZJULX-UHFFFAOYSA-N;
MW          208.301;      // g/mol [origin=calculated method=formula-sum]
Tc          762.15;      // K   [origin=predictive method=joback]
Pc          21.256;      // bar [origin=predictive method=joback]
omega       0.6870;      // -   [origin=predictive method=lee-kesler]
Tb          568.56;      // K   [origin=predictive method=joback]
HvapTb      51628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.166 1.03352 -0.0004926 5.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 5; } { group AC; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methoxyhexoxybenzene" "benzene, ((6-methoxyhexyl)oxy)-" );
standardThermochemistry
{
    dHf_298   -339560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-39010.0
}
