/*--------------------------------*- Choupo -*-----------------------*\
  Component: xalyl  (C9H19NO, CAS 533-32-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        xalyl;
formula     C9H19NO;
CAS         533-32-4;
InChIKey    QZMQDHNCNUGQSO-UHFFFAOYSA-N;
MW          157.257;      // g/mol [origin=calculated method=formula-sum]
Tc          647.56;      // K   [origin=predictive method=joback]
Pc          24.678;      // bar [origin=predictive method=joback]
omega       0.6029;      // -   [origin=predictive method=lee-kesler]
Tb          471.39;      // K   [origin=predictive method=joback]
HvapTb      44029.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.307 0.96068 -0.0005629 1.2376e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-3-methyl-butanamide" "n,n-diethylisovaleramide" "isovaleryl diethylamide" "n,n-diethyl-3-methylbutanamide" "valimyl" "valyl" "butanamide,n-diethyl-3-methyl-" "butyramide,n-diethyl-3-methyl-" "butanamide, n,n-diethyl-3-methyl-" );
standardThermochemistry
{
    dHf_298   -279420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4320.0
}
