/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethylhepta-1,3,6-triene  (C9H14, CAS 928-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethylhepta136Triene;
formula     C9H14;
CAS         928-67-6;
InChIKey    BEVRACFYDJMTEY-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          588.37;      // K   [origin=predictive method=joback]
Pc          26.680;      // bar [origin=predictive method=joback]
omega       0.3177;      // -   [origin=predictive method=lee-kesler]
Tb          402.80;      // K   [origin=predictive method=joback]
HvapTb      34406.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.839 0.83864 -0.0006 1.817e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 1; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   119410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=263700.0
    phase     gas;
}
