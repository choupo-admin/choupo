/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-oxathiane, 2,2,4,6-tetramethyl-, cis-  (C8H16OS, CAS 34560-78-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Oxathiane2246TetramethylCis;
formula     C8H16OS;
CAS         34560-78-6;
InChIKey    LPCWYDWZCPIOJH-UHFFFAOYSA-N;
MW          160.275;      // g/mol [origin=calculated method=formula-sum]
Tc          692.55;      // K   [origin=predictive method=joback]
Pc          30.289;      // bar [origin=predictive method=joback]
omega       0.3110;      // -   [origin=predictive method=lee-kesler]
Tb          467.87;      // K   [origin=predictive method=joback]
HvapTb      42384.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.96 1.13629 -0.000919 3.353e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH-O; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group O_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,6-tetramethyl-1,3-oxathiane" "1,3-oxathiane, 2,2,4,6-tetramethyl-, trans-" "1,3-oxathiane,2,2,4,6-tetramethyl,trans-" "(4r,6s)-2,2,4,6-tetramethyl-1,3-oxathiane" );
gibbsFormation
{
    dHf_298   -266310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26240.0
    phase     gas;
}
