/*--------------------------------*- Choupo -*-----------------------*\
  Component: mecamylamine  (C11H21N, CAS 60-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mecamylamine;
formula     C11H21N;
CAS         60-40-2;
InChIKey    IMYZQPCYWPFTAG-UHFFFAOYSA-N;
MW          167.296;      // g/mol [origin=calculated method=formula-sum]
Tc          723.49;      // K   [origin=predictive method=joback]
Pc          26.245;      // bar [origin=predictive method=joback]
omega       0.4521;      // -   [origin=predictive method=lee-kesler]
Tb          510.34;      // K   [origin=predictive method=joback]
HvapTb      43594.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-202.03 1.94808 -0.0019716 8.385e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 2; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,2,2,3-tetramethylbicyclo[2.2.1]heptan-3-amine" "versamine" "mecamine" "mekamine" "mevasine" "revertina" "mecamilamina" "mecamylaminum" "2-methylaminoisocamphane" "3-methylaminoisocamphane" "mecamilamina [dcit]" "mecamylaminum [inn-latin]" );
gibbsFormation
{
    dHf_298   -87660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=214130.0
    phase     gas;
}
