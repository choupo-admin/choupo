/*--------------------------------*- Choupo -*-----------------------*\
  Component: tranexamic acid  (C8H15NO2, CAS 1197-18-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tranexamicAcid;
formula     C8H15NO2;
CAS         1197-18-8;
InChIKey    GYDJEQRTZSCIOI-UHFFFAOYSA-N;
MW          157.213;      // g/mol [origin=calculated method=formula-sum]
Tc          844.03;      // K   [origin=predictive method=joback]
Pc          35.942;      // bar [origin=predictive method=joback]
omega       0.8086;      // -   [origin=predictive method=lee-kesler]
Tb          615.56;      // K   [origin=predictive method=joback]
HvapTb      61327.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.959 0.9721 -0.000553 1.044e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(aminomethyl)cyclohexane-1-carboxylic acid" "cyklokapron" "trans amcha" "tranexamsaeure" "transamin" "amstat" "tranhexamic acid" "trans-4-(aminomethyl)cyclohexanecarboxylic acid" "anvitoff" "rikavarin" "tamcha" "ugurol" );
standardThermochemistry
{
    dHf_298   -490950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-244240.0
}
