/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(azepan-1-yl)ethanol  (C8H17NO, CAS 20603-00-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Azepan1YlEthanol;
formula     C8H17NO;
CAS         20603-00-3;
InChIKey    VMRYMOMQCYSPHS-UHFFFAOYSA-N;
MW          143.23;      // g/mol [origin=calculated method=formula-sum]
Tc          700.13;      // K   [origin=predictive method=joback]
Pc          36.377;      // bar [origin=predictive method=joback]
omega       0.8272;      // -   [origin=predictive method=lee-kesler]
Tb          511.48;      // K   [origin=predictive method=joback]
HvapTb      52862.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.328 1.0703 -0.0006908 1.69e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 6; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azaperhydroepinylethan-1-ol" "2-(azepan-1-yl)ethan-1-ol" "hexahydro-1h-azepine-1-ethanol" "1h-azepine-1-ethanol,hexahydro-" "2(n-hexamethyleneimino) ethanol" );
gibbsFormation
{
    dHf_298   -218490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22600.0
    phase     gas;
}
