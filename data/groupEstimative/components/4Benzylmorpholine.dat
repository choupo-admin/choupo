/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-benzylmorpholine  (C11H15NO, CAS 10316-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Benzylmorpholine;
formula     C11H15NO;
CAS         10316-00-4;
InChIKey    GVWBJJLCTWNTRU-UHFFFAOYSA-N;
MW          177.247;      // g/mol [origin=calculated method=formula-sum]
Tc          767.44;      // K   [origin=predictive method=joback]
Pc          32.992;      // bar [origin=predictive method=joback]
omega       0.5136;      // -   [origin=predictive method=lee-kesler]
Tb          537.30;      // K   [origin=predictive method=joback]
HvapTb      49475.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.809 1.249 -0.0008873 2.416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(phenylmethyl)morpholine" "4-benzyl-morpholine" "morpholine,4-(phenylmethyl)-" "morpholine, 4-(phenylmethyl)-" );
gibbsFormation
{
    dHf_298   -17490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=223070.0
    phase     gas;
}
