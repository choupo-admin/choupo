  Component: 1,2-bis(dimethylsilyl)benzene  (C10H16Si2, CAS 17985-72-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H16Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        12BisDimethylsilylBenzene;
formula     C10H16Si2;
CAS         17985-72-7;
InChIKey    MUUXBTFQEXVEEI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          192.408;      // g/mol [origin=calculated method=formula-sum]
Tc          674.85;      // K   [origin=predictive method=joback]
Pc          24.654;      // bar [origin=predictive method=joback]
omega       0.2814;      // -   [origin=predictive method=lee-kesler]
Tb          461.46;      // K   [origin=predictive method=joback]
HvapTb      41086.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.01 0.60928 -6.956e-05 -1.088e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(dimethyl-$l^{3}-silanyl)phenyl]-dimethyl-silicon" "o-phenylenebis(dimethylsilane)" "[2-(dimethyl-" "qauceyvycbyvdk-uhfffaoysa-" "1,2-phenylenebis(dimethylsilane)" "(2-dimethylsilylphenyl)-dimethylsilane" "silane,1,2-phenylenebis[dimethyl- (9ci);silane, o-phenylenebis[dimethyl- (7ci,8ci);1,2-bis(dimethylsilyl)benzene;o-bis(dimethylsilyl)benzene;o-phenylenebis(dimethylsilane);" );
gibbsFormation
{
    dHf_298   -136290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31340.0
    phase     gas;
}
