/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloropropane  (C3H7Cl, CAS 540-54-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloropropane;
formula     C3H7Cl;
CAS         540-54-5;
InChIKey    SNMVRZFUUCLYTO-UHFFFAOYSA-N;
MW          78.539;      // g/mol [origin=calculated method=formula-sum]
Tc          477.37;      // K   [origin=predictive method=joback]
Pc          42.002;      // bar [origin=predictive method=joback]
omega       0.2232;      // -   [origin=predictive method=lee-kesler]
Tb          305.67;      // K   [origin=predictive method=joback]
HvapTb      26657.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.052 0.29562 -0.0001598 3.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylpropane" "propyl chloride" "propane, 1-chloro-" "n-propyl chloride" "1-chloro-propane" "chloropropane" "chloromethylethane" "1-propyl chloride" "1-chloropropane;propyl chloride;n-propyl chloride;" );
gibbsFormation
{
    dHf_298   -120990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     306.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-37550.0
    phase     gas;
}
