/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenedicarboxylic acid, polymer with 1,6-hexanediamine and 5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethylcyclohexane  (C26H40N4O6, CAS 71463-64-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BenzenedicarboxylicAcidPolymerWith16HexanediamineAnd5Isocy;
formula     C26H40N4O6;
CAS         71463-64-4;
InChIKey    VNAXYTYNXKHLHC-UHFFFAOYSA-N;
MW          504.628;      // g/mol [origin=calculated method=formula-sum]
Tc          1744.63;      // K   [origin=predictive method=joback]
Pc          11.850;      // bar [origin=predictive method=joback]
omega       0.9891;      // -   [origin=predictive method=lee-kesler]
Tb          1409.05;      // K   [origin=predictive method=joback]
HvapTb      149179.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2NH2; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group dCd; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 2; } { group dO_oth; count 2; } { group NH2; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid;hexane-1,6-diamine;5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethyl-cyclohexane" "isophthalic acid, hexamethylene diamine, isophorone diamine polymer" );
