/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,4-trimethyl-3-(3-oxo-1-butenyl)cyclohex-2-en-1-one  (C13H18O2, CAS 27185-77-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        244Trimethyl33Oxo1ButenylCyclohex2En1One;
formula     C13H18O2;
CAS         27185-77-9;
InChIKey    OBHGOXFSRVNKBS-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          883.45;      // K   [origin=predictive method=joback]
Pc          23.565;      // bar [origin=predictive method=joback]
omega       0.6669;      // -   [origin=predictive method=lee-kesler]
Tb          651.80;      // K   [origin=predictive method=joback]
HvapTb      56377.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.54 1.30158 -0.0009713 3.3086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dC_ring; count 2; } { group CdO; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,4-trimethyl-3-(3-oxidanylidenebut-1-enyl)cyclohex-2-en-1-one" "(e)-2,4,4-trimethyl-3-(3-oxo-1-butenyl)cyclohex-2-en-1-one" "2-cyclohexen-1-one,2,4,4-trimethyl-3-(3-oxo-1-buten-1-yl)-" "2-cyclohexen-1-one,2,4,4-trimethyl-3-[(1e)-3-oxo-1-buten-1-yl]-" "2-cyclohexen-1-one,2,4,4-trimethyl-3-(3-oxo-1-butenyl)- (8ci,9ci);2,4,4-trimethyl-3-(3-oxo-1-butenyl)-2-cyclohexen-1-one; 3-keto-b-ionone" "2-cyclohexen-1-one,2,4,4-trimethyl-3-(3-oxo-1-butenyl)-, (e)- (8ci); 2-cyclohexen-1-one, 2,4,4-trimethyl-3-[(1e)-3-oxo-1-butenyl]-(9ci); (e)-3-oxo-b-ionone;3-oxo-b-ionone; trans-3-oxo-b-ionone; trans-3-keto-b-ionone" );
standardThermochemistry
{
    dHf_298   -340310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83050.0
}
