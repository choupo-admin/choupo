/*--------------------------------*- Choupo -*-----------------------*\
  Component: dioxaphetyl butyrate  (C22H27NO3, CAS 467-86-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dioxaphetylButyrate;
formula     C22H27NO3;
CAS         467-86-7;
InChIKey    LQGIXNQCOXNCRP-UHFFFAOYSA-N;
MW          353.462;      // g/mol [origin=calculated method=formula-sum]
Tc          1109.74;      // K   [origin=predictive method=joback]
Pc          16.769;      // bar [origin=predictive method=joback]
omega       0.9576;      // -   [origin=predictive method=lee-kesler]
Tb          870.65;      // K   [origin=predictive method=joback]
HvapTb      82348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.777 2.28612 -0.0015941 4.128e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group FCH2O; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 4-morpholin-4-yl-2,2-diphenyl-butanoate" "spasmoxal" "amidalgon" "4-morpholinebutanoic acid, .alpha.,.alpha.-diphenyl-, ethyl ester" "dioxaphetyli butyras" "butyrate de dioxaphetyl [inn-french]" "diossafetile butirrato" "butirato de dioxafetilo" "butyrate de dioxaphetyl" "diossafetile butirrato [dcit]" "dioxaphetyli butyras [inn-latin]" "ethyl 4-morpholin-4-yl-2,2-diphenylbutanoate" );
gibbsFormation
{
    dHf_298   -334030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     769.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120570.0
    phase     gas;
}
