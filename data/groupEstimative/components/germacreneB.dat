/*--------------------------------*- Choupo -*-----------------------*\
  Component: germacrene b  (C15H24, CAS 15423-57-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        germacreneB;
formula     C15H24;
CAS         15423-57-1;
InChIKey    GXEGJTGWYVZSNR-SJRHNVSNSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          827.53;      // K   [origin=predictive method=joback]
Pc          19.859;      // bar [origin=predictive method=joback]
omega       0.4586;      // -   [origin=predictive method=lee-kesler]
Tb          598.90;      // K   [origin=predictive method=joback]
HvapTb      53185.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.21 1.23048 -0.00055428 4.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH=C; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 2; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1e,5e)-1,5-dimethyl-8-propan-2-ylidene-cyclodeca-1,5-diene" "(e,e)-germacrene b" "trans,trans-germacrene b" "germacra-1(10),4,7(11)-triene" "(e,e)-germacra-1(10),4,7(11)-triene" "(1e,4e)-germacra-1(10),4,7(11)-triene" "1,5-dimethyl-8-(1-methylethylidene)-1,5-cyclodecadiene" "(1e,5e)-8-isopropylidene-1,5-dimethylcyclodeca-1,5-diene" "(1e,5e)-1,5-dimethyl-8-propan-2-ylidenecyclodeca-1,5-diene" "(1e,5e)-1,5-dimethyl-8-(propan-2-ylidene)cyclodeca-1,5-diene" "(e,e)-1,5-dimethyl-8-(1-methylethylidene)-1,5-cyclodecadiene" );
gibbsFormation
{
    dHf_298   -144050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     712.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136750.0
    phase     gas;
}
