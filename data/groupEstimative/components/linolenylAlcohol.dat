/*--------------------------------*- Choupo -*-----------------------*\
  Component: linolenyl alcohol  (C18H32O, CAS 506-44-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        linolenylAlcohol;
formula     C18H32O;
CAS         506-44-5;
InChIKey    IKYKEVDKGZYRMQ-PDBXOOCHSA-N;
MW          264.453;      // g/mol [origin=calculated method=formula-sum]
Tc          889.65;      // K   [origin=predictive method=joback]
Pc          13.738;      // bar [origin=predictive method=joback]
omega       1.0755;      // -   [origin=predictive method=lee-kesler]
Tb          716.10;      // K   [origin=predictive method=joback]
HvapTb      72215.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.729 1.80782 -0.0012372 3.55e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH=CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH; count 6; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(9z,12z,15z)-octadeca-9,12,15-trien-1-ol" "(9z,12z,15z)-9,12,15-octadecatrien-1-ol" "9,12,15-octadecatrien-1-ol, (9z,12z,15z)-" "9,12,15-octadecatrienol" );
gibbsFormation
{
    dHf_298   -215420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     888.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=204520.0
    phase     gas;
}
