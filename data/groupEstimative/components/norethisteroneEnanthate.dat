/*--------------------------------*- Choupo -*-----------------------*\
  Component: norethisterone enanthate  (C27H38O3, CAS 3836-23-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norethisteroneEnanthate;
formula     C27H38O3;
CAS         3836-23-5;
InChIKey    APTGJECXMIKIET-WOSSHHRXSA-N;
MW          410.598;      // g/mol [origin=calculated method=formula-sum]
Tc          1217.33;      // K   [origin=predictive method=joback]
Pc          11.632;      // bar [origin=predictive method=joback]
omega       0.9066;      // -   [origin=predictive method=lee-kesler]
Tb          977.11;      // K   [origin=predictive method=joback]
HvapTb      85754.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-238.635 3.22274 -0.00262577 9.2499e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8r,9s,10r,13s,14s,17r)-17-ethynyl-13-methyl-3-oxidanylidene-1,2,6,7,8,9,10,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-17-yl] heptanoate" "noristerat" "norethisterone enantate" "norethindrone enanthate" "norlutin enanthate" "nee" "norethisterone oenanthate" "norigest" "sovel" "17alpha-ethynyl-17beta-heptanoyloxy-4-estren-3-one" "noristerat (tn)" "17alpha-ethinyl-19-nortestosterone enanthate" );
standardThermochemistry
{
    dHf_298   -467180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     899.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143000.0
}
