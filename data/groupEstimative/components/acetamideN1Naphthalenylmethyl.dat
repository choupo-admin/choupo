/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetamide, n-(1-naphthalenylmethyl)-  (C13H13NO, CAS 19351-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetamideN1Naphthalenylmethyl;
formula     C13H13NO;
CAS         19351-91-8;
InChIKey    SSOWOQCKTBJMET-UHFFFAOYSA-N;
MW          199.253;      // g/mol [origin=calculated method=formula-sum]
Tc          883.75;      // K   [origin=predictive method=joback]
Pc          29.893;      // bar [origin=predictive method=joback]
omega       0.7925;      // -   [origin=predictive method=lee-kesler]
Tb          651.72;      // K   [origin=predictive method=joback]
HvapTb      62292.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.829 1.14492 -0.00081418 2.2666e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 7; } { group AC; count 3; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(naphthalen-1-ylmethyl)ethanamide" "n-(1-naphthylmethyl)acetamide" "n-(naphthalen-1-ylmethyl)acetamide" );
standardThermochemistry
{
    dHf_298   45370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=228480.0
}
