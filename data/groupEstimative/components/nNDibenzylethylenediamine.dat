/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-dibenzylethylenediamine  (C16H20N2, CAS 140-28-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDibenzylethylenediamine;
formula     C16H20N2;
CAS         140-28-3;
InChIKey    JUHORIMYRDESRB-UHFFFAOYSA-N;
MW          240.35;      // g/mol [origin=calculated method=formula-sum]
Tc          945.94;      // K   [origin=predictive method=joback]
Pc          23.428;      // bar [origin=predictive method=joback]
omega       0.8962;      // -   [origin=predictive method=lee-kesler]
Tb          719.38;      // K   [origin=predictive method=joback]
HvapTb      68634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.886 1.5184 -0.0010062 2.512e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group ACCH2; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-bis(phenylmethyl)ethane-1,2-diamine" "benzathine" "dbed" "benzatin" "1,2-bis(benzylamino)ethane" "1,2-ethanediamine, n,n'-bis(phenylmethyl)-" "usaf do-53" "ethylenediamine, n,n'-dibenzyl-" "n,n'-dibenzylethane-1,2-diamine" "n1,n2-dibenzylethane-1,2-diamine" "n,n'-bis(phenylmethyl)-1,2-ethanediamine" "1,2-ethanediamine, n1,n2-bis(phenylmethyl)-" );
gibbsFormation
{
    dHf_298   206430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=487440.0
    phase     gas;
}
