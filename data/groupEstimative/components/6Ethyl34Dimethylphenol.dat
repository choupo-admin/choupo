/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-ethyl-3,4-dimethylphenol  (C10H14O, CAS 2219-78-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Ethyl34Dimethylphenol;
formula     C10H14O;
CAS         2219-78-5;
InChIKey    ZUDAICPAUJSPHK-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          766.35;      // K   [origin=predictive method=joback]
Pc          33.490;      // bar [origin=predictive method=joback]
omega       0.6158;      // -   [origin=predictive method=lee-kesler]
Tb          545.66;      // K   [origin=predictive method=joback]
HvapTb      54468.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.429 0.91056 -0.00067368 2.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-4,5-dimethyl-phenol" "3,4-xylenol, 6-ethyl-" "2-ethyl-4,5-dimethylphenol" "phenol, 2-ethyl-4,5-dimethyl-" "3,4-dimethyl-6-ethylphenol" "3, 6-ethyl-" "4,5-dimethyl-2-ethylphenol" "phenol,2-ethyl-4,5-dimethyl-" "3,4-dimethyl-6-ethylphenole" "1-hydroxy-3,4-dimethyl-6-ethylbenzene" );
standardThermochemistry
{
    dHf_298   -213450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28150.0
}
