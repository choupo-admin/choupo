/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(2-hydroxyethyl)imino]diethane-2,1-diyl diacetate  (C10H19NO5, CAS 64897-90-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyethylIminoDiethane21DiylDiacetate;
formula     C10H19NO5;
CAS         64897-90-1;
InChIKey    NBNYBDWTJKPKGR-UHFFFAOYSA-N;
MW          233.264;      // g/mol [origin=calculated method=formula-sum]
Tc          818.80;      // K   [origin=predictive method=joback]
Pc          23.158;      // bar [origin=predictive method=joback]
omega       1.3201;      // -   [origin=predictive method=lee-kesler]
Tb          649.46;      // K   [origin=predictive method=joback]
HvapTb      71390.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.216 1.00214 -0.000474 4.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group OH; count 1; } { group CH3COO; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group OH; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-acetyloxyethyl(2-hydroxyethyl)amino]ethyl ethanoate" "ethanol, 2,2'-((2-hydroxyethyl)imino)bis-, 1,1'-diacetate" "ethanol, 2,2'-[(2-hydroxyethyl)imino]bis-, 1,1'-diacetate" "ethanol, 2,2',2''-nitrilotri-, diacetate (ester)" "2,2'-((2-hydroxyethyl)imino)bisethyl 1,1'-diacetate" "2-[2-acetyloxyethyl(2-hydroxyethyl)amino]ethyl acetate" );
gibbsFormation
{
    dHf_298   -968990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     715.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-613460.0
    phase     gas;
}
