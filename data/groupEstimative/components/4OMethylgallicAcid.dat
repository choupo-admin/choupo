/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-o-methylgallic acid  (C8H8O5, CAS 4319-02-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4OMethylgallicAcid;
formula     C8H8O5;
CAS         4319-02-2;
InChIKey    UBXDWYFLYYJQFR-UHFFFAOYSA-N;
MW          184.147;      // g/mol [origin=calculated method=formula-sum]
Tc          986.22;      // K   [origin=predictive method=joback]
Pc          59.172;      // bar [origin=predictive method=joback]
omega       1.3777;      // -   [origin=predictive method=lee-kesler]
Tb          743.47;      // K   [origin=predictive method=joback]
HvapTb      81942.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.73 0.92222 -0.00084988 3.24e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACOH; count 2; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxy-3,5-bis(oxidanyl)benzoic acid" "3,5-dihydroxy-4-methoxybenzoic acid" "5-hydroxyisovanillic acid" "4-methoxy-3,5-dihydroxybenzoic acid" "3,5-dihydroxy-4-methoxy-benzoic acid" "3,5-dihydroxy-p-anisic acid" "3,5-dihydroxy-4-methoxybenzoes" "benzoic acid, 3,5-dihydroxy-4-methoxy-" "4-methoxygallic acid" "ambap4319-02-2" "3,5-dihydroxy-4-methoxybenzoate" "4-methoxy-3,5-dihydroxybenzoate" );
gibbsFormation
{
    dHf_298   -820500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-638890.0
    phase     gas;
}
