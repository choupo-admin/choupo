/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butyl-6-tert-octyl-o-cresol  (C19H32O, CAS 71889-15-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButyl6TertOctylOCresol;
formula     C19H32O;
CAS         71889-15-1;
InChIKey    NRWUHKORTFMBBF-UHFFFAOYSA-N;
MW          276.464;      // g/mol [origin=calculated method=formula-sum]
Tc          964.94;      // K   [origin=predictive method=joback]
Pc          15.561;      // bar [origin=predictive method=joback]
omega       0.7253;      // -   [origin=predictive method=lee-kesler]
Tb          741.89;      // K   [origin=predictive method=joback]
HvapTb      70614.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.029 2.14308 -0.00167868 5.394e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 1; } { group C; count 3; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group CH2; count 1; } { group C; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-tert-butyl-2-methyl-6-(2,4,4-trimethylpentan-2-yl)phenol" "phenol, 4-(1,1-dimethylethyl)-2-methyl-6-(1,1,3,3-tetramethylbutyl)-" "6-(1,1,3,3-tetramethylbutyl)-4-tert-butyl-2-cresol" );
gibbsFormation
{
    dHf_298   -425460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     687.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56150.0
    phase     gas;
}
