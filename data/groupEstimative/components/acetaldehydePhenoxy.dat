/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetaldehyde, phenoxy-  (C8H8O2, CAS 2120-70-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetaldehydePhenoxy;
formula     C8H8O2;
CAS         2120-70-9;
InChIKey    XFFILAFLGDUMBF-UHFFFAOYSA-N;
MW          136.15;      // g/mol [origin=calculated method=formula-sum]
Tc          694.45;      // K   [origin=predictive method=joback]
Pc          39.160;      // bar [origin=predictive method=joback]
omega       0.5230;      // -   [origin=predictive method=lee-kesler]
Tb          480.40;      // K   [origin=predictive method=joback]
HvapTb      44808.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.389 0.5962 -0.0003246 5.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenoxyethanal" "2-phenoxyacetaldehyde" "cortex aldehyde" "phenoxyacetaldehyde" "acetaldehyde, 2-phenoxy-" "phenoxy-acetaldehyde" "acetaldehyde,2-phenoxy-" );
gibbsFormation
{
    dHf_298   -189720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75630.0
    phase     gas;
}
