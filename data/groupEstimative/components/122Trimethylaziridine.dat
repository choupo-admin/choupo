/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,2-trimethylaziridine  (C5H11N, CAS 23132-47-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        122Trimethylaziridine;
formula     C5H11N;
CAS         23132-47-0;
InChIKey    DVDMSISHJUNIAQ-UHFFFAOYSA-N;
MW          85.15;      // g/mol [origin=calculated method=formula-sum]
Tc          506.82;      // K   [origin=predictive method=joback]
Pc          41.623;      // bar [origin=predictive method=joback]
omega       0.2698;      // -   [origin=predictive method=lee-kesler]
Tb          329.15;      // K   [origin=predictive method=joback]
HvapTb      27357.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.46 1.05516 -0.00116 5.129e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group C_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aziridine,1,2,2-trimethyl-" );
standardThermochemistry
{
    dHf_298   15200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     326.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=169360.0
}
