/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-bis(chloromethyl)-4-lauryltoluene  (C21H34Cl2, CAS 68833-59-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26BisChloromethyl4Lauryltoluene;
formula     C21H34Cl2;
CAS         68833-59-0;
InChIKey    FKRMEMVMXFURIB-UHFFFAOYSA-N;
MW          357.403;      // g/mol [origin=calculated method=formula-sum]
Tc          990.98;      // K   [origin=predictive method=joback]
Pc          10.950;      // bar [origin=predictive method=joback]
omega       0.8714;      // -   [origin=predictive method=lee-kesler]
Tb          796.56;      // K   [origin=predictive method=joback]
HvapTb      75372.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.573 1.75504 -0.00098948 2.075e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloromethyl)-5-dodecyl-2-methyl-benzene" "1,3-bis(chloromethyl)-5-dodecyl-2-methylbenzene" "2,6-bis(chloromethyl)-4-dodecyltoluene" "benzene, 1,3-bis(chloromethyl)-5-dodecyl-2-methyl-" "5-dodecyl-2-methyl-1,3-bis(xylyl chloride)" );
gibbsFormation
{
    dHf_298   -306130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     915.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185600.0
    phase     gas;
}
