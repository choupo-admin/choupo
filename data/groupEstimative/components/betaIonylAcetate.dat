/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-ionyl acetate  (C15H24O2, CAS 22030-19-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaIonylAcetate;
formula     C15H24O2;
CAS         22030-19-9;
InChIKey    WODKSVNXBYBTQC-UHFFFAOYSA-N;
MW          236.355;      // g/mol [origin=calculated method=formula-sum]
Tc          845.12;      // K   [origin=predictive method=joback]
Pc          18.310;      // bar [origin=predictive method=joback]
omega       0.6368;      // -   [origin=predictive method=lee-kesler]
Tb          633.65;      // K   [origin=predictive method=joback]
HvapTb      56855.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.42 1.639 -0.0012514 4.191e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH3COO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2,6,6-trimethylcyclohexen-1-yl)but-3-en-2-yl ethanoate" "3-buten-2-ol, 4-(2,6,6-trimethyl-1-cyclohexen-1-yl)-, 2-acetate" "3-buten-2-ol, 4-(2,6,6-trimethyl-1-cyclohexen-1-yl)-, acetate" "ionyl acetate, beta-" "beta-lonyl acetate" "4-(2,6,6-trimethylcyclohexen-1-yl)but-3-en-2-yl acetate" "4-(2,6,6-trimethyl-1-cyclohexen-1-yl)-3-buten-2-yl acetate" );
standardThermochemistry
{
    dHf_298   -453870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     764.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-127510.0
}
