/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-androstene-3|a,17|a-diol  (C19H30O2, CAS 1852-61-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Androstene3A17ADiol;
formula     C19H30O2;
CAS         1852-61-5;
InChIKey    BTTWKVFKBPAFDK-KYQPOWKGSA-N;
MW          290.447;      // g/mol [origin=calculated method=formula-sum]
Tc          1073.61;      // K   [origin=predictive method=joback]
Pc          20.642;      // bar [origin=predictive method=joback]
omega       1.3169;      // -   [origin=predictive method=lee-kesler]
Tb          857.60;      // K   [origin=predictive method=joback]
HvapTb      89483.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-290.46 2.82124 -0.00253864 9.729e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 5; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,8r,9s,10r,13s,14s,17s)-10,13-dimethyl-2,3,6,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthrene-3,17-diol" "androst-4-ene-3,17-diol" "4-androstene-3,17-diol" "4-androstene-3alpha,17beta-diol" "(3alpha,17beta)-androst-4-ene-3,17-diol" );
gibbsFormation
{
    dHf_298   -463780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4180.0
    phase     gas;
}
