/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanol, 1-butyl-  (C10H20O, CAS 5445-30-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanol1Butyl;
formula     C10H20O;
CAS         5445-30-7;
InChIKey    RCHLXMOXBJRGNX-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          733.71;      // K   [origin=predictive method=joback]
Pc          29.666;      // bar [origin=predictive method=joback]
omega       0.7788;      // -   [origin=predictive method=lee-kesler]
Tb          540.37;      // K   [origin=predictive method=joback]
HvapTb      53811.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.507 1.40182 -0.0011642 4.252e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butylcyclohexan-1-ol" "1-n-butylcyclohexanol" "1-butylcyclohexanol" "1-butyl-cyclohexan-1-ol" "agn-pc-03v8po" );
gibbsFormation
{
    dHf_298   -332400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-84540.0
    phase     gas;
}
