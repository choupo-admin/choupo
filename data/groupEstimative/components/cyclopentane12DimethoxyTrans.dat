/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentane, 1,2-dimethoxy-, trans-  (C7H14O2, CAS 29887-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentane12DimethoxyTrans;
formula     C7H14O2;
CAS         29887-56-7;
InChIKey    YLBQPTZQSYROOF-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          608.25;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       0.3729;      // -   [origin=predictive method=lee-kesler]
Tb          415.21;      // K   [origin=predictive method=joback]
HvapTb      35944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.02 0.64764 -0.000207 -2.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dimethoxycyclopentane" "trans-1,2-dimethoxycyclopentane" "cyclopentane, 1,2-dimethoxy-, cis-" "agn-pc-00mld0" "cyclopentane, 1,2-dimethoxy-" "cyclopentane, 1,2-dimethoxy-,cis-" );
gibbsFormation
{
    dHf_298   -412110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-173100.0
    phase     gas;
}
