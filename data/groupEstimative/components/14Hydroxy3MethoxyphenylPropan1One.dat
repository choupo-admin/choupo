/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-hydroxy-3-methoxyphenyl)propan-1-one  (C10H12O3, CAS 1835-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Hydroxy3MethoxyphenylPropan1One;
formula     C10H12O3;
CAS         1835-14-9;
InChIKey    FBGXENQFSMMBNY-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          841.44;      // K   [origin=predictive method=joback]
Pc          35.986;      // bar [origin=predictive method=joback]
omega       0.8488;      // -   [origin=predictive method=lee-kesler]
Tb          616.97;      // K   [origin=predictive method=joback]
HvapTb      62962.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.869 0.87884 -0.00061102 1.7766e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH2CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-methoxy-4-oxidanyl-phenyl)propan-1-one" "3-methoxy-4-hydroxypropiophenone" "4-hydroxy-3-methoxypropiophenone" "1-propanone, 1-(4-hydroxy-3-methoxyphenyl)-" "4'-hydroxy-3'-methoxypropiophenone" "1-propanone, 1-(4-hydroxy-3-methoxyphenyl)" "propiovanillone" "propioguaiacol" "propioguaiacone" "2-methoxy-4-propionyl phenol" "fbgxenqfsmmbny-uhfffaoysa-" "propiophenone, 4'-hydroxy-3'-methoxy" );
standardThermochemistry
{
    dHf_298   -446780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-252440.0
}
