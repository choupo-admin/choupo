/*--------------------------------*- Choupo -*-----------------------*\
  Component: lisadimate  (C10H13NO4, CAS 136-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lisadimate;
formula     C10H13NO4;
CAS         136-44-7;
InChIKey    WHQOKFZWSDOTQP-UHFFFAOYSA-N;
MW          211.217;      // g/mol [origin=calculated method=formula-sum]
Tc          974.01;      // K   [origin=predictive method=joback]
Pc          38.675;      // bar [origin=predictive method=joback]
omega       1.7564;      // -   [origin=predictive method=lee-kesler]
Tb          774.73;      // K   [origin=predictive method=joback]
HvapTb      91810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.992 0.8964 -0.00049716 8.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 2; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(oxidanyl)propyl 4-azanylbenzoate" "glyceryl paba" "glycerol 1-(p-aminobenzoate)" "1,2,3-propanetriol, 1-(4-aminobenzoate)" "glyceryl p-aminobenzoate" "glyceryl paraaminobenzoate" "lisadimatum [inn-latin]" "glyceryl para-aminobenzoate" "monoglycerol p-aminobenzoate" "glycerol 1-(4-aminobenzoate)" "2,3-dihydroxypropyl 4-aminobenzoate" "(+-)-glycerol 1-(p-aminobenzoate)" );
gibbsFormation
{
    dHf_298   -617900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     628.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-383900.0
    phase     gas;
}
