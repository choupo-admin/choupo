/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r,2r)-(+)-1,2-diphenylethylenediamine  (C14H16N2, CAS 35132-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2r12Diphenylethylenediamine;
formula     C14H16N2;
CAS         35132-20-8;
InChIKey    PONXTPCRRASWKW-ZIAGYGMSSA-N;
MW          212.296;      // g/mol [origin=calculated method=formula-sum]
Tc          979.58;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       0.7775;      // -   [origin=predictive method=lee-kesler]
Tb          717.46;      // K   [origin=predictive method=joback]
HvapTb      71816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.03 1.3116 -0.0008934 2.274e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CHNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2r)-1,2-diphenylethane-1,2-diamine" "(1r,2r)-(+)-1,2-diamino-1,2-diphenylethane" "(1r,2r)-1,2-diphenyl-1,2-ethanediamine" "(+)-1,2-diphenylethylenediamine" "(1r,2r)-(+)-1,2-diphenyl-1,2-ethanediamine" "(1r,2r)-(+)-1,2-diphenyl-1,2-ethane diamine" "(1r,2r)-1,2-diphenylethylenediamine" "(r,r)-(+)-1,2-diphenylethylenediamine" "(1r,2r)-(-)-1,2-diphenylethylenediamine" "(1r,2r)-1,2-diamino-1,2-diphenylethane" "(1r,2r)-1,2-diphenyl-ethane-1,2-diamine" "1,2-ethanediamine, 1,2-diphenyl-, (1r,2r)-" );
gibbsFormation
{
    dHf_298   197790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=419840.0
    phase     gas;
}
