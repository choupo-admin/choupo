/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(4-carboxyphenoxy)ethane  (C16H14O6, CAS 3753-05-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Bis4CarboxyphenoxyEthane;
formula     C16H14O6;
CAS         3753-05-7;
InChIKey    VAXBLYWAVAIJJJ-UHFFFAOYSA-N;
MW          302.282;      // g/mol [origin=calculated method=formula-sum]
Tc          1206.26;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       1.5065;      // -   [origin=predictive method=lee-kesler]
Tb          964.86;      // K   [origin=predictive method=joback]
HvapTb      96234.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.332 1.2222 -0.00069812 1.268e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group CH2O; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(4-carboxyphenoxy)ethoxy]benzoic acid" "4,4'-[ethane-1,2-diylbis(oxy)]dibenzoic acid" "benzoic acid, 4,4'-(1,2-ethanediylbis(oxy))bis-" "benzoic acid, 4,4'-[1,2-ethanediylbis(oxy)]bis-" "4,4'-(1,2-ethanediylbis(oxy))bisbenzoic acid" "ethylene glycol bis(4-carboxyphenyl) ether" "benzoic acid,4,4'-[1,2-ethanediylbis(oxy)]bis-" "benzoicacid, 4,4'-(ethylenedioxy)di- (6ci,7ci,8ci); 1,2-bis(4-carboxyphenoxy)ethane;1,2-bis(p-carboxyphenoxy)ethane; 1,2-diphenoxyethane-4,4'-dicarboxylic acid;4,4'-(ethylenedioxy)dibenzoic acid; 4,4'-ethylenedioxybis[benzoic acid]; a,a'-bi-p-anisic acid" );
standardThermochemistry
{
    dHf_298   -888430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     682.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-608420.0
}
