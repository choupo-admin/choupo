/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetratriacontyl methacrylate  (C38H74O2, CAS 67905-42-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetratriacontylMethacrylate;
formula     C38H74O2;
CAS         67905-42-4;
InChIKey    OIUCPPFBFOLPIO-UHFFFAOYSA-N;
MW          563.008;      // g/mol [origin=calculated method=formula-sum]
Tc          1480.73;      // K   [origin=predictive method=joback]
Pc          4.315;      // bar [origin=predictive method=joback]
omega       -0.1660;      // -   [origin=predictive method=lee-kesler]
Tb          1123.82;      // K   [origin=predictive method=joback]
HvapTb      106999.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.927 3.53894 -0.001974 4.031e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 33; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 33; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetratriacontyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, tetratriacontyl ester" "cetostearyl methacrylate" );
gibbsFormation
{
    dHf_298   -1029290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1678.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38000.0
    phase     gas;
}
