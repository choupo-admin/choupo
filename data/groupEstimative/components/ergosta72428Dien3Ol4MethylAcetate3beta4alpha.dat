/*--------------------------------*- Choupo -*-----------------------*\
  Component: ergosta-7,24(28)-dien-3-ol, 4-methyl-, acetate, (3beta,4alpha)-  (C31H50O2, CAS 55399-28-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ergosta72428Dien3Ol4MethylAcetate3beta4alpha;
formula     C31H50O2;
CAS         55399-28-5;
InChIKey    ATSVMNCIUVPBNE-WCKBIBOTSA-N;
MW          454.739;      // g/mol [origin=calculated method=formula-sum]
Tc          1227.59;      // K   [origin=predictive method=joback]
Pc          8.154;      // bar [origin=predictive method=joback]
omega       0.7245;      // -   [origin=predictive method=lee-kesler]
Tb          997.03;      // K   [origin=predictive method=joback]
HvapTb      88569.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-286.648 3.80374 -0.00301224 1.029e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 9; } { group CH; count 8; } { group C; count 2; } { group CH2=C; count 1; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 2; } { group CH; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 6; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,4s,9r,10s,13r,14r,17r)-4,10,13-trimethyl-17-[(2r)-6-methyl-5-methylidene-heptan-2-yl]-2,3,4,5,6,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] ethanoate" );
standardThermochemistry
{
    dHf_298   -639540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1051.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135190.0
}
