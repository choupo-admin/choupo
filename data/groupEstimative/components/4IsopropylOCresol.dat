/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropyl-o-cresol  (C10H14O, CAS 1740-97-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4IsopropylOCresol;
formula     C10H14O;
CAS         1740-97-2;
InChIKey    WYXXLXHHWYNKJF-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          764.80;      // K   [origin=predictive method=joback]
Pc          34.399;      // bar [origin=predictive method=joback]
omega       0.5814;      // -   [origin=predictive method=lee-kesler]
Tb          540.24;      // K   [origin=predictive method=joback]
HvapTb      53418.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.41 0.97596 -0.00074392 2.41e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-4-propan-2-yl-phenol" "4-isopropyl-2-methylphenol" "2-methyl-4-propan-2-ylphenol" "phenol, 2-methyl-4-(1-methylethyl)-" "2-methyl-4-(propan-2-yl)phenol" );
gibbsFormation
{
    dHf_298   -207260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-20960.0
    phase     gas;
}
