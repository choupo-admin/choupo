/*--------------------------------*- Choupo -*-----------------------*\
  Component: urochloralic acid  (C8H11Cl3O7, CAS 97-25-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        urochloralicAcid;
formula     C8H11Cl3O7;
CAS         97-25-6;
InChIKey    IQOASJJGUQMXDW-GHQVIJFQSA-N;
MW          325.519;      // g/mol [origin=calculated method=formula-sum]
Tc          1182.11;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       2.1052;      // -   [origin=predictive method=lee-kesler]
Tb          963.99;      // K   [origin=predictive method=joback]
HvapTb      118575.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.261 1.0127 -0.0005427 7.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 4; } { group OH; count 3; } { group CH2O; count 1; } { group CH-O; count 1; } { group COOH; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group CH_ring; count 5; } { group Cl; count 3; } { group OH; count 3; } { group O; count 1; } { group O_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,3s,4s,5r,6r)-3,4,5-tris(oxidanyl)-6-[2,2,2-tris(chloranyl)ethoxy]oxane-2-carboxylic acid" "trichloroethanol glucuronide" "trichloroethyl " "a-d-glucuronide" "2,2,2-trichloroethanol glucuronide" "a," "a," "a-trichloroethyl-" "a-d-glucuronic acid" "2,2,2-trichloroethyl " "a-d-glucopyranosiduronic acid" "2,2,2-trichloroethyl beta-d-glucopyranosiduronic acid" "beta-d-glucopyranosiduronic acid, 2,2,2-trichloroethyl" "(2s,3s,4s,5r,6r)-3,4,5-trihydroxy-6-(2,2,2-trichloroethoxy)oxane-2-carboxylic acid" "uca" );
gibbsFormation
{
    dHf_298   -1362640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-968350.0
    phase     gas;
}
