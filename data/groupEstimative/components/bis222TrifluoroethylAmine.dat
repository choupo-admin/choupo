/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2,2,2-trifluoroethyl)amine  (C4H5F6N, CAS 407-01-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis222TrifluoroethylAmine;
formula     C4H5F6N;
CAS         407-01-2;
InChIKey    GTJGHXLFPMOKCE-UHFFFAOYSA-N;
MW          181.079;      // g/mol [origin=calculated method=formula-sum]
Tc          469.09;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       0.5072;      // -   [origin=predictive method=lee-kesler]
Tb          330.45;      // K   [origin=predictive method=joback]
HvapTb      23440.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.358 0.7824 -0.0006844 2.243e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2NH; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 2; } { group F; count 6; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(fluoranyl)-n-[2,2,2-tris(fluoranyl)ethyl]ethanamine" "2,2,2-trifluoro-n-(2,2,2-trifluoroethyl)ethanamine" "ethanamine, 2,2,2-trifluoro-n-(2,2,2-trifluoroethyl)-" "bis(trifluoroethyl)amine" "1,1,15,5,5-hexafluoro-3-azapentane" "1,1,1,5,5,5-hexafluoro-3-azapentane" "ethanamine,2,2,2-trifluoro-n-(2,2,2-trifluoroethyl)-" "diethylamine,2,2,2,2',2',2'-hexafluoro- (7ci,8ci); bis(2,2,2-trifluoroethyl)amine;n,n-bis(2,2,2-trifluoroethyl)amine" );
standardThermochemistry
{
    dHf_298   -1266580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1090990.0
}
