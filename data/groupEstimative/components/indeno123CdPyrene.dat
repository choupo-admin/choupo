/*--------------------------------*- Choupo -*-----------------------*\
  Component: indeno[1,2,3-cd]pyrene  (C22H12, CAS 193-39-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        indeno123CdPyrene;
formula     C22H12;
CAS         193-39-5;
InChIKey    SXQBHARYMNFBPS-UHFFFAOYSA-N;
MW          276.338;      // g/mol [origin=calculated method=formula-sum]
Tc          1092.77;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.9122;      // -   [origin=predictive method=lee-kesler]
Tb          829.06;      // K   [origin=predictive method=joback]
HvapTb      76418.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.11 1.9088 -0.00183068 6.932e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 10; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 12; } { group dC_ring; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o-phenylenepyrene" "1,10-(1,2-phenylene)pyrene" "indeno(1,2,3-cd)pyrene" "1,10-(o-phenylene)pyrene" "2,3-phenylenepyrene" "2,3-o-phenylenepyrene" "1,10-(ortho-phenylene)pyrene" "indeno(1,2,3-cd)pyrene [polycyclic aromatic compounds]" "indeno(1,2,3-cd)pyrene [polycyclic aromatic hydrocarbons]" "indeno[1,2,3-c,d]pyrene solution" "1,10-(1,2-phenylene)pyrene;1,10-(o-phenylene)pyrene;" );
standardThermochemistry
{
    dHf_298   557670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     332.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=729980.0
}
