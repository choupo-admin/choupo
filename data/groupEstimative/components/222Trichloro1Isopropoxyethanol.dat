/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,2-trichloro-1-isopropoxyethanol  (C5H9Cl3O2, CAS 2873-12-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222Trichloro1Isopropoxyethanol;
formula     C5H9Cl3O2;
CAS         2873-12-3;
InChIKey    CRPHMEAAZLEFAI-UHFFFAOYSA-N;
MW          207.475;      // g/mol [origin=calculated method=formula-sum]
Tc          734.00;      // K   [origin=predictive method=joback]
Pc          34.643;      // bar [origin=predictive method=joback]
omega       0.8094;      // -   [origin=predictive method=lee-kesler]
Tb          536.78;      // K   [origin=predictive method=joback]
HvapTb      56896.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.97 0.60764 -0.000407 1.012e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group OH; count 1; } { group CH-O; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group C; count 1; } { group Cl; count 3; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(chloranyl)-1-propan-2-yloxy-ethanol" "2,2,2-trichloro-1-propan-2-yloxyethanol" "ethanol,2,2,2-trichloro-1-(1-methylethoxy)-" "ethanol,2,2,2-trichloro-1-isopropoxy- (7ci,8ci); chloral 2-propanol hemiacetal; chloralisopropyl hemiacetal" );
gibbsFormation
{
    dHf_298   -497510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-288430.0
    phase     gas;
}
