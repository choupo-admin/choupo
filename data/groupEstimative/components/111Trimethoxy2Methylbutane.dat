/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1-trimethoxy-2-methylbutane  (C8H18O3, CAS 98944-42-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Trimethoxy2Methylbutane;
formula     C8H18O3;
CAS         98944-42-4;
InChIKey    QWPCHBGGMCMXPS-UHFFFAOYSA-N;
MW          162.229;      // g/mol [origin=calculated method=formula-sum]
Tc          624.39;      // K   [origin=predictive method=joback]
Pc          24.752;      // bar [origin=predictive method=joback]
omega       0.4954;      // -   [origin=predictive method=lee-kesler]
Tb          446.23;      // K   [origin=predictive method=joback]
HvapTb      38948.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.961 0.706 -0.0002534 -9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-trimethoxy-2-methyl-butane" );
standardThermochemistry
{
    dHf_298   -619140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-298120.0
}
