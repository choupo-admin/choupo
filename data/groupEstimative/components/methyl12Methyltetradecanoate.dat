/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 12-methyltetradecanoate  (C16H32O2, CAS 5129-66-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl12Methyltetradecanoate;
formula     C16H32O2;
CAS         5129-66-8;
InChIKey    BJIUDNXPLSJWKE-UHFFFAOYSA-N;
MW          256.43;      // g/mol [origin=calculated method=formula-sum]
Tc          790.54;      // K   [origin=predictive method=joback]
Pc          13.310;      // bar [origin=predictive method=joback]
omega       0.8374;      // -   [origin=predictive method=lee-kesler]
Tb          623.46;      // K   [origin=predictive method=joback]
HvapTb      58229.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.071 1.47496 -0.0007552 1.216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecanoic acid, 12-methyl-, methyl ester" "methyl 12-methylmyristate" "12-methyltetradecanoic acid methyl ester" "tetradecanoic acid,12-methyl-, methyl ester" "tetradecanoic acid, 12-methyl-, methyl ester, (s)-" "12-methyltetradecanoicacid methyl ester; methyl 12-methyltetradecanoate" );
standardThermochemistry
{
    dHf_298   -696130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     821.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-228970.0
}
