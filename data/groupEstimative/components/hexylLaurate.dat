/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexyl laurate  (C18H36O2, CAS 34316-64-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexylLaurate;
formula     C18H36O2;
CAS         34316-64-8;
InChIKey    CMBYOWLFQAFZCP-UHFFFAOYSA-N;
MW          284.484;      // g/mol [origin=calculated method=formula-sum]
Tc          835.25;      // K   [origin=predictive method=joback]
Pc          11.561;      // bar [origin=predictive method=joback]
omega       0.8897;      // -   [origin=predictive method=lee-kesler]
Tb          669.66;      // K   [origin=predictive method=joback]
HvapTb      63069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.935 1.65904 -0.0008608 1.459e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexyl dodecanoate" "dodecanoic acid, hexyl ester" "hexyl dodecanoat" "laurinsaeurehexylester" "dodecanoic acid hexyl ester" "dodecanoic acid, hexylester" "we(6:0/12:0)" "lauricacid, hexyl ester (6ci,7ci,8ci);cetiol a;crodamol hl-r;hexyl dodecanoate;hexyl laurate;kak-hl;standamul cta;n-hexyl laurate;" );
standardThermochemistry
{
    dHf_298   -732130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     908.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209690.0
}
