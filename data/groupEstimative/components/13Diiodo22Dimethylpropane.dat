/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diiodo-2,2-dimethylpropane  (C5H10I2, CAS 66688-49-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diiodo22Dimethylpropane;
formula     C5H10I2;
CAS         66688-49-1;
InChIKey    GDVIDBDQSYVBSD-UHFFFAOYSA-N;
MW          323.935;      // g/mol [origin=calculated method=formula-sum]
Tc          753.30;      // K   [origin=predictive method=joback]
Pc          33.684;      // bar [origin=predictive method=joback]
omega       0.2569;      // -   [origin=predictive method=lee-kesler]
Tb          497.05;      // K   [origin=predictive method=joback]
HvapTb      44174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.748 0.68264 -0.0005828 2e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(iodanyl)-2,2-dimethyl-propane" "propane,3-diiodo-2,2-dimethyl-" );
gibbsFormation
{
    dHf_298   -1540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110300.0
    phase     gas;
}
