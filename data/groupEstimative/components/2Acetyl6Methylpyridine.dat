/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetyl-6-methylpyridine  (C8H9NO, CAS 6940-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Acetyl6Methylpyridine;
formula     C8H9NO;
CAS         6940-57-4;
InChIKey    FPQMUQPPAYCAME-UHFFFAOYSA-N;
MW          135.166;      // g/mol [origin=calculated method=formula-sum]
Tc          755.17;      // K   [origin=predictive method=joback]
Pc          38.771;      // bar [origin=predictive method=joback]
omega       0.5136;      // -   [origin=predictive method=lee-kesler]
Tb          521.87;      // K   [origin=predictive method=joback]
HvapTb      49296.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.57 0.6312 -0.00036612 7.736e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH3CO; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group CdO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(6-methylpyridin-2-yl)ethanone" "6-acetyl-2-picoline" "ketone, methyl 6-methyl-2-pyridyl" "1-(6-methylpyridin-2-yl)ethan-1-one" "6-acetyl-2-methylpyridine" "1-(6-methyl-2-pyridinyl)ethanone" "ethanone,1-(6-methyl-2-pyridinyl)-" "1-(6-methyl-2-pyridinyl)-ethanone" "1-(6-methyl-pyridin-2-yl)-ethanone" "ethanone, 1-(6-methyl-2-pyridinyl)-" );
standardThermochemistry
{
    dHf_298   -63180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=67390.0
}
