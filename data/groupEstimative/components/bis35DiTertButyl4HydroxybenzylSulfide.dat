/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(3,5-di-tert-butyl-4-hydroxybenzyl)sulfide  (C30H46O2S, CAS 1620-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis35DiTertButyl4HydroxybenzylSulfide;
formula     C30H46O2S;
CAS         1620-93-5;
InChIKey    UDFARPRXWMDFQU-UHFFFAOYSA-N;
MW          470.756;      // g/mol [origin=calculated method=formula-sum]
Tc          1443.28;      // K   [origin=predictive method=joback]
Pc          10.372;      // bar [origin=predictive method=joback]
omega       0.9768;      // -   [origin=predictive method=lee-kesler]
Tb          1176.38;      // K   [origin=predictive method=joback]
HvapTb      117235.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.128 3.26503 -0.00256216 8.234e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group C; count 4; } { group ACH; count 4; } { group AC; count 5; } { group ACCH2; count 1; } { group ACOH; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group CH2; count 2; } { group C; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-ditert-butyl-4-[(3,5-ditert-butyl-4-oxidanyl-phenyl)methylsulfanylmethyl]phenol" "4,4'-[sulfanediylbis(methylene)]bis(2,6-di-tert-butylphenol)" "phenol, 4,4'-[thiobis(methylene)]bis[2,6-bis(1,1-dimethylethyl)-" "2,6-ditert-butyl-4-([(3,5-ditert-butyl-4-hydroxybenzyl)sulfanyl]methyl)phenol" "alpha,alpha'-thiobis(2,6-di-tert-butyl-p-cresol)" "4,4'-(thiobis(methylene))bis(2,6-di-tert-butylphenol)" "phenol,4,4'-[thiobis(methylene)]bis[2,6-bis(1,1-dimethylethyl)-" "2,6-bis(tert-butyl)-4-({[3,5-bis(tert-butyl)-4-hydroxyphenyl]methylthio}methyl )phenol" "2,6-di-tert-butyl-4-({[(3,5-di-tert-butyl-4-hydroxyphenyl)methyl]sulfanyl}methyl)phenol" "2,6-ditert-butyl-4-[(3,5-ditert-butyl-4-hydroxyphenyl)methylsulfanylmethyl]phenol" "p-cresol, a,a'-thiobis[2,6-di-tert-butyl- (7ci,8ci);3,5-di-tert-butyl-4-hydroxybenzyl monosulfide;4,4'-(thiodimethylene)bis(2,6-di-tert-butylphenol);antioxidant 4426s;bis(3,5-di-tert-4-hydroxybenzyl) monosulfide;bis(3,5-di-tert-butyl-4-hydroxybenzyl) sulfide;methene 4426s;sandant 103;tb3;tb 3 (phenol);thioalkofen mmb;a,a'-thiobis(2,6-di-tert-butyl-p-cresol);" );
standardThermochemistry
{
    dHf_298   -583100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1045.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=123260.0
}
