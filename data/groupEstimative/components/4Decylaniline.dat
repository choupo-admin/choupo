/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-decylaniline  (C16H27N, CAS 37529-30-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Decylaniline;
formula     C16H27N;
CAS         37529-30-9;
InChIKey    WGENWPANMZLPIH-UHFFFAOYSA-N;
MW          233.399;      // g/mol [origin=calculated method=formula-sum]
Tc          868.15;      // K   [origin=predictive method=joback]
Pc          17.639;      // bar [origin=predictive method=joback]
omega       0.8386;      // -   [origin=predictive method=lee-kesler]
Tb          669.87;      // K   [origin=predictive method=joback]
HvapTb      64789.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.771 1.44732 -0.00085416 1.908e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-n-decylaniline" "p-decylaniline" "4-decyphenylamine" "4-decylphenylamine" "p-n-decylaniline" "4-n-decylaniline;" "zr d10" "r318" );
gibbsFormation
{
    dHf_298   -114720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     718.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=253070.0
    phase     gas;
}
