/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylaminoethyl butyrate  (C8H17NO2, CAS 16597-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylaminoethylButyrate;
formula     C8H17NO2;
CAS         16597-65-2;
InChIKey    NCOVMJHPLAYTJS-UHFFFAOYSA-N;
MW          159.229;      // g/mol [origin=calculated method=formula-sum]
Tc          623.48;      // K   [origin=predictive method=joback]
Pc          25.430;      // bar [origin=predictive method=joback]
omega       0.6105;      // -   [origin=predictive method=lee-kesler]
Tb          453.30;      // K   [origin=predictive method=joback]
HvapTb      42852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.334 0.83296 -0.0004294 6.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH2COO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)ethyl butanoate" "butyric acid, dimethylaminoethyl ester" "2-dimethylaminoethanol butyrate" "butanoic acid, 2-(dimethylamino)ethyl ester" "2-(dimethylamino)ethyl butyrate" "butyric acid, 2-(dimethylamino)ethyl ester" "2-dimethylaminoethyl butanoate" "butanoic acid,2-(dimethylamino)ethyl ester" "butanoic acid 2-(dimethylamino)ethyl ester" );
gibbsFormation
{
    dHf_298   -458200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183110.0
    phase     gas;
}
