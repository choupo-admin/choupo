/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropenylcyclopropane  (C6H10, CAS 4663-22-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropenylcyclopropane;
formula     C6H10;
CAS         4663-22-3;
InChIKey    MKPHNILWOMCVTH-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          526.54;      // K   [origin=predictive method=joback]
Pc          38.245;      // bar [origin=predictive method=joback]
omega       0.2239;      // -   [origin=predictive method=lee-kesler]
Tb          340.18;      // K   [origin=predictive method=joback]
HvapTb      28273.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.49 0.70462 -0.000548 1.787e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-1-en-2-ylcyclopropane" "2-cyclopropyl-1-propene" "cyclopropane, (1-methylethenyl)-" "2-cyclopropylpropene" "propene, 2-cyclopropyl-" "propene, 2-cyclopropyl- (8ci)" "cyclopropane, (1-methylethenyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   21270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     290.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=139680.0
}
