/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetracosane  (C24H50, CAS 646-31-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetracosane;
formula     C24H50;
CAS         646-31-1;
InChIKey    POOSGDOYLQNASK-UHFFFAOYSA-N;
MW          338.664;      // g/mol [origin=calculated method=formula-sum]
Tc          918.31;      // K   [origin=predictive method=joback]
Pc          8.062;      // bar [origin=predictive method=joback]
omega       0.7534;      // -   [origin=predictive method=lee-kesler]
Tb          748.72;      // K   [origin=predictive method=joback]
HvapTb      69018.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.928 2.28384 -0.0012818 2.744e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 22; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 22; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-tetracosane" "lignocerane" "ai3-52698" "tricosane, methyl-" "tetracosane, analytical standard" "CH3-(CH2)22-CH3" "CH3-[CH2]22-ch3" "tetracosane; nsc 2984; n-tetracosane" "CHEMBL4172502" "NSC2984" "HY-N7933" "STL301146" );
standardThermochemistry
{
    dHf_298   -538690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1090.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=151200.0
}
