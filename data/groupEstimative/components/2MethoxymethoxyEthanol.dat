/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(methoxymethoxy)ethanol  (C4H10O3, CAS 4484-61-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethoxymethoxyEthanol;
formula     C4H10O3;
CAS         4484-61-1;
InChIKey    INFFATMFXZFLAO-UHFFFAOYSA-N;
MW          106.121;      // g/mol [origin=calculated method=formula-sum]
Tc          591.04;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       0.8382;      // -   [origin=predictive method=lee-kesler]
Tb          428.14;      // K   [origin=predictive method=joback]
HvapTb      45997.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.543 0.29142 -2.2e-06 -6.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-dioxa-1-hexanol" "methane, (2-hydroxyethoxy)methoxy-" "ethanol, 2-(methoxymethoxy)-" );
gibbsFormation
{
    dHf_298   -542560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-364020.0
    phase     gas;
}
