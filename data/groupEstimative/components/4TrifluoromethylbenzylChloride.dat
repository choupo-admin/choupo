/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-trifluoromethylbenzyl chloride  (C8H6ClF3, CAS 939-99-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TrifluoromethylbenzylChloride;
formula     C8H6ClF3;
CAS         939-99-1;
InChIKey    MCHDHQVROPEJJT-UHFFFAOYSA-N;
MW          194.58;      // g/mol [origin=calculated method=formula-sum]
Tc          643.92;      // K   [origin=predictive method=joback]
Pc          30.090;      // bar [origin=predictive method=joback]
omega       0.4232;      // -   [origin=predictive method=lee-kesler]
Tb          446.31;      // K   [origin=predictive method=joback]
HvapTb      36978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.299 0.7934 -0.00061696 1.823e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2Cl; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(chloromethyl)-4-(trifluoromethyl)benzene" "4-(trifluoromethyl)benzyl chloride" "g1r dxfff" "p-trifluoromethylbenzyl chloride" "4-(chloromethyl)benzotrifluoride" "p-(trifluoromethyl)benzyl chloride" "alpha'-chloro-alpha,alpha,alpha-trifluoro-p-xylene" "4-trifluoromethyl benzyl chloride" "4-(trifluoromethyl)benzylchloride" "i699" "4-(chloromethyl)-1-(trifluoromethyl)benzene" "939-99-1 4-trifluoromethylbenzyl chloride" );
standardThermochemistry
{
    dHf_298   -596210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-474260.0
}
