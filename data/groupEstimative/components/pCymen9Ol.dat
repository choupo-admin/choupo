/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-cymen-9-ol  (C10H14O, CAS 4371-50-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pCymen9Ol;
formula     C10H14O;
CAS         4371-50-0;
InChIKey    CLFDIFDNDWRHJF-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          749.29;      // K   [origin=predictive method=joback]
Pc          32.210;      // bar [origin=predictive method=joback]
omega       0.8225;      // -   [origin=predictive method=lee-kesler]
Tb          551.80;      // K   [origin=predictive method=joback]
HvapTb      57083.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.199 0.85534 -0.00051796 1.177e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methylphenyl)propan-1-ol" "benzeneethanol,4-dimethyl-" "agn-pc-00gt56" "phenethyl alcohol,.beta.-dimethyl-" "benzeneethanol, .beta.,4-dimethyl-" "(2s)-2-(4-methylphenyl)propan-1-ol" );
standardThermochemistry
{
    dHf_298   -182180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3160.0
}
