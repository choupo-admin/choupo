/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethyl-n'-phenylethylenediamine  (C12H20N2, CAS 1665-59-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethylNPhenylethylenediamine;
formula     C12H20N2;
CAS         1665-59-4;
InChIKey    QUMIGAREEPSVLG-UHFFFAOYSA-N;
MW          192.306;      // g/mol [origin=calculated method=formula-sum]
Tc          761.34;      // K   [origin=predictive method=joback]
Pc          24.314;      // bar [origin=predictive method=joback]
omega       0.7056;      // -   [origin=predictive method=lee-kesler]
Tb          563.45;      // K   [origin=predictive method=joback]
HvapTb      53061.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.826 1.26504 -0.0008214 2.05e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n',n'-diethyl-n-phenyl-ethane-1,2-diamine" "aniline, n-[2-(diethylamino)ethyl]-" "n,n-diethyl-n1-phenyl ethylenediamine" "1,2-ethanediamine, n,n-diethyl-n'-phenyl-" "diethyl[2-(phenylamino)ethyl]amine" "aniline, n-(2-(diethylamino)ethyl)-" "ethylenediamine, n,n-diethyl-n'-phenyl-" "n-(beta-(n,n-diethylamino)ethyl)aniline" "benzenamine, n-(2-(diethylamino)ethyl)-" "n1,n1-diethyl-n2-phenylethane-1,2-diamine" "1,2-ethanediamine, n1,n1-diethyl-n2-phenyl-" "benzenamine, n-[2-(diethylamino)ethyl]-" );
standardThermochemistry
{
    dHf_298   66520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=362740.0
}
