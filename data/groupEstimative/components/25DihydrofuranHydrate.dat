/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dihydrofuran;hydrate  (C4H8O2, CAS 14306-51-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H8O2 (delta H+2O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        25DihydrofuranHydrate;
formula     C4H8O2;
CAS         14306-51-5;
InChIKey    YJNRHMPZGAVHKK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          88.106;      // g/mol [origin=calculated method=formula-sum]
Tc          538.24;      // K   [origin=predictive method=joback]
Pc          47.042;      // bar [origin=predictive method=joback]
omega       0.1866;      // -   [origin=predictive method=lee-kesler]
Tb          337.18;      // K   [origin=predictive method=joback]
HvapTb      29866.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.07 0.483 -0.00034998 9.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group H2O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -119290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29100.0
}
