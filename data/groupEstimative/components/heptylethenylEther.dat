/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptylethenyl ether  (C9H18O, CAS 764-95-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptylethenylEther;
formula     C9H18O;
CAS         764-95-4;
InChIKey    SWZSKZZXXULJHU-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          591.22;      // K   [origin=predictive method=joback]
Pc          23.634;      // bar [origin=predictive method=joback]
omega       0.5010;      // -   [origin=predictive method=lee-kesler]
Tb          424.62;      // K   [origin=predictive method=joback]
HvapTb      37368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.216 0.77562 -0.0003777 5.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH2=CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenoxyheptane" "heptane, 1-(ethenyloxy)-" );
standardThermochemistry
{
    dHf_298   -235880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=7740.0
}
