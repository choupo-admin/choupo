/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,5,6-pentafluoro-n,n-dimethylaniline  (C8H6F5N, CAS 1801-14-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23456PentafluoroNNDimethylaniline;
formula     C8H6F5N;
CAS         1801-14-5;
InChIKey    KGTLSNJIWZULPZ-UHFFFAOYSA-N;
MW          211.133;      // g/mol [origin=calculated method=formula-sum]
Tc          607.59;      // K   [origin=predictive method=joback]
Pc          26.111;      // bar [origin=predictive method=joback]
omega       0.6423;      // -   [origin=predictive method=lee-kesler]
Tb          443.01;      // K   [origin=predictive method=joback]
HvapTb      36946.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.97 0.57034 -0.000302 5.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group AC; count 1; } { group CH3N; count 1; } { group ACF; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC_ring; count 6; } { group F; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5,6-pentakis(fluoranyl)-n,n-dimethyl-aniline" "benzenamine, 2,3,4,5,6-pentafluoro-n,n-dimethyl-" "n,n-dimethyl-2,3,4,5,6-pentafluoroaniline" );
gibbsFormation
{
    dHf_298   -942290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-782530.0
    phase     gas;
}
