/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-sec-butyl-4-methyl-1,3-dioxane  (C9H18O2, CAS 67969-59-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2SecButyl4Methyl13Dioxane;
formula     C9H18O2;
CAS         67969-59-9;
InChIKey    FPTZRJSOBHEGPH-UHFFFAOYSA-N;
MW          158.241;      // g/mol [origin=calculated method=formula-sum]
Tc          676.37;      // K   [origin=predictive method=joback]
Pc          27.127;      // bar [origin=predictive method=joback]
omega       0.4319;      // -   [origin=predictive method=lee-kesler]
Tb          473.86;      // K   [origin=predictive method=joback]
HvapTb      44380.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.999 0.95436 -0.0004668 5.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butan-2-yl-4-methyl-1,3-dioxane" "1,3-dioxane, 4-methyl-2-(1-methylpropyl)-" "4-methyl-2-(1-methylpropyl)-1,3-dioxane" );
gibbsFormation
{
    dHf_298   -464390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     321.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133040.0
    phase     gas;
}
