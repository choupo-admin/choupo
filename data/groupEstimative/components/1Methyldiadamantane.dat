/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyldiadamantane  (C15H22, CAS 26460-76-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyldiadamantane;
formula     C15H22;
CAS         26460-76-4;
InChIKey    NOMKXIVITNLMHM-UHFFFAOYSA-N;
MW          202.341;      // g/mol [origin=calculated method=formula-sum]
Tc          780.87;      // K   [origin=predictive method=joback]
Pc          22.959;      // bar [origin=predictive method=joback]
omega       0.4637;      // -   [origin=predictive method=lee-kesler]
Tb          558.46;      // K   [origin=predictive method=joback]
HvapTb      46299.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-289.01 2.40532 -0.002306 9.071e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 7; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 7; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -28550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     211.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=362650.0
    phase     gas;
}
