/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-methylenebis[5-(diethylamino)phenol]  (C21H30N2O2, CAS 6274-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Methylenebis5DiethylaminoPhenol;
formula     C21H30N2O2;
CAS         6274-83-5;
InChIKey    HQXMQJIISUSHBT-UHFFFAOYSA-N;
MW          342.483;      // g/mol [origin=calculated method=formula-sum]
Tc          1156.66;      // K   [origin=predictive method=joback]
Pc          18.773;      // bar [origin=predictive method=joback]
omega       1.3159;      // -   [origin=predictive method=lee-kesler]
Tb          929.52;      // K   [origin=predictive method=joback]
HvapTb      98330.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.635 2.27908 -0.00178484 5.809e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(diethylamino)-2-[[4-(diethylamino)-2-oxidanyl-phenyl]methyl]phenol" "phenol, 2,2'-methylenebis(5-(diethylamino)-" "phenol, 2,2'-methylenebis[5-(diethylamino)-" "phenol,2'-methylenebis[5-(diethylamino)-" "2,2'-methanediylbis[5-(diethylamino)phenol]" "5-(diethylamino)-2-[[4-(diethylamino)-2-hydroxyphenyl]methyl]phenol" );
standardThermochemistry
{
    dHf_298   -246210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     833.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243820.0
}
