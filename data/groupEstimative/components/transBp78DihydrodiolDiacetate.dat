/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-bp-7,8-dihydrodiol diacetate  (C24H16O4, CAS 73785-34-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        transBp78DihydrodiolDiacetate;
formula     C24H16O4;
CAS         73785-34-9;
InChIKey    FSPYWBWXIUJPSS-UHFFFAOYSA-N;
MW          368.388;      // g/mol [origin=calculated method=formula-sum]
Tc          1232.60;      // K   [origin=predictive method=joback]
Pc          17.924;      // bar [origin=predictive method=joback]
omega       1.2081;      // -   [origin=predictive method=lee-kesler]
Tb          984.96;      // K   [origin=predictive method=joback]
HvapTb      95342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.83 1.85824 -0.001441 4.412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 10; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 10; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(7-acetyloxybenzo[a]pyren-8-yl) ethanoate" "trans-7,8-diacetoxy-7,8-dihydrobenzo(a)pyrene" "benzo(a)pyrene-7,8-diol, diacetate (ester), (e)-" "(7-acetyloxybenzo[a]pyren-8-yl) acetate" );
gibbsFormation
{
    dHf_298   -275250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     618.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15560.0
    phase     gas;
}
