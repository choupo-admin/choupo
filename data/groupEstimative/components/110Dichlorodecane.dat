/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,10-dichlorodecane  (C10H20Cl2, CAS 2162-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        110Dichlorodecane;
formula     C10H20Cl2;
CAS         2162-98-3;
InChIKey    RBBNTRDPSVZESY-UHFFFAOYSA-N;
MW          211.17;      // g/mol [origin=calculated method=formula-sum]
Tc          677.75;      // K   [origin=predictive method=joback]
Pc          19.718;      // bar [origin=predictive method=joback]
omega       0.6125;      // -   [origin=predictive method=lee-kesler]
Tb          503.26;      // K   [origin=predictive method=joback]
HvapTb      46624.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.58 0.9674 -0.000561 1.258e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,10-bis(chloranyl)decane" "decane, 1,10-dichloro-" "decamethylene dichloride" "decane,10-dichloro-" "1,10-decamethylene dichloride" "u778" );
gibbsFormation
{
    dHf_298   -281210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9460.0
    phase     gas;
}
