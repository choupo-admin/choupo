/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethyl-1,4-pentadiene  (C7H12, CAS 758-86-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethyl14Pentadiene;
formula     C7H12;
CAS         758-86-1;
InChIKey    SOKHGJZTJQMHEW-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          530.84;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.2534;      // -   [origin=predictive method=lee-kesler]
Tb          352.56;      // K   [origin=predictive method=joback]
HvapTb      29528.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.83 0.63464 -0.0004083 1.082e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethylpenta-1,4-diene" "1,4-pentadiene,2,3-dimethyl-" "1,4-pentadiene, 2,3-dimethyl-" );
gibbsFormation
{
    dHf_298   47980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172750.0
    phase     gas;
}
