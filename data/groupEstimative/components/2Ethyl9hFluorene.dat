/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-9h-fluorene  (C15H14, CAS 1207-20-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl9hFluorene;
formula     C15H14;
CAS         1207-20-1;
InChIKey    IAGPYKKRRMNDCQ-UHFFFAOYSA-N;
MW          194.277;      // g/mol [origin=calculated method=formula-sum]
Tc          852.34;      // K   [origin=predictive method=joback]
Pc          26.902;      // bar [origin=predictive method=joback]
omega       0.5812;      // -   [origin=predictive method=lee-kesler]
Tb          613.97;      // K   [origin=predictive method=joback]
HvapTb      55400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.599 1.28912 -0.00102188 3.309e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 7; } { group AC; count 3; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9h-fluorene, 2-ethyl-" );
gibbsFormation
{
    dHf_298   191180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=364010.0
    phase     gas;
}
