/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloheptylmethanol  (C8H16O, CAS 4448-75-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloheptylmethanol;
formula     C8H16O;
CAS         4448-75-3;
InChIKey    BMCQFFXPECPDPS-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          696.30;      // K   [origin=predictive method=joback]
Pc          36.115;      // bar [origin=predictive method=joback]
omega       0.6870;      // -   [origin=predictive method=lee-kesler]
Tb          498.64;      // K   [origin=predictive method=joback]
HvapTb      50682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.819 0.9103 -0.0004764 7.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloheptanemethanol" "bmcqffxpecpdps-uhfffaoysa-" "(hydroxymethyl)cycloheptane;cycloheptylmethanol;" );
standardThermochemistry
{
    dHf_298   -312520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-107990.0
}
