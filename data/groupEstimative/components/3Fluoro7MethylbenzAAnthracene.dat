/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-fluoro-7-methylbenz[a]anthracene  (C19H13F, CAS 2606-87-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Fluoro7MethylbenzAAnthracene;
formula     C19H13F;
CAS         2606-87-3;
InChIKey    XOOBIAYNRGAFGD-UHFFFAOYSA-N;
MW          260.311;      // g/mol [origin=calculated method=formula-sum]
Tc          984.50;      // K   [origin=predictive method=joback]
Pc          23.092;      // bar [origin=predictive method=joback]
omega       0.7616;      // -   [origin=predictive method=lee-kesler]
Tb          737.13;      // K   [origin=predictive method=joback]
HvapTb      66915.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.33 1.49262 -0.0011994 3.897e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 6; } { group ACCH3; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-fluoranyl-7-methyl-benzo[a]anthracene" "3'-fluoro-10-methyl-1,2-benzanthracene" "3-fluoro-7-methylbenz(a)anthracene" "benz(a)anthracene, 3-fluoro-7-methyl-" "benz[a]anthracene, 3-fluoro-7-methyl-" "3-fluoro-7-methyltetraphene" "3-fluoro-7-methylbenzo[a]anthracene" );
gibbsFormation
{
    dHf_298   132260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=308130.0
    phase     gas;
}
