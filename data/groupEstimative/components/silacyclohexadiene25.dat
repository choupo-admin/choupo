/*--------------------------------*- Choupo -*-----------------------*\
  Component: silacyclohexadiene-2,5  (C5H8Si, CAS 81200-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H8Si (delta H+2Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silacyclohexadiene25;
formula     C5H8Si;
CAS         81200-77-3;
InChIKey    ALBWZGRJHDEIBS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          96.204;      // g/mol [origin=calculated method=formula-sum]
Tc          532.94;      // K   [origin=predictive method=joback]
Pc          43.916;      // bar [origin=predictive method=joback]
omega       0.1525;      // -   [origin=predictive method=lee-kesler]
Tb          332.27;      // K   [origin=predictive method=joback]
HvapTb      27874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.52 0.525 -0.00040556 1.244e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 2; } { group SiH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dihydrosiline" "1-silacyclohexa-2,5-diene" );
gibbsFormation
{
    dHf_298   49850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95400.0
    phase     gas;
}
