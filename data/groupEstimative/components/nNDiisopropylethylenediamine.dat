/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-diisopropylethylenediamine  (C8H20N2, CAS 4013-94-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiisopropylethylenediamine;
formula     C8H20N2;
CAS         4013-94-9;
InChIKey    MFIGJRRHGZYPDD-UHFFFAOYSA-N;
MW          144.262;      // g/mol [origin=calculated method=formula-sum]
Tc          661.41;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.6471;      // -   [origin=predictive method=lee-kesler]
Tb          482.10;      // K   [origin=predictive method=joback]
HvapTb      45498.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.168 0.92808 -0.000515 1.04e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-di(propan-2-yl)ethane-1,2-diamine" "1,2-bis(isopropylamino)ethane" "n,n'-disopropylethylene diamine" "n,n'-diisopropyl-ethylenediamine" "diped" "1,2-ethanediamine, n,n'-bis(1-methylethyl)-" "1,2-ethanediamine, n1,n2-bis(1-methylethyl)-" "1,2-ethanediamine,n1,n2-dipropyl-" "n,n'-diisopropylethylene diamine" "n1,n2-bis(1-methylethyl)-1,2-ethanediamine" "n,n inverted exclamation marka-diisopropylethylenediamine" "n,n inverted exclamation mark -diisopropyl-1,2-diaminoethane" );
gibbsFormation
{
    dHf_298   -112070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=190380.0
    phase     gas;
}
