/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4,5-trimethoxybenzamide  (C10H13NO4, CAS 3086-62-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        345Trimethoxybenzamide;
formula     C10H13NO4;
CAS         3086-62-2;
InChIKey    GGNMTJKRHHLJHH-UHFFFAOYSA-N;
MW          211.217;      // g/mol [origin=calculated method=formula-sum]
Tc          882.15;      // K   [origin=predictive method=joback]
Pc          30.090;      // bar [origin=predictive method=joback]
omega       0.9556;      // -   [origin=predictive method=lee-kesler]
Tb          663.68;      // K   [origin=predictive method=joback]
HvapTb      66733.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (93.14 0.54076 -4.198e-05 -1.0384e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 3; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzamide, 3,4,5-trimethoxy-" "3,5-trimethoxybenzamide" "r362" "bim-0005360.p001" );
gibbsFormation
{
    dHf_298   -523060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-260630.0
    phase     gas;
}
