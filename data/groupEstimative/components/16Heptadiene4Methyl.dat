/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-heptadiene, 4-methyl-  (C8H14, CAS 52713-63-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Heptadiene4Methyl;
formula     C8H14;
CAS         52713-63-0;
InChIKey    GWBIZSHSUHWEEP-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          549.87;      // K   [origin=predictive method=joback]
Pc          27.877;      // bar [origin=predictive method=joback]
omega       0.3250;      // -   [origin=predictive method=lee-kesler]
Tb          375.56;      // K   [origin=predictive method=joback]
HvapTb      31674.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.048 0.72972 -0.0004604 1.183e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylhepta-1,6-diene" );
standardThermochemistry
{
    dHf_298   37130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=189720.0
}
