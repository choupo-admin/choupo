/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexadecane, 5-butyl-  (C20H42, CAS 6912-07-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexadecane5Butyl;
formula     C20H42;
CAS         6912-07-8;
InChIKey    WCYRXBXHFUHSAH-UHFFFAOYSA-N;
MW          282.556;      // g/mol [origin=calculated method=formula-sum]
Tc          818.83;      // K   [origin=predictive method=joback]
Pc          10.207;      // bar [origin=predictive method=joback]
omega       0.7916;      // -   [origin=predictive method=lee-kesler]
Tb          656.76;      // K   [origin=predictive method=joback]
HvapTb      59726.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.974 1.90976 -0.0010674 2.263e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 16; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 16; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-butylhexadecane" "5-n-butylhexadecane" );
standardThermochemistry
{
    dHf_298   -461410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     925.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=115080.0
}
