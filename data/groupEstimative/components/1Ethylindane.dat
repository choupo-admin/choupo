/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethylindane  (C11H14, CAS 4830-99-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethylindane;
formula     C11H14;
CAS         4830-99-3;
InChIKey    SECAQUZEXAHWBA-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          709.54;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.4004;      // -   [origin=predictive method=lee-kesler]
Tb          489.68;      // K   [origin=predictive method=joback]
HvapTb      42931.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.959 1.06132 -0.00075896 2.196e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-2,3-dihydro-1h-indene" "indan, 1-ethyl-" "1-ethylindan" "1-ethyl-[2,3-dihydroindene]" "1h-indene, 1-ethyl-2,3-dihydro-" );
standardThermochemistry
{
    dHf_298   27490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=205270.0
}
