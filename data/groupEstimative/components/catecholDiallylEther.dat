/*--------------------------------*- Choupo -*-----------------------*\
  Component: catechol diallyl ether  (C12H14O2, CAS 4218-87-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        catecholDiallylEther;
formula     C12H14O2;
CAS         4218-87-5;
InChIKey    GZWLFCGQNCRLIN-UHFFFAOYSA-N;
MW          190.242;      // g/mol [origin=calculated method=formula-sum]
Tc          749.31;      // K   [origin=predictive method=joback]
Pc          24.900;      // bar [origin=predictive method=joback]
omega       0.5910;      // -   [origin=predictive method=lee-kesler]
Tb          544.02;      // K   [origin=predictive method=joback]
HvapTb      48724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.392 0.839 -0.00041696 5.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(prop-2-enoxy)benzene" "1,2-diallyloxybenzene" "pyrocatechol diallyl ether" "1,2-bis(allyloxy)benzene" "benzene, o-bis(allyloxy)-" "benzene, 1,2-bis(2-propen-1-yloxy)-" "benzene,2-bis(2-propenyloxy)-" "benzene, 1,2-bis(2-propenyloxy)-" );
gibbsFormation
{
    dHf_298   -79530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118620.0
    phase     gas;
}
