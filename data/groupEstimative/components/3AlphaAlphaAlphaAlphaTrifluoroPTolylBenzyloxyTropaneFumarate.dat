/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(alpha-(alpha,alpha,alpha-trifluoro-p-tolyl)benzyloxy)tropane fumarate  (C26H28F3NO5, CAS 3560-78-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3AlphaAlphaAlphaAlphaTrifluoroPTolylBenzyloxyTropaneFumarate;
formula     C26H28F3NO5;
CAS         3560-78-9;
InChIKey    QLIPSOLAKVSUQN-WLHGVMLRSA-N;
MW          491.506;      // g/mol [origin=calculated method=formula-sum]
Tc          1458.71;      // K   [origin=predictive method=joback]
Pc          12.755;      // bar [origin=predictive method=joback]
omega       1.1899;      // -   [origin=predictive method=lee-kesler]
Tb          1191.48;      // K   [origin=predictive method=joback]
HvapTb      113271.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.16 2.66542 -0.00176456 4.218e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group CH=CH; count 1; } { group ACH; count 9; } { group AC; count 3; } { group CH-O; count 1; } { group CH3N; count 1; } { group COOH; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group F; count 3; } { group O; count 1; } { group COOH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-but-2-enedioic acid;8-methyl-3-[phenyl-[4-(trifluoromethyl)phenyl]methoxy]-8-azabicyclo[3.2.1]octane" "tropane, 3-(alpha-(alpha,alpha,alpha-trifluoro-p-tolyl)benzyloxy)-, fumarate" "(e)-but-2-enedioic acid; 8-methyl-3-[phenyl-[4-(trifluoromethyl)phenyl]methoxy]-8-azabicyclo[3.2.1]octane" );
gibbsFormation
{
    dHf_298   -1361270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1028.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-805690.0
    phase     gas;
}
