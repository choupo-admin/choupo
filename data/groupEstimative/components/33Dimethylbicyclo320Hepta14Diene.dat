/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethylbicyclo[3.2.0]hepta-1,4-diene  (C9H12, CAS 111869-26-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethylbicyclo320Hepta14Diene;
formula     C9H12;
CAS         111869-26-2;
InChIKey    LCUWWPJEBQOEQH-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          652.89;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.3271;      // -   [origin=predictive method=lee-kesler]
Tb          436.46;      // K   [origin=predictive method=joback]
HvapTb      36692.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.67 1.23844 -0.00128828 5.494e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylbicylo(3.2.0)hepta-1,4-diene" "bicyclo[3.2.0]hepta-1,4-diene,3,3-dimethyl-" "3,3-dimethylbicylo[3.2.0]hepta-1,4-diene" );
standardThermochemistry
{
    dHf_298   38550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     370.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=177180.0
}
