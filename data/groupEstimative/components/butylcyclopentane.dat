/*--------------------------------*- Choupo -*-----------------------*\
  Component: butylcyclopentane  (C9H18, CAS 2040-95-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylcyclopentane;
formula     C9H18;
CAS         2040-95-1;
InChIKey    ZAGHKONXGGSVDV-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          612.01;      // K   [origin=predictive method=joback]
Pc          27.643;      // bar [origin=predictive method=joback]
omega       0.3509;      // -   [origin=predictive method=lee-kesler]
Tb          420.80;      // K   [origin=predictive method=joback]
HvapTb      35885.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.777 0.99052 -0.0005932 1.354e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentane, butyl-" "n-butylcyclopentane" );
gibbsFormation
{
    dHf_298   -168610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61450.0
    phase     gas;
}
