/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-isocyanatopropanoate  (C6H9NO3, CAS 5100-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Isocyanatopropanoate;
formula     C6H9NO3;
CAS         5100-34-5;
InChIKey    XBSGYVHOINMTIM-UHFFFAOYSA-N;
MW          143.142;      // g/mol [origin=calculated method=formula-sum]
Tc          647.07;      // K   [origin=predictive method=joback]
Pc          33.999;      // bar [origin=predictive method=joback]
omega       0.6366;      // -   [origin=predictive method=lee-kesler]
Tb          461.77;      // K   [origin=predictive method=joback]
HvapTb      45889.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCd; count 1; } { group COO; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-isocyanatopropionate" "3-isocyanatopropanoic acid ethyl ester" "ethyl n-(oxomethylidene)-beta-alaninate" "propanoic acid,3-isocyanato-, ethyl ester" "ethyl n-(oxomethylene)-beta-alaninate" "3-isocyanatopropionic acid ethyl ester" );
// formation datum unavailable (element entropy missing): dHf_298=-489860.0 dGf_298=None
