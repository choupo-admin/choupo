/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-5-(trifluoromethyl)aniline  (C8H8F3NO, CAS 349-65-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy5TrifluoromethylAniline;
formula     C8H8F3NO;
CAS         349-65-5;
InChIKey    RKUSRLUGUVDNKP-UHFFFAOYSA-N;
MW          191.152;      // g/mol [origin=calculated method=formula-sum]
Tc          712.09;      // K   [origin=predictive method=joback]
Pc          32.246;      // bar [origin=predictive method=joback]
omega       0.6193;      // -   [origin=predictive method=lee-kesler]
Tb          508.81;      // K   [origin=predictive method=joback]
HvapTb      46306.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.1 0.72582 -0.00046192 1.046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3O; count 1; } { group ACNH2; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 3; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-amino-4-methoxybenzotrifluoride" "2-amino-4-trifluoromethylanisole" "2-methoxy-5-(trifluoromethyl)phenylamine" "6-methoxy-alpha,alpha,alpha-trifluoro-m-toluidine" "agn-pc-0cxoi7" "2-methoxy-5-trifluoromethylaniline" "2-amino-4-(trifluoromethyl)anisole" "2-methoxy-5-trifluoromethyl-aniline" "5-trifluoromethyl-o-anisidine" "2-methoxy-5-trifluoromethyl-phenylamine" "3-amino-4-(trifluoromethyl)anisole" "6-methoxy-" "a," "a," "a-trifluoro-m-toluidine" );
gibbsFormation
{
    dHf_298   -690370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-510510.0
    phase     gas;
}
