/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-diphenylbicyclo[3.2.0]heptane  (C19H20, CAS 94383-67-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Diphenylbicyclo320Heptane;
formula     C19H20;
CAS         94383-67-2;
InChIKey    ITJCELKBMFHZCC-UHFFFAOYSA-N;
MW          248.369;      // g/mol [origin=calculated method=formula-sum]
Tc          982.44;      // K   [origin=predictive method=joback]
Pc          24.875;      // bar [origin=predictive method=joback]
omega       0.5283;      // -   [origin=predictive method=lee-kesler]
Tb          705.91;      // K   [origin=predictive method=joback]
HvapTb      60136.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-287.78 2.527 -0.0025314 1.0306e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 2; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-diphenylbicyclo(3.2.0)heptane" );
gibbsFormation
{
    dHf_298   207490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     661.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=432340.0
    phase     gas;
}
