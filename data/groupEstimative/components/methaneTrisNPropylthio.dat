/*--------------------------------*- Choupo -*-----------------------*\
  Component: methane, tris(n-propylthio)-,  (C10H22S3, CAS 59969-91-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methaneTrisNPropylthio;
formula     C10H22S3;
CAS         59969-91-4;
InChIKey    LGJCQHBAMDVMHA-UHFFFAOYSA-N;
MW          238.466;      // g/mol [origin=calculated method=formula-sum]
Tc          855.61;      // K   [origin=predictive method=joback]
Pc          22.271;      // bar [origin=predictive method=joback]
omega       0.6691;      // -   [origin=predictive method=lee-kesler]
Tb          634.30;      // K   [origin=predictive method=joback]
HvapTb      57917.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.916 0.94293 -0.0004028 2.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH2S; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group S; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[bis(propylsulfanyl)methylsulfanyl]propane" "propane, 1,1',1''-[methylidynetris(thio)]tris-" );
gibbsFormation
{
    dHf_298   -129400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     720.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130240.0
    phase     gas;
}
