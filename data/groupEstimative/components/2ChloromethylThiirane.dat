/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(chloromethyl)thiirane  (C3H5ClS, CAS 3221-15-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloromethylThiirane;
formula     C3H5ClS;
CAS         3221-15-6;
InChIKey    XRWMHJJHPQTTLQ-UHFFFAOYSA-N;
MW          108.583;      // g/mol [origin=calculated method=formula-sum]
Tc          569.31;      // K   [origin=predictive method=joback]
Pc          49.663;      // bar [origin=predictive method=joback]
omega       0.2346;      // -   [origin=predictive method=lee-kesler]
Tb          360.24;      // K   [origin=predictive method=joback]
HvapTb      32382.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.369 0.46091 -0.0003987 1.416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH2Cl; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group Cl; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloropropylene sulfide" "thioepichlorhydrin" "thioepichlorohydrin" "(chloromethyl)thiirane" "3-chloropropylene sulfide" "2-thiiranylmethyl chloride" "thiirane, (chloromethyl)-" "1-chloro-2,3-epithiopropane" "2-(chloromethyl)ethylene sulfide" "chloropropylene sulphide" "thiirane, 2-chloromethyl-" "propane, 1-chloro-2,3-epithio-" );
gibbsFormation
{
    dHf_298   -2930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     266.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63060.0
    phase     gas;
}
