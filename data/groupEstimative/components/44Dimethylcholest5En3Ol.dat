/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-dimethylcholest-5-en-3-ol  (C29H50O, CAS 1253-88-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dimethylcholest5En3Ol;
formula     C29H50O;
CAS         1253-88-9;
InChIKey    DASOUCLGLBPXLC-UHFFFAOYSA-N;
MW          414.718;      // g/mol [origin=calculated method=formula-sum]
Tc          1215.06;      // K   [origin=predictive method=joback]
Pc          9.615;      // bar [origin=predictive method=joback]
omega       0.8923;      // -   [origin=predictive method=lee-kesler]
Tb          988.91;      // K   [origin=predictive method=joback]
HvapTb      92828.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-352.257 4.01454 -0.00353584 1.3509e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 10; } { group CH; count 7; } { group C; count 3; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 5; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4,10,13-tetramethyl-17-(6-methylheptan-2-yl)-1,2,3,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-3-ol" "cholest-5-en-3.beta.-ol, 4,4-dimethyl-" "cholest-5-en-3-ol, 4,4-dimethyl-, (3.beta.)-" "4,4-dimethylcholesterol" "4,4-dimethylcholest-5-enol" "cholest-5-en-3.beta.-ol,4-dimethyl-" "cholest-5-en-3-ol,4-dimethyl-, (3.beta.)-" "(3s,8s,9s,10r,13r,14s,17r)-4,4,10,13-tetramethyl-17-[(2r)-6-methylheptan-2-yl]-1,2,3,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-3-ol" );
gibbsFormation
{
    dHf_298   -533610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1051.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=207120.0
    phase     gas;
}
