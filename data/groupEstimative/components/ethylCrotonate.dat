/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl crotonate  (C6H10O2, CAS 623-70-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylCrotonate;
formula     C6H10O2;
CAS         623-70-1;
InChIKey    ZFDIRQKJPRINOQ-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          581.91;      // K   [origin=predictive method=joback]
Pc          33.144;      // bar [origin=predictive method=joback]
omega       0.4144;      // -   [origin=predictive method=lee-kesler]
Tb          399.26;      // K   [origin=predictive method=joback]
HvapTb      36315.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.661 0.53904 -0.0002918 5.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl but-2-enoate" "2-butenoic acid, ethyl ester, (z)-" "(e)-ethyl but-2-enoate" "2-butenoicacid, ethyl ester, (e)-;crotonic acid, ethyl ester, (e)- (8ci);(e)-2-butenoicacid ethyl ester;(e)-ethyl but-2-enoate;ethyl (e)-2-butenoate;ethyl trans-2-butenoate;ethyl trans-crotonate;trans-2-butenoicacid ethyl ester;" );
gibbsFormation
{
    dHf_298   -367230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230510.0
    phase     gas;
}
