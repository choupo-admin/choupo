/*--------------------------------*- Choupo -*-----------------------*\
  Component: geissoschizoline  (C19H26N2O, CAS 18397-07-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        geissoschizoline;
formula     C19H26N2O;
CAS         18397-07-4;
InChIKey    FAQGZHFLASTWAV-RWANUPMISA-N;
MW          298.43;      // g/mol [origin=calculated method=formula-sum]
Tc          1052.49;      // K   [origin=predictive method=joback]
Pc          21.897;      // bar [origin=predictive method=joback]
omega       1.2473;      // -   [origin=predictive method=lee-kesler]
Tb          832.74;      // K   [origin=predictive method=joback]
HvapTb      84017.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-256.428 2.66702 -0.00240536 8.985e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 4; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 1; } { group CHNH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "curan-17-ol, (16alpha)-" );
gibbsFormation
{
    dHf_298   14600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=507740.0
    phase     gas;
}
