/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pentylresorcinol  (C11H16O2, CAS 533-24-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pentylresorcinol;
formula     C11H16O2;
CAS         533-24-4;
InChIKey    PJHYOCWMKYASAB-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          863.89;      // K   [origin=predictive method=joback]
Pc          36.955;      // bar [origin=predictive method=joback]
omega       0.9339;      // -   [origin=predictive method=lee-kesler]
Tb          639.20;      // K   [origin=predictive method=joback]
HvapTb      68384.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.856 1.27912 -0.00111852 4.114e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-pentylbenzene-1,3-diol" "pentylresorcinol" "4-amylresorcinol" "normalamylresorcinol" "resorcinol, 4-pentyl-" "4-pentyl-1,3-benzenediol" "1,3-benzenediol,4-pentyl-" "1,3-benzenediol, 4-pentyl-" "1,3-benzenediol, 4-pentyl- (9ci)" "resorcinol,4-pentyl- (6ci,8ci); 4-amylresorcinol; 4-pentylresorcinol; pentylresorcinol;n-pentylresorcinol" );
standardThermochemistry
{
    dHf_298   -388460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-155090.0
}
