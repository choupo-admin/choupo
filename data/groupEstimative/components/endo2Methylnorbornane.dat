/*--------------------------------*- Choupo -*-----------------------*\
  Component: endo-2-methylnorbornane  (C8H14, CAS 765-90-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        endo2Methylnorbornane;
formula     C8H14;
CAS         765-90-2;
InChIKey    KWSARSUDWPZTFF-JECWYVHBSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          596.59;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       0.2722;      // -   [origin=predictive method=lee-kesler]
Tb          395.72;      // K   [origin=predictive method=joback]
HvapTb      33091.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.05 1.02952 -0.00075 2.245e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r)-3-methylbicyclo[2.2.1]heptane" );
gibbsFormation
{
    dHf_298   -89350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     264.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118170.0
    phase     gas;
}
