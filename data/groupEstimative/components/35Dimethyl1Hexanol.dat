/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dimethyl-1-hexanol  (C8H18O, CAS 13501-73-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dimethyl1Hexanol;
formula     C8H18O;
CAS         13501-73-0;
InChIKey    WETBJXIDTZXCBL-UHFFFAOYSA-N;
MW          130.231;      // g/mol [origin=calculated method=formula-sum]
Tc          640.20;      // K   [origin=predictive method=joback]
Pc          28.354;      // bar [origin=predictive method=joback]
omega       0.7923;      // -   [origin=predictive method=lee-kesler]
Tb          473.94;      // K   [origin=predictive method=joback]
HvapTb      49305.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.457 0.80966 -0.0004482 9.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-dimethylhexan-1-ol" "1-hexanol, 3,5-dimethyl-" );
gibbsFormation
{
    dHf_298   -371240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125220.0
    phase     gas;
}
