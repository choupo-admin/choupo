/*--------------------------------*- Choupo -*-----------------------*\
  Component: isovaleric acid  (C5H10O2, CAS 503-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isovalericAcid;
formula     C5H10O2;
CAS         503-74-2;
InChIKey    GWYFCOCPABKNJV-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          654.62;      // K   [origin=predictive method=joback]
Pc          39.014;      // bar [origin=predictive method=joback]
omega       0.5958;      // -   [origin=predictive method=lee-kesler]
Tb          459.07;      // K   [origin=predictive method=joback]
HvapTb      43500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.261 0.53554 -0.000324 7.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutanoic acid" "3-methylbutyric acid" "isopentanoic acid" "delphinic acid" "butanoic acid, 3-methyl-" "isopropylacetic acid" "3-methylbutyrate" "beta-methylbutyric acid" "isovalerianic acid" "isobutylformic acid" "isovalerianic" "isovalerate" );
standardThermochemistry
{
    dHf_298   -502080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-355130.0
}
