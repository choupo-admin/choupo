/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-diphenyl-2,2'-bipyridine  (C22H16N2, CAS 6153-92-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Diphenyl22Bipyridine;
formula     C22H16N2;
CAS         6153-92-0;
InChIKey    OXMSMRJQZMTIMT-UHFFFAOYSA-N;
MW          308.384;      // g/mol [origin=calculated method=formula-sum]
Tc          1227.78;      // K   [origin=predictive method=joback]
Pc          24.171;      // bar [origin=predictive method=joback]
omega       0.8550;      // -   [origin=predictive method=lee-kesler]
Tb          927.04;      // K   [origin=predictive method=joback]
HvapTb      87414.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.01 1.72672 -0.00118224 3.064e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group C5H3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 16; } { group dC_ring; count 6; } { group Nd_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenyl-2-(4-phenylpyridin-2-yl)pyridine" "4,4'-diphenyl-2,2'-dipyridyl" "2,2'-bipyridine, 4,4'-diphenyl-" "agn-pc-0d16is" "4-phenyl-2-(4-phenyl(2-pyridyl))pyridine" "brd-k51847055-001-01-9" "4,4 inverted exclamation marka-diphenyl-2,2 inverted exclamation marka-dipyridyl" "4,4'-diphenyl-2,2'-bipyridine;4,4'-diphenyl-2,2'-bipyridyl;4,4'-diphenyl-2,2'-dipyridyl;" );
gibbsFormation
{
    dHf_298   491350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     600.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=718840.0
    phase     gas;
}
