/*--------------------------------*- Choupo -*-----------------------*\
  Component: aspartic acid, n,n'-(2-methyl-1,5-pentanediyl)bis-, tetraethyl ester, polymer with 1,6-diisocyanatohexane  (C30H52N4O10, CAS 182241-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        asparticAcidNN2Methyl15PentanediylBisTetraethylEsterPolymerW;
formula     C30H52N4O10;
CAS         182241-06-1;
InChIKey    ZKMMDUASHHHRSC-RWVUOVKPSA-N;
MW          628.764;      // g/mol [origin=calculated method=formula-sum]
Tc          1826.06;      // K   [origin=predictive method=joback]
Pc          6.351;      // bar [origin=predictive method=joback]
omega       -0.0292;      // -   [origin=predictive method=lee-kesler]
Tb          1352.64;      // K   [origin=predictive method=joback]
HvapTb      143068.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 12; } { group CH; count 3; } { group CH2COO; count 2; } { group CH2NH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 5; } { group CH2; count 16; } { group CH; count 3; } { group dCd; count 2; } { group COO; count 4; } { group dO_oth; count 2; } { group NH; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl (2s)-2-[[5-[[(2s)-1,4-diethoxy-1,4-bis(oxidanylidene)butan-2-yl]amino]-4-methyl-pentyl]amino]butanedioate;1,6-diisocyanatohexane" "aspartic acid, n,n'-(2-methyl-1,5-pentanediyl)bis-, 1,1',4,4'-tetraethyl ester, polymer with 1,6-diisocyanatohexane" );
