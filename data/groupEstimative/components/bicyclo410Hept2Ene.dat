/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[4.1.0]hept-2-ene  (C7H10, CAS 2566-57-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo410Hept2Ene;
formula     C7H10;
CAS         2566-57-6;
InChIKey    WJSPKNSMGLBHBW-UHFFFAOYSA-N;
MW          94.157;      // g/mol [origin=calculated method=formula-sum]
Tc          581.90;      // K   [origin=predictive method=joback]
Pc          40.621;      // bar [origin=predictive method=joback]
omega       0.2500;      // -   [origin=predictive method=lee-kesler]
Tb          376.67;      // K   [origin=predictive method=joback]
HvapTb      31466.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.3 0.905 -0.00073828 2.45e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[4.1.0]hept-4-ene" "bicyclo(4.1.0)hept-2-ene" "2-norcarene(7ci,8ci)" "agn-pc-03e9f5" );
standardThermochemistry
{
    dHf_298   9410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     230.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147420.0
}
