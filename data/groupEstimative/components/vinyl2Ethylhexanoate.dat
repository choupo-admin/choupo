/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl 2-ethylhexanoate  (C10H18O2, CAS 94-04-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinyl2Ethylhexanoate;
formula     C10H18O2;
CAS         94-04-2;
InChIKey    IGBZOHMCHDADGY-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          659.01;      // K   [origin=predictive method=joback]
Pc          22.187;      // bar [origin=predictive method=joback]
omega       0.5891;      // -   [origin=predictive method=lee-kesler]
Tb          482.86;      // K   [origin=predictive method=joback]
HvapTb      44203.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.534 0.88494 -0.0004517 6.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH2=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl 2-ethylhexanoate" "vinyl 2-ethylhexoate" "2-ethylhexoic acid, vinyl ester" "hexanoic acid, 2-ethyl-, ethenyl ester" "2-ethylhexanoic acid vinyl ester" "vynate 2eh" "vinyl-2-ethylhexoate" "vinyl-2-ethylhexanoate" "2-ethylhexanoic acid, vinyl ester" "hexanoic acid, 2-ethyl-, vinyl ester" "igbzohmchdadgy-uhfffaoysa-" "2-ethyl hexanoic acid vinyl ester" );
gibbsFormation
{
    dHf_298   -446860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-191650.0
    phase     gas;
}
