/*--------------------------------*- Choupo -*-----------------------*\
  Component: monosilicic acid  (H4O4Si, CAS 10193-36-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula H4O4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        monosilicicAcid;
formula     H4O4Si;
CAS         10193-36-9;
InChIKey    RMAQACBXLXPBSY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          96.113;      // g/mol [origin=calculated method=formula-sum]
Tc          728.38;      // K   [origin=predictive method=joback]
Pc          106.281;      // bar [origin=predictive method=joback]
omega       2.2519;      // -   [origin=predictive method=lee-kesler]
Tb          569.72;      // K   [origin=predictive method=joback]
HvapTb      82604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.87 -0.0664 0.000317 -1.892e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group OH; count 4; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group OH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "silicic acid" "orthosilicic acid" "tetrahydroxysilane" "silicon tetrahydroxide" "silicasol" "silicic acid (h4sio4)" "silicic acid (ortho)" "silicic acid (si(oh)4)" "silanetetrol" "kieselsaeure" "orthokieselsaeure" "tetrahydroxidosilicon" );
gibbsFormation
{
    dHf_298   -763870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-702920.0
    phase     gas;
}
