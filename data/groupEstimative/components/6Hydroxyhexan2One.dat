/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-hydroxyhexan-2-one  (C6H12O2, CAS 21856-89-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Hydroxyhexan2One;
formula     C6H12O2;
CAS         21856-89-3;
InChIKey    UALYCKSVHDYQRP-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          654.36;      // K   [origin=predictive method=joback]
Pc          37.226;      // bar [origin=predictive method=joback]
omega       0.9173;      // -   [origin=predictive method=lee-kesler]
Tb          482.93;      // K   [origin=predictive method=joback]
HvapTb      52375.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.084 0.57982 -0.0003143 6.096e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-oxidanylhexan-2-one" "6-hydroxy-hexan-2-one" "2-hexanone, 6-hydroxy-" );
gibbsFormation
{
    dHf_298   -431980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-266100.0
    phase     gas;
}
