/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(acryloyloxy)propan-2-yl 3-oxobutanoate  (C10H14O5, CAS 3064-61-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1AcryloyloxyPropan2Yl3Oxobutanoate;
formula     C10H14O5;
CAS         3064-61-7;
InChIKey    NGZDFOYYIXAAPC-UHFFFAOYSA-N;
MW          214.217;      // g/mol [origin=calculated method=formula-sum]
Tc          784.49;      // K   [origin=predictive method=joback]
Pc          23.680;      // bar [origin=predictive method=joback]
omega       0.8792;      // -   [origin=predictive method=lee-kesler]
Tb          594.95;      // K   [origin=predictive method=joback]
HvapTb      58356.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.302 0.80214 -0.0003384 1.46e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH3CO; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-prop-2-enoyloxypropan-2-yl 3-oxidanylidenebutanoate" "1-prop-2-enoyloxypropan-2-yl 3-oxobutanoate" "1-methyl-2-((1-oxoallyl)oxy)ethyl acetoacetate" "butanoic acid, 3-oxo-,1-methyl-2-[(1-oxo-2-propen-1-yl)oxy]ethyl ester" "acetoaceticacid, 2-hydroxy-1-methylethyl ester, acrylate (8ci); butanoic acid, 3-oxo-, 1-methyl-2-[(1-oxo-2-propenyl)oxy]ethylester (9ci); 1,2-propanediol, 2-acetoacetate acrylate (8ci); acrylic acid,2-hydroxypropyl ester, acetoacetate (8ci)" );
standardThermochemistry
{
    dHf_298   -876720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     660.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-630940.0
}
