/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-propanediol, 2,2-bis(hydroxymethyl)-, homopolymer, isononanoate pentanoate  (C19H36O7, CAS 70693-38-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Propanediol22BisHydroxymethylHomopolymerIsononanoatePentan;
formula     C19H36O7;
CAS         70693-38-8;
InChIKey    JCCPFJHWZAWFMM-UHFFFAOYSA-N;
MW          376.49;      // g/mol [origin=calculated method=formula-sum]
Tc          1280.95;      // K   [origin=predictive method=joback]
Pc          13.427;      // bar [origin=predictive method=joback]
omega       0.9764;      // -   [origin=predictive method=lee-kesler]
Tb          1023.63;      // K   [origin=predictive method=joback]
HvapTb      121055.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.153 1.93294 -0.0010868 2.015e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 1; } { group C; count 1; } { group OH; count 3; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 1; } { group C; count 1; } { group OH; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[5-[2,2-bis(hydroxymethyl)-3-oxidanyl-propoxy]-5-oxidanylidene-pentyl] 7-methyloctanoate" "polypentaerythritol, valeric acid, isononanoic acid esters" );
standardThermochemistry
{
    dHf_298   -1540770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1102.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-921700.0
}
