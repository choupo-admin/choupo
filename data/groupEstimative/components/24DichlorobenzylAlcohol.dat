/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dichlorobenzyl alcohol  (C7H6Cl2O, CAS 1777-82-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24DichlorobenzylAlcohol;
formula     C7H6Cl2O;
CAS         1777-82-8;
InChIKey    DBHODFSFBXJZNY-UHFFFAOYSA-N;
MW          177.024;      // g/mol [origin=calculated method=formula-sum]
Tc          775.87;      // K   [origin=predictive method=joback]
Pc          40.518;      // bar [origin=predictive method=joback]
omega       0.8389;      // -   [origin=predictive method=lee-kesler]
Tb          563.44;      // K   [origin=predictive method=joback]
HvapTb      60225.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.291 0.5185 -0.00032532 7.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH2; count 1; } { group OH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,4-dichlorophenyl)methanol" "dybenal" "2,4-dichlorobenzenemethanol" "rapidosept" "myacide sp" "benzenemethanol, 2,4-dichloro-" "benzyl alcohol, 2,4-dichloro-" "2,4-dichlorobenzylalcohol" "(2,4-dichlorophenyl)methan-1-ol" "benzenemethanol, 2,4-dichloro- (9ci)" );
gibbsFormation
{
    dHf_298   -157930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-59470.0
    phase     gas;
}
