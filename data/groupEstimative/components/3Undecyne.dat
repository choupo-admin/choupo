/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-undecyne  (C11H20, CAS 60212-30-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Undecyne;
formula     C11H20;
CAS         60212-30-8;
InChIKey    DPWGJNPCPLQVKQ-UHFFFAOYSA-N;
MW          152.281;      // g/mol [origin=calculated method=formula-sum]
Tc          643.13;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.4553;      // -   [origin=predictive method=lee-kesler]
Tb          460.28;      // K   [origin=predictive method=joback]
HvapTb      42232.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.447 0.89904 -0.00048246 9.868e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undec-3-yne" "3-c11h20" "dpwgjnpcplqvkq-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   1930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=244540.0
}
