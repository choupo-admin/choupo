/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibutyl thiodipropionate  (C14H26O4S, CAS 6975-31-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibutylThiodipropionate;
formula     C14H26O4S;
CAS         6975-31-1;
InChIKey    HPVVIIKTKWMIGP-UHFFFAOYSA-N;
MW          290.418;      // g/mol [origin=calculated method=formula-sum]
Tc          890.22;      // K   [origin=predictive method=joback]
Pc          15.561;      // bar [origin=predictive method=joback]
omega       0.9989;      // -   [origin=predictive method=lee-kesler]
Tb          705.14;      // K   [origin=predictive method=joback]
HvapTb      68389.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.58 1.21863 -0.0005084 1.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH2COO; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group COO; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 3-(3-butoxy-3-oxidanylidene-propyl)sulfanylpropanoate" "dibutyl 3,3'-thiodipropionate" "dibutyl 3,3'-sulfanediyldipropanoate" "dibutyl 3,3'-thiobispropionate" "propanoic acid, 3,3'-thiobis-, dibutyl ester" "propionic acid, 3,3'-thiodi-, dibutyl ester" "propanoic acid, 3,3'-thiobis-, 1,1'-dibutyl ester" "propionic acid,3'-thiodi-, dibutyl ester" "propanoic acid,3'-thiobis-, dibutyl ester" "3,3'-thio-di-propanoic acid dibutyl ester" "butyl 3-(3-butoxy-3-oxopropyl)sulfanylpropanoate" "propanoic acid,3,3'-thiobis-, 1,1'-dibutyl ester" );
standardThermochemistry
{
    dHf_298   -924980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     865.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-520620.0
}
