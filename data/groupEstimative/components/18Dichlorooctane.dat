/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-dichlorooctane  (C8H16Cl2, CAS 2162-99-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Dichlorooctane;
formula     C8H16Cl2;
CAS         2162-99-4;
InChIKey    WXYMNDFVLNUAIA-UHFFFAOYSA-N;
MW          183.116;      // g/mol [origin=calculated method=formula-sum]
Tc          634.96;      // K   [origin=predictive method=joback]
Pc          23.565;      // bar [origin=predictive method=joback]
omega       0.5180;      // -   [origin=predictive method=lee-kesler]
Tb          457.50;      // K   [origin=predictive method=joback]
HvapTb      42172.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.398 0.7774 -0.0004522 1.02e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,8-bis(chloranyl)octane" "octane, 1,8-dichloro-" "octamethylene chloride" "octamethylene dichloride" "1,8-dichloroethane;1,8-dichlorooctane;" );
standardThermochemistry
{
    dHf_298   -239930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-7380.0
}
