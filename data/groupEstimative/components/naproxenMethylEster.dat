/*--------------------------------*- Choupo -*-----------------------*\
  Component: naproxen methyl ester  (C15H16O3, CAS 26159-35-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naproxenMethylEster;
formula     C15H16O3;
CAS         26159-35-3;
InChIKey    ZFYFBPCRUQZGJE-JTQLQIEISA-N;
MW          244.29;      // g/mol [origin=calculated method=formula-sum]
Tc          901.16;      // K   [origin=predictive method=joback]
Pc          22.334;      // bar [origin=predictive method=joback]
omega       0.7863;      // -   [origin=predictive method=lee-kesler]
Tb          678.62;      // K   [origin=predictive method=joback]
HvapTb      63653.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.73 1.11516 -0.00062364 1.117e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 6; } { group AC; count 3; } { group ACCH; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (2s)-2-(6-methoxynaphthalen-2-yl)propanoate" "(s)-naproxen methyl ester" "(+)-naproxen methyl ester" "methyl (s)-2-(6-methoxynaphthalen-2-yl)propanoate" "(s)-6-methoxy-" "a-methyl-2-naphthaleneacetic acid methyl ester" "(" "as)-6-methoxy-" "a-methyl-2-naphthaleneacetic acid methyl ester" "2-naphthaleneacetic acid, 6-methoxy-alpha-methyl-, methyl ester, (alphas)-" );
standardThermochemistry
{
    dHf_298   -403050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-142590.0
}
