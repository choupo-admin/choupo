/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dihydro-methylethylidene-1,4-methanonaphthalene  (C14H14, CAS 7350-72-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14DihydroMethylethylidene14Methanonaphthalene;
formula     C14H14;
CAS         7350-72-3;
InChIKey    RRINDAPCHOTJQK-UHFFFAOYSA-N;
MW          182.266;      // g/mol [origin=calculated method=formula-sum]
Tc          797.32;      // K   [origin=predictive method=joback]
Pc          26.543;      // bar [origin=predictive method=joback]
omega       0.4955;      // -   [origin=predictive method=lee-kesler]
Tb          566.47;      // K   [origin=predictive method=joback]
HvapTb      50509.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.62 1.37324 -0.00114684 3.914e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=CH; count 1; } { group ACH; count 4; } { group ACCH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-methanonaphthalene,1,4-dihydro-9-((1-methylethylidene)-" "1,4-methanonaphthalene, 1,4-dihydro-9-((1-methylethylidene)-" "11-(1-methylethylidene)tricyclo[6.2.1.0~2,7~]undeca-2(7),3,5,9-tetraene" );
standardThermochemistry
{
    dHf_298   168550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     318.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=370250.0
}
