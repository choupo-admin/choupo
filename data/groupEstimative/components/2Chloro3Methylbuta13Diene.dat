/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-3-methylbuta-1,3-diene  (C5H7Cl, CAS 1809-02-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro3Methylbuta13Diene;
formula     C5H7Cl;
CAS         1809-02-5;
InChIKey    PKVRTDNAPQGMGP-UHFFFAOYSA-N;
MW          102.561;      // g/mol [origin=calculated method=formula-sum]
Tc          532.42;      // K   [origin=predictive method=joback]
Pc          37.135;      // bar [origin=predictive method=joback]
omega       0.2201;      // -   [origin=predictive method=lee-kesler]
Tb          344.55;      // K   [origin=predictive method=joback]
HvapTb      29929.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.87 0.44542 -0.000319 9.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 2; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 2; } { group dC; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-3-methyl-buta-1,3-diene" "1,3-butadiene, 2-chloro-3-methyl-" );
gibbsFormation
{
    dHf_298   69010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     366.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=137870.0
    phase     gas;
}
