/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-monomyristin  (C17H34O4, CAS 3443-83-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Monomyristin;
formula     C17H34O4;
CAS         3443-83-2;
InChIKey    TVIMZSOUQXNWHO-UHFFFAOYSA-N;
MW          302.455;      // g/mol [origin=calculated method=formula-sum]
Tc          1017.11;      // K   [origin=predictive method=joback]
Pc          14.208;      // bar [origin=predictive method=joback]
omega       1.2867;      // -   [origin=predictive method=lee-kesler]
Tb          830.70;      // K   [origin=predictive method=joback]
HvapTb      93813.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.744 1.63792 -0.0008704 1.531e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group CH; count 1; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(oxidanyl)propan-2-yl tetradecanoate" "myristin, 2-mono-" "1,3-dihydroxypropan-2-yl tetradecanoate" "tetradecanoic acid, 2-hydroxy-1-(hydroxymethyl)ethyl ester" "2-myristoyl-glycerol" "glycerin monomyristate" "glyceryl 2-myristate" "2-monotetradecanoylglycerol" "2-tetradecanoyl-sn-glycerol" "2-tetradecanoyl-rac-glycerol" "2-myristoyloxy-propane-1,3-diol" "mag(0:0/14:0)" );
standardThermochemistry
{
    dHf_298   -1021230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     961.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-494190.0
}
