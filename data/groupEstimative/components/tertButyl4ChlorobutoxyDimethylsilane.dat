/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl(4-chlorobutoxy)dimethylsilane  (C10H23ClOSi, CAS 89031-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H23ClOSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tertButyl4ChlorobutoxyDimethylsilane;
formula     C10H23ClOSi;
CAS         89031-83-4;
InChIKey    MTQPZXNVDIKRAK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          222.828;      // g/mol [origin=calculated method=formula-sum]
Tc          670.59;      // K   [origin=predictive method=joback]
Pc          18.373;      // bar [origin=predictive method=joback]
omega       0.4322;      // -   [origin=predictive method=lee-kesler]
Tb          486.42;      // K   [origin=predictive method=joback]
HvapTb      43647.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.534 0.8171 -0.0001866 -8.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 1; } { group CH2O; count 1; } { group CH2Cl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group C; count 1; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tert-butyl-(4-chloranylbutoxy)-dimethyl-silane" "tert-butyl-(4-chlorobutoxy)-dimethylsilane" "silane,(4-chlorobutoxy)(1,1-dimethylethyl)dimethyl-" );
standardThermochemistry
{
    dHf_298   -518060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     677.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-185530.0
}
