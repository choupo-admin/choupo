/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolpropane trioctanoate  (C30H56O6, CAS 4826-87-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolpropaneTrioctanoate;
formula     C30H56O6;
CAS         4826-87-3;
InChIKey    HFWHTGSLDKKCMD-UHFFFAOYSA-N;
MW          512.772;      // g/mol [origin=calculated method=formula-sum]
Tc          1326.75;      // K   [origin=predictive method=joback]
Pc          6.055;      // bar [origin=predictive method=joback]
omega       0.3179;      // -   [origin=predictive method=lee-kesler]
Tb          1057.43;      // K   [origin=predictive method=joback]
HvapTb      103299.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.372 2.81528 -0.0014962 2.464e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 19; } { group C; count 1; } { group CH2COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 22; } { group C; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(octanoyloxymethyl)butyl octanoate" "trimethylolpropane caprylate" "2-ethyl-2-(((1-oxooctyl)oxy)methyl)-1,3-propanediyl dioctanoate" "2-ethyl-2-[[(1-oxooctyl)oxy]methyl]-1,3-propanediyl dioctanoate" "octanoic acid, 1,1'-(2-ethyl-2-(((1-oxooctyl)oxy)methyl)-1,3-propanediyl) ester" "octanoic acid, 1,1'-[2-ethyl-2-[[(1-oxooctyl)oxy]methyl]-1,3-propanediyl] ester" "trimethylolpropane tricaprylate" "octanoic acid, 2-ethyl-2-(((1-oxooctyl)oxy)methyl)-1,3-propanediyl ester" "octanoic acid, triester with 2-ethyl-2-(hydroxymethyl)-1,3-propanediol" "2-ethyl-2-(((oxo-2-ethylhexyl)oxy)methyl)-1,3-propanediyl 2-ethylhexanoate" "2-ethylhexanoic acid, 2-ethyl-2-(((1-oxo-2-ethylhexyl)oxy)methyl)-1,3-propanediyl ester" );
standardThermochemistry
{
    dHf_298   -1623120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1439.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-726550.0
}
