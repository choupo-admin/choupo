/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylbutyl trichloroacetate  (C7H11Cl3O2, CAS 78031-35-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1MethylbutylTrichloroacetate;
formula     C7H11Cl3O2;
CAS         78031-35-3;
InChIKey    GKGUCQJRCNVBMU-UHFFFAOYSA-N;
MW          233.513;      // g/mol [origin=calculated method=formula-sum]
Tc          733.08;      // K   [origin=predictive method=joback]
Pc          25.793;      // bar [origin=predictive method=joback]
omega       0.5443;      // -   [origin=predictive method=lee-kesler]
Tb          526.60;      // K   [origin=predictive method=joback]
HvapTb      50054.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.452 0.76614 -0.0004986 1.134e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CCl3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group Cl; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentan-2-yl 2,2,2-tris(chloranyl)ethanoate" "trichloroacetic acid, 2-pentyl ester" "pentan-2-yl 2,2,2-trichloroacetate" "acetic acid, trichloro-, 1-methylbutyl ester" );
gibbsFormation
{
    dHf_298   -566340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-337700.0
    phase     gas;
}
