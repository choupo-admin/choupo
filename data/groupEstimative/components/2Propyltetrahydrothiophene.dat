/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propyltetrahydrothiophene  (C7H14S, CAS 1551-34-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propyltetrahydrothiophene;
formula     C7H14S;
CAS         1551-34-4;
InChIKey    RKTPCTKFTDSWND-UHFFFAOYSA-N;
MW          130.249;      // g/mol [origin=calculated method=formula-sum]
Tc          633.59;      // K   [origin=predictive method=joback]
Pc          33.960;      // bar [origin=predictive method=joback]
omega       0.3039;      // -   [origin=predictive method=lee-kesler]
Tb          422.87;      // K   [origin=predictive method=joback]
HvapTb      37245.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.138 0.81493 -0.0005031 1.204e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propylthiolane" "thiophane, propyl-" "thiophene, tetrahydro-2-propyl-" );
gibbsFormation
{
    dHf_298   -82070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=84470.0
    phase     gas;
}
