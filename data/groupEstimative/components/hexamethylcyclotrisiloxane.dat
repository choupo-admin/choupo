/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexamethylcyclotrisiloxane  (C6H18O3Si3, CAS 541-05-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H18O3Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        hexamethylcyclotrisiloxane;
formula     C6H18O3Si3;
CAS         541-05-9;
InChIKey    HTDJPCNNEPUOOQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          222.462;      // g/mol [origin=calculated method=formula-sum]
Tc          636.32;      // K   [origin=predictive method=joback]
Pc          24.556;      // bar [origin=predictive method=joback]
omega       0.2631;      // -   [origin=predictive method=lee-kesler]
Tb          433.34;      // K   [origin=predictive method=joback]
HvapTb      43584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (115.67 0.12372 0.0007079 -4.9e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group SiO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group O_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4,6,6-hexamethyl-1,3,5,2,4,6-trioxatrisilinane" "cyclotrisiloxane, hexamethyl-" "dimethylsiloxane cyclic trimer" "sdk 10" "cyclotrisiloxane, 2,2,4,4,6,6-hexamethyl-" "m556" "cyclotrisiloxane,hexamethyl- (6ci,8ci,9ci);dimethylsiloxane cyclic trimer;ls 8120;sdk 10;" );
standardThermochemistry
{
    dHf_298   -804890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-504540.0
}
