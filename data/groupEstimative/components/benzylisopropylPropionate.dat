/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzylisopropyl propionate  (C13H18O2, CAS 67785-77-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylisopropylPropionate;
formula     C13H18O2;
CAS         67785-77-7;
InChIKey    BLKIYRRGHOQSPP-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          791.27;      // K   [origin=predictive method=joback]
Pc          22.440;      // bar [origin=predictive method=joback]
omega       0.5834;      // -   [origin=predictive method=lee-kesler]
Tb          578.71;      // K   [origin=predictive method=joback]
HvapTb      52919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.898 1.23096 -0.0007918 1.838e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-1-phenyl-propan-2-yl) propanoate" "dimethylbenzylcarbinyl propionate" "alpha,alpha-dimethylphenethyl propionate" "alpha,alpha-dimethylbenzeneethanol, propionate" "benzeneethanol, alpha,alpha-dimethyl-, propanoate" "propanoic acid, 1,1-dimethyl-2-phenylethyl ester" "benzene ethanol, alpha,alpha-dimethyl-, propanoate" "phenethyl alcohol, alpha,alpha-dimethyl-, propionate" "propanoic acid, (3-phenyl-2-methyl-2-propyl) ester" "benzeneethanol, .alpha.,.alpha.-dimethyl-, propanoate" "benzyl-isopropyl propionate" "(2-methyl-1-phenylpropan-2-yl) propanoate" );
standardThermochemistry
{
    dHf_298   -401150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-136540.0
}
