/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-1,1,3,3,3-pentafluoropropane  (C3H2ClF5, CAS 460-92-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro11333Pentafluoropropane;
formula     C3H2ClF5;
CAS         460-92-4;
InChIKey    LLJWABOOFANACB-UHFFFAOYSA-N;
MW          168.489;      // g/mol [origin=calculated method=formula-sum]
Tc          441.66;      // K   [origin=predictive method=joback]
Pc          33.412;      // bar [origin=predictive method=joback]
omega       0.3086;      // -   [origin=predictive method=lee-kesler]
Tb          295.56;      // K   [origin=predictive method=joback]
HvapTb      19980.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.439 0.6062 -0.0005854 2.053e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CF3; count 1; } { group CClF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 2; } { group F; count 5; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-1,1,3,3,3-pentakis(fluoranyl)propane" "propane, 1-chloro-1,1,3,3,3-pentafluoro-" "propane,1-chloro-1,1,3,3,3-pentafluoro-" );
standardThermochemistry
{
    dHf_298   -1119040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1005920.0
}
