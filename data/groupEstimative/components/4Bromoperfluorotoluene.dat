/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromoperfluorotoluene  (C7BrF7, CAS 17823-46-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromoperfluorotoluene;
formula     C7BrF7;
CAS         17823-46-0;
InChIKey    DONVNRFILRLHJB-UHFFFAOYSA-N;
MW          296.967;      // g/mol [origin=calculated method=formula-sum]
Tc          644.98;      // K   [origin=predictive method=joback]
Pc          28.874;      // bar [origin=predictive method=joback]
omega       0.6783;      // -   [origin=predictive method=lee-kesler]
Tb          469.16;      // K   [origin=predictive method=joback]
HvapTb      36182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.47 0.539 -0.000411 1.183e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 2; } { group Br; count 1; } { group ACF; count 4; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dC_ring; count 6; } { group F; count 7; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2,3,5,6-tetrakis(fluoranyl)-4-(trifluoromethyl)benzene" "1-bromo-2,3,5,6-tetrafluoro-4-(trifluoromethyl)benzene" "4-trifluoromethyl-2,3,5,6-tetrafluorobromobenzene" "4-bromo-2,3,5,6-tetrafluorobenzotrifluoride" "p-bromoheptafluorotoluene" "b166" "4-bromo-alpha,alpha,alpha,2,3,5,6-heptafluorotoluene" );
gibbsFormation
{
    dHf_298   -1363820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1274190.0
    phase     gas;
}
