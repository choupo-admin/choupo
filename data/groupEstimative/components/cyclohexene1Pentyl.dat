/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene, 1-pentyl-  (C11H20, CAS 15232-85-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene1Pentyl;
formula     C11H20;
CAS         15232-85-6;
InChIKey    IOTQTOFPEVQVPG-UHFFFAOYSA-N;
MW          152.281;      // g/mol [origin=calculated method=formula-sum]
Tc          677.74;      // K   [origin=predictive method=joback]
Pc          24.629;      // bar [origin=predictive method=joback]
omega       0.4406;      // -   [origin=predictive method=lee-kesler]
Tb          479.64;      // K   [origin=predictive method=joback]
HvapTb      41772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.576 1.08192 -0.00063124 1.368e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pentylcyclohexene" "1-pentyl-1-cyclohexene" "1-pentyl-cyclohexene" );
gibbsFormation
{
    dHf_298   -149400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     552.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94230.0
    phase     gas;
}
