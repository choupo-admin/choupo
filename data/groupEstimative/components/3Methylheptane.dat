/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylheptane  (C8H18, CAS 589-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylheptane;
formula     C8H18;
CAS         589-81-1;
InChIKey    LAIUFBWHERIJIH-UHFFFAOYSA-N;
MW          114.232;      // g/mol [origin=calculated method=formula-sum]
Tc          549.48;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       0.3714;      // -   [origin=predictive method=lee-kesler]
Tb          382.20;      // K   [origin=predictive method=joback]
HvapTb      33014.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.066 0.76976 -0.0004146 8.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptane, 3-methyl-, (r)-" "2-ethylhexane" "3-methyl-heptane" "heptane, 3-methyl-, (s)-" );
standardThermochemistry
{
    dHf_298   -213730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14040.0
}
