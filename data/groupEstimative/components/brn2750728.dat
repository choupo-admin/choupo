/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2750728  (C20H34ClNO, CAS 29122-56-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2750728;
formula     C20H34ClNO;
CAS         29122-56-3;
InChIKey    QCFXUDLFIPHQPV-UHFFFAOYSA-N;
MW          339.948;      // g/mol [origin=calculated method=formula-sum]
Tc          962.24;      // K   [origin=predictive method=joback]
Pc          12.217;      // bar [origin=predictive method=joback]
omega       0.8410;      // -   [origin=predictive method=lee-kesler]
Tb          764.37;      // K   [origin=predictive method=joback]
HvapTb      71000.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.373 1.79714 -0.00099612 1.921e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 1; } { group CH; count 3; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 3; } { group CH; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(5-chloranyl-2-ethoxy-phenyl)-3-methyl-n,n-di(propan-2-yl)pentan-1-amine" "phenethylamine, beta-(sec-butyl)-5-chloro-2-ethoxy-n,n-diisopropyl-" "phenethylamine,b-sec-butyl-5-chloro-2-ethoxy-n,n-diisopropyl-(8ci)" "2-(5-chloro-2-ethoxyphenyl)-3-methyl-n,n-di(propan-2-yl)pentan-1-amine" "benzeneethanamine,5-chloro-2-ethoxy-n,n-bis(1-methylethyl)-b-(1-methylpropyl)-" );
standardThermochemistry
{
    dHf_298   -344090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     838.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=194760.0
}
