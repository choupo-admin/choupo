/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylcyclopropene  (C4H6, CAS 3100-04-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylcyclopropene;
formula     C4H6;
CAS         3100-04-7;
InChIKey    SHDPRTQPPWIEJG-UHFFFAOYSA-N;
MW          54.092;      // g/mol [origin=calculated method=formula-sum]
Tc          489.26;      // K   [origin=predictive method=joback]
Pc          49.733;      // bar [origin=predictive method=joback]
omega       0.2044;      // -   [origin=predictive method=lee-kesler]
Tb          306.67;      // K   [origin=predictive method=joback]
HvapTb      25674.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.85 0.44572 -0.00038964 1.432e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropene, 1-methyl-" "ethylbloc" "smartfresh" "cyclopropene, methyl-" "1-mcp" "1-methyl-cyclopropene" "1-mcp;cyclopropene, 1-methyl-;1-methylecyclopropene;afxrd 020;afxrd 038;ethylbloc;fitomag;smartfresh;" );
standardThermochemistry
{
    dHf_298   13560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     220.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71590.0
}
