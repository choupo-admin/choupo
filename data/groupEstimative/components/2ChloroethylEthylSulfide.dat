/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloroethyl ethyl sulfide  (C4H9ClS, CAS 693-07-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroethylEthylSulfide;
formula     C4H9ClS;
CAS         693-07-2;
InChIKey    GBNVXYXIRHSYEG-UHFFFAOYSA-N;
MW          124.626;      // g/mol [origin=calculated method=formula-sum]
Tc          597.26;      // K   [origin=predictive method=joback]
Pc          38.010;      // bar [origin=predictive method=joback]
omega       0.3312;      // -   [origin=predictive method=lee-kesler]
Tb          397.33;      // K   [origin=predictive method=joback]
HvapTb      35700.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.743 0.38501 -0.000174 1.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2Cl; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group Cl; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-ethylsulfanyl-ethane" "1-chloro-2-(ethylthio)ethane" "ethane, 1-chloro-2-(ethylthio)-" "half-mustard gas" "2-ethylthioethyl chloride" "2-(ethylthio)chloroethane" "sulfide, chloroethyl ethyl" "ethyl 2-chloroethyl sulfide" "2-chloroethyl ethyl thioether" "sulfide, 2-chloroethyl ethyl" "h-mg" "h-mg; half-mustard gas" );
standardThermochemistry
{
    dHf_298   -99760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=3990.0
}
