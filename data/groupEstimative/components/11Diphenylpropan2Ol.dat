/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diphenylpropan-2-ol  (C15H16O, CAS 29338-49-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diphenylpropan2Ol;
formula     C15H16O;
CAS         29338-49-6;
InChIKey    BDZAWYBXBHTHFM-UHFFFAOYSA-N;
MW          212.292;      // g/mol [origin=calculated method=formula-sum]
Tc          911.93;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       0.9311;      // -   [origin=predictive method=lee-kesler]
Tb          687.46;      // K   [origin=predictive method=joback]
HvapTb      69439.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.63 1.31682 -0.0008914 2.271e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diphenyl-2-propanol" "1,1-diphenyl-propan-2-ol" "benzeneethanol, a-methyl-b-phenyl-" "alpha-methyl-beta-phenylphenethyl alcohol" "benzeneethanol, .alpha.-methyl-.beta.-phenyl-" );
standardThermochemistry
{
    dHf_298   -42660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158540.0
}
