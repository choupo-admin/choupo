/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloprovera  (C50H70O7, CAS 71615-27-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloprovera;
formula     C50H70O7;
CAS         71615-27-5;
InChIKey    NEDJKVIUOSOCNB-AWPSVMBFSA-N;
MW          783.103;      // g/mol [origin=calculated method=formula-sum]
Tc          2293.91;      // K   [origin=predictive method=joback]
Pc          5.584;      // bar [origin=predictive method=joback]
omega       0.0673;      // -   [origin=predictive method=lee-kesler]
Tb          1769.51;      // K   [origin=predictive method=joback]
HvapTb      164604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-531.878 6.29842 -0.00516766 1.81966e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 16; } { group CH; count 8; } { group C; count 4; } { group CH=C; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } { group CH3COO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group CH2_ring; count 17; } { group CH_ring; count 9; } { group C_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group CdO; count 1; } { group CdO_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(6s,8r,9s,10r,13s,14s,17r)-17-ethanoyl-6,10,13-trimethyl-3-oxidanylidene-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthren-17-yl] ethanoate;[(8r,9s,13s,14s,17s)-13-methyl-3-oxidanyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-17-yl] 3-cyclopentylpropanoate" "cyclofem" "estradiol cypionate mixed with medroxyprogesterone acetate" "medroxyprogesterone acetate mixed with estradiol cypionate" "estradiol cypionate mixture with medroxyprogesterone acetate" "pregn-4-ene-3,20-dione, 17-(acetyloxy)-6-methyl-, (6-alpha)-, mixt. with (17-beta)-3-hydroxyestra-1,3,5(10)-trien-17-yl cyclopentanepropanoate" "c26h36o3.c24h34o4" "[(6s,8r,9s,10r,13s,14s,17r)-17-acetyl-6,10,13-trimethyl-3-oxo-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthren-17-yl] acetate; [(8r,9s,13s,14s,17s)-3-hydroxy-13-methyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-17-yl] 3-cyclopentylpropanoate" );
standardThermochemistry
{
    dHf_298   -1491510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1655.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-321810.0
}
