/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisphenol af  (C15H10F6O2, CAS 1478-61-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisphenolAf;
formula     C15H10F6O2;
CAS         1478-61-1;
InChIKey    ZFVMWEVVKGLCIJ-UHFFFAOYSA-N;
MW          336.231;      // g/mol [origin=calculated method=formula-sum]
Tc          970.18;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       1.0631;      // -   [origin=predictive method=lee-kesler]
Tb          743.33;      // K   [origin=predictive method=joback]
HvapTb      70774.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.27 2.0284 -0.00198112 7.338e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[1,1,1,3,3,3-hexakis(fluoranyl)-2-(4-hydroxyphenyl)propan-2-yl]phenol" "4,4'-(hexafluoroisopropylidene)diphenol" "2,2-bis(4-hydroxyphenyl)hexafluoropropane" "biphenol af" "hexafluorodiphenylolpropane" "hexafluoroisopropylidenebis(4-hydroxybenzene)" "hexafluoroacetone bisphenol a" "4,4'-(1,1,1,3,3,3-hexafluoropropane-2,2-diyl)diphenol" "2,2-bis(4-hydroxyphenyl)perfluoropropane" "2,2-bis-(p-hydroxyphenyl)-hexafluoropropane" "bisphenol a hexafluoride" "phenol, 4,4'-(bis(trifluoromethyl)methylene)di-" );
gibbsFormation
{
    dHf_298   -1437400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     653.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1169340.0
    phase     gas;
}
