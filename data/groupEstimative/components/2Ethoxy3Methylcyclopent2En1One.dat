/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethoxy-3-methylcyclopent-2-en-1-one  (C8H12O2, CAS 67923-55-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethoxy3Methylcyclopent2En1One;
formula     C8H12O2;
CAS         67923-55-1;
InChIKey    JSMWJHCOWHXYML-UHFFFAOYSA-N;
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          716.95;      // K   [origin=predictive method=joback]
Pc          32.690;      // bar [origin=predictive method=joback]
omega       0.5096;      // -   [origin=predictive method=lee-kesler]
Tb          501.95;      // K   [origin=predictive method=joback]
HvapTb      42241.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.501 0.51554 -9.24e-05 -6.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2CO; count 1; } { group CH2O; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 2; } { group dC_ring; count 2; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxy-3-methyl-cyclopent-2-en-1-one" "2-cyclopenten-1-one, 2-ethoxy-3-methyl-" "2-ethoxy-3-methyl-2-cyclopenten-1-one" );
standardThermochemistry
{
    dHf_298   -362710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-156150.0
}
