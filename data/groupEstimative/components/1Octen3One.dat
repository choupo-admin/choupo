/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octen-3-one  (C8H14O, CAS 4312-99-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octen3One;
formula     C8H14O;
CAS         4312-99-6;
InChIKey    KLTVSWGXIAYTHO-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          612.27;      // K   [origin=predictive method=joback]
Pc          28.263;      // bar [origin=predictive method=joback]
omega       0.5015;      // -   [origin=predictive method=lee-kesler]
Tb          433.19;      // K   [origin=predictive method=joback]
HvapTb      39478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.016 0.71582 -0.0004156 9.236e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oct-1-en-3-one" "vinyl amyl ketone" "amyl vinyl ketone" "pentyl vinyl ketone" "1-octen-3-one solution" "n-amyl vinyl ketone; n-pentyl vinyl ketone" );
gibbsFormation
{
    dHf_298   -195600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-24600.0
    phase     gas;
}
