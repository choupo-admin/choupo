/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4,4-tetramethylcyclobutane-1,3-diamine  (C8H18N2, CAS 7531-10-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2244Tetramethylcyclobutane13Diamine;
formula     C8H18N2;
CAS         7531-10-4;
InChIKey    QWEVGNOJPHTVEY-UHFFFAOYSA-N;
MW          142.246;      // g/mol [origin=calculated method=formula-sum]
Tc          752.42;      // K   [origin=predictive method=joback]
Pc          33.567;      // bar [origin=predictive method=joback]
omega       0.5049;      // -   [origin=predictive method=lee-kesler]
Tb          525.18;      // K   [origin=predictive method=joback]
HvapTb      51540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.93 1.53328 -0.001571 6.868e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group CHNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH_ring; count 2; } { group C_ring; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-cyclobutanediamine, 2,2,4,4-tetramethyl-" "1,3-diamino-2,2,4,4-tetramethylcyclobutane" "1,2,4,4-tetramethylcyclobutane" "2,4,4-tetramethylcyclobutane-1,3-diamine" "2,2,4,4-tetramethyl-1,3-cyclobutane diamine" );
gibbsFormation
{
    dHf_298   -104770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=163920.0
    phase     gas;
}
