/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(methylthio)-2-propanol  (C4H10OS, CAS 6943-87-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylthio2Propanol;
formula     C4H10OS;
CAS         6943-87-9;
InChIKey    VHMYGROEIUZTQW-UHFFFAOYSA-N;
MW          106.183;      // g/mol [origin=calculated method=formula-sum]
Tc          639.79;      // K   [origin=predictive method=joback]
Pc          45.347;      // bar [origin=predictive method=joback]
omega       0.7018;      // -   [origin=predictive method=lee-kesler]
Tb          451.64;      // K   [origin=predictive method=joback]
HvapTb      47606.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.461 0.41813 -0.0001872 1.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylsulfanylpropan-2-ol" "2-propanol, 1-(methylthio)-" "1-(methylsulfanyl)propan-2-ol" "1-(methylthio)propan-2-ol" );
gibbsFormation
{
    dHf_298   -241530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-123340.0
    phase     gas;
}
