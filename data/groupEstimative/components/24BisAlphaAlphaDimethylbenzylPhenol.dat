/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-bis(alpha,alpha-dimethylbenzyl)phenol  (C24H26O, CAS 2772-45-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24BisAlphaAlphaDimethylbenzylPhenol;
formula     C24H26O;
CAS         2772-45-4;
InChIKey    FMUYQRFTLHAARI-UHFFFAOYSA-N;
MW          330.471;      // g/mol [origin=calculated method=formula-sum]
Tc          1175.35;      // K   [origin=predictive method=joback]
Pc          18.000;      // bar [origin=predictive method=joback]
omega       0.8618;      // -   [origin=predictive method=lee-kesler]
Tb          907.90;      // K   [origin=predictive method=joback]
HvapTb      86930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-164.21 2.39388 -0.00190832 6.029e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group ACH; count 13; } { group AC; count 4; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 2; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(2-phenylpropan-2-yl)phenol" "2,4-bis(1-methyl-1-phenylethyl)phenol" "phenol, 2,4-bis(1-methyl-1-phenylethyl)-" "2,4-dicumyl phenol" "2,4-di(alpha-methylstyryl)phenol" "phenol, 2,4-bis(alpha,alpha-dimethylbenzyl)-" "2,4-dicumylphenol" "2,4-di-alpha-cumylphenol" "2,4-bis(dimethylbenzyl)phenol" "2,4-bis(" "a," "a-dimethylbenzyl)phenol" );
gibbsFormation
{
    dHf_298   -35380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     714.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=329860.0
    phase     gas;
}
