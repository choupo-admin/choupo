/*--------------------------------*- Choupo -*-----------------------*\
  Component: propiolamide  (C3H3NO, CAS 7341-96-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propiolamide;
formula     C3H3NO;
CAS         7341-96-0;
InChIKey    HCJTYESURSHXNB-UHFFFAOYSA-N;
MW          69.063;      // g/mol [origin=calculated method=formula-sum]
Tc          597.30;      // K   [origin=predictive method=joback]
Pc          65.247;      // bar [origin=predictive method=joback]
omega       0.3837;      // -   [origin=predictive method=lee-kesler]
Tb          384.76;      // K   [origin=predictive method=joback]
HvapTb      39517.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.79 0.2288 -0.00016003 4.485e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH_C; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-ynamide" "propynoic acid amide" "2-propynamide" "propiolic acid amide" "hc.equiv.cconh2" "2-propynamide (9ci)" "hc.$.cconh2" "propynoic acid amide, propynamide" );
gibbsFormation
{
    dHf_298   107860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     320.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=134980.0
    phase     gas;
}
