/*--------------------------------*- Choupo -*-----------------------*\
  Component: (chloromethyl)cyclopropane  (C4H7Cl, CAS 5911-08-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloromethylCyclopropane;
formula     C4H7Cl;
CAS         5911-08-0;
InChIKey    ZVTQWXCKQTUVPY-UHFFFAOYSA-N;
MW          90.55;      // g/mol [origin=calculated method=formula-sum]
Tc          524.18;      // K   [origin=predictive method=joback]
Pc          43.916;      // bar [origin=predictive method=joback]
omega       0.2335;      // -   [origin=predictive method=lee-kesler]
Tb          335.29;      // K   [origin=predictive method=joback]
HvapTb      28796.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.099 0.5415 -0.0004344 1.447e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethylcyclopropane" "cyclopropylmethyl chloride" "chlorocyclopropylmethane" "1 -(chloromethyl)cyclopropane" "zvtqwxckqtuvpy-uhfffaoysa-" "(chloromethyl)cyclopropane;chlorocyclopropylmethane;cyclopropanemethyl chloride;cyclopropylcarbinylchloride;cyclopropylchloromethane;a-(chloromethyl)cyclopropane;" );
gibbsFormation
{
    dHf_298   -68830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     254.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31620.0
    phase     gas;
}
