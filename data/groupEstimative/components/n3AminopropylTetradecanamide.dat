/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(3-aminopropyl)tetradecanamide  (C17H36N2O, CAS 13482-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3AminopropylTetradecanamide;
formula     C17H36N2O;
CAS         13482-06-9;
InChIKey    OTCJNNORZZUDIL-UHFFFAOYSA-N;
MW          284.488;      // g/mol [origin=calculated method=formula-sum]
Tc          946.78;      // K   [origin=predictive method=joback]
Pc          13.546;      // bar [origin=predictive method=joback]
omega       1.1104;      // -   [origin=predictive method=lee-kesler]
Tb          765.13;      // K   [origin=predictive method=joback]
HvapTb      77259.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.075 1.72892 -0.0009743 2.0356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH2NH2; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(3-azanylpropyl)tetradecanamide" "tetradecanamide, n-(3-aminopropyl)-" "n-(3-aminopropyl)myristamide" "tetradecanoic acid, 1,3-propylenediamine monoamide" );
gibbsFormation
{
    dHf_298   -419530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     937.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=119180.0
    phase     gas;
}
