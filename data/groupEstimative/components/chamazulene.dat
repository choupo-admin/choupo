/*--------------------------------*- Choupo -*-----------------------*\
  Component: chamazulene  (C14H16, CAS 529-05-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chamazulene;
formula     C14H16;
CAS         529-05-5;
InChIKey    GXGJIOMUZAGVEH-UHFFFAOYSA-N;
MW          184.282;      // g/mol [origin=calculated method=formula-sum]
Tc          804.66;      // K   [origin=predictive method=joback]
Pc          24.243;      // bar [origin=predictive method=joback]
omega       0.5394;      // -   [origin=predictive method=lee-kesler]
Tb          580.52;      // K   [origin=predictive method=joback]
HvapTb      52660.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.289 1.07276 -0.0007046 1.873e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group AC; count 2; } { group ACCH3; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-ethyl-1,4-dimethyl-azulene" "chamazulen" "dimethulene" "camazulene" "dimethulen" "7-ethyl-1,4-dimethylazulene" "azulene, 7-ethyl-1,4-dimethyl-" "1,4-dimethyl-7-ethylazulene" "azulene, 1,4-dimethyl-7-ethyl-" "ambotz529-05-5" "gxgjiomuzagveh-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   60900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=257170.0
    phase     gas;
}
