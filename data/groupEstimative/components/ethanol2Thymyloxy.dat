/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanol, 2-thymyloxy-  (C12H18O2, CAS 55129-21-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanol2Thymyloxy;
formula     C12H18O2;
CAS         55129-21-0;
InChIKey    CLSSBPVJCYTWNL-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          816.94;      // K   [origin=predictive method=joback]
Pc          25.354;      // bar [origin=predictive method=joback]
omega       0.9990;      // -   [origin=predictive method=lee-kesler]
Tb          624.96;      // K   [origin=predictive method=joback]
HvapTb      64607.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.782 0.92266 -0.00044872 6.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(5-methyl-2-propan-2-yl-phenoxy)ethanol" "ethanol, 2-thymyloxy-," "2-(5-methyl-2-propan-2-ylphenoxy)ethanol" );
gibbsFormation
{
    dHf_298   -367150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-100950.0
    phase     gas;
}
