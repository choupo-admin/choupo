/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-methylcinnamic acid  (C10H10O2, CAS 1199-77-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaMethylcinnamicAcid;
formula     C10H10O2;
CAS         1199-77-5;
InChIKey    XNCRUNXWPDJHGV-UHFFFAOYSA-N;
MW          162.188;      // g/mol [origin=calculated method=formula-sum]
Tc          838.51;      // K   [origin=predictive method=joback]
Pc          34.561;      // bar [origin=predictive method=joback]
omega       0.7104;      // -   [origin=predictive method=lee-kesler]
Tb          604.63;      // K   [origin=predictive method=joback]
HvapTb      57332.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.38 0.94562 -0.0007101 2.105e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-3-phenyl-prop-2-enoic acid" "alpha-methyl cinnamic acid" "2-methyl-3-phenylprop-2-enoic acid" "a-methylcinnamic acid" "2-propenoic acid, 2-methyl-3-phenyl-, (2e)-" "2-propenoic acid, 2-methyl-3-phenyl-, (2z)-" );
standardThermochemistry
{
    dHf_298   -256040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-126510.0
}
