/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,1'-biphenyl)-4-carboxylic acid, 4'-(2-methylbutyl)-, 4-(hexyloxy)phenyl ester  (C30H36O3, CAS 81367-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Biphenyl4CarboxylicAcid42Methylbutyl4HexyloxyPhenylEster;
formula     C30H36O3;
CAS         81367-71-7;
InChIKey    MTNDUQQONLQZBU-HSZRJFAPSA-N;
MW          444.615;      // g/mol [origin=calculated method=formula-sum]
Tc          1302.05;      // K   [origin=predictive method=joback]
Pc          10.053;      // bar [origin=predictive method=joback]
omega       0.9477;      // -   [origin=predictive method=lee-kesler]
Tb          1061.18;      // K   [origin=predictive method=joback]
HvapTb      100617.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.973 2.32656 -0.00129828 2.352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group ACH; count 12; } { group AC; count 5; } { group ACCH; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-hexoxyphenyl) 4-[4-[(2r)-pentan-2-yl]phenyl]benzoate" );
gibbsFormation
{
    dHf_298   -442130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1039.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=92250.0
    phase     gas;
}
