/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-3-penten-1-ol  (C6H12O, CAS 763-89-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl3Penten1Ol;
formula     C6H12O;
CAS         763-89-3;
InChIKey    FKKLUOCEIANSFL-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          605.05;      // K   [origin=predictive method=joback]
Pc          36.955;      // bar [origin=predictive method=joback]
omega       0.6951;      // -   [origin=predictive method=lee-kesler]
Tb          433.10;      // K   [origin=predictive method=joback]
HvapTb      45667.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.148 0.62774 -0.0004191 1.192e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylpent-3-en-1-ol" "3-penten-1-ol, 4-methyl-" "3-penten-1-ol,4-methyl-" );
standardThermochemistry
{
    dHf_298   -211970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-65510.0
}
