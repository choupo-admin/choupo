/*--------------------------------*- Choupo -*-----------------------*\
  Component: fenpiprane  (C20H25N, CAS 3540-95-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fenpiprane;
formula     C20H25N;
CAS         3540-95-2;
InChIKey    JXJPYHDHJZJWRI-UHFFFAOYSA-N;
MW          279.427;      // g/mol [origin=calculated method=formula-sum]
Tc          984.88;      // K   [origin=predictive method=joback]
Pc          19.631;      // bar [origin=predictive method=joback]
omega       0.7180;      // -   [origin=predictive method=lee-kesler]
Tb          742.51;      // K   [origin=predictive method=joback]
HvapTb      66887.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-161.898 2.034 -0.0014252 3.824e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3,3-diphenylpropyl)piperidine" "fenpiprane (inn)" "fenpiprane [inn:ban]" );
standardThermochemistry
{
    dHf_298   160000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     720.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=494940.0
}
