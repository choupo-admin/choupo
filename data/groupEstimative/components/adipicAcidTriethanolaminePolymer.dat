/*--------------------------------*- Choupo -*-----------------------*\
  Component: adipic acid, triethanolamine polymer  (C12H25NO7, CAS 62118-43-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        adipicAcidTriethanolaminePolymer;
formula     C12H25NO7;
CAS         62118-43-8;
InChIKey    VGNUTRRATQMMHI-UHFFFAOYSA-N;
MW          295.332;      // g/mol [origin=calculated method=formula-sum]
Tc          1309.61;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       1.5908;      // -   [origin=predictive method=lee-kesler]
Tb          1055.56;      // K   [origin=predictive method=joback]
HvapTb      129008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.18 1.2651 -0.0005632 3.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group OH; count 3; } { group CH2N; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group OH; count 3; } { group COOH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2-hydroxyethyl)amino]ethanol;hexanedioic acid" "2-[bis(2-hydroxyethyl)amino]ethanol; hexanedioic acid" "adipic acid, compound with 2,2',2''-nitrilotriethanol" "hexanedioic acid, polymer with 2,2',2''-nitrilotris(ethanol)" );
gibbsFormation
{
    dHf_298   -1492330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1006.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1042100.0
    phase     gas;
}
