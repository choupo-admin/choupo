/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dinonylphenol  (C24H42O, CAS 137-99-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dinonylphenol;
formula     C24H42O;
CAS         137-99-5;
InChIKey    FDAJTLLBHNHECW-UHFFFAOYSA-N;
MW          346.599;      // g/mol [origin=calculated method=formula-sum]
Tc          1058.83;      // K   [origin=predictive method=joback]
Pc          10.701;      // bar [origin=predictive method=joback]
omega       0.9775;      // -   [origin=predictive method=lee-kesler]
Tb          861.00;      // K   [origin=predictive method=joback]
HvapTb      84970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.454 2.30004 -0.00150232 4.081e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group ACH; count 3; } { group ACCH2; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-di(nonyl)phenol" "phenol, 2,4-dinonyl-" "2,4-dinonylphenol;" );
gibbsFormation
{
    dHf_298   -490940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1004.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99360.0
    phase     gas;
}
