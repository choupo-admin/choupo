/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorobenzene  (C6H5Cl, CAS 108-90-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorobenzene;
formula     C6H5Cl;
CAS         108-90-7;
InChIKey    MVPPADPHJFYWMZ-UHFFFAOYSA-N;
MW          112.556;      // g/mol [origin=calculated method=formula-sum]
Tc          623.46;      // K   [origin=predictive method=joback]
Pc          44.444;      // bar [origin=predictive method=joback]
omega       0.2562;      // -   [origin=predictive method=lee-kesler]
Tb          400.99;      // K   [origin=predictive method=joback]
HvapTb      35611.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.58 0.5017 -0.0003542 9.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranylbenzene" "monochlorobenzene" "benzene, chloro-" "benzene chloride" "phenyl chloride" "chlorbenzene" "chlorobenzol" "monochlorbenzol" "chlorbenzol" "monochlorbenzene" "chlorobenzene, mono-" "chloorbenzeen" );
gibbsFormation
{
    dHf_298   53620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     316.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100120.0
    phase     gas;
}
