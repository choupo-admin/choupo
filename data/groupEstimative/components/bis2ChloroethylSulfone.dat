/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-chloroethyl) sulfone  (C4H8Cl2O2S, CAS 471-03-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H8Cl2O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bis2ChloroethylSulfone;
formula     C4H8Cl2O2S;
CAS         471-03-4;
InChIKey    LUYAMNYBNTVQJG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          191.066;      // g/mol [origin=calculated method=formula-sum]
Tc          500.59;      // K   [origin=predictive method=joback]
Pc          40.570;      // bar [origin=predictive method=joback]
omega       0.5178;      // -   [origin=predictive method=lee-kesler]
Tb          344.98;      // K   [origin=predictive method=joback]
HvapTb      45086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.674 0.4366 -0.0002092 1.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2Cl; count 2; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group Cl; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-(2-chloroethylsulfonyl)ethane" "mustard sulfone" "yperite sulfone" "h sulfone" "mustard gas sulfone" "sulfone, bis(2-chloroethyl)" "bis(.beta.-chloroethyl) sulfone" "bis(2-chloroethyl)sulfone" "bis(beta-chloroethyl)sulfone" "bis(beta-chloroethyl) sulfone" "ethane, 1,1'-sulfonylbis(2-chloro-" "ethane, 1,1'-sulfonylbis[2-chloro-" );
standardThermochemistry
{
    dHf_298   -652590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     637.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-542720.0
}
