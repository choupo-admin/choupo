/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethylpropane-1,3-diyl bisisobutyrate  (C13H24O4, CAS 63512-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethylpropane13DiylBisisobutyrate;
formula     C13H24O4;
CAS         63512-34-5;
InChIKey    HACYJIJMLQDPDS-UHFFFAOYSA-N;
MW          244.331;      // g/mol [origin=calculated method=formula-sum]
Tc          795.05;      // K   [origin=predictive method=joback]
Pc          17.061;      // bar [origin=predictive method=joback]
omega       0.7601;      // -   [origin=predictive method=lee-kesler]
Tb          609.37;      // K   [origin=predictive method=joback]
HvapTb      57274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.052 1.26692 -0.0006724 1.002e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2-dimethyl-3-(2-methylpropanoyloxy)propyl] 2-methylpropanoate" "2,2-dimethylpropane-1,3-diyl bis(2-methylpropanoate)" "1,3-propanediol diisobutyrate, 2,2-dimethyl" );
gibbsFormation
{
    dHf_298   -965520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     707.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-564200.0
    phase     gas;
}
