/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-9-carboxydecalin  (C11H18O2, CAS 3021-73-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis9Carboxydecalin;
formula     C11H18O2;
CAS         3021-73-6;
InChIKey    VAMBVWHKUJPMEB-UHFFFAOYSA-N;
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          868.57;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.6791;      // -   [origin=predictive method=lee-kesler]
Tb          627.59;      // K   [origin=predictive method=joback]
HvapTb      56607.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-173.47 1.6549 -0.0014346 5.247e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 1; } { group C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5,6,7,8,8a-octahydro-1h-naphthalene-4a-carboxylic acid" "cis-decalin-9-carboxylic acid" "octahydro-4a(2h)-naphthalenecarboxylic acid" "4a(2h)-naphthalenecarboxylic acid, octahydro-, cis-" "4a(2h)-naphthalenecarboxylic acid, octahydro-, trans-" "cis-decalin-9-carboxylicacid" "trans-decalin-9-carboxylic acid" "4a(2h)-naphthalenecarboxylic acid, octahydro-" "4a(2h)-naphthalenecarboxylicacid, octahydro-, cis-" "cis-octahydro-4a(2h)-naphthalenecarboxylic acid" );
gibbsFormation
{
    dHf_298   -484440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     606.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-234560.0
    phase     gas;
}
