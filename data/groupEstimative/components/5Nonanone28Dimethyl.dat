/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-nonanone, 2,8-dimethyl-  (C11H22O, CAS 2050-99-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Nonanone28Dimethyl;
formula     C11H22O;
CAS         2050-99-9;
InChIKey    JQCWLRHNAHIIGW-UHFFFAOYSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          682.76;      // K   [origin=predictive method=joback]
Pc          20.755;      // bar [origin=predictive method=joback]
omega       0.6050;      // -   [origin=predictive method=lee-kesler]
Tb          504.27;      // K   [origin=predictive method=joback]
HvapTb      46050.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.116 1.03268 -0.0005623 1.0966e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,8-dimethylnonan-5-one" "2,8-dimethyl-5-nonanone" "diisoamyl ketone" "5-nonanone,2,8-dimethyl-" "2,8-dimethyl-5-nonanone;diisopentyl ketone" );
standardThermochemistry
{
    dHf_298   -393510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-92060.0
}
