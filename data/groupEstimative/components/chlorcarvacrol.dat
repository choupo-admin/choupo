/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorcarvacrol  (C10H13ClO, CAS 5665-94-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorcarvacrol;
formula     C10H13ClO;
CAS         5665-94-1;
InChIKey    AFFXNOIULZQAML-UHFFFAOYSA-N;
MW          184.663;      // g/mol [origin=calculated method=formula-sum]
Tc          812.46;      // K   [origin=predictive method=joback]
Pc          32.393;      // bar [origin=predictive method=joback]
omega       0.6439;      // -   [origin=predictive method=lee-kesler]
Tb          582.65;      // K   [origin=predictive method=joback]
HvapTb      58465.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.22 0.92326 -0.00069728 2.251e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 2; } { group ACCH3; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-2-methyl-5-propan-2-yl-phenol" "carvasept" "monochloroisothymol" "5-chlorocarvacrol" "mcit" "carvacrol, 5-chloro-" "4-chloro-2-methyl-5-(1-methylethyl)phenol" "4-chloro-5-isopropyl-2-methylphenol" "phenol, 4-chloro-2-methyl-5-(1-methylethyl)-" "4-chloro-2-methyl-5-propan-2-ylphenol" "4-chloro-2-methyl-5-(methylethyl)phenol" "phenol, 4-chloro-2-methyl-5-(1-methylethyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   -234470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42520.0
}
