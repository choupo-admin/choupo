/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-decoxypropanenitrile  (C13H25NO, CAS 16728-51-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Decoxypropanenitrile;
formula     C13H25NO;
CAS         16728-51-1;
InChIKey    VBBZORLTUCTLEO-UHFFFAOYSA-N;
MW          211.349;      // g/mol [origin=calculated method=formula-sum]
Tc          797.73;      // K   [origin=predictive method=joback]
Pc          15.898;      // bar [origin=predictive method=joback]
omega       0.8538;      // -   [origin=predictive method=lee-kesler]
Tb          621.54;      // K   [origin=predictive method=joback]
HvapTb      57420.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.571 1.11042 -0.0005414 8.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH2O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(decyloxy)propionitrile" "propanenitrile, 3-(decyloxy)-" "3-decyloxypropanenitrile" "3-(decyloxy)propanenitrile" "3-(decyloxy)propiononitrile" );
gibbsFormation
{
    dHf_298   -278990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     679.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86760.0
    phase     gas;
}
