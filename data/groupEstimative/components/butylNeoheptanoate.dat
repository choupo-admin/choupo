/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl neoheptanoate  (C11H22O2, CAS 68039-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylNeoheptanoate;
formula     C11H22O2;
CAS         68039-02-1;
InChIKey    MWIRMYXMMPLBOV-UHFFFAOYSA-N;
MW          186.295;      // g/mol [origin=calculated method=formula-sum]
Tc          683.97;      // K   [origin=predictive method=joback]
Pc          19.753;      // bar [origin=predictive method=joback]
omega       0.5923;      // -   [origin=predictive method=lee-kesler]
Tb          506.27;      // K   [origin=predictive method=joback]
HvapTb      46191.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.175 1.11988 -0.0006518 1.345e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 4,4-dimethylpentanoate" "neoheptanoic acid, butyl ester" "n-butyl neoheptanoate" "neoheptanoic acid,butyl ester" "4,4-dimethyl-pentanoic acid butyl ester" );
standardThermochemistry
{
    dHf_298   -596400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-265790.0
}
