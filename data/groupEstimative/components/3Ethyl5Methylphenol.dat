/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethyl-5-methylphenol  (C9H12O, CAS 698-71-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethyl5Methylphenol;
formula     C9H12O;
CAS         698-71-5;
InChIKey    XTCHLXABLZQNNN-UHFFFAOYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          741.26;      // K   [origin=predictive method=joback]
Pc          38.245;      // bar [origin=predictive method=joback]
omega       0.5653;      // -   [origin=predictive method=lee-kesler]
Tb          517.80;      // K   [origin=predictive method=joback]
HvapTb      51580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.819 0.87504 -0.00068632 2.296e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-5-methyl-phenol" "m-cresol, 5-ethyl-" "phenol, 3-ethyl-5-methyl-" "3-methyl-5-ethylphenol" "1-hydroxy-3-methyl-5-ethylbenzene" "5-ethyl-m-cresol" "m-cresol, 5-ethyl- (8ci)" "phenol, 3-ethyl-5-methyl- (9ci)" );
gibbsFormation
{
    dHf_298   -181340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26940.0
    phase     gas;
}
