/*--------------------------------*- Choupo -*-----------------------*\
  Component: ketotifen fumarate  (C23H23NO5S, CAS 34580-14-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ketotifenFumarate;
formula     C23H23NO5S;
CAS         34580-14-8;
InChIKey    YNQQEYBLVYAWNX-WLHGVMLRSA-N;
MW          425.499;      // g/mol [origin=calculated method=formula-sum]
Tc          1536.55;      // K   [origin=predictive method=joback]
Pc          18.838;      // bar [origin=predictive method=joback]
omega       1.4954;      // -   [origin=predictive method=lee-kesler]
Tb          1250.88;      // K   [origin=predictive method=joback]
HvapTb      121290.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.72 2.02363 -0.00122794 2.584e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2CO; count 1; } { group CH3N; count 1; } { group COOH; count 2; } { group C=C; count 1; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group CH2_ring; count 5; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group CdO_ring; count 1; } { group COOH; count 2; } { group N; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-but-2-enedioic acid;10-(1-methylpiperidin-4-ylidene)-5h-benzo[1,2]cyclohepta[3,4-b]thiophen-4-one" "zaditen" "zaditor" "alaway" "ketotifen fumarate salt" "ketotifen hydrogen fumarate" "4,9-dihydro-4-(1-methylpiperidin-4-ylidene)-10h-benzo(4,5)cyclohepta(1,2-b)thiophene-10-one fumarate" "prestwick_743" "zaditen (tn)" "fumaric acid; ketotifen" "hc-20511 fumarate" "hc 20,511 fumarate" );
gibbsFormation
{
    dHf_298   -630600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     933.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230410.0
    phase     gas;
}
