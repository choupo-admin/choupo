/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxypinone  (C10H16O2, CAS 10136-65-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxypinone;
formula     C10H16O2;
CAS         10136-65-9;
InChIKey    VZRRCQOUNSHSGB-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          811.93;      // K   [origin=predictive method=joback]
Pc          32.954;      // bar [origin=predictive method=joback]
omega       0.8267;      // -   [origin=predictive method=lee-kesler]
Tb          597.29;      // K   [origin=predictive method=joback]
HvapTb      55858.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-158.19 1.64256 -0.001655 7.129e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group C; count 2; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 2; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,6,6-trimethyl-4-oxidanyl-bicyclo[3.1.1]heptan-3-one" "camphostene" "oxypinocamphone" "2-hydroxypinocamphone" "3-hydroxypinocamphone" "2-hydroxy-3-pinanone" "3-pinanone, 2-hydroxy-" "2-hydroxy-2,6,6-trimethylbicyclo(3.1.1)heptan-3-one" "4-hydroxy-4,6,6-trimethylbicyclo[3.1.1]heptan-3-one" "bicyclo(3.1.1)heptan-3-one, 2-hydroxy-2,6,6-trimethyl-" "bicyclo[3.1.1]heptan-3-one,2-hydroxy-2,6,6-trimethyl-" "(1r,2s,5r)-2-hydroxy-2,6,6-trimethylbicyclo[3.1.1]heptan-3-one" );
standardThermochemistry
{
    dHf_298   -410420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-143090.0
}
