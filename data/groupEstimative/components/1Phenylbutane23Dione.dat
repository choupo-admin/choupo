/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylbutane-2,3-dione  (C10H10O2, CAS 38087-02-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenylbutane23Dione;
formula     C10H10O2;
CAS         38087-02-4;
InChIKey    WZLKRAJHCPNZAA-UHFFFAOYSA-N;
MW          162.188;      // g/mol [origin=calculated method=formula-sum]
Tc          786.55;      // K   [origin=predictive method=joback]
Pc          33.763;      // bar [origin=predictive method=joback]
omega       0.6499;      // -   [origin=predictive method=lee-kesler]
Tb          562.82;      // K   [origin=predictive method=joback]
HvapTb      53622.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.389 0.81892 -0.000514 1.1522e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylbenzylglyoxal" "2,3-butanedione, 1-phenyl-" );
gibbsFormation
{
    dHf_298   -238360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-112110.0
    phase     gas;
}
