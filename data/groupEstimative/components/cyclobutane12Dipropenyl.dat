/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutane, 1,2-dipropenyl-  (C10H16, CAS 22769-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobutane12Dipropenyl;
formula     C10H16;
CAS         22769-00-2;
InChIKey    LKMHAUSOSFYRLJ-GGWOSOGESA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          643.58;      // K   [origin=predictive method=joback]
Pc          26.245;      // bar [origin=predictive method=joback]
omega       0.3354;      // -   [origin=predictive method=lee-kesler]
Tb          443.06;      // K   [origin=predictive method=joback]
HvapTb      37546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.99 1.10864 -0.0008062 2.438e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis[(e)-prop-1-enyl]cyclobutane" "cyclobutane, 1,2-dipropenyl-, (e,e)-" );
gibbsFormation
{
    dHf_298   31010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=234700.0
    phase     gas;
}
