/*--------------------------------*- Choupo -*-----------------------*\
  Component: decyl sulfide  (C20H42S, CAS 693-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decylSulfide;
formula     C20H42S;
CAS         693-83-4;
InChIKey    RKYMVQJWYYOIJB-UHFFFAOYSA-N;
MW          314.616;      // g/mol [origin=calculated method=formula-sum]
Tc          900.32;      // K   [origin=predictive method=joback]
Pc          10.266;      // bar [origin=predictive method=joback]
omega       0.8502;      // -   [origin=predictive method=lee-kesler]
Tb          725.98;      // K   [origin=predictive method=joback]
HvapTb      66931.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.308 1.89823 -0.001024 1.992e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 17; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-decylsulfanyldecane" "n-decyl sulfide" "didecyl sulfide" "decane, 1,1'-thiobis-" "11-thiaheneicosane" "decylthiodecane" "didecyl sulphide" "di-n-decyl sulfide" "decane,1'-thiobis-" "decyl sulfide (8ci)" );
gibbsFormation
{
    dHf_298   -414260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     996.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=150640.0
    phase     gas;
}
