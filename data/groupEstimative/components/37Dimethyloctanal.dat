/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethyloctanal  (C10H20O, CAS 5988-91-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethyloctanal;
formula     C10H20O;
CAS         5988-91-0;
InChIKey    UCSIFMPORANABL-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          651.92;      // K   [origin=predictive method=joback]
Pc          22.937;      // bar [origin=predictive method=joback]
omega       0.5868;      // -   [origin=predictive method=lee-kesler]
Tb          476.18;      // K   [origin=predictive method=joback]
HvapTb      43798.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.834 0.94016 -0.0005196 1.047e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octanal, 3,7-dimethyl-" "dihydrocitronellal" "tetrahydrogeranial" "6,7-dihydrocitronellal" "octanal, 3,7-dimethyl-, (3s)-" "dihydro citronellal" "(s)-3,7-dimethyloctanal" "citral,tetrahydro-; tetrahydrocitral" );
gibbsFormation
{
    dHf_298   -345870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-71080.0
    phase     gas;
}
