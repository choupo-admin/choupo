/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 2,5-dioxocyclohexane-1,4-dicarboxylate  (C10H12O6, CAS 6289-46-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl25Dioxocyclohexane14Dicarboxylate;
formula     C10H12O6;
CAS         6289-46-9;
InChIKey    MHKKFFHWMKEBDW-UHFFFAOYSA-N;
MW          228.2;      // g/mol [origin=calculated method=formula-sum]
Tc          926.15;      // K   [origin=predictive method=joback]
Pc          26.958;      // bar [origin=predictive method=joback]
omega       0.8737;      // -   [origin=predictive method=lee-kesler]
Tb          695.36;      // K   [origin=predictive method=joback]
HvapTb      61282.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.81 0.60324 0.0001314 -2.51e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group CH2CO; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group CdO_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2,5-bis(oxidanylidene)cyclohexane-1,4-dicarboxylate" "dimethyl succinylsuccinate" "dimethyl 1,4-cyclohexanedione-2,5-dicarboxylate" "succinosuccinic acid, dimethyl ester" "dimethyl succinyl succinate" "1,4-cyclohexanedicarboxylic acid, 2,5-dioxo-, dimethyl ester" "dimethyl 2,5-dioxo-1,4-cyclohexanedicarboxylate" "2,5-dioxo-1,4-cyclohexanedicarboxylic acid dimethyl ester" "1, 2,5-dioxo-, dimethyl ester" "1,4-cyclohexanedicarboxylic acid, 2,5-dioxo-, 1,4-dimethyl ester" "dimethyl succinylosuccinate" "dimethyl (1s,4s)-2,5-dioxocyclohexane-1,4-dicarboxylate" );
gibbsFormation
{
    dHf_298   -1125710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-815860.0
    phase     gas;
}
