/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(n-ethyl-4-formyl-3-methylanilino)propanenitrile  (C13H16N2O, CAS 119-97-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H16N2O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3NEthyl4Formyl3MethylanilinoPropanenitrile;
formula     C13H16N2O;
CAS         119-97-1;
InChIKey    VTXVKMVZEXXUIC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          216.284;      // g/mol [origin=calculated method=formula-sum]
Tc          835.81;      // K   [origin=predictive method=joback]
Pc          21.674;      // bar [origin=predictive method=joback]
omega       0.7110;      // -   [origin=predictive method=lee-kesler]
Tb          624.62;      // K   [origin=predictive method=joback]
HvapTb      58280.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.427 1.10774 -0.00081512 2.47e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CHO; count 1; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[ethyl-(4-methanoyl-3-methyl-phenyl)amino]propanenitrile" "2-methyl-n-ethyl-n-(2-cyanoethyl)-4-aminobenzaldehyde" "3-(ethyl(4-formyl-3-methylphenyl)amino)propanenitrile" "propanenitrile, 3-(ethyl(4-formyl-3-methylphenyl)amino)-" "propanenitrile, 3-[ethyl(4-formyl-3-methylphenyl)amino]-" "i654" "3-(ethyl(4-formyl-3-methylphenyl)amino)propiononitrile" "propanenitrile,3-[ethyl(4-formyl-3-methylphenyl)amino]-" "propionitrile,3-(n-ethyl-4-formyl-m-toluidino)- (8ci);o-tolualdehyde,4-[(2-cyanoethyl)ethylamino]- (7ci);" );
gibbsFormation
{
    dHf_298   210800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=439650.0
    phase     gas;
}
