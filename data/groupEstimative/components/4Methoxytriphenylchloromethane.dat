/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxytriphenylchloromethane  (C20H17ClO, CAS 14470-28-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxytriphenylchloromethane;
formula     C20H17ClO;
CAS         14470-28-1;
InChIKey    OBOHMJWDFPBPKD-UHFFFAOYSA-N;
MW          308.805;      // g/mol [origin=calculated method=formula-sum]
Tc          1068.04;      // K   [origin=predictive method=joback]
Pc          20.755;      // bar [origin=predictive method=joback]
omega       0.6922;      // -   [origin=predictive method=lee-kesler]
Tb          798.84;      // K   [origin=predictive method=joback]
HvapTb      73103.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.79 1.67702 -0.00117196 3.045e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 4; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[chloranyl(diphenyl)methyl]-4-methoxy-benzene" "4-methoxytrityl chloride" "4-methoxytriphenylmethyl chloride" "4-monomethoxytrityl chloride" "p-monomethoxytrityl chloride" "mmtrcl" "p-anisylchlorodiphenylmethane" "mmt polymer-bound" "1-[chloro(diphenyl)methyl]-4-methoxybenzene" "4-methoxytrityl chloride, polymer-bound" "1-(chlorodiphenylmethyl)-4-methoxybenzene" "4-methoxytriphenylchloromethane polymer-bound" );
gibbsFormation
{
    dHf_298   85280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     615.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=331030.0
    phase     gas;
}
