/*--------------------------------*- Choupo -*-----------------------*\
  Component: butane, nonafluoro-2-(trifluoromethyl)-  (C5F12, CAS 594-91-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butaneNonafluoro2Trifluoromethyl;
formula     C5F12;
CAS         594-91-2;
InChIKey    MPEFSWGYIJNMCW-UHFFFAOYSA-N;
MW          288.031;      // g/mol [origin=calculated method=formula-sum]
Tc          403.15;      // K   [origin=predictive method=joback]
Pc          21.775;      // bar [origin=predictive method=joback]
omega       0.4529;      // -   [origin=predictive method=lee-kesler]
Tb          289.09;      // K   [origin=predictive method=joback]
HvapTb      10440.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.93 1.2494 -0.001304 4.75e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CF3; count 3; } { group CF2; count 1; } { group CF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 5; } { group F; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,2,2,3,4,4,4-nonakis(fluoranyl)-3-(trifluoromethyl)butane" "perflisopent" "1,1,1,2,2,3,4,4,4-nonafluoro-3-(trifluoromethyl)butane" "butane, 1,1,1,2,3,3,4,4,4-nonafluoro-2-(trifluoromethyl)-" "perflisopent (usan/inn)" );
gibbsFormation
{
    dHf_298   -2543600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2332300.0
    phase     gas;
}
