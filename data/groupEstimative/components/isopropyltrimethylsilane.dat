/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyltrimethylsilane  (C6H16Si, CAS 3429-52-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        isopropyltrimethylsilane;
formula     C6H16Si;
CAS         3429-52-5;
InChIKey    WDIWAJVQNKHNGJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          116.279;      // g/mol [origin=calculated method=formula-sum]
Tc          511.64;      // K   [origin=predictive method=joback]
Pc          27.527;      // bar [origin=predictive method=joback]
omega       0.1894;      // -   [origin=predictive method=lee-kesler]
Tb          337.84;      // K   [origin=predictive method=joback]
HvapTb      28856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.57 0.3736 0.000109 -1.575e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(propan-2-yl)silane" "silane,trimethyl(1-methylethyl)-" "silane,isopropyltrimethyl- (6ci,7ci,8ci); isopropyltrimethylsilane;trimethylisopropylsilane" );
standardThermochemistry
{
    dHf_298   -284070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-107560.0
}
