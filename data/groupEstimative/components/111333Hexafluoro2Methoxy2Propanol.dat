/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1,3,3,3-hexafluoro-2-methoxy-2-propanol  (C4H4F6O2, CAS 662-16-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111333Hexafluoro2Methoxy2Propanol;
formula     C4H4F6O2;
CAS         662-16-8;
InChIKey    FEKJGFZZVNCSRO-UHFFFAOYSA-N;
MW          198.062;      // g/mol [origin=calculated method=formula-sum]
Tc          534.86;      // K   [origin=predictive method=joback]
Pc          33.029;      // bar [origin=predictive method=joback]
omega       0.7938;      // -   [origin=predictive method=lee-kesler]
Tb          391.65;      // K   [origin=predictive method=joback]
HvapTb      34797.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.83 0.80282 -0.000727 2.407e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group OH; count 1; } { group CH3O; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 3; } { group F; count 6; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,3,3,3-hexakis(fluoranyl)-2-methoxy-propan-2-ol" "1,1,1,3,3,3-hexafluoro-2-methoxypropan-2-ol" );
gibbsFormation
{
    dHf_298   -1613250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1419360.0
    phase     gas;
}
