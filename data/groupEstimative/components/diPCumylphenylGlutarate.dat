/*--------------------------------*- Choupo -*-----------------------*\
  Component: di(p-cumylphenyl) glutarate  (C35H36O4, CAS 68443-33-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diPCumylphenylGlutarate;
formula     C35H36O4;
CAS         68443-33-4;
InChIKey    ZZWYQFFAXIHVRM-UHFFFAOYSA-N;
MW          520.669;      // g/mol [origin=calculated method=formula-sum]
Tc          1503.55;      // K   [origin=predictive method=joback]
Pc          9.550;      // bar [origin=predictive method=joback]
omega       0.9167;      // -   [origin=predictive method=lee-kesler]
Tb          1227.06;      // K   [origin=predictive method=joback]
HvapTb      116154.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-134.077 3.03628 -0.00202532 4.871e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 2; } { group ACH; count 18; } { group AC; count 6; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 2; } { group dCH_ring; count 18; } { group dC_ring; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[4-(2-phenylpropan-2-yl)phenyl] pentanedioate" "pentanedioic acid bis[4-(1-methyl-1-phenylethyl)phenyl] ester" "pentanedioic acid, bis(4-(1-methyl-1-phenylethyl)phenyl) ester" "pentanedioic acid, bis[4-(1-methyl-1-phenylethyl)phenyl] ester" "pentanedioic acid, 1,5-bis(4-(1-methyl-1-phenylethyl)phenyl) ester" "pentanedioic acid, 1,5-bis[4-(1-methyl-1-phenylethyl)phenyl] ester" "bis(4-(1-methyl-1-phenylethyl)phenyl) glutarate" );
standardThermochemistry
{
    dHf_298   -494610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1106.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=59140.0
}
