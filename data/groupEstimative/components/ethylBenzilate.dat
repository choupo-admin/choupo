/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl benzilate  (C16H16O3, CAS 52182-15-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylBenzilate;
formula     C16H16O3;
CAS         52182-15-7;
InChIKey    AIPVNQQMYPWQSX-UHFFFAOYSA-N;
MW          256.301;      // g/mol [origin=calculated method=formula-sum]
Tc          991.59;      // K   [origin=predictive method=joback]
Pc          25.611;      // bar [origin=predictive method=joback]
omega       1.1024;      // -   [origin=predictive method=lee-kesler]
Tb          766.21;      // K   [origin=predictive method=joback]
HvapTb      78552.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.239 1.47102 -0.0010166 2.548e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-oxidanyl-2,2-diphenyl-ethanoate" "ethyl benzillate" "benzilic acid ethyl ester" "ethyl diphenylglycolate" "ethyl 2-hydroxy-2,2-diphenylacetate" "benzeneacetic acid, .alpha.-hydroxy-.alpha.-phenyl-, ethyl ester" "diphenylglycolic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -378770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     629.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-135690.0
    phase     gas;
}
