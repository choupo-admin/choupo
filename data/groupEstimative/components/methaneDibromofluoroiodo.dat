/*--------------------------------*- Choupo -*-----------------------*\
  Component: methane, dibromofluoroiodo-  (CBr2FI, CAS 1478-04-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methaneDibromofluoroiodo;
formula     CBr2FI;
CAS         1478-04-2;
InChIKey    NBMPIOUWRNYXES-UHFFFAOYSA-N;
MW          317.717;      // g/mol [origin=calculated method=formula-sum]
Tc          703.85;      // K   [origin=predictive method=joback]
Pc          66.748;      // bar [origin=predictive method=joback]
omega       0.3117;      // -   [origin=predictive method=lee-kesler]
Tb          443.98;      // K   [origin=predictive method=joback]
HvapTb      37950.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.67 0.3518 -0.000443 1.863e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group I; count 1; } { group Br; count 2; } { group CF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group F; count 1; } { group Br; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(bromanyl)-fluoranyl-iodanyl-methane" );
standardThermochemistry
{
    dHf_298   -139300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     345.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147670.0
}
