/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetyl-1-naphthyl benzoate  (C19H14O3, CAS 63450-44-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Acetyl1NaphthylBenzoate;
formula     C19H14O3;
CAS         63450-44-2;
InChIKey    DPEZTQNZBJBTSI-UHFFFAOYSA-N;
MW          290.318;      // g/mol [origin=calculated method=formula-sum]
Tc          1078.85;      // K   [origin=predictive method=joback]
Pc          22.741;      // bar [origin=predictive method=joback]
omega       0.9663;      // -   [origin=predictive method=lee-kesler]
Tb          828.71;      // K   [origin=predictive method=joback]
HvapTb      79557.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.27 1.44552 -0.00096154 2.3106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 5; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 5; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-ethanoylnaphthalen-1-yl) benzoate" "ethanone, 1-(1-(benzoyloxy)-2-naphthalenyl)-" "ethanone, 1-[1-(benzoyloxy)-2-naphthalenyl]-" "2-acetylnaphthalen-1-yl benzoate" "(2-acetylnaphthalen-1-yl) benzoate" );
standardThermochemistry
{
    dHf_298   -224160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17980.0
}
