/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1280566  (C7H12O3, CAS 27761-61-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1280566;
formula     C7H12O3;
CAS         27761-61-1;
InChIKey    GDZAVHGIQPTDDN-UHFFFAOYSA-N;
MW          144.17;      // g/mol [origin=calculated method=formula-sum]
Tc          693.88;      // K   [origin=predictive method=joback]
Pc          43.454;      // bar [origin=predictive method=joback]
omega       0.3930;      // -   [origin=predictive method=lee-kesler]
Tb          463.11;      // K   [origin=predictive method=joback]
HvapTb      42574.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-162.22 1.52624 -0.0017281 7.808e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 2; } { group FCH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group C_ring; count 2; } { group O_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethyl-3,5,8-trioxabicyclo[2.2.2]octane" "2,6,7-trioxabicyclo(2.2.2)octane, 1,4-dimethyl-" "2,6,7-trioxabicyclo[2.2.2]octane, 1,4-dimethyl-" );
gibbsFormation
{
    dHf_298   -420050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     273.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-163980.0
    phase     gas;
}
