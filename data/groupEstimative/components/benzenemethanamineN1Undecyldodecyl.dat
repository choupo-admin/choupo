/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenemethanamine, n-(1-undecyldodecyl)-  (C30H55N, CAS 71550-31-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenemethanamineN1Undecyldodecyl;
formula     C30H55N;
CAS         71550-31-7;
InChIKey    SDIVGRTZBGCYQC-UHFFFAOYSA-N;
MW          429.777;      // g/mol [origin=calculated method=formula-sum]
Tc          1181.03;      // K   [origin=predictive method=joback]
Pc          7.126;      // bar [origin=predictive method=joback]
omega       0.6372;      // -   [origin=predictive method=lee-kesler]
Tb          962.41;      // K   [origin=predictive method=joback]
HvapTb      90698.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.179 2.85704 -0.0016912 3.813e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 20; } { group ACH; count 5; } { group ACCH2; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 21; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(phenylmethyl)tricosan-12-amine" "n-(phenylmethyl)-1-undecyl-1-dodecanamine" "n-benzyltricosan-12-amine" "n-(phenylmethyl)-12-tricosanamine" );
standardThermochemistry
{
    dHf_298   -377810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1249.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=401080.0
}
