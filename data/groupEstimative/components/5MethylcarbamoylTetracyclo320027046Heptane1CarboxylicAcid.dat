/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-(methylcarbamoyl)tetracyclo[3.2.0.02,7.04,6]heptane-1-carboxylic acid  (C10H11NO3, CAS 90632-73-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5MethylcarbamoylTetracyclo320027046Heptane1CarboxylicAcid;
formula     C10H11NO3;
CAS         90632-73-8;
InChIKey    OHINAHWORQBSRC-UHFFFAOYSA-N;
MW          193.202;      // g/mol [origin=calculated method=formula-sum]
Tc          897.23;      // K   [origin=predictive method=joback]
Pc          39.357;      // bar [origin=predictive method=joback]
omega       1.1104;      // -   [origin=predictive method=lee-kesler]
Tb          674.70;      // K   [origin=predictive method=joback]
HvapTb      64072.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-258.92 2.23522 -0.0026899 1.22356e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group C; count 2; } { group COOH; count 1; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group C_ring; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-((methylamino)carbonyl)tetracyclo(3.2.0(2,7).0(4,6))heptane-1-carboxylic acid" "5-[(methylamino)carbonyl]-tetracyclo[3.2.0(2,7).0(4,6)]heptane-1-carboxylic acid" "tetracyclo[3.2.0.02,7.04,6]heptane-1-carboxylicacid, 5-[(methylamino)carbonyl]-" );
gibbsFormation
{
    dHf_298   -347310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     259.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-73020.0
    phase     gas;
}
