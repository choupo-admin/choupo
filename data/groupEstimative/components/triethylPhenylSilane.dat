/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethyl(phenyl)silane  (C12H20Si, CAS 2987-77-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H20Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        triethylPhenylSilane;
formula     C12H20Si;
CAS         2987-77-1;
InChIKey    CEAWWDXUKYZTJL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          192.377;      // g/mol [origin=calculated method=formula-sum]
Tc          708.29;      // K   [origin=predictive method=joback]
Pc          21.453;      // bar [origin=predictive method=joback]
omega       0.3876;      // -   [origin=predictive method=lee-kesler]
Tb          502.24;      // K   [origin=predictive method=joback]
HvapTb      44876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.107 0.85876 -0.0002454 -6.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "silane, triethylphenyl-" "benzene,(triethylsilyl)-" );
gibbsFormation
{
    dHf_298   -166100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     643.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57810.0
    phase     gas;
}
