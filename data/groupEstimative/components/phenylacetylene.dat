/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylacetylene  (C8H6, CAS 536-74-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylacetylene;
formula     C8H6;
CAS         536-74-3;
InChIKey    UEXCJVNBTNXOEH-UHFFFAOYSA-N;
MW          102.136;      // g/mol [origin=calculated method=formula-sum]
Tc          625.79;      // K   [origin=predictive method=joback]
Pc          44.033;      // bar [origin=predictive method=joback]
omega       0.2272;      // -   [origin=predictive method=lee-kesler]
Tb          399.44;      // K   [origin=predictive method=joback]
HvapTb      35536.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.51 0.591 -0.00043853 1.2789e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethynylbenzene" "phenylethyne" "benzene, ethynyl-" "phenylacetylide" "1-phenylethyne" "ethyne, phenyl-" "acetylene, phenyl-" "ethynyl-benzene" "phenyl acetylene" "phenylacethylene" "1-ethynylbenzene" "ethynyl-benzene (phenylacetylene)" );
standardThermochemistry
{
    dHf_298   319980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=351960.0
}
