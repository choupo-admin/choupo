/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethyl-4-formylhexanenitrile  (C9H15NO, CAS 2938-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethyl4Formylhexanenitrile;
formula     C9H15NO;
CAS         2938-69-4;
InChIKey    AMUXIQHQXOKMTN-UHFFFAOYSA-N;
MW          153.225;      // g/mol [origin=calculated method=formula-sum]
Tc          751.54;      // K   [origin=predictive method=joback]
Pc          24.654;      // bar [origin=predictive method=joback]
omega       0.6734;      // -   [origin=predictive method=lee-kesler]
Tb          553.03;      // K   [origin=predictive method=joback]
HvapTb      51530.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.366 0.89394 -0.0005996 1.594e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group CHO; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group OdCH_al; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethyl-4-methanoyl-hexanenitrile" "hexanenitrile,4-ethyl-4-formyl-" "hexanenitrile, 4-ethyl-4-formyl-" "4-cyano-2,2-diethylbutyraldehyde" );
standardThermochemistry
{
    dHf_298   -158540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61400.0
}
