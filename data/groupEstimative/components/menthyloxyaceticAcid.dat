/*--------------------------------*- Choupo -*-----------------------*\
  Component: (+)-menthyloxyacetic acid  (C12H22O3, CAS 94133-41-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        menthyloxyaceticAcid;
formula     C12H22O3;
CAS         94133-41-2;
InChIKey    CILPHQCEVYJUDN-AXFHLTTASA-N;
MW          214.305;      // g/mol [origin=calculated method=formula-sum]
Tc          859.92;      // K   [origin=predictive method=joback]
Pc          21.613;      // bar [origin=predictive method=joback]
omega       0.8193;      // -   [origin=predictive method=lee-kesler]
Tb          651.86;      // K   [origin=predictive method=joback]
HvapTb      61303.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.329 1.20646 -0.000564 5.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 4; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(1s,2r,5s)-5-methyl-2-propan-2-yl-cyclohexyl]oxyethanoic acid" "(+)-menthoxyacetic acid" "()-menthoxyacetic acid" "l-(menthyloxy)acetic acid" "{[(1s,2r,5s)-2-isopropyl-5-methylcyclohexyl]oxy}acetic acid" "2-[(1s,2r,5s)-5-methyl-2-propan-2-ylcyclohexyl]oxyacetic acid" "(1s-(1alpha,2beta,5alpha))-((5-methyl-2-(1-methylethyl)cyclohexyl)oxy)acetic acid" );
gibbsFormation
{
    dHf_298   -765140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-392160.0
    phase     gas;
}
