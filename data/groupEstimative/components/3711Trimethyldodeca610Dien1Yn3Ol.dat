/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7,11-trimethyldodeca-6,10-dien-1-yn-3-ol  (C15H24O, CAS 54325-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3711Trimethyldodeca610Dien1Yn3Ol;
formula     C15H24O;
CAS         54325-12-1;
InChIKey    ZNVPGYAGXVEAFP-UHFFFAOYSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          817.87;      // K   [origin=predictive method=joback]
Pc          19.153;      // bar [origin=predictive method=joback]
omega       0.8778;      // -   [origin=predictive method=lee-kesler]
Tb          629.95;      // K   [origin=predictive method=joback]
HvapTb      64301.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.896 1.53458 -0.00116253 3.6579e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group CH=C; count 2; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group dCH; count 2; } { group dC; count 2; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,10-dodecadien-1-yn-3-ol, 3,7,11-trimethyl-" "3,7,11-trimethyl-6,10-dodecadien-1-yn-3-ol" "6,10-dodecadien-1-yn-3-ol, 3,7,11-trimethyl-, (e)-" );
gibbsFormation
{
    dHf_298   -7150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     700.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=307850.0
    phase     gas;
}
