/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dibromobutane  (C4H8Br2, CAS 110-52-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dibromobutane;
formula     C4H8Br2;
CAS         110-52-1;
InChIKey    ULTHEAFYOOPTTB-UHFFFAOYSA-N;
MW          215.916;      // g/mol [origin=calculated method=formula-sum]
Tc          629.95;      // K   [origin=predictive method=joback]
Pc          46.657;      // bar [origin=predictive method=joback]
omega       0.4507;      // -   [origin=predictive method=lee-kesler]
Tb          423.44;      // K   [origin=predictive method=joback]
HvapTb      37368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.634 0.4602 -0.0003366 1.046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(bromanyl)butane" "tetramethylene dibromide" "butane, 1,4-dibromo-" "tetramethylene bromide" "1,4-dibrombutan" "tetramethylenebromide" "1,4-butylene bromide" "alpha,omega-dibromobutane" "1,4-dibrombutan [german]" "dbb" "butane,4-dibromo-" "1,4-dibromo-butane" );
standardThermochemistry
{
    dHf_298   -73230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11440.0
}
