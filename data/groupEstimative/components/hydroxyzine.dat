/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydroxyzine  (C21H27ClN2O2, CAS 68-88-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydroxyzine;
formula     C21H27ClN2O2;
CAS         68-88-2;
InChIKey    ZQDWXGKKHFNSQK-UHFFFAOYSA-N;
MW          374.909;      // g/mol [origin=calculated method=formula-sum]
Tc          1153.00;      // K   [origin=predictive method=joback]
Pc          18.000;      // bar [origin=predictive method=joback]
omega       1.3363;      // -   [origin=predictive method=lee-kesler]
Tb          930.57;      // K   [origin=predictive method=joback]
HvapTb      95120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.396 2.1806 -0.00151136 4.007e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 9; } { group AC; count 1; } { group ACCH; count 1; } { group CH2N; count 2; } { group ACCl; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH; count 1; } { group O; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[4-[(4-chlorophenyl)-phenyl-methyl]piperazin-1-yl]ethoxy]ethanol" "hydroxine" "hydroxizine" "hydroxycine" "hydroxyzin" "vistaril" "atarax" "hychotine" "hydroxizinum" "traquizine" "ataraxoid" "atarazoid" );
standardThermochemistry
{
    dHf_298   -98610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     845.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=362860.0
}
