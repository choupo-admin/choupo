/*--------------------------------*- Choupo -*-----------------------*\
  Component: quinuclidin-4-ol  (C7H13NO, CAS 26458-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        quinuclidin4Ol;
formula     C7H13NO;
CAS         26458-74-2;
InChIKey    RQRSQXFVRUWISR-UHFFFAOYSA-N;
MW          127.187;      // g/mol [origin=calculated method=formula-sum]
Tc          686.28;      // K   [origin=predictive method=joback]
Pc          48.427;      // bar [origin=predictive method=joback]
omega       0.7656;      // -   [origin=predictive method=lee-kesler]
Tb          487.04;      // K   [origin=predictive method=joback]
HvapTb      49054.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-170.41 1.4373 -0.001482 6.142e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group C_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azabicyclo[2.2.2]octan-4-ol" "1-azabicyclo(2.2.2)octan-4-ol" );
standardThermochemistry
{
    dHf_298   -97490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93640.0
}
