/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-heptanone, 4-(3,4-dimethoxyphenyl)-  (C15H22O3, CAS 70289-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Heptanone434Dimethoxyphenyl;
formula     C15H22O3;
CAS         70289-08-6;
InChIKey    PDKDGRVPHUMZJC-UHFFFAOYSA-N;
MW          250.338;      // g/mol [origin=calculated method=formula-sum]
Tc          878.94;      // K   [origin=predictive method=joback]
Pc          18.579;      // bar [origin=predictive method=joback]
omega       0.8669;      // -   [origin=predictive method=lee-kesler]
Tb          677.71;      // K   [origin=predictive method=joback]
HvapTb      63762.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.623 1.08248 -0.00045182 2.386e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACCH; count 1; } { group CH2CO; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3,4-dimethoxyphenyl)heptan-3-one" "3-heptanone, 4-(3,4-dimethoxyphenyl)-," );
gibbsFormation
{
    dHf_298   -521640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     661.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-172790.0
    phase     gas;
}
