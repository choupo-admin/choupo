/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-2-methylnaphthalene  (C11H9Cl, CAS 112494-52-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro2Methylnaphthalene;
formula     C11H9Cl;
CAS         112494-52-7;
InChIKey    MNCMVFFWMBXFLK-UHFFFAOYSA-N;
MW          176.643;      // g/mol [origin=calculated method=formula-sum]
Tc          785.18;      // K   [origin=predictive method=joback]
Pc          32.100;      // bar [origin=predictive method=joback]
omega       0.4512;      // -   [origin=predictive method=lee-kesler]
Tb          544.33;      // K   [origin=predictive method=joback]
HvapTb      49705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.97 0.85402 -0.00062884 1.855e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACCH3; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-methyl-naphthalene" "naphthalene, chloro-2-methyl-" "naphthalene, 1-chloro-2-methyl-" );
gibbsFormation
{
    dHf_298   118550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=229610.0
    phase     gas;
}
