/*--------------------------------*- Choupo -*-----------------------*\
  Component: androstenedione  (C19H26O2, CAS 63-05-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        androstenedione;
formula     C19H26O2;
CAS         63-05-8;
InChIKey    AEMFNILZOJDQLW-QAGGRKNESA-N;
MW          286.415;      // g/mol [origin=calculated method=formula-sum]
Tc          1084.73;      // K   [origin=predictive method=joback]
Pc          19.771;      // bar [origin=predictive method=joback]
omega       0.7263;      // -   [origin=predictive method=lee-kesler]
Tb          818.22;      // K   [origin=predictive method=joback]
HvapTb      65237.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-240.06 2.46964 -0.00210064 7.837e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 3; } { group C; count 2; } { group CH=C; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s)-10,13-dimethyl-2,6,7,8,9,11,12,14,15,16-decahydro-1h-cyclopenta[a]phenanthrene-3,17-dione" "androst-4-ene-3,17-dione" "4-androstene-3,17-dione" "4-androstenedione" "androtex" "3,17-dioxoandrost-4-ene" "fecundin" "delta-4-androstenedione" "17-ketotestosterone" "androstendione" "delta-4-androsten-3,17-dione" "d4-androstenedione" );
standardThermochemistry
{
    dHf_298   -394040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48060.0
}
