/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3-trimethyl-3-phenylindan-4',5-dicarboxylic acid  (C20H20O4, CAS 3569-18-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        113Trimethyl3Phenylindan45DicarboxylicAcid;
formula     C20H20O4;
CAS         3569-18-4;
InChIKey    CDZMWAHBQLPCHD-UHFFFAOYSA-N;
MW          324.376;      // g/mol [origin=calculated method=formula-sum]
Tc          1275.97;      // K   [origin=predictive method=joback]
Pc          21.513;      // bar [origin=predictive method=joback]
omega       1.3479;      // -   [origin=predictive method=lee-kesler]
Tb          1019.07;      // K   [origin=predictive method=joback]
HvapTb      98282.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-175.29 2.37736 -0.00230068 9.262e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 2; } { group ACH; count 7; } { group AC; count 5; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-carboxyphenyl)-1,1,3-trimethyl-2h-indene-5-carboxylic acid" "3-(4-carboxyphenyl)-1,1,3-trimethylindane-5-carboxylic acid" "3-(4-carboxyphenyl)-2,3-dihydro-1,1,3-trimethyl-1h-indene-5-carboxylic acid" "1h-indene-5-carboxylicacid, 3-(4-carboxyphenyl)-2,3-dihydro-1,1,3-trimethyl-" "3-(4-carboxyphenyl)-1,1,3-trimethyl-2,3-dihydro-1h-indene-5-carboxylic acid" "5-indancarboxylicacid, 3-(p-carboxyphenyl)-1,1,3-trimethyl- (6ci,7ci,8ci); 1,1,3-trimethyl-3-(p-carboxyphenyl)indan-5-carboxylicacid; 1,1,3-trimethyl-5-carboxy-3-(4-carboxyphenyl)indan;1,1,3-trimethyl-5-carboxy-3-(p-carboxyphenyl)indan;1-(4-carboxyphenyl)-1,3,3-trimethylindan-6-carboxylic acid;3-(4-carboxyphenyl)-1,1,3-trimethyl-5-indancarboxylic acid;5-carboxy-3-(4-carboxyphenyl)-1,1,3-trimethylindan;5-carboxy-3-(p-carboxyphenyl)-1,1,3-trimethylindan; phendic acid" );
gibbsFormation
{
    dHf_298   -635080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     816.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-332310.0
    phase     gas;
}
