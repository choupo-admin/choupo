/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-fluoro-4-methoxybenzoic acid  (C8H7FO3, CAS 403-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Fluoro4MethoxybenzoicAcid;
formula     C8H7FO3;
CAS         403-20-3;
InChIKey    HYNNNQDQEORWEU-UHFFFAOYSA-N;
MW          170.139;      // g/mol [origin=calculated method=formula-sum]
Tc          802.93;      // K   [origin=predictive method=joback]
Pc          36.377;      // bar [origin=predictive method=joback]
omega       0.8261;      // -   [origin=predictive method=lee-kesler]
Tb          586.48;      // K   [origin=predictive method=joback]
HvapTb      55759.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.5 0.56532 -0.00028652 3.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3O; count 1; } { group COOH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-fluoranyl-4-methoxy-benzoic acid" "3-fluoro-p-anisic acid" "3-fluoro-4-methoxy-benzoic acid" "3-fluoro-4-methoxy benzoic acid" "3-fluoro-4-methhoxy benzoic acid" "buttpark 45\01-63" "benzoic acid, 3-fluoro-4-methoxy-" "p798" "p-anisicacid, 3-fluoro- (7ci,8ci);4-methoxy-3-fluorobenzoic acid;" );
standardThermochemistry
{
    dHf_298   -673460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-534090.0
}
