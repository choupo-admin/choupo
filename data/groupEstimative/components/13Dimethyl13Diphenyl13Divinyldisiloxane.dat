/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dimethyl-1,3-diphenyl-1,3-divinyldisiloxane  (C18H22OSi2, CAS 2627-97-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C18H22OSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13Dimethyl13Diphenyl13Divinyldisiloxane;
formula     C18H22OSi2;
CAS         2627-97-6;
InChIKey    KPWVUBSQUODFPP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          310.543;      // g/mol [origin=calculated method=formula-sum]
Tc          924.43;      // K   [origin=predictive method=joback]
Pc          16.565;      // bar [origin=predictive method=joback]
omega       0.4876;      // -   [origin=predictive method=lee-kesler]
Tb          683.38;      // K   [origin=predictive method=joback]
HvapTb      61872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.87 1.04044 -0.000123 -2.004e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 2; } { group ACH; count 10; } { group AC; count 2; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl-(ethenyl-methyl-phenyl-silyl)oxy-methyl-phenyl-silane" "disiloxane, 1,3-diethenyl-1,3-dimethyl-1,3-diphenyl-" "1,3-divinyl-1,3-diphenyl-1,3-dimethyldisiloxane" "disiloxane, 1,3-dimethyl-1,3-diphenyl-1,3-divinyl-" "disiloxane,1,3-diethenyl-1,3-dimethyl-1,3-diphenyl-" "ethenyl-(ethenyl-methyl-phenylsilyl)oxy-methyl-phenylsilane" "disiloxane,1,3-dimethyl-1,3-diphenyl-1,3-divinyl- (6ci,7ci,8ci);1,3-divinyl-1,3-diphenyl-1,3-dimethyldisiloxane;1,3-divinyl-1,3-diphenyldimethyldisiloxane;" );
gibbsFormation
{
    dHf_298   -46390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     899.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=186660.0
    phase     gas;
}
