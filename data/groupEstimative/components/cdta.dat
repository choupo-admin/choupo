/*--------------------------------*- Choupo -*-----------------------*\
  Component: cdta  (C14H22N2O8, CAS 482-54-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cdta;
formula     C14H22N2O8;
CAS         482-54-2;
InChIKey    FCKYPQBAHLOOJQ-UHFFFAOYSA-N;
MW          346.336;      // g/mol [origin=calculated method=formula-sum]
Tc          1397.89;      // K   [origin=predictive method=joback]
Pc          24.076;      // bar [origin=predictive method=joback]
omega       1.7670;      // -   [origin=predictive method=lee-kesler]
Tb          1141.72;      // K   [origin=predictive method=joback]
HvapTb      119620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.486 1.8804 -0.001279 3.236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group CH2N; count 2; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COOH; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[2-[bis(2-hydroxy-2-oxoethyl)amino]cyclohexyl]-(2-hydroxy-2-oxoethyl)amino]ethanoic acid" "complexon iv" "cydta" "cgta" "octa" "komplexon iv" "1,2-diaminocyclohexanetetraacetic acid" "1,2-cyclohexylenedinitrilotetraacetic acid" "o-cyclohexanediaminetetraacetic acid" "1,2-cyclohexanediaminetetraacetic acid" "(1,2-cyclohexylenedinitrilo)tetraacetic acid" "1,2-cyclohexylenediaminetetraacetic acid" );
standardThermochemistry
{
    dHf_298   -1564330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     873.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1070340.0
}
