/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(hexadecylsulfonyl)-3-methylbutanoic acid  (C21H42O4S, CAS 125252-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C21H42O4S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Hexadecylsulfonyl3MethylbutanoicAcid;
formula     C21H42O4S;
CAS         125252-53-1;
InChIKey    DAMJMHIAJAAGHF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          390.623;      // g/mol [origin=calculated method=formula-sum]
Tc          984.28;      // K   [origin=predictive method=joback]
Pc          10.943;      // bar [origin=predictive method=joback]
omega       1.0465;      // -   [origin=predictive method=lee-kesler]
Tb          803.71;      // K   [origin=predictive method=joback]
HvapTb      90546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.325 2.10066 -0.0011722 2.301e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 14; } { group CH; count 1; } { group COOH; count 1; } { group CH2SuCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 15; } { group CH; count 2; } { group COOH; count 1; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexadecylsulfonyl-3-methyl-butanoic acid" "butanoic acid, 2-(hexadecylsulfonyl)-3-methyl-" "2-hexadecylsulfonyl-3-methylbutanoic acid" );
standardThermochemistry
{
    dHf_298   -1332820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1266.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-724510.0
}
