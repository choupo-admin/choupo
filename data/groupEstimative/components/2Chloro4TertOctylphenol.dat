/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-4-tert-octylphenol  (C14H21ClO, CAS 17199-24-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro4TertOctylphenol;
formula     C14H21ClO;
CAS         17199-24-5;
InChIKey    CLYCAZNGUGDEBH-UHFFFAOYSA-N;
MW          240.771;      // g/mol [origin=calculated method=formula-sum]
Tc          896.55;      // K   [origin=predictive method=joback]
Pc          22.762;      // bar [origin=predictive method=joback]
omega       0.6657;      // -   [origin=predictive method=lee-kesler]
Tb          663.17;      // K   [origin=predictive method=joback]
HvapTb      64503.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.419 1.6085 -0.00132232 4.419e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-4-(2,4,4-trimethylpentan-2-yl)phenol" "2-chloro-4-(1,1,3,3-tetramethylbutyl)phenol" "2-chloro-4-(2,4,4-trimethylpentan-2-yl)phenol" "phenol, 2-chloro-4-(1,1,3,3-tetramethylbutyl)-" "2-chloro-4-(1,3,3-tetramethylbutyl)phenol" );
standardThermochemistry
{
    dHf_298   -317780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8910.0
}
