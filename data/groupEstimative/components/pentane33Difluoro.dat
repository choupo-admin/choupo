/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentane, 3,3-difluoro-  (C5H10F2, CAS 358-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentane33Difluoro;
formula     C5H10F2;
CAS         358-03-2;
InChIKey    ADKOKWOWUJDRJK-UHFFFAOYSA-N;
MW          108.131;      // g/mol [origin=calculated method=formula-sum]
Tc          464.03;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.2769;      // -   [origin=predictive method=lee-kesler]
Tb          309.31;      // K   [origin=predictive method=joback]
HvapTb      23794.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.948 0.62824 -0.0004528 1.314e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(fluoranyl)pentane" "agn-pc-00mnn6" );
standardThermochemistry
{
    dHf_298   -547500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-395560.0
}
