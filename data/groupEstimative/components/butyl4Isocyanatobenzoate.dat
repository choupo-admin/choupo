/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 4-isocyanatobenzoate  (C12H13NO3, CAS 102561-47-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl4Isocyanatobenzoate;
formula     C12H13NO3;
CAS         102561-47-7;
InChIKey    PVCGQSQNUXNTNA-UHFFFAOYSA-N;
MW          219.24;      // g/mol [origin=calculated method=formula-sum]
Tc          841.72;      // K   [origin=predictive method=joback]
Pc          25.637;      // bar [origin=predictive method=joback]
omega       0.8283;      // -   [origin=predictive method=lee-kesler]
Tb          630.71;      // K   [origin=predictive method=joback]
HvapTb      62183.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(n-butoxycarbonyl)phenyl isocyanate" "4-carbobutoxyphenyl isocyanate" "benzoic acid,4-isocyanato-, butyl ester" "4-(n-butoxycarbonyl)phenyl isocyanate; 4-(carbobutoxy)phenyl isocyanate" );
// formation datum unavailable (element entropy missing): dHf_298=-388640.0 dGf_298=None
