/*--------------------------------*- Choupo -*-----------------------*\
  Component: di-p-tolylmethane  (C15H16, CAS 4957-14-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diPTolylmethane;
formula     C15H16;
CAS         4957-14-6;
InChIKey    HZAWPPRBCALFRN-UHFFFAOYSA-N;
MW          196.293;      // g/mol [origin=calculated method=formula-sum]
Tc          842.90;      // K   [origin=predictive method=joback]
Pc          24.362;      // bar [origin=predictive method=joback]
omega       0.5227;      // -   [origin=predictive method=lee-kesler]
Tb          606.12;      // K   [origin=predictive method=joback]
HvapTb      54860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.959 1.15204 -0.00072052 1.685e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH3; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-[(4-methylphenyl)methyl]benzene" "methane, di-p-tolyl-" "di(p-tolyl)methane" "4,4'-dimethyldiphenylmethane" "bis-p-tolylmethane" "benzene, 1,1'-methylenebis[4-methyl-" "toluene, p,p'-methylenedi-" "benzene, 1,1'-methylenebis(4-methyl-" "p-ditolylmethane" "4,4'-ditolylmethane" "agn-pc-0ckqu8" "4',4-dimethyldiphenylmethane" );
gibbsFormation
{
    dHf_298   97190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=280980.0
    phase     gas;
}
