/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,9-methano-5h-benzocycloheptene, 6,9-dihydro-  (C12H12, CAS 24309-43-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        59Methano5hBenzocycloheptene69Dihydro;
formula     C12H12;
CAS         24309-43-1;
InChIKey    FKHDAZIHDJCXAU-UHFFFAOYSA-N;
MW          156.228;      // g/mol [origin=calculated method=formula-sum]
Tc          754.68;      // K   [origin=predictive method=joback]
Pc          32.357;      // bar [origin=predictive method=joback]
omega       0.4106;      // -   [origin=predictive method=lee-kesler]
Tb          518.46;      // K   [origin=predictive method=joback]
HvapTb      45362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.33 1.2512 -0.00102084 3.35e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   137430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     292.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=304400.0
}
