/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-3-(1-chloromethyl-2-(2-ethylamyloxy)ethoxy)-2-propanol  (C13H26Cl2O3, CAS 68938-76-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro31Chloromethyl22EthylamyloxyEthoxy2Propanol;
formula     C13H26Cl2O3;
CAS         68938-76-1;
InChIKey    HOROHTJLNQBOPL-UHFFFAOYSA-N;
MW          301.248;      // g/mol [origin=calculated method=formula-sum]
Tc          883.25;      // K   [origin=predictive method=joback]
Pc          16.551;      // bar [origin=predictive method=joback]
omega       1.1740;      // -   [origin=predictive method=lee-kesler]
Tb          707.60;      // K   [origin=predictive method=joback]
HvapTb      73637.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.098 1.17774 -0.0005422 6.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group CH2O; count 1; } { group CH2Cl; count 2; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 3; } { group Cl; count 2; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-[1-chloranyl-3-(2-ethylpentoxy)propan-2-yl]oxy-propan-2-ol" "2-propanol, 1-chloro-3-(2-chloro-1-(((2-ethylpentyl)oxy)methyl)ethoxy)-" "2-propanol, 1-chloro-3-[2-chloro-1-[[(2-ethylpentyl)oxy]methyl]ethoxy]-" "1-chloro-3-[1-chloro-3-(2-ethylpentoxy)propan-2-yl]oxypropan-2-ol" "1-chloro-3-[2-chloro-1-[[(2-ethylpentyl)oxy]methyl]ethoxy]-2-propanol" );
standardThermochemistry
{
    dHf_298   -775640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     774.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-319420.0
}
