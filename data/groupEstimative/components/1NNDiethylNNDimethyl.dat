/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1, n,n-diethyl-n',n'-dimethyl-  (C8H20N2, CAS 123-10-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1NNDiethylNNDimethyl;
formula     C8H20N2;
CAS         123-10-4;
InChIKey    YUKZJEQIDOFUPV-UHFFFAOYSA-N;
MW          144.262;      // g/mol [origin=calculated method=formula-sum]
Tc          568.76;      // K   [origin=predictive method=joback]
Pc          25.252;      // bar [origin=predictive method=joback]
omega       0.5194;      // -   [origin=predictive method=lee-kesler]
Tb          407.52;      // K   [origin=predictive method=joback]
HvapTb      37488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.766 1.01168 -0.0006366 1.588e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n',n'-diethyl-n,n-dimethyl-ethane-1,2-diamine" "ethylenediamine, n,n-diethyl-n',n'-dimethyl-" "1,2-ethanediamine, n,n-diethyl-n',n'-dimethyl-" "n,n-diethyl-n',n'-dimethylethylenediamine" "1,2-ethanediamine, n1,n1-diethyl-n2,n2-dimethyl-" "[2-(dimethylamino)ethyl]diethylamine" "ethylenediamine,n-diethyl-n',n'-dimethyl-" "n,n-diethyl-n',n'-dimethylethylene diamine" "ethylenediamine, n,n-diethyl-n',n'-dimethyl- (8ci)" );
gibbsFormation
{
    dHf_298   -73390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=238040.0
    phase     gas;
}
