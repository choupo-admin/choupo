/*--------------------------------*- Choupo -*-----------------------*\
  Component: bullvalene  (C10H10, CAS 1005-51-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bullvalene;
formula     C10H10;
CAS         1005-51-2;
InChIKey    UKFBVTJTKMSPMI-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          666.25;      // K   [origin=predictive method=joback]
Pc          35.096;      // bar [origin=predictive method=joback]
omega       0.3251;      // -   [origin=predictive method=lee-kesler]
Tb          445.70;      // K   [origin=predictive method=joback]
HvapTb      38332.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.77 1.2024 -0.00104084 3.602e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 4; } { group CH=CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 4; } { group dCH_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bullvalen" "tricyclo[3.3.2.02,8]deca-3,6,9-triene" "ukfbvtjtkmspmi-uhfffaoysa-" "tricyclo[3.3.2.02,6,9-triene" );
standardThermochemistry
{
    dHf_298   115510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     140.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=285640.0
}
