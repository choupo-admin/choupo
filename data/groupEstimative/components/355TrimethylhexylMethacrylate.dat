/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5,5-trimethylhexyl methacrylate  (C13H24O2, CAS 13453-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        355TrimethylhexylMethacrylate;
formula     C13H24O2;
CAS         13453-03-7;
InChIKey    BBPSWYWJFWHIHC-UHFFFAOYSA-N;
MW          212.333;      // g/mol [origin=calculated method=formula-sum]
Tc          732.20;      // K   [origin=predictive method=joback]
Pc          17.551;      // bar [origin=predictive method=joback]
omega       0.6016;      // -   [origin=predictive method=lee-kesler]
Tb          548.15;      // K   [origin=predictive method=joback]
HvapTb      49665.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.357 1.2957 -0.000789 1.77e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5,5-trimethylhexyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 3,5,5-trimethylhexyl ester" "methacrylic acid 3,5,5-trimethylhexyl ester" );
gibbsFormation
{
    dHf_298   -527320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     656.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-172100.0
    phase     gas;
}
