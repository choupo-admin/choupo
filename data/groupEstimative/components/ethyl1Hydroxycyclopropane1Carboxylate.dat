/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 1-hydroxycyclopropane-1-carboxylate  (C6H10O3, CAS 137682-89-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl1Hydroxycyclopropane1Carboxylate;
formula     C6H10O3;
CAS         137682-89-4;
InChIKey    DPMGQZGXWRHYPE-UHFFFAOYSA-N;
MW          130.143;      // g/mol [origin=calculated method=formula-sum]
Tc          681.80;      // K   [origin=predictive method=joback]
Pc          43.169;      // bar [origin=predictive method=joback]
omega       0.8580;      // -   [origin=predictive method=lee-kesler]
Tb          494.26;      // K   [origin=predictive method=joback]
HvapTb      51798.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.099 0.99582 -0.0009912 4.102e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 1-oxidanylcyclopropane-1-carboxylate" "ethyl 1-hydroxycyclopropanecarboxylate" "1-(ethoxycarbonyl)cyclopropan-1-ol" );
standardThermochemistry
{
    dHf_298   -548640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-392290.0
}
