/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetracyclo(4.2.2.22,5.01,6)dodeca-7,9-triene  (C12H14, CAS 106697-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetracyclo422225016Dodeca79Triene;
formula     C12H14;
CAS         106697-43-2;
InChIKey    XGOOVFGSWURYBE-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          740.89;      // K   [origin=predictive method=joback]
Pc          35.096;      // bar [origin=predictive method=joback]
omega       0.3614;      // -   [origin=predictive method=lee-kesler]
Tb          499.92;      // K   [origin=predictive method=joback]
HvapTb      40240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-293.41 2.2192 -0.00254956 1.1332e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group C; count 2; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetracyclo[4.2.2.22,5.01,6]dodeca-7,9-diene(9ci)" "tetracyclo[4.2.2.22,5.01,6]dodeca-7,9-triene" );
standardThermochemistry
{
    dHf_298   146230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     326.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=342100.0
}
