/*--------------------------------*- Choupo -*-----------------------*\
  Component: sec-butylbenzene  (C10H14, CAS 135-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        secButylbenzene;
formula     C10H14;
CAS         135-98-8;
InChIKey    ZJMWRROPUADPEA-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          664.17;      // K   [origin=predictive method=joback]
Pc          29.569;      // bar [origin=predictive method=joback]
omega       0.3581;      // -   [origin=predictive method=lee-kesler]
Tb          454.64;      // K   [origin=predictive method=joback]
HvapTb      39742.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.789 0.88084 -0.0005546 1.328e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butan-2-ylbenzene" "2-phenylbutane" "benzene, sec-butyl-" "benzene, (1-methylpropyl)-" "(1-methylpropyl)benzene" "secondary butylbenzene" "(methylpropyl)benzene" "benzene, (1-methylpropyl)-, (s)-" "s-butylbenzene" "butylbenzene, branched and linear" "sec-butyl-benzene" "1-sec-butylbenzene" );
standardThermochemistry
{
    dHf_298   -18480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143290.0
}
