/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 1,1,7,7-tetramethyl-11-oxo-2,3,5,6,7,11-hexahydro-1h-pyrano[2,3-f]pyrido[3,2,1-ij]quinoline-10-carboxylate  (C22H27NO4, CAS 113869-06-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl1177Tetramethyl11Oxo2356711Hexahydro1hPyrano23FPyrido32;
formula     C22H27NO4;
CAS         113869-06-0;
InChIKey    VQQDHBUBOPTRBY-UHFFFAOYSA-N;
MW          369.461;      // g/mol [origin=calculated method=formula-sum]
Tc          1129.51;      // K   [origin=predictive method=joback]
Pc          15.476;      // bar [origin=predictive method=joback]
omega       1.1039;      // -   [origin=predictive method=lee-kesler]
Tb          903.68;      // K   [origin=predictive method=joback]
HvapTb      84875.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-183.139 2.7484 -0.00260728 1.031e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group C; count 2; } { group CH=C; count 1; } { group ACH; count 1; } { group AC; count 5; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH2_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 6; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "coumarin 314t" "ethyl 1,1,7,7-tetramethyl-11-oxo-2,3,6,7-tetrahydro-1h,5h,11h-pyrano[2,3-f]pyrido[3,2,1-ij]quinoline-10-carboxylate" );
gibbsFormation
{
    dHf_298   -552100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     847.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90300.0
    phase     gas;
}
