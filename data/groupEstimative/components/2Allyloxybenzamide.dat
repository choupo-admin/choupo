/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-allyloxybenzamide  (C10H11NO2, CAS 14520-53-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Allyloxybenzamide;
formula     C10H11NO2;
CAS         14520-53-7;
InChIKey    FZEIWORKISALCO-UHFFFAOYSA-N;
MW          177.203;      // g/mol [origin=calculated method=formula-sum]
Tc          832.42;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.7610;      // -   [origin=predictive method=lee-kesler]
Tb          605.56;      // K   [origin=predictive method=joback]
HvapTb      59919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.551 0.7661 -0.00042096 7.296e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-prop-2-enoxybenzamide" "o-(allyloxy)benzamide" "benzamide, 2-allyloxy-" "2-(2-propenyloxy)benzamide" "benzamide, o-(allyloxy)- (6ci,7ci)" "benzamide, 2-(2-propenyloxy)-" "benzamide,2-(2-propen-1-yloxy)-" "benzamide, 2-(2-propenyloxy)- (9ci)" "benzamide,2-(2-propenyloxy)- (9ci); benzamide, 2-(allyloxy)- (8ci); benzamide,o-(allyloxy)- (6ci,7ci); 2-allyloxybenzamide; o-(allyloxy)benzamide" );
standardThermochemistry
{
    dHf_298   -110250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56470.0
}
