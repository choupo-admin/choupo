/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-cyclohexylhydroxylamine  (C6H13NO, CAS 2211-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nCyclohexylhydroxylamine;
formula     C6H13NO;
CAS         2211-64-5;
InChIKey    GUQRKZPMVLRXLT-UHFFFAOYSA-N;
MW          115.176;      // g/mol [origin=calculated method=formula-sum]
Tc          696.13;      // K   [origin=predictive method=joback]
Pc          45.408;      // bar [origin=predictive method=joback]
omega       0.7998;      // -   [origin=predictive method=lee-kesler]
Tb          498.78;      // K   [origin=predictive method=joback]
HvapTb      52494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.09 0.8061 -0.0004626 9.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group OH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexylhydroxylamine" "n-hydroxycyclohexylamine" "hydroxylamine, n-cyclohexyl-" "n-hydroxycyclohexanamine" "n-cyclohexyl-hydroxylamine" "cyclohexanamine, n-hydroxy-" );
gibbsFormation
{
    dHf_298   -211610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23340.0
    phase     gas;
}
