/*--------------------------------*- Choupo -*-----------------------*\
  Component: di(2-chloroethyl)acetal  (C6H12Cl2O2, CAS 14689-97-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        di2ChloroethylAcetal;
formula     C6H12Cl2O2;
CAS         14689-97-5;
InChIKey    KHNOWHUSVXGGLG-UHFFFAOYSA-N;
MW          187.06;      // g/mol [origin=calculated method=formula-sum]
Tc          639.52;      // K   [origin=predictive method=joback]
Pc          27.877;      // bar [origin=predictive method=joback]
omega       0.5402;      // -   [origin=predictive method=lee-kesler]
Tb          456.14;      // K   [origin=predictive method=joback]
HvapTb      42152.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (72.534 0.46692 -0.0001246 -3.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2O; count 2; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group Cl; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(2-chloroethyloxy)ethane" "1,1-bis(2-chloroethoxy)ethane" "di(2-chloroethyl) acetal" "2,2'-dichlorodiethyl ethanol" "1,1'-(ethylidene)bis(oxy)bis(2-chloroethane)" "acetaldehyde, bis(2-chloroethyl) acetal" "ethane, 1,1'-(ethylidene)bis(oxy)bis(2-chloro-" "acetaldehyde, bis(2-chloroethyl) acetal (6ci,7ci,8ci)" "ethane, bis(2-chloroethoxy)-" "ethane, 1,1-bis(2-choroethoxy)-" "ethane, 1,1-bis(2-choroethoxy)- (9ci)" "ethane,1'-(ethylidene)bis(oxy)bis(2-chloro-" );
standardThermochemistry
{
    dHf_298   -468370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-236660.0
}
