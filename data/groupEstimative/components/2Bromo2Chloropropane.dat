/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-2-chloropropane  (C3H6BrCl, CAS 2310-98-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo2Chloropropane;
formula     C3H6BrCl;
CAS         2310-98-7;
InChIKey    YSQXISYCKHFJFJ-UHFFFAOYSA-N;
MW          157.435;      // g/mol [origin=calculated method=formula-sum]
Tc          578.47;      // K   [origin=predictive method=joback]
Pc          47.236;      // bar [origin=predictive method=joback]
omega       0.2429;      // -   [origin=predictive method=lee-kesler]
Tb          368.60;      // K   [origin=predictive method=joback]
HvapTb      31796.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.23 0.45964 -0.000403 1.395e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 2; } { group C; count 1; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-2-chloranyl-propane" "propane, 2-bromo-2-chloro-" "propane,2-bromo-2-chloro- (7ci,8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -103410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     318.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-20390.0
}
