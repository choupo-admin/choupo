/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-biphenylisocyanate  (C13H9NO, CAS 17337-13-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Biphenylisocyanate;
formula     C13H9NO;
CAS         17337-13-2;
InChIKey    IHHUGFJSEJSCGE-UHFFFAOYSA-N;
MW          195.221;      // g/mol [origin=calculated method=formula-sum]
Tc          873.40;      // K   [origin=predictive method=joback]
Pc          32.840;      // bar [origin=predictive method=joback]
omega       0.6083;      // -   [origin=predictive method=lee-kesler]
Tb          622.05;      // K   [origin=predictive method=joback]
HvapTb      59278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group dCd; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-2-phenyl-benzene" "1-isocyanato-2-phenylbenzene" "2-biphenylyl isocyanate" "2-isocyanatobiphenyl" "2-phenylbenzenisocyanate" "2-isocyanato-biphenyl" "2-biphenyl isocyanate" "1-isocyanato-2-phenyl-menzene" "ihhugfjsejscge-uhfffaoysa-" "isocyanic acid 2-biphenyl ester" "[1,1-biphenyl]-2-yl isocyanate" "[1,1'-biphenyl]-2-yl isocyanate" );
