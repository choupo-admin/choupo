/*--------------------------------*- Choupo -*-----------------------*\
  Component: glycine, n-cyclohexyl-  (C8H15NO2, CAS 58695-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glycineNCyclohexyl;
formula     C8H15NO2;
CAS         58695-41-3;
InChIKey    OQMYZVWIXPPDDE-UHFFFAOYSA-N;
MW          157.213;      // g/mol [origin=calculated method=formula-sum]
Tc          817.80;      // K   [origin=predictive method=joback]
Pc          35.473;      // bar [origin=predictive method=joback]
omega       0.8194;      // -   [origin=predictive method=lee-kesler]
Tb          597.87;      // K   [origin=predictive method=joback]
HvapTb      57431.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.599 1.0129 -0.0006136 1.321e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(cyclohexylamino)ethanoic acid" "n-cyclohexylglycine" "cyclohexyl glycine" "2-(cyclohexylamino)acetic acid" );
gibbsFormation
{
    dHf_298   -450930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-213590.0
    phase     gas;
}
