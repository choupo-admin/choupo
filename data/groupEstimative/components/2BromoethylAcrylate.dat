/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromoethyl acrylate  (C5H7BrO2, CAS 4823-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromoethylAcrylate;
formula     C5H7BrO2;
CAS         4823-47-6;
InChIKey    CDZAAIHWZYWBSS-UHFFFAOYSA-N;
MW          179.013;      // g/mol [origin=calculated method=formula-sum]
Tc          632.49;      // K   [origin=predictive method=joback]
Pc          39.956;      // bar [origin=predictive method=joback]
omega       0.5021;      // -   [origin=predictive method=lee-kesler]
Tb          435.06;      // K   [origin=predictive method=joback]
HvapTb      39896.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.952 0.4422 -0.0002479 4.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromoethyl prop-2-enoate" "acrylic acid, 2-bromoethyl ester" "2-propenoic acid, 2-bromoethyl ester" "2-propenoic acid,2-bromoethyl ester" "2-propenoic acid, 2-bromoethyl ester (9ci)" );
standardThermochemistry
{
    dHf_298   -312050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-216990.0
}
