/*--------------------------------*- Choupo -*-----------------------*\
  Component: controvlar  (C42H52O5, CAS 8015-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        controvlar;
formula     C42H52O5;
CAS         8015-12-1;
InChIKey    GEONECATAKDDLT-JDSZYESASA-N;
MW          636.873;      // g/mol [origin=calculated method=formula-sum]
Tc          1894.12;      // K   [origin=predictive method=joback]
Pc          9.233;      // bar [origin=predictive method=joback]
omega       0.8190;      // -   [origin=predictive method=lee-kesler]
Tb          1536.19;      // K   [origin=predictive method=joback]
HvapTb      149090.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-469.98 5.36216 -0.00479602 1.82588e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 6; } { group C; count 4; } { group CH=C; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } { group CH3COO; count 1; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group tCH; count 2; } { group tC; count 2; } { group CH2_ring; count 14; } { group CH_ring; count 7; } { group C_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,13s,14s,17r)-17-ethynyl-13-methyl-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthrene-3,17-diol;[(8r,9s,10r,13s,14s,17r)-17-ethynyl-13-methyl-3-oxidanylidene-1,2,6,7,8,9,10,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-17-yl] ethanoate" "primodos" "gyn-anovlar" "loestrin 21 1/20" "norlestrin 21 1/50" "norlestrin 28 1/50" "gynonlar 21" "loestrin 21 1.5/30" "anovlar 21" "norlestrin 21 2.5/50" "junel 1/20" "junel 1.5/30" );
gibbsFormation
{
    dHf_298   -505100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1348.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=330600.0
    phase     gas;
}
