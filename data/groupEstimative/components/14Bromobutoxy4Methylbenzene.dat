/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-bromobutoxy)-4-methylbenzene  (C11H15BrO, CAS 3257-49-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Bromobutoxy4Methylbenzene;
formula     C11H15BrO;
CAS         3257-49-6;
InChIKey    WKFSNKTYOQGTBN-UHFFFAOYSA-N;
MW          243.144;      // g/mol [origin=calculated method=formula-sum]
Tc          787.19;      // K   [origin=predictive method=joback]
Pc          27.527;      // bar [origin=predictive method=joback]
omega       0.6417;      // -   [origin=predictive method=lee-kesler]
Tb          571.52;      // K   [origin=predictive method=joback]
HvapTb      51863.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.974 0.88542 -0.00049916 9.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-bromanylbutoxy)-4-methyl-benzene" "toluene, p-(4-bromobutoxy)-" "toluene, p-(4-bromobutoxy)-," );
standardThermochemistry
{
    dHf_298   -151200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53840.0
}
