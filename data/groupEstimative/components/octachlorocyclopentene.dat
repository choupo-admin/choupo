/*--------------------------------*- Choupo -*-----------------------*\
  Component: octachlorocyclopentene  (C5Cl8, CAS 706-78-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octachlorocyclopentene;
formula     C5Cl8;
CAS         706-78-5;
InChIKey    DMZRCHJVWAKCAX-UHFFFAOYSA-N;
MW          343.655;      // g/mol [origin=calculated method=formula-sum]
Tc          913.05;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.4343;      // -   [origin=predictive method=lee-kesler]
Tb          629.22;      // K   [origin=predictive method=joback]
HvapTb      59606.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.73 1.3126 -0.001879 9.518e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl2; count 3; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 3; } { group dC_ring; count 2; } { group Cl; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,3,4,4,5,5-octakis(chloranyl)cyclopentene" "perchlorocyclopentene" "cyclopentene, octachloro-" "octachlorocyclopent-1-ene" "s719" "1,2,3,3,4,4,5,5-octachlorocyclopentene" "cyclopentene,1,2,3,3,4,4,5,5-octachloro-" );
gibbsFormation
{
    dHf_298   -172090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-88860.0
    phase     gas;
}
