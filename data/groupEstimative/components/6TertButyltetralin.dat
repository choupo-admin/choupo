/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-tert-butyltetralin  (C14H20, CAS 42044-26-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6TertButyltetralin;
formula     C14H20;
CAS         42044-26-8;
InChIKey    XCYVLZXWLBLNID-UHFFFAOYSA-N;
MW          188.314;      // g/mol [origin=calculated method=formula-sum]
Tc          800.82;      // K   [origin=predictive method=joback]
Pc          23.703;      // bar [origin=predictive method=joback]
omega       0.4438;      // -   [origin=predictive method=lee-kesler]
Tb          569.01;      // K   [origin=predictive method=joback]
HvapTb      49456.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.92 1.42956 -0.00103592 3.006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-tert-butyl-1,2,3,4-tetrahydronaphthalene" "naphthalene, 6-(1,1-dimethylethyl)-1,2,3,4-tetrahydro-" "6-tert-butyl-[1,3,4-tetrahydronaphthalene]" "naphthalene,1-dimethylethyl)-1,2,3,4-tetrahydro-" );
standardThermochemistry
{
    dHf_298   -40470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=219350.0
}
