/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-pentachloropropene  (C3HCl5, CAS 1600-37-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1hPentachloropropene;
formula     C3HCl5;
CAS         1600-37-9;
InChIKey    MAXQCYDCBHPIAB-UHFFFAOYSA-N;
MW          214.291;      // g/mol [origin=calculated method=formula-sum]
Tc          690.50;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.3274;      // -   [origin=predictive method=lee-kesler]
Tb          458.87;      // K   [origin=predictive method=joback]
HvapTb      43927.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.37 0.3485 -0.000333 1.2e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl2; count 1; } { group Cl_C=C_; count 3; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dC; count 2; } { group Cl; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,3,3-pentakis(chloranyl)prop-1-ene" "1-propene, 1,1,2,3,3-pentachloro-" "1,1,2,3,3-pentachloroprop-1-ene" "1,1,2,3,3-pentachloropropylene" "propene, 1,1,2,3,3-pentachloro-" "1,1,2,3,3-pentachloropropene" "1-propene, pentachloro-" "1,1,2,2,3,3-pentachloropropane" );
gibbsFormation
{
    dHf_298   -91590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-24590.0
    phase     gas;
}
