/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-octadecenamide, n,n-dimethyl-, (9z)-, dimer  (C40H78N2O2, CAS 71302-52-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9OctadecenamideNNDimethyl9zDimer;
formula     C40H78N2O2;
CAS         71302-52-8;
InChIKey    YEASSJSUKSETHZ-ZVMXUFIRSA-N;
MW          619.076;      // g/mol [origin=calculated method=formula-sum]
Tc          1719.44;      // K   [origin=predictive method=joback]
Pc          4.131;      // bar [origin=predictive method=joback]
omega       -0.3004;      // -   [origin=predictive method=lee-kesler]
Tb          1257.14;      // K   [origin=predictive method=joback]
HvapTb      122422.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.682 3.82952 -0.0020928 3.9912e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 28; } { group CH=CH; count 2; } { group CON_CH3_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 28; } { group dCH; count 4; } { group CdO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-n,n-dimethyloctadec-9-enamide" );
standardThermochemistry
{
    dHf_298   -836210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1894.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=305320.0
}
