/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-(methoxycarbonyl)nicotinic acid  (C8H7NO4, CAS 5027-65-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5MethoxycarbonylNicotinicAcid;
formula     C8H7NO4;
CAS         5027-65-6;
InChIKey    GUXKBDHITFXEJG-UHFFFAOYSA-N;
MW          181.147;      // g/mol [origin=calculated method=formula-sum]
Tc          909.36;      // K   [origin=predictive method=joback]
Pc          40.312;      // bar [origin=predictive method=joback]
omega       0.9680;      // -   [origin=predictive method=lee-kesler]
Tb          671.73;      // K   [origin=predictive method=joback]
HvapTb      67121.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.08 0.65518 -0.00036282 5.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C5H3N; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methoxycarbonylpyridine-3-carboxylic acid" "3,5-pyridinecarboxylic acid, 3-methyl ester" "5-(methoxycarbonyl)pyridine-3-carboxylic acid" "agn-pc-02leuy" "3,5-pyridinedicarboxylic acid, 3-methyl ester" "pyridine-3,5-dicarboxylic acid monomethyl ester" );
gibbsFormation
{
    dHf_298   -618150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-457970.0
    phase     gas;
}
