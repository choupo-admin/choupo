/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluorobenzoic acid  (C7H5FO2, CAS 456-22-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4FluorobenzoicAcid;
formula     C7H5FO2;
CAS         456-22-4;
InChIKey    BBYDXOIZLAWGSL-UHFFFAOYSA-N;
MW          140.113;      // g/mol [origin=calculated method=formula-sum]
Tc          758.08;      // K   [origin=predictive method=joback]
Pc          42.719;      // bar [origin=predictive method=joback]
omega       0.6871;      // -   [origin=predictive method=lee-kesler]
Tb          536.20;      // K   [origin=predictive method=joback]
HvapTb      50461.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.39 0.593 -0.00041016 1.063e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group COOH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-fluoranylbenzoic acid" "p-fluorobenzoic acid" "benzoic acid, 4-fluoro-" "4-fluoro-benzoic acid" "benzoic acid, p-fluoro-" "para-fluorobenzoic acid" "c456-22-4[rn]" "4-fluorobenzoatd" "pfba" "p-fluoro-benzoic acid" "p-fluoro- (8ci)" "benzoic acid, p-fluoro- (8ci)" );
standardThermochemistry
{
    dHf_298   -509130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-427880.0
}
