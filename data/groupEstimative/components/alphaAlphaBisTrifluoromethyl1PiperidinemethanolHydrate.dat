name        alphaAlphaBisTrifluoromethyl1PiperidinemethanolHydrate;
formula     C8H13F6NO2;
CAS         30192-67-7;
InChIKey    HAZLTDXMBYOQPB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          269.185;      // g/mol [origin=calculated method=formula-sum]
Tc          655.87;      // K   [origin=predictive method=joback]
Pc          25.201;      // bar [origin=predictive method=joback]
omega       0.8456;      // -   [origin=predictive method=lee-kesler]
Tb          493.14;      // K   [origin=predictive method=joback]
HvapTb      43900.0;      // J/mol [origin=predictive method=joback]

