{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.08 1.5281 -0.001351 4.482e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group OH; count 1; } { group H2O; count 1; } { group CH2N; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
