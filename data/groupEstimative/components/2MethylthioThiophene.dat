/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(methylthio)thiophene  (C5H6S2, CAS 5780-36-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylthioThiophene;
formula     C5H6S2;
CAS         5780-36-9;
InChIKey    ZLSMPEVZXWDWEK-UHFFFAOYSA-N;
MW          130.223;      // g/mol [origin=calculated method=formula-sum]
Tc          704.75;      // K   [origin=predictive method=joback]
Pc          49.804;      // bar [origin=predictive method=joback]
omega       0.2969;      // -   [origin=predictive method=lee-kesler]
Tb          453.86;      // K   [origin=predictive method=joback]
HvapTb      41165.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.2 0.47432 -0.00031702 8.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3S; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group S; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylsulfanylthiophene" "thiophene, 2-(methylthio)-" "2-(methylsulfanyl)thiophene" "2-methylthiothiophene" "2-methylthio-thiophene" "thiophene,2-(methylthio)-" "2-(methylthio)thiophene;methyl 2-thienyl sulfide;" );
gibbsFormation
{
    dHf_298   125510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158750.0
    phase     gas;
}
