/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-heptyloxyphenol  (C13H20O2, CAS 13037-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Heptyloxyphenol;
formula     C13H20O2;
CAS         13037-86-0;
InChIKey    HZBABTUFXQLADL-UHFFFAOYSA-N;
MW          208.301;      // g/mol [origin=calculated method=formula-sum]
Tc          832.46;      // K   [origin=predictive method=joback]
Pc          24.925;      // bar [origin=predictive method=joback]
omega       0.8500;      // -   [origin=predictive method=lee-kesler]
Tb          626.76;      // K   [origin=predictive method=joback]
HvapTb      62232.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.254 1.25132 -0.00085996 2.473e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-heptoxyphenol" "phenol, 4-(heptyloxy)-" "p-n-heptyloxyphenol" "p-(heptyloxy)phenol" "4-n-heptyloxyphenol" "phenol, p-(heptyloxy)-" "4-(heptyloxy)benzolol" "hydroquinone monoheptyl ether" "4-(heptyloxy)phenol (9ci)" "phenol,p-(heptyloxy)- (7ci,8ci);p-(heptyloxy)phenol;p-heptoxyphenol;" );
standardThermochemistry
{
    dHf_298   -384650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-88630.0
}
