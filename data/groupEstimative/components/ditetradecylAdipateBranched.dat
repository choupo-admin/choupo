/*--------------------------------*- Choupo -*-----------------------*\
  Component: ditetradecyl adipate, branched  (C34H66O4, CAS 69227-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ditetradecylAdipateBranched;
formula     C34H66O4;
CAS         69227-17-4;
InChIKey    RAOCGRRIIGUDCV-RTOKGZNSSA-N;
MW          538.898;      // g/mol [origin=calculated method=formula-sum]
Tc          1392.20;      // K   [origin=predictive method=joback]
Pc          5.073;      // bar [origin=predictive method=joback]
omega       0.0867;      // -   [origin=predictive method=lee-kesler]
Tb          1092.20;      // K   [origin=predictive method=joback]
HvapTb      104540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.072 3.14792 -0.0016494 2.772e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 20; } { group CH; count 4; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 22; } { group CH; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-[(5s)-5-butyl-8-methyl-nonyl] o6-[(4s)-4-[(2r)-2-methylbutyl]nonyl] hexanedioate" "hexanedioic acid, ditetradecyl ester, branched" "1-o-[(5s)-5-butyl-8-methylnonyl] 6-o-[(4s)-4-[(2r)-2-methylbutyl]nonyl] hexanedioate" );
gibbsFormation
{
    dHf_298   -1400770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1544.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-395100.0
    phase     gas;
}
