/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-phenyl-6,7,8,9-tetrahydro-5h-benzo[7]annulene  (C17H18, CAS 35068-34-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Phenyl6789Tetrahydro5hBenzo7Annulene;
formula     C17H18;
CAS         35068-34-9;
InChIKey    UYQXAXXXMIEYGP-UHFFFAOYSA-N;
MW          222.331;      // g/mol [origin=calculated method=formula-sum]
Tc          921.66;      // K   [origin=predictive method=joback]
Pc          24.435;      // bar [origin=predictive method=joback]
omega       0.5191;      // -   [origin=predictive method=lee-kesler]
Tb          662.18;      // K   [origin=predictive method=joback]
HvapTb      58907.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.56 1.5332 -0.00102376 2.567e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5h-benzocycloheptene, 5-phenyl-6,7,8,9-tetrahydro-," );
gibbsFormation
{
    dHf_298   127860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=344000.0
    phase     gas;
}
