/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicofol  (C14H9Cl5O, CAS 115-32-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicofol;
formula     C14H9Cl5O;
CAS         115-32-2;
InChIKey    UOAMTSKGCBMZTC-UHFFFAOYSA-N;
MW          370.475;      // g/mol [origin=calculated method=formula-sum]
Tc          1113.95;      // K   [origin=predictive method=joback]
Pc          25.379;      // bar [origin=predictive method=joback]
omega       1.0431;      // -   [origin=predictive method=lee-kesler]
Tb          856.11;      // K   [origin=predictive method=joback]
HvapTb      88646.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.25 1.3766 -0.00114212 3.552e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group OH; count 1; } { group CCl3; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 5; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(chloranyl)-1,1-bis(4-chlorophenyl)ethanol" "kelthane" "acarin" "mitigan" "dichlorokelthane" "2,2,2-trichloro-1,1-bis(4-chlorophenyl)ethanol" "dtmc" "kelthanethanol" "cekudifol" "dicomite" "tricofol" "carbax" );
standardThermochemistry
{
    dHf_298   -130600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     616.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=81770.0
}
