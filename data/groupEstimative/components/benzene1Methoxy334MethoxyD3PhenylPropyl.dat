/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-methoxy-3-(3-(4-methoxy-d3-phenyl)propyl)-  (C17H17D3O2, CAS 67081-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C17H17D3O2 (delta D+3H-3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzene1Methoxy334MethoxyD3PhenylPropyl;
formula     C17H17D3O2;
CAS         67081-97-4;
InChIKey    RMKFJKIMETUHQG-FIBGUPNXSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          259.363;      // g/mol [origin=calculated method=formula-sum]
Tc          918.39;      // K   [origin=predictive method=joback]
Pc          19.718;      // bar [origin=predictive method=joback]
omega       0.7690;      // -   [origin=predictive method=lee-kesler]
Tb          696.72;      // K   [origin=predictive method=joback]
HvapTb      64132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.777 1.21564 -0.00060732 8.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-3-[3-[4-(trideuteriomethoxy)phenyl]propyl]benzene" );
gibbsFormation
{
    dHf_298   -208530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     615.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87820.0
    phase     gas;
}
