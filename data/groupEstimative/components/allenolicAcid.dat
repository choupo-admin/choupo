/*--------------------------------*- Choupo -*-----------------------*\
  Component: allenolic acid  (C13H12O3, CAS 553-39-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allenolicAcid;
formula     C13H12O3;
CAS         553-39-9;
InChIKey    NHGXZNWPADXVOA-UHFFFAOYSA-N;
MW          216.236;      // g/mol [origin=calculated method=formula-sum]
Tc          1016.18;      // K   [origin=predictive method=joback]
Pc          35.986;      // bar [origin=predictive method=joback]
omega       1.1768;      // -   [origin=predictive method=lee-kesler]
Tb          773.81;      // K   [origin=predictive method=joback]
HvapTb      79288.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.298 1.3021 -0.00111324 3.863e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 6; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(6-oxidanylnaphthalen-2-yl)propanoic acid" "amphihydroxynaphthyl-b-propionic acid" "6-hydroxy-2-naphthalenepropanoic acid" "2-naphthalenepropanoic acid, 6-hydroxy-" "2-hydroxy-6-naphthalenepropionic acid" "6-hydroxy-2-naphthalenepropionic acid" "2-naphthalenepropanoicacid, 6-hydroxy-" "2-naphthalenepropionic acid, 6-hydroxy-" "3-(6-hydroxynaphthalen-2-yl)propanoic acid" );
gibbsFormation
{
    dHf_298   -423100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230520.0
    phase     gas;
}
