/*--------------------------------*- Choupo -*-----------------------*\
  Component: tris(methylthio)methane  (C4H10S3, CAS 5418-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trisMethylthioMethane;
formula     C4H10S3;
CAS         5418-86-0;
InChIKey    YFMZQCCTZUJXEB-UHFFFAOYSA-N;
MW          154.304;      // g/mol [origin=calculated method=formula-sum]
Tc          746.07;      // K   [origin=predictive method=joback]
Pc          42.002;      // bar [origin=predictive method=joback]
omega       0.3728;      // -   [origin=predictive method=lee-kesler]
Tb          497.02;      // K   [origin=predictive method=joback]
HvapTb      44561.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.37 0.37293 -7.64e-05 -4.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH3S; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group S; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(methylsulfanyl)methane" "methane, tris(methylthio)-" "trimethyl trithioorthoformate" "orthoformic acid, trithio-, trimethyl ester" "trithiomethoxymethane" "methyl orthotrithioformate" "methane,tris(methylthio)-" );
standardThermochemistry
{
    dHf_298   -5560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79720.0
}
