/*--------------------------------*- Choupo -*-----------------------*\
  Component: [2.1.1]cryptand  (C14H28N2O4, CAS 31250-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        211Cryptand;
formula     C14H28N2O4;
CAS         31250-06-3;
InChIKey    LVNQVIZBPSRXAN-UHFFFAOYSA-N;
MW          288.388;      // g/mol [origin=calculated method=formula-sum]
Tc          976.46;      // K   [origin=predictive method=joback]
Pc          25.611;      // bar [origin=predictive method=joback]
omega       0.7747;      // -   [origin=predictive method=lee-kesler]
Tb          726.66;      // K   [origin=predictive method=joback]
HvapTb      71392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.75 1.8092 -0.0009018 9.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group FCH2O; count 4; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 14; } { group O_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7,13,18-tetraoxa-1,10-diazabicyclo[8.5.5]icosane" "4,7,13,18-tetraoxa-1,10-diazabicyclo[8.5.5]eicosane" "4,7,13,18-tetraoxa-1,10-diazabicyclo(8.5.5)icosane" );
standardThermochemistry
{
    dHf_298   -612870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     671.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64200.0
}
