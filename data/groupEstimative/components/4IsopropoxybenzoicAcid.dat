/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropoxybenzoic acid  (C10H12O3, CAS 13205-46-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4IsopropoxybenzoicAcid;
formula     C10H12O3;
CAS         13205-46-4;
InChIKey    ZVERWTXKKWSSHH-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          850.26;      // K   [origin=predictive method=joback]
Pc          31.491;      // bar [origin=predictive method=joback]
omega       0.8270;      // -   [origin=predictive method=lee-kesler]
Tb          627.55;      // K   [origin=predictive method=joback]
HvapTb      59978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.61 0.80894 -0.00044916 8.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH-O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-propan-2-yloxybenzoic acid" "4-isopropoxybenzoicacid" "4-isopropoxy-benzoic acid" "4-iso-propyloxybenzoic acid" "4-(propan-2-yloxy)benzoic acid" "benzoic acid, 4-(1-methylethoxy)-" "4-(methylethoxy)benzoic acid" "4-(prop-2-yloxy)benzoic acid" "benzoic acid,4-(1-methylethoxy)-" "4-(propan-2-yl-oxy)benzoic acid" );
standardThermochemistry
{
    dHf_298   -512440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-315250.0
}
