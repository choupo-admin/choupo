/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorocyclohexanone  (C6H9ClO, CAS 822-87-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorocyclohexanone;
formula     C6H9ClO;
CAS         822-87-7;
InChIKey    CCHNWURRBFGQCD-UHFFFAOYSA-N;
MW          132.587;      // g/mol [origin=calculated method=formula-sum]
Tc          695.71;      // K   [origin=predictive method=joback]
Pc          39.506;      // bar [origin=predictive method=joback]
omega       0.3349;      // -   [origin=predictive method=lee-kesler]
Tb          461.68;      // K   [origin=predictive method=joback]
HvapTb      38011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.85 0.5344 -0.00016 -3.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2CO; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Cl; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylcyclohexan-1-one" "cyclohexanone, 2-chloro-" ".alpha.-chlorocyclohexanone" "2-chlorocyclohexonone" "alpha-chlorocyclohexanone" "2-chlorocyclohexan-1-one" "2-chloro-cyclohexan-1-one" );
gibbsFormation
{
    dHf_298   -266290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     313.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-110430.0
    phase     gas;
}
