/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-butylphenyl 4-(4-hexyloxybenzoyloxy)benzoate  (C30H34O5, CAS 72928-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Butylphenyl44HexyloxybenzoyloxyBenzoate;
formula     C30H34O5;
CAS         72928-56-4;
InChIKey    DVZYCDSTDIGEFM-UHFFFAOYSA-N;
MW          474.597;      // g/mol [origin=calculated method=formula-sum]
Tc          1371.06;      // K   [origin=predictive method=joback]
Pc          10.033;      // bar [origin=predictive method=joback]
omega       0.9709;      // -   [origin=predictive method=lee-kesler]
Tb          1119.84;      // K   [origin=predictive method=joback]
HvapTb      108412.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.882 2.26584 -0.00120048 1.786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group ACH; count 12; } { group AC; count 5; } { group ACCH2; count 1; } { group CH2O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(4-butylphenoxy)carbonylphenyl] 4-hexoxybenzoate" "benzoic acid, 4-(hexyloxy)-, 4-((4-butylphenoxy)carbonyl)phenyl ester" "benzoic acid, 4-(hexyloxy)-, 4-[(4-butylphenoxy)carbonyl]phenyl ester" );
standardThermochemistry
{
    dHf_298   -754130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1100.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-215680.0
}
