/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-1,3-dithiane  (C6H12S2, CAS 6007-23-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl13Dithiane;
formula     C6H12S2;
CAS         6007-23-4;
InChIKey    MMCSAFCIQDJGDY-UHFFFAOYSA-N;
MW          148.282;      // g/mol [origin=calculated method=formula-sum]
Tc          691.28;      // K   [origin=predictive method=joback]
Pc          39.014;      // bar [origin=predictive method=joback]
omega       0.2739;      // -   [origin=predictive method=lee-kesler]
Tb          452.09;      // K   [origin=predictive method=joback]
HvapTb      41003.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.529 0.72474 -0.000421 8.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl[1,3]dithiane" "1,3-dithiane, 2-ethyl-" "1,3-dithiane, 2-ethyl" "m-dithiane,2-ethyl- (7ci,8ci); 2-ethyl-1,3-dithian; 2-ethyl-1,3-dithiane; propanal, cyclic1,3-propanediyl mercaptal; propionaldehyde, cyclic trimethylene mercaptal" );
standardThermochemistry
{
    dHf_298   -22330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103810.0
}
