/*--------------------------------*- Choupo -*-----------------------*\
  Component: (12r)-n-[3-(dimethylamino)propyl]-12-oxidanyl-octadec-9-enamide  (C23H46N2O2, CAS 20457-75-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12rN3DimethylaminoPropyl12OxidanylOctadec9Enamide;
formula     C23H46N2O2;
CAS         20457-75-4;
InChIKey    DWIUBTKCNCCGOO-JOCHJYFZSA-N;
MW          382.633;      // g/mol [origin=calculated method=formula-sum]
Tc          1154.24;      // K   [origin=predictive method=joback]
Pc          9.766;      // bar [origin=predictive method=joback]
omega       0.8923;      // -   [origin=predictive method=lee-kesler]
Tb          938.22;      // K   [origin=predictive method=joback]
HvapTb      98266.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.134 2.42086 -0.0014873 3.5806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group CH3N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 16; } { group CH; count 1; } { group dCH; count 2; } { group OH; count 1; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-octadecenamide,n-[3-(dimethylamino)propyl]-12-hydroxy-, (9z,12r)-" "9-octadecenamide,n-[3-(dimethylamino)propyl]-12-hydroxy-, [r-(z)]-; ricinoleamide, n-[3-(dimethylamino)propyl]-(8ci); mackine 201; ricinoleic acid-g-dimethylaminopropylamide" );
standardThermochemistry
{
    dHf_298   -549920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1170.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=154990.0
}
