/*--------------------------------*- Choupo -*-----------------------*\
  Component: palmitic acid  (C16H32O2, CAS 57-10-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        palmiticAcid;
formula     C16H32O2;
CAS         57-10-3;
InChIKey    IPCSVZSSVZVIGE-UHFFFAOYSA-N;
MW          256.43;      // g/mol [origin=calculated method=formula-sum]
Tc          887.59;      // K   [origin=predictive method=joback]
Pc          14.080;      // bar [origin=predictive method=joback]
omega       1.0440;      // -   [origin=predictive method=lee-kesler]
Tb          711.19;      // K   [origin=predictive method=joback]
HvapTb      68374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.056 1.57462 -0.0009192 2.072e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecanoic acid" "cetylic acid" "palmitate" "n-hexadecanoic acid" "hexadecylic acid" "hydrofol" "n-hexadecoic acid" "1-pentadecanecarboxylic acid" "c16 fatty acid" "palmitinic acid" "hexaectylic acid" "pentadecanecarboxylic acid" );
gibbsFormation
{
    dHf_298   -723840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     832.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-260070.0
    phase     gas;
}
