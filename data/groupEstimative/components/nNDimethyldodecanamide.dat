/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyldodecanamide  (C14H29NO, CAS 3007-53-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyldodecanamide;
formula     C14H29NO;
CAS         3007-53-2;
InChIKey    BDYUSDIJIDGWCY-UHFFFAOYSA-N;
MW          227.392;      // g/mol [origin=calculated method=formula-sum]
Tc          753.25;      // K   [origin=predictive method=joback]
Pc          15.987;      // bar [origin=predictive method=joback]
omega       0.8477;      // -   [origin=predictive method=lee-kesler]
Tb          586.23;      // K   [origin=predictive method=joback]
HvapTb      55547.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.17 1.42976 -0.0008317 1.8376e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyllauramide" "hallcomid m 12" "dodecanamide, n,n-dimethyl-" "n,n-dimethyldodecamide" "lauryl n,n-dimethylamide" "lauric acid n,n-dimethylamide" "nn-dimethyldodecanamide" "dodecanamide,n-dimethyl-" "n,n-dimethyl dodecanamide" "dodecanamide,n,n-dimethyl-" );
standardThermochemistry
{
    dHf_298   -377340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     744.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48860.0
}
