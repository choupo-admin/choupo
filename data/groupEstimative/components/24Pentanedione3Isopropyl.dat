/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-pentanedione, 3-isopropyl-  (C8H14O2, CAS 1540-38-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Pentanedione3Isopropyl;
formula     C8H14O2;
CAS         1540-38-1;
InChIKey    BPIHCIRSGQKCLT-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          683.54;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.5890;      // -   [origin=predictive method=lee-kesler]
Tb          489.50;      // K   [origin=predictive method=joback]
HvapTb      46118.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.97 0.71968 -0.0003804 6.492e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-propan-2-ylpentane-2,4-dione" "2,4-pentanedione, 3-(1-methylethyl)-" "isopropylacetylacetone" "2, 3-isopropyl-" "2, 3-(1-methylethyl)-" "3-isopropyl-pentane-2,4-dione" "3-(1-methylethyl)pentane-2,4-dione" "3-isopropyl-2,4-pentanedione" "2,4-pentanedione,3-(1-methylethyl)-" "3-acetyl-4-methyl-2-pentanone" );
gibbsFormation
{
    dHf_298   -444170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246240.0
    phase     gas;
}
