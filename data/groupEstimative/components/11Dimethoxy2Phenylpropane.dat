/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethoxy-2-phenylpropane  (C11H16O2, CAS 90-87-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dimethoxy2Phenylpropane;
formula     C11H16O2;
CAS         90-87-9;
InChIKey    UFOUDYPOSJJEDJ-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          729.59;      // K   [origin=predictive method=joback]
Pc          26.004;      // bar [origin=predictive method=joback]
omega       0.5243;      // -   [origin=predictive method=lee-kesler]
Tb          521.92;      // K   [origin=predictive method=joback]
HvapTb      46400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.62 0.85536 -0.0003902 3.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethoxypropan-2-ylbenzene" "2-phenylpropionaldehyde dimethyl acetal" "hydratropic aldehyde dimethyl acetal" "hydratropaldehyde dimethyl acetal" "2-phenylpropanal dimethylacetal" "2-phenylpropanal dimethyl acetal" "hydratropaldehyde, dimethyl acetal" "benzene, (2,2-dimethoxy-1-methylethyl)-" "hydrotropaldehyde dimethyl acetal" "hydrotropic aldehyde dimethyl acetal" "(2,2-dimethoxy-1-methylethyl)benzene" "2-phenylpropionaldehyde-dimethyl acetal" );
gibbsFormation
{
    dHf_298   -308840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60730.0
    phase     gas;
}
