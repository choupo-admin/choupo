name        2HydroxyethylZ12r12Oxidanyloctadec9Enoate1Isocyanato44Isocya;
formula     C35H48N2O6;
CAS         71394-34-8;
InChIKey    GJQVQIUHQNUMTJ-UFCNDGOASA-N;
MW          592.777;      // g/mol [origin=calculated method=formula-sum]
Tc          1956.74;      // K   [origin=predictive method=joback]
Pc          7.560;      // bar [origin=predictive method=joback]
omega       0.0535;      // -   [origin=predictive method=lee-kesler]
Tb          1444.76;      // K   [origin=predictive method=joback]
HvapTb      159073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group CH; count 1; } { group dCH; count 2; } { group dCd; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-octadecenoic acid, 12-hydroxy-, 2-hydroxyethyl ester, (9z,12r)-, polymer with 1,1'-methylenebis(4-isocyanatobenzene)" );
