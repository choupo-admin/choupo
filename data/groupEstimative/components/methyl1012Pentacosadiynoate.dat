/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 10,12-pentacosadiynoate  (C26H44O2, CAS 120650-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl1012Pentacosadiynoate;
formula     C26H44O2;
CAS         120650-77-3;
InChIKey    GGSURCIXQQGITI-UHFFFAOYSA-N;
MW          388.636;      // g/mol [origin=calculated method=formula-sum]
Tc          1067.98;      // K   [origin=predictive method=joback]
Pc          8.707;      // bar [origin=predictive method=joback]
omega       0.8221;      // -   [origin=predictive method=lee-kesler]
Tb          870.70;      // K   [origin=predictive method=joback]
HvapTb      85181.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.779 2.11944 -0.00111172 1.9906e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 18; } { group CH2COO; count 1; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 19; } { group tC; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl pentacosa-10,12-diynoate" );
gibbsFormation
{
    dHf_298   -352650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1163.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=263270.0
    phase     gas;
}
