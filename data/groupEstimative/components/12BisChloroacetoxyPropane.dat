/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(chloroacetoxy)propane  (C7H10Cl2O4, CAS 42831-64-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12BisChloroacetoxyPropane;
formula     C7H10Cl2O4;
CAS         42831-64-1;
InChIKey    RVKVLMMCZLSUGU-UHFFFAOYSA-N;
MW          229.053;      // g/mol [origin=calculated method=formula-sum]
Tc          744.62;      // K   [origin=predictive method=joback]
Pc          26.407;      // bar [origin=predictive method=joback]
omega       0.7450;      // -   [origin=predictive method=lee-kesler]
Tb          550.62;      // K   [origin=predictive method=joback]
HvapTb      54372.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.443 0.57872 -0.0002118 -2.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2Cl; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group Cl; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-chloranylethanoyloxy)propyl 2-chloranylethanoate" "2-(2-chloroacetyl)oxypropyl 2-chloroacetate" "acetic acid, chloro-, 1-methyl-1,2-ethanediyl ester" "acetic acid, 1-methyl-1,2-ethanediyl ester" );
gibbsFormation
{
    dHf_298   -859130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-638980.0
    phase     gas;
}
