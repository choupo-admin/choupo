/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2,2,3-pentachloropropane  (C3H3Cl5, CAS 16714-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11223Pentachloropropane;
formula     C3H3Cl5;
CAS         16714-68-4;
InChIKey    IYFMQUDCYNWFTL-UHFFFAOYSA-N;
MW          216.307;      // g/mol [origin=calculated method=formula-sum]
Tc          677.99;      // K   [origin=predictive method=joback]
Pc          36.115;      // bar [origin=predictive method=joback]
omega       0.3190;      // -   [origin=predictive method=lee-kesler]
Tb          451.72;      // K   [origin=predictive method=joback]
HvapTb      42513.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.461 0.4545 -0.0004164 1.409e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2Cl; count 1; } { group CHCl2; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group Cl; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2,3-pentakis(chloranyl)propane" "propane, 1,1,2,2,3-pentachloro-" );
gibbsFormation
{
    dHf_298   -197980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-84870.0
    phase     gas;
}
