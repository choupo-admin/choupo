/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-hydroxypropyl)ammonium citrate  (C9H17NO8, CAS 30798-32-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxypropylAmmoniumCitrate;
formula     C9H17NO8;
CAS         30798-32-4;
InChIKey    KFAOXEXTCSIFGD-UHFFFAOYSA-N;
MW          267.234;      // g/mol [origin=calculated method=formula-sum]
Tc          1343.37;      // K   [origin=predictive method=joback]
Pc          37.408;      // bar [origin=predictive method=joback]
omega       2.1590;      // -   [origin=predictive method=lee-kesler]
Tb          1096.67;      // K   [origin=predictive method=joback]
HvapTb      129729.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.243 1.06662 -0.000548 6.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } { group CH2NH2; count 1; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } { group COOH; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azanylpropan-2-ol;2-oxidanylpropane-1,2,3-tricarboxylic acid" "1-aminopropan-2-ol 2-hydroxypropane-1,2,3-tricarboxylate(1:1)" "2-propanol, 1-amino-, 2-hydroxy-1,2,3-propanetricarboxylate (1:?)" "2-propanol, 1-amino-, 2-hydroxy-1,2,3-propanetricarboxylate (salt)" "citric acid, monoisopropanolamine salt" "1-aminopropan-2-ol; 2-hydroxypropane-1,2,3-tricarboxylic acid" "1-aminopropan-2-ol 2-hydroxypropane-1,2,3-tricarboxylate (1:1)" );
standardThermochemistry
{
    dHf_298   -1676220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     878.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1318380.0
}
