/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-propylcyclopropanemethylamine  (C7H15N, CAS 26389-60-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nPropylcyclopropanemethylamine;
formula     C7H15N;
CAS         26389-60-6;
InChIKey    MAVLRJDQJZJTQP-UHFFFAOYSA-N;
MW          113.204;      // g/mol [origin=calculated method=formula-sum]
Tc          600.12;      // K   [origin=predictive method=joback]
Pc          32.765;      // bar [origin=predictive method=joback]
omega       0.4674;      // -   [origin=predictive method=lee-kesler]
Tb          416.67;      // K   [origin=predictive method=joback]
HvapTb      37525.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.927 0.89592 -0.0006258 1.819e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(cyclopropylmethyl)propan-1-amine" "cyclopropanemethanamine, n-propyl-" "(cyclopropylmethyl)propylamine" "(cyclopropylmethyl)(propyl)amine" "cyclopropanemethanamine,n-propyl-" "n-(cyclopropylmethyl)-n-propylamine" );
standardThermochemistry
{
    dHf_298   -61540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158200.0
}
