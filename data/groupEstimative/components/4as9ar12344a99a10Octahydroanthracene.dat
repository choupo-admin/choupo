/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4as,9ar)-1,2,3,4,4a,9,9a,10-octahydroanthracene  (C14H18, CAS 64363-88-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4as9ar12344a99a10Octahydroanthracene;
formula     C14H18;
CAS         64363-88-8;
InChIKey    XKTGUHNAJQJXGC-OKILXGFUSA-N;
MW          186.298;      // g/mol [origin=calculated method=formula-sum]
Tc          815.42;      // K   [origin=predictive method=joback]
Pc          26.680;      // bar [origin=predictive method=joback]
omega       0.4452;      // -   [origin=predictive method=lee-kesler]
Tb          573.60;      // K   [origin=predictive method=joback]
HvapTb      49866.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.17 1.478 -0.00104956 2.948e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   26050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=267080.0
}
