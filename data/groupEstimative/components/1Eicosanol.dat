/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-eicosanol  (C20H42O, CAS 629-96-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Eicosanol;
formula     C20H42O;
CAS         629-96-9;
InChIKey    BTFJIXJJCSYFAL-UHFFFAOYSA-N;
MW          298.555;      // g/mol [origin=calculated method=formula-sum]
Tc          918.85;      // K   [origin=predictive method=joback]
Pc          10.778;      // bar [origin=predictive method=joback]
omega       1.0184;      // -   [origin=predictive method=lee-kesler]
Tb          749.38;      // K   [origin=predictive method=joback]
HvapTb      76793.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.001 1.93782 -0.0010946 2.366e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 19; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 19; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "icosan-1-ol" "arachidyl alcohol" "n-eicosanol" "arachidic alcohol" "arachic alcohol" "eicosyl alcohol" "eicosan-1-ol" "n-1-eicosanol" "icosanol" "eicosanol" "1-icosanol" "pri-n-eicosyl alcohol" );
standardThermochemistry
{
    dHf_298   -608360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     985.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19300.0
}
