/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetic acid ethenyl ester, polymer with ethenol, (2z)-2-butenedioate  (C10H12O6, CAS 72828-12-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aceticAcidEthenylEsterPolymerWithEthenol2z2Butenedioate;
formula     C10H12O6;
CAS         72828-12-7;
InChIKey    HGEYTIUPRGPIPD-BJILWQEISA-N;
MW          228.2;      // g/mol [origin=calculated method=formula-sum]
Tc          896.45;      // K   [origin=predictive method=joback]
Pc          24.243;      // bar [origin=predictive method=joback]
omega       1.0174;      // -   [origin=predictive method=lee-kesler]
Tb          689.27;      // K   [origin=predictive method=joback]
HvapTb      68744.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.87 0.66882 -0.0001184 -1.134e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group CH=CH; count 1; } { group CH3COO; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 2; } { group dCH; count 4; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-4-ethenoxy-4-oxidanylidene-but-2-enoic acid;ethenyl ethanoate" );
standardThermochemistry
{
    dHf_298   -978100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     793.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-780190.0
}
