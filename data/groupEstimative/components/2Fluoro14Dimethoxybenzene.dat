/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluoro-1,4-dimethoxybenzene  (C8H9FO2, CAS 82830-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Fluoro14Dimethoxybenzene;
formula     C8H9FO2;
CAS         82830-49-7;
InChIKey    WNCYZVMZKSOPMU-UHFFFAOYSA-N;
MW          156.156;      // g/mol [origin=calculated method=formula-sum]
Tc          662.20;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       0.4996;      // -   [origin=predictive method=lee-kesler]
Tb          463.39;      // K   [origin=predictive method=joback]
HvapTb      41005.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.4 0.45134 -0.00010292 -4.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3O; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-fluoranyl-1,4-dimethoxy-benzene" "1,4-dimethoxy-2-fluorobenzene" "2,5-dimethoxyfluorobenzene" "2,5-dimethoxy-1-fluorobenzene" "benzene,2-fluoro-1,4-dimethoxy-" "2-fluorohydroquinone dimethyl ether" "82830-49-7 1,4-dimethoxy-2-fluorobenzene" "2,5-dimethoxyfluorobenzene;2-fluoro-1,4-dimethoxybenzene;benzene, 2-fluoro-1,4-dimethoxy-;" );
gibbsFormation
{
    dHf_298   -455410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-295180.0
    phase     gas;
}
