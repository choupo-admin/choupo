/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxy-4-methyl-2-pentanone  (C7H14O2, CAS 107-70-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxy4Methyl2Pentanone;
formula     C7H14O2;
CAS         107-70-0;
InChIKey    KOKPBCHLPVDQTK-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          620.71;      // K   [origin=predictive method=joback]
Pc          30.024;      // bar [origin=predictive method=joback]
omega       0.4520;      // -   [origin=predictive method=lee-kesler]
Tb          432.82;      // K   [origin=predictive method=joback]
HvapTb      39036.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.911 0.70348 -0.0003991 8.016e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH3CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxy-4-methyl-pentan-2-one" "pent-oxone solvent" "pentoxone" "2-pentanone, 4-methoxy-4-methyl-" "4-methoxy-4-methylpentan-2-one" "4-methyl-4-methoxy-2-pentanone" "me 6 k" "2-pentanone,4-methoxy-4-methyl-" );
standardThermochemistry
{
    dHf_298   -441360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-223020.0
}
