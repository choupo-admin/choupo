/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-bromo-2-naphthol  (C10H7BrO, CAS 15231-91-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Bromo2Naphthol;
formula     C10H7BrO;
CAS         15231-91-1;
InChIKey    YLDFTMJPQJXGSS-UHFFFAOYSA-N;
MW          223.069;      // g/mol [origin=calculated method=formula-sum]
Tc          891.46;      // K   [origin=predictive method=joback]
Pc          51.093;      // bar [origin=predictive method=joback]
omega       0.7204;      // -   [origin=predictive method=lee-kesler]
Tb          625.82;      // K   [origin=predictive method=joback]
HvapTb      61881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.98 1.0045 -0.00094884 3.567e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 4; } { group Br; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-bromanylnaphthalen-2-ol" "2-naphthalenol, 6-bromo-" "6-bromonaphthalen-2-ol" "6-bromo-naphthalen-2-ol" "6-bromo-.beta.-naphthol" "bromo-6 naphtol-2 [french]" "2-naphthol, 6-bromo-" "bromo-6 naphtol-2" "6-bromo-2-naphthalenol" "6-bromo2-hydroxynaphthalene" "6-bromo-2-hydroxynaphtalene" "2-naphthalenol, 6-bromo- (9ci)" );
standardThermochemistry
{
    dHf_298   15420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102450.0
}
