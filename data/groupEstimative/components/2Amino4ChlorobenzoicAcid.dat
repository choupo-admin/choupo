/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-4-chlorobenzoic acid  (C7H6ClNO2, CAS 89-77-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino4ChlorobenzoicAcid;
formula     C7H6ClNO2;
CAS         89-77-0;
InChIKey    JYYLQSCZISREGY-UHFFFAOYSA-N;
MW          171.58;      // g/mol [origin=calculated method=formula-sum]
Tc          897.71;      // K   [origin=predictive method=joback]
Pc          45.654;      // bar [origin=predictive method=joback]
omega       0.8986;      // -   [origin=predictive method=lee-kesler]
Tb          651.87;      // K   [origin=predictive method=joback]
HvapTb      66966.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.2 0.5904 -0.00039052 9.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACNH2; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-4-chloranyl-benzoic acid" "4-chloroanthranilic acid" "4-chloro anthranilic acid" "2-carboxy-5-chloroaniline" "4-chloroanthranil acid" "2,4-acba" "benzoic acid, 2-amino-4-chloro-" "4-chloro-2-aminobenzoic acid" "anthranilic acid, 4-chloro- (6ci,7ci,8ci)" "2-amino-4-chlorobenzoic" "anthranilic acid, 4-chloro-" "2-amino-4-chloro benzoic acid" );
gibbsFormation
{
    dHf_298   -306440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-188180.0
    phase     gas;
}
