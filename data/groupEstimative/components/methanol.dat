/*--------------------------------*- Choupo -*-----------------------*\
  Component: -methanol  (C9H10O3, CAS 3663-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methanol;
formula     C9H10O3;
CAS         3663-82-9;
InChIKey    GWQOQQVKVOOHTI-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          808.71;      // K   [origin=predictive method=joback]
Pc          42.330;      // bar [origin=predictive method=joback]
omega       0.9520;      // -   [origin=predictive method=lee-kesler]
Tb          594.27;      // K   [origin=predictive method=joback]
HvapTb      64350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.329 0.8897 -0.00060636 1.583e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydro-1,4-benzodioxin-3-ylmethanol" "2-hydroxymethyl-1,4-benzodioxane" "1,4-benzodioxan-2-methanol" "(2,3-dihydro-benzo[1,4]dioxin-2-yl)-methanol" "2,3-dihydro-1,4-benzodioxin-2-ylmethanol" "1,4-benzodioxane-2-methanol" "2-hydroxymethyl-1,4-benzodioxan" "1,4-benzodioxin-2-methanol, 2,3-dihydro-" "2-(hydroxymethyl)-1,4-benzodioxan" "(2,3-dihydro-benzo[1,4]dioxin-2-yl)" "(2,3-dihydrobenzo[b][1,4]dioxin-2-yl)methanol" "2-hydroxymethyl-1,4-benzo-dioxan" );
standardThermochemistry
{
    dHf_298   -353620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     271.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-132730.0
}
