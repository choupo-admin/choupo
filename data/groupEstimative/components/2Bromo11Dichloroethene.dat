/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-1,1-dichloroethene  (C2HBrCl2, CAS 5870-61-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo11Dichloroethene;
formula     C2HBrCl2;
CAS         5870-61-1;
InChIKey    OEKZZIRTAIOPIP-UHFFFAOYSA-N;
MW          175.834;      // g/mol [origin=calculated method=formula-sum]
Tc          612.55;      // K   [origin=predictive method=joback]
Pc          54.225;      // bar [origin=predictive method=joback]
omega       0.2861;      // -   [origin=predictive method=lee-kesler]
Tb          390.42;      // K   [origin=predictive method=joback]
HvapTb      35289.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.17 0.2655 -0.0002833 1.139e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group Br; count 1; } { group Cl_C=C_; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group dC; count 1; } { group Cl; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-1,1-bis(chloranyl)ethene" "2-bromo-1,1-dichloroethylene" "ethene, 2-bromo-1,1-dichloro-" "ethene,2-bromo-1,1-dichloro- (9ci)" "ethylene,2-bromo-1,1-dichloro- (7ci,8ci); 1,1-dichloro-2-bromoethylene;2-bromo-1,1-dichloroethylene" );
gibbsFormation
{
    dHf_298   17670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     341.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28090.0
    phase     gas;
}
