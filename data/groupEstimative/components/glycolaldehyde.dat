/*--------------------------------*- Choupo -*-----------------------*\
  Component: glycolaldehyde  (C2H4O2, CAS 141-46-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glycolaldehyde;
formula     C2H4O2;
CAS         141-46-8;
InChIKey    WGCNASOHLSPBMP-UHFFFAOYSA-N;
MW          60.052;      // g/mol [origin=calculated method=formula-sum]
Tc          557.14;      // K   [origin=predictive method=joback]
Pc          64.619;      // bar [origin=predictive method=joback]
omega       0.7430;      // -   [origin=predictive method=lee-kesler]
Tb          386.20;      // K   [origin=predictive method=joback]
HvapTb      43445.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.761 0.2023 -0.0001084 2.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group OH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylethanal" "hydroxyacetaldehyde" "glycolic aldehyde" "glycollaldehyde" "diose" "methylol formaldehyde" "glycoaldehyde" "monomethylolformaldehyde" "acetaldehyde, hydroxy-" "2-hydroxyethanal" "2-oh-acetaldehyde" "2-hydroxyacetaldehyde" );
gibbsFormation
{
    dHf_298   -322420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     303.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-270380.0
    phase     gas;
}
