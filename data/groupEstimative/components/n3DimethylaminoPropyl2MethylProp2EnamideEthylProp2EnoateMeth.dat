/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-[3-(dimethylamino)propyl]-2-methyl-prop-2-enamide;ethyl prop-2-enoate;methyl 2-methylprop-2-enoate  (C19H34N2O5, CAS 114535-81-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3DimethylaminoPropyl2MethylProp2EnamideEthylProp2EnoateMeth;
formula     C19H34N2O5;
CAS         114535-81-8;
InChIKey    RMWBWVTYLPYUOL-UHFFFAOYSA-N;
MW          370.49;      // g/mol [origin=calculated method=formula-sum]
Tc          1059.32;      // K   [origin=predictive method=joback]
Pc          11.126;      // bar [origin=predictive method=joback]
omega       0.9912;      // -   [origin=predictive method=lee-kesler]
Tb          859.84;      // K   [origin=predictive method=joback]
HvapTb      86665.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (105.174 1.39882 -0.0002068 -2.3904e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group CH3N; count 1; } { group COO; count 2; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group CdO; count 1; } { group COO; count 2; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, methyl ester, polymer with n-(3-(dimethylamino)propyl)-2-methyl-2-propenamide and ethyl 2-propenoate" );
standardThermochemistry
{
    dHf_298   -928160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1275.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-403490.0
}
