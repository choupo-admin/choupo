/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanenitrile, 3-(hexadecyloxy)-  (C19H37NO, CAS 3605-77-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanenitrile3Hexadecyloxy;
formula     C19H37NO;
CAS         3605-77-4;
InChIKey    UAHOEGZWOAYFTI-UHFFFAOYSA-N;
MW          295.511;      // g/mol [origin=calculated method=formula-sum]
Tc          936.48;      // K   [origin=predictive method=joback]
Pc          10.514;      // bar [origin=predictive method=joback]
omega       0.9225;      // -   [origin=predictive method=lee-kesler]
Tb          758.82;      // K   [origin=predictive method=joback]
HvapTb      70776.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.117 1.68042 -0.0008678 1.538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH2O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-hexadecoxypropanenitrile" "3-(hexadecyloxy)propanenitrile" );
gibbsFormation
{
    dHf_298   -402830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     913.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=137280.0
    phase     gas;
}
