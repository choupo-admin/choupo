/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butoxyethyl acrylate  (C9H16O3, CAS 7251-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButoxyethylAcrylate;
formula     C9H16O3;
CAS         7251-90-3;
InChIKey    PTJDGKYFJYEAOK-UHFFFAOYSA-N;
MW          172.224;      // g/mol [origin=calculated method=formula-sum]
Tc          656.30;      // K   [origin=predictive method=joback]
Pc          23.749;      // bar [origin=predictive method=joback]
omega       0.6518;      // -   [origin=predictive method=lee-kesler]
Tb          482.84;      // K   [origin=predictive method=joback]
HvapTb      44775.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.625 0.72082 -0.0002831 1.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2=CH; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butoxyethyl prop-2-enoate" "2-butoxyethoxy acrylate" "butyl cellosolve acrylate" "2-propenoic acid, 2-butoxyethyl ester" "acrylic acid, butoxyethyl ester" "acrylic acid, 2-butoxyethyl ester" "2-n-butoxyethyl acrylate" "2-propenoic acid,2-butoxyethyl ester" "acrylic acid, 2-butoxyethyl ester (8ci)" );
gibbsFormation
{
    dHf_298   -553160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-302630.0
    phase     gas;
}
