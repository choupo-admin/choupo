/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(dodecylamino)propanenitrile  (C15H30N2, CAS 4763-40-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3DodecylaminoPropanenitrile;
formula     C15H30N2;
CAS         4763-40-0;
InChIKey    DKRQDOPNZFOLQD-UHFFFAOYSA-N;
MW          238.419;      // g/mol [origin=calculated method=formula-sum]
Tc          872.98;      // K   [origin=predictive method=joback]
Pc          14.027;      // bar [origin=predictive method=joback]
omega       0.9723;      // -   [origin=predictive method=lee-kesler]
Tb          695.05;      // K   [origin=predictive method=joback]
HvapTb      65898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.043 1.43982 -0.0008098 1.715e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH2NH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(dodecylamino)propionitrile" "propanenitrile, 3-(dodecylamino)-" "3-(dodecylamino)propiononitrile" "propanenitrile,3-(dodecylamino)-" );
standardThermochemistry
{
    dHf_298   -134580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     787.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=297990.0
}
