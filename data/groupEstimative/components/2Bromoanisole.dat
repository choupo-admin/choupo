/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromoanisole  (C7H7BrO, CAS 578-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromoanisole;
formula     C7H7BrO;
CAS         578-57-4;
InChIKey    HTDQSWDEWGSAMN-UHFFFAOYSA-N;
MW          187.036;      // g/mol [origin=calculated method=formula-sum]
Tc          711.37;      // K   [origin=predictive method=joback]
Pc          43.169;      // bar [origin=predictive method=joback]
omega       0.4393;      // -   [origin=predictive method=lee-kesler]
Tb          480.00;      // K   [origin=predictive method=joback]
HvapTb      42959.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.61 0.50542 -0.00028156 5.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-methoxy-benzene" "1-bromo-2-methoxybenzene" "o-bromoanisole" "anisole, o-bromo-" "benzene, 1-bromo-2-methoxy-" "o-anisyl bromide" "2-methoxybromobenzene" "o-methoxybromobenzene" "o-methoxyphenyl bromide" "2-methoxyphenyl bromide" "2-bromoanisol" "2-bromo-1-methoxybenzene" );
standardThermochemistry
{
    dHf_298   -68640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20160.0
}
