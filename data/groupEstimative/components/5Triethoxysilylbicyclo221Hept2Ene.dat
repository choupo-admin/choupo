name        5Triethoxysilylbicyclo221Hept2Ene;
formula     C13H24O3Si;
CAS         18401-43-9;
InChIKey    HHKDWDAAEFGBAC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          256.417;      // g/mol [origin=calculated method=formula-sum]
Tc          771.46;      // K   [origin=predictive method=joback]
Pc          18.123;      // bar [origin=predictive method=joback]
omega       0.6251;      // -   [origin=predictive method=lee-kesler]
Tb          577.94;      // K   [origin=predictive method=joback]
HvapTb      52037.0;      // J/mol [origin=predictive method=joback]

