{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.503 1.05276 -0.00026148 -9.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } { group CH=CH; count 1; } { group CH2O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
