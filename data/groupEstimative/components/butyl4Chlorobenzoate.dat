/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 4-chlorobenzoate  (C11H13ClO2, CAS 27942-64-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl4Chlorobenzoate;
formula     C11H13ClO2;
CAS         27942-64-9;
InChIKey    PBPVJPWUWLGOEC-UHFFFAOYSA-N;
MW          212.673;      // g/mol [origin=calculated method=formula-sum]
Tc          790.73;      // K   [origin=predictive method=joback]
Pc          25.252;      // bar [origin=predictive method=joback]
omega       0.6482;      // -   [origin=predictive method=lee-kesler]
Tb          578.59;      // K   [origin=predictive method=joback]
HvapTb      54810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.583 0.86242 -0.00046456 7.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 4-chloranylbenzoate" "4-chlorobenzoic acid, butyl ester" "benzoic acid, 4-chloro-, butyl ester" "4-chlorobenzoic acid butyl ester" );
standardThermochemistry
{
    dHf_298   -378330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-177780.0
}
