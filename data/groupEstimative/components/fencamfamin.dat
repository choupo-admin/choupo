/*--------------------------------*- Choupo -*-----------------------*\
  Component: fencamfamin  (C15H21N, CAS 1209-98-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fencamfamin;
formula     C15H21N;
CAS         1209-98-9;
InChIKey    IKFBPFGUINLYQI-UHFFFAOYSA-N;
MW          215.34;      // g/mol [origin=calculated method=formula-sum]
Tc          854.43;      // K   [origin=predictive method=joback]
Pc          22.784;      // bar [origin=predictive method=joback]
omega       0.6240;      // -   [origin=predictive method=lee-kesler]
Tb          628.06;      // K   [origin=predictive method=joback]
HvapTb      57076.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-139.589 1.66532 -0.0011552 3.156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 3; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-2-phenyl-bicyclo[2.2.1]heptan-3-amine" "fencamfamine" "reactivan" "fencamfaminum" "euvitol" "fenacamfamin" "fencanfamina" "fencamfamina [dcit]" "2-ethylamino-3-phenylnorbornane" "fencamfamine [inn-french]" "fencamfaminum [inn-latin]" "fencamfamina" );
standardThermochemistry
{
    dHf_298   35830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=371200.0
}
