/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutanol  (C4H8O, CAS 2919-23-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobutanol;
formula     C4H8O;
CAS         2919-23-5;
InChIKey    KTHXBEHDVMTNOH-UHFFFAOYSA-N;
MW          72.107;      // g/mol [origin=calculated method=formula-sum]
Tc          577.57;      // K   [origin=predictive method=joback]
Pc          54.465;      // bar [origin=predictive method=joback]
omega       0.5868;      // -   [origin=predictive method=lee-kesler]
Tb          394.31;      // K   [origin=predictive method=joback]
HvapTb      41262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.82 0.5591 -0.000398 1.156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobutyl hydroxide" "hydroxycyclobutane" "kthxbehdvmtnoh-uhfffaoysa-" "r970" "cyclobutylalcohol;cyclobutyl hydroxide;hydroxycyclobutane;" );
standardThermochemistry
{
    dHf_298   -211480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     292.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105370.0
}
