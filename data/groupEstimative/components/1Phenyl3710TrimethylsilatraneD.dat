name        1Phenyl3710TrimethylsilatraneD;
formula     C15H23NO3Si;
CAS         54824-83-8;
InChIKey    RJQQQNQWKNMYNG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          293.438;      // g/mol [origin=calculated method=formula-sum]
Tc          923.22;      // K   [origin=predictive method=joback]
Pc          21.158;      // bar [origin=predictive method=joback]
omega       0.6544;      // -   [origin=predictive method=lee-kesler]
Tb          685.79;      // K   [origin=predictive method=joback]
HvapTb      67160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
