{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.47 1.50516 -0.0007253 6.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH-O; count 3; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7,10-trimethyl-5-phenyl-4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecane" "1-phenyl,3,7,10-trimethylsilatrane, e" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane, 3,7,10-trimethyl-1-phenyl-" "2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane, 3,7,10-trimethyl-1-phenyl-" "3,7,10-trimethyl-1-phenyl-2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane" );
