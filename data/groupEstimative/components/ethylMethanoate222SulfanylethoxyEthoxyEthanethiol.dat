/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl methanoate;2-[2-(2-sulfanylethoxy)ethoxy]ethanethiol  (C9H20O4S2, CAS 167614-38-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H20O4S2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethylMethanoate222SulfanylethoxyEthoxyEthanethiol;
formula     C9H20O4S2;
CAS         167614-38-2;
InChIKey    NERCDLHZQNEDQG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          256.375;      // g/mol [origin=calculated method=formula-sum]
Tc          759.79;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.5865;      // -   [origin=predictive method=lee-kesler]
Tb          553.90;      // K   [origin=predictive method=joback]
HvapTb      51843.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (96.807 0.58892 -2.68e-05 -1.23e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group HCOO; count 1; } { group CH2O; count 2; } { group CH2SH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group O; count 2; } { group SH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "formic acid, ethyl ester, polymer with 2,2'-(1,2-ethanediylbis(oxy))bis(ethanethiol)" );
standardThermochemistry
{
    dHf_298   -451740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     945.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-187120.0
}
