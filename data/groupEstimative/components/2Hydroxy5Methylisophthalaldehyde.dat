/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxy-5-methylisophthalaldehyde  (C9H8O3, CAS 7310-95-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H8O3 (delta C+2H+2O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Hydroxy5Methylisophthalaldehyde;
formula     C9H8O3;
CAS         7310-95-4;
InChIKey    ZBOUXALQDLLARY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          164.16;      // g/mol [origin=calculated method=formula-sum]
Tc          700.15;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       0.4599;      // -   [origin=predictive method=lee-kesler]
Tb          475.62;      // K   [origin=predictive method=joback]
HvapTb      47496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.52 0.83172 -0.00092528 3.981e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 1; } { group ACOH; count 1; } { group CHO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-2-oxidanyl-benzene-1,3-dicarbaldehyde" "2,6-diformyl-4-methylphenol" "2-hydroxy-5-methyl-1,3-benzenedicarboxaldehyde" "1,3-benzenedicarboxaldehyde, 2-hydroxy-5-methyl-" "2-hydroxy-5-methylbenzene-1,3-dicarbaldehyde" "2,6-diformyl-4--methylphenol" "2-hydroxy-5-methylisophthaldehyde" "2-hydroxy-5-methylisophthalaldehyd" "s366" "1,3-benzenedicarboxaldehyde, 2-hydroxy-5-methyl" );
gibbsFormation
{
    dHf_298   -39910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=51350.0
    phase     gas;
}
