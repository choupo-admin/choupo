/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dibromo-2-fluorobenzene  (C6H3Br2F, CAS 1435-52-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dibromo2Fluorobenzene;
formula     C6H3Br2F;
CAS         1435-52-5;
InChIKey    WNSNPGHNIJOOPM-UHFFFAOYSA-N;
MW          253.896;      // g/mol [origin=calculated method=formula-sum]
Tc          748.92;      // K   [origin=predictive method=joback]
Pc          51.020;      // bar [origin=predictive method=joback]
omega       0.5000;      // -   [origin=predictive method=lee-kesler]
Tb          505.11;      // K   [origin=predictive method=joback]
HvapTb      44603.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.6 0.4641 -0.00035892 1.097e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group Br; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(bromanyl)-2-fluoranyl-benzene" "2,5-dibromofluorobenzene" "4-bromo-2-fluorobromobenzene" "2-fluoro-4-bromobromobenzene" "2,5-dibromo-fluorobenzene" "benzene, 1,4-dibromo-2-fluoro-" "2,5-dibromo-1-fluorobenzene" );
standardThermochemistry
{
    dHf_298   -97030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-73380.0
}
