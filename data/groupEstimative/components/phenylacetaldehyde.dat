/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylacetaldehyde  (C8H8O, CAS 122-78-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylacetaldehyde;
formula     C8H8O;
CAS         122-78-1;
InChIKey    DTUQWGWMVIHBKE-UHFFFAOYSA-N;
MW          120.151;      // g/mol [origin=calculated method=formula-sum]
Tc          673.89;      // K   [origin=predictive method=joback]
Pc          40.007;      // bar [origin=predictive method=joback]
omega       0.4437;      // -   [origin=predictive method=lee-kesler]
Tb          457.98;      // K   [origin=predictive method=joback]
HvapTb      42398.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.889 0.6594 -0.0004356 1.074e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylethanal" "benzeneacetaldehyde" "hyacinthin" "alpha-tolualdehyde" "phenylethanal" "phenylacetic aldehyde" "alpha-toluic aldehyde" "acetaldehyde, phenyl-" "oxophenylethane" "1-oxo-2-phenylethane" "benzylcarboxaldehyde" "2-phenylacetaldehyde" );
standardThermochemistry
{
    dHf_298   -57500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29370.0
}
