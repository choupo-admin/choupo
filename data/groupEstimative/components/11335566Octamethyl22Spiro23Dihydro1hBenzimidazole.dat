/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'3,3',5,5'6,6'-octamethyl-2,2'-spiro(2,3-dihydro-1h-benzimidazole  (C21H28N4, CAS 99643-38-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11335566Octamethyl22Spiro23Dihydro1hBenzimidazole;
formula     C21H28N4;
CAS         99643-38-6;
InChIKey    MTFYBWKFOIZUKS-UHFFFAOYSA-N;
MW          336.483;      // g/mol [origin=calculated method=formula-sum]
Tc          1020.18;      // K   [origin=predictive method=joback]
Pc          16.565;      // bar [origin=predictive method=joback]
omega       1.0741;      // -   [origin=predictive method=lee-kesler]
Tb          810.12;      // K   [origin=predictive method=joback]
HvapTb      77160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-171.79 2.64796 -0.00248956 9.642e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 4; } { group AC; count 4; } { group ACCH3; count 4; } { group CH3N; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group N; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1',3,3',5,5',6,6'-octamethyl-2,2'-spirobi[benzimidazole]" "1,1'3,3',5,5'6,6'-octamethyl-2,2'-spiro[2,3-dihydro-1h-benzimidazole" );
standardThermochemistry
{
    dHf_298   409570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=920320.0
}
