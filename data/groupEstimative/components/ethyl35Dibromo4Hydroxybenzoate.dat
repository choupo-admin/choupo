/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3,5-dibromo-4-hydroxybenzoate  (C9H8Br2O3, CAS 55771-81-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl35Dibromo4Hydroxybenzoate;
formula     C9H8Br2O3;
CAS         55771-81-8;
InChIKey    RLKDCOVOJVJVFI-UHFFFAOYSA-N;
MW          323.968;      // g/mol [origin=calculated method=formula-sum]
Tc          963.99;      // K   [origin=predictive method=joback]
Pc          45.104;      // bar [origin=predictive method=joback]
omega       1.0440;      // -   [origin=predictive method=lee-kesler]
Tb          713.32;      // K   [origin=predictive method=joback]
HvapTb      72519.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.271 0.83712 -0.00066748 2.158e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group Br; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3,5-bis(bromanyl)-4-oxidanyl-benzoate" "ethyl 4-hydroxy-3,5-dibromobenzoate" "benzoic acid, 3,5-dibromo-4-hydroxy-, ethyl ester" "benzoic acid,5-dibromo-4-hydroxy-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -457430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-318300.0
}
