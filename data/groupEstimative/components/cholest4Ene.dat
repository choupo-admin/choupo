/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholest-4-ene  (C27H46, CAS 16732-86-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholest4Ene;
formula     C27H46;
CAS         16732-86-8;
InChIKey    YWHWYTRNKBGSRE-UHFFFAOYSA-N;
MW          370.665;      // g/mol [origin=calculated method=formula-sum]
Tc          1083.95;      // K   [origin=predictive method=joback]
Pc          10.379;      // bar [origin=predictive method=joback]
omega       0.7040;      // -   [origin=predictive method=lee-kesler]
Tb          860.07;      // K   [origin=predictive method=joback]
HvapTb      73466.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-317.617 3.5516 -0.00297484 1.0757e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 12; } { group CH; count 6; } { group C; count 2; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 9; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,6,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthrene" );
standardThermochemistry
{
    dHf_298   -314660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     938.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=348010.0
}
