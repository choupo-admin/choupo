/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-phenyl-1-pentyne  (C11H12, CAS 1823-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Phenyl1Pentyne;
formula     C11H12;
CAS         1823-14-9;
InChIKey    KOSORCNALVBYBP-UHFFFAOYSA-N;
MW          144.217;      // g/mol [origin=calculated method=formula-sum]
Tc          685.33;      // K   [origin=predictive method=joback]
Pc          31.036;      // bar [origin=predictive method=joback]
omega       0.3673;      // -   [origin=predictive method=lee-kesler]
Tb          468.08;      // K   [origin=predictive method=joback]
HvapTb      42214.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.237 0.876 -0.00060173 1.6359e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-4-ynylbenzene" "benzene, 4-pentynyl-" "pent-4-yn-1-ylbenzene" "5-phenyl pentyne" "pent-4-ynyl-benzene" "5-phenypent-1-yne" "1-(pent-4-yn-1-yl)benzene" );
gibbsFormation
{
    dHf_298   258060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=377220.0
    phase     gas;
}
