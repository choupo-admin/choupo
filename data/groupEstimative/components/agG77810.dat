name        agG77810;
formula     C35H72O11;
CAS         71010-83-8;
InChIKey    GUAWLDJQYMMLCV-UHFFFAOYSA-N;
MW          668.95;      // g/mol [origin=calculated method=formula-sum]
Tc          6456.92;      // K   [origin=predictive method=joback]
Pc          6.241;      // bar [origin=predictive method=joback]
omega       -0.5266;      // -   [origin=predictive method=lee-kesler]
Tb          1863.26;      // K   [origin=predictive method=joback]
HvapTb      228312.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (70.209 3.41044 -0.0016108 1.747e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 28; } { group C; count 2; } { group OH; count 6; } { group CH2O; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 29; } { group C; count 2; } { group OH; count 6; } { group O; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[2,2-bis(hydroxymethyl)-3-oxidanyl-propoxy]methyl]-2-(hydroxymethyl)propane-1,3-diol;heptanoic acid;octadecanoic acid" "heptanoic acid; 2-[[3-hydroxy-2,2-bis(hydroxymethyl)propoxy]methyl]-2-(hydroxymethyl)propane-1,3-diol; octadecanoic acid" "heptanoic acid; 2-[[3-hydroxy-2,2-bis(hydroxymethyl)propoxy]methyl]-2-(hydroxymethyl)propane-1,3-diol; stearic acid" "dipentaerythritol mixed stearates and heptanoates" "dipentaerythritol, ester with enanthylic acid and stearic acid" "octadecanoic acid, mixed esters with dipentaerythritol and heptanoic acid" );
standardThermochemistry
{
    dHf_298   -2752610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     2079.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1573760.0
}
