/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dimethoxybenzamide  (C9H11NO3, CAS 17213-58-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dimethoxybenzamide;
formula     C9H11NO3;
CAS         17213-58-0;
InChIKey    YTLRWVNYANKXOW-UHFFFAOYSA-N;
MW          181.191;      // g/mol [origin=calculated method=formula-sum]
Tc          837.77;      // K   [origin=predictive method=joback]
Pc          34.807;      // bar [origin=predictive method=joback]
omega       0.8207;      // -   [origin=predictive method=lee-kesler]
Tb          613.40;      // K   [origin=predictive method=joback]
HvapTb      61435.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.25 0.56844 -0.00016562 -3.604e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 2; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzamide, 3,5-dimethoxy-" "am787" "p763" );
standardThermochemistry
{
    dHf_298   -358730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154420.0
}
