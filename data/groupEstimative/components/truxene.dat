/*--------------------------------*- Choupo -*-----------------------*\
  Component: truxene  (C27H18, CAS 548-35-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        truxene;
formula     C27H18;
CAS         548-35-6;
InChIKey    YGPLLMPPZRUGTJ-UHFFFAOYSA-N;
MW          342.441;      // g/mol [origin=calculated method=formula-sum]
Tc          1241.26;      // K   [origin=predictive method=joback]
Pc          19.458;      // bar [origin=predictive method=joback]
omega       1.0521;      // -   [origin=predictive method=lee-kesler]
Tb          972.53;      // K   [origin=predictive method=joback]
HvapTb      89730.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-180.7 2.367 -0.00213868 7.748e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 9; } { group ACCH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 12; } { group dC_ring; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( ".alpha.-truxene" "5h-tribenzo[a,f,k]trindene, 10,15-dihydro-" "truxen" "tribenzylenebenzene" "benzene, tribenzylene-" "10,15-dihydro-5h-tribenzo(a,f,k)triindene" "10,15-dihydro-5h-tribenzo[a,f,k]trindene" "5h-tribenzo[a,f,k]trindene,10,15-dihydro-" "5h-diindeno[1,2'-c]fluorene, 10,15-dihydro-" "heptacyclo[18.7.0.0^{2,10}.0^{3,8}.0^{11,19}.0^{12,17}.0^{21,26}]heptacosa-1(20),2(10),3,5,7,11(19),12,14,16,21,23,25-dodecaene" );
standardThermochemistry
{
    dHf_298   570130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=827040.0
}
