/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-diazabicyclo[3.3.3]undecane  (C9H18N2, CAS 283-58-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Diazabicyclo333Undecane;
formula     C9H18N2;
CAS         283-58-9;
InChIKey    UWUHOLGLQASSHA-UHFFFAOYSA-N;
MW          154.257;      // g/mol [origin=calculated method=formula-sum]
Tc          677.23;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.4530;      // -   [origin=predictive method=lee-kesler]
Tb          466.03;      // K   [origin=predictive method=joback]
HvapTb      40674.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-154.4 1.4326 -0.001103 3.36e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-diazabicyclo(3.3.3)undecane" "1,5-diazabicyclo[3.3.3]undecane(8ci,9ci)" );
gibbsFormation
{
    dHf_298   73770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=347080.0
    phase     gas;
}
