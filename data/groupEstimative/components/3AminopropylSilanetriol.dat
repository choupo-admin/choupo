/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-aminopropyl)silanetriol  (C3H11NO3Si, CAS 58160-99-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C3H11NO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3AminopropylSilanetriol;
formula     C3H11NO3Si;
CAS         58160-99-9;
InChIKey    JTXUAHIMULPXKY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          137.21;      // g/mol [origin=calculated method=formula-sum]
Tc          788.47;      // K   [origin=predictive method=joback]
Pc          59.814;      // bar [origin=predictive method=joback]
omega       1.8864;      // -   [origin=predictive method=lee-kesler]
Tb          618.71;      // K   [origin=predictive method=joback]
HvapTb      83244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.343 0.2465 0.0001408 -1.523e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 3; } { group CH2NH2; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group OH; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-tris(oxidanyl)silylpropan-1-amine" "3-aminopropylsilanetriol" "silanetriol, (3-aminopropyl)-" "silanetriol, 1-(3-aminopropyl)-" "hydrolyzed triethoxy-gamma-aminopropylsilane" "aminopropylsilanetriol" "3-trihydroxysilylpropan-1-amine" "p779" "silanetriol, (3-aminopropyl)-, homopolymer" );
gibbsFormation
{
    dHf_298   -639770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-474390.0
    phase     gas;
}
