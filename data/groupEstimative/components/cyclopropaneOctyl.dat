/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropane, octyl-  (C11H22, CAS 1472-09-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropaneOctyl;
formula     C11H22;
CAS         1472-09-9;
InChIKey    VFWTZFZJUAJMJB-UHFFFAOYSA-N;
MW          154.297;      // g/mol [origin=calculated method=formula-sum]
Tc          632.23;      // K   [origin=predictive method=joback]
Pc          21.755;      // bar [origin=predictive method=joback]
omega       0.5100;      // -   [origin=predictive method=lee-kesler]
Tb          458.02;      // K   [origin=predictive method=joback]
HvapTb      39993.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.353 1.19972 -0.0007948 2.19e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octylcyclopropane" "octane, 1-cyclopropyl-" );
gibbsFormation
{
    dHf_298   -197570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102490.0
    phase     gas;
}
