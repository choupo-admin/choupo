/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-5-vinylpyridine  (C8H9N, CAS 140-76-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl5Vinylpyridine;
formula     C8H9N;
CAS         140-76-1;
InChIKey    VJOWMORERYNYON-UHFFFAOYSA-N;
MW          119.167;      // g/mol [origin=calculated method=formula-sum]
Tc          693.04;      // K   [origin=predictive method=joback]
Pc          37.777;      // bar [origin=predictive method=joback]
omega       0.3616;      // -   [origin=predictive method=lee-kesler]
Tb          464.68;      // K   [origin=predictive method=joback]
HvapTb      41880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.92 0.63918 -0.00040772 1.038e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethenyl-2-methyl-pyridine" "5-ethenyl-2-methylpyridine" "2-picoline, 5-vinyl-" "pyridine, 5-ethenyl-2-methyl-" "2-methyl-5-vinyl-pyridine" "2-mvp" "pyridine, 2-methyl-5-vinyl-" "pyridine, 2-methyl-5-vinyl" "mvp" "5-vinyl-2-methylpyridine homopolymer" "pyridine, 5-ethenyl-2-methyl-, homopolymer" "poly(2-methyl-5-vinylpyridine)" );
gibbsFormation
{
    dHf_298   174830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=284150.0
    phase     gas;
}
