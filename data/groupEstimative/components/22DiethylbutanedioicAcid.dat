/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-diethylbutanedioic acid  (C8H14O4, CAS 5692-97-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DiethylbutanedioicAcid;
formula     C8H14O4;
CAS         5692-97-7;
InChIKey    WKRCUUPMCASSBN-UHFFFAOYSA-N;
MW          174.196;      // g/mol [origin=calculated method=formula-sum]
Tc          879.07;      // K   [origin=predictive method=joback]
Pc          31.245;      // bar [origin=predictive method=joback]
omega       1.1029;      // -   [origin=predictive method=lee-kesler]
Tb          670.43;      // K   [origin=predictive method=joback]
HvapTb      66434.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.657 0.99124 -0.0007284 2.119e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-diethylsuccinic acid" "butanedioic acid,2,2-diethyl-" "succinicacid, 2,2-diethyl- (6ci,7ci,8ci); 2,2-diethylsuccinic acid;2-ethyl-1,2-butanedicarboxylic acid" );
standardThermochemistry
{
    dHf_298   -917740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-668500.0
}
