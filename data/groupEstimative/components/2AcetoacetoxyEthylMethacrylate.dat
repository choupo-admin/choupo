/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(Acetoacetoxy)ethyl methacrylate  (C10H14O5, CAS 21282-97-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AcetoacetoxyEthylMethacrylate;
formula     C10H14O5;
CAS         21282-97-3;
InChIKey    IBDVWXAVKPRHCU-UHFFFAOYSA-N;
MW          214.217;      // g/mol [origin=calculated method=formula-sum]
Tc          784.27;      // K   [origin=predictive method=joback]
Pc          23.611;      // bar [origin=predictive method=joback]
omega       0.8844;      // -   [origin=predictive method=lee-kesler]
Tb          595.27;      // K   [origin=predictive method=joback]
HvapTb      58824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.293 0.79614 -0.0003375 3.76e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group CH3CO; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group CdO; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methylprop-2-enoyloxy)ethyl 3-oxobutanoate" "2-(Acetylacetoxy)ethyl methacrylate" "2-(Methacryloyloxy)ethyl acetoacetate" "2-(Methacryloyloxy)ethyl3-oxobutanoate" "2-hydroxyethyl methacrylate acetoacetate" "2-[(2-Methylprop-2-enoyl)oxy]ethyl 3-oxobutanoate" "3-Oxo-butyric acid 2-(2-methylacryloyloxy)ethyl ester" "aaem" "acetoacetic acid, 2-hydroxyethyl ester methacrylate" "Butanoic acid, 3-oxo-, 2-[(2-methyl-1-oxo-2-propen-1-yl)oxy]ethyl ester" "Butanoic acid, 3-oxo-, 2-[(2-methyl-1-oxo-2-propenyl)oxy]ethyl ester" "eastman aaem" );
gibbsFormation
{
    dHf_298   -881230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     666.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-637050.0
    phase     gas;
}
