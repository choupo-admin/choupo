/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-hexadecene, 1,1-diethoxy-14-methyl-, (8z)-  (C21H42O2, CAS 71566-69-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Hexadecene11Diethoxy14Methyl8z;
formula     C21H42O2;
CAS         71566-69-3;
InChIKey    NJUSQJGBBUENCQ-CSNYQSHPSA-N;
MW          326.565;      // g/mol [origin=calculated method=formula-sum]
Tc          900.09;      // K   [origin=predictive method=joback]
Pc          9.766;      // bar [origin=predictive method=joback]
omega       0.8419;      // -   [origin=predictive method=lee-kesler]
Tb          728.20;      // K   [origin=predictive method=joback]
HvapTb      66342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.253 1.90428 -0.0009868 1.755e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 11; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 13; } { group CH; count 2; } { group dCH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e,14r)-1,1-diethoxy-14-methyl-hexadec-8-ene" "14-methyl-8-hexadecenal diethyl acetal, (z)-" "(e,14r)-1,1-diethoxy-14-methylhexadec-8-ene" );
standardThermochemistry
{
    dHf_298   -634550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     970.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-8720.0
}
