/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropyldiphenylmethane  (C16H18, CAS 886-58-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Isopropyldiphenylmethane;
formula     C16H18;
CAS         886-58-8;
InChIKey    YSJOJXAZBPBDJM-UHFFFAOYSA-N;
MW          210.32;      // g/mol [origin=calculated method=formula-sum]
Tc          859.61;      // K   [origin=predictive method=joback]
Pc          22.697;      // bar [origin=predictive method=joback]
omega       0.5392;      // -   [origin=predictive method=lee-kesler]
Tb          623.58;      // K   [origin=predictive method=joback]
HvapTb      56036.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.849 1.31244 -0.00084516 2.048e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(phenylmethyl)-4-propan-2-yl-benzene" "1-benzyl-4-propan-2-ylbenzene" "benzene, 1-(1-methylethyl)-4-(phenylmethyl)-" );
gibbsFormation
{
    dHf_298   82740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=296590.0
    phase     gas;
}
