/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenyl-1-butanol  (C10H14O, CAS 2722-36-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenyl1Butanol;
formula     C10H14O;
CAS         2722-36-3;
InChIKey    SQGBBDFDRHDJCJ-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          743.27;      // K   [origin=predictive method=joback]
Pc          32.765;      // bar [origin=predictive method=joback]
omega       0.8242;      // -   [origin=predictive method=lee-kesler]
Tb          546.82;      // K   [origin=predictive method=joback]
HvapTb      56421.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.498 0.91482 -0.000585 1.426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylbutan-1-ol" "benzenepropanol, .gamma.-methyl-" "agn-pc-00fafc" "benzenepropanol, g-methyl-" "benzenepropanol, gamma-methyl-" "3-deuterio-3-phenylbutan-1-ol" "(r)-3-phenyl-butan-1-ol" );
standardThermochemistry
{
    dHf_298   -170710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6470.0
}
