/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-(-)-2-phenylbutyric acid  (C10H12O2, CAS 938-79-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r2PhenylbutyricAcid;
formula     C10H12O2;
CAS         938-79-4;
InChIKey    OFJWFSNDPCAWDK-SECBINFHSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          824.85;      // K   [origin=predictive method=joback]
Pc          32.653;      // bar [origin=predictive method=joback]
omega       0.7427;      // -   [origin=predictive method=lee-kesler]
Tb          600.15;      // K   [origin=predictive method=joback]
HvapTb      56906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.189 0.93162 -0.0006272 1.608e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-phenylbutanoic acid" "(2r)-2-phenyl-mutanoic acid" );
standardThermochemistry
{
    dHf_298   -368750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200620.0
}
