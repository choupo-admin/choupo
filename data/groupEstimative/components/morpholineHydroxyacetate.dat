/*--------------------------------*- Choupo -*-----------------------*\
  Component: morpholine hydroxyacetate  (C6H13NO4, CAS 67785-98-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        morpholineHydroxyacetate;
formula     C6H13NO4;
CAS         67785-98-2;
InChIKey    RIUDGYLEEGUDAZ-UHFFFAOYSA-N;
MW          163.173;      // g/mol [origin=calculated method=formula-sum]
Tc          894.36;      // K   [origin=predictive method=joback]
Pc          47.760;      // bar [origin=predictive method=joback]
omega       1.2715;      // -   [origin=predictive method=lee-kesler]
Tb          675.69;      // K   [origin=predictive method=joback]
HvapTb      75093.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.841 0.5846 -5.27e-05 -1.23e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group COOH; count 1; } { group Morpholine; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group OH; count 1; } { group O_ring; count 1; } { group COOH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "morpholine;2-oxidanylethanoic acid" "acetic acid, hydroxy-, compd. with morpholine (1:1)" "acetic acid, 2-hydroxy-, compd. with morpholine (1:1)" "2-hydroxyacetic acid; morpholine" "hydroxyacetic acid - morpholine (1:1)" );
standardThermochemistry
{
    dHf_298   -800820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-552100.0
}
