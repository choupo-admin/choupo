/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentanedioic acid, di-c9-11-branched and linear alkyl esters  (C23H44O4, CAS 72828-54-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentanedioicAcidDiC911BranchedAndLinearAlkylEsters;
formula     C23H44O4;
CAS         72828-54-7;
InChIKey    HIRZAKOZLHMWTA-NHCUHLMSSA-N;
MW          384.601;      // g/mol [origin=calculated method=formula-sum]
Tc          1030.34;      // K   [origin=predictive method=joback]
Pc          8.651;      // bar [origin=predictive method=joback]
omega       0.8339;      // -   [origin=predictive method=lee-kesler]
Tb          841.40;      // K   [origin=predictive method=joback]
HvapTb      80830.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.435 2.09108 -0.0010446 1.473e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 13; } { group CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 15; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o5-[(3r)-nonan-3-yl] o1-[(2r)-2-propylhexyl] pentanedioate" "5-o-[(3r)-nonan-3-yl] 1-o-[(2r)-2-propylhexyl] pentanedioate" );
standardThermochemistry
{
    dHf_298   -1163170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1135.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-482840.0
}
