/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-benzylaniline  (C13H13N, CAS 28059-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Benzylaniline;
formula     C13H13N;
CAS         28059-64-5;
InChIKey    DWOBGCPUQNFAFB-UHFFFAOYSA-N;
MW          183.254;      // g/mol [origin=calculated method=formula-sum]
Tc          880.99;      // K   [origin=predictive method=joback]
Pc          32.210;      // bar [origin=predictive method=joback]
omega       0.6036;      // -   [origin=predictive method=lee-kesler]
Tb          627.91;      // K   [origin=predictive method=joback]
HvapTb      60387.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.949 1.0834 -0.00072216 1.806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(phenylmethyl)aniline" "o-aminodiphenylmethane" "2-aminodiphenylmethane" "benzenamine, 2-(phenylmethyl)-" "2-benzylbenzenamine" "2-benzylphenylamine" "2-(phenylmethyl)benzenamine" "benzenamine,2-(phenylmethyl)-" "o700" );
standardThermochemistry
{
    dHf_298   183730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=340220.0
}
