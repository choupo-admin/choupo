/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-bromovinyl)benzene  (C8H7Br, CAS 98-81-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1BromovinylBenzene;
formula     C8H7Br;
CAS         98-81-7;
InChIKey    SRXJYTZCORKVNA-UHFFFAOYSA-N;
MW          183.048;      // g/mol [origin=calculated method=formula-sum]
Tc          710.90;      // K   [origin=predictive method=joback]
Pc          42.220;      // bar [origin=predictive method=joback]
omega       0.3609;      // -   [origin=predictive method=lee-kesler]
Tb          472.04;      // K   [origin=predictive method=joback]
HvapTb      41523.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.78 0.703 -0.0005392 1.628e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylethenylbenzene" "alpha-bromostyrene" "benzene, (1-bromoethenyl)-" "1-bromostyrene" "1-phenylvinyl bromide" "styrene, alpha-bromo-" "styrene, .alpha.-bromo-" "alpha-bromostyrol [russian]" "alpha-bromostyrol" "1-bromoethenylbenzene" "(1-bromovinyl)benzene," );
standardThermochemistry
{
    dHf_298   170050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222500.0
}
