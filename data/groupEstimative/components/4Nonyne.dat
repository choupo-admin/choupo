/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-nonyne  (C9H16, CAS 20184-91-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Nonyne;
formula     C9H16;
CAS         20184-91-2;
InChIKey    RAYTXPDVKZFUEI-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          600.57;      // K   [origin=predictive method=joback]
Pc          27.070;      // bar [origin=predictive method=joback]
omega       0.3597;      // -   [origin=predictive method=lee-kesler]
Tb          414.52;      // K   [origin=predictive method=joback]
HvapTb      37780.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.265 0.70904 -0.00037366 7.488e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "non-4-yne" "4-c9h16" "butylpropylacetylene" "4-c9h16;4-nonyne;n-butyl-n-propylacetylene;4-nonyne, 98+%;butylpropylacetylene" );
gibbsFormation
{
    dHf_298   43210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=227700.0
    phase     gas;
}
