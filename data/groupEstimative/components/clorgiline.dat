/*--------------------------------*- Choupo -*-----------------------*\
  Component: clorgiline  (C13H15Cl2NO, CAS 17780-72-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        clorgiline;
formula     C13H15Cl2NO;
CAS         17780-72-2;
InChIKey    BTFHLQRNAMSNLC-UHFFFAOYSA-N;
MW          272.169;      // g/mol [origin=calculated method=formula-sum]
Tc          849.10;      // K   [origin=predictive method=joback]
Pc          22.461;      // bar [origin=predictive method=joback]
omega       0.7195;      // -   [origin=predictive method=lee-kesler]
Tb          633.52;      // K   [origin=predictive method=joback]
HvapTb      61213.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.134 1.02132 -0.00061885 1.3819e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 3; } { group AC; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } { group ACCl; count 2; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2,4-bis(chloranyl)phenoxy]-n-methyl-n-prop-2-ynyl-propan-1-amine" "clorgyline" "chlorgyline" "clorgilinum" "clorgilin" "clorgilina" "clorgilinum [inn-latin]" "clorgiline (inn)" "clorgiline [inn]" "n-methyl-n-propargyl-3-(2,4-dichlorophenoxy)propylamine" "n-(3-(2,4-dichlorophenoxy)propyl)-n-methyl-2-propynylamine" "2-propynylamine, n-(3-(2,4-dichlorophenoxy)propyl)-n-methyl-" );
gibbsFormation
{
    dHf_298   97670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=356720.0
    phase     gas;
}
