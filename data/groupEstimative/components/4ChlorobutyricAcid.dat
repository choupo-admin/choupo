/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorobutyric acid  (C4H7ClO2, CAS 627-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorobutyricAcid;
formula     C4H7ClO2;
CAS         627-00-9;
InChIKey    IPLKGJHGWCVSOG-UHFFFAOYSA-N;
MW          122.548;      // g/mol [origin=calculated method=formula-sum]
Tc          673.60;      // K   [origin=predictive method=joback]
Pc          41.623;      // bar [origin=predictive method=joback]
omega       0.6451;      // -   [origin=predictive method=lee-kesler]
Tb          474.06;      // K   [origin=predictive method=joback]
HvapTb      46047.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.743 0.4414 -0.0002868 7.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group COOH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranylbutanoic acid" "butanoic acid, 4-chloro-" "4-chlorobutanoic acid" "butyric acid, 4-chloro-" "gamma-chlorobutyric acid" "gammachlorobutyric acid" ".gamma.-chlorobutyric acid" "4-chloro-butyric acid" "4-chloro-n-butyric acid" "butyric acid, 4-chloro- (8ci)" );
gibbsFormation
{
    dHf_298   -491900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-373040.0
    phase     gas;
}
