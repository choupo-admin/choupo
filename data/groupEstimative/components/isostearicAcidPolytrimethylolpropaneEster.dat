/*--------------------------------*- Choupo -*-----------------------*\
  Component: isostearic acid, polytrimethylolpropane ester  (C24H48O4, CAS 70913-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isostearicAcidPolytrimethylolpropaneEster;
formula     C24H48O4;
CAS         70913-84-7;
InChIKey    GHJJFOYNDRLLFV-UHFFFAOYSA-N;
MW          400.644;      // g/mol [origin=calculated method=formula-sum]
Tc          1230.62;      // K   [origin=predictive method=joback]
Pc          9.149;      // bar [origin=predictive method=joback]
omega       0.7075;      // -   [origin=predictive method=lee-kesler]
Tb          987.63;      // K   [origin=predictive method=joback]
HvapTb      108099.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.092 2.42876 -0.001423 3.083e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 17; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 18; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)butyl 16-methylheptadecanoate" );
gibbsFormation
{
    dHf_298   -1174460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1195.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-432410.0
    phase     gas;
}
