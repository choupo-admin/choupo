/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,5,5-tetramethyl-2,5-disilafuran  (C6H16OSi2, CAS 7418-20-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H16OSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2255Tetramethyl25Disilafuran;
formula     C6H16OSi2;
CAS         7418-20-4;
InChIKey    ZJWXCSUSULCHCK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          160.363;      // g/mol [origin=calculated method=formula-sum]
Tc          573.00;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       0.1960;      // -   [origin=predictive method=lee-kesler]
Tb          378.04;      // K   [origin=predictive method=joback]
HvapTb      34270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.21 0.33588 0.0002653 -2.554e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,5,5-tetramethyl-1,2,5-oxadisilolane" "2,2,5,5-tetramethyl-2,5-disila-1-oxacyclopentane" "1-oxa-2,5-disilacyclopentane, 2,2,5,5-tetramethyl-" "2,2,5,5-tetramethyl-1-oxa-2,5-disilacyclopentane" "1-oxa-2,5-disilacyclopentane,2,2,5,5-tetramethyl-" "1,1,3,3-tetramethyl-2-oxa-1,3-disilacyclopentane;2,2,5,5-tetramethyl-1-oxa-2,5-disilacyclopentane;2,2,5,5-tetramethyl-2,5-disila-1-oxacyclopentane;" );
standardThermochemistry
{
    dHf_298   -429270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     543.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-227540.0
}
