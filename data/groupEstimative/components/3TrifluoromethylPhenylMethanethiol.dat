/*--------------------------------*- Choupo -*-----------------------*\
  Component: [3-(trifluoromethyl)phenyl]methanethiol  (C8H7F3S, CAS 25697-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3TrifluoromethylPhenylMethanethiol;
formula     C8H7F3S;
CAS         25697-55-6;
InChIKey    CQIQWIMXCPTQPJ-UHFFFAOYSA-N;
MW          192.198;      // g/mol [origin=calculated method=formula-sum]
Tc          685.81;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       0.4333;      // -   [origin=predictive method=lee-kesler]
Tb          471.74;      // K   [origin=predictive method=joback]
HvapTb      39330.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.299 0.8139 -0.00061896 1.789e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2SH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(trifluoromethyl)benzylthiol" "3-trifluoromethylbenzyl mercaptan" "3-(trifluoromethyl)benzyl mercaptan" "m-trifluoromethylbenzyl mercaptan" "3-(trifluoromethyl)phenylmethanethiol" "[3-(trifluoromethyl)phenyl]methane-1-thiol" "3-(trifluoromethyl)benzyl thiol" "3-(trifluoromethylbenzyl)mercaptan" "3-(thiomethyl)benzotrifluoride, [3-(trifluoromethyl)phenyl]methanethiol" "methanethiol,(a,a,a-trifluoro-m-tolyl)- (8ci);1-(mercaptomethyl)-3-trifluoromethylbenzene;3-(trifluoromethyl)benzenemethanethiol;3-(trifluoromethyl)toluene-a-thiol;[3-(trifluoromethyl)phenyl]methanethiol;m-(trifluoromethyl)benzyl mercaptan;" );
gibbsFormation
{
    dHf_298   -541990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-432940.0
    phase     gas;
}
