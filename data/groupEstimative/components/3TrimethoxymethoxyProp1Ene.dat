/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(trimethoxymethoxy)prop-1-ene  (C7H14O4, CAS 154016-62-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3TrimethoxymethoxyProp1Ene;
formula     C7H14O4;
CAS         154016-62-3;
InChIKey    DJWWKGDEPXTXNR-UHFFFAOYSA-N;
MW          162.185;      // g/mol [origin=calculated method=formula-sum]
Tc          621.73;      // K   [origin=predictive method=joback]
Pc          27.789;      // bar [origin=predictive method=joback]
omega       0.5315;      // -   [origin=predictive method=lee-kesler]
Tb          442.89;      // K   [origin=predictive method=joback]
HvapTb      38850.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.061 0.52186 -0.0001077 -5.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group CH2=CH; count 1; } { group CH3O; count 3; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "allyl (trimethoxymethyl) ether" "trimethoxymethyl allyl ether" "1-propene, 3-(trimethoxymethoxy)-" );
gibbsFormation
{
    dHf_298   -600010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-321260.0
    phase     gas;
}
