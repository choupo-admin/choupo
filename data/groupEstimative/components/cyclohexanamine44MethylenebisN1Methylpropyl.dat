/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanamine, 4,4'-methylenebis[n-(1-methylpropyl)-  (C21H42N2, CAS 154279-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanamine44MethylenebisN1Methylpropyl;
formula     C21H42N2;
CAS         154279-60-4;
InChIKey    PICLBAFTFYTURY-UHFFFAOYSA-N;
MW          322.581;      // g/mol [origin=calculated method=formula-sum]
Tc          1018.42;      // K   [origin=predictive method=joback]
Pc          12.329;      // bar [origin=predictive method=joback]
omega       0.8518;      // -   [origin=predictive method=lee-kesler]
Tb          809.30;      // K   [origin=predictive method=joback]
HvapTb      74676.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.317 2.35428 -0.0012734 2.215e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 11; } { group CH; count 4; } { group CHNH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-butan-2-yl-4-[[4-(butan-2-ylamino)cyclohexyl]methyl]cyclohexan-1-amine" "cyclohexanamine, 4,4'-methylenebis(n-(1-methylpropyl)-" "agn-pc-03h6gq" );
standardThermochemistry
{
    dHf_298   -312430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     890.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=333320.0
}
