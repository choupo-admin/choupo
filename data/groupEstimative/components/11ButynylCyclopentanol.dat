/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(1-butynyl)cyclopentanol  (C9H14O, CAS 155879-96-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11ButynylCyclopentanol;
formula     C9H14O;
CAS         155879-96-2;
InChIKey    MUYNZFHFJRJANX-UHFFFAOYSA-N;
MW          138.21;      // g/mol [origin=calculated method=formula-sum]
Tc          735.78;      // K   [origin=predictive method=joback]
Pc          38.819;      // bar [origin=predictive method=joback]
omega       0.6647;      // -   [origin=predictive method=lee-kesler]
Tb          522.22;      // K   [origin=predictive method=joback]
HvapTb      53565.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.919 1.16662 -0.00106406 4.2218e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group tC; count 2; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-but-1-ynylcyclopentan-1-ol" "agn-pc-01nprw" "cyclopentanol,1-(1-butyn-1-yl)-" "cyclopentanol,1-(1-butynyl)- (9ci);1-(1-butynyl)cyclopentanol;" );
gibbsFormation
{
    dHf_298   -33300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=121940.0
    phase     gas;
}
