/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisphenol fluorenone  (C25H18O2, CAS 3236-71-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisphenolFluorenone;
formula     C25H18O2;
CAS         3236-71-3;
InChIKey    YWFPGFJLYRKYJZ-UHFFFAOYSA-N;
MW          350.417;      // g/mol [origin=calculated method=formula-sum]
Tc          1338.92;      // K   [origin=predictive method=joback]
Pc          27.672;      // bar [origin=predictive method=joback]
omega       1.2948;      // -   [origin=predictive method=lee-kesler]
Tb          1047.96;      // K   [origin=predictive method=joback]
HvapTb      106118.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-234.69 2.7154 -0.00268524 1.0618e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 16; } { group AC; count 6; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dCH_ring; count 16; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[9-(4-hydroxyphenyl)fluoren-9-yl]phenol" "9,9-bis(4-hydroxyphenyl)fluorene" "4,4'-(9-fluorenylidene)diphenol" "4,4'-(9h-fluorene-9,9-diyl)diphenol" "fluornen-9-bisphenol" "phenol, 4,4'-(9h-fluoren-9-ylidene)bis-" "fluorene-9-bisphenol" "g00028-watson-int" "4,4'(9-fluorenylidene)diphenol" "4,4-(9-fluorenylidene)diphenol" "4,4-(9h-fluorene-9,9-diyl)diphenol" "h164" );
gibbsFormation
{
    dHf_298   109590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     684.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=360220.0
    phase     gas;
}
