/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-isobutyldecalin  (C14H26, CAS 92369-83-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaIsobutyldecalin;
formula     C14H26;
CAS         92369-83-0;
InChIKey    UGISRBVUOVJMIH-UHFFFAOYSA-N;
MW          194.362;      // g/mol [origin=calculated method=formula-sum]
Tc          758.29;      // K   [origin=predictive method=joback]
Pc          20.163;      // bar [origin=predictive method=joback]
omega       0.4318;      // -   [origin=predictive method=lee-kesler]
Tb          545.37;      // K   [origin=predictive method=joback]
HvapTb      46575.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.549 1.57664 -0.0009404 2.057e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methylpropyl)-1,2,3,4,4a,5,6,7,8,8a-decahydronaphthalene" ".alpha.-isobutyldecalin" "1-(2-methylpropyl)decahydronaphthalene" );
gibbsFormation
{
    dHf_298   -236950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=129950.0
    phase     gas;
}
