/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethoxytoluene  (C9H12O2, CAS 24599-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethoxytoluene;
formula     C9H12O2;
CAS         24599-58-4;
InChIKey    IQISOVKPFBLQIQ-UHFFFAOYSA-N;
MW          152.193;      // g/mol [origin=calculated method=formula-sum]
Tc          693.91;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.4901;      // -   [origin=predictive method=lee-kesler]
Tb          487.00;      // K   [origin=predictive method=joback]
HvapTb      44048.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.4 0.53456 -0.00014092 -3.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethoxy-2-methyl-benzene" "1,4-dimethoxy-2-methylbenzene" "toluene, 2,5-dimethoxy-" "benzene, 1,4-dimethoxy-2-methyl-" "methyl hydroquinone dimethyl ester" "2-methylhydroquinone dimethyl ether" "benzene,4-dimethoxy-2-methyl-" "2,5-dimethoxy-1-methylbenzene" "1,4-dimethoxy-2-methyl-benzen;1,4-dimethoxy-2-methylbenzene" );
gibbsFormation
{
    dHf_298   -279940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-91950.0
    phase     gas;
}
