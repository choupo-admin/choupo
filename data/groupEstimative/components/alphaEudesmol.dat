/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-eudesmol  (C15H26O, CAS 473-16-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaEudesmol;
formula     C15H26O;
CAS         473-16-5;
InChIKey    FCSRUSQUAVXUKK-VNHYZAJKSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          874.33;      // K   [origin=predictive method=joback]
Pc          21.553;      // bar [origin=predictive method=joback]
omega       0.8082;      // -   [origin=predictive method=lee-kesler]
Tb          662.02;      // K   [origin=predictive method=joback]
HvapTb      64375.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-172.87 2.00198 -0.00164664 5.771e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(2r,4ar,8ar)-4a,8-dimethyl-2,3,4,5,6,8a-hexahydro-1h-naphthalen-2-yl]propan-2-ol" "2-[(2r,4ar,8ar)-4a,8-dimethyl-1,2,3,4,4a,5,6,8a-octahydronaphthalen-2-yl]propan-2-ol" "(2r,4ar,8ar)-1,2,3,4,4a,5,6,8a-octahydro-alpha,alpha,4a,8-tetramethyl-2-naphthalenemethanol" "2-naphthalenemethanol, 1,2,3,4,4a,5,6,8a-octahydro-alpha,alpha,4a,8-tetramethyl-, (2r,4ar,8ar)-" );
gibbsFormation
{
    dHf_298   -351740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21670.0
    phase     gas;
}
