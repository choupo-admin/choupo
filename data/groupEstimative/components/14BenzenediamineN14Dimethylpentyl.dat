/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-benzenediamine, n-(1,4-dimethylpentyl)-  (C13H22N2, CAS 63302-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BenzenediamineN14Dimethylpentyl;
formula     C13H22N2;
CAS         63302-43-2;
InChIKey    MDDXGELKFXXQDP-UHFFFAOYSA-N;
MW          206.333;      // g/mol [origin=calculated method=formula-sum]
Tc          864.95;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.8058;      // -   [origin=predictive method=lee-kesler]
Tb          650.52;      // K   [origin=predictive method=joback]
HvapTb      63771.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.618 1.25036 -0.00074596 1.646e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CHNH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n4-(5-methylhexan-2-yl)benzene-1,4-diamine" "1,4-benzenediamine, n1-(1,4-dimethylpentyl)-" "4-n-(5-methylhexan-2-yl)benzene-1,4-diamine" );
standardThermochemistry
{
    dHf_298   -9890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=312320.0
}
