/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-chloropropyl)cyclohexane  (C9H17Cl, CAS 1124-62-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ChloropropylCyclohexane;
formula     C9H17Cl;
CAS         1124-62-5;
InChIKey    QEISABAAOUXQNG-UHFFFAOYSA-N;
MW          160.685;      // g/mol [origin=calculated method=formula-sum]
Tc          668.23;      // K   [origin=predictive method=joback]
Pc          27.297;      // bar [origin=predictive method=joback]
omega       0.3759;      // -   [origin=predictive method=lee-kesler]
Tb          462.50;      // K   [origin=predictive method=joback]
HvapTb      40442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.007 0.9877 -0.0005672 1.145e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylpropylcyclohexane" "3-chloropropylcyclohexane" "(3-chloro-propyl)-cyclohexane" "1-chloro-3-cyclohexylpropane" );
gibbsFormation
{
    dHf_298   -190510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37420.0
    phase     gas;
}
