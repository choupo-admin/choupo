/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloeicosane  (C20H40, CAS 296-56-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloeicosane;
formula     C20H40;
CAS         296-56-0;
InChIKey    ZBLGFUHEYYJSSE-UHFFFAOYSA-N;
MW          280.54;      // g/mol [origin=calculated method=formula-sum]
Tc          1005.70;      // K   [origin=predictive method=joback]
Pc          15.379;      // bar [origin=predictive method=joback]
omega       0.4293;      // -   [origin=predictive method=lee-kesler]
Tb          741.20;      // K   [origin=predictive method=joback]
HvapTb      63260.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-158.53 1.918 -0.000551 -1.54e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 20; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 20; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloicosane" );
standardThermochemistry
{
    dHf_298   -467710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1225.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19720.0
}
