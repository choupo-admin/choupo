/*--------------------------------*- Choupo -*-----------------------*\
  Component: 15-phenylnonacosane  (C35H64, CAS 56247-97-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Phenylnonacosane;
formula     C35H64;
CAS         56247-97-3;
InChIKey    YNXOIJANZCYQIZ-UHFFFAOYSA-N;
MW          484.897;      // g/mol [origin=calculated method=formula-sum]
Tc          1275.38;      // K   [origin=predictive method=joback]
Pc          5.565;      // bar [origin=predictive method=joback]
omega       0.3201;      // -   [origin=predictive method=lee-kesler]
Tb          1026.64;      // K   [origin=predictive method=joback]
HvapTb      95392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.514 3.25584 -0.0019146 4.303e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 26; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 26; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonacosan-15-ylbenzene" "benzene, (1-tetradecylpentadecyl)-" "benzene,(1-tetradecylpentadecyl)-" );
gibbsFormation
{
    dHf_298   -534480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1403.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=353790.0
    phase     gas;
}
