/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethoxytriethylsilane  (C8H20OSi, CAS 597-67-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H20OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethoxytriethylsilane;
formula     C8H20OSi;
CAS         597-67-1;
InChIKey    DFJDZTPFNSXNAX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          160.332;      // g/mol [origin=calculated method=formula-sum]
Tc          576.17;      // K   [origin=predictive method=joback]
Pc          22.187;      // bar [origin=predictive method=joback]
omega       0.3774;      // -   [origin=predictive method=lee-kesler]
Tb          406.46;      // K   [origin=predictive method=joback]
HvapTb      36106.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.934 0.49448 0.0001144 -1.88e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethoxy(triethyl)silane" "silane, ethoxytriethyl-" "triethylethoxysilane" );
gibbsFormation
{
    dHf_298   -452290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-193280.0
    phase     gas;
}
