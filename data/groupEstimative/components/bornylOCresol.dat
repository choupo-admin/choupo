/*--------------------------------*- Choupo -*-----------------------*\
  Component: bornyl-o-cresol  (C17H24O, CAS 71965-25-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bornylOCresol;
formula     C17H24O;
CAS         71965-25-8;
InChIKey    IPMPHMRYTZWESP-JJRVBVJISA-N;
MW          244.378;      // g/mol [origin=calculated method=formula-sum]
Tc          955.31;      // K   [origin=predictive method=joback]
Pc          23.203;      // bar [origin=predictive method=joback]
omega       0.7070;      // -   [origin=predictive method=lee-kesler]
Tb          709.73;      // K   [origin=predictive method=joback]
HvapTb      66466.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-234.8 2.45808 -0.00246992 1.0331e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-4-[(1s,3r,4r)-4,7,7-trimethyl-3-bicyclo[2.2.1]heptanyl]phenol" "phenol, 2-methyl(1,7,7-trimethylbicyclo(2.2.1)heptyl)-" );
gibbsFormation
{
    dHf_298   -217220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=123420.0
    phase     gas;
}
