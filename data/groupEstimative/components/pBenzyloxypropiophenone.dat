/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-benzyloxypropiophenone  (C16H16O2, CAS 4495-66-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pBenzyloxypropiophenone;
formula     C16H16O2;
CAS         4495-66-3;
InChIKey    IKFGSOJYHVTNDV-UHFFFAOYSA-N;
MW          240.302;      // g/mol [origin=calculated method=formula-sum]
Tc          934.15;      // K   [origin=predictive method=joback]
Pc          23.542;      // bar [origin=predictive method=joback]
omega       0.7824;      // -   [origin=predictive method=lee-kesler]
Tb          700.31;      // K   [origin=predictive method=joback]
HvapTb      65580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.308 1.21532 -0.00071226 1.4146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 9; } { group AC; count 3; } { group CH2CO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-phenylmethoxyphenyl)propan-1-one" "1-(4-(benzyloxy)phenyl)propan-1-one" "4-benzyloxy-propiophenone" "1-[4-(benzyloxy)phenyl]-1-propanone" "1-[4-(benzyloxy)phenyl]propan-1-one" "1-propanone, 1-[4-(phenylmethoxy)phenyl]-" "1-[4-(phenylmethoxy)phenyl]propan-1-one" "4'-(benzyloxy)propiophenone" );
standardThermochemistry
{
    dHf_298   -156780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     598.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65110.0
}
