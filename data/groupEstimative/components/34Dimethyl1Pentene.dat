/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethyl-1-pentene  (C7H14, CAS 7385-78-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dimethyl1Pentene;
formula     C7H14;
CAS         7385-78-6;
InChIKey    WFHXQNMTMDKVJG-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          530.72;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       0.2713;      // -   [origin=predictive method=lee-kesler]
Tb          355.56;      // K   [origin=predictive method=joback]
HvapTb      29730.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.83 0.66066 -0.0003863 8.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 2; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 2; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dimethylpent-1-ene" "1-pentene, 3,4-dimethyl-" "agn-pc-0cpr1t" "1-pentene,3,4-dimethyl-" "1-pentene, 3,4-dimethyl- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -72940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91020.0
}
