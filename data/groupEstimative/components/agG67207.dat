/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-67207  (C24H51NO3, CAS 68929-16-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG67207;
formula     C24H51NO3;
CAS         68929-16-8;
InChIKey    MRJWKJUSWPVRHF-UHFFFAOYSA-N;
MW          401.676;      // g/mol [origin=calculated method=formula-sum]
Tc          1242.29;      // K   [origin=predictive method=joback]
Pc          8.495;      // bar [origin=predictive method=joback]
omega       0.6762;      // -   [origin=predictive method=lee-kesler]
Tb          1000.25;      // K   [origin=predictive method=joback]
HvapTb      105198.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.09 2.28636 -0.0010826 1.324e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 19; } { group OH; count 1; } { group CH2N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 20; } { group OH; count 1; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethanol;octadecanoic acid" "octadecanoic acid compd. with 2-(diethylamino)ethanol (1:1)" "octadecanoic acid, compd. with 2-(diethylamino)ethanol (1:1)" "octadecanoic acid, compd. with 2-(n,n-diethylamino)ethanol (1:1)" );
standardThermochemistry
{
    dHf_298   -1085280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1318.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-323510.0
}
