/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyl-tert-butylamine  (C5H13N, CAS 14610-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylTertButylamine;
formula     C5H13N;
CAS         14610-37-8;
InChIKey    ZQGJEUVBUVKZKS-UHFFFAOYSA-N;
MW          87.166;      // g/mol [origin=calculated method=formula-sum]
Tc          542.94;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       0.3093;      // -   [origin=predictive method=lee-kesler]
Tb          360.94;      // K   [origin=predictive method=joback]
HvapTb      31864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.34 0.68088 -0.0004686 1.307e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,2-dimethylpropan-2-amine" "n-tert-butylmethylamine" "2-propanamine, n,2-dimethyl-" "n-methyl-tert.-butylamine" "methyl-tert-butylamine" "tert-butyl(methyl)amine" "agn-pc-0d8inn" );
gibbsFormation
{
    dHf_298   -101810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83450.0
    phase     gas;
}
