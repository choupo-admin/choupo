/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-2-adamantanol  (C11H18O, CAS 702-98-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl2Adamantanol;
formula     C11H18O;
CAS         702-98-7;
InChIKey    JKOZWMQUOWYZAB-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          763.51;      // K   [origin=predictive method=joback]
Pc          31.280;      // bar [origin=predictive method=joback]
omega       0.7624;      // -   [origin=predictive method=lee-kesler]
Tb          558.85;      // K   [origin=predictive method=joback]
HvapTb      54901.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-195.78 1.76482 -0.001641 6.391e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 4; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 4; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyladamantan-2-ol" "2-methyl-2-adamantol" "tricyclo(3.3.1.1(3,7))decan-2-ol, 2-methyl-" "2-adamantanol, 2-methyl-" "ambap702-98-7" "2-hydroxy-2-methyladamantane" "tricyclo[3.3.1.13, 2-methyl-" "(1r,3r,5r,7r)-2-methyladamantan-2-ol" "k186" "2-methyltricyclo[3.3.1.1~3,7~]decan-2-ol" "tricyclo[3.3.1.13,7]decan-2-ol, 2-methyl-" "tricyclo[3.3.1.13,7]decan-2-ol, 2-methyl-;2-methyladamantan-2-ol;2-adamantanol, 2-methyl-;" );
standardThermochemistry
{
    dHf_298   -235800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54160.0
}
