/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetamidoethyl acetate  (C6H11NO3, CAS 16180-96-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AcetamidoethylAcetate;
formula     C6H11NO3;
CAS         16180-96-4;
InChIKey    SKPWGBMKZNVXFF-UHFFFAOYSA-N;
MW          145.158;      // g/mol [origin=calculated method=formula-sum]
Tc          687.27;      // K   [origin=predictive method=joback]
Pc          34.079;      // bar [origin=predictive method=joback]
omega       0.7519;      // -   [origin=predictive method=lee-kesler]
Tb          499.14;      // K   [origin=predictive method=joback]
HvapTb      49539.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.992 0.56724 -0.0002379 4.56e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH3COO; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CdO; count 1; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-acetamidoethyl ethanoate" "2-(acetylamino)ethyl acetate" "acetamide, n-(2-(acetyloxy)ethyl)-" "acetamide, n-[2-(acetyloxy)ethyl]-" );
gibbsFormation
{
    dHf_298   -543560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-350260.0
    phase     gas;
}
