/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonadecyl bromide  (C19H39Br, CAS 4434-66-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonadecylBromide;
formula     C19H39Br;
CAS         4434-66-6;
InChIKey    GWESGLGUMMNXDU-UHFFFAOYSA-N;
MW          347.425;      // g/mol [origin=calculated method=formula-sum]
Tc          871.67;      // K   [origin=predictive method=joback]
Pc          11.314;      // bar [origin=predictive method=joback]
omega       0.8958;      // -   [origin=predictive method=lee-kesler]
Tb          700.48;      // K   [origin=predictive method=joback]
HvapTb      64323.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.192 1.84702 -0.0010812 2.49e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylnonadecane" "1-bromononadecane" "nonadecane, 1-bromo-" );
standardThermochemistry
{
    dHf_298   -409160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     947.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=123420.0
}
