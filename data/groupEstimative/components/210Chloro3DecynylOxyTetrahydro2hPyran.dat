/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-((10-chloro-3-decynyl)oxy)tetrahydro-2h-pyran  (C15H25ClO2, CAS 71673-29-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        210Chloro3DecynylOxyTetrahydro2hPyran;
formula     C15H25ClO2;
CAS         71673-29-5;
InChIKey    PFKZTZZEEPSIAA-HNNXBMFYSA-N;
MW          272.813;      // g/mol [origin=calculated method=formula-sum]
Tc          865.80;      // K   [origin=predictive method=joback]
Pc          18.016;      // bar [origin=predictive method=joback]
omega       0.7290;      // -   [origin=predictive method=lee-kesler]
Tb          658.15;      // K   [origin=predictive method=joback]
HvapTb      62870.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.082 1.3417 -0.00067656 1.0138e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group CH2Cl; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group tC; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Cl; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-(10-chloranyldec-3-ynoxy)oxane" "2h-pyran, 2-((10-chloro-3-decynyl)oxy)tetrahydro-" "2h-pyran, 2-((10-chloro-3-decyn-1-yl)oxy)tetrahydro-" "(2r)-2-(10-chlorodec-3-ynoxy)oxane" );
standardThermochemistry
{
    dHf_298   -306270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     674.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99620.0
}
