/*--------------------------------*- Choupo -*-----------------------*\
  Component: betulin  (C30H50O2, CAS 473-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betulin;
formula     C30H50O2;
CAS         473-98-3;
InChIKey    FVWJYYTZTCVBKE-ROUWMTJPSA-N;
MW          442.728;      // g/mol [origin=calculated method=formula-sum]
Tc          1346.30;      // K   [origin=predictive method=joback]
Pc          10.821;      // bar [origin=predictive method=joback]
omega       1.0374;      // -   [origin=predictive method=lee-kesler]
Tb          1099.42;      // K   [origin=predictive method=joback]
HvapTb      108130.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-512.739 4.89922 -0.0048474 2.0225e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 11; } { group CH; count 6; } { group C; count 5; } { group CH2=C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 6; } { group C_ring; count 5; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,3as,5ar,5br,7ar,9s,11ar,11br,13ar,13br)-3a-(hydroxymethyl)-5a,5b,8,8,11a-pentamethyl-1-prop-1-en-2-yl-1,2,3,4,5,6,7,7a,9,10,11,11b,12,13,13a,13b-hexadecahydrocyclopenta[a]chrysen-9-ol" "betulinol" "trochol" "betuline" "betulol" "lup-20(29)-ene-3b,28-diol" "lup-20(29)-ene-3beta,28-diol" "lup-20(30)-ene-3beta,28-diol" "lup-20(29)-ene-3,28-diol, (3beta)-" "betulinic alcohol" "betulin, 23" "lup-20(29)-ene-3 beta,28-diol" );
standardThermochemistry
{
    dHf_298   -570150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1179.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164810.0
}
