/*--------------------------------*- Choupo -*-----------------------*\
  Component: pirprofen  (C13H14ClNO2, CAS 31793-07-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pirprofen;
formula     C13H14ClNO2;
CAS         31793-07-4;
InChIKey    PIDSZXPFGCURGN-UHFFFAOYSA-N;
MW          251.71;      // g/mol [origin=calculated method=formula-sum]
Tc          980.25;      // K   [origin=predictive method=joback]
Pc          28.203;      // bar [origin=predictive method=joback]
omega       0.9873;      // -   [origin=predictive method=lee-kesler]
Tb          743.46;      // K   [origin=predictive method=joback]
HvapTb      72022.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.64 1.34012 -0.0010058 2.949e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 1; } { group CH2N; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group Cl; count 1; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[3-chloranyl-4-(2,5-dihydropyrrol-1-yl)phenyl]propanoic acid" "rengasil" "pirprofene [inn-french]" "pirprofenum [inn-latin]" "hydratropic acid, 3-chloro-4-(3-pyrrolin-1-yl)-" "3-chloro-4-(3-pyrrolin-1-yl)hydratropic acid" "2-[3-chloro-4-(2,5-dihydro-1h-pyrrol-1-yl)phenyl]propanoic acid" "pirprofene" "pirprofeno" "pirprofenum" "pirprofen[usan:ban:inn]" "pirprofen (usan/inn)" );
standardThermochemistry
{
    dHf_298   -257060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9450.0
}
