/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropane, 1,1,2-trimethyl-  (C6H12, CAS 4127-45-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropane112Trimethyl;
formula     C6H12;
CAS         4127-45-1;
InChIKey    BXIIJPAVISPOGI-UHFFFAOYSA-N;
MW          84.162;      // g/mol [origin=calculated method=formula-sum]
Tc          525.41;      // K   [origin=predictive method=joback]
Pc          36.642;      // bar [origin=predictive method=joback]
omega       0.2076;      // -   [origin=predictive method=lee-kesler]
Tb          339.19;      // K   [origin=predictive method=joback]
HvapTb      27403.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.86 0.99016 -0.001 4.293e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2-trimethylcyclopropane" "1,1,2-trimethyl cyclopropane" "1,2-trimethylcyclopropane" "cyclopropane,1,2-trimethyl-" "cyclopropane,1,1,2-trimethyl-" );
standardThermochemistry
{
    dHf_298   -99470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     326.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47190.0
}
