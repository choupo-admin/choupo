/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,6-dimethylbicyclo(3.1.1)hept-2-en-2-acetaldehyde  (C11H16O, CAS 30897-75-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        66Dimethylbicyclo311Hept2En2Acetaldehyde;
formula     C11H16O;
CAS         30897-75-7;
InChIKey    BLKPFVWYBFDTPX-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          728.46;      // K   [origin=predictive method=joback]
Pc          28.233;      // bar [origin=predictive method=joback]
omega       0.5225;      // -   [origin=predictive method=lee-kesler]
Tb          517.40;      // K   [origin=predictive method=joback]
HvapTb      46292.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.289 1.46544 -0.00135904 5.354e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(6,6-dimethyl-4-bicyclo[3.1.1]hept-3-enyl)ethanal" "bicyclo[3.1.1]hept-2-ene-2-acetaldehyde, 6,6-dimethyl-" "nopylaldehyde" "bicyclo(3.1.1)hept-2-ene-2-acetaldehyde, 6,6-dimethyl-" "agn-pc-00k92e" "(6,6-dimethylbicyclo[3.1.1]hept-2-en-2-yl)acetaldehyde" "bicyclo[3.1.1]hept-2-ene-2-acetaldehyde,6,6-dimethyl-" "2-(6,6-dimethyl-4-bicyclo[3.1.1]hept-3-enyl)acetaldehyde" );
standardThermochemistry
{
    dHf_298   -175300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58750.0
}
