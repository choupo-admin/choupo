/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-1-aminoindane  (C9H11N, CAS 10277-74-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r1Aminoindane;
formula     C9H11N;
CAS         10277-74-4;
InChIKey    XJEVHMGJSYVQBQ-SECBINFHSA-N;
MW          133.194;      // g/mol [origin=calculated method=formula-sum]
Tc          755.18;      // K   [origin=predictive method=joback]
Pc          40.108;      // bar [origin=predictive method=joback]
omega       0.4747;      // -   [origin=predictive method=lee-kesler]
Tb          516.45;      // K   [origin=predictive method=joback]
HvapTb      49120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.65 0.9332 -0.00069356 2.068e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r)-2,3-dihydro-1h-inden-1-amine" "(r)-(-)-1-aminoindan" "(r)-(-)-1-aminoindane" "(r)-(-)-1-indanamine" "(r)-2,3-dihydro-1h-inden-1-amine" "(r)-1-aminoindan" "(1r)indanylamine" "r-ai" "rasagiline intermediate" "(r)-indan-1-ylamine" "(1r)-indan-1-amine" "(r)-(-)-indanamine" );
standardThermochemistry
{
    dHf_298   102560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=254880.0
}
