/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3s,8s,9s,10r,13r,14s,17r)-17-(1,5-dimethylhex-4-enyl)-10,13-dimethyl-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-ol  (C27H44O, CAS 32617-26-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3s8s9s10r13r14s17r1715Dimethylhex4Enyl1013Dimethyl2347891112;
formula     C27H44O;
CAS         32617-26-8;
InChIKey    AVSXSVCZWQODGV-XWPGJHTNSA-N;
MW          384.648;      // g/mol [origin=calculated method=formula-sum]
Tc          1176.54;      // K   [origin=predictive method=joback]
Pc          11.141;      // bar [origin=predictive method=joback]
omega       0.9577;      // -   [origin=predictive method=lee-kesler]
Tb          952.06;      // K   [origin=predictive method=joback]
HvapTb      90262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-318.578 3.5731 -0.00303274 1.107e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 10; } { group CH; count 6; } { group C; count 2; } { group CH=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,8s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-(6-methylhept-5-en-2-yl)-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-ol" "cholesta-5,24-dien-3-beta-ol" "cholesta-5,24-dien-3-ol,(3b)-" "cholesta-5,24-dien-3beta-ol (8ci)" "cholesta-5,24-dien-3-ol, (3beta)- (9ci)" );
gibbsFormation
{
    dHf_298   -374520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     945.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=277590.0
    phase     gas;
}
