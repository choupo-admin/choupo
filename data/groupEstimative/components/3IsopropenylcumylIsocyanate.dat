  Component: 3-isopropenylcumyl isocyanate  (C13H15NO, CAS 2094-99-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3IsopropenylcumylIsocyanate;
formula     C13H15NO;
CAS         2094-99-7;
InChIKey    ZVEMLYIXBCTVOF-UHFFFAOYSA-N;
MW          201.269;      // g/mol [origin=calculated method=formula-sum]
Tc          814.54;      // K   [origin=predictive method=joback]
Pc          24.752;      // bar [origin=predictive method=joback]
omega       0.5603;      // -   [origin=predictive method=lee-kesler]
Tb          588.70;      // K   [origin=predictive method=joback]
HvapTb      55116.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-isocyanatopropan-2-yl)-3-prop-1-en-2-yl-benzene" "3-isopropenyl-alpha,alpha-dimethylbenzyl isocyanate" "3-isopropenyl-.alpha.,.alpha.-dimethylbenzyl isocyanate" "isocyanic acid 3-isopropenylcumyl ester" "3-isopropenyl-" "a," "a-dimethylbenzyl isocyanate" "2-[3-(1-methylvinyl)phenyl]propan-2-isocyanate" "3-isopropenyl-a,a-dimethylbenzyl isocyanate" "1-(1-isocyanato-1-methylethyl)-3-isopropenylbenzene" "1-(2-isocyanatopropan-2-yl)-3-prop-1-en-2-ylbenzene" "1-(2-isocyanatopropan-2-yl)-3-(prop-1-en-2-yl)benzene" "isocyanic acid 3-isopropenyl-alpha,alpha-dimethylbenzyl ester" );
