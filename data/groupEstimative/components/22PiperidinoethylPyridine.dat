/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-piperidinoethyl)pyridine  (C12H18N2, CAS 5452-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22PiperidinoethylPyridine;
formula     C12H18N2;
CAS         5452-83-5;
InChIKey    ZOXWZYTVCGKPOX-UHFFFAOYSA-N;
MW          190.29;      // g/mol [origin=calculated method=formula-sum]
Tc          823.19;      // K   [origin=predictive method=joback]
Pc          29.959;      // bar [origin=predictive method=joback]
omega       0.5719;      // -   [origin=predictive method=lee-kesler]
Tb          586.93;      // K   [origin=predictive method=joback]
HvapTb      53401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.978 1.38076 -0.00096486 2.64e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2N; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-piperidin-1-ylethyl)pyridine" "pyridine, 2-(2-piperidinoethyl)-" "2-(2-(piperidyl)ethyl)pyridine" "1-[2-(2-pyridyl)ethyl]piperidine" "2-(2-(1-piperidinyl)ethyl)pyridine" "1-(2-(alpha-pyridyl)ethyl)piperidine" "2-[2-(piperidin-1-yl)ethyl]pyridine" "2-(2-piperidin-1-yl-ethyl)-pyridine" "pyridine, 2-(2-(1-piperidinyl)ethyl)-" "pyridine, 2-[2-(1-piperidinyl)ethyl]-" "2-[2-(1-piperidinyl)ethyl]pyridine" "1-[2-(pyridin-2-yl)ethyl]piperidine" );
standardThermochemistry
{
    dHf_298   126660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=394660.0
}
