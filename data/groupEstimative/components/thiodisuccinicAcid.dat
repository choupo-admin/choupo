/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiodisuccinic acid  (C8H10O8S, CAS 4917-76-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiodisuccinicAcid;
formula     C8H10O8S;
CAS         4917-76-4;
InChIKey    SASYRHXVHLPMQD-UHFFFAOYSA-N;
MW          266.22;      // g/mol [origin=calculated method=formula-sum]
Tc          1275.08;      // K   [origin=predictive method=joback]
Pc          39.209;      // bar [origin=predictive method=joback]
omega       2.0556;      // -   [origin=predictive method=lee-kesler]
Tb          1032.58;      // K   [origin=predictive method=joback]
HvapTb      108099.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.252 0.97319 -0.000668 1.674e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group COOH; count 4; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 2; } { group COOH; count 4; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1,4-bis(oxidanyl)-1,4-bis(oxidanylidene)butan-2-yl]sulfanylbutanedioic acid" "2,2'-thiodisuccinic acid" "2,2'-sulfanediyldisuccinic acid" "butanedioic acid, 2,2'-thiobis-" "2,2-thiodisuccinic acid" "succinic acid, 2,2'-thiodi-" "butanedioic acid,2,2'-thiobis-" "sasyrhxvhlpmqd-uhfffaoysa-" "2,2'-sulfanediyldibutanedioic acid" "2-(1,2-dicarboxyethylthio)butanedioic acid" "2-(1,2-dicarboxyethylsulfanyl)butanedioic acid" "2-[(1,2-dicarboxyethyl)sulfanyl]butanedioic acid" );
gibbsFormation
{
    dHf_298   -1578220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     722.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1330920.0
    phase     gas;
}
