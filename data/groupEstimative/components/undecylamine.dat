/*--------------------------------*- Choupo -*-----------------------*\
  Component: undecylamine  (C11H25N, CAS 7307-55-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        undecylamine;
formula     C11H25N;
CAS         7307-55-3;
InChIKey    QFKMMXYLAPZKIB-UHFFFAOYSA-N;
MW          171.328;      // g/mol [origin=calculated method=formula-sum]
Tc          696.81;      // K   [origin=predictive method=joback]
Pc          20.346;      // bar [origin=predictive method=joback]
omega       0.7176;      // -   [origin=predictive method=lee-kesler]
Tb          523.81;      // K   [origin=predictive method=joback]
HvapTb      50721.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.62 1.11072 -0.000618 1.307e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undecan-1-amine" "1-undecanamine" "n-undecylamine" "1-aminoundecane" "hendecylamine" "1-undecylamine" "monoundecylamine" "undecyl-amine" "n-undecylamin" "1-amino-undecane" );
standardThermochemistry
{
    dHf_298   -236580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     636.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108190.0
}
