/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptaethylene glycol monododecyl ether  (C26H54O8, CAS 3055-97-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptaethyleneGlycolMonododecylEther;
formula     C26H54O8;
CAS         3055-97-8;
InChIKey    DWHIUNMOTRUVPG-UHFFFAOYSA-N;
MW          494.71;      // g/mol [origin=calculated method=formula-sum]
Tc          1340.58;      // K   [origin=predictive method=joback]
Pc          7.145;      // bar [origin=predictive method=joback]
omega       0.2865;      // -   [origin=predictive method=lee-kesler]
Tb          1043.60;      // K   [origin=predictive method=joback]
HvapTb      107019.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (163.045 2.06542 -0.000644 -7.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CH2O; count 6; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 25; } { group OH; count 1; } { group O; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-[2-[2-(2-dodecoxyethoxy)ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethanol" "dodecylheptaglycol" "3,6,9,12,15,18,21-heptaoxatritriacontan-1-ol" "polyoxyethylene (7) lauryl ether" "c12e7" "laureth-7" "polyethylene glycol (7) lauryl ether" "peg-7 lauryl ether" "polyoxyethylene 7 lauryl ether" "lauryl alcohol hexa(oxyethylene) ethanol" "o553" );
standardThermochemistry
{
    dHf_298   -1657740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1298.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-703780.0
}
