/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,7,8,9-hexahydroanthanthrene  (C22H18, CAS 35281-34-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123789Hexahydroanthanthrene;
formula     C22H18;
CAS         35281-34-6;
InChIKey    ZSZZSGNVFIHJFK-UHFFFAOYSA-N;
MW          282.386;      // g/mol [origin=calculated method=formula-sum]
Tc          1088.79;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.9045;      // -   [origin=predictive method=lee-kesler]
Tb          831.58;      // K   [origin=predictive method=joback]
HvapTb      75542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-169.45 2.0768 -0.00186884 6.806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 6; } { group AC; count 6; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 6; } { group dC_ring; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,7,8,9-hexahydrodibenzo(def,mno)chrysene" "dibenzo(def,mno)chrysene, 1,2,3,7,8,9-hexahydro-" "dibenzo[def,mno]chrysene, 1,2,3,7,8,9-hexahydro-" "1,2,3,7,8,9-hexahydronaphtho[7,8,1,2,3-nopqr]tetraphene" );
standardThermochemistry
{
    dHf_298   384330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=640100.0
}
