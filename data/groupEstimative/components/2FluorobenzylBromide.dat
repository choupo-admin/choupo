/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluorobenzyl bromide  (C7H6BrF, CAS 446-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2FluorobenzylBromide;
formula     C7H6BrF;
CAS         446-48-0;
InChIKey    FFWQLZFIMNTUCZ-UHFFFAOYSA-N;
MW          189.027;      // g/mol [origin=calculated method=formula-sum]
Tc          677.75;      // K   [origin=predictive method=joback]
Pc          41.623;      // bar [origin=predictive method=joback]
omega       0.4210;      // -   [origin=predictive method=lee-kesler]
Tb          456.85;      // K   [origin=predictive method=joback]
HvapTb      39732.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.799 0.5804 -0.00040896 1.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group Br; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(bromomethyl)-2-fluoranyl-benzene" "o-fluorobenzyl bromide" "1-(bromomethyl)-2-fluorobenzene" "2-fluorobenzylbromide" "alpha-bromo-2-fluorotoluene" "alpha-bromo-o-fluorotoluene" "3-fluorobenzylbromide" "a-bromo-o-fluorotoluene" "tpc-i181" "wt164" "446-48-0 2-fluorobenzyl bromide" "f146" );
standardThermochemistry
{
    dHf_298   -132530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-69650.0
}
