/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-2-methylpropanoic acid  (C4H7ClO2, CAS 16674-04-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro2MethylpropanoicAcid;
formula     C4H7ClO2;
CAS         16674-04-7;
InChIKey    AWSSTZZQBPIWKZ-UHFFFAOYSA-N;
MW          122.548;      // g/mol [origin=calculated method=formula-sum]
Tc          677.75;      // K   [origin=predictive method=joback]
Pc          42.056;      // bar [origin=predictive method=joback]
omega       0.6084;      // -   [origin=predictive method=lee-kesler]
Tb          473.62;      // K   [origin=predictive method=joback]
HvapTb      45659.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.061 0.44732 -0.00029 7.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group COOH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-2-methyl-propanoic acid" "3-chloro-2-methylpropionic acid" "3-cmpa" "propanoic acid,3-chloro-2-methyl-" "propanoic acid, 3-chloro-2-methyl-" "isobutyricacid, b-chloro- (4ci); propionic acid,3-chloro-2-methyl- (6ci,7ci,8ci); 3-chloro-2-methylpropanoic acid; 3-chloro-2-methylpropionicacid; b-chloroisobutyric acid" );
standardThermochemistry
{
    dHf_298   -497180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-375480.0
}
