/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(hexyloxy)phenyl 4-(decyloxy)benzoate  (C29H42O4, CAS 68162-09-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HexyloxyPhenyl4DecyloxyBenzoate;
formula     C29H42O4;
CAS         68162-09-4;
InChIKey    JBMARNOUPBCWIL-UHFFFAOYSA-N;
MW          454.651;      // g/mol [origin=calculated method=formula-sum]
Tc          1260.73;      // K   [origin=predictive method=joback]
Pc          8.656;      // bar [origin=predictive method=joback]
omega       0.8340;      // -   [origin=predictive method=lee-kesler]
Tb          1029.50;      // K   [origin=predictive method=joback]
HvapTb      98251.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.724 2.30084 -0.00116552 1.684e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group ACH; count 8; } { group AC; count 4; } { group CH2O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-hexoxyphenyl) 4-decoxybenzoate" "4-(n-decyloxy)benzoic acid,4-(n-hexyloxy)phenyl ether" "4-n-hexoxyphenyl-4'-n-decyloxybenzoate" );
standardThermochemistry
{
    dHf_298   -773490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1134.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-121510.0
}
