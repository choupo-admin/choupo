/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tert-butylthiophene  (C8H12S, CAS 1689-78-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TertButylthiophene;
formula     C8H12S;
CAS         1689-78-7;
InChIKey    SWCDOJGIOCVXFM-UHFFFAOYSA-N;
MW          140.244;      // g/mol [origin=calculated method=formula-sum]
Tc          679.89;      // K   [origin=predictive method=joback]
Pc          34.480;      // bar [origin=predictive method=joback]
omega       0.2808;      // -   [origin=predictive method=lee-kesler]
Tb          450.49;      // K   [origin=predictive method=joback]
HvapTb      39730.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.6 0.89077 -0.00069222 2.159e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(tert-butyl)thiophene" "thiophene, 2-tert-butyl-" "thiophene, 2-(1,1-dimethylethyl)-" "2-tert-butyl-thiophene" "2-t-butylthiophene" "thiophene, (1,1-dimethylethyl)-" );
standardThermochemistry
{
    dHf_298   12970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=153730.0
}
