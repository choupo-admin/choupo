/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3,3-tetrabromo-1,2,2,3-tetrafluoropropane  (C3Br4F4, CAS 36567-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1133Tetrabromo1223Tetrafluoropropane;
formula     C3Br4F4;
CAS         36567-29-0;
InChIKey    UFNADSRPYOEKAI-UHFFFAOYSA-N;
MW          431.641;      // g/mol [origin=calculated method=formula-sum]
Tc          760.93;      // K   [origin=predictive method=joback]
Pc          54.627;      // bar [origin=predictive method=joback]
omega       0.5959;      // -   [origin=predictive method=lee-kesler]
Tb          520.27;      // K   [origin=predictive method=joback]
HvapTb      40856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.13 0.8662 -0.001006 3.99e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Br; count 4; } { group CF2; count 1; } { group CF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group F; count 4; } { group Br; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,3,3-tetrakis(bromanyl)-1,2,2,3-tetrakis(fluoranyl)propane" "propane, 1,1,3,3-tetrabromo-1,2,2,3-tetrafluoro-" );
gibbsFormation
{
    dHf_298   -810620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-739060.0
    phase     gas;
}
