/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethyl-1-silacyclopentane  (C6H14Si, CAS 1072-54-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H14Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        11Dimethyl1Silacyclopentane;
formula     C6H14Si;
CAS         1072-54-4;
InChIKey    KDQBKCRYCZJUAE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          114.263;      // g/mol [origin=calculated method=formula-sum]
Tc          548.64;      // K   [origin=predictive method=joback]
Pc          33.567;      // bar [origin=predictive method=joback]
omega       0.1774;      // -   [origin=predictive method=lee-kesler]
Tb          353.96;      // K   [origin=predictive method=joback]
HvapTb      29638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.05 0.53544 -0.000117 -5.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethylsilolane" "silacyclopentane, 1,1-dimethyl-" "silacyclopentane,1,1-dimethyl-;1,1-dimethylsilacyclopentane;1,1-dimethylsilolan;cyclotetramethylenedimethylsilane;" );
standardThermochemistry
{
    dHf_298   -191810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-48760.0
}
