/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-h-03326  (C5H8Cl2O2, CAS 76043-70-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agH03326;
formula     C5H8Cl2O2;
CAS         76043-70-4;
InChIKey    HOAZEZNLXSODIR-UHFFFAOYSA-N;
MW          171.017;      // g/mol [origin=calculated method=formula-sum]
Tc          739.78;      // K   [origin=predictive method=joback]
Pc          46.151;      // bar [origin=predictive method=joback]
omega       0.7204;      // -   [origin=predictive method=lee-kesler]
Tb          523.11;      // K   [origin=predictive method=joback]
HvapTb      55652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.92 0.9109 -0.0008637 3.468e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group FCH2O; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group Cl; count 2; } { group OH; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(chloranyl)oxan-2-ol" "3,3-dichlorooxan-2-ol" "2h-pyran-2-ol,3,3-dichlorotetrahydro-" "3,3-dichloro-2h-3,4,5,6-tetrahydropyran-2-ol" "pyran-2-ol,3,3-dichlorotetrahydro- (6ci); 3,3-dichloro-2-hydroxytetrahydropyran" );
standardThermochemistry
{
    dHf_298   -413020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-244330.0
}
