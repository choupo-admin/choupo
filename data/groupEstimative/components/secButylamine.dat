/*--------------------------------*- Choupo -*-----------------------*\
  Component: sec-butylamine  (C4H11N, CAS 13952-84-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        secButylamine;
formula     C4H11N;
CAS         13952-84-6;
InChIKey    BHRZNVHARXXAHW-UHFFFAOYSA-N;
MW          73.139;      // g/mol [origin=calculated method=formula-sum]
Tc          549.47;      // K   [origin=predictive method=joback]
Pc          42.330;      // bar [origin=predictive method=joback]
omega       0.3433;      // -   [origin=predictive method=lee-kesler]
Tb          363.21;      // K   [origin=predictive method=joback]
HvapTb      34751.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.061 0.45164 -0.0002404 4.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butan-2-amine" "2-butanamine" "2-aminobutane" "1-methylpropylamine" "2-butylamine" "1-methylpropanamine" "butafume" "deccotane" "frucote" "tutane" "sec-butylamine, (s)-" "2-aminobutane base" );
gibbsFormation
{
    dHf_298   -97380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     353.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46810.0
    phase     gas;
}
