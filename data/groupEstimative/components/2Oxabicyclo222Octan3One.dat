/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxabicyclo[2.2.2]octan-3-one  (C7H10O2, CAS 4350-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Oxabicyclo222Octan3One;
formula     C7H10O2;
CAS         4350-84-9;
InChIKey    NVORRKXXHHFWDH-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          634.59;      // K   [origin=predictive method=joback]
Pc          37.870;      // bar [origin=predictive method=joback]
omega       0.4245;      // -   [origin=predictive method=lee-kesler]
Tb          431.46;      // K   [origin=predictive method=joback]
HvapTb      38409.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.55 0.9158 -0.0007028 2.136e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxabicyclo[2.2.2]octan-2-one" "2-oxabicyclo(2.2.2)octan-3-one" "3,6-ethanotetrahydropyran-2-one" "4-hydroxy-1-cyclohexanecarboxylic acid delta-lactone" );
gibbsFormation
{
    dHf_298   -359490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     299.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180810.0
    phase     gas;
}
