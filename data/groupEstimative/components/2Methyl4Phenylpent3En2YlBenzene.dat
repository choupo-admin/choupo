/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-methyl-4-phenylpent-3-en-2-yl)benzene  (C18H20, CAS 6258-73-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl4Phenylpent3En2YlBenzene;
formula     C18H20;
CAS         6258-73-7;
InChIKey    VOOVDZMAQQVAEW-UHFFFAOYSA-N;
MW          236.358;      // g/mol [origin=calculated method=formula-sum]
Tc          914.52;      // K   [origin=predictive method=joback]
Pc          20.512;      // bar [origin=predictive method=joback]
omega       0.5074;      // -   [origin=predictive method=lee-kesler]
Tb          665.61;      // K   [origin=predictive method=joback]
HvapTb      58956.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.63 1.70176 -0.0012757 3.751e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-4-phenyl-pent-3-en-2-yl)benzene" "1,1'-(1,3,3-trimethylprop-1-ene-1,3-diyl)dibenzene" "benzene,1,1'-(1,3,3-trimethyl-1-propene-1,3-diyl)bis-" );
gibbsFormation
{
    dHf_298   156890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=400010.0
    phase     gas;
}
