/*--------------------------------*- Choupo -*-----------------------*\
  Component: shogaol  (C17H24O3, CAS 555-66-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        shogaol;
formula     C17H24O3;
CAS         555-66-8;
InChIKey    OQWKEEOHDMUXEO-BQYQJAHWSA-N;
MW          276.376;      // g/mol [origin=calculated method=formula-sum]
Tc          991.09;      // K   [origin=predictive method=joback]
Pc          19.119;      // bar [origin=predictive method=joback]
omega       1.1038;      // -   [origin=predictive method=lee-kesler]
Tb          781.29;      // K   [origin=predictive method=joback]
HvapTb      78502.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.414 1.56384 -0.00107562 3.0836e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-(3-methoxy-4-oxidanyl-phenyl)dec-4-en-3-one" "6-shogaol" "(6)-shogaol" "[6]-shogaol" "(e)-1-(4-hydroxy-3-methoxyphenyl)dec-4-en-3-one" "4-decen-3-one, 1-(4-hydroxy-3-methoxyphenyl)-" "trans-6-shogaol" "1-(4-hydroxy-3-methoxyphenyl)-4-decen-3-one" "4-decen-3-one, 1-(4-hydroxy-3-methoxyphenyl)" "brd-k23331196-001-01-9" "1-(4-hydroxy-3-methoxyphenyl)-4-decen-3-one; shogaol" );
gibbsFormation
{
    dHf_298   -474040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     763.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113280.0
    phase     gas;
}
