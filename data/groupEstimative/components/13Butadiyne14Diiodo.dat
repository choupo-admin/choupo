/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-butadiyne, 1,4-diiodo-  (C4I2, CAS 53214-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Butadiyne14Diiodo;
formula     C4I2;
CAS         53214-97-4;
InChIKey    HUKBPXSFAFKZBD-UHFFFAOYSA-N;
MW          301.844;      // g/mol [origin=calculated method=formula-sum]
Tc          819.69;      // K   [origin=predictive method=joback]
Pc          56.874;      // bar [origin=predictive method=joback]
omega       0.1346;      // -   [origin=predictive method=lee-kesler]
Tb          495.40;      // K   [origin=predictive method=joback]
HvapTb      47548.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.75 0.1622 -0.00017232 7.416e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group I; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 4; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(iodanyl)buta-1,3-diyne" "1,4-diiodobuta-1,3-diyne" "1,4-diiodo-1,3-butadiyne" );
gibbsFormation
{
    dHf_298   572450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     366.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=504640.0
    phase     gas;
}
