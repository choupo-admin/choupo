/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-isopropyl-9h-fluorene  (C16H16, CAS 3299-99-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Isopropyl9hFluorene;
formula     C16H16;
CAS         3299-99-8;
InChIKey    HOJPTYYFGWUDJX-UHFFFAOYSA-N;
MW          208.304;      // g/mol [origin=calculated method=formula-sum]
Tc          864.43;      // K   [origin=predictive method=joback]
Pc          24.171;      // bar [origin=predictive method=joback]
omega       0.5678;      // -   [origin=predictive method=lee-kesler]
Tb          626.76;      // K   [origin=predictive method=joback]
HvapTb      56267.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.55 1.42304 -0.00109112 3.39e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-propan-2-yl-9h-fluorene" "9h-fluorene, 9-(1-methylethyl)-" );
standardThermochemistry
{
    dHf_298   156390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=371910.0
}
