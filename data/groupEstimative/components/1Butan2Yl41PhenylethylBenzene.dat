/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butan-2-yl-4-(1-phenylethyl)benzene  (C18H22, CAS 101646-62-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butan2Yl41PhenylethylBenzene;
formula     C18H22;
CAS         101646-62-2;
InChIKey    BGXDETJQFCTFFK-UHFFFAOYSA-N;
MW          238.374;      // g/mol [origin=calculated method=formula-sum]
Tc          900.35;      // K   [origin=predictive method=joback]
Pc          19.186;      // bar [origin=predictive method=joback]
omega       0.6007;      // -   [origin=predictive method=lee-kesler]
Tb          668.90;      // K   [origin=predictive method=joback]
HvapTb      60100.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.349 1.50836 -0.00095716 2.281e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group ACH; count 9; } { group AC; count 1; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   36180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=310990.0
}
