/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecylcyclohexane  (C18H36, CAS 1795-17-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecylcyclohexane;
formula     C18H36;
CAS         1795-17-1;
InChIKey    BLRBGKYYWDBAQQ-UHFFFAOYSA-N;
MW          252.486;      // g/mol [origin=calculated method=formula-sum]
Tc          811.58;      // K   [origin=predictive method=joback]
Pc          13.310;      // bar [origin=predictive method=joback]
omega       0.7112;      // -   [origin=predictive method=lee-kesler]
Tb          630.99;      // K   [origin=predictive method=joback]
HvapTb      56091.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.079 1.83592 -0.0010364 2.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-dodecyl cyclohexane" "1-cyclohexyldodecane" "cyclohexane, dodecyl-" "laurylcyclohexane" );
standardThermochemistry
{
    dHf_298   -360530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     826.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125130.0
}
