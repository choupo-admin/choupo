/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,1-dimethoxyethyl)benzene  (C10H14O2, CAS 4316-35-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11DimethoxyethylBenzene;
formula     C10H14O2;
CAS         4316-35-2;
InChIKey    XKSUVRWJZCEYQQ-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          711.53;      // K   [origin=predictive method=joback]
Pc          28.843;      // bar [origin=predictive method=joback]
omega       0.4403;      // -   [origin=predictive method=lee-kesler]
Tb          496.69;      // K   [origin=predictive method=joback]
HvapTb      43654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.58 0.87436 -0.0005012 9.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethoxyethylbenzene" "acetophenone dimethyl acetal" "benzene, (1,1-dimethoxyethyl)-" "benzene,(1,1-dimethoxyethyl)-" "acetophenone,dimethyl acetal (7ci,8ci); (1,1-dimethoxyethyl)benzene;1,1-dimethoxy-1-phenylethane; acetophenone dimethyl ketal; ethanone, 1-phenyl-,dimethyl acetal" );
standardThermochemistry
{
    dHf_298   -286390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-61430.0
}
