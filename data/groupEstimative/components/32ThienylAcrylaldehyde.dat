/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-thienyl)acrylaldehyde  (C7H6OS, CAS 14756-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32ThienylAcrylaldehyde;
formula     C7H6OS;
CAS         14756-03-7;
InChIKey    IEAUKTACQUVNLS-UHFFFAOYSA-N;
MW          138.184;      // g/mol [origin=calculated method=formula-sum]
Tc          717.68;      // K   [origin=predictive method=joback]
Pc          44.444;      // bar [origin=predictive method=joback]
omega       0.4446;      // -   [origin=predictive method=lee-kesler]
Tb          483.66;      // K   [origin=predictive method=joback]
HvapTb      45478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.0 0.66441 -0.00054282 1.774e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CHO; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group OdCH_al; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-thiophen-2-ylprop-2-enal" "2-propenal,3-(2-thienyl)-" "2-thiopheneacrolein(6ci,7ci,8ci); 3-(2-thienyl)acrolein; 3-(a-thienyl)propenal; 3-thiophen-2-ylpropenal" );
standardThermochemistry
{
    dHf_298   74000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=123170.0
}
