/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[4-(3-bicyclo[2.2.1]heptanyl)phenyl]ethanone  (C15H18O, CAS 54762-86-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        143Bicyclo221HeptanylPhenylEthanone;
formula     C15H18O;
CAS         54762-86-6;
InChIKey    RIQCUGGXKQATJX-UHFFFAOYSA-N;
MW          214.308;      // g/mol [origin=calculated method=formula-sum]
Tc          877.07;      // K   [origin=predictive method=joback]
Pc          24.338;      // bar [origin=predictive method=joback]
omega       0.6253;      // -   [origin=predictive method=lee-kesler]
Tb          641.41;      // K   [origin=predictive method=joback]
HvapTb      58357.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.66 1.52812 -0.00107626 2.9936e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanone, 1-(4-(1r,2s,4s)-bicyclo(2.2.1)hept-2-ylphenyl)-, rel-" "ethanone, 1-[4-(1r,2s,4s)-bicyclo[2.2.1]hept-2-ylphenyl]-, rel-" "endo-1-(4-bicyclo(2.2.1)hept-2-ylphenyl)ethan-1-one" "1-[4-[(1s,3s,4r)-3-bicyclo[2.2.1]heptanyl]phenyl]ethanone" );
standardThermochemistry
{
    dHf_298   -121350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=150970.0
}
