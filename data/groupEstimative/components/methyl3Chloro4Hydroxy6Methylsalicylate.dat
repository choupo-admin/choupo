/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-chloro-4-hydroxy-6-methylsalicylate  (C9H9ClO4, CAS 38103-07-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3Chloro4Hydroxy6Methylsalicylate;
formula     C9H9ClO4;
CAS         38103-07-0;
InChIKey    IDVMSOLGOULRNA-UHFFFAOYSA-N;
MW          216.617;      // g/mol [origin=calculated method=formula-sum]
Tc          938.34;      // K   [origin=predictive method=joback]
Pc          43.569;      // bar [origin=predictive method=joback]
omega       1.0839;      // -   [origin=predictive method=lee-kesler]
Tb          699.05;      // K   [origin=predictive method=joback]
HvapTb      77048.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.86 0.92214 -0.00080144 2.897e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 1; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 2; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Cl; count 1; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-chloranyl-6-methyl-2,4-bis(oxidanyl)benzoate" "methyl 3-chloro-2,4-dihydroxy-6-methylbenzoate" "benzoic acid, 3-chloro-2,4-dihydroxy-6-methyl-, methyl ester" "benzoic acid,3-chloro-2,4-dihydroxy-6-methyl-, methyl ester" "methyl3-chloro-2,4-dihydroxy-6-methylbenzoate; methyl 6-methyl-3-chloro-b-resorcylate" );
gibbsFormation
{
    dHf_298   -703140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-513490.0
    phase     gas;
}
