/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene-hexa-n-hexanoate  (C42H66O12, CAS 65201-69-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneHexaNHexanoate;
formula     C42H66O12;
CAS         65201-69-6;
InChIKey    GUERWKLSTJCDLZ-UHFFFAOYSA-N;
MW          762.978;      // g/mol [origin=calculated method=formula-sum]
Tc          2471.37;      // K   [origin=predictive method=joback]
Pc          4.058;      // bar [origin=predictive method=joback]
omega       -0.5149;      // -   [origin=predictive method=lee-kesler]
Tb          1561.46;      // K   [origin=predictive method=joback]
HvapTb      159114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (154.754 3.28872 -0.0013894 4.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 18; } { group AC; count 6; } { group CH2COO; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 24; } { group dC_ring; count 6; } { group COO; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,3,4,5,6-penta(hexanoyloxy)phenyl] hexanoate" );
gibbsFormation
{
    dHf_298   -2634710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1962.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1495200.0
    phase     gas;
}
