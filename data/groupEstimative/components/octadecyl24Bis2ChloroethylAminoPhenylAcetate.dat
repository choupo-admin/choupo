/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecyl 2-[4-[bis(2-chloroethyl)amino]phenyl]acetate  (C30H51Cl2NO2, CAS 66232-30-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecyl24Bis2ChloroethylAminoPhenylAcetate;
formula     C30H51Cl2NO2;
CAS         66232-30-2;
InChIKey    XHDQZPFSXMCVDF-UHFFFAOYSA-N;
MW          528.643;      // g/mol [origin=calculated method=formula-sum]
Tc          1316.11;      // K   [origin=predictive method=joback]
Pc          6.736;      // bar [origin=predictive method=joback]
omega       0.5093;      // -   [origin=predictive method=lee-kesler]
Tb          1063.18;      // K   [origin=predictive method=joback]
HvapTb      103532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.488 2.79812 -0.00163116 3.447e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group ACH; count 4; } { group AC; count 2; } { group CH2COO; count 1; } { group CH2N; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 22; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecyl 2-[4-[bis(2-chloroethyl)amino]phenyl]ethanoate" "2-(n,n-bis(2-chloroethyl)aminophenyl)acetic acid octadecyl ester" );
gibbsFormation
{
    dHf_298   -718700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1346.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=81050.0
    phase     gas;
}
