/*--------------------------------*- Choupo -*-----------------------*\
  Component: flurbiprofen axetil  (C19H19FO4, CAS 91503-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        flurbiprofenAxetil;
formula     C19H19FO4;
CAS         91503-79-6;
InChIKey    ALIVXCSEERJYHU-UHFFFAOYSA-N;
MW          330.355;      // g/mol [origin=calculated method=formula-sum]
Tc          1034.50;      // K   [origin=predictive method=joback]
Pc          16.949;      // bar [origin=predictive method=joback]
omega       0.9758;      // -   [origin=predictive method=lee-kesler]
Tb          812.47;      // K   [origin=predictive method=joback]
HvapTb      76985.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.05 1.44606 -0.00077172 1.065e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH; count 1; } { group CH3COO; count 1; } { group ACF; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-acetyloxyethyl 2-(3-fluoranyl-4-phenyl-phenyl)propanoate" "ropion" "ropiopn" "lipfen" "lfp 83" "fp 83" "lipo-flurbiprofen axetil" "liposomal flurbiprofen axetil" "1-acetoxyethyl 2-(2-fluoro-4-biphenylyl)propionate" "1-acetoxyethyl 2-(2-fluorobiphenyl-4-yl)propanoate" "1-acetoxyethyl-2-(2-fluoro-4-biphenylyl)propionate" "4-biphenylacetic acid, 2-fluoro-alpha-methyl-, 1-acetoxyethyl ester" );
gibbsFormation
{
    dHf_298   -826600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     786.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-505770.0
    phase     gas;
}
