/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-cyclohexylresorcinol  (C12H16O2, CAS 2138-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Cyclohexylresorcinol;
formula     C12H16O2;
CAS         2138-20-7;
InChIKey    LSEHCENPUMUIKC-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          941.60;      // K   [origin=predictive method=joback]
Pc          42.386;      // bar [origin=predictive method=joback]
omega       0.8385;      // -   [origin=predictive method=lee-kesler]
Tb          681.63;      // K   [origin=predictive method=joback]
HvapTb      71039.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-125.37 1.4962 -0.00125392 4.329e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 3; } { group ACCH; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-cyclohexylbenzene-1,3-diol" "1,3-benzenediol, 4-cyclohexyl-" "1, 4-cyclohexyl-" "4-cyclohexyl-benzene-1,3-diol" );
standardThermochemistry
{
    dHf_298   -354780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122220.0
}
