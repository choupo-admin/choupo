/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-bromoethoxy)benzene  (C8H9BrO, CAS 589-10-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromoethoxyBenzene;
formula     C8H9BrO;
CAS         589-10-6;
InChIKey    JJFOBACUIRKUPN-UHFFFAOYSA-N;
MW          201.063;      // g/mol [origin=calculated method=formula-sum]
Tc          724.00;      // K   [origin=predictive method=joback]
Pc          38.916;      // bar [origin=predictive method=joback]
omega       0.4903;      // -   [origin=predictive method=lee-kesler]
Tb          497.90;      // K   [origin=predictive method=joback]
HvapTb      44523.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.598 0.6599 -0.000403 8.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromoethyloxybenzene" "2-bromoethyl phenyl ether" "2-phenoxyethylbromide" "beta-bromophenetole" "benzene, (2-bromoethoxy)-" "2-phenoxyethyl bromide" "1-bromo-2-phenoxyethane" "(2-bromethoxy)benzol" "beta-phenoxyethyl bromide" "phenetole, .beta.-bromo-" "2-bromoethylphenylether" "2-bromo-1-phenoxyethane" );
gibbsFormation
{
    dHf_298   -77810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38210.0
    phase     gas;
}
