/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-deoxy-l-ascorbic acid  (C6H8O5, CAS 528-81-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6DeoxyLAscorbicAcid;
formula     C6H8O5;
CAS         528-81-4;
InChIKey    LGBPWIAXPVUTMY-JLAZNSOCSA-N;
MW          160.125;      // g/mol [origin=calculated method=formula-sum]
Tc          862.08;      // K   [origin=predictive method=joback]
Pc          53.357;      // bar [origin=predictive method=joback]
omega       2.0406;      // -   [origin=predictive method=lee-kesler]
Tb          687.06;      // K   [origin=predictive method=joback]
HvapTb      87535.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.17 0.60282 -0.0003758 8.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 2; } { group OH; count 3; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH_ring; count 1; } { group dC_ring; count 2; } { group OH; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-3,4-bis(oxidanyl)-2-[(1s)-1-oxidanylethyl]-2h-furan-5-one" "ascorbic acid, 6-deoxy-" "6-desoxy-l-ascorbic acid" "l-ascorbic acid, 6-deoxy-" "ascorbic acid, 6-deoxy-, l-" );
standardThermochemistry
{
    dHf_298   -838780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-652180.0
}
