/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-methanonaphthalene, 1,2,3,4,5,6,7,8-octahydro-5-methyl-  (C12H18, CAS 86954-77-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Methanonaphthalene12345678Octahydro5Methyl;
formula     C12H18;
CAS         86954-77-0;
InChIKey    OFFBVHGPEBVOQQ-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          732.51;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       0.4189;      // -   [origin=predictive method=lee-kesler]
Tb          512.04;      // K   [origin=predictive method=joback]
HvapTb      44005.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.61 1.40232 -0.00105 3.241e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 3; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -50090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=218910.0
}
