/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(n-methylaniline)methane  (C15H18N2, CAS 1807-55-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisNMethylanilineMethane;
formula     C15H18N2;
CAS         1807-55-2;
InChIKey    ZMVMYBGDGJLCHV-UHFFFAOYSA-N;
MW          226.323;      // g/mol [origin=calculated method=formula-sum]
Tc          938.83;      // K   [origin=predictive method=joback]
Pc          25.000;      // bar [origin=predictive method=joback]
omega       0.8474;      // -   [origin=predictive method=lee-kesler]
Tb          706.46;      // K   [origin=predictive method=joback]
HvapTb      67732.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.379 1.30444 -0.00081772 1.895e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-4-[[4-(methylamino)phenyl]methyl]aniline" "dimethyldiaminodiphenylmethane" "4,4'-methylenebis(n-methylaniline)" "bis(n-methylanilino)methan [german]" "aniline, 4,4'-methylenebis(n-methyl-" "4,4'-methylenebis(n-methylbenzenamine)" "n,n'-dimethyl-4,4'-methylenedianiline" "benzenamine, 4,4'-methylenebis(n-methyl-" "n,n'-dimethyl-4,4'-diaminodiphenylmethane" "aniline, n,n'-dimethyl-4,4'-methylenedi-" "benzenamine, 4,4'-methylenebis[n-methyl-" "n-methyl-4-{[4-(methylamino)phenyl]methyl}aniline" );
standardThermochemistry
{
    dHf_298   204130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=459760.0
}
