/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-1-pentene  (C6H12, CAS 691-37-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl1Pentene;
formula     C6H12;
CAS         691-37-2;
InChIKey    WSSSPWUEQFSQQG-UHFFFAOYSA-N;
MW          84.162;      // g/mol [origin=calculated method=formula-sum]
Tc          504.01;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.2547;      // -   [origin=predictive method=lee-kesler]
Tb          333.12;      // K   [origin=predictive method=joback]
HvapTb      27892.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.239 0.55974 -0.0003287 7.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylpent-1-ene" "1-pentene, 4-methyl-" "poly(4-methyl-1-pentene)" "poly(4-methylpentene)" "isohexene" "4-methylpentene" "1-pentene, 4-methyl-, homopolymer" "4-methy l-1-pentene" );
gibbsFormation
{
    dHf_298   -47020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85040.0
    phase     gas;
}
