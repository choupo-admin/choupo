/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-Methyl-1,2-propanediol  (C4H10O2, CAS 558-43-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl12Propanediol;
formula     C4H10O2;
CAS         558-43-0;
InChIKey    BTVWZWFKMIUSGS-UHFFFAOYSA-N;
MW          90.122;      // g/mol [origin=calculated method=formula-sum]
Tc          639.80;      // K   [origin=predictive method=joback]
Pc          51.093;      // bar [origin=predictive method=joback]
omega       1.0906;      // -   [origin=predictive method=lee-kesler]
Tb          472.25;      // K   [origin=predictive method=joback]
HvapTb      56560.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.639 0.57764 -0.0004264 1.279e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropane-1,2-diol" "1,1-dimethyl-1,2-ethanediol" "1,1-dimethylethylene glycol" "1,2-dihydroxy-2-methylpropane" "1,2-dihydroxyisobutane" "1,2-propanediol, 2-methyl-" "2-hydroxy-2-methyl-1-propyl alcohol" "2-hydroxy-2-methylpropanol" "2-methyl-2-hydroxy-1-propanol" "2-methyl-2-hydroxy-1-propyl alcohol" "2-methyl-2-hydroxypropanol" "isobutene glycol" );
gibbsFormation
{
    dHf_298   -439100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-288000.0
    phase     gas;
}
