\*---------------------------------------------------------------------------*/

name        2924Dipentylphenoxy369121518212427Nonaoxanonacosan1Ol;
formula     C36H66O11;
CAS         68214-68-6;
InChIKey    IUGUYAKPEVLCSE-UHFFFAOYSA-N;
MW          674.913;      // g/mol [origin=calculated method=formula-sum]
Tc          2057.35;      // K   [origin=predictive method=joback]
Pc          5.048;      // bar [origin=predictive method=joback]
omega       -0.3817;      // -   [origin=predictive method=lee-kesler]
Tb          1376.30;      // K   [origin=predictive method=joback]
HvapTb      140109.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (225.148 2.62794 -0.00075212 -1.453e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group CH2O; count 9; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 28; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-[2-[2-[2-[2-[2-[2-(2,4-dipentylphenoxy)ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethanol" "3,6,9,12,15,18,21,24,27-nonaoxanonacosan-1-ol, 29-(2,4-dipentylphenoxy)-" "29-(2,4-dipentylphenoxy)-3,6,9,12,15,18,21,24,27-nonaoxanonacosanol" );
standardThermochemistry
{
    dHf_298   -2047210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1603.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-841430.0
}
