/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(phenylethynyl)cyclopentanol  (C13H14O, CAS 25118-60-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PhenylethynylCyclopentanol;
formula     C13H14O;
CAS         25118-60-9;
InChIKey    ZDUXLFHBOAAXED-UHFFFAOYSA-N;
MW          186.254;      // g/mol [origin=calculated method=formula-sum]
Tc          884.75;      // K   [origin=predictive method=joback]
Pc          36.377;      // bar [origin=predictive method=joback]
omega       0.7616;      // -   [origin=predictive method=lee-kesler]
Tb          640.42;      // K   [origin=predictive method=joback]
HvapTb      64745.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-130.46 1.4677 -0.00131286 4.9528e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-phenylethynyl)cyclopentan-1-ol" "1-(phenylethynyl)-1-cyclopentanol" "cyclopentanol,1-(2-phenylethynyl)-" "cyclopentanol,1-(phenylethynyl)- (8ci,9ci); 1-(phenylethynyl)cyclopentanol;1-hydroxy-1-(phenylethynyl)cyclopentane" );
standardThermochemistry
{
    dHf_298   120670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=268030.0
}
