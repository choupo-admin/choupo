/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromobenzylamine  (C7H8BrN, CAS 3959-07-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromobenzylamine;
formula     C7H8BrN;
CAS         3959-07-7;
InChIKey    XRNVSPDQTPVECU-UHFFFAOYSA-N;
MW          186.052;      // g/mol [origin=calculated method=formula-sum]
Tc          775.16;      // K   [origin=predictive method=joback]
Pc          47.694;      // bar [origin=predictive method=joback]
omega       0.5433;      // -   [origin=predictive method=lee-kesler]
Tb          530.11;      // K   [origin=predictive method=joback]
HvapTb      51190.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.399 0.6305 -0.00043596 1.178e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2NH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-bromophenyl)methanamine" "p-bromobenzylamine" "4-bromo-benzylamine" "benzenemethanamine, 4-bromo-" "(4-bromophenyl)methylamine" "1-(4-bromophenyl)methanamine" "4-bromobenzylaminehydrochloride" "pzh" "p625" "(4-bromophenyl)methanamine;p-bromobenzenemethanamine" "benzylamine,p-bromo- (7ci,8ci); (4-bromophenyl)methanamine; 1-(4-bromophenyl)methanamine;4-bromobenzenemethanamine; 4-bromobenzylamine; p-bromobenzenemethanamine;p-bromobenzylamine" );
standardThermochemistry
{
    dHf_298   97370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191610.0
}
