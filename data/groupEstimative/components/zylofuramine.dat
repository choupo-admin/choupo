/*--------------------------------*- Choupo -*-----------------------*\
  Component: zylofuramine  (C14H21NO, CAS 3563-92-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        zylofuramine;
formula     C14H21NO;
CAS         3563-92-6;
InChIKey    DOFCLOLKFGSRTG-ZIAGYGMSSA-N;
MW          219.328;      // g/mol [origin=calculated method=formula-sum]
Tc          863.09;      // K   [origin=predictive method=joback]
Pc          24.053;      // bar [origin=predictive method=joback]
omega       0.6975;      // -   [origin=predictive method=lee-kesler]
Tb          638.56;      // K   [origin=predictive method=joback]
HvapTb      59849.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.798 1.46572 -0.0009343 2.217e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group FCH2O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r)-n-ethyl-1-[(2r)-oxolan-2-yl]-2-phenyl-ethanamine" "zylofuraminum [inn-latin]" "d-threo-alpha-benzyl-n-ethyltetrahydrofurfurylamine" "zilofuramina" "zylofuraminum" "zylofuramine [inn]" "(1r)-n-ethyl-1-[(2r)-oxolan-2-yl]-2-phenylethanamine" "furfurylamine, alpha-benzyl-n-ethyl-tetrahydro-, d-threo-" "2-furanmethanamine, n-ethyltetrahydro-alpha-(phenylmethyl)-, (r-(r*,r*))-" "2-furanmethanamine, n-ethyltetrahydro-alpha-(phenylmethyl)-, (r-(r*,r*))- (9ci)" );
gibbsFormation
{
    dHf_298   -119090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=216790.0
    phase     gas;
}
