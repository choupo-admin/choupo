/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-hydroxyethyl) azelaate  (C13H24O6, CAS 29602-44-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2HydroxyethylAzelaate;
formula     C13H24O6;
CAS         29602-44-6;
InChIKey    RLLLKKWXYJLXOU-UHFFFAOYSA-N;
MW          276.329;      // g/mol [origin=calculated method=formula-sum]
Tc          977.87;      // K   [origin=predictive method=joback]
Pc          19.372;      // bar [origin=predictive method=joback]
omega       1.5534;      // -   [origin=predictive method=lee-kesler]
Tb          797.84;      // K   [origin=predictive method=joback]
HvapTb      92704.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.471 1.1972 -0.000555 4.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group OH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 11; } { group OH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-hydroxyethyl) nonanedioate" "nonanedioic acid, bis(2-hydroxyethyl) ester" "nonanedioic acid, 1,9-bis(2-hydroxyethyl) ester" "bis(2-hydroxyethyl) azelate" "bis(2-hydroxyethyl)azelate" "nonanedioic acid,1,9-bis(2-hydroxyethyl) ester" "nonanedioicacid, bis(2-hydroxyethyl) ester (9ci); bis(2-hydroxyethyl) azelate" );
gibbsFormation
{
    dHf_298   -1250670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     866.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-835800.0
    phase     gas;
}
