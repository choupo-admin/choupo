/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane 40-47  (C9H24N2O3Si, CAS 25147-91-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H24N2O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silane4047;
formula     C9H24N2O3Si;
CAS         25147-91-5;
InChIKey    GPYDVGGHRWMVQP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          236.387;      // g/mol [origin=calculated method=formula-sum]
Tc          777.94;      // K   [origin=predictive method=joback]
Pc          20.984;      // bar [origin=predictive method=joback]
omega       0.9034;      // -   [origin=predictive method=lee-kesler]
Tb          596.88;      // K   [origin=predictive method=joback]
HvapTb      60229.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (117.306 0.60116 0.00019 -2.642e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH3O; count 3; } { group CH2NH2; count 1; } { group CH2NH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group O; count 3; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-(3-trimethoxysilylpropyl)propane-1,3-diamine" "(n-(3-aminopropyl)-3-aminopropyl)trimethoxysilane" "n-[3-(trimethoxysilyl)propyl]propane-1,3-diamine" "1,3-propanediamine, n-(3-(trimethoxysilyl)propyl)-" );
gibbsFormation
{
    dHf_298   -650110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     759.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-239020.0
    phase     gas;
}
