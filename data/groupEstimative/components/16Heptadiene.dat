/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-heptadiene  (C7H12, CAS 3070-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Heptadiene;
formula     C7H12;
CAS         3070-53-9;
InChIKey    GEAWFZNTIFJMHR-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          523.63;      // K   [origin=predictive method=joback]
Pc          30.659;      // bar [origin=predictive method=joback]
omega       0.3082;      // -   [origin=predictive method=lee-kesler]
Tb          353.12;      // K   [origin=predictive method=joback]
HvapTb      29836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.457 0.6288 -0.0004028 1.069e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hepta-1,6-diene" "ch2=ch(ch2)3ch=ch2" );
standardThermochemistry
{
    dHf_298   63050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=183740.0
}
