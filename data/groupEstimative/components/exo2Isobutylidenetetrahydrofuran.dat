/*--------------------------------*- Choupo -*-----------------------*\
  Component: exo-2-isobutylidenetetrahydrofuran  (C8H14O, CAS 56755-30-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        exo2Isobutylidenetetrahydrofuran;
formula     C8H14O;
CAS         56755-30-7;
InChIKey    JACGTRYVOSXWIR-SOFGYWHQSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          641.51;      // K   [origin=predictive method=joback]
Pc          32.840;      // bar [origin=predictive method=joback]
omega       0.3649;      // -   [origin=predictive method=lee-kesler]
Tb          435.74;      // K   [origin=predictive method=joback]
HvapTb      38877.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.07 0.84744 -0.000552 1.434e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH; count 1; } { group CH2_ring; count 3; } { group dC_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2e)-2-(2-methylpropylidene)oxolane" );
standardThermochemistry
{
    dHf_298   -188880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     370.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17640.0
}
