/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl l-leucinate  (C8H17NO2, CAS 2743-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylLLeucinate;
formula     C8H17NO2;
CAS         2743-60-4;
InChIKey    QIGLJVBIRIXQRN-ZETCQYMHSA-N;
MW          159.229;      // g/mol [origin=calculated method=formula-sum]
Tc          703.53;      // K   [origin=predictive method=joback]
Pc          27.469;      // bar [origin=predictive method=joback]
omega       0.6625;      // -   [origin=predictive method=lee-kesler]
Tb          512.51;      // K   [origin=predictive method=joback]
HvapTb      50674.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.152 0.78276 -0.0003666 3.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CHNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (2s)-2-azanyl-4-methyl-pentanoate" "(s)-ethyl 2-amino-4-methylpentanoate" "l-leucine, ethyl ester" "(s)-ethyl-2-amino-4-methylpentanoate" "ethyl (2s)-2-amino-4-methylpentanoate" "leucine,ethyl ester, l- (8ci); (+)-l-leucine ethyl ester; ethyl l-leucinate; ethylleucinate; leucine ethyl ester; o-ethyl-l-leucine" );
gibbsFormation
{
    dHf_298   -502500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-232320.0
    phase     gas;
}
