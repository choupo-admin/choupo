/*--------------------------------*- Choupo -*-----------------------*\
  Component: germacrone  (C15H22O, CAS 6902-91-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        germacrone;
formula     C15H22O;
CAS         6902-91-6;
InChIKey    CAULGCQHVOVVRN-SWZPTJTJSA-N;
MW          218.34;      // g/mol [origin=calculated method=formula-sum]
Tc          907.58;      // K   [origin=predictive method=joback]
Pc          20.493;      // bar [origin=predictive method=joback]
omega       0.5635;      // -   [origin=predictive method=lee-kesler]
Tb          666.72;      // K   [origin=predictive method=joback]
HvapTb      57432.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.78 1.06218 -0.00031028 -6.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH=C; count 2; } { group CH2CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 3; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e,7e)-3,7-dimethyl-10-propan-2-ylidene-cyclodeca-3,7-dien-1-one" "germacron" "(3e,7e)-3,7-dimethyl-10-(propan-2-ylidene)cyclodeca-3,7-dienone" "3,7-cyclodecadien-1-one, 3,7-dimethyl-10-(1-methylethylidene)-, (e,e)-" "ambotz6902-91-6" "(3e,7e)-3,7-dimethyl-10-propan-2-ylidenecyclodeca-3,7-dien-1-one" );
standardThermochemistry
{
    dHf_298   -281750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14160.0
}
