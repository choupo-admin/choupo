/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-angelica lactone  (C5H6O2, CAS 591-12-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaAngelicaLactone;
formula     C5H6O2;
CAS         591-12-8;
InChIKey    QOTQFLOTGBBMEX-UHFFFAOYSA-N;
MW          98.101;      // g/mol [origin=calculated method=formula-sum]
Tc          581.87;      // K   [origin=predictive method=joback]
Pc          43.916;      // bar [origin=predictive method=joback]
omega       0.3903;      // -   [origin=predictive method=lee-kesler]
Tb          387.77;      // K   [origin=predictive method=joback]
HvapTb      35307.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.35 0.48592 -0.00034944 9.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-3h-furan-2-one" "5-methyl-2(3h)-furanone" "alpha-angelicalactone" "2(3h)-furanone, 5-methyl-" "5-methylfuran-2(3h)-one" ".alpha.-angelica lactone" "4-hydroxy-3-pentenoic acid gamma-lactone" "delta(2)-angelica lactone" "4-hydroxypent-3-enoic acid lactone" "gamma-methyl-beta,gamma-crotonolactone" "delta(sup 2)-angelica lactone" "alpha(beta,gamma or delta2)-angelica lactone" );
standardThermochemistry
{
    dHf_298   -324360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     310.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230360.0
}
