/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chlorobicyclo[3.2.1]oct-2-ene  (C8H11Cl, CAS 35242-17-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chlorobicyclo321Oct2Ene;
formula     C8H11Cl;
CAS         35242-17-2;
InChIKey    XLVAWKKCOIWHBT-UHFFFAOYSA-N;
MW          142.626;      // g/mol [origin=calculated method=formula-sum]
Tc          667.51;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.3206;      // -   [origin=predictive method=lee-kesler]
Tb          446.23;      // K   [origin=predictive method=joback]
HvapTb      38911.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.14 0.9377 -0.00069964 2.111e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH=C; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylbicyclo[3.2.1]oct-3-ene" "bicyclo[3.2.1]oct-2-ene, 3-chloro-" "agn-pc-00gqtx" "3-chlorobicyclo[3.2.1]oct-2-ene, mixture of endo and exo" "3-chlorobicyclo[3.2.1]oct-3-ene" "bicyclo[3.2.1]oct-2-ene,3-chloro-" );
gibbsFormation
{
    dHf_298   -44600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     316.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122180.0
    phase     gas;
}
