/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl chloro(diphenyl)acetate  (C16H15ClO2, CAS 52460-86-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylChloroDiphenylAcetate;
formula     C16H15ClO2;
CAS         52460-86-3;
InChIKey    MSBGLMWCKRSNHW-UHFFFAOYSA-N;
MW          274.744;      // g/mol [origin=calculated method=formula-sum]
Tc          958.91;      // K   [origin=predictive method=joback]
Pc          22.568;      // bar [origin=predictive method=joback]
omega       0.6822;      // -   [origin=predictive method=lee-kesler]
Tb          711.46;      // K   [origin=predictive method=joback]
HvapTb      66258.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.639 1.44382 -0.0010066 2.54e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 10; } { group AC; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-chloranyl-2,2-diphenyl-ethanoate" "ethyl 2-chloro-2,2-diphenylacetate" "ethyl 2-chloro-2,2-diphenyl-acetate" "benzeneacetic acid, a-chloro-a-phenyl-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -242280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-10800.0
}
