/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-benzalbutyramide  (C11H13NO, CAS 7236-47-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Benzalbutyramide;
formula     C11H13NO;
CAS         7236-47-7;
InChIKey    KAJZGRFYZKWYDX-UHFFFAOYSA-N;
MW          175.231;      // g/mol [origin=calculated method=formula-sum]
Tc          842.22;      // K   [origin=predictive method=joback]
Pc          32.064;      // bar [origin=predictive method=joback]
omega       0.6853;      // -   [origin=predictive method=lee-kesler]
Tb          608.40;      // K   [origin=predictive method=joback]
HvapTb      59781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.039 1.02372 -0.0007166 1.9636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-4-phenyl-but-3-enamide" "3-butenamide, 3-methyl-4-phenyl-" "agn-pc-02lsrd" );
gibbsFormation
{
    dHf_298   -5200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=163350.0
    phase     gas;
}
