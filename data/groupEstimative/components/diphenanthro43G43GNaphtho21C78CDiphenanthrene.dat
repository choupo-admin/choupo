/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenanthro[4,3-g:4',3'-g']naphtho[2,1-c:7,8-c']diphenanthrene  (C58H32, CAS 57483-71-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diphenanthro43G43GNaphtho21C78CDiphenanthrene;
formula     C58H32;
CAS         57483-71-3;
InChIKey    FYHJTLVERBIHKT-UHFFFAOYSA-N;
MW          728.894;      // g/mol [origin=calculated method=formula-sum]
Tc          2342.95;      // K   [origin=predictive method=joback]
Pc          8.402;      // bar [origin=predictive method=joback]
omega       0.5440;      // -   [origin=predictive method=lee-kesler]
Tb          1859.82;      // K   [origin=predictive method=joback]
HvapTb      176242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-320.91 4.6728 -0.00413548 1.46e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 32; } { group AC; count 26; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 32; } { group dC_ring; count 26; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[14]helicene" "(14)helicene" );
standardThermochemistry
{
    dHf_298   1342350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     819.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1820780.0
}
