/*--------------------------------*- Choupo -*-----------------------*\
  Component: ibufenac  (C12H16O2, CAS 1553-60-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ibufenac;
formula     C12H16O2;
CAS         1553-60-2;
InChIKey    CYWFCPPBTWOZSF-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          868.53;      // K   [origin=predictive method=joback]
Pc          26.111;      // bar [origin=predictive method=joback]
omega       0.8400;      // -   [origin=predictive method=lee-kesler]
Tb          650.89;      // K   [origin=predictive method=joback]
HvapTb      62020.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.708 1.06214 -0.00066896 1.597e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(2-methylpropyl)phenyl]ethanoic acid" "4-isobutylphenylacetic acid" "dytransin" "ibunac" "medirex" "isodilan" "(p-isobutylphenyl)acetic acid" "(4-isobutylphenyl)acetic acid" "ibufenacum" "ibufenaco" "4-(2-methylpropyl)benzeneacetic acid" "ibufenacum [inn-latin]" );
gibbsFormation
{
    dHf_298   -421500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-193410.0
    phase     gas;
}
