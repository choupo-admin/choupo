/*--------------------------------*- Choupo -*-----------------------*\
  Component: s-triazine-1,3,5(2h,4h,6h)triacetonitrile  (C9H12N6, CAS 6865-92-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sTriazine1352h4h6hTriacetonitrile;
formula     C9H12N6;
CAS         6865-92-5;
InChIKey    CTTRIWVSECLRDA-UHFFFAOYSA-N;
MW          204.237;      // g/mol [origin=calculated method=formula-sum]
Tc          977.15;      // K   [origin=predictive method=joback]
Pc          25.000;      // bar [origin=predictive method=joback]
omega       1.1601;      // -   [origin=predictive method=lee-kesler]
Tb          760.49;      // K   [origin=predictive method=joback]
HvapTb      73413.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.547 1.2123 -0.0009862 3.167e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2N; count 3; } { group CH2CN; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 3; } { group N; count 3; } { group CN; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[3,5-bis(cyanomethyl)-1,3,5-triazinan-1-yl]ethanenitrile" "1,3,5-tris(cyanomethyl)-s-hexahydrotriazine" "1,3,5-tris(cyanomethyl)hexahydro-s-triazine" "s-triazine, hexahydro-1,3,5-tris(cyanomethyl)-" "2-[3,5-bis(cyanomethyl)-1,3,5-triazaperhydroinyl]ethanenitrile" "acetonitrile, (methyleneamino)-, trimer" "acetonitrile, 2-(methyleneamino)-, trimer" "2-[3,5-bis(cyanomethyl)-1,3,5-triazinan-1-yl]acetonitrile" );
standardThermochemistry
{
    dHf_298   561280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=825240.0
}
