/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-amino-2,4,6-triiodobenzoic acid  (C7H4I3NO2, CAS 3119-15-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Amino246TriiodobenzoicAcid;
formula     C7H4I3NO2;
CAS         3119-15-1;
InChIKey    QMQFFHSJUJDRPG-UHFFFAOYSA-N;
MW          514.814;      // g/mol [origin=calculated method=formula-sum]
Tc          1223.09;      // K   [origin=predictive method=joback]
Pc          42.220;      // bar [origin=predictive method=joback]
omega       0.9964;      // -   [origin=predictive method=lee-kesler]
Tb          903.82;      // K   [origin=predictive method=joback]
HvapTb      92024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (65.98 0.5816 -0.00048024 1.567e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 4; } { group ACNH2; count 1; } { group COOH; count 1; } { group I; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 1; } { group dC_ring; count 5; } { group I; count 3; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azanyl-2,4,6-tris(iodanyl)benzoic acid" "3-amino-2,4,6-triiodo-benzoicacid" "3-amino-2,4,6-triiodo-benzoic acid" "benzoic acid, 3-amino-2,4,6-triiodo-" "acido 3-amino-2,4,6-triiodobenzoico" "67031-56-5 (mono-hydrochloride salt)" "u348" );
gibbsFormation
{
    dHf_298   -83030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-21150.0
    phase     gas;
}
