/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1-trifluoro-3-methylbutane  (C5H9F3, CAS 406-49-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Trifluoro3Methylbutane;
formula     C5H9F3;
CAS         406-49-5;
InChIKey    CONTVCYXDSFGMN-UHFFFAOYSA-N;
MW          126.121;      // g/mol [origin=calculated method=formula-sum]
Tc          457.75;      // K   [origin=predictive method=joback]
Pc          30.659;      // bar [origin=predictive method=joback]
omega       0.3008;      // -   [origin=predictive method=lee-kesler]
Tb          308.14;      // K   [origin=predictive method=joback]
HvapTb      22589.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.539 0.64594 -0.0004724 1.365e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(fluoranyl)-3-methyl-butane" );
gibbsFormation
{
    dHf_298   -748890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-592810.0
    phase     gas;
}
