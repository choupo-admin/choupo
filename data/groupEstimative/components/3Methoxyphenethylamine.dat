/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxyphenethylamine  (C9H13NO, CAS 2039-67-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxyphenethylamine;
formula     C9H13NO;
CAS         2039-67-0;
InChIKey    WJBMRZAHTUFBGE-UHFFFAOYSA-N;
MW          151.209;      // g/mol [origin=calculated method=formula-sum]
Tc          750.37;      // K   [origin=predictive method=joback]
Pc          33.567;      // bar [origin=predictive method=joback]
omega       0.5930;      // -   [origin=predictive method=lee-kesler]
Tb          532.13;      // K   [origin=predictive method=joback]
HvapTb      51617.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.092 0.71912 -0.00036236 5.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-methoxyphenyl)ethanamine" "2-(3-methoxyphenyl)ethylamine" "m-methoxyphenethylamine" "m-methoxyphenylethylamine" "3-methoxyphenylethylamine" "phenethylamine, m-methoxy-" "3-methoxy-2-phenylethylamine" "3-methoxy-beta-phenethylamine" "benzeneethanamine, 3-methoxy-" "2-(3-methoxyphenyl)ethan-1-amine" "3-(2-aminoethyl)anisole" "(3-methoxybenzyl)methylamine" );
standardThermochemistry
{
    dHf_298   -102460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89130.0
}
