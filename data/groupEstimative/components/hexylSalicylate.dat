/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexyl salicylate  (C13H18O3, CAS 6259-76-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexylSalicylate;
formula     C13H18O3;
CAS         6259-76-3;
InChIKey    DUKPKQFHJQGTGU-UHFFFAOYSA-N;
MW          222.284;      // g/mol [origin=calculated method=formula-sum]
Tc          872.92;      // K   [origin=predictive method=joback]
Pc          25.482;      // bar [origin=predictive method=joback]
omega       0.9315;      // -   [origin=predictive method=lee-kesler]
Tb          662.56;      // K   [origin=predictive method=joback]
HvapTb      67229.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.345 1.25972 -0.00087636 2.45e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexyl 2-oxidanylbenzoate" "hexyl 2-hydroxybenzoate" "n-hexyl salicylate" "benzoic acid, 2-hydroxy-, hexyl ester" "1-hexyl salicylate" "salicylic acid, hexyl ester (6ci,7ci,8ci)" "salicylicacid, hexyl ester (6ci,7ci,8ci);1-hexyl salicylate;n-hexylsalicylate;" );
gibbsFormation
{
    dHf_298   -569710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-294000.0
    phase     gas;
}
