/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylacetoacetamide  (C5H9NO2, CAS 20306-75-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylacetoacetamide;
formula     C5H9NO2;
CAS         20306-75-6;
InChIKey    ATWLCPHWYPSRBQ-UHFFFAOYSA-N;
MW          115.132;      // g/mol [origin=calculated method=formula-sum]
Tc          666.57;      // K   [origin=predictive method=joback]
Pc          41.144;      // bar [origin=predictive method=joback]
omega       0.6758;      // -   [origin=predictive method=lee-kesler]
Tb          471.91;      // K   [origin=predictive method=joback]
HvapTb      46652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.851 0.49904 -0.0002594 4.072e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3CO; count 1; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CdO; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-3-oxidanylidene-butanamide" "n-methyl-3-oxobutyramide" "n-methyl-3-oxobutanamide" "butanamide, n-methyl-3-oxo-" "acetoacet-monomethylamide" "n-monomethylacetoacetamide" "n-acetoacetylmethylamine" "n-methyl acetoacetylamide" "agn-pc-0cj1gg" "butanamide,n-methyl-3-oxo-" "acetoacetamide,n-methyl- (8ci);2-acetyl-n-methylacetamide;n-methyl-3-oxobutanamide;" );
gibbsFormation
{
    dHf_298   -318220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-177230.0
    phase     gas;
}
