/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,8,11,14-tetraoxa-6,9,12-trimethylpentadecan-3-ol  (C14H30O5, CAS 71735-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        581114Tetraoxa6912Trimethylpentadecan3Ol;
formula     C14H30O5;
CAS         71735-67-6;
InChIKey    WLTNLBZUVZXKTC-XUXIUFHCSA-N;
MW          278.389;      // g/mol [origin=calculated method=formula-sum]
Tc          870.05;      // K   [origin=predictive method=joback]
Pc          15.923;      // bar [origin=predictive method=joback]
omega       1.1937;      // -   [origin=predictive method=lee-kesler]
Tb          700.02;      // K   [origin=predictive method=joback]
HvapTb      71525.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (90.725 1.1387 -0.000337 -5.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 3; } { group CH3O; count 1; } { group CH2O; count 2; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 4; } { group OH; count 1; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-1-[(2s)-1-[(2s)-1-[(2s)-1-methoxypropan-2-yl]oxypropan-2-yl]oxypropan-2-yl]oxybutan-2-ol" "5,8,11,14-tetraoxapentadecan-3-ol, 6,9,12-trimethyl-" );
gibbsFormation
{
    dHf_298   -1034520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     759.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-499580.0
    phase     gas;
}
