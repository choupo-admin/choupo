/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-undecyn-4-ol  (C11H20O, CAS 22127-86-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Undecyn4Ol;
formula     C11H20O;
CAS         22127-86-2;
InChIKey    IBEKWLNDNQDLQS-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          702.63;      // K   [origin=predictive method=joback]
Pc          24.362;      // bar [origin=predictive method=joback]
omega       0.9010;      // -   [origin=predictive method=lee-kesler]
Tb          533.14;      // K   [origin=predictive method=joback]
HvapTb      56229.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.277 0.99482 -0.00060413 1.4739e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undec-1-yn-4-ol" );
gibbsFormation
{
    dHf_298   -135980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125550.0
    phase     gas;
}
