/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzaldehyde,3,3'-[1,4-butanediylbis(oxy)]bis-  (C18H18O4, CAS 121799-26-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C18H18O4 (delta C+2H+2O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzaldehyde3314ButanediylbisOxyBis;
formula     C18H18O4;
CAS         121799-26-6;
InChIKey    DPWLMAHEZCLAJY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          298.338;      // g/mol [origin=calculated method=formula-sum]
Tc          891.76;      // K   [origin=predictive method=joback]
Pc          19.579;      // bar [origin=predictive method=joback]
omega       0.7179;      // -   [origin=predictive method=lee-kesler]
Tb          672.44;      // K   [origin=predictive method=joback]
HvapTb      61612.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.686 1.3268 -0.00096772 2.88e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 8; } { group AC; count 4; } { group CHO; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[4-(3-methanoylphenoxy)butoxy]benzaldehyde" "1,4-bis(3-formylphenoxy)butane" "3-[4-(3-formylphenoxy)butoxy]benzaldehyde" "benzaldehyde, 3,3'-[1,4-butanediylbis(oxy)]bis-" "1,4-bis(3-formylphenoxy)butane;1,4-bis(m-formylphenoxy)butane" );
gibbsFormation
{
    dHf_298   -76270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     816.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184160.0
    phase     gas;
}
