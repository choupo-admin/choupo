/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl cinnamate  (C10H10O2, CAS 103-26-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylCinnamate;
formula     C10H10O2;
CAS         103-26-4;
InChIKey    CCRCUPLGCSFEDV-BQYQJAHWSA-N;
MW          162.188;      // g/mol [origin=calculated method=formula-sum]
Tc          737.39;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.5018;      // -   [origin=predictive method=lee-kesler]
Tb          517.46;      // K   [origin=predictive method=joback]
HvapTb      47495.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.88 0.84012 -0.0005406 1.236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (e)-3-phenylprop-2-enoate" "methyl 3-phenylacrylate" "methyl cinnamylate" "cinnamic acid methyl ester" "methyl 3-phenylpropenoate" "cinnamic acid, methyl ester" "methyl (e)-cinnamate" "methyl cinnamate (natural)" "methyl 3-phenyl-2-propenoate" "methyl (2e)-3-phenylacrylate" "cinnamic acid, methyl ester, (e)-" "methyl (2e)-3-phenylprop-2-enoate" );
gibbsFormation
{
    dHf_298   -213260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-84420.0
    phase     gas;
}
