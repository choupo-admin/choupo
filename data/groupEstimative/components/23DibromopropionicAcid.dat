/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dibromopropionic acid  (C3H4Br2O2, CAS 600-05-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DibromopropionicAcid;
formula     C3H4Br2O2;
CAS         600-05-5;
InChIKey    ZMYAKSMZTVWUJB-UHFFFAOYSA-N;
MW          231.871;      // g/mol [origin=calculated method=formula-sum]
Tc          779.27;      // K   [origin=predictive method=joback]
Pc          61.903;      // bar [origin=predictive method=joback]
omega       0.7877;      // -   [origin=predictive method=lee-kesler]
Tb          545.63;      // K   [origin=predictive method=joback]
HvapTb      51918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.461 0.4219 -0.000358 1.202e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group COOH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group Br; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(bromanyl)propanoic acid" "2,3-dibromopropanoic acid" "propanoic acid, 2,3-dibromo-" "propionic acid, 2,3-dibromo-" "alpha,beta-dibromopropionic acid" "propanoic acid,3-dibromo-" "propionic acid,3-dibromo-" "2,3-dibromo-propionic acid" ".alpha.,.beta.-dibromopropionic acid" );
gibbsFormation
{
    dHf_298   -408140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-343330.0
    phase     gas;
}
