/*--------------------------------*- Choupo -*-----------------------*\
  Component: meperidide  (C27H33FN2O2, CAS 2266-22-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        meperidide;
formula     C27H33FN2O2;
CAS         2266-22-0;
InChIKey    QFLXBYDLGCRGPT-UHFFFAOYSA-N;
MW          436.571;      // g/mol [origin=calculated method=formula-sum]
Tc          1288.95;      // K   [origin=predictive method=joback]
Pc          13.840;      // bar [origin=predictive method=joback]
omega       1.1535;      // -   [origin=predictive method=lee-kesler]
Tb          1043.77;      // K   [origin=predictive method=joback]
HvapTb      97833.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-233.217 3.08702 -0.00246672 8.0872e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 1; } { group CH2CO; count 1; } { group CH2N; count 1; } { group ACF; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 8; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 1; } { group CdO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-fluorophenyl)-4-[4-(3-methylphenyl)-4-pyrrolidin-1-ylcarbonyl-piperidin-1-yl]butan-1-one" "methylperidide" "pyrrolidine, 1-(1-(3-(p-fluorobenzoyl)propyl)-4-m-tolylisonipecotoyl)-" "1-((1-(4-(4-fluorophenyl)-4-oxobutyl)-4-(3-methylphenyl)-4-piperidinyl)carbonyl)pyrrolidine" "pyrrolidine, 1-((1-(4-(4-fluorophenyl)-4-oxobutyl)-4-(3-methylphenyl)-4-piperidinyl)carbonyl)-" "1-(4-fluorophenyl)-4-[4-(3-methylphenyl)-4-(pyrrolidine-1-carbonyl)piperidin-1-yl]butan-1-one" );
standardThermochemistry
{
    dHf_298   -274000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1090.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=238350.0
}
