/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanoic acid, 2,2-dimethyl, 1-methylpropyl ester  (C9H18O2, CAS 5487-60-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanoicAcid22Dimethyl1MethylpropylEster;
formula     C9H18O2;
CAS         5487-60-5;
InChIKey    DTXXVVZDBVWESG-UHFFFAOYSA-N;
MW          158.241;      // g/mol [origin=calculated method=formula-sum]
Tc          645.09;      // K   [origin=predictive method=joback]
Pc          23.795;      // bar [origin=predictive method=joback]
omega       0.4655;      // -   [origin=predictive method=lee-kesler]
Tb          460.07;      // K   [origin=predictive method=joback]
HvapTb      41351.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.039 0.9358 -0.0005462 1.102e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butan-2-yl 2,2-dimethylpropanoate" "propanoic acid, 2,2-dimethyl-, 1-methylpropyl ester" );
standardThermochemistry
{
    dHf_298   -560400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-285070.0
}
