/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-azabicyclo(4.2.1)nona-2,4,7-triene  (C8H9N, CAS 6789-38-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Azabicyclo421Nona247Triene;
formula     C8H9N;
CAS         6789-38-4;
InChIKey    PJQAHZVEAXXQES-UHFFFAOYSA-N;
MW          119.167;      // g/mol [origin=calculated method=formula-sum]
Tc          689.26;      // K   [origin=predictive method=joback]
Pc          43.397;      // bar [origin=predictive method=joback]
omega       0.3461;      // -   [origin=predictive method=lee-kesler]
Tb          454.96;      // K   [origin=predictive method=joback]
HvapTb      41378.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.97 0.8554 -0.00061384 1.726e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 3; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 6; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-azabicyclo[4.2.1]nona-2,4,7-triene" );
gibbsFormation
{
    dHf_298   129820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     228.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=279270.0
    phase     gas;
}
