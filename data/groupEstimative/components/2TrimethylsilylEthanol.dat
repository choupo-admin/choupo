/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(trimethylsilyl)ethanol  (C5H14OSi, CAS 2916-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H14OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2TrimethylsilylEthanol;
formula     C5H14OSi;
CAS         2916-68-9;
InChIKey    ZNGINKJHQQQORD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          118.251;      // g/mol [origin=calculated method=formula-sum]
Tc          574.85;      // K   [origin=predictive method=joback]
Pc          33.567;      // bar [origin=predictive method=joback]
omega       0.5919;      // -   [origin=predictive method=lee-kesler]
Tb          407.58;      // K   [origin=predictive method=joback]
HvapTb      43697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.452 0.30666 0.0001362 -1.591e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group OH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-trimethylsilylethanol" "(2-hydroxyethyl)trimethylsilane" "ethanol, 2-(trimethylsilyl)-" "silane, (2-hydroxyethyl)trimethyl-" "2-trimethylsilanyl-ethanol" "2-(trimethylsilyl) ethanol" "2-(trimethylsilyl)ethan-1-ol" "3,3-dimethyl-3-silabutan-1-ol" "3,5-dimethyl-4-isoxazolemethanol" "(3,5-dimethylisoxazol-4-yl)methanol;3,5-dimethylisoxazole-4-methanol;3,5-dimethyl-4-hydroxymethylisoxazole" );
gibbsFormation
{
    dHf_298   -410380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-250360.0
    phase     gas;
}
