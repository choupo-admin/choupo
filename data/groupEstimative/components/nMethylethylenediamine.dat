/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylethylenediamine  (C3H10N2, CAS 109-81-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylethylenediamine;
formula     C3H10N2;
CAS         109-81-9;
InChIKey    KFIGICHILYTCJF-UHFFFAOYSA-N;
MW          74.127;      // g/mol [origin=calculated method=formula-sum]
Tc          579.32;      // K   [origin=predictive method=joback]
Pc          48.494;      // bar [origin=predictive method=joback]
omega       0.4836;      // -   [origin=predictive method=lee-kesler]
Tb          390.94;      // K   [origin=predictive method=joback]
HvapTb      39349.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.442 0.42692 -0.0002314 4.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2NH2; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-methylethane-1,2-diamine" "1,2-ethanediamine, n-methyl-" "ethylenediamine, n-methyl-" "2-(methylamino)ethylamine" "n-methyldiaminoethane" "n-methylethanediamine" "2-aminoethylmethylamine" "n-methylethylidenediamine" "n-methylethane-1,2-diamine" "n-methyl-1,2-ethanediamine" "1,2-ethanediamine, n1-methyl-" "2-methylaminoethylamine" );
standardThermochemistry
{
    dHf_298   -17990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     365.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130220.0
}
