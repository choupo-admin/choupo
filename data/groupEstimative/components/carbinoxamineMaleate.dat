/*--------------------------------*- Choupo -*-----------------------*\
  Component: carbinoxamine maleate  (C20H23ClN2O5, CAS 3505-38-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carbinoxamineMaleate;
formula     C20H23ClN2O5;
CAS         3505-38-2;
InChIKey    GVNWHCVWDRNXAZ-BTJKTKAUSA-N;
MW          406.863;      // g/mol [origin=calculated method=formula-sum]
Tc          1397.99;      // K   [origin=predictive method=joback]
Pc          17.419;      // bar [origin=predictive method=joback]
omega       1.4205;      // -   [origin=predictive method=lee-kesler]
Tb          1137.67;      // K   [origin=predictive method=joback]
HvapTb      114568.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.112 1.7091 -0.00090822 1.32e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } { group C5H4N; count 1; } { group COOH; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group COOH; count 2; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-but-2-enedioic acid;2-[(4-chlorophenyl)-pyridin-2-yl-methoxy]-n,n-dimethyl-ethanamine" "lergefin" "ciberon" "cliston" "p-carbinoxamine maleate" "paracarbinoxamine maleate" "allergefon maleate" "hislosine" "ziriton" "rondec" "carbinoxamine maleate salt" "histine sirup" );
standardThermochemistry
{
    dHf_298   -742400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     987.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-311190.0
}
