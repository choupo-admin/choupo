/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl2-methoxy-1-adamantanecarboxylate  (C13H20O3, CAS 103549-36-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Methoxy1Adamantanecarboxylate;
formula     C13H20O3;
CAS         103549-36-6;
InChIKey    GGHGRMSWVJKWNT-UHFFFAOYSA-N;
MW          224.3;      // g/mol [origin=calculated method=formula-sum]
Tc          807.14;      // K   [origin=predictive method=joback]
Pc          23.025;      // bar [origin=predictive method=joback]
omega       0.6270;      // -   [origin=predictive method=lee-kesler]
Tb          593.07;      // K   [origin=predictive method=joback]
HvapTb      52491.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-151.98 1.80284 -0.0015138 5.412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 4; } { group C; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 4; } { group C_ring; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-methoxyadamantane-1-carboxylate" "2-methoxytricyclo[3.3.1.13,7decane-1-carboxylic acid, methyl ester" "tricyclo[3.3.1.13,7]decane-1-carboxylicacid, 2-methoxy-, methyl ester" "2-methoxytricyclo(3.3.1.13,7decane-1-carboxylic acid, methyl ester" );
standardThermochemistry
{
    dHf_298   -574350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-207550.0
}
