/*--------------------------------*- Choupo -*-----------------------*\
  Component: thf glycol  (C6H12O3, CAS 104-80-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thfGlycol;
formula     C6H12O3;
CAS         104-80-3;
InChIKey    YCZZQSFWHFBKMU-UHFFFAOYSA-N;
MW          132.159;      // g/mol [origin=calculated method=formula-sum]
Tc          737.11;      // K   [origin=predictive method=joback]
Pc          46.151;      // bar [origin=predictive method=joback]
omega       1.2859;      // -   [origin=predictive method=lee-kesler]
Tb          558.80;      // K   [origin=predictive method=joback]
HvapTb      66766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.208 0.744 -0.0004215 8.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group OH; count 2; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group OH; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[5-(hydroxymethyl)oxolan-2-yl]methanol" "2,5-bishydroxymethyl tetrahydrofuran" "tetrahydro-2,5-furandimethanol" "2,5-anhydro-3,4-dideoxyhexitol" "2,5-tetrahydrofurandimethanol" "2,5-dihydroxymethyltetrahydrofuran" "2,5-dihydroxymethyl tetrahydrofuran" "2,5-bis(hydroxymethyl)tetrahydrofuran" "2,5-bis[hydroxymethyl]tetrahydrofuran" "(tetrahydrofuran-2,5-diyl)dimethanol" "[(2r,5s)-5-(hydroxymethyl)oxolan-2-yl]methanol" "agn-pc-00jxue" );
gibbsFormation
{
    dHf_298   -563490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     347.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-331280.0
    phase     gas;
}
