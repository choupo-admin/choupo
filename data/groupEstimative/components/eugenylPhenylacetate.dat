/*--------------------------------*- Choupo -*-----------------------*\
  Component: eugenyl phenylacetate  (C18H18O3, CAS 10402-33-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eugenylPhenylacetate;
formula     C18H18O3;
CAS         10402-33-2;
InChIKey    JEEUACXJJPNYOL-UHFFFAOYSA-N;
MW          282.339;      // g/mol [origin=calculated method=formula-sum]
Tc          978.03;      // K   [origin=predictive method=joback]
Pc          19.169;      // bar [origin=predictive method=joback]
omega       0.8639;      // -   [origin=predictive method=lee-kesler]
Tb          752.08;      // K   [origin=predictive method=joback]
HvapTb      70685.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.768 1.29902 -0.00070102 1.097e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methoxy-4-prop-2-enyl-phenyl) 2-phenylethanoate" "eugenol phenylacetate" "4-allyl-2-methoxyphenyl phenylacetate" "benzeneacetic acid, 2-methoxy-4-(2-propenyl)phenyl ester" "benzeneacetic acid, 2-methoxy-4-(2-propen-1-yl)phenyl ester" "acetic acid, 4-allyl-2-methoxyphenyl ester" "(2-methoxy-4-prop-2-enylphenyl) 2-phenylacetate" "2-methoxy-4-(prop-2-en-1-yl)phenyl phenylacetate" "2-methoxy-4-(prop-2-en-1-yl)phenyl 2-phenylacetate" );
gibbsFormation
{
    dHf_298   -288800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-21290.0
    phase     gas;
}
