/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2,4,6-trichlorophenoxy)ethanol  (C8H7Cl3O2, CAS 6161-87-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2246TrichlorophenoxyEthanol;
formula     C8H7Cl3O2;
CAS         6161-87-1;
InChIKey    LZTZSANFAWWCRW-UHFFFAOYSA-N;
MW          241.492;      // g/mol [origin=calculated method=formula-sum]
Tc          862.50;      // K   [origin=predictive method=joback]
Pc          33.182;      // bar [origin=predictive method=joback]
omega       1.0448;      // -   [origin=predictive method=lee-kesler]
Tb          651.15;      // K   [origin=predictive method=joback]
HvapTb      69908.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.072 0.4976 -0.00022208 1.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCl; count 3; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4,6-tris(chloranyl)phenoxy]ethanol" "2-(2,4,6-trichlorophenoxy)ethan-1-ol" "2-(2,4,6-trichloro-phenoxy)-ethanol" "ethanol,2-(2,4,6-trichlorophenoxy)-" "ethanol, 2-(2,4,6-trichlorophenoxy)-" "ethanol, 2-(2,4,6-trichlorophenoxy)-," );
standardThermochemistry
{
    dHf_298   -338000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-177610.0
}
