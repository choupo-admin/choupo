/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholan-24-oic acid, 3,7,12-trioxo-, (5.beta.)-  (C24H34O5, CAS 81-23-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholan24OicAcid3712Trioxo5Beta;
formula     C24H34O5;
CAS         81-23-2;
InChIKey    OHXPGWPVLFPUSM-UHFFFAOYSA-N;
MW          402.531;      // g/mol [origin=calculated method=formula-sum]
Tc          1397.51;      // K   [origin=predictive method=joback]
Pc          13.881;      // bar [origin=predictive method=joback]
omega       1.1599;      // -   [origin=predictive method=lee-kesler]
Tb          1132.03;      // K   [origin=predictive method=joback]
HvapTb      95818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-215.458 2.89556 -0.0021734 7.22e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 6; } { group C; count 2; } { group CH2CO; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 5; } { group C_ring; count 2; } { group CdO_ring; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[10,13-dimethyl-3,7,12-tris(oxidanylidene)-1,2,4,5,6,8,9,11,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-17-yl]pentanoic acid" "4-(10,13-dimethyl-3,7,12-trioxoperhydrocyclopenta[a]phenanthren-17-yl)pentanoic acid" "agn-pc-00hpql" "3,7,12-trioxocholan-24-oic acid" "(5beta,14beta,17alpha)-3,7,12-trioxocholan-24-oic acid" "(4r)-4-[(5r,8s,9r,10s,13r,14s,17r)-10,13-dimethyl-3,7,12-trioxo-1,2,4,5,6,8,9,11,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-17-yl]pentanoic acid" "4-(10,13-dimethyl-3,7,12-trioxo-1,2,4,5,6,8,9,11,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-17-yl)pentanoic acid" );
gibbsFormation
{
    dHf_298   -1077480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-414530.0
    phase     gas;
}
