/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,10-dihydrophenanthrene  (C14H12, CAS 776-35-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        910Dihydrophenanthrene;
formula     C14H12;
CAS         776-35-2;
InChIKey    XXPBFNVKTVJZKF-UHFFFAOYSA-N;
MW          180.25;      // g/mol [origin=calculated method=formula-sum]
Tc          841.70;      // K   [origin=predictive method=joback]
Pc          31.140;      // bar [origin=predictive method=joback]
omega       0.4982;      // -   [origin=predictive method=lee-kesler]
Tb          590.38;      // K   [origin=predictive method=joback]
HvapTb      52684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.11 1.244 -0.00098812 3.14e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenanthrene, 9,10-dihydro-" "dihydrophenanthrene" "9,10-dihydro-phenanthrene" "phenanthrene, 9,10-dihydro- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   217130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=353120.0
}
