/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolpropane dimethacrylate  (C14H22O5, CAS 19727-16-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolpropaneDimethacrylate;
formula     C14H22O5;
CAS         19727-16-3;
InChIKey    GCNKJQRMNYNDBI-UHFFFAOYSA-N;
MW          270.325;      // g/mol [origin=calculated method=formula-sum]
Tc          901.69;      // K   [origin=predictive method=joback]
Pc          18.154;      // bar [origin=predictive method=joback]
omega       1.1837;      // -   [origin=predictive method=lee-kesler]
Tb          718.43;      // K   [origin=predictive method=joback]
HvapTb      75775.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.434 1.34386 -0.0008012 1.613e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group CH2=C; count 2; } { group OH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group dCH2; count 2; } { group dC; count 2; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(hydroxymethyl)-2-(2-methylprop-2-enoyloxymethyl)butyl] 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 1,1'-(2-ethyl-2-(hydroxymethyl)-1,3-propanediyl) ester" "2-propenoic acid, 2-methyl-, 1,1'-[2-ethyl-2-(hydroxymethyl)-1,3-propanediyl] ester" "2-ethyl-2-(hydroxymethyl)-1,3-propanediyl bismethacrylate" "2-propenoic acid, 2-methyl-, 2-ethyl-2-(hydroxymethyl)-1,3-propanediyl ester" );
gibbsFormation
{
    dHf_298   -896550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     798.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-529140.0
    phase     gas;
}
