/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethyl 4-chloropentanoate  (C6H10Cl2O2, CAS 80418-52-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloromethyl4Chloropentanoate;
formula     C6H10Cl2O2;
CAS         80418-52-6;
InChIKey    BTDLLBKQZJSWTP-UHFFFAOYSA-N;
MW          185.044;      // g/mol [origin=calculated method=formula-sum]
Tc          660.92;      // K   [origin=predictive method=joback]
Pc          29.061;      // bar [origin=predictive method=joback]
omega       0.5368;      // -   [origin=predictive method=lee-kesler]
Tb          469.52;      // K   [origin=predictive method=joback]
HvapTb      44739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.943 0.53852 -0.000252 2.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2COO; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl 4-chloranylpentanoate" "4-chloropentanoic acid, chloromethyl ester" "pentanoic acid, 4-chloro-, chloromethyl ester" );
standardThermochemistry
{
    dHf_298   -521210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-337030.0
}
