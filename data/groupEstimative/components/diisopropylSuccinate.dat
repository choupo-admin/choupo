/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisopropyl succinate  (C10H18O4, CAS 924-88-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisopropylSuccinate;
formula     C10H18O4;
CAS         924-88-9;
InChIKey    YPLYFEUBZLLLIY-UHFFFAOYSA-N;
MW          202.25;      // g/mol [origin=calculated method=formula-sum]
Tc          725.70;      // K   [origin=predictive method=joback]
Pc          21.593;      // bar [origin=predictive method=joback]
omega       0.7310;      // -   [origin=predictive method=lee-kesler]
Tb          543.96;      // K   [origin=predictive method=joback]
HvapTb      51892.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.252 0.85608 -0.0003374 -7.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipropan-2-yl butanedioate" "succinic acid diisopropyl ester" "butanedioic acid, bis(1-methylethyl) ester" "butanedioic acid, 1,4-bis(1-methylethyl) ester" "yplyfeubzllliy-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -894850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     629.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-592300.0
}
