/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl benzyl ether  (C10H12O, CAS 14593-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylBenzylEther;
formula     C10H12O;
CAS         14593-43-2;
InChIKey    HUGHWHMUUQNACD-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          681.86;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       0.4400;      // -   [origin=predictive method=lee-kesler]
Tb          474.18;      // K   [origin=predictive method=joback]
HvapTb      41870.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.598 0.7917 -0.0004633 9.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enoxymethylbenzene" "benzene, [(2-propenyloxy)methyl]-" "benzene, ((2-propenyloxy)methyl)-" "ether, allyl benzyl" "allyloxy-methyl-benzene" "alpha-(allyloxy)toluene" "1-(allyloxymethyl)benzene" "benzene,[(2-propen-1-yloxy)methyl]-" "benzene,[(2-propenyloxy)methyl]- (9ci);ether, allyl benzyl (6ci,7ci,8ci);((allyloxy)methyl)benzene;3-(benzyloxy)-1-propene;3-(benzyloxy)propene;allylbenzyl ether;benzyl allyl ether;[[(2-propenyl)oxy]methyl]benzene;" );
standardThermochemistry
{
    dHf_298   -19990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128570.0
}
