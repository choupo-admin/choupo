/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethyl-3-methylhexanoic acid  (C9H18O2, CAS 50902-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethyl3MethylhexanoicAcid;
formula     C9H18O2;
CAS         50902-82-4;
InChIKey    APIWHOUUMCIHFT-UHFFFAOYSA-N;
MW          158.241;      // g/mol [origin=calculated method=formula-sum]
Tc          741.19;      // K   [origin=predictive method=joback]
Pc          25.663;      // bar [origin=predictive method=joback]
omega       0.7255;      // -   [origin=predictive method=lee-kesler]
Tb          547.80;      // K   [origin=predictive method=joback]
HvapTb      51496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.166 1.03546 -0.0007102 1.958e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-3-methyl-hexanoic acid" );
standardThermochemistry
{
    dHf_298   -588110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-316170.0
}
