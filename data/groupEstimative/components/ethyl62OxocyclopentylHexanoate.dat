/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 6-(2-oxocyclopentyl)hexanoate  (C13H22O3, CAS 63135-03-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl62OxocyclopentylHexanoate;
formula     C13H22O3;
CAS         63135-03-5;
InChIKey    LJZYHOVSZOHASC-UHFFFAOYSA-N;
MW          226.316;      // g/mol [origin=calculated method=formula-sum]
Tc          838.88;      // K   [origin=predictive method=joback]
Pc          19.824;      // bar [origin=predictive method=joback]
omega       0.7971;      // -   [origin=predictive method=lee-kesler]
Tb          638.36;      // K   [origin=predictive method=joback]
HvapTb      56443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.574 1.14742 -0.0004722 1.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 6-(2-oxidanylidenecyclopentyl)hexanoate" "cyclopentanehexanoicacid, 2-oxo-, ethyl ester" "ethyl 6-(2-oxocyclopentyl)hexanoate;ethyl 6-(2-oxocyclopentyl)hexanoate 96%" );
standardThermochemistry
{
    dHf_298   -706150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-337830.0
}
