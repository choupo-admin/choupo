/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,7-diphenylnaphthalene  (C22H16, CAS 970-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17Diphenylnaphthalene;
formula     C22H16;
CAS         970-06-9;
InChIKey    GQHLUGQTYDTQDG-UHFFFAOYSA-N;
MW          280.37;      // g/mol [origin=calculated method=formula-sum]
Tc          1087.93;      // K   [origin=predictive method=joback]
Pc          22.208;      // bar [origin=predictive method=joback]
omega       0.7151;      // -   [origin=predictive method=lee-kesler]
Tb          811.94;      // K   [origin=predictive method=joback]
HvapTb      74358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.67 1.7344 -0.00126924 3.584e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 16; } { group AC; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 16; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene, 1,7-diphenyl-" );
gibbsFormation
{
    dHf_298   380310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=558980.0
    phase     gas;
}
