/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyltetrahydrofuran-3-one  (C5H8O2, CAS 3188-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyltetrahydrofuran3One;
formula     C5H8O2;
CAS         3188-00-9;
InChIKey    FCWYQRVIQDNGBI-UHFFFAOYSA-N;
MW          100.117;      // g/mol [origin=calculated method=formula-sum]
Tc          644.06;      // K   [origin=predictive method=joback]
Pc          44.922;      // bar [origin=predictive method=joback]
omega       0.3478;      // -   [origin=predictive method=lee-kesler]
Tb          424.05;      // K   [origin=predictive method=joback]
HvapTb      35738.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.39 0.43922 -0.0001177 -3.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2CO; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyloxolan-3-one" "2-methyl tetrahydro-3-furanone" "3(2h)-furanone, dihydro-2-methyl-" "dihydro-2-methyl-3(2h)-furanone" "dihydro-2-methyl-3-furanone" "2-methyl-3-oxotetrahydrofuran" "tetrahydro-2-methylfuran-3-one" "2-methyl-2h-furan-3-one" "2-methyltetrahydro-3-furanone" "2-methyl-3-ketotetrahydrofuran" "2-methyl-4,5-dihydro-3(2h)-furanone" "coffee furanone" );
standardThermochemistry
{
    dHf_298   -355750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     170.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180940.0
}
