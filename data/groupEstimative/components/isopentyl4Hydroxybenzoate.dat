/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopentyl 4-hydroxybenzoate  (C12H16O3, CAS 6521-30-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopentyl4Hydroxybenzoate;
formula     C12H16O3;
CAS         6521-30-8;
InChIKey    KSHVDKDQYBNSAN-UHFFFAOYSA-N;
MW          208.257;      // g/mol [origin=calculated method=formula-sum]
Tc          857.20;      // K   [origin=predictive method=joback]
Pc          28.384;      // bar [origin=predictive method=joback]
omega       0.8490;      // -   [origin=predictive method=lee-kesler]
Tb          639.24;      // K   [origin=predictive method=joback]
HvapTb      64615.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.118 1.17064 -0.00082516 2.326e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutyl 4-oxidanylbenzoate" "isoamyl 4-hydroxybenzoate" "3-methylbutyl 4-hydroxybenzoate" "benzoic acid, 4-hydroxy-, 3-methylbutyl ester" "isoamylparaben" "p-hydroxybenzoic acid isoamyl ester" "isoamyl p-hydroxybenzoate" "iso-amyl-4-hydroxybenzoate" "ambap6521-30-8" "4-hydroxybenzoic acid isoamyl ester" "benzoicacid, 4-hydroxy-, 3-methylbutyl ester, zinc salt (9ci)" "benzoic acid,4-hydroxy-, 3-methylbutyl ester, zinc salt (2:1)" );
standardThermochemistry
{
    dHf_298   -554350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-304860.0
}
