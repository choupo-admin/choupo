/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-ethenylphenyl)acetonitrile  (C10H9N, CAS 110013-89-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23EthenylphenylAcetonitrile;
formula     C10H9N;
CAS         110013-89-3;
InChIKey    VBRWJLQEFUANAQ-UHFFFAOYSA-N;
MW          143.189;      // g/mol [origin=calculated method=formula-sum]
Tc          788.23;      // K   [origin=predictive method=joback]
Pc          29.377;      // bar [origin=predictive method=joback]
omega       0.5304;      // -   [origin=predictive method=lee-kesler]
Tb          558.82;      // K   [origin=predictive method=joback]
HvapTb      50600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.799 0.7302 -0.00047626 1.195e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-ethenylphenyl)ethanenitrile" "(3-vinylphenyl)acetonitrile" "benzeneacetonitrile,3(or 4)-ethenyl- (9ci)" );
standardThermochemistry
{
    dHf_298   265640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=357120.0
}
