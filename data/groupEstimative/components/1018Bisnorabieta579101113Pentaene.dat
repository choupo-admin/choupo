/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10,18-bisnorabieta-5,7,9(10),11,13-pentaene  (C18H22, CAS 6566-19-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1018Bisnorabieta579101113Pentaene;
formula     C18H22;
CAS         6566-19-4;
InChIKey    PEGDXOHRNDHEEB-UHFFFAOYSA-N;
MW          238.374;      // g/mol [origin=calculated method=formula-sum]
Tc          917.00;      // K   [origin=predictive method=joback]
Pc          19.718;      // bar [origin=predictive method=joback]
omega       0.6293;      // -   [origin=predictive method=lee-kesler]
Tb          682.61;      // K   [origin=predictive method=joback]
HvapTb      61261.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.97 1.59996 -0.0010992 3.038e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-7-propan-2-yl-1,2,3,4-tetrahydrophenanthrene" "7-isopropyl-1-methyl-1,2,3,4-tetrahydrophenanthrene" "phenanthrene, 1,2,3,4-tetrahydro-1-methyl-7-(1-methylethyl)-" "1,2,3,4-tetrahydroretene" );
gibbsFormation
{
    dHf_298   39700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     543.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=337060.0
    phase     gas;
}
