/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-acetyl-4-oxopentanoate  (C9H14O4, CAS 18835-02-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Acetyl4Oxopentanoate;
formula     C9H14O4;
CAS         18835-02-4;
InChIKey    NKGFIBABDQHCHZ-UHFFFAOYSA-N;
MW          186.207;      // g/mol [origin=calculated method=formula-sum]
Tc          763.20;      // K   [origin=predictive method=joback]
Pc          26.488;      // bar [origin=predictive method=joback]
omega       0.8357;      // -   [origin=predictive method=lee-kesler]
Tb          571.04;      // K   [origin=predictive method=joback]
HvapTb      56139.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.152 0.75396 -0.000337 2.022e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH3CO; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CdO; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-ethanoyl-4-oxidanylidene-pentanoate" "pentanoic acid, 3-acetyl-4-oxo-, ethyl ester" "ethyl 3-acetyllevulinate" "ethyl 3-acetyl-4-oxo-pentanoate" "3-acetyl-4-oxo-pentanoic acid ethyl ester" "pentanoic acid,3-acetyl-4-oxo-, ethyl ester" "levulinic acid,3-acetyl-, ethyl ester (6ci,8ci); 3-acetyl-4-oxopentanoic acid ethyl ester;ethyl 3-acetyl-4-oxopentanoate; ethyl 3-acetyllevulinate; ethyl b',b-diacetylpropionate" );
gibbsFormation
{
    dHf_298   -776810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-545750.0
    phase     gas;
}
