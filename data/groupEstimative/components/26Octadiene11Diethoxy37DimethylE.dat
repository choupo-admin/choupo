/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-octadiene, 1,1-diethoxy-3,7-dimethyl-, (e)-  (C14H26O2, CAS 7492-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Octadiene11Diethoxy37DimethylE;
formula     C14H26O2;
CAS         7492-66-2;
InChIKey    NTXGFKWLJFHGGJ-UHFFFAOYSA-N;
MW          226.36;      // g/mol [origin=calculated method=formula-sum]
Tc          752.62;      // K   [origin=predictive method=joback]
Pc          16.338;      // bar [origin=predictive method=joback]
omega       0.6719;      // -   [origin=predictive method=lee-kesler]
Tb          572.40;      // K   [origin=predictive method=joback]
HvapTb      51266.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.734 1.2532 -0.0006912 1.437e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 1; } { group dCH; count 2; } { group dC; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diethoxy-3,7-dimethyl-octa-2,6-diene" "1,1-diethoxy-3,7-dimethylocta-2,6-diene" "2,6-octadiene,1,1-diethoxy-3,7-dimethyl-" "2,6-octadienal,3,7-dimethyl-, diethyl acetal (8ci); citral diethyl acetal (6ci);1,1-diethoxy-3,7-dimethylocta-2,6-diene" );
gibbsFormation
{
    dHf_298   -387150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     692.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2100.0
    phase     gas;
}
