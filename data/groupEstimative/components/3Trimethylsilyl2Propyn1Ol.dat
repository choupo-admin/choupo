/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-trimethylsilyl-2-propyn-1-ol  (C6H12OSi, CAS 5272-36-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H12OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Trimethylsilyl2Propyn1Ol;
formula     C6H12OSi;
CAS         5272-36-6;
InChIKey    ZVGCJDPEKKEYES-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          128.246;      // g/mol [origin=calculated method=formula-sum]
Tc          628.68;      // K   [origin=predictive method=joback]
Pc          36.202;      // bar [origin=predictive method=joback]
omega       0.5454;      // -   [origin=predictive method=lee-kesler]
Tb          439.46;      // K   [origin=predictive method=joback]
HvapTb      48075.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.101 0.25186 0.00017394 -1.6822e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group OH; count 1; } { group C_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-trimethylsilylprop-2-yn-1-ol" "3-(trimethylsilyl)propargyl alcohol" "3-(trimethylsilyl)-2-propyn-1-ol" "2-propyn-1-ol, 3-(trimethylsilyl)-" "1-trimethylsilylpropargyl alcohol" "3-(trimethylsilyl)prop-2-yn-1-ol" );
gibbsFormation
{
    dHf_298   -158720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-39140.0
    phase     gas;
}
