/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propynyl benzeneacetate  (C11H10O2, CAS 72928-39-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropynylBenzeneacetate;
formula     C11H10O2;
CAS         72928-39-3;
InChIKey    PGGKKLLJQLDTQC-UHFFFAOYSA-N;
MW          174.199;      // g/mol [origin=calculated method=formula-sum]
Tc          748.11;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.5152;      // -   [origin=predictive method=lee-kesler]
Tb          526.30;      // K   [origin=predictive method=joback]
HvapTb      49621.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.828 0.8212 -0.00050713 1.0649e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-ynyl 2-phenylethanoate" "benzeneacetic acid, 2-propynyl ester" "benzeneacetic acid, 2-propyn-1-yl ester" "prop-2-ynyl 2-phenylacetate" );
gibbsFormation
{
    dHf_298   -59220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66850.0
    phase     gas;
}
