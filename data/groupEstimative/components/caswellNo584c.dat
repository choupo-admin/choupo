/*--------------------------------*- Choupo -*-----------------------*\
  Component: caswell no. 584c  (C21H36O, CAS 53905-38-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        caswellNo584c;
formula     C21H36O;
CAS         53905-38-7;
InChIKey    LTNBHNLTEGZRFB-UHFFFAOYSA-N;
MW          304.518;      // g/mol [origin=calculated method=formula-sum]
Tc          925.30;      // K   [origin=predictive method=joback]
Pc          11.891;      // bar [origin=predictive method=joback]
omega       0.7568;      // -   [origin=predictive method=lee-kesler]
Tb          730.05;      // K   [origin=predictive method=joback]
HvapTb      65616.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.144 1.93492 -0.00114996 2.554e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(8-methoxy-4,8-dimethyl-nonyl)-4-propan-2-yl-benzene" "1-(8-methoxy-4,8-dimethylnonyl)-4-(1-methylethyl)benzene" "benzene, 1-(8-methoxy-4,8-dimethylnonyl)-4-(1-methylethyl)-" "1-(8-methoxy-4,8-dimethylnonyl)-4-propan-2-ylbenzene" );
standardThermochemistry
{
    dHf_298   -403240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     814.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=121680.0
}
